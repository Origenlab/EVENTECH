{
  "name": "astro-pro-template",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "npm run validate:mdx && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint src/**/*.{astro,ts,tsx}",
    "format": "prettier --write src/**/*.{astro,ts,tsx,css,md,mdx}",
    "lighthouse": "npx lighthouse http://localhost:4321 --output=html --output-path=./lighthouse-report.html",
    "validate:mdx": "node scripts/validate-mdx.mjs",
    "install:hooks": "bash scripts/install-hooks.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^6.0.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "astro": "^6.1.1"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.0.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.7.0"
  }
}
