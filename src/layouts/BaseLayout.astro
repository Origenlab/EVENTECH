---
/**
 * ─── BaseLayout ───
 * The root layout. Every page inherits from this.
 * Handles: <html>, <head>, global styles, skip link, structured data.
 */
import SEOHead from "@components/SEOHead.astro";
import JsonLd from "@components/JsonLd.astro";
import { SITE, type SEOProps } from "@data/site";
import { organizationJsonLd, websiteJsonLd, localBusinessJsonLd } from "@utils/seo";
import "@styles/global.css";

type Props = SEOProps & {
  jsonLd?: Record<string, unknown>[];
};

const { jsonLd = [], ...seoProps } = Astro.props;

// Grafo base presente en TODAS las páginas: Organization + WebSite + LocalBusiness.
// El nodo LocalBusiness (#localbusiness) resuelve las referencias `provider @id`
// que emiten las páginas de servicio. Las páginas que necesiten un LocalBusiness
// específico (zonas) deben usar un @id propio para no duplicar el global.
const hasLocalBusiness = jsonLd.some(
  (n) => (n as { "@id"?: string })["@id"] === `${SITE.url}/#localbusiness`
);
const allJsonLd = [
  organizationJsonLd(),
  websiteJsonLd(),
  ...(hasLocalBusiness ? [] : [localBusinessJsonLd()]),
  ...jsonLd,
];
---

<!doctype html>
<html lang={SITE.locale} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/icon-192.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1a1a2e" />

    <!-- Fuente display (Cormorant) — rediseño premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&display=swap"
    />

    <!-- SEO -->
    <SEOHead {...seoProps} />

    <!-- JSON-LD Structured Data -->
    {allJsonLd.map((data) => <JsonLd data={data} />)}

    <!-- Preload critical fonts (add paths when using custom fonts) -->
    <!-- <link rel="preload" href="/fonts/my-font.woff2" as="font" type="font/woff2" crossorigin /> -->
  <!-- ExactDN CDN -->
  <script is:inline>
    (function(){
      var cdn = "https://ehzpd66uywy.exactdn.com";
      if (window.location.hostname === "localhost") return;
      document.addEventListener("DOMContentLoaded", function(){
        var imgs = document.querySelectorAll("img[src^=\"/images/\"]");
        for (var i = 0; i < imgs.length; i++) {
          imgs[i].src = cdn + imgs[i].getAttribute("src");
        }
      });
    })();
  </script>
  </head>

  <body>
    <!-- Accessibility: Skip to Content -->
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <slot />
  </body>
</html>
