---
/**
 * ─── BlogLayout ───
 * Layout profesional para artículos del blog.
 * Incluye: HeroPage, Breadcrumbs, two-column layout con sidebar dinámico.
 */
import PageLayout from "./PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import RelatedContent from "@components/RelatedContent.astro";
import { readingTime } from "@utils/helpers";
import { articleJsonLd, breadcrumbJsonLd, canonicalURL } from "@utils/seo";
import {
  findRelatedServices,
  findRelatedEventTypes,
  findRelatedVenueTypes,
  POPULAR_VENUES,
  CDMX_ZONES
} from "@utils/interlinking";
import { getCollection } from "astro:content";
import { SITE } from "@data/site";
import "@styles/blog.css";
import "@styles/blog-components.css";

type Props = {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  image?: string;
  imageAlt?: string;
  author?: string;
  body: string;
  slug: string;
  category?: string;
  tags?: string[];
  relatedPosts?: string[];
  relatedServices?: string[];
  keywords?: string[];
};

const {
  title,
  description,
  date,
  updatedDate,
  image,
  imageAlt,
  author = "Equipo EVENTECH",
  body,
  slug,
  category,
  tags,
  relatedPosts,
  relatedServices,
  keywords,
} = Astro.props;

const minutes = readingTime(body);

// Format dates
const formattedDate = date.toLocaleDateString("es-MX", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("es-MX", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Fetch related posts
let relatedPostsData: Awaited<ReturnType<typeof getCollection<"blog">>> = [];
if (relatedPosts && relatedPosts.length > 0) {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);
  relatedPostsData = allPosts.filter(p => relatedPosts.includes(p.slug)).slice(0, 4);
}

// Auto-detect related content for interlinking (SEO)
const autoRelatedServices = findRelatedServices(body, title, tags || [], 4);
const autoRelatedEvents = findRelatedEventTypes(body, title, category, 3);
const autoRelatedVenueTypes = findRelatedVenueTypes(body, title, 3);

// Get recommended venues based on content
const recommendedVenues = POPULAR_VENUES.slice(0, 4);

// Extract headings for TOC (## and ### level headings)
const headingMatches = body.matchAll(/^(#{2,3})\s+(.+)$/gm);
const headings = Array.from(headingMatches).map(match => {
  const level = match[1].length; // 2 or 3
  const text = match[2].trim()
    .replace(/\*\*/g, '') // Remove bold markers
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1'); // Remove links, keep text
  const headingSlug = text
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
  return { text, slug: headingSlug, level };
});

// Service labels and URLs
const SERVICE_DATA: Record<string, { label: string; url: string; icon: string }> = {
  "mobiliario": { label: "Mobiliario", url: "/servicios/mobiliario/", icon: "🪑" },
  "audiovisual": { label: "Audiovisual", url: "/servicios/audiovisual/", icon: "🔊" },
  "carpas": { label: "Carpas", url: "/servicios/carpas/", icon: "⛺" },
  "iluminacion": { label: "Iluminación", url: "/servicios/iluminacion/", icon: "💡" },
  "pistas-baile": { label: "Pistas de Baile", url: "/servicios/pistas-baile/", icon: "💃" },
  "inflables": { label: "Inflables", url: "/servicios/inflables/", icon: "🎈" },
  "catering": { label: "Equipo Catering", url: "/servicios/catering/", icon: "🍽️" },
  "accesorios": { label: "Accesorios", url: "/servicios/accesorios/", icon: "🔧" },
};

// Get dynamic services (from article) or default set
const displayServices = relatedServices && relatedServices.length > 0
  ? relatedServices.filter(s => SERVICE_DATA[s])
  : ["mobiliario", "audiovisual", "iluminacion", "carpas"];

const CATEGORY_LABELS: Record<string, string> = {
  "bodas": "Bodas",
  "xv-anos": "XV Años",
  "corporativos": "Corporativos",
  "tendencias": "Tendencias",
  "guias": "Guías",
  "tips": "Tips",
  "casos-exito": "Casos de Éxito",
};

const CATEGORY_ICONS: Record<string, string> = {
  "bodas": "💍",
  "xv-anos": "👑",
  "corporativos": "🏢",
  "tendencias": "📈",
  "guias": "📖",
  "tips": "💡",
  "casos-exito": "🏆",
};

const categoryLabel = category ? (CATEGORY_LABELS[category] || category) : "Blog";
const categoryIcon = category ? (CATEGORY_ICONS[category] || "📄") : "📄";

// Breadcrumbs
const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Blog", href: "/blog/" },
  { label: title },
];

// JSON-LD
const jsonLd = [
  articleJsonLd({
    title,
    description,
    url: canonicalURL(`/blog/${slug}/`),
    image,
    datePublished: date.toISOString(),
    dateModified: updatedDate?.toISOString(),
    author,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Blog", url: "/blog/" },
    { name: title, url: `/blog/${slug}/` },
  ]),
];

// Generar excerpt para las cards del hero
const paragraphs = body.split('\n\n').filter(p => p.trim() && !p.startsWith('#') && !p.startsWith('-') && !p.startsWith('*') && !p.startsWith('|'));
const firstParagraph = paragraphs[0]?.replace(/\*\*/g, '').replace(/\[([^\]]+)\]\([^)]+\)/g, '$1').substring(0, 280) || description;
---

<PageLayout
  title={title}
  description={description}
  image={image}
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge={`${categoryIcon} ${categoryLabel} · ${minutes} min de lectura`}
    title={title}
    subtitle={description}
    primaryCTA={{ label: "Cotizar equipo", href: "/cotizar/" }}
    secondaryCTA={{ label: "Ver servicios", href: "/servicios/" }}
    cards={[
      {
        title: "Sobre este artículo",
        content: `<strong>${firstParagraph}...</strong> Continúa leyendo para descubrir toda la información que necesitas.`,
      },
      {
        title: "¿Necesitas ayuda?",
        content: `En <strong>EVENTECH</strong> somos expertos en renta de equipo para eventos en CDMX. <strong>Contáctanos por WhatsApp</strong> para asesoría personalizada gratuita.`,
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Te interesa lo que estás leyendo?"
    subheadline="Cotiza el equipo que necesitas para tu evento sin compromiso"
    primaryCTA={{ label: "Cotizar ahora", href: "/cotizar/" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CONTENT
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <!-- Two-column layout: Content + Sidebar -->
      <div class="blog-post-layout">
        <!-- Main Content -->
        <article class="blog-post__main">
          <!-- Article Header -->
          <header class="blog-article__header">
            <div class="blog-article__meta-bar">
              {category && (
                <a href={`/blog/?cat=${category}`} class="blog-post__category-link">
                  <span class="blog-post__category-icon">{categoryIcon}</span>
                  {categoryLabel}
                </a>
              )}
            </div>
            <div class="blog-article__meta">
              <span class="blog-article__reading">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {minutes} min de lectura
              </span>
              {author && (
                <span class="blog-article__author">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                  Por {author}
                </span>
              )}
            </div>
            {tags && tags.length > 0 && (
              <div class="blog-article__tags">
                {tags.map(tag => (
                  <span class="blog-article__tag">#{tag.replace(/\s+/g, '')}</span>
                ))}
              </div>
            )}
          </header>

          <!-- Hero Image -->
          {image ? (
            <figure class="blog-article__figure">
              <img
                src={image}
                alt={imageAlt || title}
                class="blog-article__image"
                width="800"
                height="450"
                loading="eager"
              />
            </figure>
          ) : (
            <div class="blog-article__placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          )}

          <!-- Article Content -->
          <div class="prose">
            <slot />
          </div>

          <!-- Article Footer -->
          <footer class="blog-article__footer">
            <div class="blog-article__share">
              <span class="blog-article__share-label">Comparte este artículo:</span>
              <div class="blog-article__share-buttons">
                <a href={`https://wa.me/?text=${encodeURIComponent(title + ' - ' + canonicalURL(`/blog/${slug}/`))}`} class="blog-article__share-btn blog-article__share-btn--whatsapp" target="_blank" rel="noopener" aria-label="Compartir en WhatsApp">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>
                <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalURL(`/blog/${slug}/`))}`} class="blog-article__share-btn blog-article__share-btn--facebook" target="_blank" rel="noopener" aria-label="Compartir en Facebook">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(canonicalURL(`/blog/${slug}/`))}`} class="blog-article__share-btn blog-article__share-btn--twitter" target="_blank" rel="noopener" aria-label="Compartir en X">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalURL(`/blog/${slug}/`))}`} class="blog-article__share-btn blog-article__share-btn--linkedin" target="_blank" rel="noopener" aria-label="Compartir en LinkedIn">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                </a>
              </div>
            </div>
          </footer>

          <!-- Related Content for SEO Interlinking -->
          <RelatedContent
            title="Explora Más Contenido"
            services={autoRelatedServices}
            venues={recommendedVenues}
            events={autoRelatedEvents}
            variant="grid"
          />
        </article>

        <!-- Sidebar -->
        <aside class="blog-sidebar">
          <!-- Quick Navigation -->
          <div class="blog-sidebar-card blog-sidebar-card--highlight">
            <h3 class="blog-sidebar-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
              Navegación Rápida
            </h3>
            <div class="quick-actions">
              <a href="/cotizar/" class="quick-action quick-action--primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>
                Cotizar Equipo
              </a>
              <a href={`https://wa.me/${SITE.contact.whatsapp}`} class="quick-action quick-action--whatsapp">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <!-- Table of Contents -->
          {headings.length > 2 && (
            <div class="blog-sidebar-card">
              <h3 class="blog-sidebar-card__title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                En este artículo
              </h3>
              <nav aria-label="Tabla de contenidos">
                <ul class="toc-list">
                  {headings.slice(0, 10).map(h => (
                    <li class:list={["toc-list__item", { "toc-list__item--sub": h.level === 3 }]}>
                      <a href={`#${h.slug}`} class="toc-list__link">{h.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            </div>
          )}

          <!-- Services Links (Dynamic) -->
          <div class="blog-sidebar-card">
            <h3 class="blog-sidebar-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Servicios Relacionados
            </h3>
            <div class="blog-sidebar__services">
              {displayServices.map(serviceKey => {
                const service = SERVICE_DATA[serviceKey];
                return service ? (
                  <a href={service.url} class="blog-sidebar__service-link">
                    <span class="service-link__icon">{service.icon}</span>
                    {service.label}
                  </a>
                ) : null;
              })}
            </div>
            <a href="/servicios/" class="blog-sidebar__view-all">
              Ver todos los servicios →
            </a>
          </div>

          <!-- Directorio Links -->
          <div class="blog-sidebar-card">
            <h3 class="blog-sidebar-card__title">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              Directorio de Venues
            </h3>
            <div class="blog-sidebar__zones">
              {CDMX_ZONES.slice(0, 6).map(zone => (
                <a href={zone.href} class="blog-sidebar__zone-link">
                  {zone.label}
                </a>
              ))}
            </div>
            <a href="/directorio/" class="blog-sidebar__view-all">
              Ver directorio completo →
            </a>
          </div>

          <!-- Related Posts -->
          {relatedPostsData.length > 0 && (
            <div class="blog-sidebar-card">
              <h3 class="blog-sidebar-card__title">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                Te puede interesar
              </h3>
              <div class="related-posts-list">
                {relatedPostsData.map(post => (
                  <a href={`/blog/${post.slug}/`} class="related-post-card">
                    {post.data.image ? (
                      <img
                        src={post.data.image}
                        alt=""
                        class="related-post-card__image"
                        width="70"
                        height="52"
                        loading="lazy"
                      />
                    ) : (
                      <div class="related-post-card__image related-post-card__image--placeholder">
                        <span class="related-post-card__placeholder-icon">
                          {CATEGORY_ICONS[post.data.category || ''] || '📄'}
                        </span>
                      </div>
                    )}
                    <div class="related-post-card__content">
                      <span class="related-post-card__category">
                        {CATEGORY_LABELS[post.data.category || ''] || 'Blog'}
                      </span>
                      <span class="related-post-card__title">{post.data.title}</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Author Card -->
          <div class="blog-sidebar-card">
