---
/**
 * ─── Eventos Index ───
 * Hub page con los tipos de eventos que cubrimos.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { breadcrumbJsonLd } from "@utils/seo";

const jsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Eventos", url: "/eventos/" },
  ]),
];
---

<PageLayout
  title="Tipos de Eventos en CDMX"
  description="Renta de equipo para bodas, XV años, eventos corporativos, fiestas infantiles y más en CDMX. Paquetes completos con montaje incluido. Cotiza sin compromiso."
  jsonLd={jsonLd}
>

  <HeroPage
    badge="Equipamiento para todo tipo de eventos"
    title='Renta de Equipo para <span class="highlight">Eventos en CDMX</span>'
    subtitle="Bodas, XV años, corporativos, fiestas infantiles y eventos sociales. Contamos con todo el equipamiento que necesitas para hacer tu celebración inolvidable."
    primaryCTA={{ label: "Cotiza tu evento", href: "/cotizar/" }}
    secondaryCTA={{ label: "Ver catálogo", href: "/servicios/" }}
    cards={[
      {
        title: "Equipamiento para cada celebración",
        content: "<strong>Equipo para eventos</strong> adaptado a cada tipo de celebración. Desde bodas íntimas con iluminación romántica hasta congresos corporativos con pantallas LED de última generación. Cada evento tiene necesidades únicas y nosotros tenemos la solución perfecta."
      },
      {
        title: "Experiencia en más de 500 eventos",
        content: "<strong>Equipo para eventos</strong> respaldado por experiencia real. Más de 500 eventos exitosos en CDMX y zona metropolitana nos avalan. Conocemos los mejores venues, sabemos qué equipo funciona mejor en cada espacio y anticipamos cada detalle logístico."
      }
    ]}
  />

  <CTABanner
    headline="¿Qué tipo de evento estás organizando?"
    subheadline="Selecciona tu tipo de evento y descubre el equipamiento ideal, o cotiza directamente para recibir asesoría personalizada."
    primaryCTA={{ label: "Cotizar ahora", href: "/cotizar/" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
  />

  <section class="section" aria-labelledby="tipos-heading">
    <div class="container">
      <SectionHeader
        id="tipos-heading"
        title="Tipos de Eventos"
        subtitle="Encuentra el equipamiento perfecto"
        description={[
          "Cada tipo de evento requiere un enfoque diferente. Explora nuestras guías especializadas con recomendaciones de equipo, presupuestos estimados y todo lo que necesitas saber.",
          "Si no encuentras tu tipo de evento, no te preocupes — contáctanos y te asesoramos de manera personalizada."
        ]}
      />

      <div class="grid grid--4">
        <Card
          name="Bodas"
          excerpt="Mobiliario elegante, iluminación romántica, pistas de baile y más para tu boda perfecta."
          cta="Ver equipo para bodas"
          href="/eventos/bodas/"
          icon="heart"
        />
        <Card
          name="XV Años"
          excerpt="Pistas LED, inflables, efectos especiales y todo para una fiesta de XV años inolvidable."
          cta="Ver equipo para XV"
          href="/eventos/xv-anos/"
          icon="crown"
        />
        <Card
          name="Corporativos"
          excerpt="Audiovisual profesional, mobiliario ejecutivo y carpas para congresos y conferencias."
          cta="Ver equipo corporativo"
          href="/eventos/corporativos/"
          icon="briefcase"
        />
        <Card
          name="Fiestas Infantiles"
          excerpt="Inflables, brincolines, juegos interactivos y diversión segura para los más pequeños."
          cta="Ver equipo infantil"
          href="/eventos/fiestas-infantiles/"
          icon="balloon"
        />
      </div>
    </div>
  </section>

  <CTABanner
    headline="Tu evento perfecto comienza aquí"
    subheadline="Más de 500 eventos exitosos nos respaldan. Cotiza hoy y recibe asesoría personalizada sin compromiso."
    primaryCTA={{ label: "Cotizar ahora", href: "/cotizar/" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
    variant="accent"
  />
</PageLayout>
