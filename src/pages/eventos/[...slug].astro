---
/**
 * ─── Event Pages ───
 * Renderiza páginas de tipos de eventos desde content collections.
 */
import { getCollection } from "astro:content";
import EventLayout from "@layouts/EventLayout.astro";
import { eventTypeJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

export async function getStaticPaths() {
  const eventos = await getCollection("eventos");
  return eventos.map((evento) => ({
    params: { slug: evento.slug },
    props: { evento },
  }));
}

const { evento } = Astro.props;
const { Content } = await evento.render();
const { title, description, seoTitle, seoDescription, hero, faqs } = evento.data;

const pageTitle = seoTitle || title;
const pageDescription = seoDescription || description;
const pageUrl = `/eventos/${evento.slug}/`;

const jsonLd = [
  eventTypeJsonLd({
    name: pageTitle,
    description: pageDescription,
    url: pageUrl,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Eventos", url: "/eventos/" },
    { name: title, url: pageUrl },
  ]),
  ...(faqs?.length ? [faqJsonLd(faqs)] : []),
];
---

<EventLayout
  title={pageTitle}
  description={pageDescription}
  hero={hero}
  jsonLd={jsonLd}
>
  <Content />
</EventLayout>
