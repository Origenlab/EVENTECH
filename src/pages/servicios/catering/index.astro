---
/**
 * ─── EVENTECH.MX — Catering y Barras para Eventos (L3, rediseño 2026) ───
 * Renta de equipo para catering: barras, cocina móvil, refrigeración y vajilla.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "estaciones-servicio",
    name: "Estaciones de Servicio",
    badge: "El corazón del evento",
    excerpt: "Barras de coctelería, estaciones de café, candy bar, bufets y mesas de carving con montaje y servicio completo. La diferencia entre un catering funcional y uno que se convierte en parte del diseño del evento.",
    href: "/servicios/catering/estaciones-servicio/",
    image: "/images/catering/barra-cocteleria-botanica-boda.avif",
    subcategories: [
      { name: "Barras de Bebidas", href: "/servicios/catering/estaciones-servicio/barras-bebidas/" },
      { name: "Tacos y Parrilla", href: "/servicios/catering/estaciones-servicio/tacos-parrilla/" },
      { name: "Estaciones de Postres", href: "/servicios/catering/estaciones-servicio/postres/" },
      { name: "Cocina en Vivo", href: "/servicios/catering/estaciones-servicio/cocina-vivo/" },
    ],
  },
  {
    id: "cocina-movil",
    name: "Cocina Móvil",
    badge: "Producción gastronómica en sitio",
    excerpt: "Equipo de cocina profesional portátil: parrillas industriales, freidoras, mesas de trabajo, hornos de convección y líneas de servicio completas para producción en el venue.",
    href: "/servicios/catering/cocina-movil/",
    image: "/images/catering/mesa-bufet-banquete-corporativo.avif",
    subcategories: [
      { name: "Parrillas Industriales", href: "/servicios/catering/cocina-movil/parrillas/" },
      { name: "Planchas y Freidoras", href: "/servicios/catering/cocina-movil/planchas-freidoras/" },
      { name: "Mesas de Trabajo Inoxidable", href: "/servicios/catering/cocina-movil/mesas-inoxidable/" },
      { name: "Hornos de Convección", href: "/servicios/catering/cocina-movil/hornos-conveccion/" },
    ],
  },
  {
    id: "refrigeracion",
    name: "Refrigeración",
    badge: "Cadena de frío garantizada",
    excerpt: "Cámaras de refrigeración portátiles, enfriadores de vinos y bebidas, cubetas de hielo de gran capacidad y sistemas de temperatura controlada para eventos con servicio de alimentos y bebidas.",
    href: "/servicios/catering/refrigeracion/",
    image: "/images/catering/cafe-break-corporativo-setup.avif",
    subcategories: [
      { name: "Refrigeradores Industriales", href: "/servicios/catering/refrigeracion/refrigeradores/" },
      { name: "Fuentes y Conservación", href: "/servicios/catering/refrigeracion/fuentes-conservacion/" },
      { name: "Hieleras Profesionales", href: "/servicios/catering/refrigeracion/hieleras/" },
      { name: "Dispensadores de Bebidas", href: "/servicios/catering/refrigeracion/dispensadores-bebidas/" },
    ],
  },
  {
    id: "vajilla-cristaleria",
    name: "Vajilla y Cristalería",
    badge: "El acabado de la mesa",
    excerpt: "Vajilla de porcelana, cristalería fina, cubiertos de acero inoxidable, charolas y fuentes para buffet. El equipamiento que define si la mesa se ve de evento o de evento de verdad.",
    href: "/servicios/catering/vajilla-cristaleria/",
    image: "/images/catering/vajilla-cristaleria-premium-boda.avif",
    subcategories: [
      { name: "Platos y Vajilla", href: "/servicios/catering/vajilla-cristaleria/platos-vajilla/" },
      { name: "Copas y Cristalería", href: "/servicios/catering/vajilla-cristaleria/copas-cristaleria/" },
      { name: "Cubiertos y Charolas", href: "/servicios/catering/vajilla-cristaleria/cubiertos-charolas/" },
      { name: "Equipo de Servicio", href: "/servicios/catering/vajilla-cristaleria/equipo-servicio/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🍽️",
    title: "Equipo de restaurante, no de evento",
    body: "Todo nuestro inventario de cocina móvil es equipo de uso profesional continuo — las mismas marcas y especificaciones que usan los restaurantes de fine dining en CDMX, disponibles en formato portátil para eventos.",
  },
  {
    icon: "🧊",
    title: "Cadena de frío verificada",
    body: "Nuestras cámaras portátiles mantienen temperatura de 2°C a 8°C con termómetro digital de registro. Entregamos reporte de temperatura al cierre del evento para eventos con requisitos de inocuidad alimentaria.",
  },
  {
    icon: "✨",
    title: "Montaje estético, no solo funcional",
    body: "Las estaciones de servicio se montan como parte del diseño del evento — colores, materiales, iluminación y distribución coordinados con la decoración. El candy bar y la barra de coctelería son elementos visuales, no solo funcionales.",
  },
  {
    icon: "🚿",
    title: "Sanitización certificada antes de entrega",
    body: "Toda la vajilla, cristalería y equipo de cocina pasa por lavado industrial a 85°C y desinfección química certificada antes de cada evento. Entregamos con sello de sanitización intacto.",
  },
  {
    icon: "📦",
    title: "Inventario completo desde una sola empresa",
    body: "Desde la parrilla industrial hasta la copa de champagne — todo en un solo pedido, una sola coordinación y un solo cargo logístico. Sin gestionar 4 proveedores distintos para el mismo evento.",
  },
  {
    icon: "🔄",
    title: "Retiro y conteo al finalizar",
    body: "Al terminar el evento recogemos, contamos y reportamos el inventario. Sin cargos sorpresa por piezas que el servicio de catering dijo que desaparecieron — el conteo se hace en conjunto con el cliente.",
  },
];

const steps = [
  { n: 1, t: "Levantamiento de necesidades", p: "Revisamos el menú del catering, el número de comensales, el layout del venue y los momentos de servicio para dimensionar correctamente el equipo necesario." },
  { n: 2, t: "Propuesta y coordinación", p: "Presentamos inventario detallado con cantidades, especificaciones y layout de montaje. Coordinamos directamente con el chef o empresa de catering si ya cuentan con uno." },
  { n: 3, t: "Montaje previo al evento", p: "Instalamos cocina, estaciones de servicio y refrigeración el día anterior o la mañana del evento. Todo verificado y en temperatura antes de que llegue el equipo de catering." },
  { n: 4, t: "Retiro y reporte de inventario", p: "Al finalizar recogemos, lavamos en sitio el equipo más delicado y realizamos conteo conjunto de vajilla y cristalería antes de retirarnos." },
];

const faqs = [
  {
    question: "¿Rentan equipo de catering sin servicio de comida incluido?",
    answer: "Sí. Nuestra especialidad es exactamente esa: renta de equipo y montaje de estaciones sin servicio de alimentos. Puedes contratar a tu empresa de catering favorita y nosotros les proveemos todo el equipamiento — cocina móvil, refrigeración, estaciones de servicio, vajilla y cristalería — montado y listo en el venue antes de que llegue su equipo. También coordinamos directamente con el chef o proveedor de catering para asegurarnos de que el equipo cumple sus requerimientos técnicos.",
  },
  {
    question: "¿Cuánta vajilla y cristalería necesito para mi evento?",
    answer: "La regla estándar es: platos de presentación y plato fuerte = 1 por comensal + 10% de reposición; copas de agua y vino = 2 por comensal; vasos de highball para cocteles = 1.5 por comensal si hay barra abierta. Para bufets con múltiples estaciones añadimos 30% adicional por movimiento de platos. Calculamos el inventario exacto según tu menú y servicio — no te pedimos que hagas las cuentas.",
  },
  {
    question: "¿Las cámaras de refrigeración portátiles funcionan con corriente normal?",
    answer: "Sí. Nuestras cámaras portátiles de hasta 500 litros funcionan con 110V/15A — un contacto estándar de cualquier venue. Las unidades de mayor capacidad pueden requerir 220V; lo especificamos en la cotización. Todas tienen termostato digital, alarma de temperatura y registro de datos. Para eventos con requisitos de inocuidad alimentaria, entregamos el reporte de temperatura del periodo de uso.",
  },
  {
    question: "¿Pueden montar el candy bar o la barra de coctelería con decoración incluida?",
    answer: "Sí. El montaje estético es parte del servicio — no solo el equipo funcional. El candy bar se monta con mesa de presentación, estructura de altura, recipientes acrílicos o de vidrio, señalización personalizada y decoración coordinada con el concepto del evento. La barra de coctelería incluye tabla de trabajo, fregadero portátil, estantes para botellas, iluminación LED integrada y frente personalizable. El diseño se presenta para aprobación antes del evento.",
  },
  {
    question: "¿Qué pasa si se rompe algo durante el evento?",
    answer: "La vajilla y cristalería tienen una merma esperada en eventos — nadie rompe cero piezas. Incluimos un 10% adicional de inventario como colchón. Las roturas que excedan ese porcentaje se cargan al costo por pieza acordado en el contrato, que se entrega junto con la cotización. El conteo se hace en conjunto al finalizar el evento — no hay cargos unilaterales sin verificación.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar el equipo de catering?",
    answer: "Para eventos medianos (hasta 200 personas) recomendamos 2–3 semanas de anticipación. Para eventos grandes o con requerimientos específicos de cocina móvil (múltiples líneas, hornos de convección, equipo especializado), 4–6 semanas. En temporada alta (noviembre–febrero) lo ideal es reservar con 6–8 semanas para garantizar disponibilidad del inventario completo.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo de Catering para Eventos en CDMX",
    description: "Renta de equipo para catering en CDMX: barras de servicio, cocina móvil, refrigeración portátil y vajilla premium para bodas, corporativos y eventos sociales.",
    url: "/servicios/catering/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering y Barras", url: "/servicios/catering/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering y Barras" },
];
---

<PageLayout
  title="Renta de Equipo para Catering y Barras en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/catering/barra-cocteleria-botanica-boda.avif"
  description="Renta de equipo para catering en CDMX: barras de coctelería, cocina móvil, refrigeración portátil y vajilla premium. Montaje incluido. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="catering-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Equipo para catering · CDMX y ZMVM</p>
            <h1 id="catering-hero-heading">
              El equipo que convierte cualquier venue en una <em>cocina y barra de nivel profesional</em>
            </h1>
            <p class="hm-hero__lead">
              Barras de coctelería, cocina móvil industrial, refrigeración con cadena de frío
              verificada y vajilla sanitizada. Todo montado en el venue antes de que llegue
              tu equipo de catering — sin que tengas que coordinar con cuatro proveedores distintos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20equipo%20para%20catering%20en%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver el equipo disponible
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>equipo para catering</strong> — no servicio de comida.
              Nuestra especialidad es proveer todo el equipamiento que un chef o empresa de
              catering necesita para operar en cualquier venue de CDMX: cocina móvil industrial,
              estaciones de servicio montadas con diseño, refrigeración con cadena de frío
              verificada y vajilla completa sanitizada. Todo desde una sola empresa, con un solo punto de contacto. Para eventos que además necesitan <a href="/servicios/audiovisual/">sistema de sonido</a> para maestro de ceremonias o música durante la cena, lo coordinamos en paralelo.
            </p>
            <p>
              Con <strong>cientos de eventos equipados</strong> en Ciudad de México y zona
              metropolitana, conocemos los requerimientos técnicos de los chefs y empresas
              de catering más exigentes de la ciudad — y sabemos cómo anticiparnos a ellos
              antes de que el evento empiece.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Equipo de catering disponible">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20equipo%20para%20catering%20en%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Todo el equipamiento, un solo proveedor</p>
            <h2 id="catalogo-heading">¿Qué equipo necesita tu evento?</h2>
            <p class="hm__head-sub">Estaciones de servicio, cocina móvil, refrigeración o vajilla — o todo junto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La diferencia entre un evento donde la comida y las bebidas fluyen con
              naturalidad y uno donde el servicio se nota improvisado no siempre está
              en el menú — está en el equipo con que se sirve. Un bufet en charolas
              de plástico no es el mismo que uno en fuentes de acero inoxidable. Una
              barra de coctelería sin fregadero ni superficie de trabajo fuerza al
              bartender a improvisar. Un candy bar sin estructura de altura se ve plano.
            </p>
            <p>
              El equipamiento correcto es lo que permite que el catering opere con
              la eficiencia y la estética que el evento merece. Eso es lo que rentamos.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada línea, a fondo</p>
            <h2 id="detalle-heading">Equipo de catering en detalle</h2>
            <p class="hm__head-sub">Qué incluye cada categoría y por qué el equipamiento correcto define la experiencia gastronómica del evento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de un servicio de catering impecable hay una cadena de equipamiento
              que trabaja en silencio: la cocina que mantiene temperaturas correctas, la
              refrigeración que cuida la cadena de frío, las estaciones que permiten
              servir con fluidez y la vajilla que hace que cada plato llegue a la mesa
              con la presentación que merece. Cuando uno de esos eslabones falla,
              el invitado lo nota — aunque no sepa exactamente por qué.
            </p>
          </div>
        </div>

        <!-- Estaciones de Servicio -->
        <article class="hm-feat" aria-labelledby="feat-estaciones">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Estaciones de Servicio</p>
            <h3 class="hm-feat__title" id="feat-estaciones">Barras y estaciones montadas con diseño — donde el servicio se convierte en parte del espectáculo</h3>
            <p class="hm-feat__lead">La barra de coctelería y el candy bar no son solo puntos de servicio. Son elementos visuales que los invitados fotografían y recuerdan tanto como la decoración floral.</p>
            <p>
              Nuestras <strong>barras de coctelería</strong> se montan con estructura de
              madera o acrílico de 180×60 cm, fregadero portátil de acero inoxidable,
              estantes para botellas con iluminación LED integrada, superficie de mármol
              o encimera personalizable y frente decorativo coordinado con el concepto
              del evento. El bartender tiene todo lo que necesita para operar con
              eficiencia — y los invitados ven una instalación que parece diseñada
              específicamente para ese espacio.
            </p>
            <p>
              El <strong>candy bar</strong> se monta con mesa de presentación de 2–3 niveles,
              recipientes de vidrio o acrílico en formatos variados, estructura de altura
              con elementos decorativos, señalización personalizada y base de tela o
              madera coordinada con la paleta del evento. Para la
              <strong>estación de café</strong> de eventos corporativos y break de
              congresos incluimos máquina de espresso profesional, molinillo, dispensadores
              de leche caliente y fría, estantería para cápsulas y punto de servicio de
              agua caliente para tés. La <strong>mesa de bufet</strong> se monta con
              cubre-mesas de lino, chafing dishes de acero inoxidable con base de agua
              caliente, señalética de menú y fuentes de presentación a distintas alturas.
              Combina con <a href="/servicios/mobiliario/">mobiliario de evento</a> para
              integrar las estaciones al diseño general del espacio.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Barras de Bebidas", href: "/servicios/catering/estaciones-servicio/barras-bebidas/" },
                { name: "Tacos y Parrilla", href: "/servicios/catering/estaciones-servicio/tacos-parrilla/" },
                { name: "Postres", href: "/servicios/catering/estaciones-servicio/postres/" },
                { name: "Cocina en Vivo", href: "/servicios/catering/estaciones-servicio/cocina-vivo/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/catering/estaciones-servicio/">
              Ver estaciones de servicio
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/catering/barra-cocteleria-botanica-boda.avif" alt="Barra de coctelería botánica montada para boda elegante en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/catering/barra-dulces-candy-bar-xv-anos.avif" alt="Candy bar con recipientes de vidrio y estructura de altura para XV años" loading="lazy" decoding="async" />
              <img src="/images/catering/catering-evento-01.avif" alt="Estación de café profesional en break corporativo con barista" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- Cocina Móvil -->
        <article class="hm-feat" aria-labelledby="feat-cocina">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Cocina Móvil</p>
            <h3 class="hm-feat__title" id="feat-cocina">Equipo industrial portátil — la cocina completa que el chef necesita en cualquier venue de CDMX</h3>
            <p class="hm-feat__lead">El problema más común del catering en venues sin cocina propia: el chef llega con un menú de gala y el espacio de producción no está a la altura. Aplica en salones sin cocina, haciendas, jardines residenciales y eventos bajo <a href="/servicios/carpas/">carpa</a>. Nosotros resolvemos eso.</p>
            <p>
              Nuestra <strong>cocina móvil</strong> se configura según el menú y el número
              de comensales. Para banquetes de 100 a 300 personas montamos líneas completas
              con <strong>parrillas industriales de 4 y 6 quemadores</strong>, mesas de
              trabajo de acero inoxidable calibre 14, freidoras industriales de 20 litros,
              hornos de convección portátiles de 6 bandejas y lavabo de manos con agua
              caliente y fría para cumplimiento NOM-251. Para eventos más grandes
              escalamos con unidades adicionales — sin restricción de capacidad.
            </p>
            <p>
              Todos los equipos operan con <strong>gas LP o gas natural</strong> según
              lo disponible en el venue. Llevamos tanques de gas de respaldo para
              eventos donde el suministro no está garantizado. Las
              <strong>mesas de trabajo modulares</strong> se ensamblan en la configuración
              que el chef especifique — isla central, línea perimetral o configuración
              en L según el espacio. Incluimos <strong>estantes de almacenamiento</strong>,
              porta-contenedores gastronorm y racks de utensilios. La cocina completa
              se instala y se verifica la mañana del evento — el chef llega a un espacio
              de producción listo para operar, no a armar equipo.
            </p>
