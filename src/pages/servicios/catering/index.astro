---
/**
 * ─── Catering Category Page ───
 * Página de categoría: Renta de Equipo de Catering para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import CtaBar from "@components/CtaBar.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import FaqSection from "@components/FaqSection.astro";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering" },
];

const SUB_SERVICES = [
  {
    name: "Estaciones de Servicio",
    excerpt: "Barras de bebidas, estaciones de tacos, carnes, postres y comida en vivo. Muebles diseñados para montajes de servicio profesional con iluminación integrada.",
    href: "/servicios/catering/estaciones-servicio/",
    image: "/images/catering/barra-cocteleria-botanica-boda.avif",
    subcategories: [
      { name: "Barras de Bebidas", href: "/servicios/catering/estaciones-servicio/barras-bebidas/" },
      { name: "Tacos y Parrilla", href: "/servicios/catering/estaciones-servicio/tacos-parrilla/" },
      { name: "Estaciones de Postres", href: "/servicios/catering/estaciones-servicio/postres/" },
      { name: "Cocina en Vivo", href: "/servicios/catering/estaciones-servicio/cocina-vivo/" },
    ],
  },
  {
    name: "Cocina Móvil",
    excerpt: "Parrillas industriales, planchas, freidoras, hornos de convección, calentadores y mesas de trabajo en acero inoxidable para cocina en sitio.",
    href: "/servicios/catering/cocina-movil/",
    image: "/images/catering/cafe-break-corporativo-setup.avif",
    subcategories: [
      { name: "Parrillas Industriales", href: "/servicios/catering/cocina-movil/parrillas/" },
      { name: "Planchas y Freidoras", href: "/servicios/catering/cocina-movil/planchas-freidoras/" },
      { name: "Hornos de Convección", href: "/servicios/catering/cocina-movil/hornos-conveccion/" },
      { name: "Mesas de Trabajo Inox", href: "/servicios/catering/cocina-movil/mesas-inoxidable/" },
    ],
  },
  {
    name: "Vajilla y Cristalería",
    excerpt: "Platos de porcelana, copas de cristal, cubiertos de acero inoxidable, charolas, samovares y equipo de servicio para banquetes de cualquier escala.",
    href: "/servicios/catering/vajilla-cristaleria/",
    image: "/images/catering/vajilla-cristaleria-premium-boda.avif",
    subcategories: [
      { name: "Platos y Vajilla", href: "/servicios/catering/vajilla-cristaleria/platos-vajilla/" },
      { name: "Copas y Cristalería", href: "/servicios/catering/vajilla-cristaleria/copas-cristaleria/" },
      { name: "Cubiertos y Charolas", href: "/servicios/catering/vajilla-cristaleria/cubiertos-charolas/" },
      { name: "Equipo de Servicio", href: "/servicios/catering/vajilla-cristaleria/equipo-servicio/" },
    ],
  },
  {
    name: "Refrigeración",
    excerpt: "Refrigeradores industriales, hieleras profesionales, dispensadores de bebidas, fuentes de chocolate y equipo de conservación en frío y caliente.",
    href: "/servicios/catering/refrigeracion/",
    image: "/images/catering/mesa-bufet-banquete-corporativo.avif",
    subcategories: [
      { name: "Refrigeradores Industriales", href: "/servicios/catering/refrigeracion/refrigeradores/" },
      { name: "Hieleras Profesionales", href: "/servicios/catering/refrigeracion/hieleras/" },
      { name: "Dispensadores de Bebidas", href: "/servicios/catering/refrigeracion/dispensadores-bebidas/" },
      { name: "Fuentes y Conservación", href: "/servicios/catering/refrigeracion/fuentes-conservacion/" },
    ],
  },
];

const faqs = [
  { question: "¿Rentan equipo de catering sin servicio de alimentos?", answer: "Sí. Nuestro servicio es exclusivamente renta de equipo e infraestructura para catering. No proveemos alimentos ni personal de cocina — eso lo maneja tu chef, banquetero o servicio de catering favorito. Nosotros proporcionamos todo el equipo físico: estaciones de servicio, cocina móvil, vajilla, cristalería, refrigeración y mobiliario especializado. Esto te da la libertad de trabajar con el proveedor de alimentos que prefieras mientras nosotros nos encargamos de la infraestructura." },
  { question: "¿Qué incluye una estación de servicio completa?", answer: "Una estación de servicio completa incluye: mueble base con acabado personalizable (madera, acrílico o laminado), superficie de trabajo en acero inoxidable grado alimenticio 304, falda decorativa, iluminación LED integrada, rótulo con nombre de la estación, y los accesorios específicos según el tipo — chafers y calentadores para estaciones calientes, hielo y enfriadores para estaciones frías, o tablas y cuchillos para estaciones de corte en vivo." },
  { question: "¿La vajilla viene sanitizada y lista para usar?", answer: "Sí. Toda nuestra vajilla, cristalería y cubiertos pasan por un proceso de lavado industrial con agua a 82°C, sanitizado con solución antibacterial de grado alimenticio y secado en ambiente controlado. Se entregan empacados individualmente en charolas de transporte forradas con papel grado alimenticio. Al finalizar el evento, recogemos todo sucio — el lavado posterior está incluido en el precio de renta." },
  { question: "¿Tienen equipo suficiente para eventos de más de 500 personas?", answer: "Sí. Nuestro inventario está diseñado para eventos de gran escala. Manejamos vajilla completa para hasta 1,500 comensales simultáneos, cristalería para 2,000 personas, y equipo de cocina móvil para montar cocinas industriales temporales con capacidad de producción para banquetes masivos. Para eventos de más de 800 personas recomendamos reservar con al menos 4 semanas de anticipación." },
  { question: "¿Pueden montar una cocina temporal completa en mi venue?", answer: "Sí. Nuestro servicio de cocina móvil permite montar cocinas industriales temporales en cualquier espacio: jardines, estacionamientos, explanadas o áreas de servicio. Incluye mesas de trabajo en acero inoxidable, parrillas y planchas industriales, hornos de convección, freidoras, calentadores de agua, tanques de gas LP con regulador certificado, conexiones eléctricas y extintores. Todo cumple con normativa sanitaria vigente." },
  { question: "¿Con cuánta anticipación debo reservar el equipo de catering?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para eventos estándar. Para eventos grandes (300+ personas) o en temporada alta (noviembre a febrero) lo ideal es apartar con 6 semanas. Realizamos una reunión de planeación con tu chef o banquetero para definir el listado exacto de equipo según el menú, número de tiempos, estilo de servicio y layout del venue." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo de Catering CDMX",
    description: "Estaciones de servicio, cocina móvil, vajilla, cristalería y refrigeración para banquetes y eventos en CDMX. Sanitización certificada incluida.",
    url: "/servicios/catering/",
    priceRange: { min: 2000, max: 75000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Equipo de Catering"
  description="Renta de equipo de catering para eventos en CDMX: estaciones de servicio, cocina móvil, vajilla de porcelana, cristalería y refrigeración industrial. Cotiza ya."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Infraestructura gastronómica de nivel profesional"
    title='Renta de <span class="highlight">Equipo de Catering</span> para Eventos en CDMX'
    subtitle="Estaciones de servicio personalizadas, cocina móvil industrial, vajilla de porcelana, cristalería fina, cubiertos premium y refrigeración profesional. Toda la infraestructura que tu chef o banquetero necesita para lucirse, con sanitización certificada y logística impecable."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo de catering para mi evento en CDMX` }}
    cards={[
      {
        title: "Equipo de grado comercial con sanitización certificada",
        content: "<strong>Renta de equipo de catering para eventos</strong> con estándares de higiene y calidad de restaurante profesional. Vajilla de porcelana blanca de alta temperatura (1280°C) resistente a impactos, cristalería de vidrio templado Libbey y Arcoroc, cubiertos de acero inoxidable 18/10 con acabado espejo, y equipo de cocina industrial con certificación NSF. Todo pasa por un proceso de <strong>lavado a 82°C, sanitizado con solución antibacterial de grado alimenticio</strong> y empaque individual en charolas de transporte. Inventario para hasta 1,500 comensales simultáneos.",
      },
      {
        title: "Logística coordinada con tu chef y diseño de layout gastronómico",
        content: "<strong>Servicio integral de infraestructura de catering</strong> diseñado para trabajar en perfecta coordinación con tu proveedor de alimentos. Nuestro equipo de logística se reúne con tu chef o banquetero para diseñar el <strong>layout de cocina, estaciones de servicio y flujo de meseros</strong> según el menú, número de tiempos y estilo de servicio (buffet, plated, estaciones en vivo o coctel). Entregamos todo montado y listo para operar. Complementa con <strong>mobiliario de banquete, iluminación ambiental</strong> y equipo audiovisual para una producción integral.",
      },
    ]}
  />

  <CtaBar headline="¿Qué equipo de catering necesitas?" items={[
    { label: "Estaciones", href: "/servicios/catering/estaciones-servicio/", icon: "catering" },
    { label: "Cocina Móvil", href: "/servicios/catering/cocina-movil/", icon: "catering" },
    { label: "Vajilla", href: "/servicios/catering/vajilla-cristaleria/", icon: "catering" },
    { label: "Refrigeración", href: "/servicios/catering/refrigeracion/", icon: "catering" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="El mejor banquete merece la mejor infraestructura"
    subheadline="Recibe una propuesta personalizada con todo el equipo que tu chef necesita según el menú y número de invitados — sin compromiso"
    primaryCTA={{ label: "Cotizar equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="¿Qué equipo de catering puedes rentar para tu evento?"
        subtitle="Infraestructura profesional para cualquier tipo de banquete y estilo de servicio"
        description={[
          "Desde una estación de tacos elegante para una boda en un jardín de Coyoacán hasta una cocina industrial completa para un banquete corporativo de 1,000 personas en Santa Fe — contamos con el inventario más completo de equipo de catering para eventos en la Ciudad de México y zona metropolitana.",
          "Cada pieza cumple con estándares sanitarios de la industria restaurantera. Trabajamos en coordinación con tu chef o banquetero para garantizar que tengas exactamente el equipo que necesita para ejecutar el menú perfecto."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <CategoryCard
            title={sub.name}
            subtitle={sub.excerpt}
            href={sub.href}
            image={sub.image}
            subcategories={sub.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESTACIONES DE SERVICIO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="estaciones-heading">
    <div class="container">
      <ServiceShowcase
    title="Estaciones de Servicio"
    headingId="estaciones-heading"
    badge="Lo más solicitado para bodas y corporativos"
    subtitle="Barras de bebidas, estaciones de tacos, carnes, mariscos, postres y cocina en vivo con muebles profesionales, iluminación LED integrada y acabados personalizables."
    tags={["Estación Tacos", "Barra Cocteles", "Postres Multinivel", "Acero Inox 304", "LED Integrado", "Show Cooking"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Estaciones"
  >
    <Fragment slot="body">
      <p class="showcase__text">Las <strong>estaciones de servicio</strong> son el formato gastronómico más popular en eventos contemporáneos — combinan la frescura de la comida preparada al momento con la experiencia visual del show cooking. Nuestros <strong>muebles de estación</strong> están fabricados con estructura de acero con acabados en <strong>madera natural, acrílico blanco, laminado negro mate o forrado textil</strong> según el estilo de tu evento. Cada estación incluye <strong>superficie de trabajo en acero inoxidable 304 de grado alimenticio</strong>, chafers profesionales con quemador de gel, iluminación LED perimetral integrada y rótulo personalizado.</p>
      <p class="showcase__text">Ofrecemos configuraciones para todo tipo de estaciones: <strong>tacos y parrilla con campana extractora portátil</strong>, estación de <strong>mariscos con cama de hielo y refrigeración integrada</strong>, estación de <strong>postres con exhibidores de acrílico multinivel</strong>, barra de <strong>cocteles con iluminación RGB</strong> y estación de <strong>café y chocolate con máquina espresso profesional</strong>. Cada estación se diseña a medida con tu chef o banquetero para garantizar el flujo de servicio óptimo. Complementa con <a href="/servicios/mobiliario/">mobiliario elegante</a> para el área de comensales y <a href="/servicios/iluminacion/">iluminación ambiental</a> que realce la presentación gastronómica.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
              <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/>
              <line x1="10" y1="1" x2="10" y2="4"/>
              <line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EQUIPO DE COCINA MÓVIL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cocina-heading">
    <div class="container">
      <ServiceShowcase
    title="Equipo de Cocina Móvil"
    headingId="cocina-heading"
    badge="Cocinas industriales temporales"
    subtitle="Parrillas industriales, planchas, freidoras, hornos de convección, calentadores y mesas de trabajo en acero inoxidable para montar cocinas profesionales en cualquier espacio."
    tags={["Parrilla 6 Quemadores", "Horno Convección", "Plancha Cromo 90cm", "Freidora 30L", "Acero Inox 304", "NOM-093-SSA1"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Cocina Móvil"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestro <strong>equipo de cocina móvil</strong> permite montar una cocina industrial completa en cualquier venue — desde jardines y estacionamientos hasta explanadas y áreas de servicio sin infraestructura previa. Las <strong>parrillas industriales de acero inoxidable</strong> con 4 y 6 quemadores de alta potencia (40,000 BTU por quemador), <strong>planchas de cromo pulido de 90 cm</strong> para cocción uniforme, y <strong>hornos de convección de 5 charolas</strong> con control digital de temperatura forman la base de cualquier operación gastronómica profesional.</p>
      <p class="showcase__text">Complementamos con <strong>freidoras de doble tanque de 30 litros</strong>, <strong>calentadores de agua de paso para servicio continuo</strong>, <strong>tanques de gas LP de 30 kg con regulador y manguera certificados</strong>, y <strong>mesas de trabajo en acero inoxidable 304</strong> con entrepaño y respaldo sanitario. Para eventos al aire libre, instalamos todo bajo <a href="/servicios/carpas/">carpas de servicio</a> con piso nivelado y ventilación adecuada. Incluimos <strong>extintores tipo K</strong> para cocina y conexiones eléctricas 110V/220V según el equipo. Todo el equipo cumple con <strong>normativa NOM-093-SSA1</strong> de prácticas de higiene.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       VAJILLA Y CRISTALERÍA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="vajilla-heading">
    <div class="container">
      <ServiceShowcase
    title="Vajilla y Cristalería"
    headingId="vajilla-heading"
    badge="Inventario para hasta 1,500 comensales"
    subtitle="Platos de porcelana blanca de alta temperatura, copas de cristal templado, cubiertos de acero inoxidable 18/10, charolas de servicio y samovares profesionales para banquetes de cualquier escala."
    tags={["Porcelana 1280°C", "Cristal Libbey", "Acero 18/10", "Filete Dorado", "1,500 Comensales", "Sanitización Incluida"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Vajilla"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestra <strong>vajilla de porcelana blanca</strong> está fabricada con cocción a 1280°C que garantiza resistencia superior a impactos y manchas — la misma calidad que usan los restaurantes de alto nivel. La línea completa incluye <strong>plato base de 30 cm, plato fuerte de 27 cm, plato de ensalada de 21 cm, plato de pan de 16 cm, taza de consomé con plato</strong> y <strong>taza de café con plato</strong>. Disponibles en acabado blanco clásico y línea premium con filete dorado o plateado para bodas y galas.</p>
      <p class="showcase__text">La <strong>cristalería de vidrio templado Libbey y Arcoroc</strong> incluye copa de vino tinto (350 ml), copa de vino blanco (250 ml), copa flauta para champagne (180 ml), vaso highball (350 ml), vaso old fashioned (270 ml) y copa de agua (300 ml). Los <strong>cubiertos de acero inoxidable 18/10</strong> con acabado espejo incluyen cuchillo, tenedor, cuchara sopera, cuchara de postre y tenedor de postre — disponibles en línea clásica y línea contemporánea. Complementa la mesa con <a href="/servicios/mobiliario/">mesas y sillas de banquete premium</a> y <a href="/servicios/iluminacion/">iluminación de centros de mesa</a> para una presentación impecable.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       REFRIGERACIÓN Y CONSERVACIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="refrigeracion-heading">
    <div class="container">
      <ServiceShowcase
    title="Refrigeración y Conservación"
    headingId="refrigeracion-heading"
    badge="Cadena de frío y calor garantizada"
    subtitle="Refrigeradores industriales, hieleras profesionales, dispensadores de bebidas, fuentes de chocolate, baños maría y equipo de conservación que mantiene la cadena de frío y calor durante todo el evento."
    tags={["Refrigerador 47 ft³", "Hielera 400L", "Dispensador 5 Tanques", "Baño María 5 Insertos", "Fuente Chocolate", "Cadena de Frío"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Refrigeración"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>cadena de temperatura</strong> es crítica para la seguridad alimentaria en cualquier banquete. Nuestros <strong>refrigeradores industriales de dos puertas</strong> (47 pies cúbicos) mantienen temperatura constante de 0-4°C para almacenar ingredientes, postres y bebidas antes y durante el servicio. Las <strong>hieleras profesionales de acero inoxidable</strong> de 100, 200 y 400 litros con drenaje y ruedas mantienen botellas y latas perfectamente frías. Los <strong>dispensadores de bebidas</strong> de 3 y 5 tanques con sistema de enfriamiento eléctrico sirven aguas frescas, jugos y limonadas a temperatura ideal.</p>
      <p class="showcase__text">Para conservación en caliente, ofrecemos <strong>baños maría eléctricos</strong> de 3 y 5 insertos con control de temperatura, <strong>chafers rectangulares y redondos</strong> con quemador de gel para buffet elegante, y <strong>calentadores de platos infrarrojos</strong> que mantienen la vajilla a temperatura de servicio. Las <strong>fuentes de chocolate</strong> de 3 y 5 niveles (40 a 70 cm) con cascada continua son la atracción estrella de mesas de postres. Todo el equipo opera con <strong>conexión eléctrica estándar 110V</strong> — para eventos al aire libre llevamos extensiones industriales y reguladores de voltaje. Complementa con <a href="/servicios/carpas/">carpas de servicio</a> para proteger el área de cocina y buffet.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
