    primaryCTA={{ label: "Cotizar equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo de catering para mi evento en CDMX` }}
    variant="accent"
  />
