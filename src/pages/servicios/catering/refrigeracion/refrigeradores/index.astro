---
/**
 * ─── Refrigeradores Industriales — Pagina de Producto (Nivel 4) ───
 * Refrigeradores verticales reach-in, congeladores de cofre y walk-in
 * coolers portátiles para conservar alimentos en eventos masivos.
 *
 * Jerarquia: Servicios > Catering > Refrigeración > Refrigeradores Industriales
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
  { label: "Refrigeradores Industriales" },
];

const faqs = [
  { question: "¿Qué requerimientos eléctricos necesitan los refrigeradores industriales?", answer: 'Los refrigeradores reach-in de 1 y 2 puertas operan con corriente estándar de <strong>110V y un circuito dedicado de 15 amperes</strong>. Los congeladores de cofre de 300L también funcionan con 110V. Para equipos de mayor capacidad como el congelador de 500L y los <strong>walk-in coolers portátiles se requiere conexión de 220V</strong> con circuito de 30 amperes. Siempre realizamos una evaluación previa de la instalación eléctrica de tu venue. Si no cuentas con acceso a corriente, ofrecemos <a href="/servicios/accesorios/plantas-energia/">plantas de energía</a> compatibles.' },
  { question: "¿Qué temperatura garantizan los equipos durante el evento?", answer: "Todos nuestros refrigeradores cuentan con <strong>termostatos digitales de precisión</strong> que mantienen temperaturas constantes. Los reach-in operan entre 2°C y 8°C, ideales para bebidas, lácteos, ensaladas y carnes frías. Los congeladores de cofre mantienen entre -18°C y -22°C para helados, postres congelados y hielo. Cada equipo tiene <strong>alarma de temperatura integrada</strong> que alerta si la puerta queda abierta o si la temperatura sube del rango seguro." },
  { question: "¿Cómo funciona la instalación de un walk-in cooler portátil?", answer: "Nuestros walk-in coolers portátiles son <strong>estructuras modulares de paneles aislados</strong> que armamos directamente en tu venue. El modelo de 3x2m requiere un espacio de al menos 4x3 metros y el de 4x3m necesita 5x4 metros. Llegamos <strong>6 horas antes del evento</strong> con camión de rampa hidráulica, armamos la estructura, conectamos el sistema de refrigeración a 220V y verificamos que alcance temperatura óptima. Incluye estantería de acero inoxidable, iluminación LED interior y piso antideslizante." },
  { question: "¿Los refrigeradores funcionan bien en eventos al aire libre?", answer: "Sí, nuestros equipos están diseñados para operar en condiciones de calor ambiente de hasta <strong>43°C sin perder rendimiento</strong>. Para eventos en exterior recomendamos ubicar los equipos bajo sombra — carpas, toldos o zonas techadas — para optimizar la eficiencia energética y reducir el consumo eléctrico. Los walk-in coolers portátiles cuentan con <strong>paneles aislados de poliuretano de alta densidad</strong> que mantienen la temperatura interna incluso en días muy calurosos." },
  { question: "¿Con cuánta anticipación entregan los equipos?", answer: "Entregamos e instalamos todos los equipos de refrigeración entre <strong>4 y 6 horas antes de tu evento</strong> para que alcancen su temperatura óptima de operación. Los refrigeradores reach-in alcanzan temperatura en 2-3 horas, mientras que los walk-in coolers requieren 4-5 horas de pre-enfriamiento. Para eventos que inician temprano, podemos entregar <strong>la noche anterior con cargo adicional mínimo</strong>. La recolección se realiza al finalizar tu evento sin costo extra." },
  { question: "¿Puedo combinar varios equipos de refrigeración en un mismo evento?", answer: "Absolutamente, es la configuración más común en eventos grandes. Puedes combinar <strong>reach-in para bebidas + congelador para hielo + walk-in cooler para alimentos</strong> del banquete. Ofrecemos <strong>paquetes de refrigeración completa</strong> con descuento al combinar múltiples equipos. Nuestro asesor evalúa tu menú, número de asistentes y tipo de venue para recomendarte la combinación ideal. También puedes complementar con nuestras <a href=\"/servicios/catering/hieleras/\">hieleras profesionales</a> para las barras de bebidas." },
];

const specs = [
  { label: "Reach-in 1 puerta", value: "500 litros, temperatura 2-8°C" },
  { label: "Reach-in 2 puertas", value: "1,000 litros, temperatura 2-8°C" },
  { label: "Congelador cofre 300L", value: "Temperatura -18 a -22°C" },
  { label: "Congelador cofre 500L", value: "Temperatura -18 a -22°C" },
  { label: "Walk-in cooler 3x2m", value: "2-8°C, capacidad 12m³" },
  { label: "Walk-in cooler 4x3m", value: "2-8°C, capacidad 24m³" },
  { label: "Energía", value: "110V estándar / 220V para walk-in" },
  { label: "Termostato", value: "Digital de precisión con alarma" },
  { label: "Compresor", value: "Hermético de alta eficiencia" },
  { label: "Entrega", value: "Pre-enfriado 4-6 hrs antes del evento" },
];

const sidebarNav = [
  { name: "Refrigeradores Industriales", href: null, active: true },
  { name: "Hieleras Profesionales", href: "/servicios/catering/refrigeracion/hieleras/" },
  { name: "Dispensadores de Bebidas", href: "/servicios/catering/refrigeracion/dispensadores-bebidas/" },
  { name: "Fuentes y Conservación", href: "/servicios/catering/refrigeracion/fuentes-conservacion/" },
];

const sidebarRelated = [
  { name: "Estaciones de Servicio", href: "/servicios/catering/estaciones-servicio/" },
  { name: "Cocina Móvil", href: "/servicios/catering/cocina-movil/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Marcos Villanueva", text: "Rentamos un walk-in cooler de 4x3m y dos refrigeradores reach-in para un festival gastronómico de 3 días en la Condesa. Todo el equipo llegó pre-enfriado, el técnico verificó temperaturas constantemente y no tuvimos ni un solo problema de conservación. Impresionante logística.", rating: 5, date: "2025-11-20" },
  { author: "Daniela Reyes", text: "Para nuestra boda campestre de 400 personas en Valle de Bravo necesitábamos conservar todo el banquete. EVENTECH nos armó un paquete con refrigerador de 2 puertas, congelador y hieleras. Todo funcionó perfecto durante 12 horas de evento. La comida siempre fresca y las bebidas heladas.", rating: 5, date: "2025-10-05" },
  { author: "Ing. Fernando López", text: "Organizamos una expo corporativa de 2 días con servicio de catering para 600 personas. Rentamos 3 refrigeradores industriales y un walk-in cooler. El equipo de EVENTECH fue muy profesional en la instalación y el monitoreo de temperatura. Cero incidentes, servicio de primera.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Refrigeradores Industriales para Eventos en CDMX",
    description: "Refrigeradores verticales reach-in, congeladores y walk-in coolers portátiles para conservar alimentos en eventos masivos. Desde $1,500 por día.",
    url: "/servicios/catering/refrigeracion/refrigeradores/",
    priceRange: { min: 1500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 187,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Refrigeración", url: "/servicios/catering/refrigeracion/" },
    { name: "Refrigeradores Industriales", url: "/servicios/catering/refrigeracion/refrigeradores/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Refrigeradores Industriales para Eventos en CDMX | EVENTECH"
  description="Renta de refrigeradores verticales reach-in, congeladores y walk-in coolers portátiles para conservar alimentos en eventos masivos. Desde $1,500 por día."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Conservación industrial para eventos"
    title='Renta de <span class="highlight">Refrigeradores Industriales</span> para Eventos'
    subtitle="Refrigeradores verticales reach-in de 1 y 2 puertas, congeladores de cofre y walk-in coolers portátiles con termostato digital y técnico de instalación incluido."
    primaryCTA={{ label: "Cotiza tu refrigerador", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar refrigeradores industriales para mi evento` }}
    cards={[
      {
        title: "Refrigeradores verticales reach-in y congeladores de cofre",
        content: "<strong>Renta de refrigeradores industriales</strong> de grado comercial para eventos en CDMX. Refrigeradores verticales reach-in de 1 y 2 puertas con capacidad de 500 y 1,000 litros, congeladores de cofre de 300 y 500 litros, y walk-in coolers portátiles de 3x2 y 4x3 metros para eventos de gran escala. Cada equipo con termostato digital de precisión, estantes de acero inoxidable y compresor hermético de alta eficiencia para conservación segura de alimentos y bebidas.",
      },
      {
        title: "Entrega pre-enfriada y técnico de instalación incluido",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta. Termostato digital de precisión con alarma de temperatura, entrega con pre-enfriamiento de 4 a 6 horas antes del evento y técnico de instalación que verifica conexión eléctrica, calibración de temperatura y funcionamiento óptimo. Walk-in coolers con paneles modulares, iluminación LED interior y piso antideslizante. Recolección al finalizar el evento sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas conservar alimentos en tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el refrigerador ideal para tu volumen de alimentos y número de asistentes"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Refrigeración para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas refrigeradores industriales para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar refrigeradores industriales para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Refrigeradores Industriales</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Refrigerador Reach-In 1 Puerta -->
          <section class="section section--alt" aria-labelledby="reach-in-1-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Compacto y eficiente</span>
                <h2 class="showcase__title" id="reach-in-1-heading">Refrigerador Reach-In 1 Puerta</h2>
                <p class="showcase__subtitle">El refrigerador ideal para eventos medianos: 500 litros de capacidad con acceso rápido y temperatura constante.</p>
                <p class="showcase__text">Nuestro <strong>refrigerador reach-in de 1 puerta</strong> es la solución compacta para eventos de hasta 150 personas. Con <strong>500 litros de capacidad</strong> y temperatura controlada entre 2°C y 8°C, conserva bebidas, lácteos, ensaladas, frutas y carnes frías con total seguridad. La puerta de vidrio templado permite visualizar el contenido sin abrirla, reduciendo la pérdida de frío. Estantes ajustables de acero inoxidable con capacidad para organizar charolas, bandejas y cajas de forma eficiente.</p>
                <p class="showcase__text">El compresor hermético de alta eficiencia mantiene temperatura constante incluso con aperturas frecuentes durante el servicio. Incluye <strong>termostato digital con display LED, iluminación interior y sistema de drenaje automático</strong>. Opera con corriente estándar de 110V, compatible con cualquier venue. Ideal para <strong>bodas, bautizos, graduaciones y eventos corporativos</strong> donde necesitas conservación confiable sin ocupar mucho espacio. Combínalo con nuestras <a href="/servicios/catering/estaciones-servicio/">estaciones de servicio</a> para un montaje de catering profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">500 litros</span>
                  <span class="showcase__tag">2-8°C</span>
                  <span class="showcase__tag">110V</span>
                  <span class="showcase__tag">Hasta 150 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Reach-In 1 Puerta
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Refrigerador Reach-In 1 Puerta</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Refrigerador Reach-In 2 Puertas -->
          <section class="section section--alt" aria-labelledby="reach-in-2-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Doble capacidad de almacenamiento</span>
                <h2 class="showcase__title" id="reach-in-2-heading">Refrigerador Reach-In 2 Puertas</h2>
                <p class="showcase__subtitle">1,000 litros de capacidad para banquetes grandes y eventos con servicio continuo de alimentos.</p>
                <p class="showcase__text">El <strong>refrigerador reach-in de 2 puertas</strong> es nuestro equipo más solicitado para <strong>bodas de 200 a 400 personas y eventos corporativos de gran formato</strong>. Con <strong>1,000 litros de capacidad</strong>, ofrece espacio suficiente para conservar todo el menú de un banquete completo: entradas, ensaladas, carnes marinadas, postres, bebidas y complementos. Dos puertas independientes de vidrio templado permiten acceso simultáneo desde ambos lados, optimizando el flujo de trabajo del equipo de catering.</p>
                <p class="showcase__text">El sistema de refrigeración por convección forzada distribuye el frío de manera uniforme en todos los niveles, eliminando puntos calientes. <strong>6 estantes ajustables de acero inoxidable</strong> permiten configurar alturas según el tipo de alimento. Incluye <strong>termostato digital dual, alarma de puerta abierta y registro de temperatura</strong> para cumplir con normas de inocuidad alimentaria. Opera con 110V estándar. Complementa con nuestro <a href="/servicios/catering/cocina-movil/">equipo de cocina móvil</a> para una operación gastronómica completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">1,000 litros</span>
                  <span class="showcase__tag">2-8°C</span>
                  <span class="showcase__tag">2 puertas</span>
                  <span class="showcase__tag">200-400 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Reach-In 2 Puertas
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Refrigerador Reach-In 2 Puertas</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Congelador de Cofre Industrial -->
          <section class="section section--alt" aria-labelledby="congelador-cofre-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Congelación garantizada</span>
                <h2 class="showcase__title" id="congelador-cofre-heading">Congelador de Cofre Industrial</h2>
                <p class="showcase__subtitle">Congeladores de 300 y 500 litros para hielo, helados y productos que requieren temperaturas bajo cero.</p>
                <p class="showcase__text">Nuestros <strong>congeladores de cofre industriales</strong> mantienen temperaturas entre <strong>-18°C y -22°C</strong>, ideales para almacenamiento masivo de hielo, helados, postres congelados, mariscos y cualquier producto que requiera congelación. El modelo de <strong>300 litros</strong> es perfecto para barras de bebidas y estaciones de helado en eventos de hasta 200 personas. El modelo de <strong>500 litros</strong> cubre las necesidades de festivales gastronómicos, expos y eventos de más de 400 asistentes con servicio de hielo continuo.</p>
                <p class="showcase__text">El aislamiento de poliuretano de alta densidad garantiza retención de temperatura superior, incluso con aperturas frecuentes. Incluyen <strong>canasta organizadora extraíble, termostato ajustable, luz indicadora de operación y cerradura de seguridad</strong>. Los congeladores de 300L operan con 110V estándar; el modelo de 500L requiere 220V. Ideales para complementar las <a href="/servicios/catering/refrigeracion/hieleras/">hieleras profesionales</a> en barras con servicio de hielo durante todo el evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">300L y 500L</span>
                  <span class="showcase__tag">-18 a -22°C</span>
                  <span class="showcase__tag">Aislamiento PU</span>
                  <span class="showcase__tag">Cerradura seguridad</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Congelador de Cofre
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
