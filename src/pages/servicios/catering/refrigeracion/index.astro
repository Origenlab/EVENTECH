---
/**
 * ─── Refrigeracion y Conservacion para Eventos — Sub-subcategoria (Nivel 3) ───
 * Pagina especializada: Renta de Refrigeracion y Conservacion para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const REFRIGERACION = [
  {
    name: "Refrigeradores Industriales",
    excerpt: "Refrigeradores verticales reach-in, congeladores de cofre y walk-in coolers portátiles para conservar alimentos y bebidas en cualquier evento masivo o social.",
    cta: "Refrigeradores",
    href: "#refrigeradores-heading",
    icon: "package",
  },
  {
    name: "Hieleras Profesionales",
    excerpt: "Hieleras profesionales de 100 y 200 litros, máquinas de hielo industriales, contenedores isotérmicos y cubetas de champagne para servicio continuo de bebidas frías.",
    cta: "Hieleras",
    href: "#hieleras-heading",
    icon: "shield",
  },
  {
    name: "Dispensadores de Bebidas",
    excerpt: "Dispensadores de jugos, agua y limonada, torres cerveceras, enfriadores de vino y máquinas de bebidas frozen para barras y estaciones de servicio en eventos.",
    cta: "Dispensadores",
    href: "#dispensadores-heading",
    icon: "utensils",
  },
  {
    name: "Fuentes y Conservación",
    excerpt: "Fuentes de chocolate, charoleras con calentador, vitrinas frías de exhibición y gabinetes calientes para mantener alimentos a temperatura ideal durante todo el evento.",
    cta: "Fuentes",
    href: "#fuentes-heading",
    icon: "heart",
  },
];

const faqs = [
  { question: "¿Qué requerimientos eléctricos necesita el equipo de refrigeración?", answer: "La mayoría de nuestros refrigeradores industriales operan con corriente estándar de 110V/120V y requieren un circuito dedicado de 15 a 20 amperes. Los congeladores de cofre y walk-in coolers portátiles pueden requerir 220V dependiendo de su capacidad. Siempre realizamos una evaluación previa de la instalación eléctrica de tu venue para asegurar compatibilidad. Si tu evento es en exterior sin acceso a corriente, ofrecemos plantas de energía compatibles como complemento." },
  { question: "¿Cómo garantizan el control de temperatura durante todo el evento?", answer: "Todos nuestros equipos cuentan con termostatos digitales de precisión que mantienen temperaturas constantes entre -18°C y 8°C según el tipo de equipo. Los refrigeradores industriales tienen alarmas de temperatura integradas y nuestro equipo técnico verifica la calibración antes de la entrega. Para eventos largos (más de 8 horas), realizamos monitoreo periódico para garantizar que los alimentos se conserven en condiciones óptimas de inocuidad alimentaria." },
  { question: "¿Los equipos funcionan bien en eventos al aire libre con calor?", answer: "Sí, nuestros equipos están diseñados para operar en condiciones de calor. Los refrigeradores industriales mantienen su rendimiento hasta en temperaturas ambiente de 43°C. Para eventos en exterior recomendamos ubicar los equipos bajo sombra (carpas o toldos) para optimizar su eficiencia energética. Las hieleras isotérmicas profesionales mantienen temperatura hasta 12 horas sin conexión eléctrica. Ofrecemos también ventiladores industriales como complemento para áreas de servicio muy calurosas." },
  { question: "¿Cómo es la logística de entrega e instalación del equipo?", answer: "Entregamos e instalamos todo el equipo de refrigeración entre 4 y 6 horas antes de tu evento para alcanzar la temperatura óptima de operación. Nuestro equipo de logística cuenta con camiones con rampa hidráulica para refrigeradores pesados y walk-in coolers. Incluimos conexión eléctrica, verificación de temperatura y prueba de funcionamiento. Al finalizar tu evento, recogemos todo el equipo. El servicio de entrega y recolección está incluido dentro de CDMX y zona metropolitana." },
  { question: "¿Puedo combinar equipo de refrigeración con otros servicios de catering?", answer: "Por supuesto, es lo más recomendable. Nuestro equipo de refrigeración se complementa perfectamente con nuestras estaciones de servicio, cocina móvil y vajilla profesional. Ofrecemos paquetes integrales de catering que incluyen refrigeración, conservación y servicio completo. Al combinar servicios obtienes mejor precio, logística coordinada y un solo punto de contacto para todo tu evento. Consulta nuestros paquetes de refrigeración con catering completo." },
  { question: "¿Con cuánta anticipación debo reservar el equipo de refrigeración?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación, especialmente en temporada alta (marzo a junio y noviembre a enero). Los walk-in coolers portátiles y las máquinas de hielo industriales son los equipos más solicitados y se agotan primero. Para eventos grandes que requieran múltiples refrigeradores o paquetes completos de refrigeración, lo ideal es apartar con 1 mes de anticipación. También atendemos solicitudes de último momento sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Refrigeración y Conservación para Eventos en CDMX",
    description: "Refrigeradores industriales, hieleras profesionales, dispensadores de bebidas y fuentes de chocolate para eventos. Entrega e instalación incluida.",
    url: "/servicios/catering/refrigeracion/",
    priceRange: { min: 500, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Refrigeración", url: "/servicios/catering/refrigeracion/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Refrigeración y Conservación para Eventos en CDMX"
  description="Renta de refrigeradores industriales, hieleras profesionales, dispensadores de bebidas y fuentes de chocolate para eventos en CDMX. Instalación incluida. Desde $500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Conservación profesional para tu evento"
    title='Renta de <span class="highlight">Refrigeración y Conservación</span> para Eventos en CDMX'
    subtitle="Refrigeradores industriales, hieleras profesionales, dispensadores de bebidas y fuentes de chocolate con instalación y logística incluida para cualquier tipo de evento."
    primaryCTA={{ label: "Cotiza tu equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo de refrigeración para mi evento` }}
    cards={[
      {
        title: "Equipos de refrigeración de grado comercial para cada evento",
        content: "<strong>Renta de refrigeración para eventos</strong> con equipos de grado comercial e industrial disponibles en CDMX. Refrigeradores verticales reach-in de una y dos puertas con capacidad de 500 a 1,200 litros para banquetes y recepciones. Congeladores de cofre industriales para almacenamiento masivo de hielo y productos congelados. Walk-in coolers portátiles de 3 a 6 metros cúbicos para eventos de gran formato con cientos de comensales — cada equipo verificado, sanitizado y calibrado antes de cada entrega.",
      },
      {
        title: "Entrega, instalación y soporte técnico incluido",
        content: "<strong>Servicio logístico completo</strong> incluido en cada renta de equipo de refrigeración. Nuestro equipo se encarga del transporte con vehículos especializados, instalación con conexión eléctrica verificada, calibración de temperatura según el tipo de alimentos a conservar, y prueba de funcionamiento previa al evento. Termostatos digitales de precisión y monitoreo de temperatura para garantizar la inocuidad alimentaria durante todo tu evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas conservar alimentos y bebidas en tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con el equipo de refrigeración ideal para tu tipo de evento y número de asistentes"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Refrigeración y Conservación"
        subtitle="Equipo profesional para mantener todo fresco y a temperatura ideal"
        description={[
          "Desde refrigeradores industriales para banquetes masivos hasta fuentes de chocolate para mesas de postres. Contamos con el inventario de refrigeración para eventos más completo de la Ciudad de México.",
          "Cada equipo incluye entrega, instalación, calibración de temperatura y recolección al finalizar tu evento. Equipos sanitizados y certificados para garantizar la inocuidad de tus alimentos."
        ]}
      />

      <div class="grid grid--4">
        {REFRIGERACION.map((equipo) => (
          <Card
            name={equipo.name}
            excerpt={equipo.excerpt}
            cta={equipo.cta}
            href={equipo.href}
            icon={equipo.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       REFRIGERADORES INDUSTRIALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="refrigeradores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Conservación garantizada</span>
          <h2 class="showcase__title" id="refrigeradores-heading">Refrigeradores Industriales</h2>
          <p class="showcase__subtitle">Equipos de grado comercial para conservar grandes volúmenes de alimentos y bebidas en cualquier evento.</p>
          <p class="showcase__text">Nuestros <strong>refrigeradores industriales</strong> están diseñados para las exigencias de eventos de alto volumen. <strong>Refrigeradores verticales reach-in</strong> de una y dos puertas con capacidad de 500 a 1,200 litros, ideales para banquetes, recepciones y eventos corporativos. <strong>Congeladores de cofre industriales</strong> de 300 a 600 litros para almacenamiento masivo de hielo, postres congelados y productos que requieren temperaturas bajo cero. Termostatos digitales con rango de 0°C a 8°C en refrigeración y hasta -18°C en congelación.</p>
          <p class="showcase__text">Para eventos de gran formato ofrecemos <strong>walk-in coolers portátiles</strong> de 3 a 6 metros cúbicos que funcionan como cámaras frigoríficas temporales, perfectos para bodas de más de 300 invitados, festivales gastronómicos y eventos masivos. Cada equipo incluye <strong>estantes ajustables de acero inoxidable, iluminación LED interior y sistema de drenaje</strong>. Combínalos con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para crear áreas de servicio protegidas y funcionales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Reach-in 500-1,200L</span>
            <span class="showcase__tag">Congelador cofre</span>
            <span class="showcase__tag">Walk-in cooler</span>
            <span class="showcase__tag">Acero inoxidable</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Refrigeradores
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
              <line x1="4" y1="10" x2="20" y2="10"/>
              <line x1="10" y1="6" x2="10" y2="6.01"/>
              <line x1="10" y1="14" x2="10" y2="14.01"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HIELERAS PROFESIONALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="hieleras-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Hielo siempre disponible</span>
          <h2 class="showcase__title" id="hieleras-heading">Hieleras Profesionales</h2>
          <p class="showcase__subtitle">Contenedores isotérmicos, máquinas de hielo y cubetas de champagne para servicio ininterrumpido de bebidas frías.</p>
          <p class="showcase__text">Nuestras <strong>hieleras profesionales</strong> garantizan que las bebidas de tu evento se mantengan perfectamente frías durante toda la celebración. <strong>Hieleras de 100 y 200 litros</strong> con aislamiento térmico de grado comercial que mantienen temperatura hasta 12 horas sin conexión eléctrica. <strong>Máquinas de hielo industriales</strong> con producción de 50 a 150 kg diarios para barras de servicio continuo. <strong>Contenedores isotérmicos</strong> de acero inoxidable con drenaje integrado para servicio limpio y organizado.</p>
          <p class="showcase__text">Para eventos premium ofrecemos <strong>cubetas de champagne en acero inoxidable y acrílico iluminado</strong>, enfriadores de botella individuales y bins de hielo con presentación elegante para barras de coctelería. Cada hielera incluye <strong>tapa hermética, asas ergonómicas y sistema de drenaje</strong> para facilitar el manejo durante el servicio. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario de barras</a> para crear estaciones de bebidas profesionales y con estilo.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Hielera 100L</span>
            <span class="showcase__tag">Hielera 200L</span>
            <span class="showcase__tag">Máquina de hielo</span>
            <span class="showcase__tag">Cubetas champagne</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Hieleras
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L12 22"/>
              <path d="M2 12L22 12"/>
              <path d="M5.5 5.5L18.5 18.5"/>
              <path d="M18.5 5.5L5.5 18.5"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       DISPENSADORES DE BEBIDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="dispensadores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Servicio continuo</span>
          <h2 class="showcase__title" id="dispensadores-heading">Dispensadores de Bebidas</h2>
          <p class="showcase__subtitle">Dispensadores de jugos, torres cerveceras, enfriadores de vino y máquinas de bebidas frozen para servicio profesional.</p>
          <p class="showcase__text">Nuestros <strong>dispensadores de bebidas</strong> ofrecen servicio continuo y presentación impecable para cualquier tipo de evento. <strong>Dispensadores de jugos, agua y limonada</strong> en vidrio y acero inoxidable con capacidad de 10 a 20 litros y sistema de enfriamiento integrado, perfectos para recepciones, brunchs y eventos al aire libre. <strong>Torres cerveceras</strong> de 2, 4 y 6 líneas con sistema de CO2 y enfriamiento que mantienen la cerveza a temperatura ideal de 3°C a 5°C durante todo el evento.</p>
          <p class="showcase__text">También contamos con <strong>enfriadores de vino</strong> de 12 a 24 botellas con control de temperatura por zona para tintos y blancos, y <strong>máquinas de bebidas frozen</strong> de 1, 2 y 3 tanques para margaritas, daiquiris y granizados. Cada dispensador incluye <strong>limpieza, sanitización y los insumos técnicos necesarios</strong> (CO2, mangueras, conectores). Combínalos con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para crear barras de bebidas con ambiente espectacular.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Dispensador jugos</span>
            <span class="showcase__tag">Torre cervecera</span>
            <span class="showcase__tag">Enfriador vinos</span>
            <span class="showcase__tag">Máquina frozen</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Dispensadores
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2h8l2 6H6l2-6z"/>
              <rect x="6" y="8" width="12" height="12" rx="1"/>
              <line x1="10" y1="20" x2="10" y2="22"/>
              <line x1="14" y1="20" x2="14" y2="22"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FUENTES Y CONSERVACIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="fuentes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Show y frescura</span>
          <h2 class="showcase__title" id="fuentes-heading">Fuentes y Conservación</h2>
          <p class="showcase__subtitle">Fuentes de chocolate, charoleras con calentador, vitrinas frías y gabinetes calientes para presentación y conservación perfecta.</p>
          <p class="showcase__text">Nuestras <strong>fuentes y equipos de conservación</strong> combinan espectáculo visual con funcionalidad profesional. <strong>Fuentes de chocolate</strong> de 3, 4 y 5 niveles en acero inoxidable con capacidad de 2 a 8 kg de chocolate, perfectas para mesas de postres en bodas, XV años y eventos sociales. <strong>Charoleras con calentador</strong> (chafing dishes) con sistema de baño maría para mantener platillos calientes a 65°C durante horas en buffets y estaciones de servicio.</p>
          <p class="showcase__text">Para exhibición y conservación contamos con <strong>vitrinas frías de exhibición</strong> con iluminación LED y vidrio templado para postres, ensaladas y canapés que requieren refrigeración visible. <strong>Gabinetes calientes</strong> con control de temperatura y humedad para pan, tortillas y platillos que necesitan mantenerse calientes sin resecarse. Cada equipo incluye <strong>instalación, prueba de temperatura y limpieza</strong>. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para crear estaciones de servicio con pantallas de menú digital.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Fuente chocolate</span>
            <span class="showcase__tag">Chafing dish</span>
            <span class="showcase__tag">Vitrina fría</span>
            <span class="showcase__tag">Gabinete caliente</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Fuentes y Conservación
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Refrigeración para Eventos"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu equipo de refrigeración, es natural tener preguntas sobre capacidad, requerimientos eléctricos y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre refrigeración para eventos al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de equipo de refrigeración para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Equipo de Refrigeración"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de equipos de refrigeración y conservación. Sin compromiso, sin costos ocultos.",
          "Ya sea un refrigerador industrial para tu banquete o un paquete completo de refrigeración para tu festival, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoRefrigeracion">
                Tipo de equipo
              </label>
              <select id="tipoRefrigeracion" name="tipoRefrigeracion" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de equipo</option>
                <option value="Refrigerador Industrial Vertical">Refrigerador Industrial Vertical</option>
                <option value="Congelador Industrial">Congelador Industrial</option>
                <option value="Hielera Profesional 100L">Hielera Profesional 100L</option>
                <option value="Hielera Profesional 200L">Hielera Profesional 200L</option>
                <option value="Máquina de Hielo">Máquina de Hielo</option>
                <option value="Dispensador Bebidas">Dispensador Bebidas</option>
                <option value="Torre Cervecera">Torre Cervecera</option>
                <option value="Fuente de Chocolate">Fuente de Chocolate</option>
                <option value="Paquete Refrigeración Evento">Paquete Refrigeración Evento</option>
                <option value="Paquete Completo">Paquete Completo</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de asistentes, tipo de venue (salón/jardín/terraza), alimentos o bebidas a conservar, duración del evento..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Evaluación técnica gratis</h3>
            <p class="reserva-card__text">Evaluamos tu venue sin costo para recomendarte el equipo de refrigeración ideal según espacio y requerimientos eléctricos.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para tu presupuesto y tipo de evento.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const tipoRefrigeracion = document.getElementById('tipoRefrigeracion').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — Refrigeración y Conservación*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (tipoRefrigeracion) texto += `*Tipo de equipo:* ${tipoRefrigeracion}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Conservación profesional para eventos impecables"
    subheadline="Más de 500 eventos exitosos con equipos de refrigeración nos respaldan. Cotiza hoy y recibe asesoría sin compromiso."
    primaryCTA={{ label: "Cotizar refrigeración", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo de refrigeración para mi evento` }}
    variant="accent"
  />
</PageLayout>

