---
/**
 * ─── Dispensadores de Bebidas — Pagina de Producto (Nivel 4) ───
 * Dispensadores de jugos, torres cerveceras, enfriadores de vino
 * y máquinas de bebidas frozen para barras y eventos.
 *
 * Jerarquia: Servicios > Catering > Refrigeración > Dispensadores de Bebidas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
  { label: "Dispensadores de Bebidas" },
];

const faqs = [
  { question: "¿Qué tipos de dispensadores de bebidas tienen disponibles?", answer: "Contamos con 4 tipos principales: <strong>Dispensadores de jugos y agua</strong> de 10 y 20 litros con enfriamiento integrado, ideales para recepciones y brunchs. <strong>Torres cerveceras</strong> de 1 y 3 grifos con sistema CO2 para servicio de cerveza de barril. <strong>Enfriadores de vino</strong> de 12 y 24 botellas con control de temperatura por zona. Y <strong>máquinas de bebidas frozen</strong> de 2 y 3 tanques para margaritas, daiquiris y granizados. Todos incluyen instalación y puesta en marcha." },
  { question: "¿Las torres cerveceras incluyen el tanque de CO2 y los barriles?", answer: "Sí, cada torre cervecera incluye el <strong>tanque de CO2 necesario para la operación</strong>, regulador de presión, mangueras de conexión y grifo profesional. Los <strong>barriles de cerveza no están incluidos</strong> — tú proporcionas los barriles de la cervecería o marca de tu preferencia (barriles estándar de 20L o 30L con conexión tipo S o D). Nuestro técnico conecta todo, ajusta la presión óptima según el tipo de cerveza y verifica el flujo antes de que inicie tu evento." },
  { question: "¿Las máquinas de bebidas frozen pueden hacer cualquier sabor?", answer: "Sí, las máquinas frozen son muy versátiles. Cada tanque funciona de forma independiente, así que puedes ofrecer <strong>2 o 3 sabores diferentes simultáneamente</strong>. Los sabores más populares son margarita, piña colada, daiquiri de fresa, limonada frozen y michelada frozen. Tú proporcionas las mezclas preparadas y la máquina se encarga de congelarlas y mantenerlas en consistencia perfecta. Cada tanque de 12-15 litros rinde aproximadamente <strong>60-75 vasos de 200ml</strong>." },
  { question: "¿Qué requerimientos eléctricos necesitan los dispensadores?", answer: "Los dispensadores de jugos y las torres cerveceras operan con <strong>110V estándar</strong> (corriente normal). Los enfriadores de vino de 12 botellas también usan 110V; el de 24 botellas con zonas duales requiere un circuito dedicado de 15 amperes. Las máquinas frozen de 2 tanques funcionan con 110V, mientras que las de 3 tanques necesitan <strong>220V</strong>. Todas requieren un espacio plano y estable. Si tu evento es en exterior sin corriente, ofrecemos <a href=\"/servicios/accesorios/plantas-energia/\">plantas de energía</a> compatibles." },
  { question: "¿Puedo combinar dispensadores con una barra de bebidas?", answer: "Es la combinación ideal. Muchos clientes arman su barra con <strong>torre cervecera + dispensadores de jugos + máquina frozen + hieleras</strong> para ofrecer servicio completo. Complementa con nuestras <a href=\"/servicios/mobiliario/barras/\">barras de bebidas profesionales</a> para una presentación impecable. Ofrecemos <strong>paquetes de bar completo</strong> que incluyen todos los dispensadores, equipo de enfriamiento y mobiliario de barra con descuento por combinación." },
  { question: "¿Cuánto espacio necesito para instalar los dispensadores?", answer: "Depende del tipo de dispensador. Los <strong>dispensadores de jugos</strong> de 10L ocupan 40x30 cm sobre una mesa; los de 20L, 50x40 cm. Las <strong>torres cerveceras</strong> necesitan un espacio de 60x40 cm sobre barra más espacio inferior para el barril (60x60 cm). Los <strong>enfriadores de vino</strong> de 12 botellas ocupan 50x50 cm en piso; los de 24, 60x60 cm. Las <strong>máquinas frozen</strong> requieren 80x50 cm sobre superficie estable. Recomendamos al menos <strong>2-3 metros lineales de barra</strong> para un montaje completo." },
];

const specs = [
  { label: "Dispensador jugo 10L", value: "Con enfriamiento y grifo" },
  { label: "Dispensador jugo 20L", value: "Con enfriamiento y grifo" },
  { label: "Torre cervecera 1 grifo", value: "Sistema CO2 con barril 20/30L" },
  { label: "Torre cervecera 3 grifos", value: "Sistema CO2 triple con barriles" },
  { label: "Enfriador vino 12 btl", value: "Termoeléctrico 8-18°C" },
  { label: "Enfriador vino 24 btl", value: "Compresor 5-18°C zonas duales" },
  { label: "Máquina frozen 2 tanques", value: "12L por tanque, 110V" },
  { label: "Máquina frozen 3 tanques", value: "15L por tanque, 220V" },
  { label: "CO2", value: "Tanque incluido para torres cerveceras" },
  { label: "Instalación", value: "Técnico de montaje incluido" },
];

const sidebarNav = [
  { name: "Refrigeradores Industriales", href: "/servicios/catering/refrigeracion/refrigeradores/" },
  { name: "Hieleras Profesionales", href: "/servicios/catering/refrigeracion/hieleras/" },
  { name: "Dispensadores de Bebidas", href: null, active: true },
  { name: "Fuentes y Conservación", href: "/servicios/catering/refrigeracion/fuentes-conservacion/" },
];

const sidebarRelated = [
  { name: "Estaciones de Servicio", href: "/servicios/catering/estaciones-servicio/" },
  { name: "Cocina Móvil", href: "/servicios/catering/cocina-movil/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Paulina Herrera", text: "Para nuestra boda con barra abierta rentamos 2 torres cerveceras de 3 grifos y una máquina frozen de 3 tanques. Las torres mantuvieron la cerveza perfecta toda la noche y los margaritas frozen fueron el hit de la fiesta. El técnico de EVENTECH fue muy atento y todo funcionó sin fallas.", rating: 5, date: "2025-11-08" },
  { author: "Ricardo Domínguez", text: "Organizamos una feria de cerveza artesanal con 6 torres cerveceras y dispensadores de jugos como opción sin alcohol. EVENTECH coordinó todo impecablemente: conexiones, CO2, presión perfecta para cada tipo de cerveza. Los asistentes quedaron encantados con el servicio. Volveremos a trabajar con ellos.", rating: 5, date: "2025-09-30" },
  { author: "Ing. Laura Castillo", text: "Para nuestro evento empresarial de verano rentamos dispensadores de agua fresca, enfriadores de vino y máquinas frozen. La presentación fue excelente y todo funcionó perfectamente durante las 6 horas del evento. El equipo llegó a tiempo y el desmontaje fue rápido. Muy profesionales.", rating: 5, date: "2025-08-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Dispensadores de Bebidas para Eventos en CDMX",
    description: "Dispensadores de jugos, torres cerveceras, enfriadores de vino y máquinas de bebidas frozen para barras y eventos. Desde $800 por día.",
    url: "/servicios/catering/refrigeracion/dispensadores-bebidas/",
    priceRange: { min: 800, max: 4500 },
    reviews,
    ratingValue: 5,
    reviewCount: 176,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Refrigeración", url: "/servicios/catering/refrigeracion/" },
    { name: "Dispensadores de Bebidas", url: "/servicios/catering/refrigeracion/dispensadores-bebidas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Dispensadores de Bebidas para Eventos en CDMX | EVENTECH"
  description="Renta de dispensadores de jugos, torres cerveceras, enfriadores de vino y máquinas de bebidas frozen para barras y eventos. Desde $800 por día."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Servicio continuo de bebidas"
    title='Renta de <span class="highlight">Dispensadores de Bebidas</span> para Eventos'
    subtitle="Dispensadores de jugos y agua, torres cerveceras con CO2, enfriadores de vino con control de temperatura y máquinas de bebidas frozen para barras profesionales."
    primaryCTA={{ label: "Cotiza tu dispensador", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar dispensadores de bebidas para mi evento` }}
    cards={[
      {
        title: "Dispensadores de jugos, torres cerveceras y enfriadores de vino",
        content: "<strong>Renta de dispensadores de bebidas</strong> profesionales para eventos en CDMX. Dispensadores de jugos y agua de 10 y 20 litros con enfriamiento integrado, torres cerveceras de 1 y 3 grifos con sistema CO2, enfriadores de vino para 12 y 24 botellas con control de temperatura por zona, y máquinas de bebidas frozen de 2 y 3 tanques para margaritas, daiquiris y granizados.",
      },
      {
        title: "Instalación profesional y servicio técnico incluido",
        content: "<strong>Servicio de instalación completo</strong> incluido en cada renta. Sistema de enfriamiento integrado en dispensadores, tanque de CO2 incluido para torres cerveceras, vasos de degustación opcionales y mantenimiento técnico durante el evento. Nuestro técnico se encarga del montaje, conexión, calibración y verificación de funcionamiento antes de que inicie tu evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas servicio profesional de bebidas en tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con los dispensadores ideales para tu tipo de barra y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Refrigeración para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas dispensadores de bebidas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar dispensadores de bebidas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Dispensadores de Bebidas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Dispensadores de Jugos y Agua -->
          <section class="section section--alt" aria-labelledby="dispensadores-jugos-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Frescura para recepciones</span>
                <h2 class="showcase__title" id="dispensadores-jugos-heading">Dispensadores de Jugos y Agua</h2>
                <p class="showcase__subtitle">Dispensadores con enfriamiento integrado de 10 y 20 litros para recepciones, brunchs y eventos al aire libre.</p>
                <p class="showcase__text">Nuestros <strong>dispensadores de jugos y agua</strong> ofrecen servicio continuo de bebidas frescas con presentación elegante. El modelo de <strong>10 litros</strong> es perfecto para mesas de bienvenida, estaciones de café y áreas de descanso en eventos de hasta 80 personas. El modelo de <strong>20 litros</strong> cubre recepciones y brunchs de hasta 150 personas con flujo constante. Ambos cuentan con <strong>sistema de enfriamiento integrado</strong> que mantiene las bebidas entre 4°C y 8°C sin necesidad de hielo.</p>
                <p class="showcase__text">Fabricados en <strong>acero inoxidable con grifo de servicio profesional</strong> y base elevada para facilitar el llenado de vasos. El sistema de enfriamiento por compresión mantiene temperatura constante sin diluir el sabor de las bebidas. Perfectos para <strong>agua de frutas, limonadas, jugos naturales, agua mineral y aguas frescas tradicionales</strong>. Cada dispensador incluye limpieza, sanitización y verificación de funcionamiento. Combínalos con nuestras <a href="/servicios/catering/vajilla-cristaleria/">copas y cristalería</a> para un servicio de primera.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">10 y 20 litros</span>
                  <span class="showcase__tag">Enfriamiento integrado</span>
                  <span class="showcase__tag">Acero inoxidable</span>
                  <span class="showcase__tag">4-8°C</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Dispensadores de Jugos
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Dispensadores de Jugos y Agua</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Torres Cerveceras -->
          <section class="section section--alt" aria-labelledby="torres-cerveceras-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Cerveza de barril perfecta</span>
                <h2 class="showcase__title" id="torres-cerveceras-heading">Torres Cerveceras</h2>
                <p class="showcase__subtitle">Torres de 1 y 3 grifos con sistema CO2 profesional para servicio de cerveza de barril en eventos.</p>
                <p class="showcase__text">Nuestras <strong>torres cerveceras profesionales</strong> ofrecen servicio de cerveza de barril con la temperatura y presión perfectas. La torre de <strong>1 grifo</strong> es ideal para eventos íntimos y barras temáticas con una sola variedad de cerveza, compatible con barriles estándar de 20 y 30 litros. La torre de <strong>3 grifos</strong> permite ofrecer hasta 3 variedades diferentes simultáneamente — perfecta para <strong>bodas con barra abierta, ferias de cerveza artesanal y eventos corporativos</strong> donde la diversidad de opciones es clave.</p>
                <p class="showcase__text">Cada torre incluye <strong>tanque de CO2, regulador de presión calibrado, mangueras de grado alimenticio y grifo profesional con compensador de flujo</strong>. El sistema de enfriamiento mantiene la cerveza entre 3°C y 5°C desde el barril hasta el grifo. Nuestro técnico conecta los barriles, calibra la presión según el tipo de cerveza (ale, lager, stout) y verifica el primer servicio. También ofrecemos <strong>vasos de cerveza</strong> en renta. Complementa con nuestras <a href="/servicios/mobiliario/barras/">barras de bebidas</a> para una estación cervecera completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">1 y 3 grifos</span>
                  <span class="showcase__tag">Sistema CO2</span>
                  <span class="showcase__tag">3-5°C</span>
                  <span class="showcase__tag">Barriles 20/30L</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Torres Cerveceras
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Torres Cerveceras</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Enfriadores de Vino -->
          <section class="section section--alt" aria-labelledby="enfriadores-vino-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Vinos a temperatura perfecta</span>
                <h2 class="showcase__title" id="enfriadores-vino-heading">Enfriadores de Vino</h2>
                <p class="showcase__subtitle">Enfriadores de 12 y 24 botellas con control de temperatura para servicio profesional de vinos.</p>
                <p class="showcase__text">Nuestros <strong>enfriadores de vino profesionales</strong> mantienen cada botella a la temperatura ideal de servicio. El modelo de <strong>12 botellas</strong> con sistema termoeléctrico silencioso ofrece un rango de 8°C a 18°C, perfecto para barras pequeñas y mesas de honor en bodas de hasta 100 personas. El modelo de <strong>24 botellas</strong> con compresor profesional cuenta con <strong>zonas duales de temperatura</strong> (5-18°C) para almacenar vinos blancos y tintos simultáneamente en sus rangos óptimos.</p>
                <p class="showcase__text">Ambos modelos incluyen <strong>estantes de madera con revestimiento antivibración, iluminación LED interior suave, panel digital de control de temperatura y puerta de vidrio templado con protección UV</strong> que permite visualizar las etiquetas sin abrir. El enfriador de 24 botellas ofrece además <strong>control independiente por zona</strong>: zona superior para blancos a 8-12°C y zona inferior para tintos a 14-18°C. Perfectos para <strong>bodas, catas de vino, eventos gourmet y recepciones de gala</strong>. Complementa con nuestra <a href="/servicios/catering/vajilla-cristaleria/">cristalería profesional</a> para el servicio.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">12 y 24 botellas</span>
                  <span class="showcase__tag">Zonas duales</span>
                  <span class="showcase__tag">5-18°C</span>
                  <span class="showcase__tag">Protección UV</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Enfriadores de Vino
                </a>
              </div>
              <div class="showcase__image">
