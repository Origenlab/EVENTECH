---
/**
 * ─── Barras de Bebidas — Página de Producto (L5) ───
 * Barras móviles LED, coctelería, cerveza artesanal y café barista para eventos.
 * Homologada al Template-L5-producto (tiffany): componentes l3/l4, dorado #c2a24a,
 * galería showcase__gallery3, Acabados grid, 8 FAQs, título sin marca.
 *
 * Jerarquía: Servicios > Catering > Estaciones de Servicio > Barras de Bebidas
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Estaciones de Servicio", href: "/servicios/catering/estaciones-servicio/" },
  { label: "Barras de Bebidas" },
];

const faqs = [
  { question: "¿Qué incluye la renta de una barra de bebidas?", answer: 'Cada renta incluye la <strong>estructura de la barra</strong> (LED, madera premium o acero inoxidable según modelo), backbar refrigerado, cristalería completa (copas, vasos highball, vasos old fashioned), hielera industrial, utensilios de coctelería profesional, iluminación LED integrada con control remoto, mantelería decorativa y montaje/desmontaje sin costo dentro de CDMX. El servicio de bartender y los insumos de bebidas se cotizan por separado o como <a href="/servicios/catering/estaciones-servicio/">paquete integral de estaciones</a>.' },
  { question: "¿Cuánto cuesta rentar una barra de bebidas en CDMX?", answer: "El precio de una barra de bebidas para evento va <strong>desde $2,500</strong> (barra de café barista o cerveza estándar) hasta $8,000+ (barra premium de mixología con setup completo de destilados). La barra LED de coctelería, la más solicitada, ronda los $3,500–$5,500 según tamaño y duración. El precio incluye estructura, cristalería, refrigeración y montaje; el bartender profesional y los insumos de bebidas se cotizan aparte. Te enviamos precio cerrado el mismo día según tu número de invitados y tipo de evento." },
  { question: "¿Puedo contratar bartender profesional con la barra?", answer: "Sí, ofrecemos <strong>bartender profesional certificado</strong> como servicio adicional. Nuestros bartenders manejan coctelería clásica, mixología molecular y flair bartending (show de botellas). Cada bartender atiende cómodamente de 100 a 150 invitados; para eventos grandes recomendamos 2 o más. El servicio incluye carta de cocteles personalizada, preparación en vivo y atención premium durante todo el evento." },
  { question: "¿Cuánto espacio necesito para instalar una barra?", answer: "Una barra estándar de 2.4 metros necesita un espacio mínimo de <strong>4 × 2.5 metros</strong> (incluyendo zona de servicio trasera y circulación frontal). Para barras dobles o en L, el requerimiento es de 6 × 3 metros. Realizamos una <strong>visita técnica gratuita</strong> a tu venue para evaluar el espacio, accesos y conexiones eléctricas, y proponer la mejor ubicación según el flujo de invitados." },
  { question: "¿Se puede personalizar la barra con branding corporativo?", answer: "Sí, nuestras barras son <strong>100% personalizables</strong>. Ofrecemos viniles adhesivos con tu logo, impresión en gran formato para el frontal, iluminación LED programable con los colores de tu marca, menús impresos personalizados y elementos decorativos temáticos. Para eventos corporativos, el branding convierte la barra en una extensión de tu imagen empresarial. Envíanos tu logotipo y paleta y te presentamos opciones." },
  { question: "¿Qué tipos de barra ofrecen y cuál me conviene?", answer: "Ofrecemos 4 tipos principales: <strong>Barra LED de Coctelería</strong> (iluminación RGB, ideal para bodas y fiestas nocturnas), <strong>Barra de Cerveza Artesanal</strong> (dispensadores de grifo, perfecta para eventos casuales y corporativos), <strong>Barra de Café Barista</strong> (máquina espresso profesional, ideal para congresos y eventos matutinos) y <strong>Barra Premium de Mixología</strong> (setup completo de destilados, para eventos de alto nivel). Nuestro asesor te recomienda la mejor según tu evento y presupuesto." },
  { question: "¿Puedo combinar la barra con otras estaciones de servicio?", answer: 'Sí, es la combinación más popular. Una barra de bebidas con <a href="/servicios/catering/estaciones-servicio/tacos-parrilla/">estación de tacos y parrilla</a> crea el combo perfecto para fiestas; para bodas elegantes, la barra LED con una <a href="/servicios/catering/estaciones-servicio/postres/">estación de postres</a> es espectacular. Ofrecemos descuentos por paquetes de múltiples estaciones — arma la experiencia gastronómica completa desde una sola cotización.' },
  { question: "¿Con cuánta anticipación debo reservar la barra?", answer: "Recomendamos reservar con <strong>3 a 6 semanas de anticipación</strong>, especialmente en temporada alta (noviembre a febrero y temporada de bodas). La barra LED de coctelería es la más solicitada y se agota primero los fines de semana. Para eventos grandes o con branding personalizado, lo ideal es apartar con 2 meses. Atendemos solicitudes de última hora sujetas a disponibilidad; un anticipo confirma tu fecha." },
];

const specs = [
  { label: "Tipos", value: "Barra LED, Coctelería, Cerveza artesanal, Café barista, Premium mixología" },
  { label: "Material", value: "Acrílico LED / Madera premium / Acero inoxidable" },
  { label: "Capacidad de servicio", value: "100–300 personas por barra" },
  { label: "Iluminación", value: "LED RGB, 16 colores con control remoto" },
  { label: "Dimensiones", value: "2.4 × 0.6 × 1.1 m (estándar); doble y en L disponibles" },
  { label: "Bartender", value: "Profesional certificado (servicio adicional)" },
  { label: "Cristalería", value: "Incluida: copas, flauta, martini, highball, old fashioned" },
  { label: "Refrigeración", value: "Backbar refrigerado incluido" },
  { label: "Personalización", value: "Branding con vinil, impresión y LED de marca" },
  { label: "Montaje", value: "Incluido; 2 h antes del evento + desmontaje" },
];

const sidebarNav = [
  { name: "Barras de Bebidas", href: null, active: true },
  { name: "Tacos y Parrilla", href: "/servicios/catering/estaciones-servicio/tacos-parrilla/" },
  { name: "Estaciones de Postres", href: "/servicios/catering/estaciones-servicio/postres/" },
  { name: "Cocina en Vivo", href: "/servicios/catering/estaciones-servicio/cocina-vivo/" },
];

const sidebarRelated = [
  { name: "Cocina Móvil", href: "/servicios/catering/cocina-movil/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];

const reviews = [
  { author: "Mariana López", text: "Rentamos la barra LED para nuestra boda en un jardín de Coyoacán con 200 invitados. La iluminación cambiaba de color y combinaba perfecto con la decoración. El bartender preparó cocteles personalizados espectaculares y la cristalería incluida era de primera. Todos preguntaron dónde contratamos el servicio.", rating: 5, date: "2025-11-20" },
  { author: "Carlos Mendoza", text: "Contratamos una barra de cerveza artesanal para el lanzamiento de producto de nuestra empresa en un hotel de Polanco. Los dispensadores de grifo funcionaron perfecto toda la noche, la barra con branding corporativo se veía increíble y el equipo fue muy profesional con el montaje y desmontaje.", rating: 5, date: "2025-10-12" },
  { author: "Sofía Ramírez", text: "La barra de café barista fue el hit de nuestro evento. El barista preparó cappuccinos y lattes con arte increíble, además de cocteles de café con licor. La máquina espresso profesional y la presentación superaron nuestras expectativas. Servicio puntual y excelente atención.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Barras de Bebidas para Eventos en CDMX",
    description: "Renta de barras móviles LED, coctelería, cerveza artesanal y café barista para bodas, XV años y corporativos en CDMX. Cristalería y montaje incluidos. Desde $2,500.",
    url: "/servicios/catering/estaciones-servicio/barras-bebidas/",
    image: "/images/barras/barra-bebidas-led-nocturna-corporativo.avif",
    priceRange: { min: 2500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 185,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Estaciones de Servicio", url: "/servicios/catering/estaciones-servicio/" },
    { name: "Barras de Bebidas", url: "/servicios/catering/estaciones-servicio/barras-bebidas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Barras de Bebidas para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/barras/barra-bebidas-led-nocturna-corporativo.avif"
  description="Renta de barras de bebidas LED, coctelería, cerveza artesanal y café barista en CDMX. Cristalería y montaje incluidos, bartender opcional. Cotiza desde $2,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Barras premium para cada tipo de evento"
    title='Renta de <span class="highlight">Barras de Bebidas</span> para Eventos en CDMX'
    subtitle="Barras móviles LED con cambio de color, coctelería profesional, cerveza artesanal de grifo y café barista. Cristalería y refrigeración incluidas, bartender profesional opcional y montaje sin costo en CDMX."
    primaryCTA={{ label: "Cotiza tu barra", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar barras de bebidas para mi evento` }}
    cards={[
      {
        title: "Barras móviles LED con cristalería y refrigeración incluidas",
        content: "<strong>Renta de barras de bebidas para eventos</strong> con el diseño más impactante de CDMX. Barras móviles LED con cambio de color RGB y 16 tonalidades programables, estaciones de coctelería con backlit LED, dispensadores de cerveza de barril con enfriadores integrados y barras de café tipo barista con máquina espresso profesional. Estructura en acrílico iluminado, madera premium o acero inoxidable según tu estilo. Cristalería completa incluida: copas flauta, martini, highball y old fashioned.",
      },
      {
        title: "Bartender profesional opcional y montaje sin costo",
        content: "<strong>Servicio completo de montaje</strong> incluido en cada renta. Nuestro equipo se encarga del transporte, instalación de la estructura, conexiones eléctricas, calibración de iluminación LED, enfriamiento del backbar y verificación de cristalería antes del evento. Bartender profesional disponible como servicio adicional: coctelería clásica, mixología molecular y flair bartending. Montaje y desmontaje sin costo dentro de CDMX.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Necesitas la barra perfecta para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el tipo de barra ideal para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- 3. ACABADOS — 4 tipos de barra (anclas on-page) -->
  <section class="section" aria-labelledby="tipos-heading">
    <div class="container">
      <SectionHeader
        id="tipos-heading"
        title="4 tipos de barra — elige la tuya"
        subtitle="Cada barra tiene su personalidad"
        description={[
          "Desde la barra LED que se roba las fotos de la fiesta hasta la barra premium de mixología para eventos de alto nivel. Todas incluyen cristalería, refrigeración y montaje — la diferencia está en la experiencia que quieres dar a tus invitados."
        ]}
      />

      <div class="grid grid--4">
        <ProductCard
          name="Barra LED Coctelería"
          price="Desde $3,500"
          excerpt="Iluminación RGB de 16 colores que cambia con la temática. La estrella de bodas y fiestas nocturnas."
          href="#barra-led-heading"
          image="/images/barras/barra-bebidas-led-nocturna-corporativo.avif"
          badge="Más popular"
          tags={["LED RGB", "Coctelería", "Bodas", "Cristalería incluida"]}
        />
        <ProductCard
          name="Barra de Cerveza Artesanal"
          price="Desde $2,500"
          excerpt="Dispensadores de grifo con enfriamiento integrado. Casual y sofisticada para after office y festivales."
          href="#barra-cerveza-heading"
          image="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif"
          tags={["Grifo 2–6 líneas", "Enfriamiento", "Corporativos", "Casual"]}
        />
        <ProductCard
          name="Barra de Café Barista"
          price="Desde $2,500"
          excerpt="Máquina espresso profesional con barista y latte art. Ideal para congresos, brunch y eventos matutinos."
          href="#barra-cafe-heading"
          image="/images/catering/cafe-break-corporativo-setup.avif"
          tags={["Espresso pro", "Latte art", "Congresos", "Brunch"]}
        />
        <ProductCard
          name="Barra Premium Mixología"
          price="Desde $6,000"
          excerpt="Setup completo de destilados y mixólogo certificado para cocteles de autor en eventos de alto nivel."
          href="#barra-premium-heading"
          image="/images/barras/barra-bebidas-vinos-whiskey-corporativo.avif"
          tags={["Destilados", "Cocteles de autor", "Galas", "VIP"]}
        />
      </div>
    </div>
  </section>

  <!-- MOBILE SIDEBAR (≤1024px) -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Estaciones de Servicio</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas barras de bebidas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar barras de bebidas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Barras de Bebidas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Barra LED Coctelería -->
          <section class="section" aria-labelledby="barra-led-heading">
            <ServiceShowcase
              title="Barra LED Coctelería"
              headingId="barra-led-heading"
              badge="La estrella de la fiesta"
              subtitle="Iluminación RGB espectacular de 16 colores para crear el ambiente perfecto en bodas y fiestas."
              tags={["LED RGB", "16 colores", "Cristalería incluida", "Backbar refrigerado"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Barra LED"
            >
              <Fragment slot="body">
                <p class="showcase__text">Nuestra <strong>barra LED de coctelería</strong> es la opción más impactante para bodas, fiestas y eventos nocturnos. La estructura de acrílico translúcido con <strong>iluminación LED RGB integrada</strong> cambia entre 16 colores con control remoto y se sincroniza con la temática de tu evento. Equipada con backbar refrigerado, cristalería premium completa (copa flauta, martini, highball, old fashioned) y estación de preparación con todos los utensilios de mixología.</p>
                <p class="showcase__text">Ideal para <strong>bodas elegantes, recepciones de gala, cumpleaños y eventos corporativos nocturnos</strong> donde la barra se convierte en el punto focal. La iluminación resalta los momentos clave: brindis, primer baile, corte de pastel. Combínala con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente integral que tus invitados recordarán.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/barras/barra-bebidas-led-nocturna-corporativo.avif" alt="Barra de bebidas con iluminación LED en evento corporativo nocturno en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/barras/barra-bebidas-neon-led-azul-dorado-corporativo.avif" alt="Barra LED neón azul y dorado para evento corporativo" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/catering/barra-cocteleria-botanica-boda.avif" alt="Barra de coctelería botánica montada para boda elegante" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Barra de Cerveza Artesanal -->
          <section class="section" aria-labelledby="barra-cerveza-heading">
            <ServiceShowcase
              title="Barra de Cerveza Artesanal"
              headingId="barra-cerveza-heading"
              badge="Casual y sofisticada"
              subtitle="Dispensadores de grifo profesionales con enfriamiento integrado para servir cerveza perfecta toda la noche."
              tags={["Grifo 2–6 líneas", "Enfriamiento integrado", "Vasos especializados", "Menú personalizable"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Barra Cerveza"
            >
              <Fragment slot="body">
                <p class="showcase__text">Nuestra <strong>barra de cerveza artesanal</strong> transforma tu evento en una experiencia cervecera de primer nivel. Equipada con <strong>dispensadores de grifo profesionales</strong> de 2, 4 o 6 líneas, sistema de enfriamiento que mantiene la cerveza a temperatura ideal (3–5 °C) y torre de servicio de acero inoxidable con diseño industrial. La estructura de madera premium combina el estilo rústico artesanal con la funcionalidad profesional.</p>
                <p class="showcase__text">Perfecta para <strong>eventos corporativos casuales, after office, cumpleaños, festivales y eventos deportivos</strong>. Cada línea de grifo puede servir una cerveza distinta, ofreciendo variedad de estilos a tus invitados. Incluye vasos especializados (pinta, tulipán, weizen) y pizarrón con menú personalizable. Combínala con nuestra <a href="/servicios/catering/estaciones-servicio/tacos-parrilla/">estación de tacos y parrilla</a> para el combo perfecto de fiesta.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Barra de madera con bartender sirviendo bebidas en evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/mobiliario/barra-madera-dorada-bartender.avif" alt="Barra de madera con detalles dorados y bartender en evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/mobiliario/barra-hexagonal-bartender-botanical.avif" alt="Barra hexagonal con decoración botánica y bartender" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Barra de Café Barista -->
          <section class="section" aria-labelledby="barra-cafe-heading">
            <ServiceShowcase
