---
/**
 * ─── Estaciones de Servicio para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Estaciones de Servicio para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Estaciones de Servicio" },
];

const ESTACIONES = [
  {
    name: "Barras de Bebidas",
    excerpt: "Barras móviles LED, estaciones de coctelería, dispensadores de vino y cerveza, y barras de café tipo barista. Diseño premium para bodas, corporativos y fiestas.",
    cta: "Barras",
    href: "#barras-heading",
    icon: "utensils",
  },
  {
    name: "Estaciones de Tacos y Parrilla",
    excerpt: "Taquizas gourmet con trompo de pastor, estaciones de parrilla en vivo, carving stations y cocina regional mexicana. El favorito de todos los invitados.",
    cta: "Tacos y Parrilla",
    href: "#tacos-heading",
    icon: "award",
  },
  {
    name: "Estaciones de Postres",
    excerpt: "Mesas de postres temáticas, candy bar personalizado, fuentes de chocolate y estaciones de waffles y crepas. El toque dulce que completa tu evento.",
    cta: "Postres",
    href: "#postres-heading",
    icon: "heart",
  },
  {
    name: "Estaciones de Cocina en Vivo",
    excerpt: "Show cooking con chef interactivo, sushi bar en vivo, estación de wok, pasta station y experiencias gastronómicas que entretienen a tus invitados.",
    cta: "Cocina en Vivo",
    href: "#cocina-heading",
    icon: "layers",
  },
];

const faqs = [
  { question: "¿Qué incluye la renta de una estación de servicio?", answer: "Cada estación incluye el mobiliario especializado (barra, mesa, plancha o equipo según el tipo), montaje y desmontaje profesional, mantelería o decoración base de la estación, utensilios de servicio, iluminación integrada y personal de montaje. Algunas estaciones como las barras LED incluyen la estructura iluminada y controlador de colores. El servicio de alimentos, chef o bartender se cotiza por separado o como paquete integral según tus necesidades." },
  { question: "¿Puedo traer mi propio servicio de catering y solo rentar las estaciones?", answer: "Sí, absolutamente. Muchos de nuestros clientes rentan únicamente el mobiliario y equipo de las estaciones (barras, planchas, mesas de postres, fuentes de chocolate) y contratan su propio servicio de catering o chef. Nosotros nos encargamos del montaje, la estructura y los complementos. También ofrecemos paquetes integrales que incluyen chef, meseros y alimentos si lo prefieres." },
  { question: "¿Cuántas estaciones necesito según el número de invitados?", answer: "Como regla general, recomendamos 1 estación por cada 80-100 invitados para mantener un flujo cómodo sin filas largas. Para eventos de 100 a 200 personas, 2 a 3 estaciones son ideales. Para eventos de 200 a 400 personas, 3 a 5 estaciones. Para eventos masivos de 400+ personas, 5 o más estaciones distribuidas estratégicamente. Nuestro equipo de logística te ayuda a planificar la distribución óptima según tu venue." },
  { question: "¿Qué requerimientos eléctricos o de gas necesitan las estaciones?", answer: "Las barras LED y fuentes de chocolate necesitan conexión eléctrica estándar (110V). Las estaciones de tacos con trompo y parrilla usan gas LP (tanque incluido en la renta). Las estaciones de cocina en vivo con wok o plancha requieren conexión de gas y extracción de humo (o se ubican en área ventilada). Realizamos una visita técnica previa para evaluar las instalaciones de tu venue y garantizar que todo funcione de forma segura." },
  { question: "¿Cuánto tiempo toma el montaje de las estaciones?", answer: "El montaje estándar de una estación individual toma entre 1 y 2 horas. Para paquetes de múltiples estaciones, el montaje completo requiere de 3 a 5 horas dependiendo de la cantidad y complejidad. Las barras LED y fuentes de chocolate necesitan 30 minutos adicionales de calibración. Llegamos con suficiente anticipación para que todo esté listo antes de que lleguen tus invitados. El desmontaje se realiza al finalizar el evento." },
  { question: "¿Con cuánta anticipación debo reservar las estaciones de servicio?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas). Las barras LED y las estaciones de tacos con trompo son las más solicitadas y se agotan primero. Para eventos grandes con múltiples estaciones o paquetes completos, lo ideal es apartar con 2 meses de anticipación. Atendemos solicitudes de última hora sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Estaciones de Servicio para Eventos en CDMX",
    description: "Estaciones de servicio para eventos: barras de bebidas, tacos y parrilla, postres y cocina en vivo. Montaje profesional incluido.",
    url: "/servicios/catering/estaciones-servicio/",
    priceRange: { min: 1500, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Estaciones de Servicio", url: "/servicios/catering/estaciones-servicio/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Estaciones de Servicio para Eventos en CDMX"
  description="Renta de estaciones de servicio para eventos en CDMX: barras de bebidas LED, tacos y parrilla, mesas de postres y cocina en vivo. Montaje incluido. Desde $1,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Experiencia gastronómica para tu evento"
    title='Renta de <span class="highlight">Estaciones de Servicio</span> para Eventos en CDMX'
    subtitle="Barras de bebidas LED, estaciones de tacos y parrilla, mesas de postres y cocina en vivo. Montaje profesional y equipo completo para transformar tu evento en una experiencia gastronómica inolvidable."
    primaryCTA={{ label: "Cotiza tu estación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar estaciones de servicio para mi evento` }}
    cards={[
      {
        title: "Estaciones de servicio profesionales para cada tipo de evento",
        content: "<strong>Renta de estaciones de servicio para eventos</strong> con el equipamiento más completo de la Ciudad de México. Barras de bebidas móviles con iluminación LED integrada y estaciones de coctelería para bodas y fiestas. Taquizas gourmet con trompo de pastor y parrilla en vivo para eventos sociales y corporativos. Mesas de postres temáticas con fuente de chocolate y candy bar personalizado. Estaciones de cocina en vivo con chef interactivo para experiencias gastronómicas de alto nivel — cada estación diseñada para impresionar a tus invitados.",
      },
      {
        title: "Montaje profesional con logística completa",
        content: "<strong>Servicio integral de montaje</strong> incluido en cada renta de estaciones de servicio. Nuestro equipo de logística se encarga del transporte, instalación del mobiliario especializado, conexiones eléctricas y de gas, decoración base de cada estación y pruebas de funcionamiento previas al evento. Visita técnica gratuita a tu venue para planificar la distribución óptima de estaciones según el flujo de invitados y las condiciones del espacio.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la experiencia gastronómica perfecta para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con las estaciones ideales para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de estación
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Estaciones de Servicio"
        subtitle="La experiencia gastronómica perfecta para cada celebración"
        description={[
          "Desde barras de bebidas LED para bodas elegantes hasta estaciones de tacos y parrilla para fiestas memorables. Contamos con el catálogo de estaciones de servicio más completo de la Ciudad de México.",
          "Cada estación incluye mobiliario especializado, montaje profesional y equipo completo. Diseño, funcionalidad y sabor garantizados para impresionar a todos tus invitados."
        ]}
      />

      <div class="grid grid--4">
        {ESTACIONES.map((estacion) => (
          <Card
            name={estacion.name}
            excerpt={estacion.excerpt}
            cta={estacion.cta}
            href={estacion.href}
            icon={estacion.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BARRAS DE BEBIDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="barras-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Centro de la fiesta</span>
          <h2 class="showcase__title" id="barras-heading">Barras de Bebidas</h2>
          <p class="showcase__subtitle">El punto focal de toda celebración: barras móviles con diseño premium e iluminación espectacular.</p>
          <p class="showcase__text">Nuestras <strong>barras de bebidas para eventos</strong> transforman cualquier espacio en un punto de encuentro irresistible. <strong>Barras móviles con iluminación LED integrada</strong> que cambian de color según la temática de tu evento, disponibles en configuraciones de 2, 3 y 4 metros de largo. Estaciones de coctelería profesional con backlit LED, torre de dispensadores y cristalería premium. <strong>Barras de vino y cerveza</strong> con dispensadores de grifo, enfriadores integrados y presentación elegante para bodas y eventos corporativos.</p>
          <p class="showcase__text">Incluyen <strong>estaciones de café tipo barista</strong> con máquina espresso profesional, molinillo, accesorios de latte art y menú personalizado de bebidas calientes. Cada barra se instala con estructura de soporte independiente, iluminación ambiental y decoración base. Combínalas con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para crear ambientes espectaculares que tus invitados no olvidarán.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Barra LED</span>
            <span class="showcase__tag">Coctelería</span>
            <span class="showcase__tag">Vino y cerveza</span>
            <span class="showcase__tag">Café barista</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Barras de Bebidas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2h8l-1 7H9L8 2z"/>
              <path d="M12 9v4"/>
              <path d="M7 13h10"/>
              <rect x="5" y="17" width="14" height="4" rx="1"/>
              <line x1="5" y1="13" x2="5" y2="17"/>
              <line x1="19" y1="13" x2="19" y2="17"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESTACIONES DE TACOS Y PARRILLA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tacos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Favorito de los invitados</span>
          <h2 class="showcase__title" id="tacos-heading">Estaciones de Tacos y Parrilla</h2>
          <p class="showcase__subtitle">Taquizas gourmet, parrilla en vivo y cocina regional mexicana que conquistan a todos los paladares.</p>
          <p class="showcase__text">Las <strong>estaciones de tacos para eventos</strong> son el hit garantizado de cualquier celebración. <strong>Taquizas gourmet con trompo de pastor</strong> auténtico, tortillas hechas a mano y salsas artesanales. <strong>Carving stations</strong> con cortes premium servidos al momento: rib eye, arrachera, costillas BBQ y pechuga marinada. <strong>Parrilla en vivo</strong> con chef asador que prepara hamburguesas gourmet, brochetas, vegetales a la plancha y especialidades regionales frente a tus invitados.</p>
          <p class="showcase__text">Ofrecemos también <strong>estaciones de cocina regional mexicana</strong>: tlacoyos, quesadillas, esquites, elotes y antojitos típicos que aportan un toque auténtico a tu evento. Cada estación incluye plancha o parrilla profesional, campana de extracción portátil, mesa de preparación y servicio con presentación premium. Complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para crear un espacio techado ideal para estaciones al aire libre.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Trompo de pastor</span>
            <span class="showcase__tag">Parrilla en vivo</span>
            <span class="showcase__tag">Carving station</span>
            <span class="showcase__tag">Cocina regional</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Tacos y Parrilla
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/>
              <path d="M12 6v6l4 2"/>
              <circle cx="12" cy="12" r="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESTACIONES DE POSTRES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="postres-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">El toque dulce</span>
          <h2 class="showcase__title" id="postres-heading">Estaciones de Postres</h2>
          <p class="showcase__subtitle">Mesas de postres temáticas, candy bar y fuentes de chocolate que endulzan cada celebración.</p>
          <p class="showcase__text">Nuestras <strong>estaciones de postres para eventos</strong> son el complemento perfecto para cualquier celebración. <strong>Mesas de postres temáticas</strong> con diseño personalizado según la paleta de colores y estilo de tu evento: vintage, rústico, elegante, tropical o minimalista. <strong>Candy bar completo</strong> con dulces, gomitas, chocolates, marshmallows y dispensadores decorativos en presentación premium que los invitados adoran.</p>
          <p class="showcase__text">Incluimos <strong>fuentes de chocolate</strong> de 3 y 5 niveles con chocolate belga premium (oscuro, con leche o blanco) y estación de frutas, churros y marshmallows para sumergir. <strong>Estaciones de waffles y crepas</strong> preparados al momento con toppings variados: Nutella, frutas frescas, crema batida, helado y salsas artesanales. Cada mesa incluye mobiliario decorativo, bases, bandejas y presentación profesional. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para una presentación impecable.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Mesa de postres</span>
            <span class="showcase__tag">Candy bar</span>
            <span class="showcase__tag">Fuente de chocolate</span>
            <span class="showcase__tag">Waffles y crepas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Estaciones de Postres
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESTACIONES DE COCINA EN VIVO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cocina-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Show gastronómico</span>
          <h2 class="showcase__title" id="cocina-heading">Estaciones de Cocina en Vivo</h2>
          <p class="showcase__subtitle">Show cooking interactivo con chef profesional que transforma la comida en espectáculo.</p>
          <p class="showcase__text">Las <strong>estaciones de cocina en vivo</strong> convierten la preparación de alimentos en un espectáculo que entretiene e impresiona a tus invitados. <strong>Sushi bar en vivo</strong> con itamae (chef de sushi) preparando nigiri, rolls y sashimi al momento con ingredientes premium y presentación artística. <strong>Estación de wok</strong> con chef ejecutando salteados a fuego alto con vegetales, proteínas y salsas asiáticas en un show visual de llamas y aromas irresistibles.</p>
          <p class="showcase__text">Ofrecemos también <strong>pasta station</strong> con chef italiano preparando fettuccine, ravioli y risotto al momento con salsas caseras y toques gourmet. <strong>Chef interactivo</strong> que personaliza cada plato según las preferencias de tus invitados, explicando ingredientes y técnicas de cocina. Cada estación incluye equipo profesional, utensilios, plancha o wok, mesa de preparación y campana extractora portátil. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para proyectar el show cooking en pantallas LED.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Sushi bar</span>
            <span class="showcase__tag">Estación de wok</span>
            <span class="showcase__tag">Pasta station</span>
            <span class="showcase__tag">Chef interactivo</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Cocina en Vivo
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 7V5a4 4 0 00-8 0v2"/>
              <line x1="12" y1="11" x2="12" y2="17"/>
              <line x1="9" y1="14" x2="15" y2="14"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Estaciones de Servicio"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu estación de servicio, es natural tener preguntas sobre qué incluye, logística, requerimientos técnicos y tiempos de montaje. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre estaciones de servicio al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de estaciones de servicio para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Estación de Servicio"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de estaciones de servicio. Sin compromiso, sin costos ocultos.",
          "Ya sea una barra de bebidas LED para tu boda o un paquete completo de múltiples estaciones para tu festival, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoEstacion">
                Tipo de estación
              </label>
              <select id="tipoEstacion" name="tipoEstacion" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de estación</option>
                <option value="Barra de Bebidas LED">Barra de Bebidas LED</option>
                <option value="Barra de Coctelería">Barra de Coctelería</option>
                <option value="Estación de Tacos">Estación de Tacos</option>
                <option value="Estación de Parrilla">Estación de Parrilla</option>
                <option value="Trompo de Pastor">Trompo de Pastor</option>
                <option value="Mesa de Postres">Mesa de Postres</option>
                <option value="Fuente de Chocolate">Fuente de Chocolate</option>
                <option value="Estación de Cocina en Vivo">Estación de Cocina en Vivo</option>
                <option value="Paquete Múltiples Estaciones">Paquete Múltiples Estaciones</option>
                <option value="Paquete Completo">Paquete Completo</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de invitados, tipo de venue (salón/jardín/terraza), tipo de comida preferida, si necesitas chef o solo equipo..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Visita técnica gratis</h3>
            <p class="reserva-card__text">Evaluamos tu venue sin costo para planificar la distribución óptima de estaciones según el espacio y flujo de invitados.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para armar el paquete ideal para tu presupuesto.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const tipoEstacion = document.getElementById('tipoEstacion').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — Estaciones de Servicio*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (tipoEstacion) texto += `*Tipo de estación:* ${tipoEstacion}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="La experiencia gastronómica que tu evento merece"
    subheadline="Más de 500 eventos exitosos con estaciones de servicio nos respaldan. Cotiza hoy y recibe asesoría personalizada sin compromiso."
    primaryCTA={{ label: "Cotizar estaciones de servicio", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar estaciones de servicio para mi evento` }}
    variant="accent"
  />
</PageLayout>

