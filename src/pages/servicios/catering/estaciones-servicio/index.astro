---
/**
 * ─── EVENTECH.MX — Estaciones de Servicio para Eventos (L3, rediseño 2026) ───
 * Barras de bebidas · Tacos y parrilla · Postres · Cocina en vivo — CDMX y ZMVM
 * Homologado al sistema hm- (home-2026.css, dorado). Hijos hoja: specs, sin L6.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "barras-bebidas",
    name: "Barras de Bebidas",
    badge: "El centro de la fiesta",
    excerpt: "Barras móviles con iluminación LED, estaciones de coctelería profesional, dispensadores de vino y cerveza, y café tipo barista. El punto de encuentro que define el ambiente de bodas, corporativos y fiestas.",
    href: "/servicios/catering/estaciones-servicio/barras-bebidas/",
    image: "/images/barras/barra-bebidas-led-nocturna-corporativo.avif",
    imageAlt: "Barra de bebidas con iluminación LED en evento corporativo nocturno en CDMX",
    specs: ["Barra LED 2–4 m", "Coctelería pro", "Vino y cerveza", "Café barista"],
  },
  {
    id: "tacos-parrilla",
    name: "Tacos y Parrilla",
    badge: "Favorito de los invitados",
    excerpt: "Taquizas gourmet con trompo de pastor, parrilla en vivo, carving stations y cocina regional mexicana preparada al momento. El hit garantizado de cualquier celebración, sin filas ni platillos fríos.",
    href: "/servicios/catering/estaciones-servicio/tacos-parrilla/",
    image: "/images/catering/mesa-bufet-banquete-corporativo.avif",
    imageAlt: "Estación de servicio de alimentos y bufet montada para banquete de evento",
    specs: ["Trompo de pastor", "Parrilla en vivo", "Carving station", "Cocina regional"],
  },
  {
    id: "postres",
    name: "Estaciones de Postres",
    badge: "El toque dulce",
    excerpt: "Mesas de postres temáticas, candy bar personalizado, fuentes de chocolate y estaciones de waffles y crepas al momento. El cierre dulce que los invitados fotografían y recuerdan.",
    href: "/servicios/catering/estaciones-servicio/postres/",
    image: "/images/barras/barra-postres-boda-blanco-dorado-macarons.avif",
    imageAlt: "Mesa de postres en blanco y dorado con macarons para boda elegante en CDMX",
    specs: ["Mesa de postres", "Candy bar", "Fuente de chocolate", "Waffles y crepas"],
  },
  {
    id: "cocina-vivo",
    name: "Cocina en Vivo",
    badge: "Show gastronómico",
    excerpt: "Show cooking con chef interactivo, sushi bar, estación de wok y pasta station preparadas frente a tus invitados. La experiencia gastronómica que convierte el servicio de comida en espectáculo.",
    href: "/servicios/catering/estaciones-servicio/cocina-vivo/",
    image: "/images/barras/estacion-jamon-iberico-carving-lujo-02.avif",
    imageAlt: "Estación de cocina en vivo con chef preparando alimentos en evento premium",
    specs: ["Chef interactivo", "Sushi bar", "Estación de wok", "Pasta station"],
  },
];

const whyFeatures = [
  {
    title: "Montaje estético, no solo funcional",
    body: "Las estaciones se montan como parte del diseño del evento — colores, materiales, iluminación y distribución coordinados con tu decoración. La barra de coctelería y el candy bar son elementos visuales que los invitados fotografían, no solo puntos de servicio.",
  },
  {
    title: "Equipo profesional y chef opcional",
    body: "Rentas solo el equipo y montaje, o lo contratas como paquete integral con chef, bartender y meseros. Tú decides: trae tu propio catering y nosotros ponemos las estaciones, o te armamos la experiencia completa desde una sola empresa.",
  },
  {
    title: "Visita técnica previa sin costo",
    body: "Evaluamos gas, corriente eléctrica, extracción de humo y flujo de invitados en tu venue antes del evento. Así garantizamos que cada estación opere de forma segura y que la distribución evite cuellos de botella el día de la celebración.",
  },
  {
    title: "Un solo proveedor para todo el montaje",
    body: "Estación, mobiliario, iluminación y carpa desde un mismo pedido y una sola coordinación. Sin gestionar cuatro proveedores distintos que no se hablan entre sí — un solo punto de contacto que responde por el evento completo.",
  },
  {
    title: "Reposición y colchón en sitio",
    body: "Cargamos insumos de respaldo y equipo de reposición en cada servicio. Si algo falla durante el montaje —un dispensador, una plancha, una conexión— lo resolvemos en el momento, sin que el servicio de tu evento se detenga.",
  },
  {
    title: "Cadena de frío e inocuidad garantizada",
    body: "Para estaciones con alimentos mantenemos refrigeración con temperatura controlada y protocolo de inocuidad. El equipo de cocina se sanitiza antes de cada evento — la seguridad alimentaria no es opcional cuando sirves a cientos de invitados.",
  },
];

const steps = [
  { n: 1, t: "Cotización y visita técnica", p: "Nos indicas tipo de evento, número de invitados, fecha y qué estaciones te interesan. En menos de 24 horas te enviamos propuesta y, si el evento lo amerita, agendamos visita técnica gratuita al venue para evaluar gas, corriente y extracción." },
  { n: 2, t: "Diseño y distribución de estaciones", p: "Definimos cuántas estaciones necesitas según el aforo, el estilo visual de cada una y su ubicación en el layout para que el flujo de invitados sea cómodo. Coordinamos con tu wedding planner, decoradora o el propio salón si ya trabajas con alguien." },
  { n: 3, t: "Montaje y pruebas previas", p: "Llegamos con anticipación el día del evento —o la tarde anterior según acuerdo— para instalar cada estación, conectar equipo, montar la decoración base y probar funcionamiento. Todo queda listo y verificado antes de que llegue el primer invitado." },
  { n: 4, t: "Servicio en evento y desmontaje", p: "Durante el evento el equipo opera con reposición de insumos en sitio. Al finalizar recogemos, limpiamos y desmontamos sin presiones de tiempo si la celebración se extiende — el horario de retiro se acuerda con anticipación." },
];

const faqs = [
  {
    question: "¿Qué incluye la renta de una estación de servicio?",
    answer: "Cada estación incluye el mobiliario especializado (barra, mesa, plancha o equipo según el tipo), montaje y desmontaje profesional, mantelería o decoración base, utensilios de servicio, iluminación integrada y personal de montaje. Estaciones como las barras LED incluyen la estructura iluminada con control de color. El servicio de alimentos, chef o bartender se cotiza por separado o como paquete integral — tú eliges qué necesitas.",
  },
  {
    question: "¿Puedo traer mi propio catering y solo rentar las estaciones?",
    answer: "Sí, absolutamente. Muchos clientes rentan únicamente el mobiliario y equipo de las estaciones (barras, planchas, mesas de postres, fuentes de chocolate) y contratan su propio servicio de catering o chef. Nosotros nos encargamos del montaje, la estructura y los complementos. También ofrecemos paquetes integrales con chef, meseros y alimentos si prefieres una sola coordinación.",
  },
  {
    question: "¿Cuántas estaciones necesito según el número de invitados?",
    answer: "Como regla general recomendamos 1 estación por cada 80–100 invitados para mantener un flujo cómodo sin filas largas. Para eventos de 100 a 200 personas, 2 a 3 estaciones son ideales; de 200 a 400 personas, 3 a 5 estaciones; y para eventos masivos de 400+ personas, 5 o más distribuidas estratégicamente. En la visita técnica te ayudamos a planificar la distribución óptima según tu venue.",
  },
  {
    question: "¿Qué requerimientos eléctricos o de gas necesitan las estaciones?",
    answer: "Las barras LED y las fuentes de chocolate usan corriente estándar (110V). Las estaciones de tacos con trompo y parrilla funcionan con gas LP (tanque incluido en la renta). Las estaciones de cocina en vivo con wok o plancha requieren gas y extracción de humo, o se ubican en área ventilada. Realizamos una visita técnica previa para evaluar las instalaciones de tu venue y garantizar que todo opere de forma segura.",
  },
  {
    question: "¿Cuánto tiempo toma el montaje de las estaciones?",
    answer: "El montaje de una estación individual toma entre 1 y 2 horas. Para paquetes de múltiples estaciones el montaje completo requiere de 3 a 5 horas según la cantidad y complejidad. Las barras LED y fuentes de chocolate necesitan 30 minutos adicionales de calibración. Llegamos con suficiente anticipación para que todo esté listo antes de que lleguen tus invitados; el desmontaje se realiza al finalizar el evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar las estaciones de servicio?",
    answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas). Las barras LED y las estaciones de tacos con trompo son las más solicitadas y se agotan primero. Para eventos grandes con múltiples estaciones o paquetes completos, lo ideal es apartar con 2 meses. Atendemos solicitudes de última hora sujetas a disponibilidad.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Estaciones de Servicio para Eventos en CDMX",
    description: "Estaciones de servicio para eventos en CDMX: barras de bebidas LED, tacos y parrilla, mesas de postres y cocina en vivo con chef. Montaje profesional incluido.",
    url: "/servicios/catering/estaciones-servicio/",
    image: "/images/barras/barra-bebidas-led-nocturna-corporativo.avif",
    priceRange: { min: 1500, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering y Barras", url: "/servicios/catering/" },
    { name: "Estaciones de Servicio", url: "/servicios/catering/estaciones-servicio/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Estaciones de Servicio" },
];
---

<PageLayout
  title="Renta de Estaciones de Servicio para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/barras/barra-bebidas-led-nocturna-corporativo.avif"
  description="Renta de estaciones de servicio para eventos en CDMX: barras de bebidas LED, tacos y parrilla, mesas de postres y cocina en vivo. Montaje incluido."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="estaciones-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Estaciones de servicio · CDMX y ZMVM</p>
            <h1 id="estaciones-hero-heading">
              Las estaciones que convierten tu catering en una <em>experiencia que se ve y se recuerda</em>
            </h1>
            <p class="hm-hero__lead">
              Barras de bebidas con LED, taquizas y parrilla en vivo, mesas de postres
              temáticas y cocina en vivo con chef. Montaje profesional, equipo completo
              y visita técnica sin costo — todo desde una sola empresa para que tu evento
              sepa tan bien como se ve.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20estaciones%20de%20servicio%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar estaciones
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver tipos de estación
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>estaciones de servicio para eventos</strong> con el
              equipamiento más completo de la Ciudad de México: barras de bebidas móviles
              con iluminación LED, taquizas gourmet con trompo de pastor y parrilla en vivo,
              mesas de postres y candy bar personalizados, y estaciones de cocina en vivo
              con chef interactivo. Cada estación se monta con diseño, equipo profesional y
              decoración coordinada con el concepto de tu evento. Para el mobiliario de mesas
              y áreas de estar coordinamos el <a href="/servicios/mobiliario/">mobiliario del evento</a>
              en el mismo pedido.
            </p>
            <p>
              Con <strong>cientos de eventos servidos</strong> en CDMX y zona metropolitana,
              sabemos que la diferencia entre un catering funcional y uno memorable está en
              cómo se sirve. Trae tu propio catering y nosotros ponemos las estaciones, o te
              armamos la experiencia completa con chef y bartender. Combínalas con
              <a href="/servicios/iluminacion/">iluminación profesional</a> para que cada
              estación sea también un punto visual del evento.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de estación de servicio disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20estaciones%20de%20servicio%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La experiencia gastronómica, en estaciones</p>
            <h2 id="catalogo-heading">¿Qué estación necesita tu evento?</h2>
            <p class="hm__head-sub">4 líneas de estación — o todas juntas para un recorrido gastronómico completo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La estación de servicio es donde el catering deja de ser solo comida y se
              vuelve parte del espectáculo. Una barra de coctelería con iluminación, una
              taquiza con trompo girando frente a los invitados, una mesa de postres que
              parece salida de una revista o un chef preparando sushi al momento: cada
              estación es un punto de reunión y una foto que tus invitados van a compartir.
            </p>
            <p>
              No se trata solo de alimentar a la gente — se trata de darle al evento
              momentos de sabor y sorpresa que se recuerdan. Eso es lo que montamos.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={s.imageAlt} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada estación, a fondo</p>
            <h2 id="detalle-heading">Las 4 estaciones — en detalle</h2>
            <p class="hm__head-sub">Qué incluye cada línea, cómo se monta y para qué tipo de evento y aforo funciona mejor.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada estación hay decisiones que definen la experiencia: el equipo
              que permite servir con fluidez sin filas, la iluminación que la convierte en
              punto visual, la logística de gas y extracción que la hace segura, y el diseño
              que la integra a la decoración. Conocer esas diferencias te permite elegir la
              combinación correcta para tu evento — y no solo por presupuesto.
            </p>
          </div>
        </div>

        <!-- BARRAS DE BEBIDAS -->
        <article class="hm-feat" aria-labelledby="feat-barras">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Barras de Bebidas</p>
            <h3 class="hm-feat__title" id="feat-barras">El centro de la fiesta — barras móviles con diseño premium e iluminación que marca el ambiente</h3>
            <p class="hm-feat__lead">La barra de bebidas no es solo un punto de servicio: es donde los invitados se reúnen, brindan y toman las fotos. Por eso la montamos como una instalación, no como una mesa con botellas.</p>
            <p>
              Nuestras <strong>barras móviles con iluminación LED integrada</strong> cambian
              de color según la temática del evento y están disponibles en configuraciones de
              2, 3 y 4 metros de largo. Cada barra incluye estructura de soporte independiente,
              backbar refrigerado, cristalería completa, hielera industrial, utensilios de
              coctelería profesional y frente decorativo personalizable. Las
              <strong>estaciones de coctelería</strong> se montan con superficie de trabajo,
              torre de dispensadores y todo lo que el bartender necesita para operar sin improvisar.
            </p>
            <p>
              Sumamos <strong>barras de vino y cerveza</strong> con dispensadores de grifo y
              enfriadores integrados, y <strong>estaciones de café tipo barista</strong> con
              máquina espresso profesional, molinillo y menú de bebidas calientes para bodas,
              corporativos y break de congresos. El servicio de bartender profesional se cotiza
              como complemento. Combina la barra con nuestra
              <a href="/servicios/iluminacion/">iluminación arquitectónica</a> para multiplicar
              el efecto visual en el salón.
            </p>
            <ul class="hm-feat__stats">
              {["Barra 2 / 3 / 4 m", "LED RGB", "Backbar refrigerado", "Cristalería incluida", "Bartender opcional"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/catering/estaciones-servicio/barras-bebidas/">
              Ver Barras de Bebidas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/barras/barra-bebidas-led-nocturna-corporativo.avif" alt="Barra de bebidas con iluminación LED en evento corporativo nocturno en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Barra de coctelería de madera montada para boda de lujo" loading="lazy" decoding="async" />
              <img src="/images/barras/barra-bebidas-vinos-whiskey-corporativo.avif" alt="Barra de vinos y whiskey montada para evento corporativo premium" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- TACOS Y PARRILLA -->
        <article class="hm-feat" aria-labelledby="feat-tacos">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Tacos y Parrilla</p>
            <h3 class="hm-feat__title" id="feat-tacos">Taquizas, parrilla en vivo y carving stations — el sabor mexicano que conquista a todos los invitados</h3>
            <p class="hm-feat__lead">Ninguna estación genera fila más feliz que la de tacos. Es el hit garantizado de cualquier celebración — y montada con equipo profesional, sirve rápido, caliente y sin humo en el salón.</p>
            <p>
              Las <strong>taquizas gourmet con trompo de pastor</strong> se montan con trompo
              vertical a la vista, tortillas hechas a mano y salsas artesanales. La
              <strong>parrilla en vivo</strong> incluye chef asador que prepara cortes premium,
              hamburguesas gourmet, brochetas y vegetales a la plancha frente a tus invitados,
              con campana de extracción portátil para que el humo no invada el espacio. Las
              <strong>carving stations</strong> presentan cortes servidos al momento: rib eye,
              arrachera, costillas y pechuga marinada.
            </p>
            <p>
              Sumamos <strong>estaciones de cocina regional mexicana</strong> con tlacoyos,
              quesadillas, esquites y antojitos que aportan un toque auténtico. Cada estación
              incluye plancha o parrilla profesional, mesa de preparación, campana de extracción
              y servicio con presentación premium. Las estaciones al aire libre lucen mejor bajo
              una de nuestras <a href="/servicios/carpas/">carpas para eventos</a>, que crean un
              espacio techado sin perder la vista del show del asador.
            </p>
            <ul class="hm-feat__stats">
