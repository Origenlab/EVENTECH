---
/**
 * ─── Mesas de Trabajo de Acero Inoxidable — Pagina de Producto (Nivel 4) ───
 * Mesas de trabajo de acero inoxidable comercial, estaciones de preparacion,
 * estanteria y tarjas portatiles con certificacion de higiene.
 *
 * Jerarquia: Servicios > Catering > Cocina Movil > Mesas de Trabajo Inoxidable
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Cocina Movil", href: "/servicios/catering/cocina-movil/" },
  { label: "Mesas de Trabajo Inoxidable" },
];

const faqs = [
  { question: "¿Qué certificaciones de higiene tienen las mesas y tarjas?", answer: "Todo nuestro equipo de acero inoxidable cuenta con <strong>certificación NOM (Norma Oficial Mexicana)</strong> para contacto con alimentos y <strong>certificación NSF International</strong>, el estándar global más reconocido en seguridad alimentaria. El acero inoxidable grado 304 que utilizamos es el mismo que se emplea en cocinas industriales de hospitales y restaurantes. Antes de cada evento realizamos <strong>sanitización certificada</strong> con documentación disponible si tu evento requiere permisos sanitarios de COFEPRIS o la delegación correspondiente." },
  { question: "¿Cuánto peso soportan las mesas de trabajo?", answer: "Nuestras mesas de trabajo están diseñadas para uso industrial intensivo. La <strong>mesa de 1.2 metros</strong> soporta hasta 200 kg de carga distribuida. Las <strong>mesas de 1.5 y 1.8 metros</strong> soportan hasta 250 kg gracias a su estructura reforzada con entrepaño inferior y patas de calibre grueso. La <strong>estantería de 4 niveles</strong> soporta 200 kg por nivel (800 kg totales). Todas cuentan con patas ajustables con niveladores para garantizar estabilidad en superficies irregulares como jardines, terrazas y pisos de carpa." },
  { question: "¿Las tarjas portátiles tienen agua caliente?", answer: "Sí, nuestras tarjas portátiles cuentan con <strong>sistema de agua caliente y fría autónomo</strong>. La tarja de 1 tina incluye un calentador eléctrico de paso que proporciona agua caliente instantánea para lavado de manos y utensilios. La tarja de 2 tinas cuenta con mezcladora profesional de palanca para control preciso de temperatura. Ambas incluyen <strong>tanque de agua limpia de 80 litros y tanque de agua gris de 80 litros</strong>, bomba de presión eléctrica y conexión a 110V estándar. El servicio incluye tanques llenos al inicio del evento." },
  { question: "¿Puedo combinar mesas de trabajo con otro equipo de cocina?", answer: 'Las mesas de trabajo son la base de cualquier operación de cocina móvil. Las combinaciones más solicitadas son: <strong>mesa + parrilla</strong> para estaciones de preparación y emplatado junto al asado, <strong>mesa + horno</strong> para zonas de horneado con superficie de trabajo amplia, y <strong>mesa + tarja + estantería</strong> para una estación de preparación completa con lavado y almacenamiento. Ofrecemos paquetes de cocina completa con descuentos especiales. Visita nuestra página de <a href="/servicios/catering/cocina-movil/">cocina móvil</a> para ver todas las opciones.' },
  { question: "¿Cómo se transportan las mesas y tarjas al venue?", answer: "Todo nuestro equipo se transporta en <strong>vehículos cerrados con rampa</strong> para proteger las superficies de acero inoxidable durante el traslado. Las mesas son desarmables (patas desmontables) para facilitar el transporte y acceso a espacios reducidos. Las tarjas portátiles incluyen ruedas para fácil desplazamiento dentro del venue. Nuestro equipo de logística se encarga de la <strong>descarga, armado, nivelación e instalación</strong> de todas las piezas. El servicio cubre toda la CDMX y zona metropolitana sin costo adicional." },
  { question: "¿El equipo funciona bien en eventos al aire libre?", answer: "Sí, todo nuestro equipo de acero inoxidable está diseñado para uso en <strong>interiores y exteriores</strong>. El acero grado 304 es resistente a la corrosión, humedad y cambios de temperatura. Las patas ajustables con niveladores permiten instalar las mesas en superficies irregulares como césped, grava y pisos de carpa. Para eventos al aire libre, recomendamos complementar con una <a href='/servicios/carpas/'>carpa</a> para proteger el área de preparación del sol y la lluvia, y una <a href='/servicios/accesorios/plantas-energia/'>planta de energía</a> si se requieren conexiones eléctricas para tarjas y equipos." },
];

const specs = [
  { label: "Mesas trabajo", value: "1.2, 1.5 y 1.8 metros" },
  { label: "Material", value: "Acero inoxidable 304 calibre 18" },
  { label: "Entrepaño", value: "Inferior de refuerzo incluido" },
  { label: "Estantería", value: "4 niveles, capacidad 200 kg/nivel" },
  { label: "Tarja 1 tina", value: "Con mezcladora y drenaje" },
  { label: "Tarja 2 tinas", value: "Con escurridero lateral" },
  { label: "Certificación", value: "NOM + NSF International" },
  { label: "Patas", value: "Ajustables con niveladores" },
  { label: "Capacidad mesa", value: "250 kg de carga" },
  { label: "Complementos", value: "Tablas, cuchillos, contenedores" },
];

const sidebarNav = [
  { name: "Parrillas Industriales", href: "/servicios/catering/cocina-movil/parrillas/" },
  { name: "Planchas y Freidoras", href: "/servicios/catering/cocina-movil/planchas-freidoras/" },
  { name: "Hornos de Convección", href: "/servicios/catering/cocina-movil/hornos-conveccion/" },
  { name: "Mesas de Trabajo Inoxidable", href: null, active: true },
];

const sidebarRelated = [
  { name: "Estaciones de Servicio", href: "/servicios/catering/estaciones-servicio/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Chef Eduardo Sánchez", text: "Montamos una cocina móvil completa para una boda de 200 personas en un jardín de San Ángel. Rentamos 4 mesas de 1.8m, 2 tarjas de 2 tinas y estantería de 4 niveles. Todo el equipo llegó impecable, el acero inoxidable 304 se nota de calidad profesional y las patas ajustables nivelaron perfecto en el césped. La tarja con agua caliente fue indispensable.", rating: 5, date: "2025-11-25" },
  { author: "Andrea Gutiérrez", text: "Para un festival gastronómico de 3 días rentamos 8 mesas de trabajo y 4 tarjas portátiles para las diferentes estaciones de comida. El servicio de EVENTECH fue excepcional — entregaron todo el primer día a las 6 AM, cada pieza en perfecto estado y con documentación de higiene NSF. Las tarjas con tanques de 80 litros alcanzaron perfecto para cada jornada.", rating: 5, date: "2025-10-18" },
  { author: "Luis Fernando Ortiz", text: "Organizamos un evento de catering corporativo para 300 personas y el paquete de cocina completa con mesas, tarjas y estantería fue exactamente lo que necesitábamos. La estantería de 4 niveles organizó todos nuestros insumos perfectamente y las mesas soportaron todo el peso del equipo de cocina sin problema. Muy profesional y puntual.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesas de Trabajo de Acero Inoxidable en CDMX",
    description: "Renta de mesas de trabajo de acero inoxidable comercial, estaciones de preparación, estantería y tarjas portátiles con certificación de higiene. Desde $800.",
    url: "/servicios/catering/cocina-movil/mesas-inoxidable/",
    priceRange: { min: 800, max: 3000 },
    reviews,
    ratingValue: 5,
    reviewCount: 128,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Cocina Móvil", url: "/servicios/catering/cocina-movil/" },
    { name: "Mesas de Trabajo Inoxidable", url: "/servicios/catering/cocina-movil/mesas-inoxidable/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mesas de Trabajo de Acero Inoxidable en CDMX | EVENTECH"
  description="Renta de mesas de trabajo de acero inoxidable comercial, estaciones de preparación, estantería y tarjas portátiles con certificación de higiene. Desde $800."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Certificación de higiene NOM"
    title='Renta de <span class="highlight">Mesas de Trabajo Inoxidable</span> para Eventos'
    subtitle="Mesas de trabajo de acero inoxidable 304 en tamaños de 1.2, 1.5 y 1.8 metros con entrepaño inferior, estantería de 4 niveles y tarjas portátiles de 1 y 2 tinas. Certificación NOM y NSF."
    primaryCTA={{ label: "Cotiza tu equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mesas de trabajo inoxidable para mi evento` }}
    cards={[
      {
        title: "Mesas de trabajo y estantería de acero inoxidable 304",
        content: "<strong>Renta de mesas de trabajo de acero inoxidable</strong> 304 en tamaños de 1.2, 1.5 y 1.8 metros con entrepaño inferior, estantería de 4 niveles y tarjas portátiles de 1 y 2 tinas. Calibre 18 de alta resistencia con capacidad de carga de hasta 250 kg. Patas ajustables con niveladores para superficies irregulares. Certificación NOM para contacto con alimentos y NSF International. Ideales para cocinas móviles de eventos, festivales gastronómicos y catering profesional.",
      },
      {
        title: "Certificación de higiene y complementos profesionales",
        content: "<strong>Servicio completo de mesas y tarjas</strong> con certificación de higiene NOM y NSF, superficie antibacteriana, patas ajustables y complementos de preparación profesional para cocina móvil. Incluye tablas de corte por código de color HACCP, contenedores GN y kit de sanitización. Transporte en vehículos cerrados, armado, nivelación e instalación incluidos. Cobertura completa en CDMX y zona metropolitana sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas equipo de preparación profesional para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con las mesas, tarjas y estantería ideal para tu operación de cocina"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Cocina Móvil para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas mesas de trabajo inoxidable para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas de trabajo inoxidable para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Mesas de Trabajo Inoxidable</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Mesa de Trabajo 1.5m -->
          <section class="section section--alt" aria-labelledby="mesa-150-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">La más versátil</span>
                <h2 class="showcase__title" id="mesa-150-heading">Mesa de Trabajo 1.5m</h2>
                <p class="showcase__subtitle">La mesa estándar para preparación de alimentos en cocinas móviles y estaciones de catering.</p>
                <p class="showcase__text">Nuestra <strong>mesa de trabajo de 1.5 metros</strong> es la opción más versátil del catálogo, perfecta para la mayoría de las operaciones de cocina móvil. Fabricada en <strong>acero inoxidable grado 304 calibre 18</strong> con superficie lisa antibacteriana y bordes redondeados para fácil limpieza. El <strong>entrepaño inferior de refuerzo</strong> proporciona almacenamiento adicional para insumos, contenedores y utensilios. Capacidad de carga de <strong>250 kg distribuidos</strong> sobre la superficie de trabajo.</p>
                <p class="showcase__text">Incluye <strong>patas ajustables con niveladores de rosca</strong> para compensar superficies irregulares en jardines, terrazas y pisos de carpa. La altura estándar de 90 cm es ergonómicamente ideal para trabajo de pie prolongado. Complementa con <strong>tablas de corte por código de color HACCP</strong> (rojo para carnes, verde para verduras, azul para pescado). Combínala con nuestras <a href="/servicios/catering/cocina-movil/parrillas/">parrillas industriales</a> para crear una estación de preparación y asado profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">1.5 metros</span>
                  <span class="showcase__tag">Acero 304</span>
                  <span class="showcase__tag">250 kg carga</span>
                  <span class="showcase__tag">Entrepaño incluido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Mesa 1.5m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Mesa de Trabajo 1.5m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Mesa de Trabajo 1.8m con Entrepaño -->
          <section class="section section--alt" aria-labelledby="mesa-180-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Máxima superficie de trabajo</span>
                <h2 class="showcase__title" id="mesa-180-heading">Mesa de Trabajo 1.8m con Entrepaño</h2>
                <p class="showcase__subtitle">La mesa más grande para operaciones de cocina de alto volumen y emplatado de banquetes.</p>
                <p class="showcase__text">La <strong>mesa de trabajo de 1.8 metros</strong> es nuestra opción de mayor superficie, diseñada para <strong>operaciones de cocina de alto volumen y emplatado de banquetes grandes</strong>. Con 180 cm de largo por 75 cm de ancho, ofrece el espacio necesario para que 2-3 personas trabajen simultáneamente en preparación, corte y emplatado. El <strong>entrepaño inferior reforzado</strong> de acero inoxidable proporciona almacenamiento adicional para charolas, contenedores y equipo pesado.</p>
                <p class="showcase__text">Fabricada con el mismo <strong>acero inoxidable 304 calibre 18</strong> de grado comercial con soldadura TIG sanitaria y acabado mate antirreflejo. Las <strong>patas de calibre grueso con niveladores</strong> garantizan estabilidad total incluso con carga máxima de 250 kg. Ideal para <strong>banquetes de boda, congresos corporativos y festivales gastronómicos</strong> donde se requiere preparación masiva de alimentos. Combínala con nuestros <a href="/servicios/catering/cocina-movil/hornos-conveccion/">hornos de convección</a> para una línea de producción profesional completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">1.8 metros</span>
                  <span class="showcase__tag">75 cm ancho</span>
                  <span class="showcase__tag">Entrepaño reforzado</span>
                  <span class="showcase__tag">2-3 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Mesa 1.8m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Mesa de Trabajo 1.8m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Estantería 4 Niveles -->
          <section class="section section--alt" aria-labelledby="estanteria-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Almacenamiento organizado</span>
                <h2 class="showcase__title" id="estanteria-heading">Estantería 4 Niveles</h2>
                <p class="showcase__subtitle">Estantería de acero inoxidable de 4 niveles para organizar insumos, equipo y contenedores en tu cocina móvil.</p>
                <p class="showcase__text">Nuestra <strong>estantería de 4 niveles en acero inoxidable</strong> es el complemento esencial para organizar cualquier operación de cocina móvil. Con <strong>capacidad de 200 kg por nivel</strong> (800 kg totales), almacena charolas GN, contenedores de alimentos, equipo de cocina, vajilla y utensilios con seguridad y accesibilidad. Los <strong>entrepaños perforados</strong> permiten circulación de aire para almacenamiento higiénico conforme a normativas sanitarias.</p>
                <p class="showcase__text">Fabricada en <strong>acero inoxidable con acabado cromado sanitario</strong>. Los niveles son <strong>ajustables en altura</strong> cada 5 cm para adaptarse al tamaño del equipo y contenedores que necesites almacenar. Las patas con <strong>niveladores y opcionales de ruedas con freno</strong> permiten colocarla en cualquier superficie y moverla según las necesidades del servicio. Ideal para combinar con mesas de trabajo y tarjas en una estación de preparación completa. Complementa con nuestras <a href="/servicios/catering/vajilla-cristaleria/">vajillas y cristalería</a> para tener todo organizado.</p>
                <div class="showcase__tags">
