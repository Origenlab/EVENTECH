---
/**
 * ─── Equipo de Cocina Movil para Eventos — Sub-subcategoria (Nivel 3) ───
 * Pagina especializada: Renta de Equipo de Cocina Movil para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Cocina Móvil" },
];

const COCINA = [
  {
    name: "Parrillas Industriales",
    excerpt: "Parrillas de gas y carbón de grado industrial en múltiples tamaños y capacidades BTU. Ideales para catering masivo, banquetes al aire libre y eventos corporativos.",
    cta: "Parrillas",
    href: "#parrillas-heading",
    icon: "utensils",
  },
  {
    name: "Planchas y Freidoras",
    excerpt: "Planchas industriales flat-top y freidoras de doble canasta con opciones de gas y eléctricas. Versatilidad culinaria para cualquier menú de evento.",
    cta: "Planchas",
    href: "#planchas-heading",
    icon: "package",
  },
  {
    name: "Hornos de Convección",
    excerpt: "Hornos de convección profesionales, gabinetes de conservación caliente, mesas de vapor y chafing dishes para mantener la temperatura perfecta en cada platillo.",
    cta: "Hornos",
    href: "#hornos-heading",
    icon: "layers",
  },
  {
    name: "Mesas de Trabajo Inoxidable",
    excerpt: "Mesas de trabajo de acero inoxidable comercial, estaciones de preparación, estantería y tarjas portátiles con certificación de higiene para eventos.",
    cta: "Mesas",
    href: "#mesas-heading",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Ofrecen opciones de gas y eléctricas para el equipo de cocina?", answer: "Sí, contamos con equipo en ambas modalidades. Nuestras parrillas, planchas y freidoras están disponibles en versiones de gas LP, gas natural y eléctricas. La elección depende de tu venue y la disponibilidad de conexiones. Para eventos en jardines o espacios abiertos sin instalación eléctrica de alto amperaje, recomendamos equipo de gas. Para salones con infraestructura eléctrica adecuada (220V trifásico), las opciones eléctricas ofrecen mayor control de temperatura. Nuestro equipo técnico evalúa tu espacio y te recomienda la mejor opción." },
  { question: "¿El equipo de cocina cuenta con certificaciones de seguridad alimentaria?", answer: "Todo nuestro equipo de cocina móvil cumple con las normas NOM de seguridad alimentaria y está fabricado en acero inoxidable grado 304, aprobado para contacto con alimentos. Las mesas de trabajo y tarjas cuentan con certificación NSF International. Realizamos limpieza profunda y sanitización certificada antes y después de cada evento. Además, proporcionamos documentación de higiene si tu evento requiere permisos sanitarios especiales de COFEPRIS o la delegación correspondiente." },
  { question: "¿Incluyen entrega, instalación y recolección del equipo?", answer: "Sí, todos nuestros paquetes de cocina móvil incluyen transporte en vehículos especializados, descarga con equipo de carga, instalación completa en el área designada, conexión de gas (tanques incluidos) o eléctrica, verificación de funcionamiento y una prueba de encendido. Al finalizar tu evento, nuestro equipo regresa para el desmontaje y recolección. El servicio cubre toda la CDMX y zona metropolitana sin costo adicional. Para ubicaciones fuera del área metropolitana, cotizamos el envío por separado." },
  { question: "¿Qué requerimientos eléctricos necesita el equipo de cocina?", answer: "Los requerimientos varían según el equipo. Las parrillas y planchas de gas solo requieren una conexión eléctrica estándar de 110V para el encendido electrónico. Los hornos de convección eléctricos necesitan conexión de 220V monofásico o trifásico (según modelo). Las freidoras eléctricas industriales requieren 220V con circuito dedicado de 30A mínimo. Si tu venue no cuenta con la infraestructura eléctrica necesaria, podemos incluir una planta de energía portátil en tu paquete — consulta nuestros accesorios de plantas de energía." },
  { question: "¿Puedo combinar el equipo de cocina con renta de carpas?", answer: "Por supuesto, es una de las combinaciones más populares. Una carpa estructural o tipo hangar proporciona el espacio techado ideal para montar tu cocina móvil, protegiéndola del sol, lluvia y viento. Ofrecemos paquetes integrados de cocina + carpa con descuentos especiales. Nuestras carpas incluyen pisos nivelados y laterales removibles para ventilación. Visita nuestra sección de carpas para eventos para conocer todas las opciones disponibles y armar tu paquete completo." },
  { question: "¿Con cuánta anticipación debo reservar el equipo de cocina móvil?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas de abril a junio). Para eventos grandes que requieran paquetes completos de cocina (parrillas + hornos + mesas + tarjas), lo ideal es apartar con 1 a 2 meses. Las parrillas industriales y hornos de convección son los equipos más solicitados y se agotan primero. También atendemos solicitudes de último momento sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo de Cocina Móvil para Eventos en CDMX",
    description: "Parrillas industriales, planchas, freidoras, hornos de convección y mesas de trabajo inoxidable para catering y eventos. Entrega e instalación incluidas.",
    url: "/servicios/catering/cocina-movil/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Cocina Móvil", url: "/servicios/catering/cocina-movil/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Equipo de Cocina Móvil para Eventos en CDMX"
  description="Renta de parrillas industriales, planchas, freidoras, hornos de convección y mesas de acero inoxidable para eventos en CDMX. Entrega incluida. Desde $500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Equipo profesional de cocina para eventos"
    title='Renta de <span class="highlight">Cocina Móvil</span> para Eventos en CDMX'
    subtitle="Parrillas industriales, planchas, freidoras, hornos de convección y mesas de trabajo en acero inoxidable. Equipo comercial certificado con entrega, instalación y soporte técnico incluidos."
    primaryCTA={{ label: "Cotiza tu equipo de cocina", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo de cocina móvil para mi evento` }}
    cards={[
      {
        title: "Equipo de cocina comercial para cualquier tipo de evento",
        content: "<strong>Renta de equipo de cocina móvil para eventos</strong> con la más amplia variedad de equipamiento profesional en CDMX. Parrillas industriales de gas y carbón con capacidades desde 40,000 hasta 120,000 BTU para banquetes masivos. Planchas flat-top y freidoras de doble canasta para menús versátiles. Hornos de convección profesionales y gabinetes de conservación caliente para mantener cada platillo en su punto perfecto. Mesas de trabajo en acero inoxidable grado 304 con certificación NSF — todo el equipamiento que necesitas para operar una cocina completa en cualquier venue.",
      },
      {
        title: "Entrega, instalación y soporte técnico completo",
        content: "<strong>Servicio integral de cocina móvil</strong> que incluye transporte en vehículos especializados, descarga con equipo de carga, instalación completa con conexiones de gas y verificación eléctrica, prueba de encendido de cada equipo y soporte técnico durante tu evento. Tanques de gas LP incluidos en equipos de combustión. Sanitización certificada pre y post evento con documentación COFEPRIS disponible. Desmontaje y recolección sin costo adicional en toda la CDMX y zona metropolitana.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas equipo de cocina profesional para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con el equipo ideal para tu menú y número de comensales"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo de cocina
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Cocina Móvil"
        subtitle="Equipamiento profesional para cada necesidad gastronómica"
        description={[
          "Desde parrillas industriales para asados masivos hasta mesas de trabajo certificadas para preparación higiénica. Contamos con el inventario de equipo de cocina móvil más completo de la Ciudad de México.",
          "Cada equipo incluye entrega, instalación, conexiones de gas o eléctricas, verificación de funcionamiento y recolección. Acero inoxidable comercial y certificaciones de seguridad alimentaria garantizadas."
        ]}
      />

      <div class="grid grid--4">
        {COCINA.map((equipo) => (
          <Card
            name={equipo.name}
            excerpt={equipo.excerpt}
            cta={equipo.cta}
            href={equipo.href}
            icon={equipo.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PARRILLAS INDUSTRIALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="parrillas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Potencia profesional</span>
          <h2 class="showcase__title" id="parrillas-heading">Parrillas Industriales</h2>
          <p class="showcase__subtitle">Parrillas de gas y carbón de grado comercial para banquetes, asados masivos y catering profesional.</p>
          <p class="showcase__text">Nuestras <strong>parrillas industriales</strong> están disponibles en versiones de <strong>gas LP, gas natural y carbón</strong> con capacidades desde <strong>40,000 hasta 120,000 BTU</strong>. Fabricadas en acero inoxidable de alta resistencia con quemadores de acero fundido y rejillas de hierro esmaltado. Disponibles en tamaños de <strong>60 cm, 90 cm, 120 cm y 180 cm</strong> de ancho para adaptarse al volumen de tu evento. Ideales para empresas de catering, banquetes al aire libre, asados corporativos y festivales gastronómicos con capacidad de servir desde 50 hasta 500+ comensales.</p>
          <p class="showcase__text">Incluyen <strong>reguladores de presión certificados, mangueras de alta resistencia y tanques de gas LP</strong> (para modelos de gas). Las parrillas de carbón cuentan con compartimento de cenizas y sistema de ventilación regulable para control preciso de temperatura. Cada parrilla se entrega con prueba de encendido y verificación de seguridad. Combínalas con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para crear estaciones de asado techadas y protegidas del clima.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Gas LP</span>
            <span class="showcase__tag">Gas Natural</span>
            <span class="showcase__tag">Carbón</span>
            <span class="showcase__tag">40K-120K BTU</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Parrillas Industriales
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2h18v8H3z"/>
              <path d="M3 10h18v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4z"/>
              <line x1="8" y1="16" x2="8" y2="20"/>
              <line x1="16" y1="16" x2="16" y2="20"/>
              <line x1="6" y1="20" x2="18" y2="20"/>
              <line x1="7" y1="2" x2="7" y2="0"/>
              <line x1="12" y1="2" x2="12" y2="0"/>
              <line x1="17" y1="2" x2="17" y2="0"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PLANCHAS Y FREIDORAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="planchas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Versatilidad culinaria</span>
          <h2 class="showcase__title" id="planchas-heading">Planchas y Freidoras</h2>
          <p class="showcase__subtitle">Planchas flat-top industriales y freidoras de doble canasta para menús versátiles en cualquier evento.</p>
          <p class="showcase__text">Nuestras <strong>planchas industriales flat-top</strong> ofrecen una superficie de cocción continua de acero laminado en caliente con grosor de 12 mm para distribución uniforme del calor. Disponibles en <strong>60 cm, 90 cm y 120 cm</strong> con zona fría incorporada para mantener ingredientes a temperatura. Las <strong>freidoras de doble canasta</strong> cuentan con capacidad de 15 a 30 litros de aceite, termostato digital de precisión (150°C a 200°C) y sistema de drenaje rápido. Opciones de <strong>gas y eléctricas (dual-fuel)</strong> para adaptarse a cualquier venue.</p>
          <p class="showcase__text">Incluyen <strong>cubiertas antisalpicaduras, termómetros industriales y utensilios de cocción profesional</strong>. Ideales para estaciones de tacos, hamburguesas gourmet, alitas, papas fritas y cualquier preparación que requiera plancha o fritura profunda. Perfectas para food trucks, estaciones de comida en festivales y catering de alto volumen. Complementa con nuestros <a href="/servicios/accesorios/">accesorios para eventos</a> como señalización de menú y alfombras antifatiga para el área de cocina.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Plancha 60-120 cm</span>
            <span class="showcase__tag">Freidora 15-30 L</span>
            <span class="showcase__tag">Gas / Eléctrica</span>
            <span class="showcase__tag">Dual-Fuel</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Planchas y Freidoras
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="6" width="20" height="12" rx="2"/>
              <line x1="6" y1="6" x2="6" y2="2"/>
              <line x1="12" y1="6" x2="12" y2="3"/>
              <line x1="18" y1="6" x2="18" y2="2"/>
              <line x1="6" y1="18" x2="6" y2="22"/>
              <line x1="18" y1="18" x2="18" y2="22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HORNOS DE CONVECCIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="hornos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Cocción perfecta</span>
          <h2 class="showcase__title" id="hornos-heading">Hornos de Convección</h2>
          <p class="showcase__subtitle">Hornos profesionales, gabinetes de conservación y equipos de servicio caliente para mantener cada platillo en su punto.</p>
          <p class="showcase__text">Nuestros <strong>hornos de convección profesionales</strong> cuentan con ventilación forzada para distribución uniforme del calor, capacidad de <strong>5, 10 y 20 charolas estándar</strong>, control digital de temperatura (50°C a 300°C) y temporizador programable. Complementados con <strong>gabinetes de conservación caliente (holding cabinets)</strong> de 12 a 24 charolas que mantienen los alimentos a temperatura de servicio (60°C-85°C) durante horas sin resecarlos. <strong>Mesas de vapor (steam tables)</strong> de 3 a 6 pozos con control individual de temperatura y <strong>chafing dishes</strong> de acero inoxidable en formato redondo y rectangular.</p>
          <p class="showcase__text">Incluyen <strong>charolas de acero inoxidable, rejillas de enfriamiento y guantes térmicos industriales</strong>. El horno de convección es esencial para catering de bodas, eventos corporativos de gran escala y banquetes donde se requiere preparación simultánea de múltiples platillos. Los gabinetes de conservación son indispensables para buffets prolongados. Combina con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para presentaciones de chef o demostraciones culinarias en vivo durante tu evento.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Horno 5-20 charolas</span>
            <span class="showcase__tag">Holding Cabinet</span>
            <span class="showcase__tag">Steam Table</span>
            <span class="showcase__tag">Chafing Dish</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Hornos y Conservación
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="20" rx="2"/>
              <rect x="7" y="5" width="10" height="8" rx="1"/>
              <line x1="7" y1="17" x2="10" y2="17"/>
              <line x1="14" y1="17" x2="17" y2="17"/>
              <circle cx="12" cy="17" r="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS DE TRABAJO INOXIDABLE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="mesas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Higiene certificada</span>
          <h2 class="showcase__title" id="mesas-heading">Mesas de Trabajo Inoxidable</h2>
          <p class="showcase__subtitle">Mesas de acero inoxidable comercial, estaciones de preparación, estantería y tarjas portátiles para cocinas de evento.</p>
          <p class="showcase__text">Nuestras <strong>mesas de trabajo en acero inoxidable grado 304</strong> cumplen con certificación NSF International para contacto con alimentos. Disponibles en dimensiones de <strong>120×60 cm, 150×70 cm y 180×75 cm</strong> con refuerzos inferiores y patas ajustables para superficies irregulares. <strong>Estaciones de preparación</strong> con tablas de corte intercambiables por código de color (HACCP). <strong>Estantería de almacenamiento</strong> de 4 y 5 niveles en acero inoxidable para organizar insumos y equipo. <strong>Tarjas portátiles</strong> de uno y dos pozos con sistema de agua caliente y fría autónomo — grado comercial para cumplir normativas sanitarias.</p>
          <p class="showcase__text">Incluyen <strong>niveladores ajustables, conexiones de agua rápida y kit de sanitización</strong>. Las mesas de trabajo son la base de cualquier operación de cocina móvil profesional — desde la preparación de ingredientes hasta el emplatado final. Las tarjas portátiles son obligatorias por normativa para cualquier operación de alimentos en eventos. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario para eventos</a> para crear áreas de servicio completas con mesas de buffet y sillas para comensales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Acero Inox 304</span>
            <span class="showcase__tag">Certificación NSF</span>
            <span class="showcase__tag">Tarjas Portátiles</span>
            <span class="showcase__tag">Estantería 4-5 niveles</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Mesas Inoxidable
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="8" width="20" height="3" rx="1"/>
              <line x1="5" y1="11" x2="5" y2="20"/>
              <line x1="19" y1="11" x2="19" y2="20"/>
              <line x1="3" y1="20" x2="7" y2="20"/>
              <line x1="17" y1="20" x2="21" y2="20"/>
              <line x1="5" y1="15" x2="19" y2="15"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Cocina Móvil"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu equipo de cocina móvil, es natural tener preguntas sobre opciones de combustible, certificaciones, logística y requerimientos técnicos. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
