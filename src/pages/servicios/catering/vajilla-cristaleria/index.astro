---
/**
 * ─── Vajilla y Cristalería para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Vajilla y Cristalería para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const VAJILLA = [
  {
    name: "Platos y Vajilla",
    excerpt: "Vajilla de porcelana blanca, borde dorado y charger plates para banquetes formales, bodas y eventos corporativos. Platos trinche, ensalada, pan y postre.",
    cta: "Platos",
    href: "#platos-heading",
    icon: "utensils",
  },
  {
    name: "Copas y Cristalería",
    excerpt: "Copas de vino tinto, blanco, champagne, vasos highball, copas de coctelería, caballitos y tarros cerveceros. Cristal y vidrio templado disponibles.",
    cta: "Copas",
    href: "#copas-heading",
    icon: "crown",
  },
  {
    name: "Cubiertos y Charolas",
    excerpt: "Cubiertos de acero inoxidable y silver-plated para servicio formal. Charolas de servicio, paneras y bandejas para presentaciones impecables en cada mesa.",
    cta: "Cubiertos",
    href: "#cubiertos-heading",
    icon: "award",
  },
  {
    name: "Equipo de Servicio",
    excerpt: "Samovares, chafing dishes, dispensadores de bebidas, bases para pastel y poncheras para banquetes profesionales con servicio de primer nivel.",
    cta: "Equipo",
    href: "#equipo-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Cuál es el pedido mínimo de vajilla para eventos?", answer: "Nuestro pedido mínimo es de 50 servicios (50 personas). Cada servicio incluye plato trinche, plato ensalada, plato pan, plato postre, copa de vino, copa de agua, vaso highball y juego completo de cubiertos (5 piezas). Para eventos más pequeños podemos hacer excepciones según disponibilidad. Contamos con inventario para atender banquetes de hasta 2,000 personas en un solo evento." },
  { question: "¿Qué pasa si se rompe o daña alguna pieza durante el evento?", answer: "Entendemos que en eventos con muchos invitados pueden ocurrir accidentes. Incluimos un margen de tolerancia del 2% sobre el total de piezas rentadas sin cargo adicional. Las piezas que excedan ese margen se cobran a precio de reposición: platos de porcelana desde $180, copas de cristal desde $120 y cubiertos desde $45 por pieza. Recomendamos contratar nuestro seguro de protección que cubre hasta el 10% del inventario por solo $500 adicionales." },
  { question: "¿Cómo funciona la entrega y recolección de la vajilla?", answer: "Entregamos la vajilla un día antes del evento o el mismo día por la mañana, según tu preferencia. Llega en cajas de transporte especializadas con divisores acolchados para evitar daños. Incluimos un inventario detallado que firmamos en conjunto. La recolección se realiza al día siguiente del evento. Solo pedimos que las piezas estén enjuagadas (sin necesidad de lavarlas a fondo) y organizadas en las mismas cajas. El transporte dentro de CDMX está incluido." },
  { question: "¿Puedo combinar diferentes estilos de vajilla en un mismo evento?", answer: "Por supuesto, la mezcla de estilos es una tendencia muy popular en bodas y eventos de diseño. Puedes combinar platos base dorados con vajilla blanca, copas de cristal cortado con vasos modernos, o cubiertos silver-plated con servilleteros rústicos. Nuestro equipo de asesoría te ayuda a crear la combinación perfecta. Te enviamos fotos de montajes previos para que visualices el resultado antes de confirmar tu selección." },
  { question: "¿La vajilla se entrega lavada y lista para usar?", answer: "Sí, toda nuestra vajilla se entrega completamente lavada, sanitizada y pulida lista para colocar en las mesas. Cada pieza pasa por un proceso de lavado industrial con agua a 82°C, secado con aire caliente y pulido manual. Las copas de cristal se pulen individualmente para eliminar manchas de agua. Al momento de la recolección, solo necesitas enjuagar las piezas; nosotros nos encargamos del lavado profesional posterior sin costo adicional." },
  { question: "¿Con cuánta anticipación debo reservar la vajilla para mi evento?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo a junio). Para eventos de más de 300 personas o que requieran vajilla especializada como charger plates dorados o cristalería de diseño, lo ideal es apartar con 2 meses de anticipación. Aceptamos solicitudes de última hora sujetas a disponibilidad, pero la variedad de estilos puede ser limitada." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Vajilla y Cristalería para Eventos en CDMX",
    description: "Vajilla de porcelana, copas de cristal, cubiertos y equipo de servicio para banquetes, bodas y eventos corporativos. Entrega sanitizada y lista para usar.",
    url: "/servicios/catering/vajilla-cristaleria/",
    priceRange: { min: 500, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Vajilla y Cristalería", url: "/servicios/catering/vajilla-cristaleria/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Vajilla y Cristalería para Eventos en CDMX"
  description="Renta de vajilla de porcelana, copas de cristal, cubiertos y equipo de servicio para eventos en CDMX. Entrega sanitizada. Desde $15 por persona. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Elegancia en cada detalle de tu mesa"
    title='Renta de <span class="highlight">Vajilla y Cristalería</span> para Eventos en CDMX'
    subtitle="Vajilla de porcelana premium, copas de cristal fino y cubiertos profesionales para banquetes de 50 a 2,000 personas. Entrega sanitizada, pulida y lista para usar."
    primaryCTA={{ label: "Cotiza tu vajilla", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar vajilla y cristalería para mi evento` }}
    cards={[
      {
        title: "Vajilla y cristalería de grado profesional para cada banquete",
        content: "<strong>Renta de vajilla y cristalería para eventos</strong> con la calidad más alta disponible en CDMX. Platos de porcelana blanca y borde dorado en presentaciones trinche, ensalada, pan y postre para montajes de mesa formales e informales. Copas de cristal fino para vino tinto, blanco, champagne, agua y coctelería. Cubiertos de acero inoxidable y silver-plated con terminado espejo — cada pieza inspeccionada, lavada industrialmente y pulida a mano antes de cada entrega.",
      },
      {
        title: "Servicio integral con entrega sanitizada",
        content: "<strong>Logística profesional</strong> incluida en cada renta de vajilla. Nuestro equipo se encarga del transporte en cajas especializadas con divisores acolchados, inventario detallado al momento de entrega, y recolección al día siguiente. Toda la vajilla llega sanitizada a 82°C y pulida individualmente. Atendemos banquetes desde 50 hasta 2,000 personas con vajilla uniforme y consistente en cada pieza.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas vajilla impecable para tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con la vajilla ideal para tu estilo de banquete y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de vajilla
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Vajilla y Cristalería"
        subtitle="Todo lo que necesitas para un montaje de mesa perfecto"
        description={[
          "Desde vajilla de porcelana blanca clásica hasta cristalería de diseño y cubiertos silver-plated. Contamos con el inventario de vajilla para eventos más completo de la Ciudad de México.",
          "Cada pieza incluye lavado industrial, sanitización a alta temperatura y pulido manual. Entrega en cajas especializadas con inventario detallado y recolección incluida."
        ]}
      />

      <div class="grid grid--4">
        {VAJILLA.map((item) => (
          <Card
            name={item.name}
            excerpt={item.excerpt}
            cta={item.cta}
            href={item.href}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PLATOS Y VAJILLA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="platos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Porcelana premium</span>
          <h2 class="showcase__title" id="platos-heading">Platos y Vajilla</h2>
          <p class="showcase__subtitle">Porcelana de alta calidad para montajes de mesa elegantes y memorables.</p>
          <p class="showcase__text">Nuestra <strong>vajilla de porcelana blanca</strong> es la base de un montaje de mesa impecable. Disponible en 4 presentaciones esenciales: <strong>plato trinche (27 cm), plato ensalada (21 cm), plato pan (16 cm) y plato postre (19 cm)</strong>. Línea clásica en blanco puro con bordes suaves y acabado brillante, ideal para <strong>bodas, banquetes corporativos, cenas de gala y celebraciones formales</strong>. Cada plato fabricado en porcelana de alta resistencia con certificación alimentaria.</p>
          <p class="showcase__text">Nuestra línea premium incluye <strong>vajilla con borde dorado de 24K</strong> para eventos de lujo, <strong>charger plates (platos base) en dorado, plateado, rose gold y cristal</strong> que elevan cualquier presentación de mesa. También disponemos de <strong>platos soperos, bowls para pasta, platos para sushi y tazones para consomé</strong>. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para crear ambientes de banquete excepcionales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Porcelana blanca</span>
            <span class="showcase__tag">Borde dorado</span>
            <span class="showcase__tag">Charger plates</span>
            <span class="showcase__tag">Platos soperos</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Platos y Vajilla
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       COPAS Y CRISTALERÍA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="copas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Cristal de primera</span>
          <h2 class="showcase__title" id="copas-heading">Copas y Cristalería</h2>
          <p class="showcase__subtitle">Cristal fino y vidrio templado para brindar con elegancia en cada evento.</p>
          <p class="showcase__text">Nuestra <strong>cristalería profesional</strong> cubre todas las necesidades de servicio de bebidas. <strong>Copas de vino tinto (450 ml), vino blanco (350 ml), champagne flauta (200 ml) y copa de agua (300 ml)</strong> en cristal transparente con tallo elegante y base estable. Línea de <strong>copas de coctelería: martini, margarita, coupe, old fashioned y highball</strong> para barras de servicio profesional. También disponemos de <strong>caballitos tequileros, tarros cerveceros y vasos de shot</strong> para eventos casuales y fiestas.</p>
          <p class="showcase__text">Ofrecemos dos líneas de calidad: <strong>cristal premium</strong> con mayor transparencia, brillo y ligereza para bodas y cenas de gala, y <strong>vidrio templado</strong> más resistente y económico para eventos masivos, festivales y fiestas sociales. Cada copa se entrega pulida individualmente sin manchas de agua ni huellas. Complementa tu cristalería con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para que el cristal brille bajo la luz perfecta.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Copa vino</span>
            <span class="showcase__tag">Champagne flauta</span>
            <span class="showcase__tag">Coctelería</span>
            <span class="showcase__tag">Vidrio templado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Copas y Cristalería
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2h8l-1 9H9L8 2z"/>
              <path d="M12 11v7"/>
              <path d="M8 18h8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CUBIERTOS Y CHAROLAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cubiertos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Servicio impecable</span>
          <h2 class="showcase__title" id="cubiertos-heading">Cubiertos y Charolas</h2>
          <p class="showcase__subtitle">Cubiertos profesionales y charolas de servicio para banquetes de primer nivel.</p>
          <p class="showcase__text">Nuestros <strong>cubiertos de acero inoxidable 18/10</strong> con acabado espejo son el estándar para banquetes profesionales. Cada servicio incluye <strong>cuchillo trinche, tenedor de mesa, cuchara sopera, tenedor de ensalada y cuchara de postre</strong>. Disponibles también en sets especializados con <strong>cuchillo para mantequilla, tenedor para mariscos, cuchara para consomé y pinzas para hielo</strong>. El acero 18/10 garantiza resistencia a la corrosión y un brillo duradero durante todo el evento.</p>
          <p class="showcase__text">Para eventos de lujo ofrecemos <strong>cubiertos silver-plated (bañados en plata)</strong> con grabado decorativo y terminado artesanal que aportan distinción a cada puesto de mesa. Complementamos con <strong>charolas de servicio ovaladas y rectangulares</strong> en acero inoxidable y silver-plated, <strong>paneras tejidas con forro de tela, bandejas para canapés y pinzas de servicio</strong>. Combínalos con nuestra <a href="/servicios/accesorios/">mantelería y accesorios textiles</a> para un montaje de mesa completo y coordinado.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Acero inoxidable</span>
            <span class="showcase__tag">Silver-plated</span>
            <span class="showcase__tag">Charolas servicio</span>
            <span class="showcase__tag">Paneras</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Cubiertos y Charolas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/>
              <path d="M7 2v20"/>
              <path d="M21 15V2v0a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EQUIPO DE SERVICIO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="equipo-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Para banquetes profesionales</span>
          <h2 class="showcase__title" id="equipo-heading">Equipo de Servicio</h2>
          <p class="showcase__subtitle">Samovares, chafing dishes y complementos esenciales para banquetes de alto nivel.</p>
          <p class="showcase__text">El <strong>equipo de servicio profesional</strong> es indispensable para mantener la temperatura, presentación y flujo de alimentos en cualquier banquete. Nuestros <strong>chafing dishes (baños maría) rectangulares y redondos</strong> en acero inoxidable con tapa roll-top mantienen los alimentos calientes durante horas. <strong>Samovares de 10, 15 y 20 litros</strong> para café, té y chocolate caliente con sistema de calentamiento por combustible sólido. <strong>Dispensadores de bebidas</strong> de vidrio y acero para aguas frescas, jugos y limonada con grifo de servicio.</p>
          <p class="showcase__text">Completamos tu servicio de banquete con <strong>bases para pastel (cake stands) en varios niveles</strong> para mesas de postres espectaculares, <strong>poncheras (punch bowls) de cristal con cucharón</strong>, <strong>hieleras de acero inoxidable, pinzas de hielo, termos industriales y cafeteras percoladoras</strong>. Para eventos al aire libre, recomendamos combinar con nuestras <a href="/servicios/carpas/">carpas y cubiertas</a> para proteger las estaciones de servicio del sol y la lluvia.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Chafing dishes</span>
            <span class="showcase__tag">Samovares</span>
            <span class="showcase__tag">Dispensadores</span>
            <span class="showcase__tag">Cake stands</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Equipo de Servicio
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8h1a4 4 0 010 8h-1"/>
              <path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/>
              <line x1="10" y1="1" x2="10" y2="4"/>
              <line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Vajilla y Cristalería"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu vajilla, es natural tener preguntas sobre cantidades mínimas, políticas de daños, logística y estilos disponibles. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre vajilla y cristalería al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de vajilla y cristalería para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Vajilla y Cristalería"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de vajilla y cristalería. Sin compromiso, sin costos ocultos.",
          "Ya sea vajilla para 50 personas o un banquete completo para 2,000 invitados, estamos aquí para ayudarte."
        ]}
