---
/**
 * ─── Cubiertos y Charolas — Pagina de Producto (Nivel 4) ───
 * Cubiertos de acero inoxidable y silver-plated, charolas de servicio
 * y bandejas para presentaciones impecables en banquetes.
 *
 * Jerarquia: Servicios > Catering > Vajilla y Cristalería > Cubiertos y Charolas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Catering", href: "/servicios/catering/" },
  { label: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { label: "Cubiertos y Charolas" },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre cubiertos de acero inoxidable y silver-plated?", answer: 'Los <strong>cubiertos de acero inoxidable 18/10</strong> tienen un acabado brillante tipo espejo, son altamente resistentes a la corrosión y perfectos para banquetes formales e informales. Los <strong>cubiertos silver-plated</strong> (bañados en plata) tienen un acabado más refinado con grabado decorativo artesanal, ideales para <strong>bodas de lujo, cenas de gala y eventos diplomáticos</strong>. Ambas líneas se entregan pulidas profesionalmente.' },
  { question: "¿Qué incluye un juego completo de cubiertos?", answer: 'Cada juego de <strong>5 piezas</strong> incluye: cuchillo trinche, tenedor de mesa, cuchara sopera, tenedor de postre y cuchara de café. Opcionalmente puedes agregar piezas especializadas como <strong>cuchillo para mantequilla, tenedor para mariscos, cuchara para consomé, pinzas para hielo y pinzas de servicio</strong>. Los juegos se entregan en estuches organizados para facilitar el montaje.' },
  { question: "¿Qué tipos de charolas de servicio tienen?", answer: 'Disponemos de <strong>charolas ovaladas</strong> en tamaños de 45 y 60 cm, <strong>charolas redondas</strong> de 35 y 45 cm, todas en acero inoxidable con acabado espejo. También ofrecemos <strong>charolas silver-plated</strong> con borde decorativo para servicio formal. Complementamos con paneras de acero con forro de tela, bandejas para canapés y fuentes de presentación para buffet.' },
  { question: "¿Cuál es el pedido mínimo de cubiertos?", answer: 'El pedido mínimo es de <strong>50 juegos</strong> (50 personas). Puedes rentar juegos completos de 5 piezas o piezas individuales según tus necesidades. Las charolas de servicio se rentan por unidad con un mínimo de 5 piezas. Contamos con inventario de hasta <strong>2,000 juegos</strong> disponibles para eventos grandes.' },
  { question: "¿Qué pasa si se pierde o daña alguna pieza?", answer: 'Incluimos un <strong>margen de tolerancia del 2%</strong> sin cargo adicional. Las piezas que excedan ese porcentaje se cobran a precio de reposición: cubiertos de acero desde $45 por pieza, silver-plated desde $120 por pieza, charolas desde $350. Realizamos un <strong>inventario detallado</strong> al momento de entrega y recolección para un control preciso.' },
  { question: "¿Puedo combinar cubiertos con la vajilla de EVENTECH?", answer: 'Por supuesto, es lo más recomendable. Al rentar cubiertos junto con nuestra <a href="/servicios/catering/vajilla-cristaleria/platos-vajilla/">vajilla de porcelana</a> y <a href="/servicios/catering/vajilla-cristaleria/copas-cristaleria/">cristalería</a>, garantizas un montaje de mesa coordinado y uniforme. Ofrecemos <strong>paquetes combinados con descuento</strong> cuando rentas vajilla + cubiertos + cristalería en un mismo pedido.' },
];

const specs = [
  { label: "Línea estándar", value: "Acero inoxidable 18/10" },
  { label: "Línea premium", value: "Silver-plated con estuche" },
  { label: "Juego 5 piezas", value: "Cuchillo, tenedor, cuchara, postre, café" },
  { label: "Charola ovalada", value: "45 y 60 cm acero inoxidable" },
  { label: "Charola redonda", value: "35 y 45 cm acabado espejo" },
  { label: "Panera", value: "Acero inoxidable con forro tela" },
  { label: "Pinzas servicio", value: "Profesionales de acero" },
  { label: "Pedido mínimo", value: "50 juegos" },
  { label: "Pulido", value: "Profesional incluido pre-evento" },
  { label: "Inventario", value: "Hasta 2,000 juegos disponibles" },
];

const sidebarNav = [
  { name: "Platos y Vajilla", href: "/servicios/catering/vajilla-cristaleria/platos-vajilla/" },
  { name: "Copas y Cristalería", href: "/servicios/catering/vajilla-cristaleria/copas-cristaleria/" },
  { name: "Cubiertos y Charolas", href: null, active: true },
  { name: "Equipo de Servicio", href: "/servicios/catering/vajilla-cristaleria/equipo-servicio/" },
];

const sidebarRelated = [
  { name: "Estaciones de Servicio", href: "/servicios/catering/estaciones-servicio/" },
  { name: "Cocina Móvil", href: "/servicios/catering/cocina-movil/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Mobiliario Mesas", href: "/servicios/mobiliario/mesas/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
];

const reviews = [
  { author: "Alejandra Villanueva", text: "Rentamos cubiertos silver-plated para nuestra boda de 180 personas en San Ángel Inn. Cada pieza llegó impecablemente pulida con un brillo extraordinario. Los invitados comentaron lo elegante que lucía cada puesto de mesa. Las charolas de servicio también fueron perfectas. Totalmente recomendados.", rating: 5, date: "2025-11-08" },
  { author: "Grupo Financiero BBVA", text: "Para nuestra cena ejecutiva de 120 personas necesitábamos cubiertos de primera calidad. Los juegos de acero inoxidable 18/10 fueron exactamente lo que buscábamos: elegantes, brillantes y en perfecto estado. El inventario coincidió al 100% y la recolección fue puntual. Excelente servicio.", rating: 5, date: "2025-10-22" },
  { author: "Embajada de España en México", text: "Organizamos una recepción diplomática para 100 comensales con protocolo formal de 7 tiempos. Los cubiertos silver-plated con sus piezas especializadas fueron perfectos para cada tiempo de la cena. Las charolas ovaladas con acabado espejo completaron un servicio impecable. Profesionalismo de primer nivel.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Cubiertos y Charolas para Eventos en CDMX",
    description: "Renta de cubiertos de acero inoxidable y silver-plated, charolas de servicio y bandejas para presentaciones impecables en banquetes. Desde $8 por juego.",
    url: "/servicios/catering/vajilla-cristaleria/cubiertos-charolas/",
    priceRange: { min: 8, max: 35 },
    reviews,
    ratingValue: 5,
    reviewCount: 176,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Catering", url: "/servicios/catering/" },
    { name: "Vajilla y Cristalería", url: "/servicios/catering/vajilla-cristaleria/" },
    { name: "Cubiertos y Charolas", url: "/servicios/catering/vajilla-cristaleria/cubiertos-charolas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Cubiertos y Charolas para Eventos en CDMX | EVENTECH"
  description="Renta de cubiertos de acero inoxidable y silver-plated, charolas de servicio y bandejas para presentaciones impecables en banquetes. Desde $8 por juego."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Servicio formal impecable"
    title='Renta de <span class="highlight">Cubiertos y Charolas</span> para Eventos'
    subtitle="Cubiertos de acero inoxidable 18/10 y silver-plated para servicio formal de 5 piezas. Charolas de servicio ovaladas y redondas con acabado espejo. Pulido profesional incluido."
    primaryCTA={{ label: "Cotiza tus cubiertos", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar cubiertos y charolas para mi evento` }}
    cards={[
      {
        title: "Cubiertos profesionales de acero inoxidable y silver-plated",
        content: "<strong>Renta de cubiertos para eventos</strong> con la calidad más alta disponible en CDMX. Cubiertos de acero inoxidable 18/10 y silver-plated para servicio formal de 5 piezas: cuchillo, tenedor, cuchara, tenedor postre y cuchara café. Charolas de servicio ovaladas y redondas en acero inoxidable con acabado espejo. Complementos disponibles: paneras con forro de tela, pinzas de servicio profesionales y bandejas para canapés.",
      },
      {
        title: "Pulido profesional y logística completa incluida",
        content: "<strong>Pulido profesional incluido</strong> en cada renta. Juegos completos o por pieza según tus necesidades. Charolas con acabado espejo inspeccionadas individualmente. Complementos como paneras y pinzas de servicio disponibles. Entrega en estuches organizados para facilitar el montaje de mesa. Inventario detallado al momento de entrega y recolección al día siguiente con lavado incluido.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas cubiertos impecables para tu banquete?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con los cubiertos ideales para tu estilo de servicio y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Vajilla y Cristalería</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas cubiertos y charolas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar cubiertos y charolas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Cubiertos y Charolas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Cubiertos Acero Inoxidable -->
          <section class="section section--alt" aria-labelledby="acero-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El estándar profesional</span>
                <h2 class="showcase__title" id="acero-heading">Cubiertos Acero Inoxidable</h2>
                <p class="showcase__subtitle">Acero inoxidable 18/10 con acabado espejo para banquetes formales e informales.</p>
                <p class="showcase__text">Nuestros <strong>cubiertos de acero inoxidable 18/10</strong> son el estándar de la industria de banquetes profesionales. El acabado tipo espejo refleja la luz de manera elegante y se mantiene brillante durante todo el evento. Cada juego de 5 piezas incluye: <strong>cuchillo trinche con filo preciso, tenedor de mesa con dientes uniformes, cuchara sopera de capacidad perfecta, tenedor de postre compacto y cuchara de café</strong>. El acero 18/10 (18% cromo, 10% níquel) garantiza resistencia total a la corrosión.</p>
                <p class="showcase__text">La línea de acero inoxidable es la <strong>opción más versátil</strong>: funciona igual de bien en una boda elegante que en un evento corporativo o una fiesta social. Su resistencia la hace ideal para <strong>eventos con servicio de meseros, buffets y banquetes de gran escala</strong>. Cada pieza se entrega con pulido profesional y en estuches organizados por tipo para facilitar el montaje. Complementa con nuestra <a href="/servicios/catering/vajilla-cristaleria/platos-vajilla/">vajilla de porcelana</a> para un montaje de mesa coordinado.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Acero 18/10</span>
                  <span class="showcase__tag">Acabado espejo</span>
                  <span class="showcase__tag">5 piezas por juego</span>
                  <span class="showcase__tag">Anti-corrosión</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cubiertos Acero
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Cubiertos Acero Inoxidable</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cubiertos Silver-Plated -->
          <section class="section section--alt" aria-labelledby="silver-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Lujo y distinción</span>
                <h2 class="showcase__title" id="silver-heading">Cubiertos Silver-Plated</h2>
                <p class="showcase__subtitle">Bañados en plata con grabado decorativo artesanal para eventos de alta categoría.</p>
                <p class="showcase__text">Nuestros <strong>cubiertos silver-plated (bañados en plata)</strong> representan el máximo nivel de elegancia en cubertería para eventos. Cada pieza está <strong>bañada en plata de ley con grabado decorativo artesanal</strong> que aporta textura y brillo excepcional. El juego premium incluye las 5 piezas estándar más opciones especializadas: <strong>cuchillo para mantequilla, tenedor para mariscos, cuchara para consomé y cucharilla de café</strong> para servicios de protocolo formal.</p>
                <p class="showcase__text">La línea silver-plated es la <strong>elección predilecta para bodas de lujo, cenas de gala, eventos diplomáticos y ceremonias de premiación</strong> donde cada detalle debe transmitir sofisticación. El baño de plata crea reflejos cálidos bajo la iluminación del evento que complementan cualquier centro de mesa floral. Se entregan en <strong>estuches individuales acolchados</strong> para proteger el acabado durante el transporte. Complementa con nuestra <a href="/servicios/accesorios/manteleria-textiles/">mantelería de lino</a> para una experiencia de mesa completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Baño de plata</span>
                  <span class="showcase__tag">Grabado artesanal</span>
                  <span class="showcase__tag">Estuche individual</span>
                  <span class="showcase__tag">Protocolo formal</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cubiertos Silver-Plated
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Cubiertos Silver-Plated</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Charolas de Servicio -->
          <section class="section section--alt" aria-labelledby="charolas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Presentación profesional</span>
                <h2 class="showcase__title" id="charolas-heading">Charolas de Servicio</h2>
                <p class="showcase__subtitle">Charolas ovaladas y redondas en acero inoxidable con acabado espejo para servicio impecable.</p>
                <p class="showcase__text">Nuestras <strong>charolas de servicio</strong> son indispensables para un servicio de banquete profesional. Las <strong>charolas ovaladas en tamaños de 45 y 60 cm</strong> son perfectas para servicio de platos principales, presentación de entremeses y distribución de postres. Las <strong>charolas redondas de 35 y 45 cm</strong> con acabado espejo son ideales para servicio de bebidas, canapés y petit fours. Todas fabricadas en acero inoxidable de grado profesional con bordes reforzados.</p>
                <p class="showcase__text">Complementamos las charolas con <strong>paneras de acero inoxidable con forro de tela</strong> que mantienen el pan caliente y presentable, <strong>bandejas para canapés con divisiones</strong>, y <strong>pinzas de servicio profesionales</strong> de diferentes tamaños. Para buffets, ofrecemos <strong>fuentes de presentación escalonadas</strong> que permiten exhibir los alimentos de manera atractiva y accesible. Combina con nuestros <a href="/servicios/catering/vajilla-cristaleria/equipo-servicio/">chafing dishes y samovares</a> para un servicio de buffet completo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Ovaladas 45/60 cm</span>
                  <span class="showcase__tag">Redondas 35/45 cm</span>
                  <span class="showcase__tag">Acabado espejo</span>
                  <span class="showcase__tag">Paneras y pinzas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Charolas de Servicio
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/>
                    <path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
                  </svg>
                  <span>Charolas de Servicio</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Servicio Formal Completo -->
          <section class="section section--alt" aria-labelledby="kit-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Todo para tu servicio de mesa</span>
