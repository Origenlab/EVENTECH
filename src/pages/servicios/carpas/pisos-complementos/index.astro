---
/**
 * ─── Pisos y Complementos para Carpas — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Pisos y Complementos para Carpas en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Pisos y Complementos" },
];

const COMPLEMENTOS = [
  {
    name: "Piso de Duela",
    excerpt: "Duela laminada de 12mm con acabado semi-mate sobre estructura elevada. Protección contra humedad del terreno, nivelación profesional y aspecto premium para bodas y eventos de gala.",
    cta: "Piso Duela",
    href: "#duela-heading",
    icon: "layers",
  },
  {
    name: "Alfombra Profesional",
    excerpt: "Alfombra industrial de alta densidad disponible en más de 15 colores. Instalación rápida sobre cualquier superficie para expos, ferias, eventos corporativos y pasarelas.",
    cta: "Alfombra",
    href: "#alfombra-heading",
    icon: "shield",
  },
  {
    name: "Cortinas y Forros",
    excerpt: "Forros interiores en chiffon, satín y blackout para transformar por completo el interior de tu carpa. Cortinas laterales, cielos decorativos y divisiones de espacio.",
    cta: "Cortinas",
    href: "#cortinas-heading",
    icon: "heart",
  },
  {
    name: "Clima Artificial",
    excerpt: "Calefacción industrial, enfriamiento evaporativo, aire acondicionado portátil y ventilación forzada para garantizar confort térmico en cualquier temporada del año.",
    cta: "Clima",
    href: "#clima-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué tipos de piso están disponibles para carpas?", answer: "Ofrecemos tres opciones principales: piso de duela laminada de 12mm con acabado semi-mate (ideal para bodas y galas), alfombra industrial de alta densidad en más de 15 colores (perfecta para expos y corporativos), y plataforma nivelada de madera contrachapada (base técnica para terrenos irregulares). Cada opción incluye estructura elevada con marco de aluminio o madera tratada que protege contra la humedad del suelo y garantiza una superficie firme y segura." },
  { question: "¿Se puede instalar piso sobre terreno irregular o con pendiente?", answer: "Sí, es una de nuestras especialidades. Utilizamos un sistema de plataforma nivelada con patas ajustables que compensa desniveles de hasta 40 cm. La estructura se ancla al terreno con estacas o contrapesos según el tipo de suelo (tierra, pasto, concreto). Realizamos una visita técnica previa para evaluar el terreno y diseñar la nivelación exacta. El resultado es una superficie perfectamente plana y estable, independientemente de las condiciones del terreno original." },
  { question: "¿Qué opciones de color tienen las cortinas y forros interiores?", answer: "Manejamos tres tipos de tela: chiffon (translúcido, elegante, disponible en blanco, ivory, champagne, rosa y azul cielo), satín (brillo sofisticado en blanco, ivory, dorado, plata, negro y rojo), y blackout (opaco total para control de luz en negro, blanco y gris). Los forros de techo se pueden combinar con drapeados decorativos y luces LED integradas. Para eventos corporativos ofrecemos impresión personalizada en telas para branding." },
  { question: "¿Cómo funciona la calefacción para carpas en invierno?", answer: "Utilizamos calefactores industriales de gas LP o eléctricos que distribuyen aire caliente de manera uniforme dentro de la carpa. Para carpas de hasta 100 m² usamos 2 calefactores de 30,000 BTU. Para carpas más grandes (200-500 m²) instalamos un sistema de ductos con calefactor central de 100,000+ BTU. Los forros interiores actúan como aislante térmico, mejorando la eficiencia del sistema hasta un 40%. La temperatura se mantiene entre 20-24°C incluso en noches de invierno en CDMX." },
  { question: "¿Qué opciones de enfriamiento tienen para eventos en verano?", answer: "Ofrecemos tres soluciones según el tipo de carpa: enfriamiento evaporativo (reduce 8-12°C, ideal para carpas semi-abiertas), aire acondicionado portátil de 5 a 20 toneladas (para carpas cerradas con forro), y ventilación forzada con extractores industriales (para carpas abiertas). El enfriamiento evaporativo es el más económico y ecológico, mientras que el AC portátil ofrece control preciso de temperatura. Nuestro técnico evalúa tu carpa y recomienda la mejor opción según dimensiones y número de asistentes." },
  { question: "¿Cuánto cuesta un paquete completo de piso más clima?", answer: "Los paquetes combinados ofrecen el mejor valor. Un paquete básico (piso de duela + ventilación para carpa de 50 m²) parte desde $8,000 MXN. Un paquete premium (duela + forros de satín + calefacción para carpa de 100 m²) desde $18,000 MXN. El paquete completo (duela nivelada + alfombra + forros + AC portátil para carpa de 200 m²) desde $35,000 MXN. Todos incluyen instalación, operación durante el evento y desmontaje. Cotizamos según las dimensiones exactas de tu carpa y las condiciones específicas de tu venue." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pisos y Complementos para Carpas en CDMX",
    description: "Pisos de duela, alfombra profesional, cortinas, forros y clima artificial para carpas de eventos. Instalación incluida.",
    url: "/servicios/carpas/pisos-complementos/",
    priceRange: { min: 2000, max: 60000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Pisos y Complementos", url: "/servicios/carpas/pisos-complementos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pisos y Complementos para Carpas en CDMX"
  description="Renta de pisos de duela, alfombra profesional, cortinas, forros interiores y clima artificial para carpas en CDMX. Instalación incluida. Desde $2,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Confort y acabado profesional para tu carpa"
    title='Renta de <span class="highlight">Pisos y Complementos</span> para Carpas en CDMX'
    subtitle="Pisos de duela laminada, alfombra industrial, cortinas decorativas y sistemas de clima artificial para transformar cualquier carpa en un espacio elegante y confortable."
    primaryCTA={{ label: "Cotiza tu complemento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar pisos y complementos para carpa` }}
    cards={[
      {
        title: "Pisos y acabados de grado profesional para cada carpa",
        content: "<strong>Renta de pisos y complementos para carpas</strong> con los materiales de mayor calidad disponibles en CDMX. Piso de duela laminada de 12mm con acabado semi-mate sobre estructura elevada con protección contra humedad para bodas y eventos de gala. Alfombra industrial de alta densidad en más de 15 colores para expos, ferias y corporativos. Forros interiores en chiffon, satín y blackout que transforman por completo la apariencia de tu carpa — cada complemento instalado por profesionales con experiencia en más de 800 eventos.",
      },
      {
        title: "Clima artificial para confort en cualquier temporada",
        content: "<strong>Sistemas de climatización profesional</strong> para carpas de cualquier dimensión. Calefacción industrial con ductos para noches frías de invierno, enfriamiento evaporativo ecológico para primavera y verano, aire acondicionado portátil de 5 a 20 toneladas para control preciso de temperatura, y ventilación forzada con extractores industriales. Cada sistema dimensionado según el tamaño de tu carpa, número de asistentes y condiciones climáticas del venue.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas que tu carpa luzca impecable y confortable?"
    subheadline="Cotiza sin compromiso pisos, forros y clima artificial con instalación profesional incluida"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de complemento
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pisos y Complementos"
        subtitle="Todo lo que necesitas para completar tu carpa"
        description={[
          "Desde pisos de duela premium para bodas de gala hasta sistemas de clima industrial para eventos masivos. Contamos con el catálogo de complementos para carpas más completo de la Ciudad de México.",
          "Cada complemento incluye instalación profesional, materiales certificados y soporte técnico durante tu evento. Combinaciones personalizadas para crear el ambiente perfecto dentro de tu carpa."
        ]}
      />

      <div class="grid grid--4">
        {COMPLEMENTOS.map((complemento) => (
          <Card
            name={complemento.name}
            excerpt={complemento.excerpt}
            cta={complemento.cta}
            href={complemento.href}
            icon={complemento.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISO DE DUELA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="duela-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Acabado premium</span>
          <h2 class="showcase__title" id="duela-heading">Piso de Duela</h2>
          <p class="showcase__subtitle">El acabado elegante que transforma cualquier carpa en un salón de eventos de primer nivel.</p>
          <p class="showcase__text">Nuestro <strong>piso de duela laminada de 12mm</strong> ofrece un acabado semi-mate con apariencia de madera natural que eleva la estética de cualquier carpa. Montado sobre una <strong>estructura elevada de marco de aluminio</strong> con patas ajustables, crea una superficie firme, nivelada y aislada del suelo que protege contra humedad, irregularidades del terreno y temperatura del piso. Disponible en tonos <strong>roble claro, nogal, caoba y gris moderno</strong>.</p>
          <p class="showcase__text">La estructura elevada permite compensar <strong>desniveles de hasta 40 cm</strong>, ideal para jardines, terrenos y espacios al aire libre. El sistema modular se instala en secciones de 1×1 metro que se ensamblan sin tornillos visibles, logrando una superficie continua y sin juntas perceptibles. Perfecto para <strong>bodas, galas, cenas de gala y eventos de lujo</strong>. Combina con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para un montaje integral de primer nivel.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Duela 12mm</span>
            <span class="showcase__tag">Semi-mate</span>
            <span class="showcase__tag">Estructura elevada</span>
            <span class="showcase__tag">Anti-humedad</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Piso de Duela
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="6" width="20" height="12" rx="2"/>
              <line x1="2" y1="12" x2="22" y2="12"/>
              <line x1="8" y1="6" x2="8" y2="18"/>
              <line x1="16" y1="6" x2="16" y2="18"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ALFOMBRA PROFESIONAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="alfombra-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">15+ colores disponibles</span>
          <h2 class="showcase__title" id="alfombra-heading">Alfombra Profesional</h2>
          <p class="showcase__subtitle">Alfombra industrial de alta densidad con instalación rápida para expos, ferias y eventos corporativos.</p>
          <p class="showcase__text">Nuestra <strong>alfombra profesional de alta densidad</strong> está disponible en más de <strong>15 colores</strong> incluyendo rojo, azul rey, verde, gris Oxford, negro, beige, burgundy y colores corporativos personalizados. Fabricada con fibra de polipropileno de <strong>alta resistencia al tráfico</strong>, soporta el paso de miles de visitantes sin desgaste visible. Instalación directa sobre concreto, pasto o plataforma nivelada con cinta de doble cara profesional.</p>
          <p class="showcase__text">Ideal para <strong>expos comerciales, ferias, convenciones, pasarelas y eventos corporativos</strong> donde la imagen de marca es fundamental. Los rollos de 4 metros de ancho permiten cubrir grandes superficies con mínimas uniones. Incluye <strong>corte a medida, instalación y retiro</strong> después del evento. Disponible también en formato de pasillo para alfombra roja de entrada. Complementa con nuestra <a href="/servicios/accesorios/">señalización y accesorios</a> para un montaje profesional completo.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Alta densidad</span>
            <span class="showcase__tag">15+ colores</span>
            <span class="showcase__tag">Corte a medida</span>
            <span class="showcase__tag">Alto tráfico</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Alfombra Profesional
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="8" width="18" height="8" rx="1"/>
              <path d="M3 16l-1 2"/>
              <path d="M21 16l1 2"/>
              <path d="M3 8l-1-2"/>
              <path d="M21 8l1-2"/>
              <line x1="7" y1="8" x2="7" y2="16"/>
              <line x1="12" y1="8" x2="12" y2="16"/>
              <line x1="17" y1="8" x2="17" y2="16"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CORTINAS Y FORROS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cortinas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Transformación total</span>
          <h2 class="showcase__title" id="cortinas-heading">Cortinas y Forros</h2>
          <p class="showcase__subtitle">Transforma el interior de tu carpa con forros decorativos en chiffon, satín y blackout.</p>
          <p class="showcase__text">Nuestros <strong>forros interiores y cortinas decorativas</strong> transforman por completo la apariencia de cualquier carpa. <strong>Forros de techo en chiffon</strong> crean drapeados elegantes con caída natural, disponibles en blanco, ivory, champagne, rosa y azul cielo. <strong>Forros de satín</strong> aportan un brillo sofisticado en blanco, ivory, dorado, plata, negro y rojo. <strong>Cortinas blackout</strong> ofrecen control total de luz para proyecciones y montajes audiovisuales.</p>
          <p class="showcase__text">Instalamos <strong>cortinas laterales, cielos decorativos con drapeado, cenefas perimetrales y divisiones de espacio</strong> para crear ambientes diferenciados dentro de una misma carpa. Los forros actúan como <strong>aislante térmico natural</strong>, mejorando la eficiencia del clima artificial hasta un 40%. Para eventos corporativos ofrecemos impresión personalizada en tela para branding. Combina con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para crear ambientes mágicos con juegos de luz a través de las telas.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Chiffon</span>
            <span class="showcase__tag">Satín</span>
            <span class="showcase__tag">Blackout</span>
            <span class="showcase__tag">Drapeados</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Cortinas y Forros
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 3h16"/>
              <path d="M4 3c0 6 2 10 4 14"/>
              <path d="M20 3c0 6-2 10-4 14"/>
              <path d="M8 17c2 2 6 2 8 0"/>
              <path d="M4 3v2c0 4 3 6 3 10"/>
              <path d="M20 3v2c0 4-3 6-3 10"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CLIMA ARTIFICIAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="clima-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Confort garantizado</span>
          <h2 class="showcase__title" id="clima-heading">Clima Artificial</h2>
          <p class="showcase__subtitle">Calefacción, enfriamiento y ventilación industrial para garantizar la temperatura ideal en cualquier temporada.</p>
          <p class="showcase__text">Nuestros <strong>sistemas de clima artificial para carpas</strong> garantizan confort térmico en cualquier época del año. <strong>Calefacción industrial</strong> con calefactores de gas LP de 30,000 a 100,000+ BTU y sistemas de ductos para distribución uniforme del calor en noches frías. <strong>Enfriamiento evaporativo</strong> que reduce la temperatura entre 8 y 12°C de manera ecológica, ideal para carpas semi-abiertas en primavera y verano.</p>
          <p class="showcase__text"><strong>Aire acondicionado portátil</strong> de 5 a 20 toneladas para carpas cerradas con forro, ofreciendo control preciso de temperatura entre 18 y 24°C. <strong>Ventilación forzada</strong> con extractores industriales de alto flujo para renovación de aire constante en carpas abiertas con gran asistencia. Todos los equipos incluyen <strong>instalación, ductos, conexiones eléctricas y operación técnica</strong> durante el evento. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para producciones de eventos integrales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Calefacción</span>
            <span class="showcase__tag">Enfriamiento</span>
            <span class="showcase__tag">AC portátil</span>
            <span class="showcase__tag">Ventilación</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Clima Artificial
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <line x1="8" y1="20" x2="8" y2="22"/>
              <line x1="16" y1="20" x2="16" y2="22"/>
              <path d="M6 12h12"/>
              <path d="M9 8l3 4-3 4"/>
              <path d="M15 8l-3 4 3 4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Pisos y Complementos"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar pisos, forros o clima para tu carpa, es natural tener preguntas sobre materiales, colores, instalación y costos. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre pisos y complementos para carpas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre pisos y complementos para carpas`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
