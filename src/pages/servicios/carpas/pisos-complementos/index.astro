---
/**
 * ─── EVENTECH.MX — Pisos y Complementos para Carpas (Hub L4, molde hm- 2026) ───
 * Duela · Alfombra · Cortinas y Forros · Clima Artificial — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/carpas — forros-interiores real; carpa-boda-0X / mediana genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "duela",
    name: "Piso de Duela",
    badge: "Para bodas y galas",
    excerpt: "Duela laminada de 12 mm con acabado semi-mate sobre estructura elevada. Protege de la humedad del terreno, con nivelación profesional y aspecto premium para bodas y galas.",
    href: "/servicios/carpas/pisos-complementos/duela/",
    image: "/images/carpas/carpa-boda-01.avif",
    specs: ["Duela 12 mm", "Semi-mate", "Estructura elevada", "Nivelación láser"],
  },
  {
    id: "alfombra",
    name: "Alfombra Profesional",
    badge: "Expos y corporativos",
    excerpt: "Alfombra industrial de alta densidad en más de 15 colores. Instalación rápida sobre cualquier superficie para expos, ferias, corporativos y pasarelas.",
    href: "/servicios/carpas/pisos-complementos/alfombra/",
    image: "/images/carpas/carpa-mediana-quinceanos-decorada.avif",
    specs: ["+15 colores", "Alta densidad", "Cualquier superficie", "Instalación rápida"],
  },
  {
    id: "cortinas-forros",
    name: "Cortinas y Forros",
    badge: "Transforma el interior",
    excerpt: "Forros en chiffon, satín y blackout que transforman el interior de la carpa. Cortinas laterales, cielos decorativos y divisiones de espacio en más de 10 colores.",
    href: "/servicios/carpas/pisos-complementos/cortinas-forros/",
    image: "/images/carpas/forros-interiores-carpa-elegante.avif",
    specs: ["Chiffon / satín / blackout", "+10 colores", "Cielos decorativos", "Divisiones"],
  },
  {
    id: "clima-artificial",
    name: "Clima Artificial",
    badge: "Cualquier temporada",
    excerpt: "Calefacción industrial, enfriamiento evaporativo y AC portátil hasta 20 toneladas. Mantiene 20–24 °C dentro de la carpa en cualquier temporada del año.",
    href: "/servicios/carpas/pisos-complementos/clima-artificial/",
    image: "/images/carpas/carpa-boda-02.avif",
    specs: ["Calefacción / AC", "Hasta 20 ton", "20–24 °C", "Evaporativo"],
  },
];

const whyFeatures = [
  {
    title: "Visita técnica para nivelar y dimensionar",
    body: "Antes de cotizar medimos el terreno, el desnivel y el volumen de la carpa. El piso y el clima no se estiman a ojo: la nivelación se calcula según la pendiente real y el clima según los metros cúbicos de aire. Partimos de una visita técnica para que el resultado sea firme, plano y a la temperatura correcta.",
  },
  {
    title: "Piso que protege de humedad y desnivel",
    body: "Estructura elevada con marco de aluminio o madera tratada y patas ajustables que compensan desniveles de hasta 40 cm. Aísla del suelo húmedo y de terrenos irregulares, entregando una superficie perfectamente plana y estable — la diferencia entre invitados caminando cómodos y tacones hundiéndose en el pasto.",
  },
  {
    title: "Forros que transforman y aíslan",
    body: "Chiffon, satín y blackout que ocultan la estructura y convierten la carpa en un salón — y que además funcionan como aislante térmico, mejorando la eficiencia del clima hasta un 40%. No es solo estética: el forro hace que el espacio se vea mejor y se sienta mejor al mismo tiempo.",
  },
  {
    title: "Clima dimensionado por metro y aforo",
    body: "Calefacción de gas o eléctrica, enfriamiento evaporativo y AC portátil hasta 20 toneladas, dimensionados según los m² de la carpa, el aforo y la temporada. Un clima subdimensionado no se siente; nosotros calculamos los BTU y las toneladas correctas para mantener 20–24 °C sin importar el mes.",
  },
  {
    title: "Instalación, operación y desmontaje incluidos",
    body: "No solo entregamos el material: instalamos, operamos durante el evento y desmontamos. El calefactor lo enciende y ajusta nuestro técnico, el piso lo nivelamos nosotros y los forros los montamos con acabado impecable. Un solo responsable de que todo funcione, de principio a fin.",
  },
  {
    title: "Paquetes integrales coordinados",
    body: "Piso, forros y clima rinden más juntos y coordinados: el forro aísla el clima, el piso sostiene el montaje y todo se instala en una sola logística. Armamos paquetes combinados con mejor precio que contratar cada complemento por separado, y con un solo equipo responsable del venue completo.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cotización", p: "Agendamos visita sin costo para medir la carpa, el desnivel del terreno y las condiciones de clima. Con esos datos dimensionamos piso, forros y equipo de climatización. En menos de 24 horas te enviamos propuesta con los complementos ideales para tu evento." },
  { n: 2, t: "Propuesta de complementos y aparto", p: "Definimos tipo de piso (duela o alfombra), forros y color, y equipo de clima según la temporada. Con el anticipo apartamos el material y la fecha. Coordinamos con el proveedor de la carpa (nuestro o externo) para que todo encaje en el montaje." },
  { n: 3, t: "Instalación, nivelación y prueba", p: "Instalamos con anticipación: nivelación láser del piso, montaje de forros con acabado, y colocación y prueba del equipo de clima. Dejamos la carpa lista y verificada antes del evento para que no haya ajustes de última hora ni sorpresas de temperatura." },
  { n: 4, t: "Operación en evento y desmontaje", p: "Durante el evento nuestro técnico opera y ajusta el clima según el llenado de la carpa y la temperatura exterior. Al finalizar, desmontamos y retiramos piso, forros y equipo. La instalación, operación y desmontaje están incluidos dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tipos de piso están disponibles para carpas?", answer: "Ofrecemos tres opciones principales: piso de duela laminada de 12mm con acabado semi-mate (ideal para bodas y galas), alfombra industrial de alta densidad en más de 15 colores (perfecta para expos y corporativos), y plataforma nivelada de madera contrachapada (base técnica para terrenos irregulares). Cada opción incluye estructura elevada con marco de aluminio o madera tratada que protege contra la humedad del suelo y garantiza una superficie firme y segura." },
  { question: "¿Se puede instalar piso sobre terreno irregular o con pendiente?", answer: "Sí, es una de nuestras especialidades. Utilizamos un sistema de plataforma nivelada con patas ajustables que compensa desniveles de hasta 40 cm. La estructura se ancla al terreno con estacas o contrapesos según el tipo de suelo (tierra, pasto, concreto). Realizamos una visita técnica previa para evaluar el terreno y diseñar la nivelación exacta. El resultado es una superficie perfectamente plana y estable, independientemente de las condiciones del terreno original." },
  { question: "¿Qué opciones de color tienen las cortinas y forros interiores?", answer: "Manejamos tres tipos de tela: chiffon (translúcido, elegante, disponible en blanco, ivory, champagne, rosa y azul cielo), satín (brillo sofisticado en blanco, ivory, dorado, plata, negro y rojo), y blackout (opaco total para control de luz en negro, blanco y gris). Los forros de techo se pueden combinar con drapeados decorativos y luces LED integradas. Para eventos corporativos ofrecemos impresión personalizada en telas para branding." },
  { question: "¿Cómo funciona la calefacción para carpas en invierno?", answer: "Utilizamos calefactores industriales de gas LP o eléctricos que distribuyen aire caliente de manera uniforme dentro de la carpa. Para carpas de hasta 100 m² usamos 2 calefactores de 30,000 BTU. Para carpas más grandes (200-500 m²) instalamos un sistema de ductos con calefactor central de 100,000+ BTU. Los forros interiores actúan como aislante térmico, mejorando la eficiencia del sistema hasta un 40%. La temperatura se mantiene entre 20-24°C incluso en noches de invierno en CDMX." },
  { question: "¿Qué opciones de enfriamiento tienen para eventos en verano?", answer: "Ofrecemos tres soluciones según el tipo de carpa: enfriamiento evaporativo (reduce 8-12°C, ideal para carpas semi-abiertas), aire acondicionado portátil de 5 a 20 toneladas (para carpas cerradas con forro), y ventilación forzada con extractores industriales (para carpas abiertas). El enfriamiento evaporativo es el más económico y ecológico, mientras que el AC portátil ofrece control preciso de temperatura. Nuestro técnico evalúa tu carpa y recomienda la mejor opción según dimensiones y número de asistentes." },
  { question: "¿Cuánto cuesta un paquete completo de piso más clima?", answer: "Los paquetes combinados ofrecen el mejor valor. Un paquete básico (piso de duela + ventilación para carpa de 50 m²) parte desde $8,000 MXN. Un paquete premium (duela + forros de satín + calefacción para carpa de 100 m²) desde $18,000 MXN. El paquete completo (duela nivelada + alfombra + forros + AC portátil para carpa de 200 m²) desde $35,000 MXN. Todos incluyen instalación, operación durante el evento y desmontaje. Cotizamos según las dimensiones exactas de tu carpa y las condiciones específicas de tu venue." },
  { question: "¿Con cuánta anticipación debo reservar piso y clima?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación. En temporada de lluvias (junio a septiembre) el piso elevado y la calefacción tienen alta demanda, y en temporada de calor el AC portátil se agota primero; para esas fechas conviene apartar con 4 a 6 semanas. Como el piso y el clima se dimensionan según la carpa, lo ideal es cotizarlos junto con la carpa o en cuanto tengas las medidas del venue, para garantizar disponibilidad del equipo del tamaño correcto." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pisos y Complementos para Carpas en CDMX",
    description: "Renta de pisos de duela, alfombra, cortinas, forros y clima artificial para carpas de eventos en CDMX. Nivelación, instalación y operación incluidas.",
    url: "/servicios/carpas/pisos-complementos/",
    priceRange: { min: 2000, max: 60000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Pisos y Complementos", url: "/servicios/carpas/pisos-complementos/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Pisos y Complementos" },
];
---

<PageLayout
  title="Renta de Pisos y Complementos para Carpas en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/carpas/forros-interiores-carpa-elegante.avif"
  description="Renta de piso de duela, alfombra, forros y clima artificial para carpas de eventos en CDMX. Nivelación e instalación incluidas. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="pisos-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Pisos y complementos · CDMX y ZMVM</p>
            <h1 id="pisos-hero-heading">
              Pisos, forros y clima que convierten <em>una carpa en un venue terminado</em>
            </h1>
            <p class="hm-hero__lead">
              Piso de duela, alfombra profesional, forros de chiffon, satín y blackout, y clima
              artificial de 20–24 °C. Los complementos que hacen que una carpa deje de sentirse
              como una carpa — con nivelación e instalación incluidas.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20pisos%20y%20complementos%20para%20mi%20carpa`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar complementos
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>pisos y complementos para carpas</strong> en CDMX y zona
              metropolitana: <strong>piso de duela laminada de 12 mm</strong> sobre estructura
              elevada, alfombra industrial en más de 15 colores, forros de chiffon, satín y
              blackout, y <strong>clima artificial</strong> de calefacción y enfriamiento hasta
              20 toneladas. Cada complemento se dimensiona a partir de una visita técnica a la
              carpa y el terreno.
            </p>
            <p>
              Con <strong>más de 500 instalaciones</strong> en CDMX, sabemos que los detalles son
              lo que separa una carpa de un venue: un piso firme, un forro que aísla y un clima a
              temperatura correcta. Por eso incluimos nivelación, instalación y operación durante
              el evento. Complementan cualquiera de nuestras carpas
              <a href="/servicios/carpas/carpas-arabes/">árabes</a>,
              <a href="/servicios/carpas/estructurales/">estructurales</a> o
              <a href="/servicios/carpas/hangar/">tipo hangar</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Pisos y complementos disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20pisos%20y%20complementos%20para%20mi%20carpa`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Todo para completar tu carpa</p>
            <h2 id="catalogo-heading">¿Qué le falta a tu carpa para estar lista?</h2>
            <p class="hm__head-sub">Piso, alfombra, forros y clima — los complementos que hacen la diferencia entre "una carpa" y un venue.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Una carpa vacía es un techo; los complementos son lo que la vuelven habitable y
              memorable. El piso decide si los invitados caminan cómodos o se hunden en el pasto,
              el forro decide si el espacio se ve como un salón, y el clima decide si la gente se
              queda o se va por frío o calor.
            </p>
            <p>
              Duela para bodas y galas. Alfombra para expos y corporativos. Cortinas y forros
              para transformar el interior. Clima artificial para cualquier temporada. Una sola
              empresa para dejar tu carpa completamente terminada.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para carpas de eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada complemento, a fondo</p>
            <h2 id="detalle-heading">Los 4 complementos — en detalle</h2>
            <p class="hm__head-sub">Material, medidas, capacidad y para qué tipo de evento funciona mejor cada complemento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada complemento hay decisiones que afectan la comodidad del evento: el
              tipo de piso que decide la estabilidad sobre el terreno, el forro que define la
              estética y el aislamiento, y el equipo de clima que marca si la temperatura es
              agradable toda la noche.
            </p>
            <p>
              Conocer estas diferencias te permite completar la carpa con criterio y no dejar
              ningún detalle al azar. A continuación, lo que realmente importa de cada complemento.
            </p>
          </div>
        </div>

        <!-- DUELA -->
        <article class="hm-feat" aria-labelledby="feat-duela">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Piso de Duela</p>
            <h3 class="hm-feat__title" id="feat-duela">El piso premium que protege del terreno y eleva la estética de bodas y galas</h3>
            <p class="hm-feat__lead">Nada delata más una carpa improvisada que el pasto bajo los pies. La duela transforma el terreno en un piso firme y elegante — y salva los tacones de tus invitadas.</p>
            <p>
              <strong>Duela laminada de 12 mm con acabado semi-mate</strong> sobre estructura
              elevada con marco de aluminio o madera tratada. Aísla de la humedad del suelo,
              nivela el terreno y entrega una superficie firme con aspecto de salón. La
              <strong>nivelación láser</strong> garantiza que quede perfectamente plana.
            </p>
            <p>
              Ideal para <strong>bodas, galas, cenas formales y recepciones</strong> donde la
              estética importa. Disponible en tonos de madera clara y oscura. Combínalo con
              nuestros <a href="/servicios/carpas/carpas-arabes/">forros de carpa</a> y
              <a href="/servicios/iluminacion/">iluminación decorativa</a> para un interior
              completamente terminado.
            </p>
            <ul class="hm-feat__stats">
              {["Duela 12 mm", "Semi-mate", "Estructura elevada", "Nivelación láser", "Anti-humedad"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/pisos-complementos/duela/">
              Ver Piso de Duela
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/carpas/carpa-boda-01.avif" alt="Piso de duela en carpa para boda de gala en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/carpas/carpa-boda-03.avif" alt="Piso de duela nivelado en interior de carpa para recepción" loading="lazy" decoding="async" />
              <img src="/images/carpas/forros-interiores-carpa-elegante.avif" alt="Duela y forros en montaje de carpa elegante" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- ALFOMBRA -->
        <article class="hm-feat" aria-labelledby="feat-alfombra">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Alfombra Profesional</p>
            <h3 class="hm-feat__title" id="feat-alfombra">Alfombra industrial de alta densidad — la solución rápida para expos y corporativos</h3>
            <p class="hm-feat__lead">Cuando el evento es de escala y presupuesto, la alfombra cubre grandes superficies rápido y en el color de tu marca. Práctica, resistente y lista en horas.</p>
            <p>
              <strong>Alfombra industrial de alta densidad</strong> en <strong>más de 15
              colores</strong>, de instalación rápida sobre cualquier superficie — cemento,
              pasto o plataforma. Resistente al tránsito intenso de expos y ferias, con acabado
              uniforme que unifica visualmente grandes áreas.
            </p>
            <p>
              Perfecta para <strong>expos, ferias comerciales, corporativos, pasarelas y áreas de
              circulación</strong>. Se puede combinar con el color institucional de tu marca para
              stands y activaciones. Ideal sobre nuestras
