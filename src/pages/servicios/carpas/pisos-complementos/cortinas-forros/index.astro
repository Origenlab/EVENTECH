---
/**
 * ─── Cortinas y Forros — Pagina de Producto (Nivel 4) ───
 * Chiffon, satín y blackout para interiores de carpas.
 * Forros decorativos, cielos drapeados y cortinas laterales.
 *
 * Jerarquia: Servicios > Carpas > Pisos y Complementos > Cortinas y Forros
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { label: "Cortinas y Forros" },
];

const faqs = [
  { question: "¿Se pueden combinar diferentes colores de forros en una misma carpa?", answer: 'Sí, las combinaciones de colores son una de nuestras especialidades. Puedes elegir un color para el <strong>cielo drapeado</strong> (blanco o ivory son los más populares) y otro para las <strong>cortinas laterales</strong> (champagne, rosado, dorado). También ofrecemos <strong>degradados de color</strong> combinando dos tonos en el cielo para un efecto más dinámico. Para eventos corporativos, podemos incorporar los colores de tu marca en secciones específicas de la carpa. Nuestro equipo de decoración te asesora con combinaciones probadas en más de 500 eventos.' },
  { question: "¿El servicio incluye el cielo drapeado decorativo?", answer: 'Sí, el <strong>cielo drapeado decorativo está incluido</strong> en nuestros paquetes de forros interiores. El drapeado se instala sobre la estructura metálica de la carpa creando pliegues elegantes con caída natural que ocultan completamente el techo industrial. Disponible en estilos <strong>catedral</strong> (pliegues hacia un punto central), <strong>ondulado</strong> (pliegues paralelos) y <strong>estrella</strong> (pliegues radiales desde el centro). Cada estilo transforma el interior de la carpa en un espacio completamente diferente.' },
  { question: "¿Las cortinas blackout sirven para oscurecer la carpa para proyecciones?", answer: 'Absolutamente. Nuestras <strong>cortinas blackout logran oscurecimiento del 95-100%</strong>, ideales para proyecciones de video, mapping, presentaciones corporativas y eventos audiovisuales dentro de carpas. El blackout se instala en paredes laterales y puede complementarse con forros de techo oscuros para control total de luz. Es la solución perfecta para <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y <a href="/servicios/audiovisual/proyectores/">proyectores</a> que necesitan condiciones de baja luminosidad para máxima calidad de imagen.' },
  { question: "¿Los forros funcionan tanto en carpas árabes como en estructurales?", answer: 'Sí, nuestros forros y cortinas son <strong>compatibles con todas las carpas</strong> de nuestro catálogo. Para <a href="/servicios/carpas/carpas-arabes/">carpas árabes</a>, los forros se adaptan a la forma de doble pico y las cortinas laterales pueden recogerse o fijarse según la ventilación deseada. Para <a href="/servicios/carpas/estructurales/">carpas estructurales</a>, los forros cubren la estructura de aluminio con sistema de rieles que permite ajustar la tensión y el drapeado. Cada tipo de carpa requiere un sistema de fijación específico que nuestro equipo maneja con experiencia.' },
  { question: "¿Cuánto tiempo tarda la instalación de forros y cortinas?", answer: 'El tiempo de instalación depende de la dimensión de la carpa y la complejidad del montaje. Para una <strong>carpa de 50-100 m²</strong> con forros de cielo y laterales, la instalación tarda <strong>4 a 6 horas</strong>. Para <strong>carpas de 100-200 m²</strong> con cielo drapeado complejo, cortinas laterales y divisiones, el montaje requiere <strong>6 a 10 horas</strong>. Recomendamos programar la instalación un día antes del evento para ajustes de iluminación y detallado final. El desmontaje toma aproximadamente la mitad del tiempo.' },
  { question: "¿El precio incluye la instalación de los forros?", answer: 'Sí, <strong>todos nuestros precios incluyen instalación completa</strong> por nuestro equipo de decoración especializado. El servicio comprende: medición de la carpa, corte y confección de forros a medida si es necesario, instalación del sistema de rieles y tensores, montaje de cielo drapeado, colocación de cortinas laterales, ajustes finales de caída y pliegues, y desmontaje posterior al evento. No hay costos ocultos ni cargos adicionales por instalación dentro de CDMX y zona metropolitana.' },
];

const specs = [
  { label: "Telas", value: "Chiffon, satín, tul, blackout" },
  { label: "Colores", value: "15+: blanco, marfil, champagne, rosado, etc" },
  { label: "Cielo", value: "Drapeado decorativo con pliegues" },
  { label: "Laterales", value: "Cortinas recogibles o fijas" },
  { label: "Divisiones", value: "Paneles separadores de espacio" },
  { label: "Blackout", value: "Oscurecimiento total para proyecciones" },
  { label: "Fijación", value: "Sistema de rieles y tensores" },
  { label: "Compatibilidad", value: "Todas las carpas árabes y estructurales" },
  { label: "Iluminación", value: "Opción LED tras tela para efecto glow" },
  { label: "Instalación", value: "Equipo de decoración incluido" },
];

const sidebarNav = [
  { name: "Piso de Duela", href: "/servicios/carpas/pisos-complementos/duela/" },
  { name: "Alfombra Profesional", href: "/servicios/carpas/pisos-complementos/alfombra/" },
  { name: "Cortinas y Forros", href: null, active: true },
  { name: "Clima Artificial", href: "/servicios/carpas/pisos-complementos/clima-artificial/" },
];

const sidebarRelated = [
  { name: "Carpas Estructurales", href: "/servicios/carpas/estructurales/" },
  { name: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
];

const reviews = [
  { author: "Laura Ramírez", text: "Los forros blancos de satín transformaron nuestra carpa árabe en un salón de ensueño para la boda. El cielo drapeado estilo catedral fue espectacular y todos los invitados quedaron impresionados. El equipo de instalación fue muy profesional y cuidadoso con cada detalle.", rating: 5, date: "2025-11-08" },
  { author: "Andrés Gutiérrez", text: "Rentamos cortinas blackout para un evento corporativo de lanzamiento de producto dentro de una carpa estructural. El oscurecimiento fue total y las proyecciones se vieron perfectas. Excelente solución para eventos audiovisuales en carpas.", rating: 5, date: "2025-10-15" },
  { author: "Valentina Flores", text: "Para los XV años de mi hija elegimos un cielo drapeado en champagne con cortinas laterales en rosa palo. El resultado fue mágico — parecía una carpa de cuento de hadas. La combinación con las luces LED detrás de la tela creó un efecto glow precioso.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Cortinas y Forros para Carpas en CDMX",
    description: "Renta de forros interiores y cortinas de chiffon, satín y blackout para transformar el interior de tu carpa. 15+ colores. Instalación incluida. Desde $3,000.",
    url: "/servicios/carpas/pisos-complementos/cortinas-forros/",
    priceRange: { min: 3000, max: 25000 },
    reviews,
    ratingValue: 5,
    reviewCount: 167,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Pisos y Complementos", url: "/servicios/carpas/pisos-complementos/" },
    { name: "Cortinas y Forros", url: "/servicios/carpas/pisos-complementos/cortinas-forros/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Cortinas y Forros para Carpas en CDMX"
  description="Renta de forros interiores y cortinas de chiffon, satín y blackout para transformar el interior de tu carpa. 15+ colores. Instalación incluida. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Transforma tu carpa por completo"
    title='Renta de <span class="highlight">Cortinas y Forros</span> para Carpas en CDMX'
    subtitle="Forros interiores en chiffon, satín y blackout que ocultan la estructura metálica y transforman tu carpa en un espacio elegante. Cielos drapeados, cortinas laterales y divisiones en 15+ colores."
    primaryCTA={{ label: "Cotiza tus forros", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar cortinas y forros para mi carpa` }}
    cards={[
      {
        title: "Forros interiores que transforman el espacio",
        content: "<strong>Forros interiores en chiffon, satín y tul</strong> que ocultan completamente la estructura metálica de la carpa y transforman el espacio en un salón de eventos elegante. Cielos drapeados con pliegues naturales en estilos catedral, ondulado y estrella. Cortinas laterales recogibles o fijas en más de 15 colores: blanco, marfil, champagne, rosado, dorado, azul cielo y más. Cada forro confeccionado a medida para tu carpa específica.",
      },
      {
        title: "Cortinas decorativas, blackout y divisiones",
        content: "<strong>Cortinas laterales, cielos decorativos drapeados y divisiones de espacio</strong> en 15+ colores para crear ambientes diferenciados dentro de tu carpa. Cortinas blackout para oscurecimiento total en eventos con proyecciones y montajes audiovisuales. Paneles separadores para dividir zonas de cocktail, cena y pista de baile. Opción de iluminación LED integrada tras la tela para efecto glow. Instalación completa por equipo de decoración profesional incluida.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres transformar el interior de tu carpa?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con los forros y cortinas ideales para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pisos y Complementos para Carpas</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas cortinas y forros para tu carpa?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar cortinas y forros para mi carpa`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 3h16"/><path d="M4 3c0 6 2 10 4 14"/><path d="M20 3c0 6-2 10-4 14"/><path d="M8 17c2 2 6 2 8 0"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Cortinas y Forros</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Forros Blancos Satinados -->
          <section class="section section--alt" aria-labelledby="forros-blancos-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Clásico para bodas</span>
                <h2 class="showcase__title" id="forros-blancos-heading">Forros Blancos Satinados</h2>
                <p class="showcase__subtitle">El clásico elegante para bodas: forros de satín blanco que transforman tu carpa en un salón de ensueño.</p>
                <p class="showcase__text">Nuestros <strong>forros blancos de satín</strong> son la opción más solicitada para bodas y eventos elegantes. El satín de alta calidad oculta completamente la estructura metálica de la carpa, creando un interior luminoso y sofisticado con un <strong>brillo suave que refleja la luz</strong> de manera hermosa. Los pliegues naturales del drapeado crean un efecto de catedral o capilla que impresiona a cada invitado desde el momento que entra.</p>
                <p class="showcase__text">Los forros blancos funcionan como un <strong>lienzo perfecto para iluminación decorativa</strong>: la luz de nuestras <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights</a> y <a href="/servicios/iluminacion/arquitectonica/uplighting/">uplighting</a> se refleja en el satín creando ambientes cálidos y románticos. Disponibles en tonos blanco puro, blanco cálido e ivory para combinar con cualquier paleta de decoración. Incluyen cielo drapeado, cortinas laterales y fijación con sistema de rieles profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Satín blanco</span>
                  <span class="showcase__tag">Bodas</span>
                  <span class="showcase__tag">Cielo drapeado</span>
                  <span class="showcase__tag">Desde $3,000</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Forros Blancos
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Forros Blancos Satinados</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cielo Drapeado Decorativo -->
          <section class="section section--alt" aria-labelledby="cielo-drapeado-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Efecto catedral</span>
                <h2 class="showcase__title" id="cielo-drapeado-heading">Cielo Drapeado Decorativo</h2>
                <p class="showcase__subtitle">Drapeados de techo que crean un efecto de catedral, domo o bóveda dentro de tu carpa.</p>
                <p class="showcase__text">Nuestro <strong>cielo drapeado decorativo</strong> transforma el techo industrial de la carpa en una obra de arte textil. Ofrecemos tres estilos principales: <strong>catedral</strong> con pliegues que convergen en un punto central creando altura visual, <strong>ondulado</strong> con pliegues paralelos que agregan movimiento y profundidad, y <strong>estrella</strong> con pliegues radiales que irradian desde el centro como los pétalos de una flor.</p>
                <p class="showcase__text">El cielo drapeado es especialmente impactante cuando se combina con <strong>iluminación LED integrada entre las telas</strong>. Nuestros técnicos instalan tiras LED, fairy lights o spots entre las capas de tela para crear un efecto glow que ilumina el drapeado desde el interior. Disponible en chiffon (translúcido, ideal para efecto glow), tul (etéreo y romántico) y satín (elegante con reflejos). Complementa con nuestros <a href="/servicios/iluminacion/decorativa/candiles/">candiles decorativos</a> para un efecto de salón de gala.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Catedral</span>
                  <span class="showcase__tag">Ondulado</span>
                  <span class="showcase__tag">Estrella</span>
                  <span class="showcase__tag">Efecto glow</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cielo Drapeado
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Cielo Drapeado Decorativo</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Cortinas Blackout -->
          <section class="section section--alt" aria-labelledby="cortinas-blackout-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Oscurecimiento total</span>
                <h2 class="showcase__title" id="cortinas-blackout-heading">Cortinas Blackout</h2>
                <p class="showcase__subtitle">Oscurecimiento total del 95-100% para proyecciones, mapping y eventos audiovisuales dentro de carpas.</p>
                <p class="showcase__text">Nuestras <strong>cortinas blackout profesionales</strong> logran un oscurecimiento del 95 al 100%, convirtiendo el interior de la carpa en un espacio controlado para proyecciones de alta calidad. Fabricadas con tela blackout de triple capa que bloquea completamente la luz solar, son la solución ideal para <strong>presentaciones corporativas, mapping, lanzamientos de producto y eventos con pantallas LED</strong> donde la calidad visual es prioritaria.</p>
                <p class="showcase__text">El blackout se instala en todas las paredes laterales y puede complementarse con forros de techo oscuros para control total de luminosidad. Incluye <strong>sistema de apertura y cierre</strong> con rieles para alternar entre modo oscuro (proyecciones) y modo abierto (coctelería/networking). Compatible con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y <a href="/servicios/audiovisual/proyectores/">proyectores profesionales</a> para una producción audiovisual completa dentro de tu carpa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Blackout 95-100%</span>
                  <span class="showcase__tag">Proyecciones</span>
                  <span class="showcase__tag">Corporativos</span>
                  <span class="showcase__tag">Rieles apertura</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cortinas Blackout
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Cortinas Blackout</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Transformación Completa -->
          <section class="section section--alt" aria-labelledby="kit-transformacion-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Transformación total</span>
                <h2 class="showcase__title" id="kit-transformacion-heading">Kit Transformación Completa</h2>
                <p class="showcase__subtitle">Paquete integral: cielo drapeado + cortinas laterales + divisiones de espacio para una transformación total.</p>
