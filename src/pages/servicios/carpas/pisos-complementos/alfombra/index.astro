---
/**
 * ─── Alfombra Profesional — Pagina de Producto (Nivel 4) ───
 * Alfombra industrial de alta densidad en 15+ colores
 * para expos, ferias, eventos corporativos y pasarelas.
 *
 * Jerarquia: Servicios > Carpas > Pisos y Complementos > Alfombra Profesional
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { label: "Alfombra Profesional" },
];

const faqs = [
  { question: "¿Cuántos colores de alfombra tienen disponibles?", answer: 'Contamos con <strong>más de 15 colores</strong> en inventario permanente: rojo, azul rey, verde, gris Oxford, negro, beige, burgundy, blanco, naranja, amarillo, rosa, morado, café, turquesa y arena. También ofrecemos <strong>colores corporativos personalizados</strong> bajo pedido con 2 semanas de anticipación. Para eventos con identidad de marca específica, podemos combinar colores por zonas — por ejemplo, alfombra negra en el escenario y alfombra con el color corporativo en el área de networking.' },
  { question: "¿Se puede usar alfombra en exterior sobre pasto o tierra?", answer: 'Sí, nuestra alfombra profesional se instala perfectamente sobre <strong>pasto, tierra compactada, concreto y madera</strong>. La base anti-deslizante con membrana protege contra la humedad del suelo y evita que la alfombra se mueva con el tráfico de los asistentes. Para terrenos muy irregulares o con pendiente, recomendamos instalar primero una <a href="/servicios/carpas/pisos-complementos/duela/">plataforma nivelada</a> y colocar la alfombra encima para un resultado óptimo.' },
  { question: "¿La alfombra resiste agua y lluvia?", answer: 'La alfombra de polipropileno es <strong>resistente a salpicaduras y humedad ligera</strong>, pero no está diseñada para eventos bajo lluvia directa sin protección. Bajo una carpa o toldo, funciona perfectamente incluso en temporada de lluvias. Si el terreno tiene humedad natural (pasto mojado), la membrana base protege la alfombra por debajo. Para eventos en exteriores sin techo, recomendamos nuestras <strong>alfombras de exterior con drenaje</strong> que permiten el paso del agua sin encharcamientos.' },
  { question: "¿Cuál es el mínimo de metros cuadrados para rentar?", answer: 'El <strong>mínimo de renta es de 15 m²</strong>, equivalente a un pasillo de alfombra roja o un área de recepción compacta. La mayoría de nuestros clientes rentan entre 50 y 500 m² para cubrir áreas completas de expos, ferias y eventos corporativos. Para <strong>pasillos de alfombra roja</strong> (entrada VIP), el mínimo es de 10 metros lineales por 1.5 metros de ancho. A mayor superficie, mejor precio por metro cuadrado.' },
  { question: "¿La alfombra se corta a medida de mi espacio?", answer: 'Sí, realizamos <strong>corte a medida</strong> según las dimensiones exactas de tu espacio. Nuestros instaladores miden el área, cortan la alfombra con precisión y la fijan con cinta de doble cara profesional para evitar bordes levantados o tropiezos. También cortamos <strong>formas especiales</strong> como círculos para áreas de networking, pasillos curvos y logotipos recortados. El corte a medida está incluido en el precio de renta.' },
  { question: "¿La instalación y retiro están incluidos en el precio?", answer: 'Sí, el precio de renta incluye <strong>transporte, instalación, fijación profesional y retiro</strong> posterior al evento. Nuestro equipo llega con anticipación para preparar la superficie, colocar la alfombra con cinta de doble cara y verificar que todos los bordes estén seguros. Después del evento, retiramos la alfombra y limpiamos el área. Para eventos de varios días, ofrecemos <strong>limpieza intermedia</strong> con aspiradora industrial incluida.' },
];

const specs = [
  { label: "Material", value: "Alfombra industrial alta densidad" },
  { label: "Colores", value: "15+: rojo, azul, negro, gris, verde, etc" },
  { label: "Base", value: "Anti-deslizante con membrana" },
  { label: "Grosor", value: "6 a 8mm" },
  { label: "Ancho rollo", value: "2 metros" },
  { label: "Instalación", value: "Rápida con cinta doble cara" },
  { label: "Superficies", value: "Concreto, pasto, tierra, madera" },
  { label: "Resistencia", value: "Tráfico intenso, eventos multi-día" },
  { label: "Corte", value: "A medida según espacio" },
  { label: "Mantenimiento", value: "Limpieza incluida post-evento" },
];

const sidebarNav = [
  { name: "Piso de Duela", href: "/servicios/carpas/pisos-complementos/duela/" },
  { name: "Alfombra Profesional", href: null, active: true },
  { name: "Cortinas y Forros", href: "/servicios/carpas/pisos-complementos/cortinas-forros/" },
  { name: "Clima Artificial", href: "/servicios/carpas/pisos-complementos/clima-artificial/" },
];

const sidebarRelated = [
  { name: "Carpas Estructurales", href: "/servicios/carpas/estructurales/" },
  { name: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
];

const reviews = [
  { author: "Carolina Mendoza", text: "Rentamos alfombra negra para una expo corporativa en el WTC. Cubrieron más de 300m² en tiempo récord y el acabado quedó impecable. La alfombra soportó 3 días de tráfico intenso sin mostrar desgaste. Servicio muy profesional y puntual.", rating: 5, date: "2025-11-12" },
  { author: "Ricardo Fuentes", text: "Alfombra roja para la gala de premiación de nuestra empresa en un hotel de Polanco. El efecto fue exactamente lo que buscábamos — elegante y VIP desde la entrada. La instalación fue rápida y el retiro después del evento fue igual de eficiente.", rating: 5, date: "2025-10-20" },
  { author: "Mariana Solís", text: "Usamos alfombra personalizada en color azul corporativo para nuestra feria de tecnología. EVENTECH cortó la alfombra a medida para cada stand y el resultado fue uniforme y profesional. El equipo de logística coordinó todo perfectamente.", rating: 5, date: "2025-09-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Alfombra Profesional para Eventos en CDMX",
    description: "Renta de alfombra profesional de alta densidad en 15+ colores para expos, ferias, eventos corporativos y pasarelas en CDMX. Instalación rápida. Desde $80/m².",
    url: "/servicios/carpas/pisos-complementos/alfombra/",
    priceRange: { min: 80, max: 200 },
    reviews,
    ratingValue: 5,
    reviewCount: 198,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Pisos y Complementos", url: "/servicios/carpas/pisos-complementos/" },
    { name: "Alfombra Profesional", url: "/servicios/carpas/pisos-complementos/alfombra/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Alfombra Profesional para Eventos en CDMX"
  description="Renta de alfombra profesional de alta densidad en 15+ colores para expos, ferias, eventos corporativos y pasarelas en CDMX. Instalación rápida. Desde $80/m²."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="15+ colores para cualquier temática"
    title='Renta de <span class="highlight">Alfombra Profesional</span> para Eventos en CDMX'
    subtitle="Alfombra industrial de alta densidad con base anti-deslizante disponible en más de 15 colores. Instalación rápida sobre cualquier superficie para expos, ferias, pasarelas y eventos corporativos."
    primaryCTA={{ label: "Cotiza tu alfombra", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar alfombra profesional para mi evento` }}
    cards={[
      {
        title: "Alfombra de alta densidad en 15+ colores",
        content: "<strong>Renta de alfombra profesional de alta densidad</strong> con base anti-deslizante y membrana protectora contra humedad. Disponible en más de 15 colores para personalizar tu evento: rojo, azul rey, verde, gris Oxford, negro, beige, burgundy, blanco y colores corporativos personalizados. Fabricada con fibra de polipropileno de alta resistencia al tráfico intenso que soporta miles de visitantes sin desgaste visible. Ideal para expos, ferias, pasarelas y eventos corporativos.",
      },
      {
        title: "Instalación rápida sobre cualquier superficie",
        content: "<strong>Instalación profesional sobre cualquier tipo de superficie</strong> — concreto, pasto, tierra o madera. Nuestro equipo mide, corta a medida y fija la alfombra con cinta de doble cara profesional para evitar bordes levantados o tropiezos. Los rollos de 2 metros de ancho permiten cubrir grandes superficies con mínimas uniones. Incluye transporte, instalación, limpieza post-evento y retiro sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas alfombra profesional para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el color y metraje ideal para tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pisos y Complementos para Carpas</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas alfombra profesional para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar alfombra profesional para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="8" rx="1"/><line x1="7" y1="8" x2="7" y2="16"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="17" y1="8" x2="17" y2="16"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Alfombra Profesional</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Alfombra Roja -->
          <section class="section section--alt" aria-labelledby="alfombra-roja-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Eventos VIP</span>
                <h2 class="showcase__title" id="alfombra-roja-heading">Alfombra Roja</h2>
                <p class="showcase__subtitle">El clásico de los eventos VIP: alfombra roja para galas, premiaciones y entradas espectaculares.</p>
                <p class="showcase__text">Nuestra <strong>alfombra roja profesional</strong> es el elemento icónico que transforma cualquier entrada en una experiencia VIP. Fabricada con fibra de polipropileno de <strong>alta densidad y color rojo intenso</strong> que no se destiñe, es perfecta para galas de premiación, estrenos, lanzamientos de producto y eventos de alfombra roja donde la primera impresión lo es todo. Disponible en anchos de 1.5, 2 y 3 metros para pasarelas y áreas de recepción.</p>
                <p class="showcase__text">La alfombra roja se complementa con nuestros <a href="/servicios/accesorios/senalizacion-alfombras/">postes con cinta</a> para delimitar el recorrido VIP, <strong>backdrops con logotipos</strong> para la zona de fotos y señalización personalizada. Ideal para <strong>premiaciones corporativas, bodas de lujo, inauguraciones y eventos de gala</strong> donde cada invitado se siente como una estrella desde el momento en que llega.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Rojo intenso</span>
                  <span class="showcase__tag">Alta densidad</span>
                  <span class="showcase__tag">Galas VIP</span>
                  <span class="showcase__tag">Desde $80/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra Roja
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Alfombra Roja</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Alfombra Negra -->
          <section class="section section--alt" aria-labelledby="alfombra-negra-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegancia corporativa</span>
                <h2 class="showcase__title" id="alfombra-negra-heading">Alfombra Negra</h2>
                <p class="showcase__subtitle">Sofisticación y elegancia para corporativos, lanzamientos de producto y eventos de alto perfil.</p>
                <p class="showcase__text">La <strong>alfombra negra profesional</strong> es la opción más solicitada para eventos corporativos y lanzamientos de producto. Su tono negro profundo y uniforme crea un ambiente sofisticado y moderno que complementa cualquier decoración. Es la base perfecta para <strong>stands de expo, áreas de presentación, escenarios y zonas de networking</strong> donde la imagen de marca requiere un fondo neutro y elegante.</p>
                <p class="showcase__text">La alfombra negra funciona excepcionalmente bien con <strong>iluminación direccional, señalización LED y mobiliario contemporáneo</strong>. En combinación con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a>, los logos y elementos de branding resaltan con mayor impacto visual. Soporta tráfico intenso de miles de visitantes durante eventos de varios días sin mostrar desgaste ni acumulación de polvo visible.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Negro profundo</span>
                  <span class="showcase__tag">Corporativos</span>
                  <span class="showcase__tag">Multi-día</span>
                  <span class="showcase__tag">Desde $80/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra Negra
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Alfombra Negra</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Alfombra Personalizada -->
          <section class="section section--alt" aria-labelledby="alfombra-personalizada-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tu color, tu marca</span>
                <h2 class="showcase__title" id="alfombra-personalizada-heading">Alfombra Personalizada</h2>
                <p class="showcase__subtitle">Color exacto a juego con tu branding corporativo o la temática de tu evento.</p>
                <p class="showcase__text">Nuestra <strong>alfombra personalizada</strong> te permite elegir el color exacto que necesitas para alinear el piso con la identidad visual de tu marca o la temática de tu evento. Con más de <strong>15 colores en inventario</strong> y la posibilidad de encargar colores especiales, garantizamos que la alfombra se integre perfectamente con tu decoración, señalización y materiales de marketing.</p>
                <p class="showcase__text">La personalización va más allá del color: ofrecemos <strong>combinaciones por zonas</strong> (un color en el escenario, otro en networking, otro en la entrada), cortes en formas especiales y la posibilidad de crear <strong>patrones con franjas de diferentes colores</strong>. Ideal para ferias comerciales, convenciones temáticas y eventos donde la coherencia visual entre el piso y la decoración marca la diferencia.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Color a medida</span>
                  <span class="showcase__tag">Branding</span>
                  <span class="showcase__tag">Combinaciones</span>
                  <span class="showcase__tag">Desde $100/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra Personalizada
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Alfombra Personalizada</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Expo -->
          <section class="section section--alt" aria-labelledby="kit-expo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Solución integral para expos</span>
                <h2 class="showcase__title" id="kit-expo-heading">Kit Expo</h2>
                <p class="showcase__subtitle">Paquete completo de alfombra + señalización + stands para ferias y exposiciones comerciales.</p>
                <p class="showcase__text">Nuestro <strong>Kit Expo</strong> es la solución integral para ferias comerciales y exposiciones que necesitan un piso profesional con todo incluido. El paquete combina <strong>alfombra profesional en el color de tu elección</strong> para cubrir toda el área de exposición, con señalización de piso para delimitar stands, pasillos de circulación y áreas comunes. Incluye corte a medida para cada stand individual.</p>
