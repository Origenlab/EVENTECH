---
/**
 * ─── Piso de Duela — Pagina de Producto (Nivel 4) ───
 * Duela laminada 12mm sobre estructura elevada de aluminio
 * para bodas, galas y eventos premium.
 *
 * Jerarquia: Servicios > Carpas > Pisos y Complementos > Piso de Duela
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { label: "Piso de Duela" },
];

const faqs = [
  { question: "¿Se puede instalar piso de duela sobre pasto o jardín?", answer: 'Sí, es una de nuestras instalaciones más frecuentes. La <strong>estructura elevada de aluminio con patas ajustables</strong> se coloca directamente sobre pasto, tierra o jardín, elevando la duela entre 10 y 15 cm sobre el terreno natural. Esto protege completamente contra la humedad del suelo y permite compensar desniveles de hasta 40 cm. La base se ancla con estacas o contrapesos según el tipo de terreno, garantizando una superficie firme y estable durante todo el evento.' },
  { question: "¿El piso de duela resiste tacones y sillas pesadas?", answer: 'Absolutamente. Nuestra <strong>duela laminada de 12mm</strong> está fabricada con un acabado semi-mate de alta resistencia al tráfico intenso. Soporta sin problema tacones de aguja, sillas Tiffany, mesas redondas con bases de hierro y el paso constante de cientos de invitados. La superficie cuenta con tratamiento <strong>anti-rayones y anti-deslizante</strong> que mantiene el aspecto impecable durante todo tu evento, incluso con pista de baile activa.' },
  { question: "¿La nivelación del terreno está incluida en el precio?", answer: 'Sí, la <strong>nivelación profesional está incluida</strong> en cada renta de piso de duela. Nuestro equipo realiza una visita técnica previa gratuita para evaluar las condiciones del terreno y diseñar el plan de nivelación. Las patas ajustables de la estructura compensan desniveles, pendientes y superficies irregulares. El resultado es un piso perfectamente plano y estable sin importar las condiciones originales del terreno.' },
  { question: "¿Cuánto tiempo tarda el montaje del piso de duela?", answer: 'El tiempo de montaje depende de la superficie a cubrir. Para áreas de <strong>50 a 100 m²</strong> (carpas medianas), el montaje tarda aproximadamente <strong>4 a 6 horas</strong>. Para superficies de <strong>100 a 200 m²</strong> (carpas grandes), el equipo completa la instalación en <strong>6 a 10 horas</strong>. Recomendamos programar el montaje un día antes del evento para garantizar tiempo de ajustes finales. El desmontaje toma aproximadamente la mitad del tiempo de instalación.' },
  { question: "¿Cuánto cuesta el metro cuadrado de piso de duela?", answer: 'El precio por metro cuadrado varía según el acabado y la superficie total. La <strong>duela natural</strong> (tono claro) parte desde <strong>$150/m²</strong>. La duela en tonos <strong>roble y nogal</strong> desde <strong>$180/m²</strong>. El <strong>Kit Piso Completo</strong> (duela + nivelación + zoclo perimetral) desde <strong>$250/m²</strong>. A mayor superficie, mejor precio por metro cuadrado. Todos los precios incluyen instalación, nivelación y desmontaje. Cotiza tu superficie exacta para un precio personalizado.' },
  { question: "¿Cuál es el mínimo de metros cuadrados para rentar?", answer: 'El <strong>mínimo de renta es de 20 m²</strong>, equivalente a una carpa pequeña o un área de recepción compacta. Sin embargo, la mayoría de nuestros clientes rentan entre 50 y 200 m², que cubre el área principal de carpas medianas a grandes. Para superficies menores a 20 m², te recomendamos nuestras <a href="/servicios/pistas-baile/">pistas de baile modulares</a> que ofrecen acabados similares en formatos más compactos.' },
];

const specs = [
  { label: "Material", value: "Duela laminada 12mm" },
  { label: "Acabado", value: "Semi-mate resistente a tráfico" },
  { label: "Estructura", value: "Base elevada de aluminio" },
  { label: "Altura", value: "10 a 15 cm sobre terreno" },
  { label: "Nivelación", value: "Profesional en terreno irregular" },
  { label: "Resistencia", value: "Tráfico intenso, tacones, sillas" },
  { label: "Colores", value: "Natural, roble, nogal, gris" },
  { label: "Dimensión módulo", value: "1.2 x 0.6 metros" },
  { label: "Protección", value: "Anti-humedad y anti-deslizante" },
  { label: "Montaje", value: "Incluido, equipo profesional" },
];

const sidebarNav = [
  { name: "Piso de Duela", href: null, active: true },
  { name: "Alfombra Profesional", href: "/servicios/carpas/pisos-complementos/alfombra/" },
  { name: "Cortinas y Forros", href: "/servicios/carpas/pisos-complementos/cortinas-forros/" },
  { name: "Clima Artificial", href: "/servicios/carpas/pisos-complementos/clima-artificial/" },
];

const sidebarRelated = [
  { name: "Carpas Estructurales", href: "/servicios/carpas/estructurales/" },
  { name: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
];

const reviews = [
  { author: "Mónica Villarreal", text: "Rentamos piso de duela natural para nuestra boda en un jardín de Coyoacán. La nivelación quedó perfecta sobre el pasto irregular y el acabado le dio un aspecto de salón de eventos a la carpa. Todos los invitados comentaron lo elegante que se veía. Servicio impecable de principio a fin.", rating: 5, date: "2025-11-20" },
  { author: "Fernando Castillo", text: "Usamos duela nogal oscuro para una gala corporativa en un terreno de Santa Fe. El equipo de EVENTECH niveló una pendiente considerable y el resultado fue una superficie perfectamente plana. Los tacones de las invitadas no dejaron marca alguna. Excelente calidad.", rating: 5, date: "2025-10-05" },
  { author: "Daniela Ortega", text: "Para los XV años de mi hija elegimos duela roble en una carpa de 120m². El montaje fue rápido, el acabado hermoso y la pista de baile funcionó perfecto sobre la duela. Muy recomendable para eventos donde quieres un piso premium.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Piso de Duela para Eventos en CDMX",
    description: "Renta de piso de duela laminada de 12mm sobre estructura elevada para carpas y eventos en CDMX. Nivelación profesional. Aspecto premium. Desde $150/m².",
    url: "/servicios/carpas/pisos-complementos/duela/",
    priceRange: { min: 150, max: 350 },
    reviews,
    ratingValue: 5,
    reviewCount: 234,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Pisos y Complementos", url: "/servicios/carpas/pisos-complementos/" },
    { name: "Piso de Duela", url: "/servicios/carpas/pisos-complementos/duela/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Piso de Duela para Eventos en CDMX"
  description="Renta de piso de duela laminada de 12mm sobre estructura elevada para carpas y eventos en CDMX. Nivelación profesional. Aspecto premium. Desde $150/m²."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Aspecto premium sobre cualquier terreno"
    title='Renta de <span class="highlight">Piso de Duela</span> para Eventos en CDMX'
    subtitle="Duela laminada de 12mm con acabado semi-mate sobre estructura elevada de aluminio. Nivelación profesional en cualquier terreno, protección contra humedad y aspecto premium para bodas y galas."
    primaryCTA={{ label: "Cotiza tu piso de duela", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar piso de duela para mi evento` }}
    cards={[
      {
        title: "Duela laminada de 12mm con acabado premium",
        content: "<strong>Renta de piso de duela laminada</strong> de 12mm con acabado semi-mate resistente al tráfico intenso sobre estructura elevada de aluminio. Protección completa contra humedad del terreno, superficie anti-deslizante y aspecto de madera natural que transforma cualquier carpa en un salón de eventos de primer nivel. Disponible en tonos natural, roble, nogal y gris. Módulos de 1.2 x 0.6 metros que se ensamblan sin juntas visibles para una superficie continua y elegante.",
      },
      {
        title: "Nivelación profesional e instalación incluida",
        content: "<strong>Nivelación profesional en cualquier terreno irregular</strong> — jardín, tierra, pasto o pendiente. La estructura elevada de aluminio con patas ajustables compensa desniveles de hasta 40 cm, creando una superficie perfectamente plana y estable. Incluye visita técnica previa gratuita, montaje por equipo profesional, zoclo perimetral opcional y desmontaje completo. Resistencia garantizada para tacones, sillas, mesas y tráfico intenso de invitados.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un piso premium para tu carpa o evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el acabado ideal para tu espacio y presupuesto"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pisos y Complementos para Carpas</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas piso de duela para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar piso de duela para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="8" y1="6" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="18"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Piso de Duela</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Duela Natural -->
          <section class="section section--alt" aria-labelledby="duela-natural-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Clásico para bodas</span>
                <h2 class="showcase__title" id="duela-natural-heading">Duela Natural</h2>
                <p class="showcase__subtitle">Tono madera clara que aporta luminosidad y calidez natural a tu carpa de bodas y eventos sociales.</p>
                <p class="showcase__text">Nuestra <strong>duela natural en tono madera clara</strong> es la favorita para bodas al aire libre y eventos sociales en la Ciudad de México. Su acabado semi-mate con veta suave refleja la luz de manera natural, creando un ambiente luminoso y cálido dentro de la carpa. Montada sobre <strong>estructura elevada de aluminio</strong> con protección anti-humedad, es perfecta para jardines, haciendas y terrenos al aire libre donde el pasto o la tierra no permiten un piso firme.</p>
                <p class="showcase__text">La duela natural combina armoniosamente con <strong>decoraciones en tonos blancos, pasteles, dorados y rústicos</strong>, convirtiéndola en la opción predilecta para bodas románticas y celebraciones elegantes. Cada módulo de 1.2 x 0.6 metros se ensambla sin tornillos visibles, logrando una superficie continua sin juntas perceptibles. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente integral y fotografías espectaculares.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono claro</span>
                  <span class="showcase__tag">Semi-mate</span>
                  <span class="showcase__tag">Bodas</span>
                  <span class="showcase__tag">Desde $150/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Natural
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Duela Natural</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Duela Roble -->
          <section class="section section--alt" aria-labelledby="duela-roble-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Versatilidad elegante</span>
                <h2 class="showcase__title" id="duela-roble-heading">Duela Roble</h2>
                <p class="showcase__subtitle">Tono medio cálido ideal para eventos elegantes, XV años y celebraciones con decoración sofisticada.</p>
                <p class="showcase__text">La <strong>duela en tono roble</strong> ofrece un equilibrio perfecto entre calidez y elegancia. Su tono medio con vetas definidas aporta personalidad y distinción a cualquier espacio, siendo la opción más versátil de nuestro catálogo. Ideal para <strong>XV años, aniversarios, cenas de gala y eventos corporativos</strong> donde se busca un piso con carácter que complemente decoraciones en tonos neutros, dorados, burgundy y verdes.</p>
                <p class="showcase__text">El acabado semi-mate de alta resistencia soporta <strong>tráfico intenso sin mostrar desgaste</strong>, incluyendo tacones, sillas pesadas y el paso continuo de invitados durante eventos de varias horas. La duela roble funciona excepcionalmente bien en carpas con <a href="/servicios/carpas/pisos-complementos/cortinas-forros/">forros de satín</a> en tonos ivory o champagne, creando un contraste elegante entre el piso cálido y las telas suaves del techo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono medio</span>
                  <span class="showcase__tag">Vetas definidas</span>
                  <span class="showcase__tag">XV años</span>
                  <span class="showcase__tag">Desde $180/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Roble
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Duela Roble</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Duela Nogal Oscuro -->
          <section class="section section--alt" aria-labelledby="duela-nogal-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Máxima sofisticación</span>
                <h2 class="showcase__title" id="duela-nogal-heading">Duela Nogal Oscuro</h2>
                <p class="showcase__subtitle">Tono oscuro premium para galas, eventos de lujo y celebraciones donde el impacto visual es prioridad.</p>
                <p class="showcase__text">La <strong>duela nogal oscuro</strong> es nuestra opción más sofisticada, con un tono profundo y rico que evoca los salones de eventos más exclusivos. Su acabado semi-mate con vetas sutiles crea un efecto de profundidad y elegancia que transforma cualquier carpa en un espacio de lujo. Perfecta para <strong>galas corporativas, cenas de premiación, bodas de noche y eventos de alto perfil</strong> donde la imagen y la atmósfera son fundamentales.</p>
                <p class="showcase__text">El contraste del piso oscuro con <strong>manteles blancos, arreglos florales y centros de mesa iluminados</strong> crea un efecto visual dramático y fotogénico que impresiona a cada invitado. La duela nogal es especialmente popular en combinación con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a> y <a href="/servicios/iluminacion/decorativa/candiles/">candiles de cristal</a>, que proyectan reflejos elegantes sobre la superficie oscura del piso.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono oscuro</span>
                  <span class="showcase__tag">Premium</span>
                  <span class="showcase__tag">Galas</span>
                  <span class="showcase__tag">Desde $200/m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Nogal
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Duela Nogal Oscuro</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Piso Completo -->
          <section class="section section--alt" aria-labelledby="kit-piso-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Solución integral</span>
                <h2 class="showcase__title" id="kit-piso-heading">Kit Piso Completo</h2>
                <p class="showcase__subtitle">Paquete todo incluido: duela + nivelación profesional + zoclo perimetral para un acabado perfecto.</p>
                <p class="showcase__text">Nuestro <strong>Kit Piso Completo</strong> es la solución integral para quienes buscan un acabado impecable de principio a fin. Incluye la <strong>duela laminada en el tono de tu elección</strong> (natural, roble, nogal o gris), estructura elevada de aluminio con nivelación profesional del terreno, y <strong>zoclo perimetral decorativo</strong> que oculta la unión entre el piso y las paredes de la carpa, creando un acabado limpio y profesional.</p>
