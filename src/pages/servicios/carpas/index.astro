---
/**
 * ─── Carpas Category Page ───
 * Página de categoría: Renta de Carpas para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas" },
];

const SUB_SERVICES = [
  {
    name: "Carpas Árabes",
    excerpt: "Elegancia clásica con techos tensados y cortinas decorativas. La opción favorita para bodas, XV años y eventos sociales al aire libre.",
    cta: "Carpas Árabes",
    href: "/servicios/carpas/carpas-arabes/",
    icon: "tent",
  },
  {
    name: "Carpas Estructurales",
    excerpt: "Estructura rígida de aluminio con lona tensada. Resistentes a lluvia y viento, ideales para eventos de gran formato durante todo el año.",
    cta: "Estructurales",
    href: "/servicios/carpas/estructurales/",
    icon: "package",
  },
  {
    name: "Carpas Tipo Hangar",
    excerpt: "Gran formato para expos, conciertos, ferias y eventos corporativos masivos. Capacidad desde 500 hasta más de 5,000 personas.",
    cta: "Tipo Hangar",
    href: "/servicios/carpas/hangar/",
    icon: "layers",
  },
  {
    name: "Pisos y Complementos",
    excerpt: "Duela de madera, alfombra, plataformas niveladas, iluminación interior, cortinas y clima artificial para completar tu espacio.",
    cta: "Complementos",
    href: "/servicios/carpas/pisos-complementos/",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Qué tamaños de carpas tienen disponibles?", answer: "Manejamos carpas desde 4x4 metros (ideales para áreas de registro o coctelería) hasta estructuras de 20x50 metros o más para grandes eventos. Las medidas más solicitadas son 6x12m (80-100 personas), 10x20m (150-200 personas) y 15x30m (300-400 personas). Diseñamos configuraciones a la medida según tu venue y número de invitados." },
  { question: "¿Las carpas resisten lluvia y viento fuerte?", answer: "Sí. Nuestras carpas estructurales y tipo hangar están certificadas para resistir lluvias intensas y vientos de hasta 80 km/h. Utilizamos lonas impermeables de grado comercial, estructura de aluminio reforzado y sistemas de anclaje profesional con lastres de concreto o estacas de acero según el terreno." },
  { question: "¿El montaje y desmontaje están incluidos en el precio?", answer: "Sí. Todos nuestros paquetes de carpas incluyen entrega, montaje profesional por nuestro equipo certificado y desmontaje al finalizar el evento. El montaje se realiza entre 24 y 48 horas antes del evento dependiendo del tamaño de la estructura." },
  { question: "¿Pueden instalar piso dentro de la carpa?", answer: "Por supuesto. Ofrecemos tres opciones de piso: duela de madera elegante (ideal para bodas), alfombra en múltiples colores y plataforma nivelada para terrenos irregulares. El piso se instala sobre una base que lo mantiene separado del suelo, garantizando estabilidad y limpieza." },
  { question: "¿Con cuánta anticipación debo reservar la carpa?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación para garantizar disponibilidad del tamaño que necesitas. En temporada alta (octubre a febrero) lo ideal es apartar con 2 meses. Para eventos muy grandes (+500 personas) o carpas tipo hangar, sugerimos contactarnos con al menos 2 meses de anticipación." },
  { question: "¿Necesito permisos especiales para instalar una carpa?", answer: "Depende del venue. En jardines y terrenos privados generalmente no se requieren permisos adicionales. Para espacios públicos o delegacionales sí pueden requerirse. Nuestro equipo te asesora sobre los requisitos específicos de tu ubicación y te ayudamos con la documentación técnica si es necesaria." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas para Eventos en CDMX",
    description: "Carpas árabes, estructurales y tipo hangar para bodas, corporativos y eventos masivos. Montaje, piso e iluminación incluidos.",
    url: "/servicios/carpas/",
    priceRange: { min: 3000, max: 150000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpas para Eventos en CDMX"
  description="Renta de carpas árabes, estructurales y tipo hangar para eventos en CDMX. Montaje profesional, piso e iluminación incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 500 eventos protegidos en CDMX"
    title='Renta de <span class="highlight">Carpas para Eventos</span> en CDMX'
    subtitle="Carpas árabes, estructurales y tipo hangar con montaje profesional, iluminación interior y opciones de piso incluidas. Transforma cualquier jardín, terraza o espacio abierto en un venue espectacular y protegido, sin importar el clima."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa para mi evento en CDMX` }}
    cards={[
      {
        title: "Estructuras de grado comercial con certificación de seguridad",
        content: "<strong>Renta de carpas para eventos</strong> fabricadas con los más altos estándares de la industria. Lonas impermeables de PVC con protección UV al 99%, estructura de aluminio anodizado serie 6000 o acero galvanizado según el tipo de carpa, tensores de acero inoxidable 304 y sistemas de anclaje profesional con lastres de concreto o estacas de acero según las condiciones del terreno. Cada estructura es inspeccionada y certificada por nuestro equipo de ingeniería antes de su instalación, garantizando la seguridad total de tus invitados ante lluvia, viento y condiciones climáticas adversas.",
      },
      {
        title: "Montaje integral con visita técnica y diseño de espacios",
        content: "<strong>Servicio completo de carpas</strong> con enfoque llave en mano. Nuestro equipo de producción realiza una visita técnica gratuita a tu venue para evaluar terreno, accesos, puntos de corriente y condiciones del espacio. Diseñamos la distribución óptima considerando flujo de invitados, ubicación de tarima y pista de baile, y ejecutamos el montaje profesional entre 24 y 48 horas antes de tu evento. Complementa tu carpa con <strong>pisos de duela o alfombra</strong>, <strong>iluminación arquitectónica interior</strong>, cortinas decorativas y clima artificial para un espacio completamente personalizado.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Tu evento es al aire libre? Nosotros lo convertimos en un venue de primer nivel"
    subheadline="Recibe una propuesta técnica personalizada con el tipo, tamaño y complementos ideales para tu celebración — sin compromiso"
    primaryCTA={{ label: "Cotizar mi carpa", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Carpas"
        subtitle="La estructura perfecta para cada tipo de evento y presupuesto"
        description={[
          "Desde una carpa íntima para 20 personas en un jardín de Coyoacán hasta estructuras de gran formato para más de 5,000 asistentes en explanadas corporativas de Santa Fe — contamos con el inventario más completo de carpas para eventos en la Ciudad de México y zona metropolitana.",
          "Cada estructura incluye montaje profesional certificado, lona impermeable de grado comercial y opciones de personalización completa: pisos, iluminación, cortinas, clima artificial y todo lo necesario para que tu espacio luzca exactamente como lo imaginaste."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <Card
            name={sub.name}
            excerpt={sub.excerpt}
            cta={sub.cta}
            href={sub.href}
            icon={sub.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS ÁRABES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="arabes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">La más solicitada para bodas</span>
          <h2 class="showcase__title" id="arabes-heading">Carpas Árabes</h2>
          <p class="showcase__subtitle">Elegancia clásica con techos tensados que crean ambientes románticos y sofisticados para bodas, XV años y eventos sociales al aire libre.</p>
          <p class="showcase__text">La <strong>carpa árabe</strong> es la opción preferida por wedding planners y organizadores de eventos sociales en CDMX por su silueta elegante con techos altos de hasta 5 metros y caídas naturales que evocan sofisticación. Disponibles en <strong>blanco, marfil, beige y colores personalizados</strong>, con cortinas laterales de tela chiffon o blackout que permiten crear ambientes abiertos, semi-cerrados o completamente cerrados según la hora del día. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para un montaje integral.</p>
          <p class="showcase__text">Disponibles desde <strong>6x6 metros (30 invitados) hasta 15x30 metros (400+ invitados)</strong>. Cada instalación incluye <strong>estructura de aluminio serie 6000, tensores de acero inoxidable 304</strong> y lona premium de PVC con protección UV al 99% e impermeabilidad certificada. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> — fairy lights, candiles o spots LED — para un resultado que dejará sin aliento a tus invitados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">6x6m</span>
            <span class="showcase__tag">6x12m</span>
            <span class="showcase__tag">10x20m</span>
            <span class="showcase__tag">15x30m</span>
            <span class="showcase__tag">Cortinas Chiffon</span>
            <span class="showcase__tag">Fairy Lights</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Carpas Árabes
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l9-16 9 16"/>
              <path d="M7.5 20l4.5-8 4.5 8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS ESTRUCTURALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="estructurales-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Certificación anti-lluvia y viento</span>
          <h2 class="showcase__title" id="estructurales-heading">Carpas Estructurales</h2>
          <p class="showcase__subtitle">Estructura rígida de aluminio anodizado con lona PVC tensada. La solución más segura y versátil para eventos profesionales durante todo el año.</p>
          <p class="showcase__text">Las <strong>carpas estructurales</strong> son la elección de empresas, agencias de eventos y wedding planners que exigen máxima confiabilidad. Su <strong>marco rígido de aluminio anodizado serie 6000</strong> con lona PVC de 650 g/m² garantiza estabilidad total ante lluvia intensa y vientos de hasta 80 km/h — certificadas bajo norma DIN 4102. Paredes laterales modulares (sólidas, con ventana o completamente transparentes) permiten configurar el espacio según las necesidades exactas de cada evento.</p>
          <p class="showcase__text">Disponibles desde <strong>5x5 hasta 20x40 metros</strong> con altura libre de 3 a 6 metros. Ideales para <strong>bodas en jardín, eventos corporativos, ferias y exposiciones</strong>. Incluyen <strong>canaletas de desagüe integradas</strong>, anclaje con lastres de 250 kg y opciones de <strong>pared panorámica transparente</strong>. Equípalas con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para presentaciones corporativas impecables dentro de la estructura.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Aluminio Serie 6000</span>
            <span class="showcase__tag">Lona PVC 650g</span>
            <span class="showcase__tag">Paredes Modulares</span>
            <span class="showcase__tag">Transparentes</span>
            <span class="showcase__tag">Anti-lluvia 80km/h</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Estructurales
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS TIPO HANGAR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="hangar-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">+500 invitados sin límite</span>
          <h2 class="showcase__title" id="hangar-heading">Carpas Tipo Hangar</h2>
          <p class="showcase__subtitle">Estructuras de gran escala para producciones masivas. La solución profesional para expos, conciertos, ferias comerciales y convenciones donde otros espacios se quedan cortos.</p>
          <p class="showcase__text">Nuestras <strong>carpas tipo hangar</strong> están diseñadas para eventos que requieren escala industrial. Con <strong>claros libres de hasta 30 metros sin columnas intermedias</strong>, ofrecen un espacio completamente diáfano perfecto para <strong>expos con stands de exhibición, conciertos con tarima y PA system, ferias comerciales con circulación vehicular</strong> y convenciones corporativas de 500 a más de 5,000 asistentes simultáneos.</p>
          <p class="showcase__text">Estructura de <strong>acero galvanizado por inmersión en caliente con lona industrial de 900 g/m²</strong>, preparada para condiciones climáticas extremas y uso intensivo. Incluyen <strong>puertas de acceso vehicular de hasta 5 metros</strong>, puntos de anclaje certificados para rigging de <a href="/servicios/iluminacion/">iluminación profesional</a> y <a href="/servicios/audiovisual/">equipo de sonido</a>, e instalación eléctrica trifásica con tableros de distribución. La estructura soporta cargas suspendidas de hasta 500 kg por punto de anclaje.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Claro 20m</span>
            <span class="showcase__tag">Claro 30m</span>
            <span class="showcase__tag">Sin Columnas</span>
            <span class="showcase__tag">Acceso Vehicular 5m</span>
            <span class="showcase__tag">Rigging Certificado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Tipo Hangar
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M4 20V8l8-5 8 5v12"/>
              <path d="M9 20v-6h6v6"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISOS Y COMPLEMENTOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pisos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Personalización total</span>
          <h2 class="showcase__title" id="pisos-heading">Pisos y Complementos</h2>
          <p class="showcase__subtitle">Duela de madera, alfombra profesional, plataformas niveladas, iluminación interior, cortinas decorativas y clima artificial. Todo para convertir una estructura vacía en un venue de primer nivel.</p>
          <p class="showcase__text">El piso transforma radicalmente la experiencia dentro de una carpa. Nuestra <strong>duela de madera laminada de 12 mm</strong> con acabado semi-mate es la opción premium para bodas y galas — instalada sobre bastidores que la elevan del terreno natural garantizando estabilidad y protección contra humedad. La <strong>alfombra industrial de alta densidad</strong> en más de 15 colores es la elección profesional para expos, ferias y corporativos. Las <strong>plataformas modulares niveladas</strong> son indispensables para jardines, predios y terrenos irregulares donde se requiere una superficie perfectamente plana.</p>
          <p class="showcase__text">Eleva el ambiente con <a href="/servicios/iluminacion/">iluminación LED profesional</a> interior — candiles de cristal, fairy lights, spots direccionables y wash lights que transforman el espacio. Agrega <strong>cortinas y forros textiles</strong> en chiffon, satín o blackout que ocultan la estructura metálica y crean ambientes envolventes. Completa con <strong>sistemas de clima artificial</strong> (calefacción industrial o enfriamiento evaporativo) para garantizar el confort de tus invitados en cualquier temporada. Complementa con <a href="/servicios/mobiliario/">mobiliario elegante</a> para un montaje integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Duela 12mm</span>
            <span class="showcase__tag">Alfombra HD</span>
            <span class="showcase__tag">Plataformas</span>
            <span class="showcase__tag">Iluminación LED</span>
            <span class="showcase__tag">Clima Artificial</span>
            <span class="showcase__tag">Cortinas Textiles</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Complementos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M12 6v6l4 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Carpas"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu carpa, es natural tener preguntas sobre tamaños, resistencia, montaje y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre carpas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de carpas para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Carpa"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de carpas. Sin compromiso, sin costos ocultos.",
