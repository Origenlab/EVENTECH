---
/**
 * ─── EVENTECH.MX — Carpas y Estructuras (L3, rediseño 2026) ───
 * Renta de carpas árabes, estructurales, hangar y pisos para eventos en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";

const SUB_SERVICES = [
  {
    id: "carpas-arabes",
    name: "Carpas Árabes",
    badge: "Más solicitada",
    excerpt: "El modelo favorito para bodas y XV años al aire libre. Elegantes, versátiles y disponibles con forro interior en blanco, crema o marfil.",
    href: "/servicios/carpas/carpas-arabes/",
    image: "/images/carpas/carpa-arabe-beduina-boda-jardin.avif",
    subcategories: [
      { name: "Árabe Estándar", href: "/servicios/carpas/carpas-arabes/estandar/" },
      { name: "Árabe Premium", href: "/servicios/carpas/carpas-arabes/premium/" },
      { name: "Con Forro Interior", href: "/servicios/carpas/carpas-arabes/con-forro/" },
      { name: "Mediana para XV años", href: "/servicios/carpas/carpas-arabes/xv-anos/" },
    ],
  },
  {
    id: "estructurales",
    name: "Estructurales",
    badge: "Gran formato",
    excerpt: "Para eventos de 100 a 2,000 personas. Sin columnas centrales, resistentes a viento y lluvia, con piso flotante nivelado incluido.",
    href: "/servicios/carpas/estructurales/",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    subcategories: [
      { name: "Estructural Mediana", href: "/servicios/carpas/estructurales/mediana/" },
      { name: "Estructural Grande", href: "/servicios/carpas/estructurales/grande/" },
      { name: "Transparente", href: "/servicios/carpas/estructurales/transparente/" },
      { name: "Con Paredes de Cristal", href: "/servicios/carpas/estructurales/cristal/" },
    ],
  },
  {
    id: "hangar",
    name: "Hangar",
    badge: "Sin límites",
    excerpt: "Estructura industrial de gran escala para eventos corporativos, exposiciones y congresos. Vanos de hasta 40 metros sin obstrucciones.",
    href: "/servicios/carpas/hangar/",
    image: "/images/carpas/carpa-hangar-industrial-evento-grande.avif",
    subcategories: [
      { name: "Hangar Estándar", href: "/servicios/carpas/hangar/estandar/" },
      { name: "Hangar XL", href: "/servicios/carpas/hangar/xl/" },
      { name: "Con Puertas Industriales", href: "/servicios/carpas/hangar/puertas-industriales/" },
      { name: "Corporativo", href: "/servicios/carpas/hangar/corporativo/" },
    ],
  },
  {
    id: "pisos-complementos",
    name: "Pisos y Complementos",
    badge: "Acabado total",
    excerpt: "Piso flotante nivelado, forros interiores, paredes laterales, climatización y cortinas de tela que transforman cualquier carpa en un recinto de lujo.",
    href: "/servicios/carpas/pisos-complementos/",
    image: "/images/carpas/forros-interiores-carpa-elegante.avif",
    subcategories: [
      { name: "Piso Flotante", href: "/servicios/carpas/pisos-complementos/piso-flotante/" },
      { name: "Forros Interiores", href: "/servicios/carpas/pisos-complementos/forros/" },
      { name: "Paredes Laterales", href: "/servicios/carpas/pisos-complementos/paredes/" },
      { name: "Climatización", href: "/servicios/carpas/pisos-complementos/climatizacion/" },
    ],
  },
];

const carpFeatures = [
  {
    icon: "📐",
    title: "Ingeniería previa al montaje",
    body: "Calculamos carga de viento, tipo de suelo y puntos de anclaje antes de proponer cualquier estructura. Lo que instalamos está dimensionado para el terreno real de tu venue.",
  },
  {
    icon: "🏗️",
    title: "Inventario certificado",
    body: "Todas nuestras estructuras cuentan con certificación de resistencia y carga. Revisadas pieza a pieza antes y después de cada evento.",
  },
  {
    icon: "✨",
    title: "Acabado de recinto, no de carpa",
    body: "Forro interior, iluminación integrada y piso nivelado son parte del paquete estándar. El objetivo es que nadie note que está bajo una estructura temporal.",
  },
  {
    icon: "📍",
    title: "Levantamiento en sitio",
    body: "Visitamos el venue antes del montaje para verificar accesos, pendientes del terreno, redes eléctricas y cualquier restricción del espacio.",
  },
  {
    icon: "👷",
    title: "Cuadrilla especializada propia",
    body: "Nuestro equipo de montaje tiene más de 15 años trabajando exclusivamente en estructuras temporales para eventos. No subcontratamos el montaje.",
  },
  {
    icon: "🛡️",
    title: "Estructura lista antes del evento",
    body: "Garantizamos que la carpa está montada, verificada y en condiciones impecables antes de que llegue el primer invitado. Sin sorpresas el día del evento.",
  },
];

const steps = [
  { n: 1, t: "Levantamiento", p: "Visitamos el venue para analizar terreno, pendientes, accesos y dimensiones disponibles. Sin costo adicional." },
  { n: 2, t: "Propuesta", p: "Te presentamos opciones de estructura con plano de distribución, capacidad estimada y cotización detallada." },
  { n: 3, t: "Montaje", p: "Nuestra cuadrilla instala la estructura en la fecha acordada. Verificamos estabilidad y acabados antes de entregarte el espacio." },
  { n: 4, t: "Desmontaje", p: "Al terminar el evento, nuestro equipo recoge y desmonta toda la estructura sin que muevas un dedo." },
];

const faqs = [
  {
    question: "¿Qué tipos de carpa ofrecen y cuál es la diferencia principal?",
    answer: "Manejamos cuatro tipos: Árabe (octogonal, ideal para bodas y XV años en jardines y haciendas), Estructural (rectangular sin columnas centrales, para eventos de 100 a 2,000 personas), Hangar (estructura industrial de gran escala para exposiciones y congresos) y Transparente (permite ver el cielo, muy solicitada para bodas nocturnas). Cada tipo responde a un perfil de evento y terreno distinto; te asesoramos sobre cuál funciona mejor para tu venue.",
  },
  {
    question: "¿El piso y la iluminación están incluidos en el precio?",
    answer: "El precio base incluye la estructura, forros exteriores y anclaje. El piso flotante nivelado, forro interior, iluminación perimetral, paredes laterales y climatización son complementos que se cotizan según el tipo de evento y venue. En la mayoría de los casos los incluimos como parte del paquete completo; lo especificamos en tu cotización.",
  },
  {
    question: "¿Cuántas personas caben en cada tipo de carpa?",
    answer: "La capacidad varía según el modelo y la distribución. Como referencia: una carpa árabe estándar de 10×10 m cubre 80–100 personas en montaje banquete; una estructural de 20×30 m, hasta 400 personas; un hangar puede superar las 1,000 personas. Te enviamos el plano con aforos exactos según la distribución que elijas.",
  },
  {
    question: "¿En cuánto tiempo se monta una carpa?",
    answer: "Una carpa árabe estándar se monta en 4–6 horas; una estructural mediana, en 1–2 días; un hangar de gran formato, en 2–3 días. Planificamos el montaje con suficiente anticipación para que la estructura esté lista y verificada el día anterior al evento.",
  },
  {
    question: "¿Las carpas son resistentes a lluvia y viento fuerte?",
    answer: "Sí. Todas nuestras estructuras están diseñadas para las condiciones climáticas de Ciudad de México y zona metropolitana. Las láminas son impermeables y los sistemas de anclaje se calculan según la carga de viento estimada para la zona. En caso de pronóstico adverso, reforzamos los anclajes y verificamos la estructura antes del evento.",
  },
  {
    question: "¿Atienden eventos fuera de CDMX?",
    answer: "Sí. Cubrimos toda la Zona Metropolitana: Naucalpan, Huixquilucan, Tlalnepantla, Ecatepec, Texcoco y Toluca, entre otros. Para eventos en Cuernavaca, Querétaro u otras ciudades lo evaluamos caso por caso. En todos los casos detallamos el costo de traslado desde la cotización.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas para Eventos en CDMX",
    description: "Renta de carpas árabes, estructurales, hangar y transparentes con piso, forro e iluminación para bodas, XV años y eventos corporativos en CDMX.",
    url: "/servicios/carpas/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas y Estructuras", url: "/servicios/carpas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpas para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/carpas/carpa-arabe-beduina-boda-jardin.avif"
  description="Renta de carpas árabes, estructurales y transparentes para eventos en CDMX. Piso flotante, forro interior e iluminación incluidos. Cotización en 24h."
  jsonLd={jsonLd}
>

  <div slot="breadcrumbs" class="hm-breadcrumb-bar">
    <div class="hm__wrap">
      <nav class="sv-breadcrumb" aria-label="Migas de pan">
                <ol>
                  <li><a href="/">Inicio</a></li>
                  <li aria-hidden="true">›</li>
                  <li><a href="/servicios/">Servicios</a></li>
                  <li aria-hidden="true">›</li>
                  <li><span aria-current="page">Carpas y Estructuras</span></li>
                </ol>
              </nav>
    </div>
  </div>
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="carp-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Renta de carpas · CDMX y Estado de México</p>
            <h1 id="carp-hero-heading">
              Carpas y estructuras que convierten cualquier terreno en el <em>recinto que imaginaste</em>
            </h1>
            <p class="hm-hero__lead">
              Carpas árabes, estructurales, hangar y transparentes — con piso flotante,
              forro interior e iluminación integrada. Montaje profesional y estructura
              verificada antes de que llegue el primer invitado.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver tipos de carpa
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 30 años instalando estructuras temporales</strong> en
              Ciudad de México y Estado de México, EVENTECH es referencia en renta
              de carpas profesionales para bodas, XV años, eventos corporativos y
              exposiciones. Cada proyecto empieza con un levantamiento en sitio:
              analizamos terreno, accesos y carga de viento antes de proponer
              cualquier estructura.
            </p>
            <p>
              Nuestro catálogo cubre <strong>los cuatro tipos de carpa más solicitados</strong>:
              árabe para jardines y haciendas, estructural sin columnas para eventos de gran
              formato, hangar industrial para exposiciones y congresos, y transparente para
              bodas nocturnas bajo las estrellas. Piso flotante, forro interior, iluminación
              perimetral y climatización disponibles en cada modelo. Para eventos en exteriores con frío, coordinamos <a href="/servicios/accesorios/calefaccion-clima/">calentadores de patio y generadores eléctricos</a> en la misma logística.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Tipos de carpa">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cuatro soluciones, un solo proveedor</p>
            <h2 id="catalogo-heading">¿Qué tipo de carpa necesitas?</h2>
            <p class="hm__head-sub">Árabe, estructural, hangar o transparente — cada una diseñada para un perfil de evento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La carpa correcta no depende únicamente del presupuesto; depende del terreno,
              el aforo, el estilo del evento y las condiciones climáticas esperadas. Una árabe
              en un jardín residencial y una estructural en una explanada corporativa son
              proyectos completamente distintos en ingeniería, logística y acabado.
            </p>
            <p>
              Por eso empezamos con un levantamiento en sitio antes de cotizar. Esa visita
              nos permite dimensionar correctamente, evitar sorpresas el día del montaje y
              garantizar que la estructura instalada está pensada para ese terreno específico.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`Renta de ${s.name.toLowerCase()} para eventos en CDMX`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver todo en {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada tipo, a fondo</p>
            <h2 id="detalle-heading">Carpas en detalle</h2>
            <p class="hm__head-sub">Capacidades, usos frecuentes y qué incluye cada renta.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada tipo de carpa hay décadas de experiencia seleccionando
              la estructura correcta para cada terreno, aforo y estilo de evento.
              Conoce qué instalamos, cómo lo montamos y por qué la elección correcta
              marca la diferencia entre un evento que parece improvisado y uno que
              parece construido específicamente para ese espacio.
            </p>
            <p>
              Cada módulo incluye modelos disponibles, casos de uso frecuentes y un
              enlace directo a la subcategoría para explorar especificaciones técnicas
              y cotizar sin rodeos.
            </p>
          </div>
        </div>

        <!-- Carpas Árabes -->
        <article class="hm-feat" aria-labelledby="feat-arabes">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Carpas Árabes</p>
            <h3 class="hm-feat__title" id="feat-arabes">La carpa árabe — elegancia clásica para bodas y XV años en jardín</h3>
            <p class="hm-feat__lead">Su forma octogonal y sus techos en punta la convierten en la estructura más fotografiada de cualquier evento al aire libre.</p>
            <p>
              La <strong>carpa árabe estándar de 10×10 m</strong> es la más solicitada para
              bodas en haciendas y jardines residenciales — cubre entre 80 y 100 personas
              en montaje banquete. Para eventos más grandes, instalamos módulos combinados
              que pueden alcanzar los 400 invitados manteniendo la estética árabe.
            </p>
            <p>
              El <strong>forro interior en tela de tafetán</strong> blanco, crema o marfil
              elimina la estructura metálica visible y crea un techo de tela que refleja la
              iluminación de forma impresionante. Combinada con
              <a href="/servicios/iluminacion/">iluminación perimetral y pin-spots</a>,
              el resultado es indistinguible de un recinto fijo de lujo. Disponible con
              <strong>paredes laterales abiertas o con cortinas</strong> de tela para
              control de privacidad y temperatura.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Árabe Estándar", href: "/servicios/carpas/carpas-arabes/estandar/" },
                { name: "Árabe Premium", href: "/servicios/carpas/carpas-arabes/premium/" },
                { name: "Con Forro", href: "/servicios/carpas/carpas-arabes/con-forro/" },
                { name: "XV años", href: "/servicios/carpas/carpas-arabes/xv-anos/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/carpas-arabes/">
              Ver carpas árabes
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/carpas/carpa-arabe-beduina-boda-jardin.avif" alt="Carpa árabe beduina en jardín para boda elegante en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/carpas/carpa-mediana-quinceanos-decorada.avif" alt="Carpa mediana decorada para XV años con iluminación interior" loading="lazy" decoding="async" />
              <img src="/images/carpas/carpa-boda-01.avif" alt="Interior de carpa árabe para boda con mesas y decoración floral" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- Estructurales -->
        <article class="hm-feat hm-feat--reverse" aria-labelledby="feat-estructurales">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Carpas Estructurales</p>
            <h3 class="hm-feat__title" id="feat-estructurales">Estructural sin columnas — hasta 2,000 personas sin obstrucciones</h3>
            <p class="hm-feat__lead">La diferencia entre una carpa que limita el evento y una que lo libera está en la ingeniería de la estructura.</p>
            <p>
              Las <strong>carpas estructurales de aluminio</strong> se montan sin columnas
              centrales: el peso se distribuye perimetralmente, dejando el interior completamente
              libre para cualquier distribución de <a href="/servicios/mobiliario/">mesas y sillas de banquete</a>, escenarios o <a href="/servicios/pistas-baile/">pistas de baile</a>.
              Disponibles desde <strong>10×15 m hasta 50×100 m</strong>, cubren desde una
              cena de 150 personas hasta congresos de 2,000 asistentes.
            </p>
            <p>
              La versión <strong>transparente de doble cubierta</strong> permite ver el cielo
              durante el día y crea un efecto visual espectacular de noche con iluminación
              interior. El <strong>piso flotante nivelado</strong> resuelve terrenos irregulares
              sin diferencia en el acabado final. Complementa con
              <a href="/servicios/carpas/pisos-complementos/">paredes de cristal y climatización</a>
              para un resultado de nivel internacional.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Mediana", href: "/servicios/carpas/estructurales/mediana/" },
                { name: "Grande", href: "/servicios/carpas/estructurales/grande/" },
                { name: "Transparente", href: "/servicios/carpas/estructurales/transparente/" },
                { name: "Cristal", href: "/servicios/carpas/estructurales/cristal/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/estructurales/">
              Ver carpas estructurales
