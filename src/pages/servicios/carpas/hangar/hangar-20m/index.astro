---
/**
 * ─── Hangar Claro 20m — Pagina de Producto (Nivel 4) ───
 * Acero galvanizado sin columnas intermedias, claro libre 20m,
 * capacidad 500-2,000 personas.
 *
 * Jerarquia: Servicios > Carpas > Hangar > Hangar 20m
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Hangar", href: "/servicios/carpas/hangar/" },
  { label: "Hangar 20m" },
];

const faqs = [
  { question: "¿Cuántas personas caben en un hangar de 20 metros?", answer: 'El hangar de 20 metros de claro libre aloja entre <strong>500 y 2,000 personas</strong> dependiendo de la configuración interior. En formato banquete con mesas redondas caben aproximadamente 800 personas, en formato expo con stands caben hasta 1,200, y en configuración tipo teatro con sillas alineadas alcanza las 2,000 personas. Nuestro equipo de producción diseña el layout óptimo según tu aforo y tipo de evento para aprovechar al máximo cada metro cuadrado del hangar.' },
  { question: "¿El hangar necesita un terreno especial para instalarse?", answer: 'El hangar de 20 metros puede instalarse sobre <strong>terreno natural (pasto, tierra compactada), asfalto, concreto o explanadas</strong>. Para terrenos blandos utilizamos lastres de concreto de 500 kg y estacas de acero de penetración profunda. En superficies duras como asfalto o concreto, el anclaje se realiza con lastre y tornillería industrial. Antes del montaje, nuestro equipo de ingeniería realiza una <strong>evaluación del terreno sin costo</strong> para determinar el sistema de anclaje ideal y garantizar la estabilidad de la estructura.' },
  { question: "¿El hangar permite acceso vehicular?", answer: 'Sí, nuestro hangar de 20 metros cuenta con <strong>acceso vehicular por ambos extremos</strong> con puertas de hasta 5 metros de altura y ancho completo del claro. Esto permite la entrada y salida de camiones de carga, montacargas, vehículos de exhibición y trailers de producción. Es ideal para <strong>expos automotrices, ferias comerciales con stands que requieren descarga directa y eventos con logística de carga pesada</strong>. Los accesos se configuran con cortinas industriales o puertas enrollables según las necesidades del evento.' },
  { question: "¿El hangar incluye piso o se renta por separado?", answer: 'El hangar se renta como estructura (acero + lona), y el <strong>piso se cotiza por separado</strong> según el tipo de evento y terreno. Ofrecemos opciones de <a href="/servicios/carpas/pisos-complementos/">piso de duela, alfombra industrial, plataforma niveladora y piso de concreto modular</a>. Para expos y ferias recomendamos piso de alfombra con rampa de acceso vehicular. Para bodas y eventos sociales, la duela de madera o piso vinílico ofrecen un acabado elegante. Nuestro equipo te asesora sobre la mejor opción según tu presupuesto y tipo de evento.' },
  { question: "¿Cuánto tiempo toma montar un hangar de 20 metros?", answer: 'El montaje de un hangar de 20 metros requiere entre <strong>1 y 3 días</strong> dependiendo del largo y la complejidad de la instalación. Un hangar de 20x20 metros se monta en 1-2 días con un equipo de 8-10 operarios. Un hangar de 20x60 metros con piso, electricidad y clima puede tomar hasta 3 días. El desmontaje toma aproximadamente el mismo tiempo. Recomendamos programar el montaje con al menos <strong>5 días de anticipación</strong> al evento para contemplar imprevistos climáticos o ajustes de última hora.' },
  { question: "¿Con cuánta anticipación debo reservar mi hangar?", answer: 'Recomendamos reservar con <strong>3 a 6 semanas de anticipación</strong> para garantizar disponibilidad, especialmente en temporada alta (octubre a febrero). Para eventos de gran escala que requieren hangar de 20x60 metros o configuraciones con piso, electricidad y clima, lo ideal es apartar con <strong>2 meses de anticipación</strong>. El anticipo para confirmar la reserva es del 30% del total, con el 70% restante pagadero 5 días antes del montaje. También atendemos solicitudes urgentes sujetas a disponibilidad de inventario.' },
];

const specs = [
  { label: "Estructura", value: "Acero galvanizado en caliente" },
  { label: "Claro libre", value: "20 metros sin columnas" },
  { label: "Largo", value: "Modulable: 20 a 100+ metros" },
  { label: "Capacidad", value: "500 a 2,000 personas" },
  { label: "Lona", value: "PVC 900 g/m\u00B2 ign\u00EDfuga" },
  { label: "Altura lateral", value: "4 metros" },
  { label: "Altura centro", value: "6 a 8 metros" },
  { label: "Acceso", value: "Vehicular por ambos extremos" },
  { label: "Anclaje", value: "Ingenier\u00EDa de suelo + lastre certificado" },
  { label: "Montaje", value: "Equipo profesional, 1-3 d\u00EDas" },
];

const sidebarNav = [
  { name: "Hangar 20m", href: null, active: true },
  { name: "Hangar 30m", href: "/servicios/carpas/hangar/hangar-30m/" },
  { name: "Hangar con Rigging", href: "/servicios/carpas/hangar/rigging/" },
  { name: "Hangar Industrial", href: "/servicios/carpas/hangar/industrial/" },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminaci\u00F3n Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Plantas de Energ\u00EDa", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
];

const reviews = [
  { author: "Fernando L\u00F3pez", text: "Rentamos un hangar de 20x40 metros para una expo automotriz en un predio de Naucalpan. La estructura lleg\u00F3 impecable, el montaje fue r\u00E1pido y el acceso vehicular nos permiti\u00F3 meter los autos de exhibici\u00F3n sin problema. El equipo de EVENTECH coordin\u00F3 toda la log\u00EDstica de forma profesional.", rating: 5, date: "2025-11-20" },
  { author: "Claudia Ram\u00EDrez", text: "Usamos el hangar de 20x30 para una boda masiva de 800 invitados en un terreno de Cuernavaca. Con piso de duela y clima artificial, parec\u00EDa un sal\u00F3n de primer nivel. La estructura soport\u00F3 una lluvia intensa sin ning\u00FAn problema. Totalmente recomendable.", rating: 5, date: "2025-10-15" },
  { author: "Ricardo Mendoza", text: "Contratamos un hangar de 20x60 para un festival de m\u00FAsica de 2 d\u00EDas. El espacio fue perfecto para montar tarima, zona general y \u00E1rea VIP. El equipo de montaje fue puntual y la estructura se sinti\u00F3 s\u00F3lida y segura durante todo el evento. Excelente servicio.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Carpa Hangar 20m para Eventos en CDMX",
    description: "Renta de carpa tipo hangar con claro libre de 20 metros sin columnas intermedias para eventos de 500-2,000 personas en CDMX. Acceso vehicular. Desde $35,000.",
    url: "/servicios/carpas/hangar/hangar-20m/",
    priceRange: { min: 35000, max: 150000 },
    reviews,
    ratingValue: 5,
    reviewCount: 178,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Hangar", url: "/servicios/carpas/hangar/" },
    { name: "Hangar 20m", url: "/servicios/carpas/hangar/hangar-20m/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpa Hangar 20m para Eventos en CDMX"
  description="Renta de carpa tipo hangar con claro libre de 20 metros sin columnas intermedias para eventos de 500-2,000 personas en CDMX. Acceso vehicular. Desde $35,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Claro libre de 20 metros sin columnas"
    title='Renta de <span class="highlight">Carpa Hangar 20m</span> para Eventos en CDMX'
    subtitle="Estructura de acero galvanizado con claro libre de 20 metros completamente di\u00E1fano. Capacidad de 500 a 2,000 personas con lona PVC de 900 g/m\u00B2, acceso vehicular y montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tu hangar 20m", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa hangar de 20 metros para mi evento` }}
    cards={[
      {
        title: "Acero galvanizado con claro libre de 20 metros sin columnas",
        content: "<strong>Renta de carpa hangar de 20 metros</strong> fabricada con acero galvanizado por inmersi\u00F3n en caliente para m\u00E1xima resistencia y durabilidad. Claro libre de 20 metros completamente di\u00E1fano \u2014 sin columnas intermedias que limiten la distribuci\u00F3n del espacio. Capacidad de <strong>500 a 2,000 personas</strong> en configuraciones de banquete, expo, teatro o concierto. Lona industrial PVC de 900 g/m\u00B2 ign\u00EDfuga con protecci\u00F3n UV e impermeabilidad certificada. Largo modulable desde 20 hasta m\u00E1s de 100 metros para adaptarse al tama\u00F1o exacto de tu evento.",
      },
      {
        title: "Acceso vehicular y montaje profesional certificado",
        content: "<strong>Acceso vehicular por ambos extremos</strong> con puertas de hasta 5 metros de altura para entrada de camiones, montacargas y veh\u00EDculos de exhibici\u00F3n. Altura \u00FAtil de 6 a 8 metros en el centro para montajes de doble piso y escenograf\u00EDas imponentes. Sistema de anclaje con ingenier\u00EDa de suelo certificada: lastres de concreto de 500 kg o estacas de acero seg\u00FAn el tipo de terreno. Montaje profesional con equipo de 8-12 operarios especializados en 1 a 3 d\u00EDas. Canaletas de desag\u00FCe integradas para precipitaciones extremas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="\u00BFNecesitas un espacio di\u00E1fano de gran formato para tu evento?"
    subheadline="Cotiza sin compromiso \u2014 te enviamos propuesta t\u00E9cnica con el hangar ideal para tu aforo y tipo de producci\u00F3n"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en \u22641024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegaci\u00F3n r\u00E1pida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Hangar para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">\u00BFNecesitas un hangar de 20 metros para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una carpa hangar de 20 metros para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones T\u00E9cnicas \u2014 Hangar Claro 20m</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Hangar 20x20 -->
          <section class="section section--alt" aria-labelledby="hangar-20x20-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ferias y expos 500 personas</span>
                <h2 class="showcase__title" id="hangar-20x20-heading">Hangar 20x20 Metros</h2>
                <p class="showcase__subtitle">La configuraci\u00F3n compacta para ferias comerciales, expos empresariales y eventos corporativos de hasta 500 personas.</p>
                <p class="showcase__text">Nuestro <strong>hangar de 20x20 metros</strong> ofrece 400 m\u00B2 de espacio completamente libre de columnas, ideal para <strong>ferias comerciales, expos empresariales, showrooms de producto y eventos corporativos</strong> de mediana escala. El claro de 20 metros permite distribuir stands de exhibici\u00F3n, \u00E1reas de conferencia y zonas de networking sin obst\u00E1culos visuales. La altura de 6 metros permite montajes de stands con doble altura y escenograf\u00EDas imponentes.</p>
                <p class="showcase__text">Incluye <strong>acceso vehicular para descarga directa de materiales y equipo de exhibici\u00F3n</strong>. La lona PVC de 900 g/m\u00B2 con protecci\u00F3n UV garantiza confort t\u00E9rmico incluso en d\u00EDas soleados. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual profesional</a> para presentaciones de alto impacto dentro de la estructura. Montaje en 1 d\u00EDa con equipo de 8 operarios.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">20x20 metros</span>
                  <span class="showcase__tag">400 m\u00B2</span>
                  <span class="showcase__tag">500 personas</span>
                  <span class="showcase__tag">Montaje 1 d\u00EDa</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Hangar 20x20
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Hangar 20x20</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Hangar 20x40 -->
          <section class="section section--alt" aria-labelledby="hangar-20x40-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas masivas 1,000 personas</span>
                <h2 class="showcase__title" id="hangar-20x40-heading">Hangar 20x40 Metros</h2>
                <p class="showcase__subtitle">El espacio perfecto para bodas de gran escala, banquetes masivos y eventos sociales de hasta 1,000 personas.</p>
                <p class="showcase__text">El <strong>hangar de 20x40 metros</strong> proporciona 800 m\u00B2 de espacio libre, la configuraci\u00F3n m\u00E1s solicitada para <strong>bodas masivas, banquetes de gala, fiestas de XV a\u00F1os de gran formato y recepciones corporativas</strong>. Con capacidad para 1,000 personas en formato banquete con mesas redondas, ofrece el espacio suficiente para pista de baile, escenario, \u00E1rea de coctelería y zona de servicio sin comprometer la comodidad de los invitados.</p>
                <p class="showcase__text">La altura de 6-8 metros permite instalar <strong>candiles decorativos, iluminaci\u00F3n profesional y elementos escenogr\u00E1ficos suspendidos</strong> para transformar el hangar en un venue de ensue\u00F1o. Complementa con nuestros <a href="/servicios/carpas/pisos-complementos/">pisos de duela y alfombra</a> para un acabado impecable, y con <a href="/servicios/iluminacion/decorativa/">iluminaci\u00F3n decorativa</a> para crear la atm\u00F3sfera perfecta. Montaje en 2 d\u00EDas con equipo de 10 operarios.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">20x40 metros</span>
                  <span class="showcase__tag">800 m\u00B2</span>
                  <span class="showcase__tag">1,000 personas</span>
                  <span class="showcase__tag">Montaje 2 d\u00EDas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Hangar 20x40
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Hangar 20x40</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Hangar 20x60 -->
          <section class="section section--alt" aria-labelledby="hangar-20x60-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Conciertos y festivales</span>
                <h2 class="showcase__title" id="hangar-20x60-heading">Hangar 20x60 Metros</h2>
                <p class="showcase__subtitle">Estructura de gran formato para conciertos, festivales y eventos de hasta 2,000 personas con producci\u00F3n escénica completa.</p>
                <p class="showcase__text">El <strong>hangar de 20x60 metros</strong> ofrece 1,200 m\u00B2 de espacio di\u00E1fano, la configuraci\u00F3n ideal para <strong>conciertos, festivales de m\u00FAsica, convenciones masivas y eventos deportivos</strong> que requieren espacio para escenarios, \u00E1reas VIP y zonas generales simult\u00E1neas. Con capacidad para 2,000 personas en configuraci\u00F3n tipo concierto, ofrece el largo suficiente para montar tarimas de 12 metros, \u00E1reas de backstage y zonas de operaci\u00F3n log\u00EDstica.</p>
                <p class="showcase__text">Los <strong>accesos vehiculares dobles por ambos extremos</strong> permiten carga y descarga simult\u00E1nea de equipo de producci\u00F3n, escenograf\u00EDa y suministros. La altura de 8 metros en el centro permite colgar <a href="/servicios/iluminacion/escenario/">iluminaci\u00F3n de escenario</a> y <a href="/servicios/audiovisual/sonido/">line arrays de sonido</a> para una producci\u00F3n de nivel profesional. Montaje en 2-3 d\u00EDas con equipo de 12 operarios.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">20x60 metros</span>
                  <span class="showcase__tag">1,200 m\u00B2</span>
                  <span class="showcase__tag">2,000 personas</span>
                  <span class="showcase__tag">Montaje 2-3 d\u00EDas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Hangar 20x60
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
