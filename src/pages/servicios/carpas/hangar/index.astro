---
/**
 * ─── Carpas Tipo Hangar para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Carpas Tipo Hangar para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Hangar" },
];

const HANGARES = [
  {
    name: "Hangar Claro 20m",
    excerpt: "Estructura de acero galvanizado con claro libre de 20 metros sin columnas intermedias. Capacidad de 500 a 2,000 personas con lona PVC de 900 g/m² y acceso vehicular.",
    cta: "Hangar 20m",
    href: "/servicios/carpas/hangar/hangar-20m/",
    icon: "package",
  },
  {
    name: "Hangar Claro 30m",
    excerpt: "Máxima escala con 30 metros de claro libre para conciertos, expos masivas y eventos deportivos. Capacidad de 2,000 a 5,000+ personas en espacio completamente diáfano.",
    cta: "Hangar 30m",
    href: "/servicios/carpas/hangar/hangar-30m/",
    icon: "layers",
  },
  {
    name: "Hangar con Rigging",
    excerpt: "Puntos de anclaje certificados para 500 kg por punto con sistema de truss integrado. La solución profesional para producciones con iluminación, sonido y pantallas suspendidas.",
    cta: "Con Rigging",
    href: "/servicios/carpas/hangar/rigging/",
    icon: "speaker",
  },
  {
    name: "Hangar Industrial",
    excerpt: "Estructura reforzada para eventos de uso intensivo y multi-día. Circulación vehicular, instalación eléctrica trifásica y tableros de distribución incluidos.",
    cta: "Industrial",
    href: "/servicios/carpas/hangar/industrial/",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Cuál es la capacidad máxima de personas en un hangar?", answer: "Depende de la configuración y el claro seleccionado. Nuestro hangar de 20 metros de claro libre aloja cómodamente entre 500 y 2,000 personas en formato tipo banquete o expo. El hangar de 30 metros de claro, en configuración abierta con sillas teatro, puede recibir de 2,000 a 5,000+ asistentes. La capacidad exacta varía según el layout interior: montaje tipo banquete, conferencia, expo con stands o concierto con área general. Nuestro equipo de producción te ayuda a diseñar la distribución óptima según el aforo que necesitas." },
  { question: "¿Qué tan resistente es el hangar ante lluvia y viento extremo?", answer: "Nuestros hangares están fabricados con acero galvanizado por inmersión en caliente y lona industrial PVC de 900 g/m² con certificación de impermeabilidad y protección UV. La estructura soporta vientos sostenidos de hasta 100 km/h y ráfagas superiores. Los sistemas de anclaje utilizan lastres de concreto de 500 kg o estacas de acero de penetración profunda según el tipo de terreno. Adicionalmente, las canaletas de desagüe integradas manejan precipitaciones extremas sin acumulación de agua en el techo." },
  { question: "¿Cuánto peso soportan los puntos de rigging del hangar?", answer: "Nuestros hangares con rigging certificado cuentan con puntos de anclaje distribuidos a lo largo de la estructura principal, cada uno con capacidad de carga de hasta 500 kg. El sistema de truss integrado permite montar line arrays de sonido, parrillas de iluminación profesional, pantallas LED y elementos escenográficos suspendidos. Cada punto es verificado por nuestro equipo de ingeniería antes del montaje. Para cargas especiales o configuraciones complejas, realizamos un cálculo estructural específico incluido en el servicio." },
  { question: "¿Cuánto tiempo toma instalar un hangar completo?", answer: "El tiempo de montaje depende del tamaño y la complejidad de la instalación. Un hangar de 20 metros de claro requiere entre 2 y 3 días de montaje con nuestro equipo profesional de 8 a 12 operarios. El hangar de 30 metros necesita de 3 a 5 días. Si incluyes rigging, piso industrial, instalación eléctrica trifásica y clima artificial, el montaje integral puede tomar de 4 a 7 días. Recomendamos programar el montaje con al menos una semana de anticipación al evento." },
  { question: "¿Qué requisitos eléctricos necesita un hangar para eventos?", answer: "Nuestros hangares industriales incluyen instalación eléctrica trifásica (220V/440V) con tableros de distribución certificados por un perito eléctrico. Para eventos estándar se requiere una acometida de al menos 100 kVA. Para conciertos o producciones con pantallas LED, sonido line array e iluminación profesional, recomendamos 200 a 400 kVA. Si el venue no cuenta con la acometida suficiente, proporcionamos generadores de respaldo silenciosos con transferencia automática. Toda la instalación cumple con la NOM-001-SEDE vigente." },
  { question: "¿Se necesitan permisos especiales para instalar un hangar?", answer: "Sí, para estructuras de gran formato generalmente se requieren permisos de la alcaldía correspondiente, especialmente en vía pública o predios con restricciones de uso de suelo. Nuestro equipo te asesora sobre los trámites específicos según la ubicación: dictamen de protección civil, permiso de vía pública (si aplica), constancia de seguridad estructural y póliza de responsabilidad civil. Entregamos toda la documentación técnica, memorias de cálculo y planos estructurales necesarios para facilitar la obtención de permisos." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Tipo Hangar para Eventos en CDMX",
    description: "Carpas tipo hangar de 20 y 30 metros de claro libre para expos, conciertos y eventos masivos. Rigging certificado, piso industrial y montaje profesional incluido.",
    url: "/servicios/carpas/hangar/",
    priceRange: { min: 25000, max: 250000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Tipo Hangar", url: "/servicios/carpas/hangar/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpas Tipo Hangar para Eventos en CDMX"
  description="Renta de carpas tipo hangar de 20 y 30 metros sin columnas para expos, conciertos y eventos masivos en CDMX. Rigging certificado, piso industrial incluido. Desde $25,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Estructuras de gran escala para eventos masivos"
    title='Renta de <span class="highlight">Carpas Tipo Hangar</span> para Eventos en CDMX'
    subtitle="Hangares de acero galvanizado con claros libres de 20 y 30 metros sin columnas intermedias. Capacidad de 500 a 5,000+ personas con rigging certificado, piso industrial y montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tu hangar", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa tipo hangar para mi evento` }}
    cards={[
      {
        title: "Estructura industrial de acero galvanizado para eventos de gran formato",
        content: "<strong>Renta de carpas tipo hangar para eventos</strong> con la estructura más robusta disponible en CDMX. Acero galvanizado por inmersión en caliente con claros libres de 20 y 30 metros completamente diáfanos — sin columnas intermedias que interrumpan la visual o limiten la distribución del espacio. Lona industrial PVC de 900 g/m² con protección UV y certificación de impermeabilidad para condiciones climáticas extremas. Capacidad desde 500 hasta más de 5,000 personas en configuraciones de expo, concierto, feria comercial o convención corporativa — cada estructura certificada por nuestro equipo de ingeniería antes del montaje.",
      },
      {
        title: "Producción integral con rigging, electricidad y logística",
        content: "<strong>Servicio completo de hangar llave en mano</strong> que incluye montaje profesional con equipo de 8 a 12 operarios especializados, puntos de anclaje certificados para rigging de hasta 500 kg por punto, sistema de truss integrado para iluminación y sonido, instalación eléctrica trifásica con tableros de distribución, puertas de acceso vehicular de hasta 5 metros de altura y canaletas de desagüe integradas. Complementa con <strong>piso industrial, clima artificial y señalización</strong> para un venue completamente equipado y autosuficiente.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Tu evento necesita escala industrial? Nosotros tenemos la estructura"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con el hangar ideal para tu espacio, aforo y tipo de producción"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de hangar
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Carpas Tipo Hangar"
        subtitle="La estructura de gran formato para cada tipo de evento masivo"
        description={[
          "Desde hangares de 20 metros para expos y ferias comerciales hasta estructuras de 30 metros con rigging profesional para conciertos y festivales de gran escala. Contamos con el inventario de carpas tipo hangar más completo de la Ciudad de México y zona metropolitana.",
          "Cada hangar incluye montaje profesional certificado, lona industrial PVC de 900 g/m², sistema de anclaje con lastres de 500 kg y opciones de personalización completa: rigging, piso industrial, instalación eléctrica trifásica y clima artificial."
        ]}
      />

      <div class="grid grid--4">
        {HANGARES.map((hangar) => (
          <Card
            name={hangar.name}
            excerpt={hangar.excerpt}
            cta={hangar.cta}
            href={hangar.href}
            icon={hangar.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HANGAR CLARO 20M — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="hangar20-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">500-2,000 personas</span>
          <h2 class="showcase__title" id="hangar20-heading">Hangar Claro 20m</h2>
          <p class="showcase__subtitle">Estructura de acero galvanizado con 20 metros de claro libre sin columnas intermedias. El hangar versátil para expos, ferias y eventos corporativos de gran formato.</p>
          <p class="showcase__text">Nuestro <strong>hangar de claro 20 metros</strong> es la opción más solicitada para eventos que requieren un espacio amplio y completamente diáfano. Fabricado con <strong>acero galvanizado por inmersión en caliente</strong> y cubierto con <strong>lona industrial PVC de 900 g/m²</strong> con protección UV al 99% e impermeabilidad certificada, ofrece un espacio libre de columnas perfecto para <strong>expos con stands, ferias comerciales, convenciones corporativas y eventos sociales de gran escala</strong>. La altura libre de 6 metros permite montar stands de doble piso y escenografías imponentes.</p>
          <p class="showcase__text">Incluye <strong>puertas de acceso vehicular de hasta 5 metros de altura</strong> para entrada y salida de camiones de carga, montacargas y vehículos de exhibición. Los sistemas de anclaje con lastres de concreto de 500 kg garantizan estabilidad total ante vientos de hasta 100 km/h. Canaletas de desagüe integradas manejan precipitaciones extremas. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual profesional</a> para presentaciones y proyecciones de alto impacto dentro de la estructura.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Claro 20m</span>
            <span class="showcase__tag">Sin Columnas</span>
            <span class="showcase__tag">Acero Galvanizado</span>
            <span class="showcase__tag">PVC 900g</span>
            <span class="showcase__tag">Acceso Vehicular</span>
          </div>
          <a href="/servicios/carpas/hangar/hangar-20m/" class="btn btn--primary btn--lg">
            Ver Hangar 20m
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M4 20V8l8-5 8 5v12"/>
              <path d="M9 20v-6h6v6"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HANGAR CLARO 30M — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="hangar30-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Máxima escala</span>
          <h2 class="showcase__title" id="hangar30-heading">Hangar Claro 30m</h2>
          <p class="showcase__subtitle">La estructura más grande de nuestro inventario. 30 metros de claro libre para conciertos, festivales, expos masivas y eventos deportivos de 2,000 a 5,000+ personas.</p>
          <p class="showcase__text">El <strong>hangar de claro 30 metros</strong> representa la máxima escala en estructuras temporales para eventos. Con un espacio completamente libre de columnas de <strong>30 metros de ancho por hasta 100 metros de largo</strong>, es la solución para <strong>conciertos y festivales de música, expos internacionales, eventos deportivos, convenciones masivas y producciones de entretenimiento</strong> donde otros espacios simplemente se quedan cortos. La estructura de acero galvanizado soporta condiciones climáticas extremas mientras la lona PVC de 900 g/m² garantiza impermeabilidad total.</p>
          <p class="showcase__text">Con capacidad para <strong>2,000 a 5,000+ personas</strong> según la configuración interior, este hangar ofrece altura libre de hasta 8 metros — espacio suficiente para montar tarimas de concierto, pantallas LED gigantes, estructuras de truss y escenografías de gran formato. Los accesos vehiculares dobles de 5 metros permiten carga y descarga simultánea de producción. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional de escenario</a> para crear producciones de nivel internacional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Claro 30m</span>
            <span class="showcase__tag">Hasta 100m largo</span>
            <span class="showcase__tag">2,000-5,000+ personas</span>
            <span class="showcase__tag">Altura 8m</span>
            <span class="showcase__tag">Acceso doble</span>
          </div>
          <a href="/servicios/carpas/hangar/hangar-30m/" class="btn btn--primary btn--lg">
            Ver Hangar 30m
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M3 20V9l9-6 9 6v11"/>
              <path d="M8 20v-8h8v8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HANGAR CON RIGGING — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="rigging-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Producción profesional</span>
          <h2 class="showcase__title" id="rigging-heading">Hangar con Rigging</h2>
          <p class="showcase__subtitle">Puntos de anclaje certificados de 500 kg con sistema de truss integrado para producciones profesionales con iluminación, sonido y pantallas LED suspendidas.</p>
          <p class="showcase__text">Nuestro <strong>hangar con rigging certificado</strong> está diseñado específicamente para producciones de entretenimiento y eventos corporativos de alto nivel que requieren elementos técnicos suspendidos. Cada estructura cuenta con <strong>puntos de anclaje distribuidos en cuadrícula con capacidad de 500 kg por punto</strong>, verificados por nuestro equipo de ingeniería antes de cada montaje. El sistema de <strong>truss integrado de aluminio de alta resistencia</strong> permite montar parrillas de iluminación, line arrays de sonido, pantallas LED y elementos escenográficos de forma segura y eficiente.</p>
          <p class="showcase__text">Incluye <strong>cálculo estructural específico</strong> para cada configuración de carga, motor chain hoists para elevación controlada y certificación de seguridad emitida por perito estructural. Ideal para <strong>conciertos con line array, premiaciones corporativas con producción audiovisual, lanzamientos de producto con escenografía suspendida y festivales con parrillas de iluminación profesional</strong>. Nuestros ingenieros de rigging supervisan todo el proceso de montaje y permanecen disponibles durante el evento. Combínalo con nuestras <a href="/servicios/pistas-baile/">pistas de baile y tarimas</a> para una producción escénica completa.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">500 kg/punto</span>
            <span class="showcase__tag">Truss Aluminio</span>
            <span class="showcase__tag">Chain Hoists</span>
            <span class="showcase__tag">Line Array</span>
            <span class="showcase__tag">Certificado</span>
          </div>
          <a href="/servicios/carpas/hangar/rigging/" class="btn btn--primary btn--lg">
            Ver Hangar con Rigging
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M4 20V8l8-5 8 5v12"/>
              <line x1="8" y1="8" x2="8" y2="14"/>
              <line x1="12" y1="8" x2="12" y2="14"/>
              <line x1="16" y1="8" x2="16" y2="14"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HANGAR INDUSTRIAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="industrial-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Uso intensivo</span>
          <h2 class="showcase__title" id="industrial-heading">Hangar Industrial</h2>
          <p class="showcase__subtitle">Estructura reforzada para eventos multi-día con circulación vehicular, instalación eléctrica trifásica y tableros de distribución profesionales.</p>
          <p class="showcase__text">El <strong>hangar industrial</strong> es nuestra solución más robusta, diseñada para <strong>eventos de uso intensivo y multi-día</strong> donde la estructura debe soportar operación continua, circulación de vehículos pesados y condiciones de carga exigentes. Fabricado con <strong>acero galvanizado de mayor calibre y refuerzos estructurales adicionales</strong>, ofrece una plataforma indestructible para ferias que duran una semana, montajes de producción de varios días y operaciones logísticas complejas. Las puertas de acceso vehicular de 5 metros permiten entrada y salida de tráileres, montacargas y vehículos de exhibición.</p>
          <p class="showcase__text">Incluye <strong>instalación eléctrica trifásica completa (220V/440V)</strong> con tableros de distribución certificados, acometidas dimensionadas para cargas de hasta 400 kVA, puntos de energía distribuidos por toda la estructura e iluminación industrial de trabajo. Opción de <strong>generadores de respaldo silenciosos con transferencia automática</strong> para garantizar operación ininterrumpida. Ideal para <strong>expos internacionales, ferias automotrices, eventos deportivos, producciones televisivas y campamentos de operación</strong>. Complementa con nuestros <a href="/servicios/accesorios/">accesorios de señalización, plantas de energía y clima artificial</a> para un venue industrial completamente autosuficiente.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Multi-día</span>
            <span class="showcase__tag">Trifásica 440V</span>
            <span class="showcase__tag">Hasta 400 kVA</span>
            <span class="showcase__tag">Acceso Vehicular</span>
            <span class="showcase__tag">Generador Respaldo</span>
          </div>
          <a href="/servicios/carpas/hangar/industrial/" class="btn btn--primary btn--lg">
            Ver Hangar Industrial
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <path d="M3 9h18"/>
              <path d="M9 21V9"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Carpas Tipo Hangar"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu hangar, es natural tener preguntas sobre capacidad, resistencia, rigging, electricidad y logística de montaje. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre carpas tipo hangar al instante.</p>
