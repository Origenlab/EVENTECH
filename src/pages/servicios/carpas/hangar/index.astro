---
/**
 * ─── EVENTECH.MX — Renta de Carpas Tipo Hangar para Eventos (Hub L4, molde hm- 2026) ───
 * Claro 20 m · Claro 30 m · Con Rigging · Industrial — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/carpas — hangar-industrial, estructural-grande reales; carpa-boda-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "hangar-20m",
    name: "Hangar Claro 20 m",
    badge: "El más solicitado",
    excerpt: "Acero galvanizado con 20 m de claro libre sin columnas intermedias, para 500 a 2,000 personas. Lona PVC 900 g/m² y acceso vehicular. Ideal para expos y corporativos.",
    href: "/servicios/carpas/hangar/hangar-20m/",
    image: "/images/carpas/carpa-hangar-industrial-evento-grande.avif",
    specs: ["20 m claro libre", "500–2,000 pax", "Lona PVC 900 g", "Acceso vehicular"],
  },
  {
    id: "hangar-30m",
    name: "Hangar Claro 30 m",
    badge: "Máxima escala",
    excerpt: "Máxima escala para conciertos, ferias masivas y eventos deportivos. De 2,000 a 5,000+ personas en espacio completamente diáfano, sin columnas en todo el claro.",
    href: "/servicios/carpas/hangar/hangar-30m/",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    specs: ["30 m claro libre", "2,000–5,000+ pax", "Espacio diáfano", "Acero galvanizado"],
  },
  {
    id: "rigging",
    name: "Hangar con Rigging",
    badge: "Producción profesional",
    excerpt: "Puntos de anclaje certificados de 500 kg c/u con truss integrado, para line arrays, iluminación escénica y pantallas LED suspendidas. Revisión de ingeniería incluida.",
    href: "/servicios/carpas/hangar/rigging/",
    image: "/images/carpas/carpa-boda-03.avif",
    specs: ["500 kg por punto", "Truss integrado", "Cálculo estructural", "Producción pro"],
  },
  {
    id: "industrial",
    name: "Hangar Industrial",
    badge: "Multi-día intensivo",
    excerpt: "Estructura reforzada para eventos multi-día de uso intensivo. Electricidad trifásica, tableros de distribución NOM, acceso vehicular de 5 m y puertas industriales.",
    href: "/servicios/carpas/hangar/industrial/",
    image: "/images/carpas/carpa-boda-04.avif",
    specs: ["Uso multi-día", "Eléctrica trifásica", "Puerta 5 m", "Tableros NOM"],
  },
];

const whyFeatures = [
  {
    title: "Cálculo estructural y memoria de ingeniería",
    body: "Un hangar de gran formato es una obra temporal, no una carpa: cada instalación se respalda con cálculo estructural y memoria de ingeniería según las cargas y el viento del sitio. No levantamos acero a ojo — entregamos los números que sostienen la estructura y que protección civil pide para autorizar el evento.",
  },
  {
    title: "Acero galvanizado y lona PVC industrial 900 g",
    body: "Estructura de acero galvanizado por inmersión en caliente y lona industrial PVC de 900 g/m² con protección UV y certificación de impermeabilidad. Material de grado industrial que soporta vientos sostenidos de 100 km/h y ráfagas superiores — revisado pieza por pieza antes de cada montaje de gran formato.",
  },
  {
    title: "Anclaje pesado y drenaje para clima extremo",
    body: "Lastres de concreto de 500 kg o estacas de acero de penetración profunda según el terreno, con canaletas de desagüe integradas que manejan precipitaciones extremas sin acumulación en el techo. La estructura queda fija y estanca sin importar el clima — clave para eventos masivos que no se pueden reprogramar.",
  },
  {
    title: "Rigging certificado con puntos verificados",
    body: "Puntos de anclaje distribuidos en la estructura principal, cada uno certificado para 500 kg, con truss integrado para colgar line arrays, parrillas de iluminación y pantallas LED. Cada punto lo verifica nuestro equipo de ingeniería antes del montaje; para cargas especiales hacemos cálculo estructural específico.",
  },
  {
    title: "Montaje propio de gran formato con prueba",
    body: "Equipo de montaje propio (no subcontratado) de 8 a 12 operarios que instala en 2 a 7 días según el claro y los complementos. Programamos con anticipación e incluimos prueba de seguridad estructural. Llegamos con margen para que el día del evento el hangar esté levantado, verificado y listo.",
  },
  {
    title: "Gestión de permisos y documentación técnica",
    body: "Te asesoramos con los trámites de gran formato y entregamos la documentación: memorias de cálculo, planos estructurales, dictamen de protección civil y constancia de seguridad. Para estructuras masivas los permisos no son opcionales — nos encargamos de que tu evento esté en regla y respaldado.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cálculo de estructura", p: "Evaluamos el terreno, la superficie, el acceso vehicular y las condiciones de viento y drenaje. Con esos datos calculamos el claro, el anclaje y la memoria de ingeniería. En menos de 24-48 horas te enviamos propuesta técnica con el hangar y los complementos ideales para tu aforo." },
  { n: 2, t: "Propuesta, permisos y aparto", p: "Definimos claro, rigging, piso, electricidad y clima. Preparamos la documentación técnica (planos, memorias, dictámenes) para los permisos de gran formato. Con el anticipo apartamos la estructura y la fecha, y coordinamos con tu productor o el venue." },
  { n: 3, t: "Montaje, rigging y prueba de seguridad", p: "Nuestro equipo instala en 2 a 7 días según el claro: armado de acero galvanizado, tensado de lona industrial, anclaje pesado, rigging certificado, piso e instalación eléctrica. Cerramos con prueba de seguridad estructural antes de entregar el espacio." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento (incluso multi-día) la estructura soporta uso intensivo con seguridad certificada. Al finalizar, nuestro equipo desmonta y retira todo el acero, lona y complementos. El montaje y desmontaje están incluidos en el servicio dentro de CDMX y ZMVM." },
];

const faqs = [
  { question: "¿Cuál es la capacidad máxima de personas en un hangar?", answer: "Depende de la configuración y el claro seleccionado. Nuestro hangar de 20 metros de claro libre aloja cómodamente entre 500 y 2,000 personas en formato tipo banquete o expo. El hangar de 30 metros de claro, en configuración abierta con sillas teatro, puede recibir de 2,000 a 5,000+ asistentes. La capacidad exacta varía según el layout interior: montaje tipo banquete, conferencia, expo con stands o concierto con área general. Nuestro equipo de producción te ayuda a diseñar la distribución óptima según el aforo que necesitas." },
  { question: "¿Qué tan resistente es el hangar ante lluvia y viento extremo?", answer: "Nuestros hangares están fabricados con acero galvanizado por inmersión en caliente y lona industrial PVC de 900 g/m² con certificación de impermeabilidad y protección UV. La estructura soporta vientos sostenidos de hasta 100 km/h y ráfagas superiores. Los sistemas de anclaje utilizan lastres de concreto de 500 kg o estacas de acero de penetración profunda según el tipo de terreno. Adicionalmente, las canaletas de desagüe integradas manejan precipitaciones extremas sin acumulación de agua en el techo." },
  { question: "¿Cuánto peso soportan los puntos de rigging del hangar?", answer: "Nuestros hangares con rigging certificado cuentan con puntos de anclaje distribuidos a lo largo de la estructura principal, cada uno con capacidad de carga de hasta 500 kg. El sistema de truss integrado permite montar line arrays de sonido, parrillas de iluminación profesional, pantallas LED y elementos escenográficos suspendidos. Cada punto es verificado por nuestro equipo de ingeniería antes del montaje. Para cargas especiales o configuraciones complejas, realizamos un cálculo estructural específico incluido en el servicio." },
  { question: "¿El hangar incluye piso y clima artificial?", answer: "El piso y la climatización se cotizan como complemento según el evento. Ofrecemos piso industrial nivelado (tarima modular sobre estructura metálica con nivelación láser, ideal para terrenos irregulares), alfombra sobre base rígida y sistemas de climatización: enfriamiento evaporativo o aire acondicionado por ductos para verano, y calefacción por aire forzado para invierno. Para eventos masivos o multi-día, el clima artificial es muy recomendable dado el volumen de aire del claro; lo dimensionamos según la superficie y el aforo." },
  { question: "¿Cuánto tiempo toma instalar un hangar completo?", answer: "El tiempo de montaje depende del tamaño y la complejidad de la instalación. Un hangar de 20 metros de claro requiere entre 2 y 3 días de montaje con nuestro equipo profesional de 8 a 12 operarios. El hangar de 30 metros necesita de 3 a 5 días. Si incluyes rigging, piso industrial, instalación eléctrica trifásica y clima artificial, el montaje integral puede tomar de 4 a 7 días. Recomendamos programar el montaje con al menos una semana de anticipación al evento." },
  { question: "¿Qué requisitos eléctricos necesita un hangar para eventos?", answer: "Nuestros hangares industriales incluyen instalación eléctrica trifásica (220V/440V) con tableros de distribución certificados por un perito eléctrico. Para eventos estándar se requiere una acometida de al menos 100 kVA. Para conciertos o producciones con pantallas LED, sonido line array e iluminación profesional, recomendamos 200 a 400 kVA. Si el venue no cuenta con la acometida suficiente, proporcionamos generadores de respaldo silenciosos con transferencia automática. Toda la instalación cumple con la NOM-001-SEDE vigente." },
  { question: "¿Se necesitan permisos especiales para instalar un hangar?", answer: "Sí, para estructuras de gran formato generalmente se requieren permisos de la alcaldía correspondiente, especialmente en vía pública o predios con restricciones de uso de suelo. Nuestro equipo te asesora sobre los trámites específicos según la ubicación: dictamen de protección civil, permiso de vía pública (si aplica), constancia de seguridad estructural y póliza de responsabilidad civil. Entregamos toda la documentación técnica, memorias de cálculo y planos estructurales necesarios para facilitar la obtención de permisos." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Tipo Hangar para Eventos en CDMX",
    description: "Renta de carpas tipo hangar de 20 y 30 m de claro libre para expos, conciertos y eventos masivos en CDMX. Rigging certificado, piso industrial y montaje profesional.",
    url: "/servicios/carpas/hangar/",
    priceRange: { min: 25000, max: 250000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Tipo Hangar", url: "/servicios/carpas/hangar/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Tipo Hangar" },
];
---

<PageLayout
  title="Renta de Carpas Tipo Hangar para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/carpas/carpa-hangar-industrial-evento-grande.avif"
  description="Renta de carpas tipo hangar de 20 y 30 m de claro libre en CDMX: expos, conciertos y eventos masivos. Rigging certificado y montaje profesional. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="hangar-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Carpas tipo hangar · CDMX y ZMVM</p>
            <h1 id="hangar-hero-heading">
              Carpas tipo hangar con <em>claros libres de hasta 30 m</em> para eventos masivos
            </h1>
            <p class="hm-hero__lead">
              Acero galvanizado, lona industrial PVC de 900 g/m² y claros diáfanos sin columnas
              de 20 a 30 metros. Rigging certificado, electricidad trifásica y montaje de gran
              formato — para expos, conciertos y ferias de 500 a 5,000+ personas.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20tipo%20hangar%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar hangar
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>carpas tipo hangar para eventos</strong> masivos en CDMX y
              zona metropolitana con estructura de <strong>acero galvanizado</strong> y lona
              industrial PVC de 900 g/m². Claros libres de <strong>20 a 30 metros sin columnas
              intermedias</strong> para 500 a 5,000+ personas, con opción de rigging certificado
              (500 kg por punto), electricidad trifásica, piso industrial y climatización. Cada
              estructura se respalda con cálculo y memoria de ingeniería.
            </p>
            <p>
              Con <strong>más de 500 instalaciones</strong> en CDMX, sabemos que un hangar es una
              obra temporal que carga producción y resiste clima extremo: por eso cada renta
              incluye cálculo estructural, anclaje pesado y gestión de permisos de gran formato.
              Para producción completa integramos
              <a href="/servicios/audiovisual/sonido/">sonido</a>,
              <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> e
              <a href="/servicios/iluminacion/">iluminación</a> colgados del rigging, desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de carpa hangar disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20tipo%20hangar%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Gran formato para eventos masivos</p>
            <h2 id="catalogo-heading">¿Qué hangar necesita tu evento?</h2>
            <p class="hm__head-sub">De la expo de 500 al concierto de 5,000+ — con el claro, el rigging y la infraestructura correctos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El hangar es lo que hace posible un evento masivo bajo techo: un claro diáfano sin
              columnas que permite ver el escenario desde cualquier ángulo y colgar toda la
              producción. La elección correcta no es solo tamaño — es la resistencia estructural,
              los puntos de rigging y la infraestructura eléctrica que soportan la producción.
            </p>
            <p>
              Claro 20 m para expos y corporativos. Claro 30 m para conciertos y ferias masivas.
              Con rigging cuando cuelga sonido, luz y pantallas. Industrial cuando el evento es
              multi-día e intensivo. Una sola empresa para toda la estructura de tu evento masivo.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos masivos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada configuración, a fondo</p>
            <h2 id="detalle-heading">Las 4 configuraciones de hangar — en detalle</h2>
            <p class="hm__head-sub">Claro, capacidad, carga de rigging e infraestructura para cada tipo de evento masivo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada hangar hay decisiones de ingeniería que afectan la seguridad y la
              producción: el claro que determina cuánta gente cabe sin columnas, la carga de
              rigging que decide qué se puede colgar, y la infraestructura eléctrica que sostiene
              todo el equipo audiovisual.
            </p>
            <p>
              Conocer estas diferencias te permite dimensionar con criterio y no quedarte corto
              el día del evento. A continuación, lo que realmente importa de cada configuración.
            </p>
          </div>
        </div>

        <!-- HANGAR 20M -->
        <article class="hm-feat" aria-labelledby="feat-hangar-20m">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Hangar Claro 20 m</p>
            <h3 class="hm-feat__title" id="feat-hangar-20m">20 metros diáfanos sin columnas — el estándar para expos y corporativos de 500 a 2,000</h3>
            <p class="hm-feat__lead">El punto de equilibrio entre escala y logística. Suficiente claro para una expo con stands o un banquete de 2,000, con un montaje que no requiere una semana entera.</p>
            <p>
              Estructura de <strong>acero galvanizado</strong> con <strong>20 metros de claro
              libre sin columnas intermedias</strong> y lona industrial PVC de 900 g/m². Para
              <strong>500 a 2,000 personas</strong> en banquete, conferencia o expo, con
              <strong>acceso vehicular</strong> para montaje de stands y logística interior.
            </p>
            <p>
              Ideal para <strong>expos, ferias comerciales, eventos corporativos y banquetes
              masivos</strong>. Se une a módulos adicionales para superficies mayores y admite
              rigging, piso e instalación eléctrica. Combínalo con nuestro
              <a href="/servicios/mobiliario/">mobiliario</a> y
              <a href="/servicios/iluminacion/">iluminación</a> para un montaje integral.
            </p>
            <ul class="hm-feat__stats">
              {["20 m claro libre", "500–2,000 pax", "Lona PVC 900 g", "Acceso vehicular", "Acero galvanizado"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/hangar/hangar-20m/">
              Ver Hangar Claro 20 m
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/carpas/carpa-hangar-industrial-evento-grande.avif" alt="Carpa tipo hangar de 20 m de claro libre para expo en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/carpas/carpa-estructural-grande-congreso.avif" alt="Hangar de 20 metros montado para evento corporativo" loading="lazy" decoding="async" />
              <img src="/images/carpas/carpa-boda-03.avif" alt="Interior diáfano de hangar sin columnas para banquete masivo" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- HANGAR 30M -->
        <article class="hm-feat" aria-labelledby="feat-hangar-30m">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Hangar Claro 30 m</p>
            <h3 class="hm-feat__title" id="feat-hangar-30m">30 metros de claro para conciertos, ferias masivas y eventos deportivos</h3>
            <p class="hm-feat__lead">La escala máxima. Cuando el evento necesita miles de personas y un escenario visible desde el fondo, el claro de 30 metros lo hace posible sin una sola columna en medio.</p>
            <p>
              <strong>30 metros de claro libre</strong> en espacio completamente diáfano, para
              <strong>2,000 a 5,000+ asistentes</strong> en configuración de concierto, feria o
