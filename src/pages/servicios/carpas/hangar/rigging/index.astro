---
/**
 * ─── Hangar con Rigging — Pagina de Producto (Nivel 4) ───
 * Puntos de anclaje 500kg + truss integrado para producciones
 * con iluminación, sonido y pantallas suspendidas.
 *
 * Jerarquia: Servicios > Carpas > Hangar > Con Rigging
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Hangar", href: "/servicios/carpas/hangar/" },
  { label: "Con Rigging" },
];

const faqs = [
  { question: "¿Cuánto peso soporta cada punto de rigging?", answer: 'Cada punto de rigging en nuestros hangares está certificado para soportar <strong>hasta 500 kg de carga</strong>. Los puntos están distribuidos en una cuadrícula (grid) con separación de 3 a 5 metros entre sí, lo que permite distribuir la carga de forma uniforme a lo largo de toda la estructura. Para cargas puntuales superiores a 500 kg, realizamos un <strong>cálculo estructural específico</strong> con refuerzos adicionales. La carga total distribuida puede alcanzar hasta 10,000 kg dependiendo del modelo de hangar (20m o 30m de claro).' },
  { question: "¿El rigging incluye el equipo audiovisual?", answer: 'No, el servicio de <strong>rigging incluye los puntos de anclaje certificados, el sistema de truss integrado, los motores chain hoist y el rigger profesional</strong>. El equipo audiovisual (sonido, iluminación, pantallas LED) se cotiza por separado según las necesidades de tu producción. Sin embargo, ofrecemos un <strong>Kit Producción Integral</strong> que combina el hangar con rigging más todo el equipo AV necesario en una sola cotización. Nuestro equipo coordina con tus proveedores de audio e iluminación para garantizar compatibilidad con los puntos de rigging.' },
  { question: "¿Se necesita un rigger especializado para el montaje?", answer: 'Sí, toda instalación de rigging en nuestros hangares es <strong>supervisada por un rigger profesional certificado</strong> que está incluido en el servicio. El rigger se encarga del cálculo de cargas, distribución de puntos, instalación de eslingas y grilletes, operación de motores chain hoist y verificación de seguridad en cada punto de anclaje. Además, permanece disponible durante el evento para realizar ajustes si es necesario. Para producciones de gran escala, proporcionamos un equipo de 2-3 riggers.' },
  { question: "¿Se puede usar rigging en cualquier modelo de hangar?", answer: 'Nuestro servicio de rigging certificado es compatible con los <strong>hangares de 20 metros y 30 metros de claro</strong>. Cada modelo tiene una capacidad de carga diferente: el hangar de 20m soporta hasta 6,000 kg distribuidos, mientras que el de 30m alcanza hasta 10,000 kg. Para hangares estándar sin refuerzo de rigging, ofrecemos una <strong>evaluación estructural</strong> para determinar si es posible agregar puntos de carga y cuánto peso soportan. El <a href="/servicios/carpas/hangar/industrial/">hangar industrial</a> también acepta configuraciones de rigging con refuerzo adicional.' },
  { question: "¿Cuánto tiempo adicional toma el montaje del rigging?", answer: 'El montaje del sistema de rigging agrega entre <strong>1 y 2 días adicionales</strong> al tiempo de instalación del hangar. Un sistema de rigging básico (8 puntos) se instala en medio día. Un sistema medio (16 puntos) requiere 1 día completo. Un sistema completo (24+ puntos) con motores chain hoist toma 1.5-2 días. Recomendamos programar el montaje del rigging <strong>después de que la estructura del hangar esté completamente instalada</strong> y antes de que entren los proveedores de sonido e iluminación.' },
  { question: "¿Qué certificaciones de seguridad tiene el rigging?", answer: 'Nuestro sistema de rigging cumple con las <strong>normas internacionales de seguridad para espectáculos y eventos</strong>. Cada punto de anclaje cuenta con certificación de carga emitida por ingeniero estructural. Utilizamos <strong>eslingas certificadas, grilletes forjados grado 8, seguros de acero y motores chain hoist con freno de seguridad automático</strong>. Antes de cada evento, nuestro rigger realiza una inspección visual y de carga de cada punto. Entregamos documentación de seguridad, certificaciones y póliza de responsabilidad civil para tu producción.' },
];

const specs = [
  { label: "Puntos rigging", value: "Certificados 500 kg por punto" },
  { label: "Truss", value: "Integrado en estructura principal" },
  { label: "Distribución", value: "Grid de puntos cada 3-5 metros" },
  { label: "Certificación", value: "Cálculo estructural por ingeniero" },
  { label: "Carga total", value: "Hasta 10,000 kg distribuidos" },
  { label: "Compatibilidad", value: "Hangar 20m y 30m" },
  { label: "Acceso", value: "Plataformas elevadoras incluidas" },
  { label: "Seguridad", value: "Eslingas, grilletes y seguros certificados" },
  { label: "Motor chain", value: "Motores de cadena opcionales" },
  { label: "Técnico", value: "Rigger profesional incluido" },
];

const sidebarNav = [
  { name: "Hangar 20m", href: "/servicios/carpas/hangar/hangar-20m/" },
  { name: "Hangar 30m", href: "/servicios/carpas/hangar/hangar-30m/" },
  { name: "Hangar con Rigging", href: null, active: true },
  { name: "Hangar Industrial", href: "/servicios/carpas/hangar/industrial/" },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
];

const reviews = [
  { author: "Gabriela Moreno", text: "Contratamos el hangar con rigging para un concierto con line array de 12 cajas por lado. Los puntos de rigging soportaron todo el sistema sin problema, y el rigger de EVENTECH coordinó perfectamente con nuestro proveedor de sonido. La producción fue impecable y segura. Totalmente recomendable.", rating: 5, date: "2025-11-08" },
  { author: "Sergio Navarro", text: "Organizamos un show corporativo con 8 pantallas LED suspendidas y parrilla de iluminación completa. El sistema de truss integrado facilitó enormemente el montaje. El rigger profesional verificó cada punto antes de subir el equipo. Excelente servicio técnico y mucha tranquilidad en temas de seguridad.", rating: 5, date: "2025-10-12" },
  { author: "Laura Estrada", text: "Usamos el hangar con rigging para un festival de 2 días con iluminación completa: 24 moving heads, 16 par LED y 4 follow spots suspendidos. Los motores chain hoist permitieron ajustar alturas durante el evento sin bajar la parrilla. El equipo de EVENTECH fue profesional de principio a fin.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Carpa Hangar con Rigging para Eventos en CDMX",
    description: "Renta de carpa hangar con puntos de rigging certificados 500 kg y truss integrado para producciones con iluminación, sonido y pantallas en CDMX. Desde $50,000.",
    url: "/servicios/carpas/hangar/rigging/",
    priceRange: { min: 50000, max: 200000 },
    reviews,
    ratingValue: 5,
    reviewCount: 112,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Hangar", url: "/servicios/carpas/hangar/" },
    { name: "Con Rigging", url: "/servicios/carpas/hangar/rigging/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpa Hangar con Rigging para Eventos en CDMX"
  description="Renta de carpa hangar con puntos de rigging certificados 500 kg y truss integrado para producciones con iluminación, sonido y pantallas en CDMX. Desde $50,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Producción profesional con rigging certificado"
    title='Renta de <span class="highlight">Carpa Hangar con Rigging</span> para Eventos en CDMX'
    subtitle="Hangar con puntos de anclaje certificados de 500 kg y sistema de truss integrado para producciones profesionales. Cuelga iluminación, sonido line array, pantallas LED y efectos con total seguridad."
    primaryCTA={{ label: "Cotiza tu hangar con rigging", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar un hangar con rigging para mi evento` }}
    cards={[
      {
        title: "Puntos de anclaje certificados 500 kg con truss integrado",
        content: "<strong>Puntos de anclaje certificados para 500 kg por punto</strong>, distribuidos en una cuadrícula (grid) cada 3 a 5 metros a lo largo de toda la estructura del hangar. Sistema de truss de aluminio de alta resistencia integrado en la estructura principal para colgar equipo de iluminación, sonido, pantallas LED y elementos escenográficos. Carga total distribuida de hasta 10,000 kg según el modelo de hangar. Compatible con hangares de 20 y 30 metros de claro. Cada punto verificado por ingeniero estructural antes del montaje.",
      },
      {
        title: "Diseñado para producciones con iluminación, sonido y pantallas",
        content: "<strong>Diseñado para colgar iluminación, sonido line array, pantallas LED y efectos suspendidos</strong> con seguridad certificada. Incluye rigger profesional que supervisa todo el proceso de montaje, eslingas certificadas, grilletes forjados grado 8 y seguros de acero. Motores chain hoist opcionales para elevación controlada con ajuste de altura durante el evento. Plataformas elevadoras incluidas para acceso seguro a los puntos de rigging. Documentación de seguridad y póliza de responsabilidad civil incluidas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Tu producción necesita rigging profesional certificado?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta técnica con cálculo de cargas para tu producción"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Hangar para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un hangar con rigging para tu producción?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un hangar con rigging para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Hangar con Rigging</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Rigging Iluminación -->
          <section class="section section--alt" aria-labelledby="rigging-iluminacion-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Grid de luces profesional</span>
                <h2 class="showcase__title" id="rigging-iluminacion-heading">Rigging para Iluminación</h2>
                <p class="showcase__subtitle">Grid de puntos de rigging para montar parrillas de iluminación con moving heads, par LED, follow spots y efectos suspendidos.</p>
                <p class="showcase__text">Nuestro <strong>rigging para iluminación</strong> proporciona un grid de puntos de anclaje distribuidos estratégicamente para montar <strong>parrillas de iluminación profesional con moving heads, par LED RGBWA, follow spots y efectos especiales suspendidos</strong>. Cada punto soporta hasta 500 kg, permitiendo colgar truss con múltiples luminarias sin comprometer la seguridad. El sistema es compatible con truss de 12" (box truss) y 20.5" (heavy duty) en configuraciones de cuadrícula, línea o perímetro.</p>
                <p class="showcase__text">Incluye <strong>motores chain hoist para ajuste de altura</strong> durante el evento — fundamental para soundchecks y ajustes de iluminación en vivo. Nuestro rigger coordina con tu proveedor de <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para distribuir los puntos de carga de forma óptima según el diseño de tu producción. Plataformas elevadoras incluidas para acceso seguro a cada punto de la parrilla.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Moving Heads</span>
                  <span class="showcase__tag">Par LED</span>
                  <span class="showcase__tag">Follow Spots</span>
                  <span class="showcase__tag">Grid Distribuido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Rigging Iluminación
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Rigging Iluminación</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Rigging Sonido -->
          <section class="section section--alt" aria-labelledby="rigging-sonido-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Line array suspendido</span>
                <h2 class="showcase__title" id="rigging-sonido-heading">Rigging para Sonido</h2>
                <p class="showcase__subtitle">Puntos de rigging reforzados para suspender line arrays de sonido con distribución uniforme en todo el hangar.</p>
                <p class="showcase__text">Nuestro <strong>rigging para sonido</strong> está diseñado para soportar <strong>line arrays profesionales de hasta 12 cajas por lado</strong> (marcas como JBL VTX, d&b audiotechnik, L-Acoustics). Los puntos de anclaje reforzados soportan el peso de los arrays (300-500 kg por lado) con total seguridad. La distribución de puntos permite configurar arrays principales, delays suspendidos, subwoofers cardioides y monitores de escenario.</p>
                <p class="showcase__text">El sistema de <strong>motores chain hoist con control de altura preciso</strong> permite posicionar los arrays en el ángulo exacto para cobertura uniforme de todo el espacio. Nuestro rigger trabaja en conjunto con tu ingeniero de <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para calcular los ángulos de inclinación y la altura óptima según el aforo y la geometría del hangar. Incluye bumpers, shackles y hardware de fly certificado.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Line Array</span>
                  <span class="showcase__tag">Delays Suspendidos</span>
                  <span class="showcase__tag">500 kg/punto</span>
                  <span class="showcase__tag">Chain Hoist</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Rigging Sonido
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Rigging Sonido</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Rigging Pantallas -->
          <section class="section section--alt" aria-labelledby="rigging-pantallas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Videowall y LED suspendido</span>
                <h2 class="showcase__title" id="rigging-pantallas-heading">Rigging para Pantallas</h2>
                <p class="showcase__subtitle">Puntos de rigging para suspender videowalls modulares, pantallas LED gigantes y monitores de escenario en altura.</p>
                <p class="showcase__text">Nuestro <strong>rigging para pantallas</strong> permite suspender <strong>videowalls modulares, pantallas LED gigantes y monitores de escenario</strong> en la altura precisa para máxima visibilidad desde cualquier punto del hangar. Los puntos de anclaje reforzados soportan el peso de pantallas de hasta 50 m² (300-800 kg según tecnología). El sistema de truss integrado facilita el montaje con rieles de deslizamiento y brazos de sujeción específicos para cada formato de pantalla.</p>
                <p class="showcase__text">Ideal para <strong>conciertos con pantallas laterales IMAG, keynotes corporativos con pantalla central gigante, premiaciones con videowall de fondo y festivales con pantallas distribuidas</strong>. Los motores chain hoist permiten ajustar la inclinación y altura de cada pantalla de forma independiente. Nuestro rigger coordina con tu proveedor de <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para garantizar la instalación segura y la orientación óptima para tu audiencia.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Videowall</span>
                  <span class="showcase__tag">Pantallas LED</span>
                  <span class="showcase__tag">IMAG</span>
                  <span class="showcase__tag">Hasta 50 m²</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Rigging Pantallas
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Rigging Pantallas</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Producción Integral -->
          <section class="section section--alt" aria-labelledby="kit-integral-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Rigging completo + equipo AV</span>
                <h2 class="showcase__title" id="kit-integral-heading">Kit Producción Integral</h2>
                <p class="showcase__subtitle">Hangar con rigging completo más equipo audiovisual integrado: sonido, iluminación y pantallas en una sola cotización.</p>
                <p class="showcase__text">Nuestro <strong>Kit Producción Integral</strong> combina el hangar con sistema de rigging completo más todo el equipo audiovisual necesario para una producción profesional. Incluye <strong>rigging certificado con 24+ puntos, truss de aluminio heavy duty, motores chain hoist, sonido line array, parrilla de iluminación de escenario y pantallas LED</strong> — todo coordinado por nuestro director técnico de principio a fin.</p>
