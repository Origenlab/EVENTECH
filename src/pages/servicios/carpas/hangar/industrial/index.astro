---
/**
 * ─── Hangar Industrial — Pagina de Producto (Nivel 4) ───
 * Reforzado para uso intensivo y multi-día con tráfico
 * vehicular e instalación eléctrica trifásica.
 *
 * Jerarquia: Servicios > Carpas > Hangar > Industrial
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Hangar", href: "/servicios/carpas/hangar/" },
  { label: "Industrial" },
];

const faqs = [
  { question: "¿Cuánto tiempo se puede mantener instalado el hangar industrial?", answer: 'Nuestro hangar industrial está diseñado para <strong>instalaciones de 1 día hasta 6 meses</strong> de duración. Para instalaciones de más de 30 días, ofrecemos contratos de renta mensual con descuentos progresivos. La estructura de acero galvanizado reforzado soporta operación continua sin degradación, y la lona PVC de grado industrial mantiene sus propiedades de impermeabilidad y protección UV durante todo el periodo de instalación. Para instalaciones superiores a 3 meses, realizamos inspecciones de mantenimiento periódicas sin costo adicional.' },
  { question: "¿El hangar industrial soporta tráfico vehicular pesado?", answer: 'Sí, nuestro hangar industrial está diseñado para soportar <strong>circulación vehicular pesada de hasta 10 toneladas</strong> por eje. Las puertas industriales enrollables de 4x4 metros permiten la entrada y salida de camiones de carga, montacargas, vehículos de exhibición y maquinaria pesada. El anclaje reforzado con cimentación temporal garantiza estabilidad total de la estructura incluso con vibraciones por tráfico vehicular continuo. Para terrenos que requieren piso de carga pesada, ofrecemos plataformas modulares de acero o concreto prefabricado.' },
  { question: "¿La instalación eléctrica trifásica está incluida?", answer: 'Sí, nuestro hangar industrial incluye <strong>instalación eléctrica trifásica (220V/440V) con tableros de distribución certificados</strong> por perito eléctrico. La acometida se dimensiona según las necesidades de tu evento: 100 kVA para eventos estándar, 200-400 kVA para eventos con maquinaria o equipo de producción intensivo. Incluye puntos de energía distribuidos por toda la estructura, iluminación industrial de trabajo (500 lux) y protección diferencial en cada circuito. Si el predio no cuenta con acometida suficiente, proporcionamos <a href="/servicios/accesorios/plantas-energia/">plantas de energía</a> de respaldo.' },
  { question: "¿Se necesitan permisos especiales para el hangar industrial?", answer: 'Para instalaciones de más de 7 días generalmente se requieren <strong>permisos de la alcaldía correspondiente</strong>. Nuestro equipo te asesora sobre los trámites específicos según la ubicación y duración: dictamen de protección civil, permiso de uso de suelo temporal (si aplica), constancia de seguridad estructural, licencia de funcionamiento temporal y póliza de responsabilidad civil. Entregamos toda la <strong>documentación técnica, memorias de cálculo, planos eléctricos y certificaciones</strong> necesarias para facilitar la obtención de permisos.' },
  { question: "¿Cuál es la diferencia entre el hangar industrial y el hangar estándar?", answer: 'El hangar industrial cuenta con <strong>refuerzos estructurales adicionales de mayor calibre</strong> diseñados para soportar operación continua, circulación vehicular pesada y condiciones de carga exigentes. Incluye puertas industriales enrollables de 4x4 metros, instalación eléctrica trifásica con tableros de distribución, ventilación forzada con extractores industriales, iluminación de trabajo de 500 lux y señalización de seguridad completa. El hangar estándar es ideal para eventos de 1-3 días; el industrial está pensado para <strong>operaciones multi-día de hasta 6 meses</strong> con uso intensivo.' },
  { question: "¿Qué anticipo se requiere y cómo es el proceso de reserva?", answer: 'El anticipo para confirmar la reserva del hangar industrial es del <strong>30% del total</strong>. El 70% restante se paga 5 días antes del inicio del montaje. Para rentas mensuales (más de 30 días), el pago es mensual anticipado con un depósito de garantía equivalente a 1 mes de renta. Aceptamos transferencia bancaria, tarjeta de crédito y facturación fiscal. El proceso de reserva incluye: visita técnica al predio (sin costo), propuesta técnica con ingeniería estructural, firma de contrato y programación de montaje. Recomendamos iniciar el proceso con <strong>6 a 8 semanas de anticipación</strong>.' },
];

const specs = [
  { label: "Estructura", value: "Acero galvanizado reforzado grado industrial" },
  { label: "Uso", value: "Intensivo, multi-día, carga pesada" },
  { label: "Circulación", value: "Vehicular pesada hasta 10 toneladas" },
  { label: "Electricidad", value: "Trifásica con tableros de distribución" },
  { label: "Pisos", value: "Opcionales: concreto, asfalto, plataforma" },
  { label: "Puertas", value: "Industriales enrollables 4x4 metros" },
  { label: "Ventilación", value: "Forzada con extractores industriales" },
  { label: "Duración", value: "1 día a 6 meses de instalación" },
  { label: "Seguridad", value: "Extintores y señalización incluidos" },
  { label: "Montaje", value: "Equipo industrial, 3-10 días" },
];

const sidebarNav = [
  { name: "Hangar 20m", href: "/servicios/carpas/hangar/hangar-20m/" },
  { name: "Hangar 30m", href: "/servicios/carpas/hangar/hangar-30m/" },
  { name: "Hangar con Rigging", href: "/servicios/carpas/hangar/rigging/" },
  { name: "Hangar Industrial", href: null, active: true },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { name: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
];

const reviews = [
  { author: "Miguel Ángel Torres", text: "Instalamos un hangar industrial durante 2 semanas para una expo automotriz en un predio de Santa Fe. La estructura soportó el tráfico de vehículos pesados sin problema, la instalación eléctrica trifásica alimentó todos los stands y la ventilación industrial mantuvo el espacio confortable. EVENTECH gestionó todos los permisos y la logística fue impecable.", rating: 5, date: "2025-11-05" },
  { author: "Patricia Sánchez", text: "Contratamos el hangar industrial para una feria comercial de 5 días con 30 expositores. Las puertas enrollables de 4x4 permitieron la descarga directa de mercancía y el piso de plataforma soportó montacargas sin problema. La iluminación industrial y la señalización de seguridad cumplieron con todos los requisitos de protección civil. Excelente servicio.", rating: 5, date: "2025-10-18" },
  { author: "Carlos Jiménez", text: "Usamos el hangar industrial para un evento deportivo de 3 días con maquinaria pesada de exhibición. La estructura reforzada soportó todo perfectamente, y el equipo de EVENTECH coordinó la instalación eléctrica trifásica con nuestros proveedores de forma profesional. La ventilación forzada fue clave para mantener el espacio ventilado. Totalmente recomendable.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Carpa Hangar Industrial para Eventos en CDMX",
    description: "Renta de carpa hangar industrial reforzada para uso intensivo, multi-día y eventos con tráfico vehicular en CDMX. Instalación eléctrica trifásica incluida. Desde $45,000.",
    url: "/servicios/carpas/hangar/industrial/",
    priceRange: { min: 45000, max: 250000 },
    reviews,
    ratingValue: 5,
    reviewCount: 98,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Hangar", url: "/servicios/carpas/hangar/" },
    { name: "Industrial", url: "/servicios/carpas/hangar/industrial/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpa Hangar Industrial para Eventos en CDMX"
  description="Renta de carpa hangar industrial reforzada para uso intensivo, multi-día y eventos con tráfico vehicular en CDMX. Instalación eléctrica trifásica incluida. Desde $45,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Resistencia industrial para eventos exigentes"
    title='Renta de <span class="highlight">Carpa Hangar Industrial</span> para Eventos en CDMX'
    subtitle="Estructura de acero galvanizado reforzado para uso intensivo, eventos multi-día y circulación vehicular pesada. Instalación eléctrica trifásica con tableros de distribución incluidos."
    primaryCTA={{ label: "Cotiza tu hangar industrial", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar un hangar industrial para mi evento` }}
    cards={[
      {
        title: "Estructura reforzada para uso intensivo y multi-día",
        content: "<strong>Estructura reforzada para uso intensivo</strong>, circulación vehicular pesada de hasta 10 toneladas y eventos multi-día de hasta 6 meses de instalación. Acero galvanizado de mayor calibre con refuerzos estructurales adicionales para soportar operación continua sin degradación. Puertas industriales enrollables de 4x4 metros para entrada y salida de camiones, montacargas y maquinaria pesada. Ventilación forzada con extractores industriales para mantener el espacio confortable en cualquier condición climática.",
      },
      {
        title: "Instalación eléctrica trifásica y pisos de carga pesada",
        content: "<strong>Instalación eléctrica trifásica (220V/440V)</strong> con tableros de distribución certificados por perito eléctrico. Puntos de energía distribuidos por toda la estructura, iluminación industrial de trabajo (500 lux) y protección diferencial en cada circuito. Pisos opcionales de concreto modular, asfalto o plataforma de acero para circulación de carga pesada. Señalización de emergencia y extintores incluidos según normativa de protección civil. Toda la instalación cumple con la NOM-001-SEDE vigente.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Tu evento necesita resistencia industrial y operación continua?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta técnica con ingeniería estructural y diseño eléctrico"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Hangar para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un hangar industrial para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un hangar industrial para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Hangar Industrial</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Industrial para Expos -->
          <section class="section section--alt" aria-labelledby="industrial-expos-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ferias con tráfico vehicular</span>
                <h2 class="showcase__title" id="industrial-expos-heading">Industrial para Expos</h2>
                <p class="showcase__subtitle">Hangar industrial con acceso vehicular y piso de carga pesada para expos, ferias automotrices y exhibiciones con descarga directa.</p>
                <p class="showcase__text">Nuestro <strong>hangar industrial para expos</strong> está diseñado para ferias y exhibiciones que requieren <strong>acceso vehicular directo para descarga de mercancía, vehículos de exhibición y maquinaria pesada</strong>. Las puertas industriales enrollables de 4x4 metros permiten la entrada de camiones completos, y el piso reforzado soporta montacargas y tráfico vehicular continuo durante toda la duración del evento.</p>
                <p class="showcase__text">Incluye <strong>instalación eléctrica trifásica con puntos de energía distribuidos</strong> para alimentar stands con maquinaria, iluminación profesional y equipos de demostración. La ventilación forzada con extractores industriales mantiene el espacio confortable incluso con gran afluencia de visitantes. Ideal para <strong>expos automotrices, ferias industriales, exposiciones de maquinaria y eventos comerciales de gran formato</strong>. Complementa con <a href="/servicios/accesorios/senalizacion-alfombras/">señalización y alfombras</a> para un montaje profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Acceso Vehicular</span>
                  <span class="showcase__tag">Piso Reforzado</span>
                  <span class="showcase__tag">Trifásica</span>
                  <span class="showcase__tag">Ventilación</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Industrial Expos
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Industrial Expos</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Industrial Multi-Día -->
          <section class="section section--alt" aria-labelledby="industrial-multidia-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Eventos de 3 a 30 días</span>
                <h2 class="showcase__title" id="industrial-multidia-heading">Industrial Multi-Día</h2>
                <p class="showcase__subtitle">Estructura reforzada para eventos de larga duración: ferias de una semana, campamentos de operación y montajes de producción de varios días.</p>
                <p class="showcase__text">El <strong>hangar industrial multi-día</strong> es la solución para eventos que requieren una estructura permanente durante <strong>3 a 30 días o más</strong>. El acero galvanizado de grado industrial soporta operación continua sin degradación, mientras la lona PVC de 900 g/m² mantiene impermeabilidad y protección UV durante todo el periodo de instalación. Ideal para <strong>ferias comerciales de una semana, campamentos de operación, cuarteles temporales y montajes de producción cinematográfica</strong>.</p>
                <p class="showcase__text">Incluye <strong>mantenimiento preventivo durante la instalación</strong>: revisión de tensores, verificación de anclajes y ajuste de lonas cada 7 días. Para instalaciones de más de 30 días, ofrecemos contratos de renta mensual con descuentos del 15-25% según duración. La señalización de seguridad, extintores y rutas de evacuación están incluidos y cumplen con la normativa de protección civil. Complementa con <a href="/servicios/accesorios/calefaccion-clima/">sistemas de clima artificial</a> para confort térmico durante toda la instalación.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">3-30+ días</span>
                  <span class="showcase__tag">Mantenimiento</span>
                  <span class="showcase__tag">Renta Mensual</span>
                  <span class="showcase__tag">Protección Civil</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Industrial Multi-Día
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Industrial Multi-Día</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Industrial con Trifásica -->
          <section class="section section--alt" aria-labelledby="industrial-trifasica-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Maquinaria y equipo pesado</span>
                <h2 class="showcase__title" id="industrial-trifasica-heading">Industrial con Trifásica</h2>
                <p class="showcase__subtitle">Hangar con instalación eléctrica trifásica certificada para eventos con maquinaria, equipo pesado y alta demanda energética.</p>
                <p class="showcase__text">Nuestro <strong>hangar industrial con trifásica</strong> incluye una instalación eléctrica completa de <strong>220V/440V con tableros de distribución certificados</strong> por perito eléctrico. La acometida se dimensiona desde 100 hasta 400 kVA según las necesidades del evento. Incluye puntos de energía distribuidos cada 5 metros, circuitos dedicados para maquinaria pesada, protección diferencial y puesta a tierra certificada.</p>
                <p class="showcase__text">Ideal para <strong>exposiciones industriales con maquinaria en operación, ferias tecnológicas con demostraciones en vivo, eventos con cocina industrial y producciones que requieren alta demanda energética</strong>. Si el predio no cuenta con acometida eléctrica suficiente, proporcionamos <a href="/servicios/accesorios/plantas-energia/">plantas de energía</a> silenciosas de 50 a 500 kW con transferencia automática. Toda la instalación cumple con la <strong>NOM-001-SEDE vigente</strong> y se certifica por perito antes de la puesta en operación.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">220V/440V</span>
                  <span class="showcase__tag">Hasta 400 kVA</span>
                  <span class="showcase__tag">Certificada</span>
                  <span class="showcase__tag">NOM-001-SEDE</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Industrial Trifásica
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Industrial Trifásica</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Industrial Completo -->
          <section class="section section--alt" aria-labelledby="kit-industrial-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Venue industrial autosuficiente</span>
