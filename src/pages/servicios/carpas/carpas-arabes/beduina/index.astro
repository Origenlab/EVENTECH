---
/**
 * ─── Carpa Árabe Beduina — Pagina de Producto (Nivel 4) ───
 * Diseño jaima africana con telas drapeadas y decoración étnica
 * para eventos temáticos y festivales.
 *
 * Jerarquia: Servicios > Carpas > Carpas Árabes > Beduina
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { label: "Beduina" },
];

const faqs = [
  { question: "¿La carpa beduina es solo decorativa o protege del clima?", answer: 'La carpa beduina es una <strong>estructura funcional completa</strong> que protege del sol, la lluvia ligera y el viento. La lona principal de algodón tratado o PVC es <strong>impermeable y resistente a UV</strong>. Las telas drapeadas decorativas van sobre la estructura base, por lo que no comprometen la protección climática. Para eventos en temporada de lluvias intensas, reforzamos con <strong>lona PVC adicional sobre las telas</strong> para garantizar impermeabilidad total sin perder la estética beduina.' },
  { question: "¿Cuántas personas caben en una carpa beduina?", answer: 'La capacidad varía según la configuración. La carpa beduina de <strong>5x5 metros</strong> acomoda 20-30 personas con cojines de suelo o 15-20 en banquete tradicional. La de <strong>8x8 metros</strong> recibe 50-70 personas. La de <strong>10x10 metros</strong> cubre 80-120 personas, y la de <strong>12x12 metros</strong> alcanza 150-200 personas con áreas diferenciadas — recepción con cojines, banquete y lounge. Nuestro equipo diseña la distribución ideal para tu número de invitados.' },
  { question: "¿Se puede combinar la carpa beduina con mobiliario moderno?", answer: 'Sí, es una combinación muy popular y estilísticamente impactante. Muchos clientes eligen <strong>mesas modernas con sillas Ghost o Chiavari</strong> dentro de la carpa beduina para crear un contraste elegante entre lo étnico y lo contemporáneo. También ofrecemos <strong>mobiliario temático a juego</strong> — mesas bajas marroquíes, cojines de suelo, pufs de cuero y sillas tipo director vintage. Nuestro equipo de diseño te asesora sobre la combinación perfecta según el concepto de tu evento.' },
  { question: "¿La decoración étnica está incluida en la renta?", answer: 'Sí, la renta de carpa beduina incluye <strong>decoración temática básica</strong>: faroles de latón marroquí, cojines decorativos de suelo, alfombras en tonos tierra y elementos ornamentales metálicos. Para una experiencia más completa, ofrecemos paquetes de <strong>decoración premium</strong> que incluyen lámparas de mosaico, tapetes artesanales, cortinas de cuentas, velas en recipientes de vidrio soplado y elementos de cerámica decorativa. El Kit Festival Étnico incluye toda la decoración premium.' },
  { question: "¿La carpa beduina se puede usar bajo lluvia?", answer: 'Sí, con las precauciones adecuadas. La estructura base cuenta con <strong>lona impermeable de protección</strong> sobre las telas decorativas. Para eventos con probabilidad de lluvia, instalamos una <strong>capa superior de PVC transparente o blanco</strong> que protege las telas drapeadas sin alterar significativamente la estética beduina. Los laterales se pueden cerrar con cortinas impermeables que mantienen el estilo étnico. Recomendamos consultar con nuestro equipo si tu evento coincide con temporada de lluvias.' },
  { question: "¿Con cuánta anticipación debo reservar la carpa beduina?", answer: 'Recomendamos reservar con <strong>4 a 8 semanas de anticipación</strong>. La carpa beduina requiere más tiempo de preparación que las carpas árabes clásicas debido a la <strong>decoración temática y las telas especiales</strong>. En temporada alta (octubre a febrero), lo ideal es apartar con <strong>2-3 meses mínimo</strong>. Los paquetes con decoración premium o el Kit Festival Étnico pueden requerir hasta 6 semanas por la logística de elementos decorativos especiales. Contacta a nuestro equipo lo antes posible para garantizar disponibilidad.' },
];

const specs = [
  { label: "Diseño", value: "Jaima beduina del norte de África" },
  { label: "Telas", value: "Algodón y lino en tonos tierra/arena/terracota" },
  { label: "Estructura", value: "Postes centrales de madera o aluminio" },
  { label: "Medidas", value: "5x5 a 12x12 metros" },
  { label: "Capacidad", value: "30 a 200 personas" },
  { label: "Decoración", value: "Faroles, cojines, alfombras incluidas" },
  { label: "Cortinas", value: "Laterales drapeadas recogibles" },
  { label: "Altura centro", value: "4 a 5.5 metros" },
  { label: "Montaje", value: "Equipo especializado incluido" },
  { label: "Personalización", value: "Colores y decoración adaptables" },
];

const sidebarNav = [
  { name: "Árabe Clásica", href: "/servicios/carpas/carpas-arabes/clasica/" },
  { name: "Árabe con Forros", href: "/servicios/carpas/carpas-arabes/forros/" },
  { name: "Árabe Transparente", href: "/servicios/carpas/carpas-arabes/transparente/" },
  { name: "Árabe Beduina", href: null, active: true },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
];

const reviews = [
  { author: "Isabela Fernández", text: "La carpa beduina fue la protagonista absoluta de nuestra boda bohemia en un jardín de Tepoztlán. Las telas en tonos arena y terracota, los faroles marroquíes y los cojines de suelo crearon un ambiente de Las Mil y Una Noches que dejó a todos sin palabras. El equipo de EVENTECH cuidó cada detalle de la decoración. Fue mágico.", rating: 5, date: "2025-11-25" },
  { author: "Diego Ramírez", text: "Organizamos un festival temático oriental para 150 personas y la carpa beduina fue el corazón del evento. La combinación de las telas drapeadas con la iluminación ambiental de faroles creó una atmósfera increíble. Los invitados se sentían transportados a otro mundo. El servicio de montaje fue impecable y puntual.", rating: 5, date: "2025-10-18" },
  { author: "Sofía Navarro", text: "Contratamos la carpa beduina de gala con acabados dorados para una cena corporativa temática. El resultado fue espectacular — parecía un set de película. La decoración incluida superó nuestras expectativas y el equipo de producción coordinó todo perfectamente con nuestro catering y DJ. Definitivamente la volveremos a usar.", rating: 5, date: "2025-09-12" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Carpa Árabe Beduina para Eventos en CDMX",
    description: "Renta de carpa árabe beduina con diseño de jaima africana, telas drapeadas y decoración étnica para eventos temáticos y festivales en CDMX. Desde $10,000.",
    url: "/servicios/carpas/carpas-arabes/beduina/",
    priceRange: { min: 10000, max: 50000 },
    reviews,
    ratingValue: 5,
    reviewCount: 134,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Carpas Árabes", url: "/servicios/carpas/carpas-arabes/" },
    { name: "Beduina", url: "/servicios/carpas/carpas-arabes/beduina/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpa Árabe Beduina para Eventos en CDMX"
  description="Renta de carpa árabe beduina con diseño de jaima africana, telas drapeadas y decoración étnica para eventos temáticos y festivales en CDMX. Desde $10,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Estilo étnico único y memorable"
    title='Renta de <span class="highlight">Carpa Árabe Beduina</span> para Eventos en CDMX'
    subtitle="Carpas beduinas con diseño de jaima del norte de África, telas drapeadas en tonos tierra y decoración étnica incluida. Faroles marroquíes, cojines de suelo y alfombras artesanales para eventos temáticos inolvidables."
    primaryCTA={{ label: "Cotiza tu carpa beduina", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa árabe beduina para mi evento` }}
    cards={[
      {
        title: "Diseño de jaima africana con telas drapeadas en tonos tierra",
        content: "<strong>Renta de carpa árabe beduina</strong> inspirada en las jaimas del norte de África. Telas drapeadas en tonos <strong>arena, terracota y tierra</strong> que crean una atmósfera envolvente y exótica. Estructura de postes centrales de madera o aluminio con altura de <strong>4 a 5.5 metros</strong> en el centro. Cortinas laterales drapeadas recogibles que permiten crear ambientes abiertos o cerrados. Capacidad de <strong>30 a 200 personas</strong> en configuraciones de 5x5 a 12x12 metros. Ideal para bodas bohemias, festivales culturales y cenas temáticas.",
      },
      {
        title: "Decoración étnica incluida con faroles, cojines y alfombras",
        content: "<strong>Decoración temática completa incluida</strong> en la renta. Faroles de latón marroquí con velas LED, cojines decorativos de suelo en colores coordinados, alfombras en tonos tierra y detalles metálicos ornamentales. Opción de <strong>decoración premium</strong> con lámparas de mosaico, tapetes artesanales, cortinas de cuentas y cerámica decorativa. Personalización de colores y telas según el concepto de tu evento. Montaje por <strong>equipo especializado</strong> en producción temática incluido.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres transportar a tus invitados a un mundo de Las Mil y Una Noches?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la configuración beduina ideal para tu evento temático"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Árabes para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una carpa árabe beduina para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una carpa árabe beduina para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Carpa Árabe Beduina</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Beduina Arena Clásica -->
          <section class="section section--alt" aria-labelledby="arena-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tonos neutros y elegantes</span>
                <h2 class="showcase__title" id="arena-heading">Beduina Arena Clásica</h2>
                <p class="showcase__subtitle">Telas en tonos arena y beige neutros para una estética beduina elegante y versátil.</p>
                <p class="showcase__text">La <strong>beduina arena clásica</strong> es nuestra versión más versátil y elegante de la carpa beduina. Las telas drapeadas en <strong>tonos arena, beige y crema</strong> crean un ambiente cálido y acogedor que se adapta a cualquier estilo de evento — desde bodas bohemias hasta cenas corporativas temáticas. Los faroles de latón marroquí con acabado envejecido aportan puntos de luz cálida que se reflejan en las telas claras, creando una <strong>atmósfera envolvente e íntima</strong>.</p>
                <p class="showcase__text">Los cojines de suelo en tonos coordinados y las alfombras en fibras naturales completan la decoración base. La paleta neutra permite <strong>personalizar con acentos de color</strong> — flores, velas, centros de mesa — sin competir con la estética de la carpa. Ideal para <strong>bodas rústicas, despedidas de soltero/a y eventos al aire libre</strong> donde se busca un ambiente elegante con un toque exótico. Combina con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un resultado espectacular.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tonos Arena</span>
                  <span class="showcase__tag">Versatil</span>
                  <span class="showcase__tag">Bodas Boho</span>
                  <span class="showcase__tag">Faroles Marroquíes</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Beduina Arena
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Beduina Arena Clásica</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Beduina Terracota -->
          <section class="section section--alt" aria-labelledby="terracota-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Estilo bohemio y cálido</span>
                <h2 class="showcase__title" id="terracota-heading">Beduina Terracota</h2>
                <p class="showcase__subtitle">Tonos cálidos terracota, óxido y borgoña para eventos bohemios con personalidad audaz.</p>
                <p class="showcase__text">La <strong>beduina terracota</strong> lleva el estilo étnico a un nivel más audaz y vibrante. Las telas drapeadas combinan tonos <strong>terracota, óxido, borgoña y siena</strong> que evocan los paisajes desérticos del Sahara y las medinas marroquíes. Los faroles de latón con vidrio de color ámbar crean puntos de luz cálida que resaltan los tonos terracota del textil, generando una <strong>atmósfera bohemia dramática</strong> y sumamente fotogénica.</p>
                <p class="showcase__text">Los cojines de suelo en terciopelo y algodón texturizado van en tonos coordinados — terracota, mostaza y borgoña — con alfombras tipo kilim artesanal. Esta paleta cromática es la favorita para <strong>bodas bohemias de otoño, cenas temáticas, eventos de moda y sesiones fotográficas</strong>. El contraste entre los tonos cálidos y la vegetación verde del jardín crea composiciones visuales espectaculares. Complementa con <a href="/servicios/iluminacion/decorativa/candiles/">candiles vintage</a> para un ambiente memorable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Terracota</span>
                  <span class="showcase__tag">Bohemio</span>
                  <span class="showcase__tag">Kilim Artesanal</span>
                  <span class="showcase__tag">Fotografía</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Beduina Terracota
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Beduina Terracota</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Beduina de Gala -->
          <section class="section section--alt" aria-labelledby="gala-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Lujo étnico sofisticado</span>
                <h2 class="showcase__title" id="gala-heading">Beduina de Gala</h2>
                <p class="showcase__subtitle">Acabados dorados, faroles de mosaico y detalles premium para cenas de gala y eventos de lujo.</p>
                <p class="showcase__text">La <strong>beduina de gala</strong> es nuestra versión más lujosa, diseñada para <strong>cenas de gala, eventos corporativos premium y celebraciones de alto perfil</strong>. Las telas drapeadas combinan tonos <strong>dorado, champagne y borgoña oscuro</strong> con acabados de terciopelo y satín que reflejan la luz de manera espectacular. Los faroles son de <strong>mosaico de vidrio multicolor</strong> artesanales que proyectan patrones de luz en las telas del techo.</p>
                <p class="showcase__text">Los detalles decorativos incluyen <strong>elementos metálicos dorados</strong>, lámparas colgantes de bronce, cojines de terciopelo con bordados y alfombras persas premium. Las cortinas laterales van en terciopelo pesado con amarres dorados para un efecto de <strong>teatro real</strong>. Es la opción favorita para <strong>galas benéficas, aniversarios de empresa, presentaciones de productos de lujo y cenas privadas exclusivas</strong>. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción de primer nivel.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Acabados Dorados</span>
                  <span class="showcase__tag">Mosaico Artesanal</span>
                  <span class="showcase__tag">Terciopelo</span>
                  <span class="showcase__tag">Eventos Premium</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Beduina de Gala
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Beduina de Gala</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Festival Étnico -->
          <section class="section section--alt" aria-labelledby="kit-festival-heading">
            <div class="showcase">
              <div class="showcase__content">
