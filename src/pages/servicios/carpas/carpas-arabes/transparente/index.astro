---
/**
 * ─── Carpa Árabe Transparente — Pagina de Producto (Nivel 4) ───
 * Paneles de PVC cristal para ver paisaje y estrellas
 * en eventos al aire libre.
 *
 * Jerarquia: Servicios > Carpas > Carpas Árabes > Transparente
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { label: "Transparente" },
];

const faqs = [
  { question: "¿La carpa árabe transparente se calienta con el sol?", answer: 'El PVC cristal permite el paso de la luz solar, por lo que en eventos diurnos con exposición directa puede generar <strong>efecto invernadero</strong>. Para eventos de día en temporada cálida, ofrecemos <strong>paneles removibles para ventilación cruzada</strong> y opciones de <a href="/servicios/accesorios/calefaccion-clima/">climatización con nebulizadores o aire acondicionado portátil</a>. En eventos al atardecer o nocturnos (los más populares con carpa transparente) la temperatura es muy agradable. La configuración híbrida con techo opaco y laterales transparentes reduce significativamente el calor.' },
  { question: "¿Se puede ver desde afuera hacia adentro?", answer: 'Sí, el PVC cristal es transparente en ambas direcciones. Durante el <strong>día</strong> se ve claramente desde afuera. Durante la <strong>noche</strong>, con la iluminación interior encendida, el efecto es espectacular — tu evento se convierte en una caja de luz visible desde el jardín. Si necesitas privacidad en ciertas zonas, incluimos <strong>cortinas de chiffon desmontables</strong> que puedes colocar en secciones específicas sin perder la vista en el resto de la carpa.' },
  { question: "¿La carpa transparente es resistente a la lluvia?", answer: 'Absolutamente. El PVC cristal de <strong>0.5 mm de espesor</strong> es 100% impermeable con sellado térmico en todas las uniones. Los techos tensados en pico canalizan el agua de lluvia hacia los laterales con <strong>sistema de drenaje integrado</strong>. La estructura de aluminio anodizado resiste vientos de hasta 70 km/h. Tu evento estará completamente protegido mientras disfrutas de la vista panorámica del paisaje y, si llueve, del espectáculo de las gotas cayendo sobre el techo transparente.' },
  { question: "¿Se puede combinar la carpa transparente con forros parciales?", answer: 'Sí, es una configuración muy popular. Puedes elegir <strong>techo transparente con laterales forrados</strong> para mayor privacidad manteniendo la vista al cielo, o <strong>techo forrado con laterales transparentes</strong> para disfrutar del paisaje sin sol directo. También ofrecemos la opción <strong>50/50</strong> — mitad transparente, mitad forrada — ideal para eventos donde una zona es de coctel con vista panorámica y otra es de banquete con ambiente más íntimo.' },
  { question: "¿Cómo luce la carpa transparente en eventos nocturnos?", answer: 'Es donde más impacto genera. Con la <strong>iluminación LED integrada</strong>, la carpa transparente se convierte en una caja de luz espectacular visible desde todo el jardín. Los <strong>fairy lights en el techo</strong> se reflejan en los paneles de PVC creando un efecto de doble iluminación. Las <strong>wash lights de color</strong> bañan los paneles transparentes con tonos cambiantes. Y por supuesto, puedes disfrutar de las estrellas y la luna a través del techo. Es la opción favorita para <strong>bodas nocturnas en jardines con paisaje</strong>.' },
  { question: "¿Se puede tener privacidad en zonas específicas de la carpa transparente?", answer: 'Sí, ofrecemos varias soluciones de privacidad. Las <strong>cortinas de chiffon desmontables</strong> se instalan en cualquier sección de la carpa y se pueden recoger o soltar según el momento del evento. También disponemos de <strong>paneles de PVC esmerilado</strong> que permiten el paso de luz pero no la visibilidad directa, ideales para zonas de servicio o camerinos. La combinación de paneles transparentes y opacos en la misma carpa te da control total sobre qué áreas son visibles y cuáles no.' },
];

const specs = [
  { label: "Paneles", value: "PVC cristal 0.5mm transparente" },
  { label: "Protección", value: "Anti-UV, anti-amarillamiento" },
  { label: "Techo", value: "Transparente completo o parcial" },
  { label: "Estructura", value: "Aluminio anodizado visible como decoración" },
  { label: "Medidas", value: "6x6 a 12x20 metros" },
  { label: "Capacidad", value: "50 a 250 personas" },
  { label: "Ventilación", value: "Paneles removibles para circulación" },
  { label: "Lluvia", value: "100% impermeable, drenaje integrado" },
  { label: "Combinación", value: "Con cortinas de chiffon opcionales" },
  { label: "Montaje", value: "Profesional incluido, 4-8 horas" },
];

const sidebarNav = [
  { name: "Árabe Clásica", href: "/servicios/carpas/carpas-arabes/clasica/" },
  { name: "Árabe con Forros", href: "/servicios/carpas/carpas-arabes/forros/" },
  { name: "Árabe Transparente", href: null, active: true },
  { name: "Árabe Beduina", href: "/servicios/carpas/carpas-arabes/beduina/" },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
];

const reviews = [
  { author: "Mariana López", text: "La carpa transparente para nuestra boda nocturna en un jardín de Cuernavaca fue absolutamente mágica. Ver las estrellas a través del techo mientras bailábamos fue un momento que nuestros invitados no van a olvidar jamás. Los fairy lights reflejados en los paneles de PVC crearon un efecto de cielo estrellado doble. Totalmente recomendado.", rating: 5, date: "2025-11-08" },
  { author: "Andrés Villalobos", text: "Usamos la carpa transparente lateral para un coctel corporativo en una terraza panorámica de Polanco. La vista de la ciudad de noche a través de los paneles fue espectacular. El equipo de EVENTECH instaló iluminación LED que cambiaba de color con los colores de nuestra marca. Experiencia de primer nivel.", rating: 5, date: "2025-10-15" },
  { author: "Elena Castillo", text: "Contratamos la carpa transparente completa para una cena de gala bajo las estrellas en un jardín de Valle de Bravo. El PVC cristal se mantuvo impecable toda la noche, sin empañarse ni generar goteo. Cuando empezó a llover ligeramente, el sonido de las gotas sobre el techo transparente fue un plus inesperado. Servicio impecable.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Carpa Árabe Transparente para Eventos en CDMX",
    description: "Renta de carpa árabe transparente con paneles de PVC cristal para disfrutar paisaje y estrellas en eventos al aire libre en CDMX. Montaje incluido. Desde $15,000.",
    url: "/servicios/carpas/carpas-arabes/transparente/",
    priceRange: { min: 15000, max: 65000 },
    reviews,
    ratingValue: 5,
    reviewCount: 156,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Carpas Árabes", url: "/servicios/carpas/carpas-arabes/" },
    { name: "Transparente", url: "/servicios/carpas/carpas-arabes/transparente/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpa Árabe Transparente para Eventos en CDMX"
  description="Renta de carpa árabe transparente con paneles de PVC cristal para disfrutar paisaje y estrellas en eventos al aire libre en CDMX. Montaje incluido. Desde $15,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Eventos bajo las estrellas"
    title='Renta de <span class="highlight">Carpa Árabe Transparente</span> para Eventos en CDMX'
    subtitle="Carpas árabes transparentes con paneles de PVC cristal anti-UV que permiten disfrutar del paisaje y las estrellas. 100% impermeables con estructura de aluminio anodizado y montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tu carpa transparente", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa árabe transparente para mi evento` }}
    cards={[
      {
        title: "Paneles de PVC cristal transparente con vista 360 grados",
        content: "<strong>Renta de carpa árabe transparente</strong> con paneles laterales y techo en PVC cristal de 0.5mm con protección <strong>anti-UV y anti-amarillamiento</strong>. Vista 360 grados del paisaje, jardín y cielo sin sacrificar protección contra lluvia y viento. Estructura de <strong>aluminio anodizado</strong> visible como elemento decorativo que aporta un toque industrial-elegante. Capacidad de <strong>50 a 250 personas</strong> en configuraciones de 6x6 a 12x20 metros. Ideal para bodas nocturnas, cenas bajo las estrellas y venues con paisaje espectacular.",
      },
      {
        title: "Combinación con cortinas de chiffon para zonas de privacidad",
        content: "<strong>Personalización total</strong> con cortinas de chiffon desmontables para crear zonas de privacidad sin perder la vista panorámica. Configuración <strong>100% transparente o híbrida</strong> — techo transparente con laterales opacos, o techo opaco con laterales de cristal. Paneles removibles para <strong>ventilación cruzada</strong> en eventos diurnos. Sistema de drenaje integrado que canaliza el agua de lluvia. Montaje profesional incluido en <strong>4 a 8 horas</strong> según el tamaño. Desmontaje sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres un evento con vista panorámica bajo las estrellas?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la configuración transparente ideal para tu venue y estilo de evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Árabes para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una carpa árabe transparente para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una carpa árabe transparente para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Carpa Árabe Transparente</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Transparente Total -->
          <section class="section section--alt" aria-labelledby="total-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Vista completa 360 grados</span>
                <h2 class="showcase__title" id="total-heading">Transparente Total</h2>
                <p class="showcase__subtitle">Techo y laterales completamente en PVC cristal para una experiencia inmersiva con el entorno.</p>
                <p class="showcase__text">La configuración <strong>transparente total</strong> ofrece la experiencia más inmersiva de nuestra colección. Tanto el <strong>techo como los laterales</strong> son de PVC cristal de 0.5mm, creando un espacio protegido que se funde con el entorno. Desde el interior, tus invitados disfrutan de una <strong>vista panorámica de 360 grados</strong> — jardín, montañas, cielo y estrellas — sin exposición a lluvia, viento ni insectos.</p>
                <p class="showcase__text">Es la opción más popular para <strong>bodas nocturnas en jardines con paisaje espectacular</strong>, cenas de gala en viñedos y eventos en venues de montaña. La estructura de aluminio anodizado queda visible como elemento decorativo, aportando un toque <strong>moderno e industrial-elegante</strong>. Combina con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para crear una caja de luz que se ve espectacular desde cualquier punto del venue.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Techo Cristal</span>
                  <span class="showcase__tag">Laterales Cristal</span>
                  <span class="showcase__tag">Vista 360°</span>
                  <span class="showcase__tag">Bodas Nocturnas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Transparente Total
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Transparente Total</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Transparente Lateral -->
          <section class="section section--alt" aria-labelledby="lateral-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Protección solar + vista panorámica</span>
                <h2 class="showcase__title" id="lateral-heading">Transparente Lateral</h2>
                <p class="showcase__subtitle">Techo opaco con laterales en PVC cristal para disfrutar del paisaje sin sol directo.</p>
                <p class="showcase__text">La configuración <strong>transparente lateral</strong> combina un <strong>techo de lona PVC opaca</strong> (blanco o marfil) con <strong>laterales de PVC cristal transparente</strong>. Esta combinación ofrece protección solar durante el día mientras mantiene la vista panorámica del entorno. Es la opción ideal para <strong>eventos que comienzan de día y continúan de noche</strong> — cócteles al atardecer, brunchs de bodas y recepciones de fin de semana.</p>
                <p class="showcase__text">El techo opaco reduce significativamente el <strong>efecto invernadero</strong> durante las horas de sol, manteniendo una temperatura agradable en el interior. Los laterales transparentes se pueden complementar con <strong>cortinas de chiffon recogibles</strong> para zonas donde se requiera privacidad. Al anochecer, la combinación de techo opaco con laterales de cristal iluminados crea un efecto de <strong>linterna gigante</strong> que se ve espectacular desde el jardín.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Techo Opaco</span>
                  <span class="showcase__tag">Laterales Cristal</span>
                  <span class="showcase__tag">Sin Sol Directo</span>
                  <span class="showcase__tag">Día y Noche</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Transparente Lateral
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Transparente Lateral</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Transparente Nocturna -->
          <section class="section section--alt" aria-labelledby="nocturna-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Efecto caja de luz</span>
                <h2 class="showcase__title" id="nocturna-heading">Transparente Nocturna</h2>
                <p class="showcase__subtitle">Configuración optimizada para eventos nocturnos con iluminación LED integrada en techo y laterales.</p>
                <p class="showcase__text">La configuración <strong>transparente nocturna</strong> está diseñada específicamente para eventos de noche. Incluye <strong>iluminación LED integrada</strong> — tiras LED perimetrales, fairy lights en el techo y wash lights de color — que transforman la carpa transparente en una <strong>espectacular caja de luz</strong> visible desde todo el venue. Los paneles de PVC cristal reflejan y multiplican cada punto de luz, creando un efecto inmersivo de estrellas y color.</p>
                <p class="showcase__text">A través del techo transparente, tus invitados disfrutan de la <strong>luna y las estrellas reales</strong> mezcladas con los fairy lights del interior — un efecto que no se puede lograr con ningún otro tipo de carpa. Las wash lights de color programables permiten cambiar el <strong>ambiente cromático</strong> a lo largo de la noche: blanco para la cena, rosa para el brindis, azul para el primer baile. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción nocturna completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">LED Integrado</span>
                  <span class="showcase__tag">Fairy Lights</span>
                  <span class="showcase__tag">Wash Lights</span>
                  <span class="showcase__tag">Efecto Estrellas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Transparente Nocturna
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Transparente Nocturna</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Jardín con Vista -->
          <section class="section section--alt" aria-labelledby="kit-jardin-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Paquete todo incluido</span>
                <h2 class="showcase__title" id="kit-jardin-heading">Kit Jardín con Vista</h2>
                <p class="showcase__subtitle">Paquete integral: carpa transparente + fairy lights + pisos de duela para eventos en jardín.</p>
