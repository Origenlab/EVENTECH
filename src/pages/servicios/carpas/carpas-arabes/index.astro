---
/**
 * ─── EVENTECH.MX — Renta de Carpas Árabes para Eventos (Hub L4, molde hm- 2026) ───
 * Clásica · Con Forros · Transparente · Beduina — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/carpas — beduina, transparente y forros reales; carpa-boda-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "clasica",
    name: "Carpa Árabe Clásica",
    badge: "La más solicitada",
    excerpt: "Techos tensados en pico con cortinas de chiffon blanco y marfil. De 6×6 m (30 personas) a 15×30 m (400+ invitados). La favorita para bodas románticas y XV años.",
    href: "/servicios/carpas/carpas-arabes/clasica/",
    image: "/images/carpas/carpa-boda-01.avif",
    specs: ["6×6 a 15×30 m", "Chiffon blanco/marfil", "Hasta 400+ pax", "Aluminio serie 6000"],
  },
  {
    id: "forros",
    name: "Carpa Árabe con Forros",
    badge: "Acabado salón de lujo",
    excerpt: "Interior completamente forrado en satín o chiffon que oculta la estructura metálica y crea un salón de lujo temporal. Ideal para galas y bodas premium.",
    href: "/servicios/carpas/carpas-arabes/forros/",
    image: "/images/carpas/forros-interiores-carpa-elegante.avif",
    specs: ["Satín / chiffon / blackout", "Drapeado nube", "10+ colores", "Aspecto salón"],
  },
  {
    id: "transparente",
    name: "Carpa Árabe Transparente",
    badge: "Vista 360°",
    excerpt: "Paneles de PVC cristal de 0.5 mm que dejan ver el jardín, el atardecer y las estrellas. Perfecta para venues con paisaje y eventos nocturnos.",
    href: "/servicios/carpas/carpas-arabes/transparente/",
    image: "/images/carpas/carpa-transparente-boda-elegante.avif",
    specs: ["PVC cristal 0.5 mm", "Vista 360°", "Config. híbrida", "Impermeable"],
  },
  {
    id: "beduina",
    name: "Carpa Árabe Beduina",
    badge: "Temática exclusiva",
    excerpt: "Jaima inspirada en el norte de África con telas drapeadas, cojines y lámparas marroquíes. Para cenas de gala temáticas y eventos con concepto oriental.",
    href: "/servicios/carpas/carpas-arabes/beduina/",
    image: "/images/carpas/carpa-arabe-beduina-boda-jardin.avif",
    specs: ["Estilo jaima", "Telas drapeadas", "Decoración incluida", "6×6 a 12×18 m"],
  },
];

const whyFeatures = [
  {
    title: "Visita técnica gratuita a tu venue",
    body: "Antes de cotizar vamos a tu jardín, terraza o predio a medir el terreno, evaluar el anclaje y diseñar la distribución óptima — mesas, pista, barra y ceremonia. Una carpa mal dimensionada arruina el montaje: por eso partimos de las medidas reales de tu espacio, no de un estimado por teléfono.",
  },
  {
    title: "Estructura certificada de grado comercial",
    body: "Aluminio anodizado serie 6000, lona PVC impermeable de 550 g/m² con protección UV al 99% y tensores de acero inoxidable 304. La estructura resiste vientos de hasta 60 km/h. No improvisamos con material de segunda: lo que se instala sobre tus invitados está certificado y revisado antes de cada montaje.",
  },
  {
    title: "Montaje profesional propio con prueba de seguridad",
    body: "Equipo de montaje propio (no subcontratado) que instala 24 a 48 horas antes según el tamaño: anclaje al terreno, tensado de lona, cortinas, nivelación y prueba de seguridad final. Llegamos con tiempo de sobra para que el día del evento la carpa ya esté impecable y verificada.",
  },
  {
    title: "Impermeable y lista para lluvia o viento",
    body: "Los techos en pico canalizan el agua a los laterales y reforzamos con canaletas de desagüe y tensores adicionales en temporada de lluvias. Tu evento no depende del clima: la carpa protege a tus invitados de sol, lluvia y viento sin que tengas que preocuparte por el pronóstico.",
  },
  {
    title: "Personalización total: forros, luz, piso y clima",
    body: "Forros que ocultan la estructura, iluminación (fairy lights, candiles, spots), piso de duela o alfombra, cortinas decorativas y clima artificial. La carpa se adapta a tu concepto — romántico, elegante, temático — hasta convertirse en un venue a medida, no una lona genérica.",
  },
  {
    title: "Montaje integral desde una sola empresa",
    body: "La carpa luce mejor cuando el mobiliario, la iluminación y el piso vienen coordinados. Integramos todo desde EVENTECH con una sola logística y un solo responsable — para que no tengas que cuadrar cinco proveedores ni que nadie se eche la culpa entre ellos el día del evento.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cotización", p: "Agendamos visita sin costo a tu venue para medir el espacio, evaluar el terreno de anclaje y entender tu concepto. En menos de 24 horas te enviamos propuesta con el tamaño de carpa, estilo y complementos ideales para tu número de invitados." },
  { n: 2, t: "Diseño de configuración y aparto", p: "Definimos medidas, estilo (clásica, forros, transparente o beduina), forros, iluminación y piso. Con el 30% de anticipo apartamos la carpa y la fecha — sin pago total por adelantado. Coordinamos con tu wedding planner o el venue si aplica." },
  { n: 3, t: "Montaje, tensado y prueba de seguridad", p: "Nuestro equipo instala 24 a 48 horas antes: anclaje, tensado de lona, cortinas, forros, nivelación y prueba de seguridad final. Todo queda listo y verificado con anticipación para que el día del evento no haya prisas ni ajustes de última hora." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento la carpa protege a tus invitados sin sorpresas. Al finalizar, nuestro equipo desmonta y retira todo. El montaje, la visita técnica y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuántas personas caben en una carpa árabe?", answer: "Depende de la configuración de tu evento. Una carpa árabe de 6x6 metros acomoda 30-40 personas en formato banquete o 50-60 en coctel. Una de 10x20 metros recibe 150-200 personas en banquete. Nuestro equipo diseña la distribución óptima considerando mesas, pista de baile, barra de bebidas y área de ceremonia para maximizar el aforo sin sacrificar comodidad." },
  { question: "¿Las carpas árabes resisten la lluvia?", answer: "Sí. Nuestras carpas árabes utilizan lona PVC impermeable de grado comercial con protección UV al 99%. Los techos tensados están diseñados con pendientes que canalizan el agua de lluvia hacia los laterales, evitando acumulación. Para eventos en temporada de lluvias, reforzamos la instalación con canaletas de desagüe y tensores adicionales. La estructura de aluminio serie 6000 resiste vientos de hasta 60 km/h." },
  { question: "¿Puedo instalar la carpa en cualquier tipo de terreno?", answer: "Sí. Instalamos sobre pasto, tierra, cemento, adoquín y azotea, adaptando el sistema de anclaje a cada superficie: estacas para terreno natural, bases con contrapeso para superficies duras donde no se puede perforar. En la visita técnica evaluamos el terreno y determinamos el método de anclaje más seguro. Para superficies irregulares o con pendiente, nivelamos con estructura ajustable para que el piso quede plano." },
  { question: "¿Puedo combinar carpa árabe con iluminación interior?", answer: "Por supuesto, es lo más recomendado. Las carpas árabes lucen espectaculares con fairy lights en el techo, candiles de cristal colgantes, spots LED direccionables y wash lights de color. Ofrecemos paquetes combo de carpa + iluminación con descuento especial. Nuestro equipo de producción diseña el esquema de luces según el tono de tu evento — romántico, elegante, festivo o temático." },
  { question: "¿Qué diferencia hay entre carpa árabe clásica y con forros?", answer: "La carpa árabe clásica muestra la estructura de aluminio visible con cortinas laterales de chiffon. La versión con forros cubre completamente el interior con tela satinada, chiffon o blackout — paredes, techo y columnas quedan ocultos bajo un acabado textil premium. Los forros transforman radicalmente el ambiente, creando un espacio tipo salón de lujo. La diferencia en precio es aproximadamente un 30-40% adicional." },
  { question: "¿Incluyen montaje y desmontaje?", answer: "Sí. Todos nuestros paquetes de carpas árabes incluyen visita técnica previa gratuita, transporte, montaje profesional por nuestro equipo certificado y desmontaje al finalizar el evento. El montaje se realiza entre 24 y 48 horas antes según el tamaño. Nuestro equipo se encarga de todo: anclaje, tensado de lona, instalación de cortinas, nivelación y prueba de seguridad final." },
  { question: "¿Con cuánta anticipación debo reservar una carpa árabe?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación. En temporada alta (octubre a febrero, temporada de bodas), lo ideal es apartar con 2 meses mínimo. Las carpas de 10x20 y 15x30 metros son las más solicitadas y se agotan primero. Para eventos de última hora, contáctanos y haremos lo posible por atenderte según disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Árabes para Eventos en CDMX",
    description: "Renta de carpas árabes clásicas, con forros, transparentes y beduinas para bodas y eventos en CDMX. Montaje profesional, visita técnica y personalización incluidos.",
    url: "/servicios/carpas/carpas-arabes/",
    priceRange: { min: 3000, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Carpas Árabes", url: "/servicios/carpas/carpas-arabes/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Carpas Árabes" },
];
---

<PageLayout
  title="Renta de Carpas Árabes para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/carpas/carpa-arabe-beduina-boda-jardin.avif"
  description="Renta de carpas árabes para bodas y eventos en CDMX: clásicas, con forros, transparentes y beduinas. Montaje profesional y visita técnica gratis. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="carpas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Carpas árabes · CDMX y ZMVM</p>
            <h1 id="carpas-hero-heading">
              Carpas árabes que transforman <em>un jardín en un venue de lujo</em>
            </h1>
            <p class="hm-hero__lead">
              Techos tensados en pico, cortinas de chiffon y forros premium. Clásica, con
              forros, transparente y beduina — con montaje profesional, visita técnica
              gratuita y personalización total.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20%C3%A1rabe%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar carpa árabe
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>carpas árabes para eventos</strong> en CDMX y zona
              metropolitana con estructura de <strong>aluminio anodizado serie 6000</strong>
              y lona PVC impermeable de 550 g/m² con protección UV. Techos tensados en pico
              de 4 a 6 metros de altura, en cuatro estilos — clásica con cortinas de chiffon,
              con forros tipo salón de lujo, transparente de PVC cristal y beduina temática.
              Cada carpa se dimensiona a partir de una visita técnica al terreno.
            </p>
            <p>
              Con <strong>más de 500 instalaciones</strong> en CDMX, sabemos que una carpa
              es lo único que separa tu evento del clima: por eso cada renta incluye visita
              técnica gratuita, montaje profesional propio y prueba de seguridad. Para un
              montaje integral sumamos <a href="/servicios/mobiliario/">mobiliario</a>,
              <a href="/servicios/iluminacion/">iluminación</a> y
              <a href="/servicios/carpas/pisos-complementos/">pisos y climatización</a> desde
              una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de carpa árabe disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20%C3%A1rabe%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La colección más completa de CDMX</p>
            <h2 id="catalogo-heading">¿Qué carpa árabe necesita tu evento?</h2>
            <p class="hm__head-sub">4 estilos — del jardín romántico con chiffon a la jaima temática de gala.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La carpa no es solo un techo: define la estética completa del evento y decide
              si el jardín se ve improvisado o transformado en un venue. El estilo correcto
              depende del concepto, del paisaje y de si quieres esconder la estructura o
              dejar que el entorno sea parte de la decoración.
            </p>
            <p>
              Clásica para bodas y XV años en jardín. Con forros cuando el interior debe
              verse como un salón de lujo. Transparente cuando el paisaje o el cielo son
              protagonistas. Beduina cuando el evento pide una experiencia temática
              inmersiva. Una sola empresa para toda la carpa de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada estilo, a fondo</p>
            <h2 id="detalle-heading">Los 4 estilos de carpa árabe — en detalle</h2>
            <p class="hm__head-sub">Material, medidas, acabado y para qué tipo de evento funciona mejor cada carpa.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada estilo de carpa hay decisiones que afectan la experiencia del
              evento: el acabado que define si se ve como una lona o como un salón, la
              transparencia que decide cuánto entra el paisaje, y la decoración que marca si
              el espacio cuenta una historia o solo cubre del clima.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada estilo.
            </p>
          </div>
        </div>

        <!-- CLÁSICA -->
        <article class="hm-feat" aria-labelledby="feat-clasica">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Carpa Árabe Clásica</p>
            <h3 class="hm-feat__title" id="feat-clasica">Elegancia atemporal en pico — la favorita de wedding planners para bodas en jardín</h3>
            <p class="hm-feat__lead">Ningún estilo dice "boda de jardín elegante" como la carpa árabe clásica. Sus picos tensados enmarcan la celebración y funcionan igual de bien de día que iluminados de noche.</p>
            <p>
              Techos tensados en pico de <strong>4 a 6 metros de altura</strong>, disponibles
              en <strong>blanco, marfil, beige y champagne</strong>, con cortinas laterales de
              chiffon que permiten ambientes abiertos, semi-cerrados o cerrados según la hora
              y el clima. Desde <strong>6×6 m (30-40 invitados) hasta 15×30 m (400+)</strong>.
            </p>
            <p>
              Estructura de aluminio serie 6000, tensores de acero inoxidable 304 y lona PVC
              de 550 g/m² con protección UV. Ideal para <strong>bodas, XV años, bautizos y
              recepciones</strong> en jardín. Complementa con nuestro
              <a href="/servicios/mobiliario/">mobiliario premium</a> — sillas Tiffany, mesas
              redondas y salas lounge — para un montaje integral perfecto.
            </p>
            <ul class="hm-feat__stats">
              {["6×6 a 15×30 m", "Chiffon 4 colores", "Hasta 400+ pax", "Aluminio 6000", "Lona PVC 550 g"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/carpas-arabes/clasica/">
              Ver Árabe Clásica
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/carpas/carpa-boda-01.avif" alt="Carpa árabe clásica con techo en pico para boda en jardín en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/carpas/carpa-boda-02.avif" alt="Carpa árabe blanca montada para recepción de boda" loading="lazy" decoding="async" />
              <img src="/images/carpas/carpa-boda-03.avif" alt="Interior de carpa árabe clásica con cortinas de chiffon" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- FORROS -->
        <article class="hm-feat" aria-labelledby="feat-forros">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Carpa Árabe con Forros</p>
            <h3 class="hm-feat__title" id="feat-forros">Interior forrado que convierte la carpa en un salón de lujo temporal</h3>
            <p class="hm-feat__lead">La diferencia entre "rentamos una carpa" y "no parece una carpa". El forro cubre toda la estructura y transforma radicalmente el ambiente — nadie adivina que debajo hay aluminio.</p>
            <p>
              El interior se cubre completamente con <strong>tela satinada, chiffon o
              blackout</strong> — paredes, techo y columnas ocultos bajo un acabado textil
              premium. Disponible en <strong>blanco, marfil, champagne, rosa palo, azul
              celeste y dorado</strong>, con posibilidad de combinar tonos para contrastes
              elegantes.
            </p>
            <p>
              Incluye <strong>pliegues decorativos en el techo (drapeado tipo nube)</strong>,
              cenefas perimetrales y amarres con lazos de raso, instalados por nuestro equipo
              con acabado impecable. El resultado es un <strong>venue exclusivo</strong>, no
              una carpa. Combina con <a href="/servicios/iluminacion/">iluminación
              decorativa</a> — fairy lights entre los pliegues crean un cielo estrellado.
            </p>
            <ul class="hm-feat__stats">
              {["Satín / chiffon / blackout", "Drapeado nube", "6+ colores", "Cenefas y lazos", "Aspecto salón"].map((sp) => (<li>{sp}</li>))}
            </ul>
