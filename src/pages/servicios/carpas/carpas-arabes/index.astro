---
/**
 * ─── Carpas Árabes para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Carpas Árabes para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import Gallery4x4 from "@components/Gallery4x4.astro";
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Carpas Árabes" },
];

const TIPOS = [
  {
    name: "Carpa Árabe Clásica",
    price: "Desde $3,000 MXN",
    excerpt: "Techos tensados en pico con cortinas de chiffon blanco y marfil. Disponible de 6x6 m (30 personas) a 10x20 m (200 personas). La favorita para bodas románticas y XV años.",
    href: "/servicios/carpas/carpas-arabes/clasica/",
    image: "/images/carpas/carpa-boda-01.avif",
    tags: ["6x6 a 10x20 m", "Chiffon blanco/marfil", "Hasta 200 personas"],
    badge: "Más solicitada",
  },
  {
    name: "Carpa Árabe con Forros",
    price: "Desde $5,500 MXN",
    excerpt: "Interior completamente forrado en tela satinada o chiffon. Oculta la estructura metálica y crea un espacio tipo salón de lujo. Ideal para galas y bodas premium.",
    href: "/servicios/carpas/carpas-arabes/forros/",
    image: "/images/carpas/forros-interiores-carpa-elegante.avif",
    tags: ["Satín o chiffon", "Aspecto salón de lujo", "Bodas premium"],
  },
  {
    name: "Carpa Árabe Transparente",
    price: "Desde $4,200 MXN",
    excerpt: "Paneles de PVC cristal que permiten ver el jardín y el cielo nocturno. Perfecta para venues con vista o cuando quieres que el paisaje sea parte de la decoración.",
    href: "/servicios/carpas/carpas-arabes/transparente/",
    image: "/images/carpas/carpa-transparente-boda-elegante.avif",
    tags: ["PVC cristal", "Vista 360°", "Eventos nocturnos"],
  },
  {
    name: "Carpa Árabe Beduina",
    price: "Desde $6,000 MXN",
    excerpt: "Jaima inspirada en el norte de África con telas drapeadas y decoración étnica. Para eventos temáticos, cenas de gala y festivales que necesitan un espacio único.",
    href: "/servicios/carpas/carpas-arabes/beduina/",
    image: "/images/carpas/carpa-arabe-beduina-boda-jardin.avif",
    tags: ["Diseño beduino", "Telas drapeadas", "Eventos temáticos"],
    badge: "Exclusiva",
  },
];

const faqs = [
  { question: "¿Cuántas personas caben en una carpa árabe?", answer: "Depende de la configuración de tu evento. Una carpa árabe de 6x6 metros acomoda 30-40 personas en formato banquete o 50-60 en coctel. Una de 10x20 metros recibe 150-200 personas en banquete. Nuestro equipo diseña la distribución óptima considerando mesas, pista de baile, barra de bebidas y área de ceremonia para maximizar el aforo sin sacrificar comodidad." },
  { question: "¿Las carpas árabes resisten la lluvia?", answer: "Sí. Nuestras carpas árabes utilizan lona PVC impermeable de grado comercial con protección UV al 99%. Los techos tensados están diseñados con pendientes que canalizan el agua de lluvia hacia los laterales, evitando acumulación. Para eventos en temporada de lluvias, reforzamos la instalación con canaletas de desagüe y tensores adicionales. La estructura de aluminio serie 6000 resiste vientos de hasta 60 km/h." },
  { question: "¿Puedo combinar carpa árabe con iluminación interior?", answer: "Por supuesto, es lo más recomendado. Las carpas árabes lucen espectaculares con fairy lights en el techo, candiles de cristal colgantes, spots LED direccionables y wash lights de color. Ofrecemos paquetes combo de carpa + iluminación con descuento especial. Nuestro equipo de producción diseña el esquema de luces según el tono de tu evento — romántico, elegante, festivo o temático." },
  { question: "¿Qué diferencia hay entre carpa árabe clásica y con forros?", answer: "La carpa árabe clásica muestra la estructura de aluminio visible con cortinas laterales de chiffon. La versión con forros cubre completamente el interior con tela satinada, chiffon o blackout — paredes, techo y columnas quedan ocultos bajo un acabado textil premium. Los forros transforman radicalmente el ambiente, creando un espacio tipo salón de lujo. La diferencia en precio es aproximadamente un 30-40% adicional." },
  { question: "¿Incluyen montaje y desmontaje?", answer: "Sí. Todos nuestros paquetes de carpas árabes incluyen visita técnica previa gratuita, transporte, montaje profesional por nuestro equipo certificado y desmontaje al finalizar el evento. El montaje se realiza entre 24 y 48 horas antes según el tamaño. Nuestro equipo se encarga de todo: anclaje, tensado de lona, instalación de cortinas, nivelación y prueba de seguridad final." },
  { question: "¿Con cuánta anticipación debo reservar una carpa árabe?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación. En temporada alta (octubre a febrero, temporada de bodas), lo ideal es apartar con 2 meses mínimo. Las carpas de 10x20 y 15x30 metros son las más solicitadas y se agotan primero. Para eventos de última hora, contáctanos y haremos lo posible por atenderte según disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Árabes para Eventos en CDMX",
    description: "Carpas árabes clásicas, con forros, transparentes y beduinas para bodas y eventos. Montaje profesional e iluminación incluidos.",
    url: "/servicios/carpas/carpas-arabes/",
    priceRange: { min: 3000, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Carpas Árabes", url: "/servicios/carpas/carpas-arabes/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpas Árabes para Eventos en CDMX"
  description="Renta de carpas árabes para bodas y eventos en CDMX. Clásicas, con forros, transparentes y beduinas. Montaje profesional incluido. Desde $3,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La favorita para bodas y XV años"
    title='Renta de <span class="highlight">Carpas Árabes</span> para Eventos en CDMX'
    subtitle="Carpas árabes con techos tensados en pico, cortinas de chiffon y forros premium. La opción más elegante para transformar jardines, terrazas y espacios abiertos en venues románticos y sofisticados."
    primaryCTA={{ label: "Cotiza tu carpa árabe", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa árabe para mi evento` }}
    cards={[
      {
        title: "Elegancia clásica con estructura certificada de grado comercial",
        content: "<strong>Renta de carpas árabes para eventos</strong> fabricadas con los más altos estándares de calidad. Estructura de <strong>aluminio anodizado serie 6000</strong> con lona PVC impermeable de 550 g/m² y protección UV al 99%. Techos tensados en pico que alcanzan alturas de <strong>4 a 6 metros</strong>, creando un efecto visual espectacular. Cortinas laterales de chiffon, satín o blackout disponibles en <strong>blanco, marfil, beige, champagne y colores personalizados</strong>. Cada carpa incluye tensores de acero inoxidable 304 y sistema de anclaje profesional adaptado al terreno de tu venue.",
      },
      {
        title: "Personalización total con forros, iluminación y complementos",
        content: "<strong>Servicio completo de carpas árabes</strong> con opciones de personalización ilimitadas. Forros interiores de tela satinada o chiffon que ocultan completamente la estructura metálica, creando un espacio tipo salón de lujo. Complementa con <strong>iluminación LED interior</strong> — fairy lights, candiles de cristal, spots direccionables — y opciones de <strong>piso de duela o alfombra</strong>, cortinas decorativas y clima artificial. Visita técnica gratuita a tu venue para diseñar la configuración perfecta según el tamaño del espacio y número de invitados.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la carpa perfecta para tu boda o evento especial?"
    subheadline="Recibe una propuesta personalizada con el tamaño, estilo y complementos ideales para tu celebración — sin compromiso"
    primaryCTA={{ label: "Cotizar mi carpa árabe", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de carpa árabe
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Tipos de Carpas Árabes"
        subtitle="La elegancia perfecta para cada estilo de evento"
        description={[
          "Desde la carpa árabe clásica con cortinas de chiffon hasta la beduina temática con telas drapeadas — contamos con la colección más completa de carpas árabes para eventos en la Ciudad de México y zona metropolitana.",
          "Cada carpa incluye montaje profesional certificado, lona impermeable de grado comercial y opciones de personalización completa con forros, iluminación, piso y climatización."
        ]}
      />

      <div class="grid grid--4">
        {TIPOS.map((tipo) => (
          <ProductCard
            name={tipo.name}
            price={tipo.price}
            excerpt={tipo.excerpt}
            href={tipo.href}
            image={tipo.image}
            tags={tipo.tags}
            badge={tipo.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPA ÁRABE CLÁSICA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="clasica-heading">
    <div class="container">
      <ServiceShowcase
    title="Carpa Árabe Clásica"
    headingId="clasica-heading"
    badge="La más solicitada para bodas"
    subtitle="Elegancia atemporal con techos tensados en pico y cortinas de chiffon para eventos sociales inolvidables."
    tags={["6x6m", "6x12m", "10x20m", "15x30m", "Chiffon Blanco", "400+ Invitados"]}
    ctaHref="/servicios/carpas/carpas-arabes/clasica/"
    ctaLabel="Ver Árabe Clásica"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>carpa árabe clásica</strong> es la opción preferida por wedding planners y organizadores de eventos en CDMX. Sus <strong>techos tensados en pico</strong> alcanzan alturas de 4 a 6 metros, creando un efecto visual majestuoso que enmarca cualquier celebración. Disponible en <strong>blanco, marfil, beige y champagne</strong>, con cortinas laterales de chiffon que permiten crear ambientes abiertos, semi-cerrados o completamente cerrados según la hora del día y las condiciones climáticas.</p>
      <p class="showcase__text">Disponibles desde <strong>6x6 metros (30-40 invitados) hasta 15x30 metros (400+ invitados)</strong>. Estructura de aluminio serie 6000, tensores de acero inoxidable 304 y lona PVC de 550 g/m² con protección UV. Ideal para <strong>bodas, XV años, bautizos y recepciones</strong> en jardines. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> — sillas Tiffany, mesas redondas y salas lounge — para un montaje integral perfecto.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l9-16 9 16"/>
              <path d="M7.5 20l4.5-8 4.5 8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPA ÁRABE CON FORROS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="forros-heading">
    <div class="container">
      <ServiceShowcase
    title="Carpa Árabe con Forros"
    headingId="forros-heading"
    badge="Acabado tipo salón de lujo"
    subtitle="Interior completamente forrado en tela premium que oculta la estructura metálica y transforma radicalmente el espacio."
    tags={["Satín Premium", "Chiffon", "Blackout", "Drapeado Nube", "10+ Colores"]}
    ctaHref="/servicios/carpas/carpas-arabes/forros/"
    ctaLabel="Ver Carpa con Forros"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>carpa árabe con forros</strong> lleva la elegancia al siguiente nivel. El interior se cubre completamente con <strong>tela satinada, chiffon o blackout</strong> — paredes, techo y columnas quedan ocultos bajo un acabado textil premium que transforma la carpa en un salón de lujo temporal. Disponible en colores <strong>blanco, marfil, champagne, rosa palo, azul celeste y dorado</strong>, con posibilidad de combinar tonos para crear contrastes elegantes.</p>
      <p class="showcase__text">El forrado incluye <strong>pliegues decorativos en el techo (drapeado tipo nube)</strong>, cenefas perimetrales y amarres con lazos de raso. Cada metro cuadrado de forro es instalado por nuestro equipo especializado con acabado impecable. El resultado es un espacio completamente personalizado que no parece una carpa sino un <strong>venue exclusivo</strong>. Combina con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> — fairy lights entre los pliegues del techo crean un efecto de cielo estrellado espectacular.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPA ÁRABE TRANSPARENTE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="transparente-heading">
    <div class="container">
      <ServiceShowcase
    title="Carpa Árabe Transparente"
    headingId="transparente-heading"
    badge="Vista panorámica 360°"
    subtitle="Paneles de PVC cristal que permiten disfrutar del paisaje, la puesta de sol y las estrellas sin sacrificar protección."
    tags={["PVC Cristal 0.5mm", "100% Transparente", "Configuración Híbrida", "Impermeable", "Vista 360°"]}
    ctaHref="/servicios/carpas/carpas-arabes/transparente/"
    ctaLabel="Ver Árabe Transparente"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>carpa árabe transparente</strong> combina la silueta elegante de la carpa árabe con <strong>paneles laterales y techo de PVC cristal de alta transparencia</strong>. El resultado es un espacio protegido que permite disfrutar del entorno — jardín, montaña, lago o ciudad — con visibilidad de 360°. Perfecta para <strong>eventos al atardecer, cenas bajo las estrellas y venues con paisaje espectacular</strong> en Cuernavaca, Valle de Bravo, Tepoztlán y zonas boscosas del sur de CDMX.</p>
      <p class="showcase__text">El PVC cristal de <strong>0.5 mm de espesor</strong> es impermeable, resistente al viento y mantiene la temperatura interior. Disponible en configuración <strong>100% transparente o híbrida</strong> (techo transparente con laterales de lona blanca o viceversa). Incluye <strong>cortinas de chiffon desmontables</strong> para ajustar privacidad y decoración. Combina con <a href="/servicios/carpas/">pisos de duela</a> y calefacción para eventos de invierno con vista panorámica completa.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M3 9h18"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPA ÁRABE BEDUINA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="beduina-heading">
    <div class="container">
      <ServiceShowcase
    title="Carpa Árabe Beduina"
    headingId="beduina-heading"
    badge="Experiencia temática única"
    subtitle="Diseño inspirado en las jaimas del norte de África con telas drapeadas y decoración étnica para eventos temáticos memorables."
    tags={["Estilo Jaima", "Telas Drapeadas", "Decoración Incluida", "Lámparas Marroquí", "Temática Completa"]}
    ctaHref="/servicios/carpas/carpas-arabes/beduina/"
    ctaLabel="Ver Árabe Beduina"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>carpa árabe beduina</strong> transporta a tus invitados a un escenario de <strong>Las Mil y Una Noches</strong>. Telas drapeadas en tonos <strong>terracota, dorado, borgoña y arena</strong>, cojines decorativos, lámparas de latón marroquí y detalles textiles artesanales crean una atmósfera envolvente y exótica. Perfecta para <strong>cenas de gala temáticas, despedidas de soltero/a, festivales culturales y eventos de lujo con concepto oriental</strong>.</p>
      <p class="showcase__text">Disponible en configuraciones de <strong>6x6 hasta 12x18 metros</strong> con áreas diferenciadas: zona de recepción con cojines de piso, área de banquete con mesas bajas o estándar, y lounge con pufs y cortinas divisorias. Incluye <strong>decoración temática completa</strong> — lámparas, telas, alfombras y elementos ornamentales. Complementa con <a href="/servicios/accesorios/">mantelería premium</a> y elementos de señalización temática para una experiencia inmersiva completa.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M5 20c0-8 2.5-14 7-14s7 6 7 14"/>
              <path d="M12 6V2"/>
              <path d="M10 10c0-2 1-4 2-4s2 2 2 4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo lucen nuestras carpas árabes?</h2>
      <Gallery4x4 images={[
        { src: "/images/carpas/carpa-arabe-beduina-boda-jardin.avif", alt: "Carpa árabe beduina para boda en jardín" },
        { src: "/images/carpas/carpa-estructural-grande-congreso.avif", alt: "Carpa estructural grande para congreso" },
        { src: "/images/carpas/carpa-hangar-industrial-evento-grande.avif", alt: "Carpa hangar industrial evento grande" },
        { src: "/images/carpas/carpa-mediana-quinceanos-decorada.avif", alt: "Carpa mediana quinceaños decorada" },
        { src: "/images/carpas/carpa-transparente-boda-elegante.avif", alt: "Carpa transparente boda elegante" },
        { src: "/images/carpas/forros-interiores-carpa-elegante.avif", alt: "Forros interiores carpa elegante" },
        { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Silla Tiffany dorada para boda de gala en CDMX" },
        { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas montaje banquete" },
      ]} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar carpas árabes?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por evento (+IVA). Incluye entrega y montaje en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$5,000",
          priceNote: "por evento",
          description: "Carpa árabe para eventos íntimos.",
          features: [
            { text: "Carpa 4x4m", included: true },
            { text: "Estructura y montaje", included: true },
            { text: "Forros interiores", included: false },
            { text: "Iluminación", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Estándar",
          badge: "Más popular",
          highlight: true,
          price: "$10,000",
          priceNote: "por evento",
          description: "Carpa árabe decorada para bodas.",
          features: [
            { text: "Carpa 6x6m", included: true },
            { text: "Forros interiores", included: true },
            { text: "Iluminación básica", included: true },
            { text: "Montaje profesional", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Premium",
          price: "$18,000",
          priceNote: "por evento",
          description: "Carpa árabe de lujo con decoración completa.",
          features: [
            { text: "Carpa 8x8m o mayor", included: true },
