              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Bautizo / Primera Comunión">Bautizo / Primera Comunión</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Cena de Gala">Cena de Gala</option>
                <option value="Festival / Temático">Festival / Temático</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoCarpa">
                Tipo de carpa árabe
              </label>
              <select id="tipoCarpa" name="tipoCarpa" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de carpa</option>
                <option value="Árabe Clásica Blanca">Árabe Clásica Blanca</option>
                <option value="Árabe Clásica Marfil">Árabe Clásica Marfil</option>
                <option value="Árabe con Forros Satín">Árabe con Forros Satín</option>
                <option value="Árabe con Forros Chiffon">Árabe con Forros Chiffon</option>
                <option value="Árabe Transparente">Árabe Transparente</option>
                <option value="Árabe Transparente Híbrida">Árabe Transparente Híbrida</option>
                <option value="Árabe Beduina Temática">Árabe Beduina Temática</option>
                <option value="Carpa + Iluminación">Paquete Carpa + Iluminación</option>
                <option value="Carpa + Piso + Iluminación">Paquete Completo (Carpa + Piso + Iluminación)</option>
                <option value="Otro">Otro / No estoy seguro</option>
