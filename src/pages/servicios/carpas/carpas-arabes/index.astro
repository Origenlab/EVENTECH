    primaryCTA={{ label: "Cotizar carpa árabe", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una carpa árabe para mi evento` }}
    variant="accent"
  />
</PageLayout>

