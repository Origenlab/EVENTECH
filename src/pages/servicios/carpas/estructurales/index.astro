---
/**
 * ─── EVENTECH.MX — Renta de Carpas Estructurales para Eventos (Hub L4, molde hm- 2026) ───
 * Medianas · Grandes · Paredes Modulares · Accesorios — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/carpas — estructural-grande, mediana reales; carpa-boda-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "medianas",
    name: "Estructural Mediana",
    badge: "La más versátil",
    excerpt: "Aluminio serie 6000 con lona PVC de 650 g/m², de 5×5 a 10×10 m para 50 a 100 personas. Paredes modulares intercambiables incluidas. Ideal para bodas íntimas, cócteles y terrazas.",
    href: "/servicios/carpas/estructurales/medianas/",
    image: "/images/carpas/carpa-mediana-quinceanos-decorada.avif",
    specs: ["5×5 a 10×10 m", "50–100 pax", "Aluminio serie 6000", "Lona PVC 650 g"],
  },
  {
    id: "grandes",
    name: "Estructural Grande",
    badge: "Gran formato",
    excerpt: "De 10×15 a 15×30 m para 150 a 400+ invitados. Aluminio reforzado certificado para vientos de 80 km/h. Ideal para bodas grandes, corporativos y ferias.",
    href: "/servicios/carpas/estructurales/grandes/",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    specs: ["10×15 a 15×30 m", "150–400+ pax", "Cert. 80 km/h", "Módulos unibles"],
  },
  {
    id: "paredes-modulares",
    name: "Paredes Modulares",
    badge: "Control total",
    excerpt: "Paneles intercambiables: sólidos, con ventana, PVC cristal transparente y tipo malla. Combínalos para controlar clima, privacidad y estética en cada lado de la carpa.",
    href: "/servicios/carpas/estructurales/paredes-modulares/",
    image: "/images/carpas/carpa-transparente-boda-elegante.avif",
    specs: ["Sólido / ventana / cristal", "Malla ventilación", "Intercambiables", "Termoselladas"],
  },
  {
    id: "accesorios-estructurales",
    name: "Accesorios Estructurales",
    badge: "Todo para completar",
    excerpt: "Drenaje integrado, pisos nivelados, climatización, iluminación LED y canales de cableado eléctrico trifásico. Todo lo que la estructura necesita para quedar lista.",
    href: "/servicios/carpas/estructurales/accesorios-estructurales/",
    image: "/images/carpas/carpa-boda-02.avif",
    specs: ["Drenaje integrado", "Eléctrica trifásica", "Pisos nivelados", "Climatización"],
  },
];

const whyFeatures = [
  {
    title: "Visita técnica y cálculo de estructura",
    body: "Antes de cotizar medimos el terreno, la superficie disponible y las condiciones de viento y drenaje. Una carpa estructural se dimensiona con números, no con estimados: definimos el tamaño de marco, el tipo de anclaje y las uniones de módulos según tu venue real — no según un aproximado por teléfono.",
  },
  {
    title: "Aluminio serie 6000 y lona PVC certificada",
    body: "Marcos de aluminio anodizado serie 6000 y lona PVC de 650 g/m² con protección UV y costuras termoselladas. Material de grado comercial, no de segunda mano: la estructura que se levanta sobre tus invitados soporta cargas reales y se revisa pieza por pieza antes de cada montaje.",
  },
  {
    title: "Anclaje profesional según el terreno",
    body: "Estacas para tierra y pasto, lastre de agua o placas de concreto para superficies duras donde no se puede perforar. El sistema de anclaje se elige según lo que encontramos en la visita técnica, con cálculo de resistencia al viento — para que la carpa esté fija y segura sin importar la superficie.",
  },
  {
    title: "Impermeable con drenaje en cada unión",
    body: "Lona termoseellada impermeable, canaletas de drenaje en las uniones de módulos y refuerzos en los puntos de tensión. En temporada de lluvias sumamos paredes laterales y desagües adicionales. Tu evento no depende del pronóstico: la estructura protege a todos de sol, lluvia y viento.",
  },
  {
    title: "Montaje propio con prueba de seguridad",
    body: "Equipo de montaje propio (no subcontratado) que instala con anticipación: armado del marco, tensado de lona, anclaje, nivelación y prueba de seguridad final. Llegamos con tiempo de sobra para que el día del evento la carpa ya esté levantada, verificada y lista.",
  },
  {
    title: "Modular: se une, se amplía y se personaliza",
    body: "La estructura crece contigo: unimos módulos para alcanzar mayor superficie, intercambiamos paredes según clima y estética, y sumamos piso, iluminación y climatización. Una sola carpa base se adapta a un cóctel de 50 o a una feria de 400 — todo coordinado desde una sola empresa.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cotización", p: "Agendamos visita sin costo para medir el terreno, evaluar el anclaje y el drenaje, y entender el tipo de evento. En menos de 24 horas te enviamos propuesta con el tamaño de estructura, paredes y accesorios ideales para tu número de invitados." },
  { n: 2, t: "Diseño de configuración y aparto", p: "Definimos medidas, unión de módulos, tipo de paredes (sólidas, ventana, cristal o malla), piso, iluminación y climatización. Con el 30% de anticipo apartamos la carpa y la fecha. Coordinamos con tu wedding planner o el venue si aplica." },
  { n: 3, t: "Montaje, anclaje y prueba de seguridad", p: "Nuestro equipo instala con anticipación: armado del marco de aluminio, tensado de lona, anclaje según el terreno, nivelación de piso y prueba de seguridad. Todo queda verificado antes del evento para que no haya ajustes de última hora." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento la estructura protege a tus invitados con seguridad certificada. Al finalizar, nuestro equipo desmonta y retira todo. La visita técnica, el montaje y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tamaños de carpas estructurales tienen disponibles?", answer: "Contamos con carpas estructurales desde 5x5 metros (25 m²) hasta 15x30 metros (450 m²) y configuraciones modulares de hasta 20x40 metros. Las medidas más solicitadas son 6x12, 10x10, 10x15 y 10x20 metros. Todas las carpas utilizan marcos de aluminio serie 6000 anodizado y lonas PVC de 650 g/m² con protección UV. Podemos unir módulos para crear superficies aún mayores según las necesidades de tu evento." },
  { question: "¿Puedo unir varias carpas para más superficie?", answer: "Sí. Las carpas estructurales son modulares y se unen entre sí mediante canaletas de conexión termoselladas, creando una sola superficie continua sin columnas intermedias en el punto de unión. Podemos combinar módulos para pasar de 10x10 a 10x20, 10x30 o configuraciones en L y T según la forma de tu terreno. La unión es completamente impermeable, con canaleta de drenaje integrada. En la visita técnica diseñamos la configuración modular óptima para tu espacio y número de invitados." },
  { question: "¿Las carpas estructurales resisten lluvia y viento?", answer: "Sí, nuestras carpas estructurales están diseñadas para condiciones climáticas adversas. Los marcos de aluminio reforzado soportan vientos de hasta 80 km/h con anclaje profesional (lastre de agua, estacas o placas de concreto según el terreno). Las lonas PVC de 650 g/m² son impermeables con costuras termoselladas que impiden filtraciones. Incluimos canaletas de drenaje en uniones de módulos y refuerzos adicionales en puntos de tensión. Para eventos en temporada de lluvias, recomendamos añadir paredes laterales para protección completa." },
  { question: "¿Ofrecen carpas con paredes transparentes?", answer: "Sí, contamos con tres tipos de paredes transparentes: paneles de PVC cristal completamente transparentes que permiten visibilidad total del entorno, paredes con ventanas (secciones transparentes en pared sólida blanca) para iluminación natural parcial, y paredes tipo malla que permiten ventilación manteniendo protección visual. Las paredes transparentes son ideales para eventos en jardines donde quieres disfrutar del paisaje con protección climática. Todas las paredes son modulares e intercambiables, puedes combinar tipos según cada lado de la carpa." },
  { question: "¿Las carpas estructurales incluyen piso?", answer: "El piso no está incluido por defecto, pero ofrecemos sistemas de piso profesional como complemento: piso de madera nivelado sobre estructura metálica (ideal para terrenos irregulares o jardines), piso tipo deck para exteriores, y alfombra sobre base rígida para acabado elegante. El sistema de piso incluye nivelación láser, rampa de acceso y puede cubrir toda la superficie de la carpa o zonas específicas como pista de baile o área de mesas. Recomendamos piso para eventos formales, terrenos con desnivel o temporada de lluvias." },
  { question: "¿Pueden instalar electricidad dentro de la carpa?", answer: "Sí, ofrecemos instalación eléctrica profesional como complemento. Incluye tablero de distribución con protección térmica y diferencial, canalización oculta de cables, tomas de corriente distribuidas estratégicamente, e iluminación interior (LED colgante, rieles o spots). Para eventos con requerimientos de alto consumo (equipos de audio, cocina, climatización) instalamos alimentación trifásica con generador de respaldo. Todo el cableado cumple normas NOM de seguridad eléctrica y es supervisado por un electricista certificado." },
  { question: "¿Con cuánta anticipación debo reservar una carpa estructural?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (octubre a febrero y Semana Santa). Las carpas de 10x15 y 10x20 son las más solicitadas y se agotan primero. Para eventos con configuraciones especiales (unión de módulos, pisos, climatización) lo ideal es apartar con 2 meses de anticipación para garantizar disponibilidad y tiempo de planeación logística. También atendemos solicitudes de último momento sujetas a inventario disponible." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Estructurales para Eventos en CDMX",
    description: "Renta de carpas estructurales de aluminio con lona PVC para bodas, corporativos y ferias en CDMX. De 5×5 a 15×30 m, anclaje certificado y montaje profesional.",
    url: "/servicios/carpas/estructurales/",
    priceRange: { min: 5000, max: 80000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Estructurales", url: "/servicios/carpas/estructurales/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Estructurales" },
];
---

<PageLayout
  title="Renta de Carpas Estructurales para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/carpas/carpa-estructural-grande-congreso.avif"
  description="Renta de carpas estructurales de aluminio con lona PVC en CDMX: de 5×5 a 15×30 m, anclaje certificado y montaje profesional. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="estructurales-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Carpas estructurales · CDMX y ZMVM</p>
            <h1 id="estructurales-hero-heading">
              Carpas estructurales que cubren <em>de 50 a 400+ invitados</em> con seguridad certificada
            </h1>
            <p class="hm-hero__lead">
              Aluminio serie 6000, lona PVC de 650 g/m² y anclaje profesional certificado para
              vientos de 80 km/h. Medianas, grandes, paredes modulares y accesorios — con
              visita técnica gratuita y montaje incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20estructural%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar carpa estructural
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>carpas estructurales para eventos</strong> en CDMX y zona
              metropolitana con marcos de <strong>aluminio anodizado serie 6000</strong> y lona
              PVC de 650 g/m² con protección UV y costuras termoselladas. Desde
              <strong>5×5 m (50 personas) hasta 15×30 m (400+)</strong> y configuraciones
              modulares que se unen sin columnas intermedias. Cada estructura se dimensiona a
              partir de una visita técnica al terreno, con cálculo de anclaje y drenaje.
            </p>
            <p>
              Con <strong>más de 500 instalaciones</strong> en CDMX, sabemos que una carpa
              estructural es una obra temporal que carga peso y resiste viento: por eso cada
              renta incluye visita técnica gratuita, anclaje profesional certificado y prueba
              de seguridad. Para un montaje integral sumamos
              <a href="/servicios/carpas/pisos-complementos/">pisos, climatización</a>,
              <a href="/servicios/mobiliario/">mobiliario</a> e
              <a href="/servicios/iluminacion/">iluminación</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de carpa estructural disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20carpa%20estructural%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La solución más completa de CDMX</p>
            <h2 id="catalogo-heading">¿Qué carpa estructural necesita tu evento?</h2>
            <p class="hm__head-sub">Del cóctel de 50 a la feria de 400+ — con la estructura, las paredes y los accesorios correctos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La carpa estructural es la que convierte un terreno vacío en un venue seguro:
              soporta peso, resiste viento y protege del clima sin columnas que estorben. La
              elección correcta no es solo tamaño — es el marco, el anclaje al terreno y las
              paredes que definen si el espacio se ventila, se cierra o deja ver el paisaje.
            </p>
            <p>
              Mediana para bodas íntimas y terrazas. Grande para eventos masivos y ferias.
              Paredes modulares para controlar clima y privacidad. Accesorios para dejar la
              estructura completa con piso, luz y electricidad. Una sola empresa para toda la
              carpa de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones estructurales — en detalle</h2>
            <p class="hm__head-sub">Medidas, materiales, capacidad y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada carpa estructural hay decisiones que afectan la seguridad y la
              experiencia: el tamaño de marco que determina cuánta gente cabe sin columnas,
              el tipo de pared que decide clima y privacidad, y el anclaje que marca la
              resistencia real al viento.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- MEDIANAS -->
        <article class="hm-feat" aria-labelledby="feat-medianas">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Estructural Mediana</p>
            <h3 class="hm-feat__title" id="feat-medianas">La estructura versátil para bodas íntimas, cócteles y terrazas de 50 a 100 personas</h3>
            <p class="hm-feat__lead">El punto dulce entre presencia y practicidad. Suficiente estructura para verse formal, suficientemente ágil para caber en una terraza o un jardín mediano sin dominar el espacio.</p>
            <p>
              Marco de <strong>aluminio serie 6000</strong> y lona PVC de 650 g/m², en medidas
              de <strong>5×5 a 10×10 metros</strong> para 50 a 100 personas en banquete. Incluye
              paredes modulares intercambiables que permiten abrir o cerrar la carpa según la
              hora y el clima. Sin columnas interiores: la superficie completa es aprovechable.
            </p>
            <p>
              Ideal para <strong>bodas íntimas, cócteles, XV años, terrazas y jardines
              medianos</strong>. Se instala en pocas horas y se puede unir a otro módulo si el
              evento crece. Complementa con nuestro
              <a href="/servicios/mobiliario/">mobiliario premium</a> — sillas, mesas y salas
              lounge — para un montaje integral perfecto.
            </p>
            <ul class="hm-feat__stats">
              {["5×5 a 10×10 m", "50–100 pax", "Aluminio serie 6000", "Lona PVC 650 g", "Paredes incluidas"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/carpas/estructurales/medianas/">
              Ver Estructural Mediana
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/carpas/carpa-mediana-quinceanos-decorada.avif" alt="Carpa estructural mediana decorada para evento social en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/carpas/carpa-boda-01.avif" alt="Carpa estructural mediana montada en jardín para boda" loading="lazy" decoding="async" />
              <img src="/images/carpas/carpa-boda-03.avif" alt="Interior de carpa estructural mediana para cóctel" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- GRANDES -->
        <article class="hm-feat" aria-labelledby="feat-grandes">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Estructural Grande</p>
            <h3 class="hm-feat__title" id="feat-grandes">Gran formato de hasta 15×30 m para bodas masivas, corporativos y ferias</h3>
            <p class="hm-feat__lead">Cuando el evento es grande, la estructura tiene que serlo sin llenarse de columnas. La carpa grande cubre cientos de invitados con un solo espacio limpio y seguro.</p>
            <p>
              De <strong>10×15 a 15×30 metros</strong> para <strong>150 a 400+ invitados</strong>,
              con aluminio reforzado <strong>certificado para vientos de 80 km/h</strong> y
              anclaje profesional según el terreno. Los módulos se unen entre sí para alcanzar
