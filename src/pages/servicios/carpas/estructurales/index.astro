---
/**
 * ─── Carpas Estructurales para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Carpas Estructurales para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const ESTRUCTURALES = [
  {
    name: "Carpas 5x5 a 10x10",
    excerpt: "Carpas estructurales de aluminio serie 6000 con lona PVC de 650 g/m². Ideales para eventos de 50 a 100 personas: bodas íntimas, cócteles, jardines y terrazas.",
    cta: "Medianas",
    href: "#medianas-heading",
    icon: "tent",
  },
  {
    name: "Carpas 10x15 a 15x30",
    excerpt: "Estructuras de gran formato para 150 a 400+ invitados. Marcos de aluminio reforzado con certificación de viento y anclaje profesional para eventos corporativos y bodas grandes.",
    cta: "Grandes",
    href: "#grandes-heading",
    icon: "package",
  },
  {
    name: "Paredes Modulares",
    excerpt: "Sistema de paredes intercambiables: sólidas, con ventana, transparentes y tipo malla. Configura tu carpa según clima, privacidad y estética de tu evento.",
    cta: "Paredes",
    href: "#paredes-heading",
    icon: "layers",
  },
  {
    name: "Accesorios Estructurales",
    excerpt: "Complementos profesionales para carpas: sistemas de drenaje, pisos nivelados, climatización, iluminación integrada y canales de cableado eléctrico.",
    cta: "Accesorios",
    href: "#accesorios-heading",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Qué tamaños de carpas estructurales tienen disponibles?", answer: "Contamos con carpas estructurales desde 5x5 metros (25 m²) hasta 15x30 metros (450 m²) y configuraciones modulares de hasta 20x40 metros. Las medidas más solicitadas son 6x12, 10x10, 10x15 y 10x20 metros. Todas las carpas utilizan marcos de aluminio serie 6000 anodizado y lonas PVC de 650 g/m² con protección UV. Podemos unir módulos para crear superficies aún mayores según las necesidades de tu evento." },
  { question: "¿Las carpas estructurales resisten lluvia y viento?", answer: "Sí, nuestras carpas estructurales están diseñadas para condiciones climáticas adversas. Los marcos de aluminio reforzado soportan vientos de hasta 80 km/h con anclaje profesional (lastre de agua, estacas o placas de concreto según el terreno). Las lonas PVC de 650 g/m² son impermeables con costuras termoselladas que impiden filtraciones. Incluimos canaletas de drenaje en uniones de módulos y refuerzos adicionales en puntos de tensión. Para eventos en temporada de lluvias, recomendamos añadir paredes laterales para protección completa." },
  { question: "¿Ofrecen carpas con paredes transparentes?", answer: "Sí, contamos con tres tipos de paredes transparentes: paneles de PVC cristal completamente transparentes que permiten visibilidad total del entorno, paredes con ventanas (secciones transparentes en pared sólida blanca) para iluminación natural parcial, y paredes tipo malla que permiten ventilación manteniendo protección visual. Las paredes transparentes son ideales para eventos en jardines donde quieres disfrutar del paisaje con protección climática. Todas las paredes son modulares e intercambiables, puedes combinar tipos según cada lado de la carpa." },
  { question: "¿Las carpas estructurales incluyen piso?", answer: "El piso no está incluido por defecto, pero ofrecemos sistemas de piso profesional como complemento: piso de madera nivelado sobre estructura metálica (ideal para terrenos irregulares o jardines), piso tipo deck para exteriores, y alfombra sobre base rígida para acabado elegante. El sistema de piso incluye nivelación láser, rampa de acceso y puede cubrir toda la superficie de la carpa o zonas específicas como pista de baile o área de mesas. Recomendamos piso para eventos formales, terrenos con desnivel o temporada de lluvias." },
  { question: "¿Con cuánta anticipación debo reservar una carpa estructural?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (octubre a febrero y Semana Santa). Las carpas de 10x15 y 10x20 son las más solicitadas y se agotan primero. Para eventos con configuraciones especiales (unión de módulos, pisos, climatización) lo ideal es apartar con 2 meses de anticipación para garantizar disponibilidad y tiempo de planeación logística. También atendemos solicitudes de último momento sujetas a inventario disponible." },
  { question: "¿Pueden instalar electricidad dentro de la carpa?", answer: "Sí, ofrecemos instalación eléctrica profesional como complemento. Incluye tablero de distribución con protección térmica y diferencial, canalización oculta de cables, tomas de corriente distribuidas estratégicamente, e iluminación interior (LED colgante, rieles o spots). Para eventos con requerimientos de alto consumo (equipos de audio, cocina, climatización) instalamos alimentación trifásica con generador de respaldo. Todo el cableado cumple normas NOM de seguridad eléctrica y es supervisado por un electricista certificado." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Carpas Estructurales para Eventos en CDMX",
    description: "Carpas estructurales de aluminio con lona PVC para bodas, corporativos y festivales. Desde 5x5 hasta 15x30 metros. Instalación profesional incluida.",
    url: "/servicios/carpas/estructurales/",
    priceRange: { min: 5000, max: 80000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Estructurales", url: "/servicios/carpas/estructurales/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Carpas Estructurales para Eventos en CDMX"
  description="Renta de carpas estructurales de aluminio de 5x5 a 15x30 metros para eventos en CDMX. Lona PVC impermeable, paredes modulares y piso opcional. Desde $5,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Estructura profesional para cualquier evento"
    title='Renta de <span class="highlight">Carpas Estructurales</span> para Eventos en CDMX'
    subtitle="Carpas estructurales de aluminio serie 6000 con lona PVC impermeable desde 5x5 hasta 15x30 metros. Paredes modulares, piso opcional e instalación profesional incluida en cada renta."
    primaryCTA={{ label: "Cotiza tu carpa", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar carpas estructurales para mi evento` }}
    cards={[
      {
        title: "Carpas estructurales de grado profesional para cada evento",
        content: "<strong>Renta de carpas estructurales para eventos</strong> con la ingeniería más robusta disponible en CDMX. Marcos de aluminio serie 6000 anodizado con uniones de acero inoxidable y lonas PVC de 650 g/m² con protección UV y costuras termoselladas. Desde carpas de 5x5 metros para cócteles íntimos de 50 personas hasta estructuras modulares de 15x30 metros para bodas y corporativos de 400+ invitados. Certificadas para vientos de hasta 80 km/h con sistema de anclaje profesional adaptable a cualquier terreno — cada estructura inspeccionada y verificada antes de cada montaje.",
      },
      {
        title: "Instalación profesional con equipo técnico dedicado",
        content: "<strong>Servicio de montaje completo</strong> incluido en cada renta de carpa estructural. Nuestro equipo de instaladores certificados se encarga del transporte, nivelación del terreno, montaje de marcos y lonas, instalación de paredes modulares, sistema de drenaje y pruebas de tensión. Supervisión de ingeniero estructural en configuraciones de gran formato. Tiempo de montaje de 4 a 12 horas según dimensión. Desmontaje y recolección incluidos sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas cubrir tu evento al aire libre?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con la carpa estructural ideal para tu espacio y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de carpa estructural
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Carpas Estructurales"
        subtitle="La estructura perfecta para cada tipo de evento"
        description={[
          "Desde carpas medianas para reuniones íntimas hasta estructuras de gran formato para bodas, corporativos y festivales. Contamos con el inventario de carpas estructurales más completo de la Ciudad de México.",
          "Cada carpa incluye marcos de aluminio certificado, lona PVC impermeable, sistema de anclaje profesional y equipo de montaje dedicado. Paredes modulares y piso opcional para una configuración a tu medida."
        ]}
      />

      <div class="grid grid--4">
        {ESTRUCTURALES.map((carpa) => (
          <Card
            name={carpa.name}
            excerpt={carpa.excerpt}
            cta={carpa.cta}
            href={carpa.href}
            icon={carpa.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS MEDIANAS 5x5 a 10x10 — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="medianas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Versátiles y resistentes</span>
          <h2 class="showcase__title" id="medianas-heading">Carpas Medianas 5x5 a 10x10</h2>
          <p class="showcase__subtitle">La solución ideal para eventos de 50 a 100 personas en jardines, terrazas y espacios al aire libre.</p>
          <p class="showcase__text">Nuestras <strong>carpas estructurales medianas</strong> están disponibles en 4 configuraciones: <strong>5x5, 6x6, 6x12 y 10x10 metros</strong> con marco de aluminio serie 6000 anodizado resistente a corrosión. La lona PVC de 650 g/m² con protección UV y costuras termoselladas garantiza impermeabilidad total. Certificadas para <strong>vientos de hasta 80 km/h</strong> con sistema de anclaje profesional adaptable a pasto, concreto y terreno mixto.</p>
          <p class="showcase__text">Ideales para <strong>bodas íntimas, cócteles, bautizos, primeras comuniones y reuniones familiares</strong>. La altura de cumbrera de 3.5 a 4 metros permite una sensación espaciosa y elegante. Incluyen <strong>canaletas de drenaje integradas</strong> para eventos en temporada de lluvias. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para crear ambientes completos con mesas, sillas y salas lounge bajo la carpa.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">5x5 metros</span>
            <span class="showcase__tag">6x12 metros</span>
            <span class="showcase__tag">10x10 metros</span>
            <span class="showcase__tag">50-100 personas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Carpas Medianas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 7l9-4 9 4v10l-9 4-9-4V7z"/>
              <path d="M12 3v18"/>
              <path d="M3 7l9 4 9-4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS GRANDES 10x15 a 15x30 — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="grandes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Gran formato profesional</span>
          <h2 class="showcase__title" id="grandes-heading">Carpas Grandes 10x15 a 15x30</h2>
          <p class="showcase__subtitle">Estructuras de gran formato para eventos de 150 a 400+ invitados con acabado profesional.</p>
          <p class="showcase__text">Nuestras <strong>carpas estructurales de gran formato</strong> están disponibles en configuraciones de <strong>10x15, 10x20, 15x20 y 15x30 metros</strong> con marcos de aluminio reforzado y uniones de acero inoxidable. Diseñadas para soportar cargas de viento, lluvia y nieve con factor de seguridad certificado. La altura de cumbrera alcanza <strong>5 a 6 metros</strong>, permitiendo montajes de iluminación, audio y decoración colgante de gran escala.</p>
          <p class="showcase__text">Son la elección preferida para <strong>bodas de gran formato, eventos corporativos, expos comerciales, ferias y festivales</strong>. La estructura modular permite unir módulos para crear superficies de hasta 20x40 metros o más. Incluyen <strong>sistema de drenaje profesional, refuerzos de viento y anclaje certificado</strong> para cada tipo de terreno. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para producciones corporativas con pantallas LED y sonido profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">10x15 metros</span>
            <span class="showcase__tag">10x20 metros</span>
            <span class="showcase__tag">15x30 metros</span>
            <span class="showcase__tag">150-400+ personas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Carpas Grandes
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="6" width="22" height="14" rx="2"/>
              <path d="M1 10h22"/>
              <path d="M6 6v-2"/>
              <path d="M18 6v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAREDES MODULARES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paredes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Configuración personalizada</span>
          <h2 class="showcase__title" id="paredes-heading">Paredes Modulares</h2>
          <p class="showcase__subtitle">Sistema de paredes intercambiables para configurar tu carpa según clima, privacidad y estética.</p>
          <p class="showcase__text">Nuestro <strong>sistema de paredes modulares</strong> ofrece cuatro tipos intercambiables que se instalan en minutos: <strong>paredes sólidas blancas</strong> para protección total contra viento y privacidad, <strong>paredes con ventana</strong> que combinan secciones sólidas con paneles transparentes para iluminación natural, <strong>paredes completamente transparentes</strong> de PVC cristal que permiten disfrutar del paisaje exterior, y <strong>paredes tipo malla</strong> que brindan ventilación manteniendo protección visual.</p>
          <p class="showcase__text">Cada pared se fija al marco de aluminio mediante <strong>sistema de rieles y tensores</strong> que garantizan un ajuste firme sin holguras. Puedes combinar diferentes tipos de pared en cada lateral de la carpa: transparentes hacia el jardín, sólidas contra el viento, y abiertas hacia el acceso. Ideales para <strong>bodas en jardín, eventos de temporada y montajes que requieren control climático</strong>. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para resaltar las paredes transparentes con efectos de luz espectaculares.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Sólidas blancas</span>
            <span class="showcase__tag">Con ventana</span>
            <span class="showcase__tag">Transparentes</span>
            <span class="showcase__tag">Tipo malla</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Paredes Modulares
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
              <line x1="15" y1="3" x2="15" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ACCESORIOS ESTRUCTURALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="accesorios-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Complementos profesionales</span>
          <h2 class="showcase__title" id="accesorios-heading">Accesorios Estructurales</h2>
          <p class="showcase__subtitle">Todo lo que necesitas para completar tu carpa: drenaje, piso, climatización e iluminación integrada.</p>
          <p class="showcase__text">Nuestros <strong>accesorios estructurales</strong> transforman una carpa básica en un espacio de evento completamente equipado. <strong>Sistema de drenaje profesional</strong> con canaletas perimetrales y bajantes que dirigen el agua lejos de la estructura. <strong>Pisos nivelados</strong> de madera sobre estructura metálica con nivelación láser, ideales para terrenos irregulares y jardines — incluyen rampa de acceso y pueden cubrir toda la superficie o zonas específicas.</p>
          <p class="showcase__text">Complementa con <strong>climatización profesional</strong>: ventiladores industriales para temporada de calor y calefactores de patio para eventos en invierno. <strong>Iluminación integrada</strong> con rieles LED, spots direccionales y guirnaldas decorativas que se instalan directamente en la estructura de la carpa. <strong>Canalización eléctrica oculta</strong> con tablero de distribución y tomas de corriente distribuidas para equipos de audio, cocina y decoración. Combina con nuestros <a href="/servicios/accesorios/">accesorios generales</a> como mantelería, señalización y plantas de energía para un montaje integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Drenaje profesional</span>
            <span class="showcase__tag">Piso nivelado</span>
            <span class="showcase__tag">Climatización</span>
            <span class="showcase__tag">Iluminación LED</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Accesorios
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Carpas Estructurales"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu carpa estructural, es natural tener preguntas sobre tamaños, resistencia, paredes y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre carpas estructurales al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de carpas estructurales para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
