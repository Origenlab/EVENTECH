---
/**
 * ─── Paredes Modulares para Carpas — Pagina de Producto (Nivel 4) ───
 * Paredes modulares: sólidas, ventana, transparentes y malla
 * para carpas estructurales.
 *
 * Jerarquia: Servicios > Carpas > Estructurales > Paredes Modulares
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Carpas", href: "/servicios/carpas/" },
  { label: "Estructurales", href: "/servicios/carpas/estructurales/" },
  { label: "Paredes Modulares" },
];

const faqs = [
  { question: "¿Se pueden combinar diferentes tipos de paredes en una misma carpa?", answer: "Sí, la combinación libre es una de las principales ventajas de nuestro sistema modular. Puedes instalar <strong>paredes transparentes hacia el jardín</strong> para disfrutar del paisaje, <strong>paredes sólidas contra la dirección del viento</strong> para protección, <strong>paredes con ventana</strong> para iluminación natural parcial y dejar lados abiertos para acceso. Cada panel se instala de forma independiente, así que puedes configurar cada lado de la carpa según tus necesidades exactas de clima, privacidad y estética." },
  { question: "¿Las paredes son removibles durante el evento?", answer: "Sí, nuestras paredes modulares están diseñadas para ser <strong>instaladas y removidas en minutos</strong> sin herramientas especiales. Utilizan un sistema de rieles de aluminio con tensores rápidos que permiten enrollar o desmontar cualquier panel individualmente. Esto es muy útil para eventos que inician como cóctel al aire libre y después necesitan protección para la cena, o para ajustar la configuración según el clima cambie durante el día. Nuestro equipo de montaje puede asistir con los cambios si lo necesitas." },
  { question: "¿Las paredes protegen del frío y del calor?", answer: "Las paredes sólidas de PVC de 650 g/m² ofrecen un <strong>excelente aislamiento contra viento y frío</strong>, reduciendo la sensación térmica dentro de la carpa significativamente. Las paredes transparentes de PVC cristal también bloquean el viento pero permiten el paso de radiación solar, lo que puede generar efecto invernadero en días soleados. Para eventos en invierno recomendamos paredes sólidas + <a href=\"/servicios/accesorios/calefaccion-clima/\">calefacción profesional</a>. Para verano, paredes tipo malla que permiten ventilación natural o paredes sólidas + enfriamiento evaporativo." },
  { question: "¿Las paredes son compatibles con todas las carpas estructurales?", answer: "Sí, nuestro sistema de paredes modulares es <strong>compatible con todas nuestras carpas estructurales</strong>, desde las medianas de 5x5 hasta las grandes de 15x30 metros. Todas comparten el mismo sistema de rieles de aluminio estandarizado. Los paneles vienen en módulos de 3 metros de ancho que se unen entre sí para cubrir cualquier longitud. Para carpas con altura lateral de 2.5 metros usamos paneles estándar, y para las de 3 metros de altura lateral usamos paneles extendidos. Nuestro equipo configura los paneles exactos para tu carpa." },
  { question: "¿Las paredes se cobran individual o por conjunto completo?", answer: "Ofrecemos ambas opciones. Puedes rentar <strong>paneles individuales</strong> (por módulo de 3 metros) si solo necesitas cubrir uno o dos lados de tu carpa, o rentar el <strong>set completo</strong> para cubrir todo el perímetro con descuento. También ofrecemos kits combinados con mezcla de tipos (por ejemplo, 2 lados sólidos + 1 transparente + 1 abierto). Los precios desde $800 por panel individual y sets completos desde $3,500 dependiendo del tamaño de la carpa." },
  { question: "¿Las paredes vienen incluidas con la renta de la carpa?", answer: "Las paredes <strong>no están incluidas por defecto</strong> en la renta básica de la carpa, ya que muchos clientes prefieren carpas abiertas o solo necesitan cubrir algunos lados. Sin embargo, ofrecemos <strong>paquetes con paredes incluidas</strong> a precio preferencial cuando se reservan junto con la carpa. Si sabes que necesitas paredes, te recomendamos solicitar el paquete combinado al momento de cotizar para obtener el mejor precio. Nuestro asesor te presentará ambas opciones en tu cotización." },
];

const specs = [
  { label: "Tipos", value: "Sólida, ventana, transparente, malla" },
  { label: "Material sólida", value: "PVC 650 g/m² blanco" },
  { label: "Material transparente", value: "PVC cristal 0.5mm" },
  { label: "Ventana", value: "Ovalada de PVC con marco" },
  { label: "Malla", value: "Mosquitero anti-insectos con ventilación" },
  { label: "Fijación", value: "Rieles de aluminio, montaje rápido" },
  { label: "Altura", value: "2.5 a 3 metros según carpa" },
  { label: "Combinación", value: "Libre por lado/sección" },
  { label: "Compatibilidad", value: "Todas nuestras carpas estructurales" },
  { label: "Instalación", value: "Incluida con renta de carpa" },
];

const sidebarNav = [
  { name: "Carpas Medianas", href: "/servicios/carpas/estructurales/medianas/" },
  { name: "Carpas Grandes", href: "/servicios/carpas/estructurales/grandes/" },
  { name: "Paredes Modulares", href: null, active: true },
  { name: "Accesorios Estructurales", href: "/servicios/carpas/estructurales/accesorios-estructurales/" },
];

const sidebarRelated = [
  { name: "Pisos y Complementos", href: "/servicios/carpas/pisos-complementos/" },
  { name: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Climatización", href: "/servicios/accesorios/calefaccion-clima/" },
];

const reviews = [
  { author: "Sofía Herrera", text: "Rentamos paredes transparentes para nuestra boda en un jardín de San Ángel. El efecto fue mágico: podíamos ver el atardecer y las luces del jardín mientras estábamos protegidos del viento. La combinación con guirnaldas Edison dentro de la carpa creó un ambiente increíble. Las paredes se veían impecables.", rating: 5, date: "2025-11-25" },
  { author: "Miguel Ángel Cortés", text: "Usamos paredes sólidas en una expo corporativa en Polanco para aislar el espacio del ruido exterior y mantener la climatización. El resultado fue excelente, la carpa se sentía como un salón cerrado con temperatura controlada. El montaje con rieles fue rapidísimo y las paredes quedaron perfectamente tensadas.", rating: 5, date: "2025-10-12" },
  { author: "Diana Estrada", text: "Contratamos el kit combinado para un cóctel: paredes transparentes hacia el jardín, sólidas contra el estacionamiento y un lado completamente abierto como acceso principal. La flexibilidad de poder mezclar tipos fue genial. A mitad del evento empezó a hacer frío y el equipo cerró el lado abierto en minutos. Servicio 10/10.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Paredes Modulares para Carpas en CDMX",
    description: "Renta de paredes modulares para carpas estructurales: sólidas, con ventana, transparentes y tipo malla. Configura tu carpa según clima y estética. Desde $800 por panel.",
    url: "/servicios/carpas/estructurales/paredes-modulares/",
    priceRange: { min: 800, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 167,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Carpas", url: "/servicios/carpas/" },
    { name: "Estructurales", url: "/servicios/carpas/estructurales/" },
    { name: "Paredes Modulares", url: "/servicios/carpas/estructurales/paredes-modulares/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Paredes Modulares para Carpas en CDMX"
  description="Renta de paredes modulares para carpas estructurales: sólidas, con ventana, transparentes y tipo malla. Configura tu carpa según clima y estética. Desde $800 por panel."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Configura tu carpa a medida"
    title='Renta de <span class="highlight">Paredes Modulares</span> para Carpas en CDMX'
    subtitle="Sistema de paredes intercambiables para carpas estructurales: sólidas PVC, con ventana ovalada, transparentes cristal y tipo malla mosquitero. Combinación libre por lado con instalación rápida mediante rieles de aluminio."
    primaryCTA={{ label: "Cotiza tus paredes", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar paredes modulares para mi carpa` }}
    cards={[
      {
        title: "Sistema de paredes intercambiables para cada necesidad",
        content: "<strong>Paredes modulares para carpas estructurales</strong> con cuatro tipos intercambiables que se instalan en minutos. Paredes <strong>sólidas de PVC 650 g/m²</strong> blancas para protección total contra viento y privacidad. Paredes <strong>con ventana ovalada</strong> que combinan secciones sólidas con paneles transparentes para iluminación natural. Paredes <strong>completamente transparentes</strong> de PVC cristal 0.5mm para disfrutar del paisaje con protección climática. Y paredes <strong>tipo malla mosquitero</strong> que brindan ventilación natural manteniendo protección visual contra insectos.",
      },
      {
        title: "Combinación libre de tipos con instalación rápida en rieles",
        content: "<strong>Configuración personalizada</strong> con combinación libre de tipos por lado y sección. Cada panel se fija al marco de aluminio mediante sistema de rieles con tensores rápidos que garantizan un ajuste firme sin holguras. Instala paredes transparentes hacia el jardín, sólidas contra el viento y malla para ventilación — todo en la misma carpa. Cierre total o parcial según el clima del momento, con opción de abrir o cerrar paneles durante el evento sin herramientas. Compatible con todas nuestras carpas estructurales de 5x5 a 15x30 metros.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas configurar tu carpa según el clima?"
    subheadline="Cotiza sin compromiso — te asesoramos sobre la combinación ideal de paredes para tu evento y temporada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Carpas Estructurales para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas paredes modulares para tu carpa?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar paredes modulares para mi carpa`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 22h20L12 2z"/><path d="M12 2v20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Paredes Modulares</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Paredes Sólidas -->
          <section class="section section--alt" aria-labelledby="solidas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Privacidad y protección total</span>
                <h2 class="showcase__title" id="solidas-heading">Paredes Sólidas PVC</h2>
                <p class="showcase__subtitle">Protección completa contra viento, lluvia y miradas externas.</p>
                <p class="showcase__text">Nuestras <strong>paredes sólidas de PVC blanco de 650 g/m²</strong> ofrecen la máxima protección contra elementos climáticos. Fabricadas con el mismo material ignífugo de las lonas de techo, bloquean completamente el viento, la lluvia y la radiación solar. Ideales para eventos en <strong>temporada de lluvias, invierno o cuando se requiere privacidad total</strong> del exterior. Las costuras termoselladas garantizan impermeabilidad absoluta en el punto de unión con el techo.</p>
                <p class="showcase__text">El acabado blanco mate genera un ambiente limpio y elegante que combina con cualquier decoración. Al cerrar completamente la carpa con paredes sólidas, se crea un espacio aislado que permite <strong>controlar la temperatura con climatización artificial</strong> — calefactores para invierno o aire acondicionado portátil para verano. La superficie interior es ideal para proyectar imágenes, logos corporativos o iluminación wash de colores. Combínalas con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a> para efectos espectaculares sobre las paredes.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">PVC 650 g/m²</span>
                  <span class="showcase__tag">Ignífuga</span>
                  <span class="showcase__tag">Impermeable</span>
                  <span class="showcase__tag">Privacidad total</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Paredes Sólidas
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Paredes Sólidas PVC</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Paredes con Ventana -->
          <section class="section section--alt" aria-labelledby="ventana-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Luz natural con protección</span>
                <h2 class="showcase__title" id="ventana-heading">Paredes con Ventana</h2>
                <p class="showcase__subtitle">El balance perfecto entre protección climática e iluminación natural.</p>
                <p class="showcase__text">Las <strong>paredes con ventana ovalada</strong> combinan secciones de PVC sólido blanco con paneles transparentes integrados que permiten el paso de luz natural sin comprometer la protección contra viento y lluvia. Cada panel incluye una <strong>ventana ovalada de PVC cristal con marco reforzado</strong> que ofrece visibilidad parcial del exterior y una estética elegante de estilo europeo.</p>
                <p class="showcase__text">Son la opción favorita para <strong>eventos diurnos donde se desea iluminación natural</strong> sin renunciar a la protección climática completa. Las ventanas ovaladas crean un juego de luz y sombra que realza la decoración interior de la carpa. Ideales para <strong>bodas de día en jardín, brunchs corporativos y eventos religiosos</strong> donde la luz natural es importante para la fotografía. Se pueden intercalar con paneles sólidos para controlar la cantidad de luz que entra según cada lateral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Ventana ovalada</span>
                  <span class="showcase__tag">PVC cristal</span>
                  <span class="showcase__tag">Luz natural</span>
                  <span class="showcase__tag">Estilo europeo</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Paredes con Ventana
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Paredes con Ventana</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Paredes Transparentes -->
          <section class="section section--alt" aria-labelledby="transparentes-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Vista panorámica</span>
                <h2 class="showcase__title" id="transparentes-heading">Paredes Transparentes</h2>
                <p class="showcase__subtitle">Disfruta del paisaje exterior con protección climática completa.</p>
                <p class="showcase__text">Nuestras <strong>paredes completamente transparentes de PVC cristal de 0.5mm</strong> son la opción premium para eventos donde el paisaje exterior es parte de la experiencia. Ofrecen <strong>visibilidad total del jardín, montañas o skyline</strong> mientras protegen completamente contra viento, lluvia y frío. El PVC cristal de alta calidad mantiene transparencia sin distorsión óptica, creando la sensación de estar al aire libre con el confort de un espacio cerrado.</p>
                <p class="showcase__text">Son las paredes más solicitadas para <strong>bodas en jardín al atardecer</strong> donde los invitados quieren disfrutar del cambio de luz y el encendido de las luces del jardín desde adentro de la carpa. También ideales para <strong>eventos en miradores y terrazas con vista</strong>. La superficie transparente refleja la iluminación interior creando un efecto espejo al anochecer que amplifica visualmente el espacio. Combínalas con <a href="/servicios/iluminacion/decorativa/">guirnaldas Edison</a> para crear un ambiente mágico que se ve desde dentro y desde fuera.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">PVC cristal 0.5mm</span>
                  <span class="showcase__tag">Visibilidad total</span>
                  <span class="showcase__tag">Sin distorsión</span>
                  <span class="showcase__tag">Efecto espejo nocturno</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Paredes Transparentes
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2L2 22h20L12 2z"/>
                    <path d="M12 2v20"/>
                  </svg>
                  <span>Paredes Transparentes</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Combinado -->
          <section class="section section--alt" aria-labelledby="combinado-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Configuración personalizada</span>
                <h2 class="showcase__title" id="combinado-heading">Kit Combinado de Paredes</h2>
                <p class="showcase__subtitle">Mix de tipos de pared según clima, vista y privacidad de cada lado.</p>
