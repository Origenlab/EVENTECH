---
/**
 * ─── Impresión y Periféricos para Eventos — Página de Producto (L5) ───
 * Impresión de gafetes/credenciales, láser multifuncional, plotter de gran
 * formato, escáner y periféricos para eventos corporativos y congresos.
 * Homologada al Template-L5-producto (tiffany): componentes l3/l4, dorado #c2a24a,
 * galería showcase__gallery3, Acabados grid, 8 FAQs, título sin marca.
 * NOTA: sin reviews reales → serviceJsonLd (no se fabrican reseñas).
 * NOTA: sin fotos de producto en el repo → imágenes corporativas/AV con alt honesto.
 *
 * Jerarquía: Servicios > Cómputo > Impresión y Periféricos
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "Impresión y Periféricos" },
];

const acabados = [
  {
    name: "Impresora de Gafetes y Credenciales",
    price: "Desde $900/día",
    excerpt: "Impresoras térmicas y de credenciales PVC calibradas con tu diseño e integradas a la plataforma de registro: el asistente hace check-in y su gafete sale impreso al momento.",
    href: "#gafetes-heading",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    tags: ["Térmica / PVC", "Integrada al registro", "Diseño calibrado", "Consumibles incluidos"],
    badge: "Más solicitada",
  },
  {
    name: "Impresora Láser y Multifuncional",
    price: "Desde $600/día",
    excerpt: "Láser monocromática de alto volumen y multifuncional a color con escáner y copiado para la oficina del evento, la sala de prensa y los documentos de última hora.",
    href: "#laser-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ["B/N 30-40 ppm", "Color + escáner", "Red y USB", "Tóner incluido"],
  },
  {
    name: "Plotter y Gran Formato",
    price: "Desde $1,800/día",
    excerpt: "Plotter de gran formato para planos, lonas, señalética y gráficos de stand impresos en sitio con color de alta fidelidad, hasta 44 pulgadas de ancho.",
    href: "#plotter-heading",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    tags: ["Hasta 44\"", "Planos y lonas", "Color de alta fidelidad", "Señalética en sitio"],
  },
  {
    name: "Escáner y Periféricos",
    price: "Desde $400/día",
    excerpt: "Escáner de documentos, lectores de código QR, webcams, diademas, hubs y energía regulada: los periféricos que sostienen cada estación de cómputo del evento.",
    href: "#perifericos-heading",
    image: "/images/eventos/corporativos/ejecutivo.avif",
    tags: ["Lectores QR", "Escáner con ADF", "Webcams y diademas", "Energía regulada"],
  },
];

const specs = [
  { label: "Líneas", value: "Gafetes/credenciales, Láser/multifuncional, Plotter gran formato, Escáner y periféricos" },
  { label: "Impresora láser", value: "Monocromática 30–40 ppm · a color 25 ppm · conexión por red y USB" },
  { label: "Multifuncional", value: "Impresión, escaneo y copiado en un solo equipo (carta y oficio)" },
  { label: "Impresora de gafetes", value: "Térmica y de credenciales PVC · integrada a tu plataforma de registro" },
  { label: "Plotter / gran formato", value: "Hasta 44\" de ancho · planos, lonas, señalética y gráficos a color" },
  { label: "Escáner", value: "Escáner de documentos de alta velocidad con alimentador automático (ADF)" },
  { label: "Periféricos", value: "Lectores QR, webcams Full HD, diademas USB, hubs, teclados y mouse" },
  { label: "Consumibles", value: "Tóner, papel, cintas y tarjetas PVC incluidos según volumen contratado" },
  { label: "Energía", value: "Multicontactos regulados con supresión de picos y extensiones profesionales" },
  { label: "Modalidad", value: "Renta por día, por evento (2–5 días) o por semana" },
  { label: "Servicio", value: "Entrega, instalación, calibración y recolección incluidas en CDMX" },
];

const sidebarNav = [
  { name: "Laptops", href: "/servicios/computo/laptops/" },
  { name: "iPads y Tablets", href: "/servicios/computo/ipads-tablets/" },
  { name: "PCs de Escritorio", href: "/servicios/computo/pcs-escritorio/" },
  { name: "Impresión y Periféricos", href: null, active: true },
];

const sidebarRelated = [
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Sonido para Eventos", href: "/servicios/audiovisual/sonido/" },
  { name: "Mobiliario para Módulos", href: "/servicios/mobiliario/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
];

const faqs = [
  { question: "¿Cuánto cuesta la renta de impresoras para eventos en CDMX?", answer: 'La <strong>renta de impresoras para eventos</strong> parte desde $600 por día para la láser monocromática de alto volumen y desde $1,200 para la multifuncional a color con escáner; la <strong>impresora de gafetes y credenciales</strong> renta desde $900 con consumibles, y el plotter de gran formato desde $1,800. Los periféricos —lectores QR, escáner de documentos, webcams y diademas— parten desde $400 por día. Todos los precios incluyen entrega, instalación, calibración, consumibles según el volumen contratado y recolección en CDMX y zona metropolitana. La cotización llega en menos de 24 horas por WhatsApp.' },
  { question: "¿Cómo funciona la acreditación con impresión de gafetes al momento?", answer: 'Integramos la <strong>impresora de gafetes</strong> con tu plataforma de registro: el asistente hace check-in en la <a href="/servicios/computo/laptops/">laptop</a> o iPad, el sistema envía a imprimir la credencial con su nombre, empresa y código QR, y la recibe en <strong>menos de 20 segundos</strong>. Antes del evento calibramos la impresora con tu diseño —tamaño, colores, logotipo y campos variables— y hacemos pruebas con datos reales de tu pre-registro. Como regla, una estación con impresión procesa entre <strong>60 y 80 acreditaciones por hora</strong>; dimensionamos el número de estaciones según tu hora pico de llegada.' },
  { question: "¿Incluyen el papel, tóner y consumibles de las impresoras?", answer: "Sí. Las <strong>impresoras láser y multifuncionales</strong> se entregan con tóner nuevo o de reserva y el papel según el volumen que nos indiques al cotizar; si el evento consume más de lo previsto, el excedente se cobra por millar a precio de lista conocido desde el contrato. Las <strong>impresoras de gafetes</strong> incluyen las cintas o tarjetas PVC contratadas más un porcentaje de reserva para errores y reimpresiones. El técnico lleva consumibles físicos de reserva y los repone sin que la fila se entere: <strong>nunca te quedas sin material a media acreditación</strong>." },
  { question: "¿Rentan plotter e impresión de gran formato para eventos?", answer: "Sí. Rentamos <strong>plotter de gran formato hasta 44 pulgadas de ancho</strong> para planos de montaje, lonas de bienvenida, señalética direccional, gráficos de stand y mamparas de fondo, con color de alta fidelidad. Es el equipo de las <strong>expos, ferias y congresos</strong> donde la señalética cambia a último momento y la gráfica se produce en el propio venue, sin depender de una imprenta externa. Entregamos con rollos de papel o vinil según el material contratado y coordinamos con tu equipo de diseño los formatos y perfiles de color antes del montaje." },
  { question: "¿Qué escáner y periféricos adicionales manejan para eventos?", answer: "Todo lo que un módulo de cómputo necesita alrededor: <strong>escáner de documentos de alta velocidad</strong> con alimentador automático para digitalizar acuses y contratos, <strong>lectores de código QR y de banda magnética</strong> para control de accesos y validación de boletos, webcams Full HD para transmisiones y videollamadas, diademas USB con cancelación de ruido para call centers, hubs, teclados y mouse adicionales, y multicontactos regulados con supresión de picos. Los periféricos se rentan como complemento de nuestro equipo de cómputo o para integrarse al tuyo. En la cotización armamos la lista completa del módulo para que el día del evento no falte el cable que detiene todo." },
  { question: "¿Entregan, instalan y configuran el equipo en el venue?", answer: 'Sí. Entregamos, instalamos, calibramos y probamos todo el equipo en el venue antes de abrir puertas: conexión a red, prueba de impresión, integración de la <a href="/servicios/computo/">plataforma de cómputo</a> y del <a href="/servicios/mobiliario/">mobiliario de los módulos de registro</a>, y verificación del diseño de gafete con datos reales. En módulos de acreditación dejamos las estaciones conectadas y funcionando, con técnico presente en el arranque. Al finalizar recogemos el equipo en el horario que acordemos, sin que tu equipo gestione la logística de devolución.' },
  { question: "¿Con cuánta anticipación debo reservar la impresión para mi evento?", answer: "Para impresoras láser sueltas basta una semana. Para <strong>módulos de acreditación con impresión de gafetes</strong> recomendamos 2 a 3 semanas: dan margen para calibrar tu diseño, integrar la plataforma de registro y hacer pruebas con datos reales. La impresión de gran formato requiere confirmar formatos y perfiles de color con anticipación. La reserva se confirma con el 50% de anticipo, los cambios no tienen costo hasta 72 horas antes del evento y emitimos factura CFDI. En temporada alta de congresos (marzo–junio y septiembre–noviembre) los módulos completos conviene apartarlos con un mes." },
  { question: "¿Tienen cobertura fuera de la Ciudad de México?", answer: "Sí. Además de todas las alcaldías de CDMX, entregamos en zona metropolitana —Naucalpan, Huixquilucan, Tlalnepantla, Ecatepec, Neza— y en Toluca, Metepec, Querétaro, Puebla y Cuernavaca. Para sedes fuera de CDMX coordinamos la logística de entrega, instalación, calibración y recolección con la anticipación necesaria; el costo de transporte se especifica en la cotización según la distancia y el volumen de equipo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Impresoras y Periféricos para Eventos en CDMX",
    description: "Renta de impresoras para eventos en CDMX: impresión de gafetes y credenciales, láser multifuncional, plotter de gran formato, escáner y periféricos con entrega e instalación en el venue. Desde $400/día.",
    url: "/servicios/computo/impresion-perifericos/",
    image: "/images/eventos/corporativos-hero.avif",
    priceRange: { min: 400, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "Impresión y Periféricos", url: "/servicios/computo/impresion-perifericos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Impresoras y Periféricos para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/eventos/corporativos-hero.avif"
  description="Renta de impresoras para eventos en CDMX: gafetes y credenciales, láser multifuncional, plotter, escáner y periféricos. Entrega e instalación en el venue."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La infraestructura del registro"
    title='Renta de <span class="highlight">Impresoras y Periféricos</span> para Eventos en CDMX'
    subtitle="Impresión de gafetes y credenciales, impresoras láser multifuncionales, plotter de gran formato, escáner y todos los periféricos que sostienen la acreditación y la operación de tu evento. Instalados y calibrados en el venue."
    primaryCTA={{ label: "Cotiza tu equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar impresoras y periféricos para mi evento` }}
    cards={[
      {
        title: "Acreditación con impresión de gafetes al momento",
        content: "<strong>Renta de impresoras para eventos</strong> con el módulo de acreditación completo: impresoras de gafetes y credenciales calibradas con tu diseño e integradas a la plataforma de registro, de modo que el asistente hace check-in y recibe su gafete impreso en segundos. Sumamos impresoras láser monocromáticas desde $600 por día y multifuncionales a color desde $1,200, con tóner y papel incluidos, para programas, constancias, listas y todos los documentos que un evento imprime en sitio.",
      },
      {
        title: "Gran formato, escáner y periféricos que no fallan",
        content: "<strong>Plotter de gran formato</strong> hasta 44 pulgadas para planos, lonas y señalética impresa en el venue, más escáner de documentos, lectores QR, webcams, diademas, hubs y multicontactos regulados. Cotización en menos de 24 horas por WhatsApp, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes, factura CFDI y cobertura en toda CDMX, Naucalpan, Huixquilucan, Tlalnepantla, Toluca, Metepec y Cuernavaca.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Tu congreso necesita acreditación con gafetes impresos?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con las impresoras y las estaciones dimensionadas para tu hora pico de llegada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- 3. ACABADOS — 4 líneas (anclas on-page) -->
  <section class="section" aria-labelledby="tipos-heading">
    <div class="container">
      <SectionHeader
        id="tipos-heading"
        title="4 líneas de equipo — elige la tuya"
        subtitle="Del gafete impreso al plano de gran formato"
        description={[
          "Desde la impresora de gafetes que no se atasca en la hora pico hasta el plotter que saca la señalética de la expo. Todas incluyen entrega, instalación, calibración y consumibles según volumen — la diferencia está en el propósito y el formato."
        ]}
      />

      <div class="grid grid--4">
        {acabados.map((a) => (
          <ProductCard
            name={a.name}
            price={a.price}
            excerpt={a.excerpt}
            href={a.href}
            image={a.image}
            tags={a.tags}
            badge={a.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- MOBILE SIDEBAR (≤1024px) -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Cómputo para Eventos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas impresión para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar impresoras y periféricos para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Impresión y Periféricos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Gafetes y Credenciales -->
          <section class="section" aria-labelledby="gafetes-heading">
            <ServiceShowcase
              title="Impresión de Gafetes y Credenciales"
              headingId="gafetes-heading"
              badge="Check-in con credencial al momento"
              subtitle="Impresoras térmicas y de credenciales PVC integradas a tu plataforma de registro, calibradas con tu diseño para imprimir el gafete al momento del check-in."
              tags={["Térmica / PVC", "Integrada al registro", "Diseño calibrado", "Desde $900/día"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Impresión de Gafetes"
            >
              <Fragment slot="body">
                <p class="showcase__text">La <strong>acreditación con impresión de gafetes</strong> es el primer contacto del asistente con tu evento, y donde más se nota la diferencia entre un módulo profesional y uno improvisado. Nuestras <strong>impresoras de gafetes térmicas y de credenciales PVC</strong> se integran con tu plataforma de registro: el asistente hace check-in y su gafete —nombre, empresa, categoría y código QR— sale impreso en <strong>menos de 20 segundos</strong>. La renta de impresoras para eventos con gafetes al momento parte desde $900 por día con consumibles incluidos.</p>
                <p class="showcase__text">Antes del evento <strong>calibramos tu diseño</strong> (formato, colores, logotipo, campos variables) y hacemos pruebas con datos reales del pre-registro. Una estación completa procesa entre 60 y 80 acreditaciones por hora; para congresos dimensionamos el número de estaciones según la hora pico de llegada. El módulo completo —laptops, impresoras y el <a href="/servicios/mobiliario/">mobiliario de los módulos de registro</a>— llega instalado y probado antes de abrir puertas.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/carpas/carpa-estructural-grande-congreso.avif" alt="Congreso corporativo de gran formato con módulos de registro y acreditación en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/eventos/corporativos/teambuilding.avif" alt="Asistentes en el área de registro de un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/eventos/corporativos-hero.avif" alt="Recepción de evento corporativo con módulos de atención al asistente en CDMX" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Láser y Multifuncional -->
          <section class="section" aria-labelledby="laser-heading">
            <ServiceShowcase
              title="Impresora Láser y Multifuncional"
              headingId="laser-heading"
              badge="La oficina del evento en sitio"
              subtitle="Láser monocromática de alto volumen y multifuncional a color con escáner y copiado para la oficina del evento, la sala de prensa y los documentos de última hora."
              tags={["B/N 30-40 ppm", "Color 25 ppm", "Escáner y copiado", "Desde $600/día"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Impresora Láser"
            >
              <Fragment slot="body">
                <p class="showcase__text">Todo evento imprime más de lo que su organizador esperaba: listas de asistencia que cambiaron anoche, programas corregidos, constancias de la capacitación, señalética de emergencia, el contrato que alguien necesita firmado hoy. Nuestras <strong>impresoras láser monocromáticas de 30 a 40 páginas por minuto</strong> rentan desde <strong>$600 por día</strong> con tóner y papel incluidos según el volumen contratado, conectadas por red o USB a las estaciones del evento.</p>
