---
/**
 * ─── Impresión y Periféricos para Eventos — Subcategoría de Cómputo (L4) ───
 * Página especializada: Renta de Impresoras, Gafetes y WiFi Temporal en CDMX.
 * Color accent: Azul #2563eb (identidad de la línea de cómputo).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "Impresión y Periféricos" },
];

const IMPRESION = [
  {
    name: "Impresora Láser B/N",
    price: "Desde $600/día",
    excerpt: "Impresoras láser monocromáticas de alto volumen con tóner incluido para listas de asistencia, programas, constancias y los documentos de última hora de todo evento.",
    href: "#reserva-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ["30-40 ppm", "Tóner incluido", "Red y USB", "Alto volumen"],
    badge: "Más solicitada",
  },
  {
    name: "Impresora Láser Color / Multifuncional",
    price: "Desde $1,200/día",
    excerpt: "Láser a color con escáner y copiado para oficinas de evento, salas de prensa y materiales con imagen de marca que deben imprimirse en sitio con calidad presentable.",
    href: "#reserva-heading",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    tags: ["Color 25 ppm", "Escáner y copiado", "WiFi y red", "Carta y oficio"],
  },
  {
    name: "Impresora de Gafetes",
    price: "Desde $900/día",
    excerpt: "Impresoras térmicas y de credenciales calibradas con tu diseño e integradas a la plataforma de registro: el asistente hace check-in y su gafete sale impreso al momento.",
    href: "#reserva-heading",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    tags: ["Térmica / PVC", "Tu diseño calibrado", "Integrada al registro", "Consumibles incluidos"],
  },
  {
    name: "Kit WiFi Temporal",
    price: "Desde $1,500/día",
    excerpt: "Red WiFi exclusiva para tu operación con módems 4G/5G de respaldo, ruteadores profesionales y puntos de acceso distribuidos. Independiente del internet del venue.",
    href: "#reserva-heading",
    image: "/images/eventos/corporativos-hero.avif",
    tags: ["Módem 4G/5G", "Puntos de acceso", "Red exclusiva", "Hasta $3,500 según cobertura"],
  },
];

const faqs = [
  { question: "¿Cuánto cuesta rentar una impresora para un evento en CDMX?", answer: "La impresora láser monocromática de alto volumen renta desde $600 por día y la láser a color multifuncional desde $1,200, ambas con tóner y papel incluidos según el volumen contratado. La impresora de gafetes con consumibles parte de $900 por día y el kit de WiFi temporal va de $1,500 a $3,500 por día según la cobertura y el número de dispositivos conectados. La entrega, instalación, calibración y recolección están incluidas en CDMX y zona metropolitana, y la cotización llega en menos de 24 horas por WhatsApp al 55 6432 8954." },
  { question: "¿Cómo funciona la acreditación con impresión de gafetes al momento?", answer: "Integramos la impresora de gafetes con tu plataforma de registro: el asistente hace check-in en la laptop o iPad, el sistema envía el gafete a imprimir con su nombre, empresa y código QR, y lo recibe en menos de 20 segundos. Calibramos la impresora con tu diseño antes del evento — tamaño, colores, logotipo y campos variables — y hacemos pruebas con datos reales de tu lista de pre-registro. Como regla, una estación con impresión procesa entre 60 y 80 acreditaciones por hora; dimensionamos el número de estaciones según tu hora pico de llegada." },
  { question: "¿El kit de WiFi temporal funciona si el venue no tiene internet?", answer: "Sí, ese es exactamente su propósito. El kit crea una red exclusiva para tu operación a partir de módems 4G/5G con planes de datos incluidos, ruteadores profesionales y puntos de acceso distribuidos según el área a cubrir. No depende del internet del venue — y si el venue sí tiene servicio, lo usamos como enlace principal y dejamos el celular como respaldo automático. Antes de cotizar verificamos la cobertura celular en la sede; en venues con señal débil (sótanos, zonas rurales) proponemos antenas externas o enlaces dedicados con costo detallado desde la propuesta." },
  { question: "¿Incluyen el papel, tóner y consumibles de las impresoras?", answer: "Sí. Las impresoras láser se entregan con tóner nuevo o de reserva y el papel según el volumen estimado que nos indiques al cotizar — si el evento consume más de lo previsto, el excedente se cobra por millar a precio de lista conocido desde el contrato. Las impresoras de gafetes incluyen las cintas o tarjetas PVC contratadas, con un porcentaje adicional de reserva para errores y reimpresiones. Nunca te quedas sin consumibles a media acreditación: el técnico lleva reserva física y la repone sin que la fila se entere." },
  { question: "¿Qué periféricos adicionales manejan para eventos?", answer: "Todo lo que un módulo de cómputo necesita alrededor: lectores de código QR y de banda magnética para control de accesos, hubs USB, teclados y mouse adicionales, diademas telefónicas con cancelación de ruido, webcams Full HD para transmisiones y videollamadas, multicontactos regulados con supresión de picos, extensiones de grado profesional y cableado de red. Los periféricos se rentan como complemento de nuestras laptops, iPads y PCs o para integrarse a tu propio equipo. En la cotización armamos la lista completa para que el día del evento no falte el cable que detiene todo." },
  { question: "¿Con cuánta anticipación debo reservar la impresión y el WiFi temporal?", answer: "Para impresoras láser sueltas basta una semana. Para módulos de acreditación con impresión de gafetes recomendamos 2 a 3 semanas: dan margen para calibrar tu diseño, integrar la plataforma de registro y hacer pruebas con datos reales. El kit de WiFi temporal requiere verificación de cobertura en sitio, idealmente con 2 semanas. La reserva se confirma con 50% de anticipo, los cambios no tienen costo hasta 72 horas antes del evento y emitimos factura CFDI. En temporada alta de congresos, los kits completos de acreditación conviene apartarlos con un mes." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Impresoras y Periféricos para Eventos CDMX",
    description: "Renta de impresoras láser, impresoras de gafetes y kits de WiFi temporal para eventos: acreditación con impresión al momento y red dedicada. Instalación incluida en CDMX.",
    url: "/servicios/computo/impresion-perifericos/",
    priceRange: { min: 600, max: 8000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "Impresión y Periféricos", url: "/servicios/computo/impresion-perifericos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Impresoras y Periféricos para Eventos"
  description="Renta de impresoras láser, impresoras de gafetes y WiFi temporal para eventos CDMX. Acreditación con impresión al momento y red dedicada. Cotización en 24h."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La infraestructura del registro"
    title='Renta de <span class="highlight">Impresión y Periféricos</span> para Eventos en CDMX'
    subtitle="Impresoras láser, impresoras de gafetes, kits de WiFi temporal y todos los periféricos que sostienen la acreditación y la operación de tu evento."
    primaryCTA={{ label: "Cotiza tu equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar impresoras y periféricos para mi evento` }}
    cards={[
      {
        title: "Acreditación con impresión de gafetes al momento",
        content: "<strong>El módulo de acreditación completo para eventos CDMX</strong>: impresoras de gafetes calibradas con tu diseño e integradas a la plataforma de registro, de modo que el asistente hace check-in y recibe su credencial impresa en segundos. Impresoras láser monocromáticas desde $600 por día y a color desde $1,200, con tóner y papel incluidos, para programas, constancias, listas y todos los documentos que un evento imprime en sitio. Consumibles de reserva siempre en el venue.",
      },
      {
        title: "WiFi temporal y periféricos que no fallan",
        content: "<strong>Kit de WiFi temporal de $1,500 a $3,500 por día</strong>: red exclusiva para tu operación con módems 4G/5G de respaldo, ruteadores profesionales y puntos de acceso distribuidos, independiente del internet del venue. Más lectores QR, diademas, webcams, hubs y multicontactos regulados. Cotización en menos de 24 horas por WhatsApp, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes, factura CFDI y cobertura en toda CDMX, Naucalpan, Huixquilucan, Tlalnepantla, Toluca, Metepec y Cuernavaca.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Tu congreso necesita acreditación con gafetes impresos?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con las impresoras, la red y las estaciones dimensionadas para tu hora pico de llegada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Impresión y Periféricos"
        subtitle="El equipo que sostiene la acreditación, la oficina del evento y la red"
        description={[
          "La impresora de gafetes que no se atasca en la hora pico, la láser que saca las constancias de la capacitación y la red que no depende del WiFi del salón. La infraestructura silenciosa que hace funcionar el registro de cualquier evento en CDMX.",
          "Cada equipo incluye entrega, instalación, calibración, consumibles según volumen contratado y recolección al finalizar tu evento."
        ]}
      />

      <div class="grid grid--4">
        {IMPRESION.map((equipo) => (
          <ProductCard
            name={equipo.name}
            price={equipo.price}
            excerpt={equipo.excerpt}
            href={equipo.href}
            image={equipo.image}
            tags={equipo.tags}
            badge={equipo.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       IMPRESORAS LÁSER — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="laser-heading">
    <div class="container">
      <ServiceShowcase
    title="Impresoras Láser"
    headingId="laser-heading"
    badge="Alto volumen en sitio"
    subtitle="Láser monocromáticas y a color con tóner incluido para la oficina del evento, la sala de prensa y los materiales de última hora."
    tags={["B/N 30-40 ppm", "Color 25 ppm", "Tóner incluido", "Desde $600/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Impresoras Láser"
  >
    <Fragment slot="body">
      <p class="showcase__text">Todo evento imprime más de lo que su organizador esperaba: listas de asistencia que cambiaron anoche, programas corregidos, constancias de la capacitación, señalética de emergencia, el contrato que alguien necesita firmado hoy. Nuestras <strong>impresoras láser monocromáticas de 30 a 40 páginas por minuto</strong> rentan desde <strong>$600 por día</strong> con tóner y papel incluidos según el volumen contratado, conectadas por red o USB a las estaciones del evento.</p>
      <p class="showcase__text">Para materiales con imagen de marca, la <strong>láser a color multifuncional</strong> (desde $1,200 por día) suma escáner y copiado — la oficina del evento completa en un solo equipo. En <strong>salas de prensa</strong> de congresos configuramos impresión compartida para todos los medios acreditados. Si el evento consume más papel del previsto, el excedente se cobra por millar a precio conocido desde el contrato y el técnico repone consumibles sin que la operación se detenga. Integra con nuestras <a href="/servicios/computo/laptops/">laptops</a> y <a href="/servicios/computo/pcs-escritorio/">PCs de escritorio</a> del mismo pedido.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 9V2h12v7"/>
              <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
              <rect x="6" y="14" width="12" height="8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GAFETES Y ACREDITACIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="gafetes-heading">
    <div class="container">
      <ServiceShowcase
    title="Impresión de Gafetes y Acreditación"
    headingId="gafetes-heading"
    badge="Check-in con credencial al momento"
    subtitle="Impresoras térmicas y de credenciales PVC integradas a tu plataforma de registro, calibradas con tu diseño."
    tags={["Térmica / PVC", "Integrada al registro", "Diseño calibrado", "Desde $900/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Impresión de Gafetes"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>acreditación con impresión de gafetes</strong> es el primer contacto del asistente con tu evento, y el momento donde más se nota la diferencia entre un módulo profesional y uno improvisado. Nuestras <strong>impresoras de gafetes térmicas y de credenciales PVC</strong> se integran con tu plataforma de registro: el asistente hace check-in en la laptop o el iPad, y su gafete — nombre, empresa, categoría y código QR — sale impreso en <strong>menos de 20 segundos</strong>.</p>
      <p class="showcase__text">Antes del evento <strong>calibramos tu diseño</strong> (formato, colores, logotipo, campos variables) y hacemos pruebas con datos reales del pre-registro. Rentan <strong>desde $900 por día</strong> con cintas, tarjetas y porta-gafetes según el aforo contratado, más reserva para reimpresiones. Una estación completa procesa entre 60 y 80 acreditaciones por hora; para congresos dimensionamos el número de estaciones según la hora pico de llegada. El módulo completo — <a href="/servicios/computo/laptops/">laptops</a>, <a href="/servicios/computo/ipads-tablets/">iPads</a>, impresoras y red — llega instalado y probado antes de abrir puertas.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="7" width="12" height="15" rx="2"/>
              <path d="M12 2v5"/>
              <path d="M9 2h6"/>
              <circle cx="12" cy="12" r="2"/>
              <path d="M9 17h6"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       WIFI TEMPORAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="wifi-heading">
    <div class="container">
      <ServiceShowcase
    title="Internet y WiFi Temporal"
    headingId="wifi-heading"
    badge="Red exclusiva para tu operación"
    subtitle="Módems 4G/5G, ruteadores profesionales y puntos de acceso distribuidos, independientes del internet del venue."
    tags={["Módem 4G/5G", "Puntos de acceso", "Respaldo automático", "$1,500-$3,500/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar WiFi Temporal"
  >
    <Fragment slot="body">
      <p class="showcase__text">La causa número uno de filas en el registro de un evento no es el software ni el personal: es el <strong>WiFi del venue compartido con 500 celulares de asistentes</strong>. El <strong>kit de WiFi temporal</strong> crea una red exclusiva para tu operación — registro, impresión de gafetes, terminales de cobro, votaciones — con módems 4G/5G con datos incluidos, ruteadores profesionales y puntos de acceso distribuidos según el área. Si el venue ofrece internet confiable, lo usamos como enlace principal y el celular queda como <strong>respaldo automático</strong>.</p>
      <p class="showcase__text">Renta de <strong>$1,500 a $3,500 por día</strong> según cobertura y dispositivos conectados. Antes de cotizar verificamos la señal celular de la sede; en venues difíciles — sótanos, haciendas, zonas con señal débil — proponemos antenas externas o enlaces dedicados con costo claro desde la propuesta. Es el complemento natural de los eventos bajo <a href="/servicios/carpas/">carpa</a> y en jardines donde no existe infraestructura, y de cualquier operación donde quedarse sin red significa detener el evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 13a10 10 0 0 1 14 0"/>
              <path d="M8.5 16.5a5 5 0 0 1 7 0"/>
              <path d="M2 9.5a15 15 0 0 1 20 0"/>
              <path d="M12 20h.01"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PERIFÉRICOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="perifericos-heading">
    <div class="container">
      <ServiceShowcase
    title="Periféricos y Accesorios"
    headingId="perifericos-heading"
    badge="Los detalles que sostienen todo"
    subtitle="Lectores QR, diademas, webcams, hubs y energía regulada: el equipo alrededor del equipo."
    tags={["Lectores QR", "Diademas USB", "Webcams Full HD", "Multicontactos regulados"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Periféricos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Alrededor de cada módulo de cómputo hay una capa de periféricos que nadie recuerda hasta que faltan. Rentamos <strong>lectores de código QR y de banda magnética</strong> para control de accesos y validación de boletos, <strong>diademas telefónicas USB</strong> con cancelación de ruido para call centers, <strong>webcams Full HD</strong> para transmisiones y videollamadas del evento, hubs USB, teclados y mouse adicionales y cableado de red profesional.</p>
      <p class="showcase__text">La capa eléctrica también viene resuelta: <strong>multicontactos regulados con supresión de picos</strong> y extensiones de grado profesional que protegen laptops, impresoras y terminales ante las variaciones típicas de la instalación de un venue. Los periféricos se cotizan como complemento de nuestras <a href="/servicios/computo/laptops/">laptops</a>, <a href="/servicios/computo/ipads-tablets/">iPads</a> y <a href="/servicios/computo/pcs-escritorio/">PCs</a>, o como refuerzo para tu propio equipo. En la propuesta armamos la lista completa del módulo — para que el día del evento no falte el cable de $200 que detiene la operación de $200,000.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="9" height="10" rx="1"/>
              <path d="M6.5 7V4a1 1 0 0 1 1-1h9a1 1 0 0 1 1 1v3"/>
              <path d="M13 12h9"/>
              <path d="M19 9l3 3-3 3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar impresión y WiFi para eventos?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por día de evento (+IVA). Incluyen entrega, instalación, consumibles según volumen y recolección en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Oficina de Evento",
          price: "$1,600",
          priceNote: "por día",
          description: "Impresión básica para la coordinación del evento.",
          features: [
            { text: "1 láser B/N alto volumen", included: true },
            { text: "Tóner y papel incluidos", included: true },
            { text: "Impresora de gafetes", included: false },
            { text: "WiFi temporal", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Acreditación",
          badge: "Más popular",
          highlight: true,
          price: "$3,800",
          priceNote: "por día",
          description: "Impresión de gafetes integrada a tu plataforma de registro.",
          features: [
            { text: "2 impresoras de gafetes", included: true },
            { text: "Diseño calibrado + pruebas", included: true },
            { text: "Consumibles con reserva", included: true },
            { text: "Lectores QR incluidos", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Congreso Conectado",
          price: "$6,900",
          priceNote: "por día",
          description: "Acreditación completa más red dedicada para toda la operación.",
          features: [
            { text: "Gafetes + láser color", included: true },
            { text: "Kit WiFi temporal completo", included: true },
            { text: "Respaldo 4G/5G automático", included: true },
            { text: "Técnico en sitio", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "A la Medida",
          price: "Cotizar",
          priceNote: "operaciones especiales",
          description: "Salas de prensa, expos multi-sede y eventos de varios días.",
          features: [
            { text: "Impresión compartida multi-punto", included: true },
            { text: "Enlaces dedicados de internet", included: true },
