---
/**
 * ─── iPads y Tablets para Eventos — Subcategoría de Cómputo (L4) ───
 * Página especializada: Renta de iPads y Tablets para Eventos en CDMX.
 * Color accent: Azul #2563eb (identidad de la línea de cómputo).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "iPads y Tablets" },
];

const TABLETS = [
  {
    name: "iPad",
    price: "Desde $350/día",
    excerpt: "iPads de generación reciente con la app de tu evento precargada y modo kiosco activado. El estándar de check-in de asistentes, encuestas de satisfacción y firmas digitales.",
    href: "#reserva-heading",
    image: "/images/eventos/corporativos-hero.avif",
    tags: ["iPadOS actualizado", "Modo kiosco", "App precargada", "Funda incluida"],
    badge: "Más solicitado",
  },
  {
    name: "iPad Pro",
    price: "Desde $600/día",
    excerpt: "iPad Pro con pantalla de 11 o 12.9 pulgadas para demostraciones de producto, catálogos interactivos premium y presentaciones donde la calidad de pantalla es protagonista.",
    href: "#reserva-heading",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    tags: ['11" / 12.9"', "ProMotion", "USB-C", "Apple Pencil opcional"],
  },
  {
    name: "Tablet Android",
    price: "Desde $350/día",
    excerpt: "Tablets Android de 10 pulgadas como alternativa flexible para captura de datos, menús digitales, control de accesos con lector QR y flotas grandes con presupuesto ajustado.",
    href: "#reserva-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ['Pantalla 10"', "Android actualizado", "Lector QR", "Ideal en volumen"],
  },
  {
    name: "Kiosco con Soporte Antirrobo",
    price: "Desde $500/día",
    excerpt: "iPad o tablet montado en pedestal, mostrador o pared con soporte antirrobo de acero y cable de carga oculto. Módulo de autoservicio listo para registro o encuestas.",
    href: "#reserva-heading",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    tags: ["Pedestal / mostrador", "Cerradura de seguridad", "Carga continua", "Rotulación opcional"],
  },
];

const faqs = [
  { question: "¿Cuánto cuesta la renta de iPads para eventos en CDMX?", answer: "Los iPads de generación reciente rentan desde $350 por día y los iPad Pro de 11 y 12.9 pulgadas desde $600 por día. Las tablets Android de 10 pulgadas parten de $350 y el kiosco completo con soporte antirrobo desde $500 por día. A partir de 10 unidades aplicamos descuentos por volumen — el caso típico es la flota de 10 a 30 iPads para check-in y encuestas de un congreso. La entrega, configuración y recolección están incluidas en CDMX y zona metropolitana, y la cotización llega en menos de 24 horas por WhatsApp al 55 6432 8954." },
  { question: "¿Los iPads llegan con la app de mi evento instalada?", answer: "Sí. Antes de la entrega instalamos y probamos la aplicación que usará tu evento: plataformas de registro y check-in, apps de encuestas y votación, catálogos interactivos o formularios propios. Activamos el modo kiosco (acceso guiado), de manera que el asistente solo puede usar la app del evento y no puede salir a otras funciones del dispositivo. También configuramos la conexión WiFi del venue o de nuestra red temporal, el brillo, el auto-bloqueo y todos los detalles para que la flota completa se comporte de forma idéntica." },
  { question: "¿Cómo evitan que se roben o dañen las tablets en un evento público?", answer: "Con tres capas: soportes antirrobo de acero con cerradura para los módulos de autoservicio (pedestal, mostrador o pared), fundas resistentes con correa de mano para el personal que camina con la tablet, y localización remota activada en todas las unidades. En eventos masivos recomendamos concentrar los kioscos en zonas con personal cercano. La responsabilidad por robo o daño se define en el contrato de renta con montos por unidad conocidos desde la cotización — sin sorpresas posteriores." },
  { question: "¿Sirven para votaciones interactivas y encuestas en tiempo real?", answer: "Es uno de sus usos principales. Configuramos la flota con la plataforma de votación o encuestas que elijas (o te recomendamos una según tu dinámica) y montamos la red que soporta a todos los dispositivos conectados simultáneamente, con módem 4G/5G de respaldo. Los resultados pueden proyectarse en tiempo real en la pantalla principal del evento — si rentas las pantallas con nosotros, la integración ya llega resuelta. Funciona para asambleas con voto registrado, dinámicas de audiencia en convenciones y evaluaciones en capacitaciones." },
  { question: "¿Qué pasa con la batería en eventos de jornada completa?", answer: "Los iPads y tablets se entregan con carga al 100% y rinden entre 8 y 10 horas de uso continuo de registro o encuestas. Para jornadas más largas incluimos cargadores y multicontactos para rotación de carga, y en los kioscos con soporte el cable de carga va oculto dentro del pedestal, por lo que el dispositivo permanece conectado permanentemente. En eventos de varios días el equipo puede quedarse resguardado en el venue y nuestro personal lo deja cargando en un espacio con acceso controlado." },
  { question: "¿Con cuánta anticipación debo reservar los iPads?", answer: "Para flotas de hasta 10 unidades, una semana de anticipación es suficiente. Para 20 a 50 unidades con app configurada y kioscos, recomendamos 2 a 3 semanas para dejar margen a las pruebas con tu plataforma de registro o votación. La reserva se confirma con el 50% de anticipo, puedes ajustar cantidades sin costo hasta 72 horas antes del evento y emitimos factura CFDI. En temporada alta de congresos (marzo–junio y septiembre–noviembre) los pedidos grandes conviene apartarlos con un mes." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de iPads y Tablets para Eventos CDMX",
    description: "Renta de iPads para eventos: check-in de asistentes, encuestas, votaciones interactivas y kioscos con soporte antirrobo. App configurada y entrega incluida en CDMX.",
    url: "/servicios/computo/ipads-tablets/",
    priceRange: { min: 350, max: 9000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "iPads y Tablets", url: "/servicios/computo/ipads-tablets/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de iPads y Tablets para Eventos CDMX"
  description="Renta de iPads para eventos en CDMX desde $350/día: check-in, encuestas, votaciones interactivas y kioscos antirrobo. App configurada y entrega incluida."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Check-in sin filas, datos sin papel"
    title='Renta de <span class="highlight">iPads y Tablets</span> para Eventos en CDMX'
    subtitle="iPads y tablets Android con la app de tu evento precargada, modo kiosco y soportes antirrobo para registro de asistentes, encuestas y votaciones interactivas."
    primaryCTA={{ label: "Cotiza tus iPads", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar renta de iPads para mi evento` }}
    cards={[
      {
        title: "La flota de tablets que tu registro necesita",
        content: "<strong>Renta de iPads para eventos</strong> desde $350 por día con la aplicación de tu evento instalada, probada y bloqueada en modo kiosco: el asistente solo ve tu app, nada más. iPad Pro para demostraciones premium, tablets Android para flotas grandes con presupuesto ajustado y kioscos con soporte antirrobo de acero para módulos de autoservicio. Toda la flota se configura de forma idéntica para que el check-in, la encuesta o la votación se comporten igual en cada dispositivo.",
      },
      {
        title: "Configuración, red y soporte incluidos",
        content: "<strong>Servicio completo para eventos CDMX</strong>: configuramos la app y la red, entregamos e instalamos en el venue, y dejamos la flota funcionando antes de abrir puertas. Cotización en menos de 24 horas por WhatsApp, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes del evento y factura CFDI. Cobertura en todas las alcaldías de CDMX, Naucalpan, Huixquilucan, Tlalnepantla, Toluca, Metepec y Cuernavaca, con descuentos por volumen desde 10 unidades.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas iPads para el check-in de tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con la cantidad, el modelo y los soportes ideales para tu registro o votación"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de iPads y Tablets"
        subtitle="Dispositivos configurados, bloqueados en tu app y listos para el asistente"
        description={[
          "Desde dos iPads para la mesa de bienvenida hasta una flota de 30 unidades para el registro de un congreso. Cada dispositivo se entrega configurado, cargado y probado con la aplicación de tu evento.",
          "Todos los equipos incluyen entrega, configuración, prueba de funcionamiento y recolección al finalizar. Con soportes antirrobo disponibles y descuentos por volumen a partir de 10 unidades."
        ]}
      />

      <div class="grid grid--4">
        {TABLETS.map((equipo) => (
          <ProductCard
            name={equipo.name}
            price={equipo.price}
            excerpt={equipo.excerpt}
            href={equipo.href}
            image={equipo.image}
            tags={equipo.tags}
            badge={equipo.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       IPADS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="ipads-heading">
    <div class="container">
      <ServiceShowcase
    title="iPads para Registro y Check-in"
    headingId="ipads-heading"
    badge="El estándar de acreditación"
    subtitle="iPads con tu app de registro precargada y modo kiosco: el check-in que procesa asistentes en segundos."
    tags={["iPadOS actualizado", "Modo kiosco", "App configurada", "Desde $350/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar iPads"
  >
    <Fragment slot="body">
      <p class="showcase__text">El iPad es el dispositivo estándar del <strong>registro de asistentes</strong> por una razón simple: procesa un check-in en segundos, se opera con una mano y proyecta una imagen profesional en la mesa de bienvenida. Rentamos <strong>iPads de generación reciente desde $350 por día</strong>, entregados con tu plataforma de registro precargada, el <strong>modo kiosco activado</strong> para que el asistente no salga de la app, y la conexión de red configurada y probada en sitio.</p>
      <p class="showcase__text">Los mismos iPads resuelven <strong>encuestas de satisfacción, firmas digitales, formularios de contacto en stands y catálogos interactivos</strong> en expos. Para congresos armamos flotas de 10 a 50 unidades con configuración idéntica y unidades de respaldo incluidas. Combínalos con el <a href="/servicios/computo/impresion-perifericos/">módulo de impresión de gafetes</a> para una acreditación completa: el asistente hace check-in en el iPad y recibe su gafete impreso al instante.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="5" y="2" width="14" height="20" rx="2"/>
              <path d="M12 18h.01"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TABLETS ANDROID — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tablets-android-heading">
    <div class="container">
      <ServiceShowcase
    title="Tablets Android"
    headingId="tablets-android-heading"
    badge="Flexibilidad en volumen"
    subtitle="Tablets de 10 pulgadas para captura de datos, menús digitales y control de accesos con lector QR."
    tags={["Pantalla 10\"", "Android actualizado", "Lector QR", "Ideal en flotas grandes"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Tablets Android"
  >
    <Fragment slot="body">
      <p class="showcase__text">Las <strong>tablets Android de 10 pulgadas</strong> son la alternativa flexible cuando la flota es grande y el presupuesto importa: misma capacidad de captura de datos, formularios y check-in, con tarifas que hacen viable equipar 30 o 40 puntos simultáneos. Rentan <strong>desde $350 por día</strong> con Android actualizado, la app de tu evento instalada y el mismo nivel de configuración previa que toda nuestra línea de cómputo.</p>
      <p class="showcase__text">Sus usos más frecuentes: <strong>control de accesos con lector de código QR</strong> en puertas y filtros, <strong>menús y catálogos digitales</strong> en activaciones y festivales gastronómicos, captura de leads en stands de expo y listas de asistencia en capacitaciones. Aceptan fundas rudas con correa de mano para el personal que opera de pie durante toda la jornada. Para el módulo de acreditación con impresión, se integran igual que los iPads con nuestras <a href="/servicios/computo/impresion-perifericos/">impresoras de gafetes</a>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M12 16h.01"/>
              <path d="M8 8h8M8 11h5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       KIOSCOS Y SOPORTES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="kioscos-heading">
    <div class="container">
      <ServiceShowcase
    title="Kioscos y Soportes Antirrobo"
    headingId="kioscos-heading"
    badge="Autoservicio seguro"
    subtitle="Pedestales, soportes de mostrador y montajes de pared con cerradura para módulos de autoservicio."
    tags={["Pedestal de piso", "Soporte de mostrador", "Cerradura de acero", "Carga oculta"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Kioscos"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>kiosco de autoservicio</strong> convierte un iPad o tablet en un módulo que trabaja solo: el asistente se registra, responde la encuesta o consulta el programa sin necesidad de personal dedicado. Nuestros <strong>soportes antirrobo de acero</strong> — pedestal de piso, soporte de mostrador o montaje de pared — fijan el dispositivo con cerradura, ocultan el cable de carga dentro de la estructura y mantienen la tablet conectada de forma permanente, eliminando el problema de la batería en jornadas largas.</p>
      <p class="showcase__text">El kiosco completo (dispositivo + soporte + configuración) renta <strong>desde $500 por día</strong>. Los pedestales aceptan <strong>rotulación con la gráfica de tu evento</strong> para integrarse al diseño del montaje, y su base ponderada les permite instalarse en cualquier superficie sin anclaje. Los puntos típicos: entrada del evento para check-in de pre-registrados, salida para encuesta de satisfacción, y zonas de exhibición para catálogos interactivos. Coordina la ubicación con nuestro <a href="/servicios/mobiliario/">mobiliario</a> para que el flujo de asistentes funcione desde el plano.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="8" y="2" width="8" height="12" rx="1"/>
              <path d="M12 14v6"/>
              <path d="M8 22h8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       VOTACIONES INTERACTIVAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="votaciones-heading">
    <div class="container">
      <ServiceShowcase
    title="Votaciones Interactivas y Encuestas en Vivo"
    headingId="votaciones-heading"
    badge="Resultados en tiempo real"
    subtitle="Flotas configuradas con plataforma de votación y la red que soporta a todos los dispositivos a la vez."
    tags={["Plataforma configurada", "Red dedicada", "Resultados en pantalla", "Asambleas y premiaciones"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Votaciones"
  >
    <Fragment slot="body">
      <p class="showcase__text">Las <strong>votaciones interactivas</strong> transforman una audiencia pasiva en participantes: asambleas que votan punto por punto, premiaciones donde el público decide, sesiones de preguntas donde los asistentes priorizan los temas. Configuramos la flota completa de iPads o tablets con la <strong>plataforma de votación o encuestas</strong> que tu evento use — o te recomendamos una según la dinámica — y montamos la <strong>red dedicada</strong> que soporta a todos los dispositivos conectados simultáneamente, con módem 4G/5G de respaldo.</p>
      <p class="showcase__text">Los resultados se proyectan <strong>en tiempo real en la pantalla principal</strong> del evento; si las <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> también son nuestras, la integración llega resuelta desde el montaje. Para asambleas con requisitos formales configuramos votación con registro por asistente, y en dinámicas ligeras de convención el mismo sistema opera encuestas anónimas. El servicio incluye prueba general con tu equipo de producción antes del evento — la votación en vivo no admite ensayo con público.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20V10M9 20V4M15 20v-8M21 20v-4"/>
              <path d="M2 20h20"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar iPads para eventos?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por día de evento (+IVA). Incluyen entrega, configuración y recolección en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$1,400",
          priceNote: "por día",
          description: "4 iPads con tu app configurada para mesa de bienvenida.",
          features: [
            { text: "4 iPads con app precargada", included: true },
            { text: "Modo kiosco activado", included: true },
            { text: "Soportes antirrobo", included: false },
            { text: "Red dedicada", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Registro",
          badge: "Más popular",
          highlight: true,
          price: "$3,650",
          priceNote: "por día",
          description: "10 iPads con descuento por volumen y respaldo incluido.",
          features: [
            { text: "10 iPads configurados", included: true },
            { text: "1 unidad de respaldo incluida", included: true },
            { text: "2 kioscos con pedestal", included: true },
            { text: "Soporte por WhatsApp", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Votación",
          price: "$7,200",
          priceNote: "por día",
          description: "Flota de votación con red dedicada y resultados en pantalla.",
          features: [
            { text: "20 iPads o tablets", included: true },
            { text: "Plataforma configurada", included: true },
            { text: "Red WiFi dedicada + respaldo 4G", included: true },
            { text: "Prueba general previa", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Congreso",
          price: "Cotizar",
          priceNote: "flotas de 30+ unidades",
          description: "Acreditación completa con iPads, gafetes y técnico en sitio.",
          features: [
            { text: "30+ dispositivos", included: true },
            { text: "Integración con impresión de gafetes", included: true },
            { text: "Técnico en sitio", included: true },
            { text: "Tarifa escalonada multi-día", included: true },
          ],
          ctaHref: "/cotizar/",
        },
      ]} />
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <h2 id="faq-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">Preguntas frecuentes sobre renta de iPads para eventos</h2>
    </div>
    <FaqSection items={faqs} serviceName="renta de iPads para eventos" />
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus iPads y Tablets"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de iPads y tablets en menos de 24 horas. Sin compromiso, sin costos ocultos.",
          "Ya sean dos iPads para la mesa de bienvenida o una flota de 30 para tu congreso, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Registro / Acreditación">Registro / Acreditación</option>
                <option value="Asamblea / Votación">Asamblea / Votación</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Activación de Marca">Activación de Marca</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoTablet">
                Tipo de equipo
              </label>
              <select id="tipoTablet" name="tipoTablet" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de equipo</option>
                <option value="iPad">iPad</option>
                <option value="iPad Pro">iPad Pro</option>
                <option value="Tablet Android">Tablet Android</option>
                <option value="Kiosco con Soporte Antirrobo">Kiosco con Soporte Antirrobo</option>
                <option value="Flota para Votaciones">Flota para Votaciones</option>
                <option value="Paquete con laptops e impresoras">Paquete con laptops e impresoras</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de dispositivos, app o plataforma que usarán, días de renta, venue del evento..."
