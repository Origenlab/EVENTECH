---
/**
 * ─── iPads y Tablets para Eventos — Página de Producto (L5) ───
 * Flotas de iPads, iPad Pro y tablets Android para check-in, encuestas,
 * votaciones interactivas y kioscos de autoservicio en eventos.
 * Homologada al Template-L5-producto (tiffany): componentes l3/l4, dorado #c2a24a,
 * galería showcase__gallery3, Acabados grid, 8 FAQs, título sin marca.
 * NOTA: sin reviews reales → serviceJsonLd (no se fabrican reseñas).
 * NOTA: sin fotos de producto de tablets en el repo → imágenes corporativas/AV con alt honesto.
 *
 * Jerarquía: Servicios > Cómputo > iPads y Tablets
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "iPads y Tablets" },
];

const acabados = [
  {
    name: "iPad para Check-in",
    price: "Desde $350/día",
    excerpt: "iPad de generación reciente con la app de tu evento precargada y modo kiosco activado. El estándar del check-in de asistentes, encuestas de satisfacción y firmas digitales.",
    href: "#ipads-heading",
    image: "/images/eventos/corporativos-hero.avif",
    tags: ["iPadOS actualizado", "Modo kiosco", "App precargada", "Desde $350/día"],
    badge: "Más solicitado",
  },
  {
    name: "Tablet Android",
    price: "Desde $350/día",
    excerpt: "Tablets Android de 10\" como alternativa flexible para captura de datos, menús digitales, control de accesos con lector QR y flotas grandes con presupuesto ajustado.",
    href: "#tablets-android-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ['Pantalla 10"', "Android actualizado", "Lector QR", "Ideal en volumen"],
  },
  {
    name: "Kiosco Antirrobo",
    price: "Desde $500/día",
    excerpt: "iPad o tablet montado en pedestal, mostrador o pared con soporte antirrobo de acero y carga oculta. Módulo de autoservicio listo para registro o encuestas.",
    href: "#kioscos-heading",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    tags: ["Pedestal / mostrador", "Cerradura de acero", "Carga continua", "Rotulación opcional"],
  },
  {
    name: "Flota para Votaciones",
    price: "Desde $7,200/día",
    excerpt: "Flota de iPads o tablets con plataforma de votación y encuestas, red dedicada y resultados proyectados en tiempo real. Asambleas, premiaciones y dinámicas de audiencia.",
    href: "#votaciones-heading",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    tags: ["Plataforma configurada", "Red dedicada", "Resultados en pantalla", "Prueba previa"],
  },
];

const specs = [
  { label: "Líneas", value: "iPad, iPad Pro 11\" y 12.9\", Tablet Android 10\", Kiosco antirrobo" },
  { label: "Sistema", value: "iPadOS actualizado / Android actualizado" },
  { label: "Pantalla", value: "10\" (Android) · 10.9\" (iPad) · 11\" y 12.9\" (iPad Pro)" },
  { label: "Modo kiosco", value: "Acceso guiado: el asistente solo ve la app de tu evento" },
  { label: "App / plataforma", value: "Registro, encuestas, votación o catálogo preinstalada y probada" },
  { label: "Conectividad", value: "WiFi del venue o red temporal dedicada + módem 4G/5G de respaldo" },
  { label: "Batería", value: "8–10 h de uso continuo · carga al 100% en la entrega" },
  { label: "Soportes y accesorios", value: "Pedestal, mostrador o pared con cerradura · fundas con correa · lector QR · Apple Pencil (Pro)" },
  { label: "Respaldo", value: "Unidades de reemplazo incluidas en pedidos de 10+" },
  { label: "Seguridad", value: "Localización remota + borrado de datos al devolver el equipo" },
];

const sidebarNav = [
  { name: "Laptops", href: "/servicios/computo/laptops/" },
  { name: "iPads y Tablets", href: null, active: true },
  { name: "PCs de Escritorio", href: "/servicios/computo/pcs-escritorio/" },
  { name: "Impresión y Periféricos", href: "/servicios/computo/impresion-perifericos/" },
];

const sidebarRelated = [
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Sonido para Eventos", href: "/servicios/audiovisual/sonido/" },
  { name: "Mobiliario para Módulos", href: "/servicios/mobiliario/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
];

const faqs = [
  { question: "¿Cuánto cuesta la renta de iPads y tablets para eventos en CDMX?", answer: 'Los iPads de generación reciente rentan <strong>desde $350 por día</strong> y los iPad Pro de 11" y 12.9" desde $600; las tablets Android de 10" parten de $350 y el kiosco completo con soporte antirrobo desde $500 por día. A partir de 10 unidades aplicamos descuentos por volumen que crecen con la cantidad y los días — el caso típico es una flota de 10 a 30 iPads para el check-in y las encuestas de un congreso. La entrega, la configuración de la app y la recolección están incluidas en CDMX y zona metropolitana, y la cotización llega en menos de 24 horas por WhatsApp.' },
  { question: "¿Los iPads llegan con la app de mi evento instalada?", answer: 'Sí. Antes de la entrega instalamos y probamos la aplicación que usará tu evento: plataformas de registro y check-in, apps de encuestas y votación, catálogos interactivos o formularios propios. Activamos el <strong>modo kiosco</strong> (acceso guiado), de manera que el asistente solo puede usar la app del evento y no sale a otras funciones del dispositivo. También configuramos la red WiFi del venue o nuestra red temporal, el brillo, el auto-bloqueo y todos los detalles para que la <strong>flota completa se comporte de forma idéntica</strong>. Es el mismo estándar de configuración de toda nuestra <a href="/servicios/computo/">línea de cómputo para eventos</a>.' },
  { question: "¿Cómo evitan que se roben o dañen las tablets en un evento público?", answer: "Con tres capas: <strong>soportes antirrobo de acero con cerradura</strong> para los módulos de autoservicio (pedestal, mostrador o pared), fundas resistentes con correa de mano para el personal que camina con la tablet, y localización remota activada en todas las unidades. En eventos masivos recomendamos concentrar los kioscos en zonas con personal cercano. La responsabilidad por robo o daño se define en el contrato de renta con montos por unidad conocidos desde la cotización — sin sorpresas posteriores." },
  { question: "¿Sirven para votaciones interactivas y encuestas en tiempo real?", answer: 'Es uno de sus usos principales. Configuramos la flota con la plataforma de <strong>votación o encuestas en vivo</strong> que elijas (o te recomendamos una según tu dinámica) y montamos la red que soporta a todos los dispositivos conectados a la vez, con módem 4G/5G de respaldo. Los resultados pueden proyectarse en tiempo real en la pantalla principal del evento; si rentas las pantallas o proyectores de nuestra <a href="/servicios/audiovisual/">línea audiovisual</a> con nosotros, la integración ya llega resuelta. Funciona para asambleas con voto registrado, dinámicas de audiencia en convenciones y evaluaciones en capacitaciones.' },
  { question: "¿Qué pasa con la batería en eventos de jornada completa?", answer: "Los iPads y tablets se entregan con carga al 100% y rinden entre <strong>8 y 10 horas</strong> de uso continuo de registro o encuestas. Para jornadas más largas incluimos cargadores y multicontactos para rotación de carga, y en los kioscos con soporte el cable va oculto dentro del pedestal, por lo que el dispositivo permanece conectado de forma permanente. En eventos de varios días el equipo puede quedarse resguardado en el venue y nuestro personal lo deja cargando en un espacio con acceso controlado." },
  { question: "¿Entregan, instalan y configuran los dispositivos en el venue?", answer: 'Sí. Entregamos, instalamos y probamos toda la flota en el venue antes de abrir puertas: encendido, conexión a la red, prueba de la app de registro o votación y verificación del modo kiosco en cada unidad. En los módulos de autoservicio dejamos los kioscos fijados y funcionando, y en las votaciones hacemos una prueba general con tu equipo de producción. Al finalizar, recogemos el equipo en el horario que acordemos, sin que tu equipo gestione la logística de devolución. Si tu evento también necesita <a href="/servicios/computo/laptops/">laptops</a> o impresión de gafetes, llega todo con un mismo proveedor.' },
  { question: "¿Con cuánta anticipación debo reservar los iPads?", answer: "Para flotas de hasta 10 unidades, una semana de anticipación es suficiente; para 20 a 50 unidades con app configurada y kioscos recomendamos 2 a 3 semanas, de modo que haya margen para las pruebas con tu plataforma de registro o votación. La reserva se confirma con el <strong>50% de anticipo</strong> y el resto contra entrega; puedes ajustar cantidades sin costo hasta 72 horas antes del evento y emitimos factura CFDI. En temporada alta de congresos (marzo–junio y septiembre–noviembre) los pedidos grandes conviene apartarlos con un mes." },
  { question: "¿Tienen cobertura fuera de la Ciudad de México?", answer: "Sí. Además de todas las alcaldías de CDMX, entregamos en zona metropolitana — Naucalpan, Huixquilucan, Tlalnepantla, Ecatepec, Neza — y en Toluca, Metepec, Querétaro, Puebla y Cuernavaca. Para sedes fuera de CDMX coordinamos la logística de entrega, configuración y recolección con la anticipación necesaria; el costo de transporte se especifica en la cotización según la distancia y el volumen de equipo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de iPads y Tablets para Eventos en CDMX",
    description: "Renta de iPads y tablets para eventos en CDMX: check-in de asistentes, encuestas, votaciones interactivas y kioscos con soporte antirrobo. App configurada y entrega en el venue. Desde $350/día.",
    url: "/servicios/computo/ipads-tablets/",
    image: "/images/eventos/corporativos-hero.avif",
    priceRange: { min: 350, max: 9000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "iPads y Tablets", url: "/servicios/computo/ipads-tablets/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de iPads y Tablets para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/eventos/corporativos-hero.avif"
  description="Renta de iPads y tablets para eventos en CDMX desde $350/día: check-in, encuestas, votaciones interactivas y kioscos antirrobo. App configurada y entrega en el venue."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Check-in sin filas, datos sin papel"
    title='Renta de <span class="highlight">iPads y Tablets</span> para Eventos en CDMX'
    subtitle="iPads, iPad Pro y tablets Android entregados con la app de tu evento precargada, modo kiosco activado y soportes antirrobo. Registro de asistentes, encuestas, votaciones interactivas y catálogos digitales."
    primaryCTA={{ label: "Cotiza tus iPads", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar renta de iPads y tablets para mi evento` }}
    cards={[
      {
        title: "La flota de tablets que tu registro necesita",
        content: "<strong>Renta de iPads para eventos</strong> desde $350 por día con la aplicación de tu evento instalada, probada y bloqueada en modo kiosco: el asistente solo ve tu app, nada más. iPad Pro para demostraciones premium, tablets Android para flotas grandes con presupuesto ajustado y kioscos con soporte antirrobo de acero para módulos de autoservicio. Toda la flota se configura de forma idéntica para que el check-in, la encuesta o la votación se comporten igual en cada dispositivo.",
      },
      {
        title: "Configuración, red y soporte incluidos",
        content: "<strong>Servicio completo para eventos en CDMX</strong>: configuramos la app y la red, entregamos e instalamos en el venue y dejamos la flota funcionando antes de abrir puertas. Cotización en menos de 24 horas por WhatsApp, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes del evento y factura CFDI. Cobertura en todas las alcaldías de CDMX y zona metropolitana — Naucalpan, Huixquilucan, Tlalnepantla, Toluca, Metepec y Cuernavaca — con descuentos por volumen desde 10 unidades.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Necesitas iPads para el check-in de tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con la cantidad, el modelo y los soportes ideales para tu registro o votación"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- 3. ACABADOS — 4 líneas (anclas on-page) -->
  <section class="section" aria-labelledby="tipos-heading">
    <div class="container">
      <SectionHeader
        id="tipos-heading"
        title="4 líneas de equipo — elige la tuya"
        subtitle="Del check-in de la entrada a la votación en vivo del auditorio"
        description={[
          "Desde un par de iPads para la mesa de bienvenida hasta una flota de 50 unidades para el registro de un congreso. Todas incluyen la app de tu evento configurada, modo kiosco, entrega e instalación en el venue y descuentos por volumen a partir de 10 unidades — la diferencia está en el dispositivo y el propósito."
        ]}
      />

      <div class="grid grid--4">
        {acabados.map((a) => (
          <ProductCard
            name={a.name}
            price={a.price}
            excerpt={a.excerpt}
            href={a.href}
            image={a.image}
            tags={a.tags}
            badge={a.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- MOBILE SIDEBAR (≤1024px) -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Cómputo para Eventos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas iPads para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar renta de iPads y tablets para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — iPads y Tablets para Eventos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: iPads para Registro y Check-in -->
          <section class="section" aria-labelledby="ipads-heading">
            <ServiceShowcase
              title="iPads para Registro y Check-in"
              headingId="ipads-heading"
              badge="El estándar de acreditación"
              subtitle="iPads con tu app de registro precargada y modo kiosco: el check-in que procesa asistentes en segundos."
              tags={["iPadOS actualizado", "Modo kiosco", "App configurada", "Desde $350/día"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar iPads"
            >
              <Fragment slot="body">
                <p class="showcase__text">El iPad es el dispositivo estándar del <strong>registro de asistentes</strong> por una razón simple: procesa un check-in en segundos, se opera con una sola mano y proyecta una imagen profesional en la mesa de bienvenida. Rentamos <strong>iPads de generación reciente desde $350 por día</strong> —y iPad Pro de 11" y 12.9" para demostraciones premium— entregados con tu plataforma de <strong>registro y acreditación</strong> precargada, el modo kiosco activado para que el asistente no salga de la app y la conexión de red configurada y probada en sitio.</p>
                <p class="showcase__text">Los mismos iPads resuelven <strong>encuestas de satisfacción, firmas digitales, formularios de contacto en stands y catálogos interactivos</strong> en expos. Para congresos armamos flotas de 10 a 50 unidades con configuración idéntica y unidades de respaldo incluidas. Combínalos con el <a href="/servicios/computo/impresion-perifericos/">módulo de impresión de gafetes</a> para una acreditación completa: el asistente hace check-in en el iPad y recibe su gafete impreso al instante.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/eventos/corporativos-hero.avif" alt="Recepción de evento corporativo con módulos de bienvenida y registro en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/eventos/corporativos/ejecutivo.avif" alt="Personal ejecutivo atendiendo a asistentes en un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/eventos/corporativos/teambuilding.avif" alt="Asistentes reunidos en la recepción de un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Tablets Android -->
          <section class="section" aria-labelledby="tablets-android-heading">
            <ServiceShowcase
              title="Tablets Android"
              headingId="tablets-android-heading"
              badge="Flexibilidad en volumen"
              subtitle="Tablets de 10 pulgadas para captura de datos, menús digitales y control de accesos con lector QR."
              tags={['Pantalla 10"', "Android actualizado", "Lector QR", "Ideal en flotas grandes"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Tablets Android"
            >
              <Fragment slot="body">
                <p class="showcase__text">Las <strong>tablets Android de 10 pulgadas</strong> son la alternativa flexible cuando la flota es grande y el presupuesto importa: la misma capacidad de captura de datos, formularios y check-in, con tarifas que hacen viable equipar 30 o 40 puntos simultáneos. Rentan <strong>desde $350 por día</strong> con Android actualizado, la app de tu evento instalada y el mismo nivel de configuración previa que toda nuestra línea de cómputo.</p>
                <p class="showcase__text">Sus usos más frecuentes: <strong>control de accesos con lector de código QR</strong> en puertas y filtros, <strong>menús y catálogos digitales</strong> en activaciones y festivales gastronómicos, captura de leads en stands y listas de asistencia en capacitaciones. Aceptan fundas rudas con correa de mano para el personal que opera de pie toda la jornada. Cuando el evento también necesita equipo de trabajo, se combinan con nuestras <a href="/servicios/computo/laptops/">laptops para eventos</a> bajo un mismo proveedor.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/blog/evento-corporativo-cdmx-produccion.avif" alt="Mesa de producción y captura de datos en un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/blog/tendencias-corporativos.avif" alt="Activación de marca en un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
