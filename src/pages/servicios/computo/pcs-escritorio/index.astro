---
/**
 * ─── PCs de Escritorio para Eventos — Página de Producto (L5) ───
 * Estaciones fijas: PC de oficina/All-in-One, workstations, gaming/render y diseño.
 * Homologada al Template-L5-producto (tiffany): componentes l3/l4, dorado #c2a24a,
 * galería showcase__gallery3, Acabados grid, 8 FAQs, título sin marca.
 * NOTA: sin reviews reales → serviceJsonLd (no se fabrican reseñas).
 * NOTA: sin fotos de producto en el repo → imágenes corporativas/AV con alt honesto.
 *
 * Jerarquía: Servicios > Cómputo > PCs de Escritorio
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "PCs de Escritorio" },
];

const acabados = [
  {
    name: "PC de Oficina / All-in-One",
    price: "Desde $600/día",
    excerpt: "Core i5, monitor de 22 a 24 pulgadas, teclado y mouse. La estación fija para captura, consulta, call centers y registro — también en formato All-in-One de un solo cable.",
    href: "#oficina-heading",
    image: "/images/eventos/corporativos/ejecutivo.avif",
    tags: ["Core i5 · 8 GB", 'Monitor 22-24"', "Windows 11 Pro", "All-in-One opcional"],
    badge: "Más solicitada",
  },
  {
    name: "Workstation",
    price: "Desde $900/día",
    excerpt: "Estación de trabajo Core i7/i9 con 16 a 32 GB de RAM y GPU dedicada para render, edición de video en sala de prensa y demostraciones de software exigente.",
    href: "#workstation-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ["Core i7/i9 · 16-32 GB", "GPU dedicada", "SSD 512 GB", "Doble monitor"],
  },
  {
    name: "PC Gaming / Render",
    price: "Desde $1,200/día",
    excerpt: "Equipos con GPU NVIDIA RTX de alto rendimiento para activaciones de marca, torneos, stands interactivos y render en tiempo real de experiencias inmersivas.",
    href: "#gaming-heading",
    image: "/images/eventos/corporativos/lanzamiento.avif",
    tags: ["GPU RTX", "Alto FPS", "VR / inmersivo", "Activaciones"],
  },
  {
    name: "Estación de Diseño",
    price: "Desde $1,000/día",
    excerpt: "Monitor calibrado de color preciso y periféricos de precisión para diseño gráfico, editorial y salas creativas de producción durante el evento.",
    href: "#diseno-heading",
    image: "/images/blog/tendencias-corporativos.avif",
    tags: ["Monitor calibrado", "Color preciso", "Suite Adobe", "Sala creativa"],
  },
];

const specs = [
  { label: "Líneas", value: "PC de Oficina/All-in-One, Workstation, PC Gaming/Render, Estación de Diseño" },
  { label: "Procesador", value: "Intel Core i5 / i7 / i9 · AMD Ryzen según la línea" },
  { label: "Memoria RAM", value: "8 GB (oficina) / 16–32 GB (workstation, render y diseño)" },
  { label: "Almacenamiento", value: "SSD 256 GB / 512 GB / 1 TB NVMe" },
  { label: "Tarjeta gráfica", value: "Integrada (oficina) / NVIDIA RTX dedicada (render, gaming, diseño)" },
  { label: "Monitor", value: '22" a 27"; doble monitor y panel calibrado disponibles' },
  { label: "Formato", value: "Torre + monitor o All-in-One todo-en-uno de un solo cable" },
  { label: "Sistema", value: "Windows 11 Pro · Linux o macOS bajo pedido" },
  { label: "Periféricos", value: "Teclado, mouse y cableado ordenado; diadema USB opcional" },
  { label: "Software", value: "Office, Adobe, CAD o CRM preinstalado, probado y con la misma imagen" },
  { label: "Energía", value: "Multicontacto regulado; planta de energía para sedes sin corriente estable" },
  { label: "Modalidad", value: "Renta por día, por evento, semanal o mensual" },
];

const sidebarNav = [
  { name: "Laptops", href: "/servicios/computo/laptops/" },
  { name: "iPads y Tablets", href: "/servicios/computo/ipads-tablets/" },
  { name: "PCs de Escritorio", href: null, active: true },
  { name: "Impresión y Periféricos", href: "/servicios/computo/impresion-perifericos/" },
];

const sidebarRelated = [
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Sonido para Eventos", href: "/servicios/audiovisual/sonido/" },
  { name: "Mobiliario para Módulos", href: "/servicios/mobiliario/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
];

const faqs = [
  { question: "¿Cuánto cuesta rentar una PC de escritorio para un evento en CDMX?", answer: 'La <strong>PC de oficina</strong> (Core i5, monitor de 22 a 24 pulgadas, teclado y mouse) renta <strong>desde $600 por día</strong>; el All-in-One de un solo cable arranca en el mismo rango, las <strong>workstations</strong> Core i7/i9 con GPU dedicada desde $900, las estaciones de <strong>gaming y render</strong> para activaciones desde $1,200 y las <strong>estaciones de diseño</strong> con monitor calibrado desde $1,000. A partir de 10 estaciones aplicamos descuentos por volumen — el caso típico del call center temporal o el centro de capacitación. Entrega, armado, cableado y recolección incluidos en CDMX y zona metropolitana, con cotización en menos de 24 horas. Conoce toda la <a href="/servicios/computo/">línea de cómputo para eventos</a>.' },
  { question: "¿Instalan las estaciones completas o solo entregan las cajas?", answer: "Instalamos todo: armamos cada estación en su mesa, conectamos monitor, teclado, mouse y red, <strong>ordenamos el cableado</strong> con canaletas o cinchos para que el área se vea profesional, y encendemos y probamos cada equipo antes de entregarte la operación. Si el pedido incluye software específico — CRM, marcadores telefónicos, suites de diseño o plataformas de captura — llega instalado y probado desde el almacén. Nuestro objetivo es que tu personal <strong>se siente y trabaje</strong>, no que arme computadoras. El desmontaje al finalizar también corre por nuestra cuenta." },
  { question: "¿PC de escritorio o laptop para mi evento?", answer: 'Depende de la operación. La <strong>PC de escritorio</strong> ofrece más pantalla, mejor ergonomía, más potencia por peso y operación continua sin depender de baterías: es la mejor opción para estaciones fijas — call centers, salas de prensa, salas de cómputo, render y diseño — que trabajan jornadas completas en un mismo lugar. Si en cambio necesitas movilidad, keynotes, registro itinerante o equipos que cambian de sala, la <a href="/servicios/computo/laptops/">renta de laptops para eventos</a> es más conveniente. Muchos montajes combinan ambas: PCs de escritorio para las posiciones fijas y laptops para ponentes y staff móvil. Te ayudamos a dimensionar la mezcla ideal.' },
  { question: "¿Pueden montar un call center o una sala de cómputo completa?", answer: "Sí, es uno de los usos más frecuentes de esta línea. Montamos <strong>filas de estaciones idénticas</strong> con PC, monitor, diadema telefónica USB y software de marcación o CRM precargado, con la red cableada o WiFi dimensionada para la operación completa — desde un <strong>call center temporal</strong> de campaña hasta una <strong>sala de cómputo</strong> para capacitación o un centro de censo. Coordinamos las mesas, sillas operativas y mamparas del mismo pedido y, para sedes sin infraestructura, la energía regulada de respaldo. Un call center de 20 posiciones se instala en un día y se retira el día que termina el proyecto, con renta semanal escalonada." },
  { question: "¿Qué requerimientos eléctricos necesitan las PCs?", answer: "Cada estación completa consume entre <strong>150 y 300 watts</strong>, por lo que un circuito estándar de 110V/15A soporta de 5 a 8 estaciones con seguridad. Para montajes grandes calculamos la distribución de cargas por circuito y llevamos multicontactos regulados con supresión de picos incluidos. Si el venue no garantiza energía estable — carpas, explanadas, sedes improvisadas — integramos <strong>plantas de energía</strong> silenciosas de nuestra línea de accesorios, con transferencia que protege los equipos ante cortes. La evaluación eléctrica previa del venue no tiene costo." },
  { question: "¿Entregan e instalan el equipo con el software listo en el venue?", answer: 'Sí. Entregamos, armamos y probamos cada estación en el venue antes de abrir puertas: encendido, conexión a red, prueba de doble monitor cuando aplica y verificación del <strong>software del evento</strong> ya instalado — Office, suites de Adobe, herramientas CAD, CRM o la plataforma de registro, con la misma imagen en todas las posiciones. Dejamos las estaciones conectadas y funcionando, y probamos la salida a <a href="/servicios/audiovisual/">proyectores y pantallas</a> cuando el equipo alimenta la señal del escenario. Al finalizar recogemos todo en el horario que acordemos, sin que tu equipo gestione la logística de devolución.' },
  { question: "¿Puedo rentar las PCs por semanas o meses para un proyecto?", answer: "Sí. Además de la renta por evento manejamos rentas <strong>semanales y mensuales</strong> para call centers de campaña, oficinas temporales, centros de censo o levantamiento de datos y proyectos con fecha de término. La tarifa baja de forma escalonada según la duración, el equipo permanece instalado en tu sede durante toda la vigencia y el <strong>soporte técnico</strong> se mantiene activo todo el periodo. La reserva se confirma con 50% de anticipo, los cambios no tienen costo hasta 72 horas antes del inicio y emitimos factura CFDI por el periodo completo." },
  { question: "¿Tienen cobertura fuera de la Ciudad de México?", answer: "Sí. Además de todas las alcaldías de CDMX, entregamos e instalamos en zona metropolitana — Naucalpan, Huixquilucan, Tlalnepantla, Ecatepec, Neza — y en Toluca, Metepec, Querétaro, Puebla y Cuernavaca. Para sedes fuera de CDMX coordinamos la logística de <strong>entrega, armado y recolección</strong> con la anticipación necesaria; el costo de transporte se especifica en la cotización según la distancia y el volumen de equipo. En operaciones de varias semanas mantenemos soporte técnico disponible durante toda la vigencia." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de PCs de Escritorio para Eventos en CDMX",
    description: "Renta de PCs de escritorio para eventos en CDMX: PCs de oficina y All-in-One, workstations, estaciones de gaming/render y diseño con software instalado, cableado y entrega en el venue. Desde $600/día.",
    url: "/servicios/computo/pcs-escritorio/",
    image: "/images/eventos/corporativos-hero.avif",
    priceRange: { min: 600, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "PCs de Escritorio", url: "/servicios/computo/pcs-escritorio/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de PCs de Escritorio para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/eventos/corporativos-hero.avif"
  description="Renta de PCs de escritorio para eventos en CDMX desde $600/día: oficina, workstations, render y diseño. Instalación y cableado incluidos en el venue."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Estaciones de escritorio para eventos"
    title='Renta de <span class="highlight">PCs de Escritorio</span> para Eventos en CDMX'
    subtitle="PCs de oficina y All-in-One, workstations, estaciones de gaming/render y salas de diseño entregadas armadas, con monitor, software instalado y cableado ordenado. Call centers temporales, salas de prensa, capacitación y activaciones de marca."
    primaryCTA={{ label: "Cotiza tus estaciones", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar renta de PCs de escritorio para mi evento` }}
    cards={[
      {
        title: "PCs de escritorio configuradas para cada operación",
        content: "<strong>Renta de PCs para eventos</strong> con cuatro líneas para cada necesidad: PC de oficina y All-in-One Core i5 con monitor de 22 a 24 pulgadas desde $600 por día para captura, consulta y call centers; workstations Core i7/i9 con GPU dedicada desde $900 para render y salas de prensa; estaciones de gaming/render para activaciones desde $1,200; y estaciones de diseño con monitor calibrado desde $1,000. Cada equipo sale del almacén armado, con el software de tu operación instalado y el cableado ordenado.",
      },
      {
        title: "Armado, cableado y respaldo incluidos",
        content: "<strong>Servicio completo para eventos en CDMX</strong>: armamos cada estación en su mesa, conectamos monitor, teclado, mouse y red, ordenamos el cableado y probamos el equipo antes de abrir puertas. En pedidos de 10 estaciones o más incluimos equipos de respaldo configurados sin costo. Cotización en menos de 24 horas por WhatsApp, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes y factura CFDI. Cobertura en todas las alcaldías de CDMX y zona metropolitana.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Necesitas una sala de cómputo o un call center para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con las estaciones, la red y la energía dimensionadas para tu operación"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- 3. ACABADOS — 4 líneas (anclas on-page) -->
  <section class="section" aria-labelledby="tipos-heading">
    <div class="container">
      <SectionHeader
        id="tipos-heading"
        title="4 líneas de equipo — elige la tuya"
        subtitle="De la estación de captura a la sala de render"
        description={[
          "Desde una PC de oficina para captura y call center hasta estaciones de render y diseño para producción y activaciones de marca. Todas incluyen software configurado, armado y cableado en el venue y descuentos por volumen a partir de 10 estaciones — la diferencia está en la potencia y el propósito."
        ]}
      />

      <div class="grid grid--4">
        {acabados.map((a) => (
          <ProductCard
            name={a.name}
            price={a.price}
            excerpt={a.excerpt}
            href={a.href}
            image={a.image}
            tags={a.tags}
            badge={a.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- MOBILE SIDEBAR (≤1024px) -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Cómputo para Eventos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas PCs para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar renta de PCs de escritorio para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — PCs de Escritorio para Eventos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: PC de Oficina / All-in-One -->
          <section class="section" aria-labelledby="oficina-heading">
            <ServiceShowcase
              title="PC de Oficina y All-in-One"
              headingId="oficina-heading"
              badge="La estación estándar del evento"
              subtitle="Core i5, monitor de 22 a 24 pulgadas y Windows 11 Pro: la estación fija que resuelve la mayoría del cómputo de un evento."
              tags={["Core i5 · 8 GB", 'Monitor 22-24"', "All-in-One opcional", "Desde $600/día"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar PCs de Oficina"
            >
              <Fragment slot="body">
                <p class="showcase__text">Nuestra <strong>PC de oficina</strong> es la estación de trabajo estándar para eventos: procesador Core i5, 8 GB de RAM, SSD y monitor de 22 a 24 pulgadas con teclado y mouse. Enciende en segundos, corre con fluidez las plataformas web de <strong>registro, captura y consulta</strong> y aguanta jornadas completas en call centers, mesas de inscripción y módulos de atención. En formato <strong>All-in-One</strong> integra CPU y pantalla en un solo cuerpo con un único cable a corriente, ideal para mostradores y puntos de cara al público donde el enredo de cables arruinaría el montaje.</p>
                <p class="showcase__text">Es también la base de las <strong>salas de cómputo y centros de capacitación</strong>: replicamos la misma imagen de software en todas las estaciones del pedido para que cada participante encuentre un entorno idéntico. Renta <strong>desde $600 por día</strong> con descuentos a partir de 10 estaciones, cableado ordenado y periféricos incluidos. Para módulos que también imprimen gafetes se integra con nuestra <a href="/servicios/computo/impresion-perifericos/">línea de impresión y periféricos</a>.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/eventos/corporativos/ejecutivo.avif" alt="Sala ejecutiva en evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/monitor-pantalla-presentacion-congreso.avif" alt="Pantalla de presentación en congreso corporativo" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/eventos/corporativos-hero.avif" alt="Montaje de evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Workstations -->
          <section class="section" aria-labelledby="workstation-heading">
            <ServiceShowcase
              title="Workstations y Estaciones de Render"
              headingId="workstation-heading"
              badge="Potencia profesional"
              subtitle="Core i7/i9, 16 a 32 GB de RAM y GPU dedicada para render, edición y demostraciones de software exigente."
              tags={["Core i7/i9 · 16-32 GB", "GPU dedicada", "Doble monitor", "Desde $900/día"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Workstations"
            >
              <Fragment slot="body">
                <p class="showcase__text">La <strong>workstation</strong> es la estación para trabajos que una PC estándar no mueve: <strong>edición de video y fotografía en salas de prensa</strong> que publican durante el evento, render de presentaciones 3D en lanzamientos inmobiliarios y automotrices, y demostraciones de <strong>software de ingeniería, arquitectura o diseño</strong> en expos técnicas. Core i7 o i9, 16 a 32 GB de RAM, gráficos NVIDIA dedicados y SSD NVMe, con configuración de <strong>doble monitor</strong> disponible para flujos de producción.</p>
                <p class="showcase__text">Renta <strong>desde $900 por día</strong> con el software profesional de tu operación instalado — desde suites de Adobe hasta herramientas CAD, con las licencias que tu equipo aporta activadas y probadas antes del evento. En cabinas de producción y streaming, la workstation opera como estación de switching y gráficos junto a nuestro <a href="/servicios/audiovisual/">equipo audiovisual completo</a>: pantallas, audio y video bajo el mismo proveedor y el mismo plan de montaje.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/blog/evento-corporativo-cdmx-produccion.avif" alt="Mesa de producción en evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
