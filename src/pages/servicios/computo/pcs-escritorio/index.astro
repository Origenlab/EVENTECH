---
/**
 * ─── PCs de Escritorio para Eventos — Subcategoría de Cómputo (L4) ───
 * Página especializada: Renta de PCs de Escritorio para Eventos en CDMX.
 * Color accent: Azul #2563eb (identidad de la línea de cómputo).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Cómputo", href: "/servicios/computo/" },
  { label: "PCs de Escritorio" },
];

const PCS = [
  {
    name: "PC de Escritorio Completa",
    price: "Desde $500/día",
    excerpt: "CPU Core i5 con monitor de 22 a 24 pulgadas, teclado, mouse y todo el cableado. La estación fija para captura, consulta y operación continua durante todo el evento.",
    href: "#reserva-heading",
    image: "/images/blog/evento-corporativo-cdmx-produccion.avif",
    tags: ["Core i5 · 8 GB", 'Monitor 22-24"', "Windows 11 Pro", "Teclado y mouse"],
    badge: "Más solicitada",
  },
  {
    name: "All-in-One",
    price: "Desde $700/día",
    excerpt: "Equipo todo-en-uno con pantalla integrada de 24 pulgadas: un solo cable a corriente, montaje en minutos y estética limpia para mostradores y módulos de cara al público.",
    href: "#reserva-heading",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    tags: ['Pantalla 24" integrada', "Un solo cable", "Montaje limpio", "Ideal en mostrador"],
  },
  {
    name: "Workstation",
    price: "Desde $900/día",
    excerpt: "Estación de trabajo Core i7 con 16 a 32 GB de RAM y gráficos dedicados para render, edición de video en sala de prensa y demostraciones de software exigente.",
    href: "#reserva-heading",
    image: "/images/eventos/corporativos-hero.avif",
    tags: ["Core i7 · 16-32 GB", "GPU dedicada", "SSD 512 GB", "Doble monitor opcional"],
  },
  {
    name: "Monitor Adicional",
    price: "Desde $250/día",
    excerpt: "Monitores de 22 a 27 pulgadas para segundas pantallas, señalización interna, monitoreo de producción o ampliar cualquier estación de trabajo del evento.",
    href: "#reserva-heading",
    image: "/images/carpas/carpa-estructural-grande-congreso.avif",
    tags: ['22" a 27"', "HDMI / DisplayPort", "Base ajustable", "Cableado incluido"],
  },
];

const faqs = [
  { question: "¿Cuánto cuesta rentar una PC de escritorio para un evento en CDMX?", answer: "La PC de escritorio completa (CPU Core i5, monitor de 22 a 24 pulgadas, teclado y mouse) renta desde $500 por día; el All-in-One con pantalla integrada desde $700, y las workstations Core i7 con gráficos dedicados desde $900 por día. Los monitores adicionales parten de $250. A partir de 10 estaciones aplicamos descuentos por volumen — el caso típico del call center temporal o el centro de capacitación. Entrega, instalación, cableado y recolección incluidos en CDMX y zona metropolitana, con cotización en menos de 24 horas por WhatsApp al 55 6432 8954." },
  { question: "¿Instalan las estaciones completas o solo entregan las cajas?", answer: "Instalamos todo: armamos cada estación en su mesa, conectamos monitor, teclado, mouse y red, ordenamos el cableado con canaletas o cinchos para que el área se vea profesional, y encendemos y probamos cada equipo antes de entregarte la operación. Si el pedido incluye software específico — CRM, marcadores telefónicos, plataformas de captura — llega instalado y probado desde el almacén. Nuestro objetivo es que tu personal se siente y trabaje, no que arme computadoras. El desmontaje al finalizar también es nuestro." },
  { question: "¿Pueden montar un call center temporal completo?", answer: "Sí, es uno de los usos más frecuentes de esta línea. Montamos filas de estaciones idénticas con PC, diadema telefónica USB, software de marcación o CRM precargado y la red cableada o WiFi dimensionada para la operación completa. Coordinamos con nuestro catálogo de mobiliario las mesas, sillas operativas y mamparas divisorias, y con la línea de accesorios la energía regulada y el respaldo eléctrico. Un call center de campaña de 20 posiciones se instala en un día y se retira el día que termina el proyecto, con renta semanal escalonada." },
  { question: "¿Qué requerimientos eléctricos necesitan las PCs?", answer: "Cada estación completa consume entre 150 y 300 watts, por lo que un circuito estándar de 110V/15A soporta de 5 a 8 estaciones con seguridad. Para montajes grandes calculamos la distribución de cargas por circuito y llevamos multicontactos regulados con supresión de picos incluidos. Si el venue no garantiza energía estable — carpas, explanadas, sedes improvisadas — integramos plantas de energía silenciosas de nuestra línea de accesorios, con transferencia que protege los equipos ante cortes. La evaluación eléctrica previa del venue no tiene costo." },
  { question: "¿Puedo rentar las PCs por semanas o meses para un proyecto?", answer: "Sí. Además de la renta por evento manejamos rentas semanales y mensuales para call centers de campaña, oficinas temporales, centros de censo o levantamiento de datos y proyectos con fecha de término. La tarifa baja de forma escalonada según la duración, el equipo permanece instalado en tu sede durante toda la vigencia y el soporte técnico se mantiene activo todo el periodo. La reserva se confirma con 50% de anticipo, los cambios no tienen costo hasta 72 horas antes del inicio y emitimos factura CFDI por el periodo completo." },
  { question: "¿Con cuánta anticipación debo reservar las estaciones de trabajo?", answer: "Para pedidos de hasta 10 estaciones, una semana de anticipación es suficiente. Para call centers y centros de capacitación de 20 a 50 posiciones recomendamos 2 a 3 semanas, que dan margen para la configuración de software, la evaluación eléctrica del sitio y el plan de cableado. Los montajes con workstation y doble monitor para salas de prensa de congresos conviene apartarlos con un mes en temporada alta (marzo–junio y septiembre–noviembre). También atendemos urgencias sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de PCs de Escritorio para Eventos CDMX",
    description: "Renta de PCs de escritorio, All-in-One y workstations para eventos: call centers temporales, salas de prensa y capacitación. Instalación completa incluida en CDMX.",
    url: "/servicios/computo/pcs-escritorio/",
    priceRange: { min: 250, max: 10000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Cómputo", url: "/servicios/computo/" },
    { name: "PCs de Escritorio", url: "/servicios/computo/pcs-escritorio/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de PCs de Escritorio para Eventos CDMX"
  description="Renta de PCs de escritorio para eventos en CDMX desde $500/día: All-in-One, workstations y monitores. Call centers, prensa y capacitación. Instalación incluida."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Estaciones fijas de trabajo"
    title='Renta de <span class="highlight">PCs de Escritorio</span> para Eventos en CDMX'
    subtitle="PCs completas, All-in-One y workstations con monitor, teclado y cableado ordenado para call centers temporales, salas de prensa y centros de capacitación."
    primaryCTA={{ label: "Cotiza tus estaciones", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar renta de PCs de escritorio para mi evento` }}
    cards={[
      {
        title: "Estaciones de trabajo completas, no cajas por armar",
        content: "<strong>Renta de computadoras para eventos CDMX</strong> en formato de estación fija: PC completa con monitor de 22 a 24 pulgadas desde $500 por día, All-in-One de montaje limpio desde $700 y workstations Core i7 con gráficos dedicados desde $900. Cada estación llega armada, conectada, con el software de tu operación instalado y el cableado ordenado con canaletas. Tu personal se sienta y trabaja desde el primer minuto — nosotros armamos, probamos y desmontamos.",
      },
      {
        title: "Del call center temporal a la sala de prensa",
        content: "<strong>Montajes completos para eventos CDMX</strong>: filas de estaciones idénticas con diadema y CRM para call centers de campaña, estaciones con doble monitor y conexión cableada para salas de prensa de congresos, y centros de capacitación con la misma imagen de software en cada posición. Cotización en menos de 24 horas, reserva con 50% de anticipo, cambios sin costo hasta 72 horas antes, factura CFDI y cobertura en toda CDMX, Naucalpan, Huixquilucan, Tlalnepantla, Toluca, Metepec y Cuernavaca.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas estaciones de trabajo para tu operación temporal?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con las estaciones, la red y la energía dimensionadas para tu proyecto"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de PCs de Escritorio"
        subtitle="Estaciones fijas para operaciones que trabajan jornadas completas"
        description={[
          "Cuando la estación no se mueve durante el evento, la PC de escritorio ofrece más pantalla, mejor ergonomía y operación continua sin depender de baterías. Es la base de call centers temporales, salas de prensa y centros de capacitación.",
          "Cada estación incluye entrega, armado completo, instalación de software, prueba de funcionamiento y recolección. Con descuentos por volumen a partir de 10 posiciones."
        ]}
      />

      <div class="grid grid--4">
        {PCS.map((equipo) => (
          <ProductCard
            name={equipo.name}
            price={equipo.price}
            excerpt={equipo.excerpt}
            href={equipo.href}
            image={equipo.image}
            tags={equipo.tags}
            badge={equipo.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ALL-IN-ONE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="aio-heading">
    <div class="container">
      <ServiceShowcase
    title="All-in-One"
    headingId="aio-heading"
    badge="Montaje limpio"
    subtitle="Pantalla, CPU y bocinas en un solo cuerpo: la estación que se instala en minutos y se ve bien de frente al público."
    tags={["Pantalla 24\" integrada", "Un solo cable", "Windows 11 Pro", "Desde $700/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar All-in-One"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>All-in-One</strong> integra CPU, pantalla de 24 pulgadas y bocinas en un solo cuerpo con un único cable a corriente. Eso lo convierte en la estación ideal para los puntos <strong>de cara al público</strong>: mostradores de informes, módulos de atención, recepciones de evento y mesas de acreditación donde el asistente ve el equipo de frente y el enredo de cables arruinaría la presentación del montaje.</p>
      <p class="showcase__text">Renta <strong>desde $700 por día</strong> con Windows 11 Pro, el software de tu operación precargado y teclado y mouse inalámbricos para mantener la superficie despejada. Su montaje toma minutos, lo que lo hace especialmente útil en eventos con tiempos de acceso al venue reducidos. Para módulos de registro con impresión de gafetes se integra directamente con nuestra <a href="/servicios/computo/impresion-perifericos/">línea de impresión y periféricos</a>, y con el <a href="/servicios/mobiliario/">mobiliario de mostrador</a> del mismo pedido.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="13" rx="2"/>
              <path d="M9 21h6"/>
              <path d="M12 16v5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       WORKSTATIONS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="workstation-heading">
    <div class="container">
      <ServiceShowcase
    title="Workstations"
    headingId="workstation-heading"
    badge="Potencia profesional"
    subtitle="Core i7, 16 a 32 GB de RAM y gráficos dedicados para render, edición y demostraciones de software exigente."
    tags={["Core i7 · 16-32 GB", "GPU dedicada", "Doble monitor", "Desde $900/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Workstations"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>workstation</strong> es la estación para trabajos que una PC estándar no mueve: <strong>edición de video y fotografía en salas de prensa</strong> que publican durante el evento, render de presentaciones 3D en lanzamientos inmobiliarios y automotrices, y <strong>demostraciones de software de ingeniería, arquitectura o diseño</strong> en expos técnicas. Core i7, 16 a 32 GB de RAM, gráficos dedicados y SSD de 512 GB, con configuración de <strong>doble monitor</strong> disponible para flujos de trabajo de producción.</p>
      <p class="showcase__text">Renta <strong>desde $900 por día</strong> con el software profesional de tu operación instalado — desde suites de Adobe hasta herramientas CAD, con las licencias que tu equipo aporta activadas y probadas antes del evento. En cabinas de producción y streaming, la workstation opera como estación de switching y gráficos junto a nuestro <a href="/servicios/audiovisual/">equipo audiovisual completo</a>: pantallas, audio y video bajo el mismo proveedor y el mismo plan de montaje.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="13" height="10" rx="1"/>
              <rect x="17" y="7" width="5" height="14" rx="1"/>
              <path d="M5 18h7"/>
              <path d="M8.5 14v4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CALL CENTERS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="call-center-heading">
    <div class="container">
      <ServiceShowcase
    title="Call Centers Temporales"
    headingId="call-center-heading"
    badge="Operación completa"
    subtitle="Filas de estaciones idénticas con diadema, CRM y red dimensionada para campañas y proyectos con fecha de término."
    tags={["Estaciones idénticas", "Diadema USB", "CRM precargado", "Renta semanal"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Call Center"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>call center temporal</strong> es el montaje donde esta línea muestra todo su valor: campañas electorales y de recaudación, ventas de temporada, mesas de ayuda de grandes eventos y centros de atención post-incidente necesitan de 10 a 50 posiciones operando en días, no en meses. Montamos <strong>filas de estaciones idénticas</strong> — PC, monitor, diadema telefónica USB con cancelación de ruido y el software de marcación o CRM precargado — con la red cableada o inalámbrica dimensionada para la operación simultánea completa.</p>
      <p class="showcase__text">La renta es <strong>por semana con tarifa escalonada</strong>: un call center de 20 posiciones se instala en un día, opera las semanas que dure el proyecto y se retira el día que termina, sin inversión en activos que después sobran. Coordinamos <a href="/servicios/mobiliario/mesas/">mesas y sillas operativas</a> del mismo pedido y, para sedes sin infraestructura, <a href="/servicios/accesorios/plantas-energia/">energía regulada de respaldo</a> que protege la operación ante cortes. Un solo proveedor y una sola instalación para toda la operación.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 11a9 9 0 0 1 18 0"/>
              <rect x="2" y="11" width="4" height="7" rx="1.5"/>
              <rect x="18" y="11" width="4" height="7" rx="1.5"/>
              <path d="M21 18a3 3 0 0 1-3 3h-4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MONITORES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="monitores-heading">
    <div class="container">
      <ServiceShowcase
    title="Monitores y Pantallas de Apoyo"
    headingId="monitores-heading"
    badge="La segunda pantalla que faltaba"
    subtitle="Monitores de 22 a 27 pulgadas para doble pantalla, monitoreo de producción y señalización interna."
    tags={["22\" a 27\"", "HDMI / DisplayPort", "Base ajustable", "Desde $250/día"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Monitores"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>monitores adicionales</strong> de 22 a 27 pulgadas resuelven las necesidades de pantalla que aparecen alrededor de toda operación de evento: la <strong>segunda pantalla</strong> de la estación de producción que monitorea la señal de programa, el monitor de confianza del ponente al pie del escenario, la pantalla de la cabina de traducción y el display de estatus en la oficina de coordinación del venue.</p>
      <p class="showcase__text">Rentan <strong>desde $250 por día</strong> con entradas HDMI y DisplayPort, base ajustable en altura e inclinación y todo el cableado incluido. Se agregan a cualquier estación de nuestra línea de cómputo o se conectan a tu propio equipo. Para pantallas de gran formato de cara al público — bienvenida, agenda del congreso, señalización de salas — el salto natural es nuestra línea de <a href="/servicios/audiovisual/pantallas-led/">pantallas LED y videowalls</a>, que se cotiza en el mismo pedido con la misma logística de entrega.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar PCs de escritorio para eventos?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por día de evento (+IVA). Incluyen entrega, armado completo y recolección en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$2,500",
          priceNote: "por día",
          description: "5 estaciones completas para módulos de captura o consulta.",
          features: [
            { text: "5 PCs con monitor 22\"", included: true },
            { text: "Software configurado", included: true },
            { text: "Diademas telefónicas", included: false },
            { text: "Técnico en sitio", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Call Center",
          badge: "Más popular",
          highlight: true,
          price: "$4,500",
          priceNote: "por día",
          description: "10 posiciones con diadema, CRM y descuento por volumen.",
          features: [
            { text: "10 estaciones idénticas", included: true },
            { text: "Diademas USB incluidas", included: true },
            { text: "Red dimensionada", included: true },
            { text: "Tarifa semanal escalonada", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Sala de Prensa",
          price: "$7,800",
          priceNote: "por día",
          description: "Estaciones de trabajo y workstations para medios en congresos.",
          features: [
            { text: "8 PCs + 2 workstations", included: true },
            { text: "Doble monitor en workstations", included: true },
            { text: "Red cableada de alta velocidad", included: true },
            { text: "Técnico en sitio", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Proyecto",
          price: "Cotizar",
          priceNote: "rentas semanales y mensuales",
          description: "20+ posiciones para campañas y operaciones temporales.",
          features: [
            { text: "20+ estaciones", included: true },
            { text: "Tarifa semanal / mensual", included: true },
            { text: "Energía regulada de respaldo", included: true },
            { text: "Soporte durante todo el periodo", included: true },
          ],
          ctaHref: "/cotizar/",
        },
      ]} />
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <h2 id="faq-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">Preguntas frecuentes sobre renta de PCs para eventos</h2>
    </div>
    <FaqSection items={faqs} serviceName="renta de PCs de escritorio para eventos" />
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Estaciones de Trabajo"
        subtitle="Cuéntanos sobre tu operación y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento o proyecto y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de estaciones de trabajo en menos de 24 horas. Sin compromiso, sin costos ocultos.",
          "Ya sean 5 PCs para un módulo de captura o un call center de 30 posiciones por dos meses, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de operación
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Call Center Temporal">Call Center Temporal</option>
                <option value="Sala de Prensa">Sala de Prensa</option>
                <option value="Centro de Capacitación">Centro de Capacitación</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Registro / Acreditación">Registro / Acreditación</option>
                <option value="Oficina Temporal">Oficina Temporal</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha de inicio
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoPc">
                Tipo de equipo
              </label>
              <select id="tipoPc" name="tipoPc" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de equipo</option>
                <option value="PC de Escritorio Completa">PC de Escritorio Completa</option>
                <option value="All-in-One">All-in-One</option>
                <option value="Workstation">Workstation</option>
                <option value="Monitores Adicionales">Monitores Adicionales</option>
                <option value="Call Center Completo">Call Center Completo (PC + diadema + CRM)</option>
                <option value="Combinación de equipos">Combinación de equipos</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de estaciones, software que deben correr, duración (días/semanas), sede de la operación..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Evaluación técnica gratis</h3>
            <p class="reserva-card__text">Evaluamos la instalación eléctrica y la conectividad de tu sede sin costo para dimensionar el montaje correcto.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Cambios sin costo hasta 72 horas antes del inicio y factura CFDI disponible.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const tipoPc = document.getElementById('tipoPc').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — PCs de Escritorio para Eventos*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de operación:* ${tipoEvento}\n`;
      texto += `*Fecha de inicio:* ${fechaTexto}\n`;
      if (tipoPc) texto += `*Tipo de equipo:* ${tipoPc}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Estaciones de trabajo listas el día que tu operación arranca"
    subheadline="PCs, All-in-One y workstations armadas, conectadas y con software instalado. Cotiza hoy y recibe asesoría sin compromiso."
    primaryCTA={{ label: "Cotizar estaciones", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar renta de PCs de escritorio para mi evento` }}
    variant="accent"
  />
</PageLayout>

