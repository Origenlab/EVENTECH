---
/**
 * ─── Calefaccion y Clima para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Calefacción y Clima para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Calefacción y Clima" },
];

const CLIMA = [
  {
    name: "Calentadores de Patio",
    excerpt: "Calentadores de propano tipo hongo y pirámide con radio de calor de 4-5 metros. Diseño elegante para terrazas, jardines y eventos al aire libre en noches frías.",
    cta: "Calentadores",
    href: "#calentadores-heading",
    icon: "heart",
  },
  {
    name: "Calefacción Industrial",
    excerpt: "Calentadores radiantes y de aire forzado para carpas, hangares y espacios de 50 a 500 m². Potencia industrial para mantener grandes áreas a temperatura confortable.",
    cta: "Industrial",
    href: "#industrial-heading",
    icon: "shield",
  },
  {
    name: "Nebulización y Ventilación",
    excerpt: "Ventiladores nebulizadores y enfriadores evaporativos para eventos de verano. Reducen la temperatura hasta 12°C en espacios abiertos y semi-abiertos.",
    cta: "Nebulización",
    href: "#nebulizacion-heading",
    icon: "layers",
  },
  {
    name: "Aire Acondicionado Portátil",
    excerpt: "Unidades de AC portátil de 2 a 20 toneladas con sistemas ducteados para carpas y salones temporales. Operación silenciosa y control de temperatura exacto.",
    cta: "AC Portátil",
    href: "#ac-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué tipo de calefacción necesito según el tamaño de mi carpa?", answer: "Para carpas pequeñas de hasta 50 m² recomendamos 2 a 3 calentadores de patio tipo hongo distribuidos estratégicamente. Para carpas medianas de 50 a 150 m² lo ideal es calefacción radiante con 2 a 4 unidades colgadas del techo de la carpa. Para carpas grandes de 150 a 500 m² recomendamos sistemas de aire forzado industrial con ductos que distribuyen el calor uniformemente. Nuestro equipo técnico evalúa las dimensiones, altura y material de tu carpa para diseñar la solución óptima con la menor cantidad de equipo." },
  { question: "¿Es seguro usar calentadores de propano en eventos?", answer: "Absolutamente. Nuestros calentadores de propano cuentan con certificación de seguridad, válvula anti-vuelco que apaga automáticamente la llama si el equipo se inclina, sensor de oxígeno para exteriores y base de contrapeso estabilizado. Cada calentador incluye tanque de propano certificado y conexiones verificadas antes de cada evento. Nuestro técnico supervisa la instalación, verifica la ventilación del espacio y permanece disponible durante todo el evento. Se recomienda mantener una distancia mínima de 1 metro entre el calentador y cualquier material inflamable." },
  { question: "¿Cuánta agua consumen los sistemas de nebulización?", answer: "Los ventiladores nebulizadores consumen entre 2 y 6 litros de agua por hora dependiendo del modelo y la intensidad de nebulización seleccionada. Un enfriador evaporativo industrial consume entre 10 y 20 litros por hora. Para un evento de 8 horas con 4 nebulizadores, el consumo total aproximado es de 100 a 200 litros. Proporcionamos tanques de reserva y conexión a toma de agua cuando está disponible. El consumo eléctrico es mínimo ya que solo alimenta el ventilador y la bomba de presión." },
  { question: "¿Qué requerimientos eléctricos necesita el aire acondicionado portátil?", answer: "Las unidades de 2 toneladas requieren una conexión de 220V/30A monofásica. Las de 5 toneladas necesitan 220V/60A. Las unidades grandes de 10 a 20 toneladas requieren conexión trifásica de 440V. Si tu venue no cuenta con la capacidad eléctrica necesaria, incluimos plantas de energía dimensionadas para alimentar los equipos de clima. Todos los cables, conectores y protecciones eléctricas están incluidos en el servicio. Nuestro técnico evalúa la infraestructura eléctrica del venue antes del evento." },
  { question: "¿Se pueden combinar calefacción y enfriamiento en zonas diferentes del mismo evento?", answer: "Sí, es una de nuestras configuraciones más solicitadas para eventos de temporada intermedia. Por ejemplo, calentadores de patio en la terraza exterior y aire acondicionado en la carpa principal, o nebulización en el área de baile al aire libre y calefacción en la zona lounge cubierta. Diseñamos un plano de climatización por zonas para que cada área de tu evento tenga la temperatura ideal. La clave es separar las zonas con barreras físicas (paredes de carpa, cortinas industriales) para maximizar la eficiencia." },
  { question: "¿Con cuánta anticipación debo reservar equipo de climatización?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta de frío (noviembre a febrero) para calefacción y en verano (abril a septiembre) para sistemas de enfriamiento. Los equipos de aire acondicionado portátil de alta capacidad (10+ toneladas) son los más solicitados y conviene apartarlos con 3 a 6 semanas. Para eventos de último momento, contamos con inventario de emergencia disponible sujeto a disponibilidad. Nuestro equipo técnico realiza una visita previa para dimensionar correctamente tu instalación." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Calefacción y Clima para Eventos en CDMX",
    description: "Calentadores de patio, calefacción industrial, nebulización y aire acondicionado portátil para eventos. Instalación y técnico incluidos.",
    url: "/servicios/accesorios/calefaccion-clima/",
    priceRange: { min: 800, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Calefacción y Clima", url: "/servicios/accesorios/calefaccion-clima/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Calefacción y Clima para Eventos en CDMX"
  description="Renta de calentadores de patio, calefacción industrial, nebulización y aire acondicionado portátil para eventos en CDMX. Técnico incluido. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Confort térmico garantizado"
    title='Renta de <span class="highlight">Calefacción y Clima</span> para Eventos en CDMX'
    subtitle="Calentadores de patio, calefacción industrial, nebulización y aire acondicionado portátil para que tus invitados disfruten la temperatura perfecta en cualquier temporada."
    primaryCTA={{ label: "Cotiza tu clima", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar calefacción y clima para mi evento` }}
    cards={[
      {
        title: "Climatización profesional para cada evento y temporada",
        content: "<strong>Renta de calefacción y clima para eventos</strong> con los equipos más avanzados disponibles en CDMX. Calentadores de patio tipo hongo y pirámide con radio de calor de 4 a 5 metros para bodas y cenas al aire libre en noches frías. Calefacción industrial radiante y de aire forzado para carpas y hangares de 50 a 500 m². Nebulizadores y enfriadores evaporativos que reducen hasta 12°C la temperatura en eventos de verano. Aire acondicionado portátil de 2 a 20 toneladas con ductos para carpas y salones temporales — cada equipo verificado y calibrado antes de cada entrega.",
      },
      {
        title: "Instalación técnica con monitoreo dedicado",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de equipos de climatización. Nuestro ingeniero de clima evalúa las dimensiones de tu venue, calcula la carga térmica necesaria, instala los equipos con conexiones eléctricas y de gas certificadas, y monitorea la temperatura durante todo el evento. Tanques de propano de respaldo, generadores de apoyo y plan de contingencia incluidos para garantizar confort ininterrumpido sin importar las condiciones climáticas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas temperatura perfecta en tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con la solución de clima ideal para tu espacio y temporada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de clima
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Calefacción y Clima"
        subtitle="La solución térmica perfecta para cada tipo de evento"
        description={[
          "Desde calentadores de patio para cenas íntimas al aire libre hasta sistemas de aire acondicionado industrial para carpas de gran formato. Contamos con el inventario de climatización más completo de la Ciudad de México.",
          "Cada equipo incluye instalación profesional, conexiones certificadas y técnico de operación dedicado. Temperatura controlada y confort garantizado para que tus invitados disfruten sin preocupaciones."
        ]}
      />

      <div class="grid grid--4">
        {CLIMA.map((item) => (
          <Card
            name={item.name}
            excerpt={item.excerpt}
            cta={item.cta}
            href={item.href}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CALENTADORES DE PATIO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="calentadores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Confort al aire libre</span>
          <h2 class="showcase__title" id="calentadores-heading">Calentadores de Patio</h2>
          <p class="showcase__subtitle">La solución elegante para mantener el calor en terrazas, jardines y eventos nocturnos al aire libre.</p>
          <p class="showcase__text">Nuestros <strong>calentadores de patio a propano</strong> están disponibles en dos estilos profesionales: <strong>tipo hongo (mushroom) y tipo pirámide</strong> con llama visible. Cada unidad genera un radio de calor efectivo de <strong>4 a 5 metros</strong>, suficiente para cubrir una mesa de 8 a 10 personas con confort. Fabricados en acero inoxidable con acabado en bronce, negro mate o plateado, su diseño elegante complementa la decoración de <strong>bodas, cenas de gala, cocteles y recepciones al aire libre</strong>.</p>
          <p class="showcase__text">Incluyen <strong>tanque de propano de 10 kg con regulador certificado</strong>, encendido electrónico piezoeléctrico, válvula anti-vuelco de seguridad y base de contrapeso estabilizado. Cada calentador opera durante 8 a 10 horas continuas con un solo tanque. Para eventos largos, proporcionamos tanques de repuesto. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario premium de exterior</a> como salas lounge y mesas altas para crear zonas de confort irresistibles en noches frías.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Tipo Hongo</span>
            <span class="showcase__tag">Tipo Pirámide</span>
            <span class="showcase__tag">Radio 4-5 m</span>
            <span class="showcase__tag">Acero Inoxidable</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Calentadores de Patio
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4"/>
              <path d="M6.8 6.8l2.8 2.8"/>
              <path d="M2 12h4"/>
              <path d="M6.8 17.2l2.8-2.8"/>
              <path d="M12 18v4"/>
              <path d="M17.2 17.2l-2.8-2.8"/>
              <path d="M22 12h-4"/>
              <path d="M17.2 6.8l-2.8 2.8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CALEFACCIÓN INDUSTRIAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="industrial-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Grandes espacios</span>
          <h2 class="showcase__title" id="industrial-heading">Calefacción Industrial</h2>
          <p class="showcase__subtitle">Potencia térmica para carpas, hangares y espacios de gran formato desde 50 hasta 500 m².</p>
          <p class="showcase__text">Nuestros <strong>sistemas de calefacción industrial</strong> están diseñados para climatizar grandes espacios en eventos. Los <strong>calentadores radiantes</strong> se instalan colgados del techo de la carpa o estructura, distribuyendo calor infrarrojo uniforme sin corrientes de aire, ideales para <strong>carpas árabes y estructurales de 50 a 200 m²</strong>. Los <strong>calentadores de aire forzado</strong> generan grandes volúmenes de aire caliente a través de ductos, cubriendo <strong>hangares y naves de 200 a 500 m²</strong> con temperatura homogénea.</p>
          <p class="showcase__text">Cada sistema incluye <strong>termostato digital de control automático</strong>, ductos de distribución de aire caliente, conexiones de gas certificadas y silenciadores para minimizar el ruido. Operan con gas LP o gas natural según disponibilidad del venue. Nuestro técnico programa la temperatura deseada y el sistema mantiene el confort de forma automática durante todo el evento. Complementa con nuestras <a href="/servicios/carpas/">carpas estructurales</a> con paredes laterales para maximizar la retención de calor y crear espacios totalmente cerrados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Radiante</span>
            <span class="showcase__tag">Aire Forzado</span>
            <span class="showcase__tag">50-500 m²</span>
            <span class="showcase__tag">Termostato Digital</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Calefacción Industrial
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="6" width="20" height="12" rx="2"/>
              <path d="M6 12h.01"/>
              <path d="M10 12h.01"/>
              <path d="M14 12h.01"/>
              <path d="M18 12h.01"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       NEBULIZACIÓN Y VENTILACIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="nebulizacion-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Frescura en verano</span>
          <h2 class="showcase__title" id="nebulizacion-heading">Nebulización y Ventilación</h2>
          <p class="showcase__subtitle">Enfriamiento natural para eventos al aire libre en temporada de calor con tecnología de micro-goteo.</p>
          <p class="showcase__text">Nuestros <strong>ventiladores nebulizadores</strong> combinan ventilación de alto flujo con micro-nebulización de agua que reduce la temperatura ambiente hasta <strong>12°C en espacios abiertos</strong>. Disponibles en formato pedestal (cobertura individual de 20-30 m²) e industrial (cobertura de 50-80 m²). Los <strong>enfriadores evaporativos</strong> utilizan paneles de celulosa saturados con agua para enfriar el aire de forma natural y ecológica, ideales para <strong>jardines, terrazas, ferias y eventos al aire libre</strong> durante los meses de calor intenso.</p>
          <p class="showcase__text">Los <strong>ventiladores industriales de alto volumen</strong> (HVLS) de 3 a 7 metros de diámetro generan una brisa suave que cubre áreas de hasta 1,000 m² con mínimo consumo eléctrico. Perfectos para <strong>hangares, bodegas evento y espacios semi-abiertos</strong>. Cada equipo incluye tanque de agua, bomba de presión, filtros y conexiones. Nuestro técnico calibra la intensidad de nebulización según la humedad ambiente para evitar condensación. Combínalos con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para crear ambientes frescos y visualmente espectaculares.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Nebulizadores</span>
            <span class="showcase__tag">Evaporativos</span>
            <span class="showcase__tag">Ventiladores HVLS</span>
            <span class="showcase__tag">Hasta -12°C</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Nebulización
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9.59 4.59A2 2 0 1 1 11 8H2"/>
              <path d="M12.59 19.41A2 2 0 1 0 14 16H2"/>
              <path d="M17.73 7.73A2.5 2.5 0 1 1 19.5 12H2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       AIRE ACONDICIONADO PORTÁTIL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="ac-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Temperatura exacta</span>
          <h2 class="showcase__title" id="ac-heading">Aire Acondicionado Portátil</h2>
          <p class="showcase__subtitle">Control preciso de temperatura con unidades portátiles de 2 a 20 toneladas para carpas y salones temporales.</p>
          <p class="showcase__text">Nuestras <strong>unidades de aire acondicionado portátil</strong> ofrecen climatización de precisión con capacidades desde <strong>2 hasta 20 toneladas de refrigeración</strong>. Las unidades compactas de 2 a 5 toneladas son ideales para <strong>carpas de 30 a 100 m²</strong>, mientras que los sistemas de 10 a 20 toneladas cubren <strong>carpas de gran formato, hangares y salones temporales de hasta 500 m²</strong>. Cada unidad cuenta con termostato digital, control remoto y operación silenciosa que no interfiere con la música ni las conversaciones.</p>
          <p class="showcase__text">Incluyen <strong>sistemas ducteados con difusores textiles</strong> que distribuyen el aire frío de manera uniforme dentro de la carpa sin corrientes directas sobre los invitados. Las unidades se instalan en el exterior de la estructura y solo los ductos ingresan al espacio, manteniendo el calor del compresor fuera. Perfectos para <strong>bodas en jardín con carpa, eventos corporativos bajo techo temporal y galas de verano</strong>. Cada instalación incluye cableado eléctrico, protecciones y opcional de planta de energía. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> diseñado para operar en ambientes climatizados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">2-20 Toneladas</span>
            <span class="showcase__tag">Ductos Textiles</span>
            <span class="showcase__tag">Operación Silenciosa</span>
            <span class="showcase__tag">Termostato Digital</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar AC Portátil
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="8" rx="2"/>
              <path d="M6 16v2"/>
              <path d="M10 16v4"/>
              <path d="M14 16v2"/>
              <path d="M18 16v4"/>
              <line x1="6" y1="8" x2="6.01" y2="8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Calefacción y Clima"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu equipo de climatización, es natural tener preguntas sobre capacidades, seguridad, consumo y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre calefacción y clima al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de calefacción y clima para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
