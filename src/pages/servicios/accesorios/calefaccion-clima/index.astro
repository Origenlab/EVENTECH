---
/**
 * ─── EVENTECH.MX — Renta de Calefacción y Clima para Eventos (Hub L4, molde hm- 2026) ───
 * Calentadores de Patio · Calefacción Industrial · Nebulización y Ventilación · AC Portátil — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro y carpas/estructurales/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/accesorios — calentador-patio-terraza-evento real; accesorio-evento-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "calentadores-patio",
    name: "Calentadores de Patio",
    badge: "Los más solicitados",
    excerpt: "Calentadores de propano tipo hongo y pirámide con radio de calor de 4 a 5 metros. Acero inoxidable con válvula anti-vuelco y base de contrapeso — ideales para terrazas, jardines y cenas al aire libre en noches frías.",
    href: "/servicios/accesorios/calefaccion-clima/calentadores-patio/",
    image: "/images/accesorios/calentador-patio-terraza-evento.avif",
    specs: ["Radio de calor 4-5 m", "14,000 BTU", "Gas LP", "Anti-vuelco"],
  },
  {
    id: "calefaccion-industrial",
    name: "Calefacción Industrial",
    badge: "Grandes espacios",
    excerpt: "Calentadores radiantes y de aire forzado para carpas, hangares y espacios de 50 a 500 m². Termostato digital y ductos de distribución para mantener grandes áreas a temperatura confortable.",
    href: "/servicios/accesorios/calefaccion-clima/calefaccion-industrial/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    specs: ["50–500 m²", "80,000 BTU", "Termostato digital", "18–30 °C"],
  },
  {
    id: "nebulizacion-ventilacion",
    name: "Nebulización y Ventilación",
    badge: "Frescura en verano",
    excerpt: "Ventiladores nebulizadores, enfriadores evaporativos y ventiladores HVLS para eventos de verano. Reducen la temperatura hasta 12 °C en espacios abiertos y semi-abiertos.",
    href: "/servicios/accesorios/calefaccion-clima/nebulizacion-ventilacion/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    specs: ["Hasta −12 °C", "Cobertura 80 m²", "Evaporativo 450 W", "Tanque 40 L"],
  },
  {
    id: "ac-portatil",
    name: "Aire Acondicionado Portátil",
    badge: "Temperatura exacta",
    excerpt: "Unidades de AC portátil de 2 a 20 toneladas con sistemas ducteados y difusores textiles para carpas y salones temporales. Operación silenciosa y control de temperatura exacto.",
    href: "/servicios/accesorios/calefaccion-clima/ac-portatil/",
    image: "/images/accesorios/accesorio-evento-03.avif",
    specs: ["2–20 toneladas", "Ducto flexible", "220V/440V", "Silencioso"],
  },
];

const whyFeatures = [
  {
    title: "Visita técnica y cálculo de carga térmica",
    body: "Antes de cotizar evaluamos los metros cuadrados, la altura, el material de la carpa y si el espacio está abierto, semi-abierto o cerrado. La calefacción y el clima se dimensionan con BTU y toneladas reales — no con \"un calentador por mesa\" calculado por teléfono.",
  },
  {
    title: "Equipo certificado y calibrado antes de cada entrega",
    body: "Tanques de propano certificados, válvulas anti-vuelco, sensores de oxígeno y conexiones eléctricas y de gas verificadas pieza por pieza. El equipo que climatiza tu evento se revisa antes de salir de bodega, no se prueba el día del montaje.",
  },
  {
    title: "Técnico en sitio durante todo el evento",
    body: "No dejamos el equipo y nos vamos. Un técnico instala, monitorea la temperatura y ajusta la operación durante el evento completo, con tanques y plantas de respaldo listos ante cualquier imprevisto.",
  },
  {
    title: "Climatización por zonas, no por evento completo",
    body: "Diseñamos un plano de clima por área: calentadores en la terraza abierta, aire acondicionado en la carpa cerrada, nebulización en la pista al aire libre. Cada zona de tu evento con la solución exacta, no una sola talla para todo el espacio.",
  },
  {
    title: "Instalación eléctrica y de gas certificada",
    body: "Conexiones trifásicas para equipos de alto consumo, protecciones térmicas y diferenciales, canalización de gas certificada y generadores de respaldo cuando el venue no tiene la capacidad necesaria. Todo bajo normas NOM y supervisado por técnico certificado.",
  },
  {
    title: "Inventario completo para cualquier temporada",
    body: "Calefacción para las noches frías de invierno, nebulización y aire acondicionado para el calor de verano — el mismo proveedor todo el año, sin importar la temporada en que sea tu evento.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cálculo de carga térmica", p: "Agendamos visita sin costo para medir el espacio, evaluar si está abierto, semi-abierto o cerrado, y calcular los BTU o toneladas necesarias. En menos de 24 horas te enviamos la propuesta con el equipo ideal para tu evento y temporada." },
  { n: 2, t: "Diseño de solución y aparto", p: "Definimos el equipo, la distribución por zonas y las conexiones eléctricas o de gas necesarias. Con el 30% de anticipo apartamos el equipo y la fecha. Coordinamos con tu wedding planner o el venue si aplica." },
  { n: 3, t: "Instalación, pruebas y monitoreo", p: "Nuestro técnico instala con anticipación: conexiones de gas o electricidad, prueba de encendido y calibración según la temperatura objetivo. Todo queda verificado antes del evento y monitoreado durante su desarrollo." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento el técnico ajusta la operación según las condiciones reales. Al finalizar, nuestro equipo desmonta y retira todo. La visita técnica, la instalación y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tipo de calefacción necesito según el tamaño de mi carpa?", answer: "Para carpas pequeñas de hasta 50 m² recomendamos 2 a 3 calentadores de patio tipo hongo distribuidos estratégicamente. Para carpas medianas de 50 a 150 m² lo ideal es calefacción radiante con 2 a 4 unidades colgadas del techo de la carpa. Para carpas grandes de 150 a 500 m² recomendamos sistemas de aire forzado industrial con ductos que distribuyen el calor uniformemente. Nuestro equipo técnico evalúa las dimensiones, altura y material de tu carpa para diseñar la solución óptima con la menor cantidad de equipo." },
  { question: "¿Es seguro usar calentadores de propano en eventos?", answer: "Absolutamente. Nuestros calentadores de propano cuentan con certificación de seguridad, válvula anti-vuelco que apaga automáticamente la llama si el equipo se inclina, sensor de oxígeno para exteriores y base de contrapeso estabilizado. Cada calentador incluye tanque de propano certificado y conexiones verificadas antes de cada evento. Nuestro técnico supervisa la instalación, verifica la ventilación del espacio y permanece disponible durante todo el evento. Se recomienda mantener una distancia mínima de 1 metro entre el calentador y cualquier material inflamable." },
  { question: "¿Los calentadores de patio se pueden usar dentro de una carpa cerrada?", answer: "Los calentadores de patio a propano están diseñados para espacios abiertos o semi-abiertos con ventilación natural, ya que la combustión de gas requiere intercambio de aire. Cuentan con sensor de oxígeno que apaga el equipo si el nivel de ventilación baja del mínimo seguro. Para carpas completamente cerradas recomendamos calefacción radiante o de aire forzado con ductos, que no queman combustible dentro del espacio ocupado y distribuyen el calor de forma segura sin importar el nivel de cierre. En la visita técnica evaluamos la ventilación real de tu carpa para recomendar el sistema correcto." },
  { question: "¿Cuánta agua consumen los sistemas de nebulización?", answer: "Los ventiladores nebulizadores consumen entre 2 y 6 litros de agua por hora dependiendo del modelo y la intensidad de nebulización seleccionada. Un enfriador evaporativo industrial consume entre 10 y 20 litros por hora. Para un evento de 8 horas con 4 nebulizadores, el consumo total aproximado es de 100 a 200 litros. Proporcionamos tanques de reserva y conexión a toma de agua cuando está disponible. El consumo eléctrico es mínimo ya que solo alimenta el ventilador y la bomba de presión." },
  { question: "¿Qué requerimientos eléctricos necesita el aire acondicionado portátil?", answer: "Las unidades de 2 toneladas requieren una conexión de 220V/30A monofásica. Las de 5 toneladas necesitan 220V/60A. Las unidades grandes de 10 a 20 toneladas requieren conexión trifásica de 440V. Si tu venue no cuenta con la capacidad eléctrica necesaria, incluimos plantas de energía dimensionadas para alimentar los equipos de clima. Todos los cables, conectores y protecciones eléctricas están incluidos en el servicio. Nuestro técnico evalúa la infraestructura eléctrica del venue antes del evento." },
  { question: "¿Se pueden combinar calefacción y enfriamiento en zonas diferentes del mismo evento?", answer: "Sí, es una de nuestras configuraciones más solicitadas para eventos de temporada intermedia. Por ejemplo, calentadores de patio en la terraza exterior y aire acondicionado en la carpa principal, o nebulización en el área de baile al aire libre y calefacción en la zona lounge cubierta. Diseñamos un plano de climatización por zonas para que cada área de tu evento tenga la temperatura ideal. La clave es separar las zonas con barreras físicas (paredes de carpa, cortinas industriales) para maximizar la eficiencia." },
  { question: "¿Con cuánta anticipación debo reservar equipo de climatización?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta de frío (noviembre a febrero) para calefacción y en verano (abril a septiembre) para sistemas de enfriamiento. Los equipos de aire acondicionado portátil de alta capacidad (10+ toneladas) son los más solicitados y conviene apartarlos con 3 a 6 semanas. Para eventos de último momento, contamos con inventario de emergencia disponible sujeto a disponibilidad. Nuestro equipo técnico realiza una visita previa para dimensionar correctamente tu instalación." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Calefacción y Clima para Eventos en CDMX",
    description: "Renta de calentadores de patio, calefacción industrial, nebulización y aire acondicionado portátil para eventos en CDMX, con instalación técnica y monitoreo incluidos.",
    url: "/servicios/accesorios/calefaccion-clima/",
    priceRange: { min: 800, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Calefacción y Clima", url: "/servicios/accesorios/calefaccion-clima/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Calefacción y Clima" },
];
---

<PageLayout
  title="Renta de Calefacción y Clima para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/accesorios/calentador-patio-terraza-evento.avif"
  description="Renta de calefacción y clima para eventos en CDMX: calentadores de patio, industrial, nebulización y AC portátil. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="calefaccion-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Calefacción y clima · CDMX y ZMVM</p>
            <h1 id="calefaccion-hero-heading">
              Calefacción y clima que mantienen <em>el confort exacto</em> en cualquier temporada del año
            </h1>
            <p class="hm-hero__lead">
              Calentadores de patio, calefacción industrial, nebulización y aire acondicionado
              portátil con instalación técnica certificada y monitoreo durante todo el evento —
              para que el clima nunca sea un problema.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20calefacción%20y%20clima%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar calefacción y clima
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>equipo de calefacción y clima para eventos</strong> en CDMX
              y zona metropolitana: calentadores de patio a propano, calefacción industrial
              radiante y de aire forzado, nebulización y enfriamiento evaporativo, y aire
              acondicionado portátil de hasta 20 toneladas. Cada solución se calcula según los
              metros cuadrados, la altura y el tipo de espacio — abierto, semi-abierto o carpa
              cerrada — para llegar con el equipo exacto, no con un estimado.
            </p>
            <p>
              Con <strong>más de 500 eventos climatizados</strong> en CDMX, sabemos que el
              confort térmico no se improvisa: cada renta incluye visita técnica, instalación
              certificada y técnico en sitio que monitorea la temperatura durante el evento. Para
              un montaje integral combina con nuestras <a href="/servicios/carpas/">carpas</a>,
              <a href="/servicios/carpas/pisos-complementos/">pisos y complementos</a> o
              <a href="/servicios/mobiliario/">mobiliario</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de equipo de calefacción y clima disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20calefacción%20y%20clima%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El inventario de clima más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué equipo de clima necesita tu evento?</h2>
            <p class="hm__head-sub">Del calentador de patio para una cena en terraza al sistema industrial para una carpa de 500 m² — con el equipo y el técnico correctos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El equipo de clima correcto no se elige solo por presupuesto — depende de si el
              espacio está abierto o cerrado, de cuántos metros cuadrados cubre y de la
              temporada del año. Un calentador de patio no climatiza una carpa cerrada de 300 m²,
              y un aire acondicionado de 2 toneladas no enfría un hangar de eventos.
            </p>
            <p>
              Calentadores de patio para terrazas y cenas íntimas. Calefacción industrial para
              carpas y hangares grandes. Nebulización y ventilación para el calor de verano. Aire
              acondicionado portátil para temperatura exacta bajo carpa. Una sola empresa para
              todo el clima de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de clima — en detalle</h2>
            <p class="hm__head-sub">Potencia, cobertura y para qué tipo de evento funciona mejor cada equipo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada equipo de clima hay una decisión técnica: la carga térmica que
              necesita el espacio, el tipo de instalación eléctrica o de gas que requiere, y si
              el área está abierta, semi-abierta o completamente cerrada.
            </p>
            <p>
              Conocer estas diferencias evita rentar de más — o de menos. A continuación, el
              detalle real de cada solución de calefacción y clima.
            </p>
          </div>
        </div>

        <!-- CALENTADORES DE PATIO -->
        <article class="hm-feat" aria-labelledby="feat-calentadores-patio">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Calentadores de Patio</p>
            <h3 class="hm-feat__title" id="feat-calentadores-patio">Calor elegante con llama visible para terrazas, jardines y cenas al aire libre</h3>
            <p class="hm-feat__lead">El calor de una llama controlada transforma una terraza fría en el rincón más buscado de la noche — sin cables tendidos ni ruido de motor.</p>
            <p>
              Dos estilos profesionales: <strong>tipo hongo (mushroom) y tipo pirámide</strong>
              con llama visible, fabricados en <strong>acero inoxidable</strong> con acabado en
              bronce, negro mate o plateado. Cada unidad genera un <strong>radio de calor
              efectivo de 4 a 5 metros</strong> — suficiente para cubrir una mesa de 8 a 10
              personas con confort real.
            </p>
            <p>
              Incluyen <strong>tanque de propano de 10 kg con regulador certificado</strong>,
              encendido electrónico piezoeléctrico, <strong>válvula anti-vuelco de
              seguridad</strong> y base de contrapeso estabilizado. Operan 8 a 10 horas continuas
              por tanque; para eventos largos llevamos tanques de repuesto. Combina con nuestro
              <a href="/servicios/mobiliario/">mobiliario premium de exterior</a> para crear
              zonas de confort en noches frías.
            </p>
            <ul class="hm-feat__stats">
              {["Radio de calor 4-5 m", "14,000 BTU", "Tanque propano 10 kg", "8-10 h por tanque", "Válvula anti-vuelco"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/accesorios/calefaccion-clima/calentadores-patio/">
              Ver Calentadores de Patio
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/accesorios/calentador-patio-terraza-evento.avif" alt="Calentador de patio tipo hongo encendido en terraza de evento en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/accesorios/accesorio-evento-04.avif" alt="Detalle de calentador de patio tipo pirámide para evento en CDMX" loading="lazy" decoding="async" />
              <img src="/images/accesorios/accesorio-evento-02.avif" alt="Zona de calentadores de patio instalada en jardín de evento en CDMX" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- CALEFACCIÓN INDUSTRIAL -->
        <article class="hm-feat" aria-labelledby="feat-calefaccion-industrial">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Calefacción Industrial</p>
            <h3 class="hm-feat__title" id="feat-calefaccion-industrial">Potencia radiante y de aire forzado para carpas y hangares de hasta 500 m²</h3>
            <p class="hm-feat__lead">Cuando el espacio es grande y está cerrado, calentar no es cuestión de más calentadores de patio — es un sistema con ductos, termostato y cálculo real de carga térmica.</p>
            <p>
              <strong>Calentadores radiantes</strong> colgados del techo de la carpa distribuyen
