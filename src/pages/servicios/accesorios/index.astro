---
/**
 * ─── EVENTECH.MX — Accesorios para Eventos (L3, rediseño 2026) ───
 * Renta de accesorios: mantelería, señalización, climatización y generadores.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "manteleria-textiles",
    name: "Mantelería y Textiles",
    badge: "El primer impacto visual",
    excerpt: "Manteles de lino, organza y terciopelo, cubre-sillas, servilletas de tela y faldones para buffet. La diferencia entre una mesa que se ve de catálogo y una mesa que el fotógrafo busca activamente.",
    href: "/servicios/accesorios/manteleria-textiles/",
    image: "/images/accesorios/manteles-premium-boda-elegante.avif",
    subcategories: [
      { name: "Manteles de Lino", href: "/servicios/accesorios/manteleria-textiles/lino/" },
      { name: "Manteles de Organza", href: "/servicios/accesorios/manteleria-textiles/organza/" },
      { name: "Cubre-sillas", href: "/servicios/accesorios/manteleria-textiles/cubre-sillas/" },
      { name: "Faldones de Buffet", href: "/servicios/accesorios/manteleria-textiles/faldones/" },
    ],
  },
  {
    id: "senalizacion-alfombras",
    name: "Señalización y Alfombras",
    badge: "La primera impresión del evento",
    excerpt: "Alfombra roja y red carpet en varios anchos y colores, señalética de acrilico y madera, porta-menús, números de mesa, porta-nombres y elementos de bienvenida para la entrada del venue.",
    href: "/servicios/accesorios/senalizacion-alfombras/",
    image: "/images/accesorios/alfombra-roja-red-carpet-evento.avif",
    subcategories: [
      { name: "Red Carpet y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/alfombras/" },
      { name: "Señalética de Evento", href: "/servicios/accesorios/senalizacion-alfombras/senaletca/" },
      { name: "Porta-menús y Números", href: "/servicios/accesorios/senalizacion-alfombras/menus/" },
      { name: "Elementos de Bienvenida", href: "/servicios/accesorios/senalizacion-alfombras/bienvenida/" },
    ],
  },
  {
    id: "calefaccion-clima",
    name: "Calefacción y Clima",
    badge: "Confort en cualquier temporada",
    excerpt: "Calentadores de patio de gas LP e infrarrojo para exteriores, ventiladores industriales, nebulizadores de agua y unidades de aire acondicionado portátil para carpas y salones sin climatización.",
    href: "/servicios/accesorios/calefaccion-clima/",
    image: "/images/accesorios/calentador-patio-terraza-evento.avif",
    subcategories: [
      { name: "Calentadores de Patio", href: "/servicios/accesorios/calefaccion-clima/calentadores/" },
      { name: "Aire Acondicionado Portátil", href: "/servicios/accesorios/calefaccion-clima/ac/" },
      { name: "Ventiladores Industriales", href: "/servicios/accesorios/calefaccion-clima/ventiladores/" },
      { name: "Nebulizadores", href: "/servicios/accesorios/calefaccion-clima/nebulizadores/" },
    ],
  },
  {
    id: "plantas-energia",
    name: "Plantas de Energía",
    badge: "El evento sin cortes",
    excerpt: "Generadores eléctricos silenciosos de 20 a 500 kVA para eventos en venues sin suministro eléctrico suficiente, exteriores, jardines y ubicaciones remotas. El seguro de vida del equipo de sonido y la iluminación.",
    href: "/servicios/accesorios/plantas-energia/",
    image: "/images/accesorios/planta-luz-generador-evento.avif",
    subcategories: [
      { name: "Generadores 20–60 kVA", href: "/servicios/accesorios/plantas-energia/pequenos/" },
      { name: "Generadores 80–200 kVA", href: "/servicios/accesorios/plantas-energia/medianos/" },
      { name: "Generadores 250–500 kVA", href: "/servicios/accesorios/plantas-energia/grandes/" },
      { name: "Distribución Eléctrica", href: "/servicios/accesorios/plantas-energia/distribucion/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🎨",
    title: "Mantelería lavada y planchada, sin arrugas",
    body: "Toda la mantelería se entrega lavada industrialmente, planchada con prensa de vapor y empacada en bolsa individual por pieza. Sin arrugas de almacenaje, sin manchas residuales, sin el olor a bodega que arruina la presentación de la mesa antes de que llegue el primer invitado.",
  },
  {
    icon: "🌡️",
    title: "Calentadores de patio calibrados para el área exacta",
    body: "Un calentador de patio calienta un área de 12–18 m² dependiendo del modelo y las condiciones del viento. Calculamos el número exacto de unidades según el plano de la terraza y las condiciones climáticas esperadas — sin zonas frías ni exceso de calor que incomoda.",
  },
  {
    icon: "⚡",
    title: "Generadores silenciosos — la música no se interrumpe",
    body: "Nuestros generadores encapsulados operan a 65–72 dB(A) a 7 metros — equivalente a una conversación normal. El invitado en la pista de baile no escucha el generador. El técnico de sonido no batalla con ruido de fondo. El evento continúa aunque la CFE tenga un problema.",
  },
  {
    icon: "📐",
    title: "Mantelería en el tamaño exacto de tu mesa",
    body: "La caída estándar de un mantel es de 25–30 cm por lado. Si tus mesas son redondas de 1.5 m, cuadradas de 90 cm o rectangulares de 180×75 cm, tenemos el mantel con la caída exacta. Sin manteles que quedan cortos ni que arrastran en el suelo.",
  },
  {
    icon: "🔌",
    title: "Distribución eléctrica incluida en generadores grandes",
    body: "Los generadores de más de 80 kVA incluyen tablero de distribución, interruptores por circuito y cableado hasta los puntos de consumo principales. No es el generador solo — es el sistema eléctrico temporal completo que el venue necesita para operar.",
  },
  {
    icon: "🚚",
    title: "Accesorios que llegan en el mismo camión que el resto del evento",
    body: "Mantelería, alfombras, calentadores y generadores salen en la misma logística que carpas, mobiliario e iluminación — un viaje, una entrega, un equipo de montaje. Sin coordinar 5 proveedores separados para que todos lleguen el mismo día.",
  },
];

const steps = [
  { n: 1, t: "Levantamiento de necesidades", p: "Revisamos el plano del venue, el tipo de mesas y sillas, las condiciones climáticas esperadas y la disponibilidad eléctrica del espacio para dimensionar correctamente cada accesorio." },
  { n: 2, t: "Propuesta y muestras de tela", p: "Para mantelería de evento de alto nivel, enviamos muestras físicas de tela para aprobación de color y textura antes de confirmar el pedido. Los colores pantone se verifican antes de la entrega." },
  { n: 3, t: "Entrega y montaje coordinado", p: "Los accesorios llegan en la misma logística que el resto del equipamiento del evento. La mantelería se pone en mesa, los calentadores se posicionan según el plano y los generadores se conectan y verifican antes de cualquier otro equipo." },
  { n: 4, t: "Retiro y conteo", p: "Al finalizar recogemos, contamos y reportamos el inventario de mantelería. Las piezas faltantes o con daño por mal uso se cargan al costo acordado en el contrato — con verificación conjunta en sitio." },
];

const faqs = [
  {
    question: "¿Cuántos calentadores de patio necesito para mi terraza?",
    answer: "La regla de base es 1 calentador de gas LP de 14,000 BTU por cada 12–15 m² de terraza en condiciones de viento moderado. Para terrazas expuestas al viento o en altitud (más de 2,200 msnm, como buena parte de CDMX), aumentamos la densidad a 1 por cada 10 m². Para jardines grandes te conviene combinar calentadores de patio con cortinas de aire perimetrales en las zonas de acceso. Calculamos el número exacto según plano y condiciones climáticas del mes del evento.",
  },
  {
    question: "¿Qué tamaño de generador necesito para mi evento?",
    answer: "El cálculo base es: suma de potencia de todo el equipo eléctrico del evento (sonido, iluminación, cocina, climatización) × 1.25 de factor de seguridad. Para un evento de 200 personas con sistema de sonido estándar, iluminación LED y bufet eléctrico, generalmente 60–80 kVA son suficientes. Para eventos con line array de gran formato, videowall LED y cocina completa, 150–200 kVA. Te enviamos el cálculo de carga exacto si nos mandas el listado de equipo eléctrico.",
  },
  {
    question: "¿La mantelería viene en todos los colores?",
    answer: "Contamos con más de 40 colores en lino, 20 en organza y 15 en terciopelo. Los colores más solicitados — blanco roto, champagne, negro, marfil, dorado, burgundy — están siempre disponibles. Colores específicos de paleta de diseñador pueden requerir 2–3 semanas de anticipación para asegurar disponibilidad. Enviamos muestras físicas de tela para aprobación antes de confirmar eventos de boda o corporativos de alta producción.",
  },
  {
    question: "¿Los generadores hacen mucho ruido?",
    answer: "Los generadores encapsulados de nuestro inventario operan a 65–72 dB(A) medidos a 7 metros — aproximadamente el nivel de una conversación normal. Se ubican siempre fuera del área del evento, idealmente a más de 15 metros de la zona de invitados. Para eventos en espacios muy reducidos donde no hay distancia suficiente, llevamos paneles de absorción acústica adicionales que reducen otros 8–12 dB. El técnico los instala y verifica antes de que lleguen los primeros invitados.",
  },
  {
    question: "¿Pueden hacer la señalética personalizada con el nombre del evento o los novios?",
    answer: "Sí. La señalética personalizada — welcome signs, números de mesa, porta-menús con nombre, señalética de dirección y elementos de photobooth — se diseña e imprime como servicio adicional. Requiere 7–10 días hábiles antes del evento para diseño, aprobación e impresión. Los soportes de acrílico, madera o metal forman parte del inventario estándar de renta — el cliente solo paga el diseño e impresión de las piezas personalizadas.",
  },
  {
    question: "¿Se puede rentar solo la mantelería sin el resto del equipo?",
    answer: "Sí. Rentamos accesorios como líneas independientes — solo mantelería, solo calentadores, solo generador, solo alfombra red carpet. No hay obligación de rentar paquete completo. La logística de entrega individual puede tener un costo mínimo de traslado dependiendo del volumen y la ubicación del venue. Lo especificamos en la cotización.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Accesorios para Eventos en CDMX",
    description: "Renta de accesorios para eventos en CDMX: mantelería premium, alfombra red carpet, calentadores de patio, generadores eléctricos y señalética. Cotización en 24h.",
    url: "/servicios/accesorios/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios" },
];
---

<PageLayout
  title="Renta de Accesorios para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/accesorios/alfombra-roja-red-carpet-evento.avif"
  description="Renta de accesorios para eventos en CDMX: mantelería, alfombra red carpet, calentadores de patio y generadores silenciosos. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="acc-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Accesorios para eventos · CDMX y ZMVM</p>
            <h1 id="acc-hero-heading">
              Los detalles que definen si un evento se ve <em>producido o improvisado</em>
            </h1>
            <p class="hm-hero__lead">
              Mantelería de lino y organza planchada sin arrugas, alfombra red carpet,
              calentadores de patio silenciosos, generadores eléctricos encapsulados
              y señalética personalizada. Los accesorios que completan el evento —
              entregados en la misma logística que el resto del equipamiento.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20accesorios%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver los accesorios disponibles
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>accesorios para eventos</strong> — los elementos que
              completan el equipamiento y definen el nivel de producción visual del evento.
              Mantelería premium planchada sin arrugas, alfombra red carpet en varios
              colores, calentadores de patio dimensionados al espacio, generadores
              eléctricos silenciosos y señalética personalizada — todo desde una sola
              empresa, con entrega coordinada con el resto del equipamiento del evento.
            </p>
            <p>
              Con <strong>más de 500 eventos equipados</strong> en CDMX y zona
              metropolitana, conocemos qué accesorio hace la diferencia visual en cada
              tipo de evento — y cuándo se puede omitir sin que se note.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Accesorios disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20accesorios%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Los detalles que completan el evento</p>
            <h2 id="catalogo-heading">¿Qué accesorios necesita tu evento?</h2>
            <p class="hm__head-sub">Mantelería, señalización, climatización o energía — o todo lo que falta en el venue.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Los accesorios son los elementos que los invitados no notan cuando están
              bien elegidos — y los que todos notan cuando faltan o están mal. El mantel
              arrugado en la mesa de honor. El jardín helado porque no había calentadores.
              El evento que se corta porque el venue se quedó sin luz. La entrada sin
              alfombra que hace que todos busquen por dónde es.
            </p>
            <p>
              Cada accesorio tiene una función específica y un dimensionamiento correcto
              para el espacio y el número de invitados. Eso es lo que revisamos antes
              de cotizar — no un número genérico de piezas, sino lo que el evento
              específicamente necesita.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada accesorio, a fondo</p>
            <h2 id="detalle-heading">Accesorios en detalle</h2>
            <p class="hm__head-sub">Materiales, dimensionamiento y por qué cada accesorio transforma la percepción del evento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El nivel de producción de un evento no solo se mide en el escenario o en
              la iluminación — se mide en cada elemento que el invitado toca, camina
              encima, siente sobre la piel cuando hace frío o percibe en la temperatura
              del ambiente. Un mantel de lino de caída perfecta. Una alfombra roja que
              empieza desde la banqueta. Un jardín a temperatura confortable en diciembre.
              La música que no se corta cuando falla la corriente del venue. Esos son
              los accesorios que nos piden los clientes que saben lo que quieren.
            </p>
          </div>
        </div>

        <!-- Mantelería -->
        <article class="hm-feat" aria-labelledby="feat-mant">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Mantelería y Textiles</p>
            <h3 class="hm-feat__title" id="feat-mant">Lino, organza y terciopelo planchados sin arrugas — la base visual de cada mesa del evento</h3>
            <p class="hm-feat__lead">El mantel es el primer elemento que el invitado ve al sentarse. Antes de la centerpiece, antes de la vajilla, antes de la iluminación — el mantel establece si la mesa se ve de producción alta o de evento genérico.</p>
            <p>
              Nuestra mantelería de <strong>lino premium</strong> está disponible en
              más de 40 colores con caídas de 25 cm, 30 cm o hasta el suelo para mesas
              redondas de 1.5 m, 1.8 m y 2.0 m y rectangulares de 150×75 cm a
              240×90 cm. Cada pieza se entrega <strong>lavada industrialmente,
              planchada con prensa de vapor y embalada individualmente</strong> —
              sin las arrugas de almacenaje que arruinan la presentación de mesa
              en cuanto se despliega. La <strong>organza</strong> en 20 colores
              se usa como sobre-mantel que crea capas de textura y luz sobre el lino
              base — la combinación estándar en bodas y eventos de gala de alto nivel.
              El <strong>terciopelo</strong> en 15 colores es la opción para eventos
              de otoño-invierno con paleta oscura — burgundy, azul marino, verde botella,
              negro — con la textura que la organza no puede replicar.
            </p>
            <p>
              Los <strong>cubre-sillas</strong> de tela drapeada, faja con lazo y
              silla fantasma con vinilo están disponibles para Tiffany, Napoleon,
              industrial y banquete. Los <strong>faldones de buffet</strong> en varios
              colores cubren las estructuras metálicas de las mesas de servicio
              que de otra forma se ven en toda la sala. Coordina la mantelería con nuestro servicio de <a href="/servicios/mobiliario/">mobiliario de evento</a> para mesas y sillas, y con <a href="/servicios/catering/">equipo de catering</a> para asegurar que el faldón de buffet y las estaciones de servicio combinen con la paleta del evento.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Manteles Lino", href: "/servicios/accesorios/manteleria-textiles/lino/" },
                { name: "Organza", href: "/servicios/accesorios/manteleria-textiles/organza/" },
                { name: "Cubre-sillas", href: "/servicios/accesorios/manteleria-textiles/cubre-sillas/" },
                { name: "Faldones Buffet", href: "/servicios/accesorios/manteleria-textiles/faldones/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/accesorios/manteleria-textiles/">
              Ver mantelería y textiles
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
