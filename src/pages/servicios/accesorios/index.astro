---
/**
 * ─── Accesorios Category Page ───
 * Página de categoría: Renta de Accesorios para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const SUB_SERVICES = [
  {
    name: "Mantelería y Textiles",
    excerpt: "Manteles, cubresillas, bandas, servilletas, caminos de mesa y overlays en más de 50 colores y 8 tipos de tela. Acabados premium para cada estilo de evento.",
    cta: "Mantelería",
    href: "#manteleria-heading",
    icon: "layers",
  },
  {
    name: "Señalización y Alfombras",
    excerpt: "Alfombras rojas y personalizadas, postes separadores con cinta de terciopelo, podiums ejecutivos, señalética direccional y backdrops para fotografía.",
    cta: "Señalización",
    href: "#senalizacion-heading",
    icon: "award",
  },
  {
    name: "Plantas de Energía",
    excerpt: "Generadores diésel silenciados de 20 kW a 500 kW, tableros de distribución eléctrica, reguladores de voltaje y sistemas de respaldo automático para eventos sin cortes.",
    cta: "Plantas de Energía",
    href: "#energia-heading",
    icon: "shield",
  },
  {
    name: "Calefacción y Clima",
    excerpt: "Calentadores de patio, calefacción industrial radiante, sistemas de nebulización, ventiladores evaporativos y aire acondicionado portátil para confort en cualquier temporada.",
    cta: "Calefacción y Clima",
    href: "#clima-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué incluye el servicio de mantelería para mi evento?", answer: "Nuestro servicio integral de mantelería incluye la selección personalizada de manteles, cubresillas, bandas decorativas, servilletas y caminos de mesa en el color y tipo de tela que elijas. Todos los textiles se entregan planchados profesionalmente con vapor industrial, listos para colocar. Al finalizar el evento, nuestro equipo recoge la mantelería completa — no necesitas preocuparte por lavado ni devolución. Disponemos de más de 50 colores en telas como poliéster premium, satín, organza, lentejuela, tul y lino sintético." },
  { question: "¿Qué capacidad de generador necesito para mi evento?", answer: "La capacidad depende del tipo de instalaciones. Como referencia: un evento social con iluminación básica, sonido y catering requiere entre 20 y 45 kW. Un evento corporativo con pantallas LED, equipos audiovisuales y clima artificial necesita entre 60 y 150 kW. Festivales, expos y eventos masivos con múltiples escenarios pueden requerir 200 a 500 kW. Nuestro equipo de ingeniería realiza un cálculo de carga eléctrica gratuito basado en el inventario completo de equipos de tu evento para dimensionar el generador exacto." },
  { question: "¿Los calentadores son seguros para espacios techados como carpas?", answer: "Sí. Nuestros calentadores infrarrojos radiantes están certificados para uso en interiores y espacios semi-cerrados. Funcionan con gas LP o natural, cuentan con válvula de seguridad por termo-par que corta el suministro automáticamente ante cualquier anomalía, sensor anti-vuelco y rejilla protectora de acero inoxidable. Para carpas, recomendamos los modelos de torre radiante de 14,000 W que calientan un radio de hasta 5 metros sin generar flama expuesta ni emisiones de monóxido detectables en espacios ventilados." },
  { question: "¿Puedo personalizar el color de la mantelería según mi paleta de colores?", answer: "Absolutamente. Manejamos un catálogo de más de 50 colores estándar disponibles de inmediato en todas nuestras telas. Para colores especiales fuera de catálogo o telas importadas, trabajamos con pedidos especiales con 3 a 4 semanas de anticipación. Ofrecemos servicio de muestra a domicilio: te enviamos swatches de los colores y telas seleccionados para que los apruebes antes de confirmar el pedido. Nuestras asesoras de diseño te ayudan a coordinar la mantelería con tu paleta decorativa." },
  { question: "¿El generador hace mucho ruido durante el evento?", answer: "Todos nuestros generadores son modelos silenciados de grado comercial con cabina acústica que reduce el nivel sonoro a entre 65 y 72 dB(A) a 7 metros — equivalente a una conversación normal. Se instalan estratégicamente a una distancia mínima de 15 metros del área de invitados, detrás de barreras naturales o estructuras cuando es posible. Para eventos con requerimientos de audio crítico como conferencias magistrales o ceremonias religiosas, disponemos de generadores ultra-silenciosos que operan a 58 dB(A)." },
  { question: "¿Con cuánta anticipación debo reservar los accesorios para mi evento?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para garantizar disponibilidad de colores y cantidades exactas en mantelería, especialmente en temporada alta (octubre a febrero). Para plantas de energía de alta capacidad (+150 kW) o pedidos grandes de mantelería especial (+100 mesas), lo ideal es reservar con 6 semanas. Señalización personalizada con logotipos o diseños especiales requiere 2 semanas para producción. Accesorios estándar como calentadores, alfombras rojas y postes separadores generalmente tienen disponibilidad inmediata." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Accesorios para Eventos en CDMX",
    description: "Mantelería premium, plantas de energía, señalización profesional y calefacción para eventos. Más de 50 colores en textiles, generadores de 20 a 500 kW. Servicio integral con entrega y montaje.",
    url: "/servicios/accesorios/",
    priceRange: { min: 800, max: 95000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Accesorios para Eventos en CDMX"
  description="Renta de mantelería premium, plantas de energía, señalización profesional y calefacción para eventos en CDMX. Más de 50 colores en textiles, generadores silenciados. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El complemento perfecto para cada detalle de tu evento"
    title='Renta de <span class="highlight">Accesorios para Eventos</span> en CDMX'
    subtitle="Mantelería en más de 50 colores y 8 tipos de tela, alfombras rojas con postes de terciopelo, señalización ejecutiva, plantas de energía silenciadas de 20 a 500 kW y sistemas de calefacción y clima artificial. Cada detalle cuenta — y nosotros nos encargamos de todos."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar accesorios para mi evento en CDMX` }}
    cards={[
      {
        title: "Textiles de grado hotelero y señalización de fabricación institucional",
        content: "<strong>Renta de accesorios para eventos</strong> con estándares de calidad que rivalizan con los principales hoteles y centros de convenciones de la Ciudad de México. Nuestra mantelería se confecciona en <strong>poliéster premium de 220 g/m², satín de doble cara, organza cristal, tul francés, lino sintético de alta densidad y lentejuela bordada sobre mesh</strong> — cada pieza es planchada con vapor industrial a 180 °C antes de la entrega. La señalización incluye <strong>podiums ejecutivos en madera de maple con acabado mate o acrílico transparente de 12 mm, postes separadores cromados de acero inoxidable 304 con cinta de terciopelo retráctil</strong> y alfombras de nylon tufted de 900 g/m² con respaldo antiderrapante de caucho natural.",
      },
      {
        title: "Infraestructura eléctrica y climatización certificada para eventos sin interrupciones",
        content: "<strong>Servicio integral de accesorios técnicos</strong> que garantiza la operación continua y el confort absoluto de tu evento. Nuestras <strong>plantas de energía diésel silenciadas</strong> operan a 65-72 dB(A) y cuentan con <strong>cabina acústica de acero galvanizado, sistema de enfriamiento por radiador, protección contra sobrecargas y transferencia automática</strong>. Complementa con <a href='/servicios/carpas/'>carpas profesionales</a> equipadas con nuestros <strong>calentadores infrarrojos radiantes de 14,000 W certificados para interiores</strong>, ventiladores evaporativos industriales de 450 W con tanque de 40 litros o <strong>equipos de aire acondicionado portátil de 5 TR</strong> para control total del clima en cualquier temporada del año.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Los detalles definen la experiencia — lleva tu evento al siguiente nivel"
    subheadline="Recibe una propuesta personalizada con textiles, energía, señalización y clima para tu celebración — sin compromiso y con asesoría experta"
    primaryCTA={{ label: "Cotizar accesorios", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Accesorios"
        subtitle="Todo lo que necesitas para complementar cada aspecto de tu evento"
        description={[
          "Desde la mantelería que viste cada mesa con elegancia hasta la planta de energía que garantiza que ni una sola luz se apague durante tu celebración — nuestro catálogo de accesorios cubre los elementos que transforman un buen evento en una experiencia extraordinaria. Servicio disponible en toda la Ciudad de México y zona metropolitana.",
          "Cada accesorio incluye entrega puntual, instalación profesional cuando aplica y recolección al finalizar el evento. Trabajamos con inventario propio y proveedores certificados para garantizar la más alta disponibilidad y calidad constante en cada pieza, sin importar el volumen de tu pedido."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <Card
            name={sub.name}
            excerpt={sub.excerpt}
            cta={sub.cta}
            href={sub.href}
            icon={sub.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MANTELERÍA Y TEXTILES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="manteleria-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">+50 colores disponibles de inmediato</span>
          <h2 class="showcase__title" id="manteleria-heading">Mantelería y Textiles</h2>
          <p class="showcase__subtitle">Manteles, cubresillas, bandas, servilletas, caminos de mesa y overlays confeccionados en 8 tipos de tela premium con acabado de planchado industrial — el toque que eleva la mesa de cada invitado.</p>
          <p class="showcase__text">Nuestra <strong>mantelería profesional para eventos</strong> se confecciona con los mismos estándares de los hoteles cinco estrellas de la Ciudad de México. El <strong>poliéster premium de 220 g/m²</strong> es nuestro textil insignia: resistente a arrugas, con caída impecable y disponible en más de 50 colores sólidos. Para bodas y galas, el <strong>satín de doble cara con brillo sedoso</strong> aporta un nivel de sofisticación inigualable, mientras que la <strong>organza cristal y el tul francés</strong> son perfectos para overlays y acentos decorativos que complementan cualquier montaje de <a href="/servicios/mobiliario/">mobiliario elegante</a>.</p>
          <p class="showcase__text">Cada pieza se entrega <strong>planchada con vapor industrial a 180 °C</strong>, doblada individualmente y empaquetada en bolsas protectoras para garantizar un acabado perfecto al momento de la colocación. Disponemos de <strong>cubresillas universales tipo funda de spandex</strong> en 25 colores, <strong>cubresillas tipo sobre en poliéster y satín</strong> con 40 opciones cromáticas, <strong>bandas decorativas de organza, satín y lentejuela</strong>, <strong>servilletas de tela de 50×50 cm</strong> y <strong>caminos de mesa en lentejuela bordada, yute natural, encaje y satín</strong>. Servicio de muestra a domicilio disponible para que apruebes colores y texturas antes de confirmar tu pedido.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Poliéster 220g</span>
            <span class="showcase__tag">Satín Doble Cara</span>
            <span class="showcase__tag">Organza Cristal</span>
            <span class="showcase__tag">Lentejuela Bordada</span>
            <span class="showcase__tag">Spandex</span>
            <span class="showcase__tag">+50 Colores</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Mantelería
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/>
              <path d="M18 14h-8"/>
              <path d="M15 18h-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SEÑALIZACIÓN Y ALFOMBRAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="senalizacion-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Impacto visual desde la entrada</span>
          <h2 class="showcase__title" id="senalizacion-heading">Señalización y Alfombras</h2>
          <p class="showcase__subtitle">Alfombras rojas y personalizadas, postes separadores cromados, podiums ejecutivos, señalética profesional y backdrops fotográficos — la primera impresión que define el tono de tu evento.</p>
          <p class="showcase__text">La entrada es el primer contacto de tus invitados con la experiencia. Nuestras <strong>alfombras de nylon tufted de 900 g/m²</strong> con respaldo antiderrapante de caucho natural están disponibles en anchos de 1.2 y 1.5 metros, con longitudes personalizadas desde 3 hasta 30 metros. El <strong>rojo clásico de alfombra ceremonial</strong> es el más solicitado para premiaciones, galas y recepciones VIP, pero también ofrecemos negro, blanco, azul marino y colores corporativos sobre pedido. Los <strong>postes separadores cromados de acero inoxidable 304</strong> con cinta de terciopelo retráctil de 2 metros delimitan pasillos de acceso con un acabado institucional impecable que complementa cualquier montaje de <a href="/servicios/iluminacion/">iluminación arquitectónica</a>.</p>
          <p class="showcase__text">Para eventos corporativos y conferencias, nuestros <strong>podiums ejecutivos</strong> están disponibles en <strong>madera de maple con acabado mate, acrílico transparente de 12 mm y modelos con pantalla LED integrada</strong> — todos con repisa interior, iluminación cuello de ganso, soporte para micrófono y pasacables oculto. La <strong>señalética direccional</strong> incluye caballetes de aluminio anodizado, banners roll-up de 85×200 cm, marcos para poster con perfil de aluminio snap-frame y backdrops tipo press wall con estructura de aluminio telescópica de hasta 3×2.4 metros. Ideales para complementar tu <a href="/servicios/audiovisual/">equipo audiovisual</a> en presentaciones y conferencias magistrales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Alfombra 900g/m²</span>
            <span class="showcase__tag">Postes Cromados</span>
            <span class="showcase__tag">Podium Ejecutivo</span>
            <span class="showcase__tag">Press Wall 3x2.4m</span>
            <span class="showcase__tag">Roll-Up Banner</span>
            <span class="showcase__tag">Snap Frame</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Señalización
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PLANTAS DE ENERGÍA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="energia-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Certificación eléctrica NOM</span>
          <h2 class="showcase__title" id="energia-heading">Plantas de Energía</h2>
          <p class="showcase__subtitle">Generadores diésel silenciados de 20 a 500 kW con cabina acústica, tableros de distribución eléctrica con protección diferencial y transferencia automática — energía ininterrumpida para eventos de cualquier escala.</p>
          <p class="showcase__text">Nuestras <strong>plantas de energía para eventos</strong> garantizan el suministro eléctrico continuo que tu producción exige. La flota incluye <strong>generadores diésel silenciados</strong> con cabina acústica de acero galvanizado que operan a <strong>65-72 dB(A) a 7 metros</strong> — el equivalente a una conversación en tono normal. Modelos desde <strong>20 kW para eventos sociales con iluminación y sonido básico</strong> hasta <strong>500 kW para festivales, expos y producciones con múltiples escenarios, pantallas LED y clima artificial</strong>. Cada generador cuenta con <strong>sistema de enfriamiento por radiador de cobre-aluminio, filtro de partículas diésel y tanque de combustible con autonomía de 8 a 16 horas</strong> dependiendo de la carga.</p>
          <p class="showcase__text">El servicio incluye <strong>tableros de distribución eléctrica</strong> con interruptores termomagnéticos, protección diferencial de 30 mA para seguridad de personas y enchufes industriales tipo CEE de 16A, 32A y 63A. Nuestros técnicos certificados NOM-001-SEDE realizan el <strong>cálculo de carga eléctrica gratuito</strong> basado en el inventario completo de <a href="/servicios/iluminacion/">iluminación</a>, <a href="/servicios/audiovisual/">equipo audiovisual</a> y demás instalaciones de tu evento. Incluimos <strong>cable de uso rudo calibre 8, 6 y 4 AWG con protección mecánica</strong>, canaletas pasa-cables para áreas de tránsito y operador técnico de guardia durante toda la duración del evento para monitoreo y respuesta inmediata ante cualquier contingencia.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">20 kW</span>
            <span class="showcase__tag">60 kW</span>
            <span class="showcase__tag">150 kW</span>
            <span class="showcase__tag">500 kW</span>
            <span class="showcase__tag">65-72 dB(A)</span>
            <span class="showcase__tag">NOM-001-SEDE</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Plantas de Energía
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CALEFACCIÓN Y CLIMA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="clima-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Confort garantizado en cualquier temporada</span>
          <h2 class="showcase__title" id="clima-heading">Calefacción y Clima</h2>
          <p class="showcase__subtitle">Calentadores infrarrojos radiantes, calefacción industrial para carpas, sistemas de nebulización, ventiladores evaporativos y aire acondicionado portátil — control total de la temperatura para el confort absoluto de tus invitados.</p>
          <p class="showcase__text">El confort térmico es un factor que tus invitados notan de inmediato pero rara vez mencionan cuando funciona bien — y que arruina la experiencia cuando falla. Nuestros <strong>calentadores de patio tipo torre radiante de 14,000 W</strong> funcionan con gas LP, cuentan con <strong>válvula de seguridad por termo-par, sensor anti-vuelco y rejilla protectora de acero inoxidable</strong>, y calientan un radio efectivo de 4 a 5 metros — ideales para terrazas, jardines y eventos al aire libre. Para <a href="/servicios/carpas/">carpas y espacios cerrados</a>, la <strong>calefacción industrial por ducto</strong> de 30,000 a 80,000 BTU distribuye aire caliente de forma uniforme con termostato digital regulable de 18 a 30 °C.</p>
          <p class="showcase__text">En temporada de calor, nuestros <strong>ventiladores evaporativos industriales de 450 W</strong> con tanque de 40 litros y oscilación de 90° reducen la temperatura percibida hasta 12 °C en áreas semi-abiertas. Los <strong>sistemas de nebulización profesional de alta presión (1,000 PSI)</strong> con boquillas de acero inoxidable de 0.15 mm generan micro-gotas que se evaporan antes de tocar a los invitados, enfriando el ambiente entre 8 y 15 °C sin mojar. Para eventos que requieren control de temperatura preciso, disponemos de <strong>equipos de aire acondicionado portátil de 3 a 5 TR (toneladas de refrigeración)</strong> con ducto flexible y termostato digital — perfectos para carpas cerradas, salas de reunión temporales y backstage de artistas. Complementa con <a href="/servicios/mobiliario/">mobiliario de descanso</a> para crear zonas de confort integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Torre 14,000 W</span>
            <span class="showcase__tag">Ducto 80,000 BTU</span>
            <span class="showcase__tag">Nebulización 1,000 PSI</span>
            <span class="showcase__tag">Evaporativo 450 W</span>
            <span class="showcase__tag">A/C 5 TR Portátil</span>
            <span class="showcase__tag">Termostato Digital</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Calefacción y Clima
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v20"/>
              <path d="M2 12h20"/>
              <path d="m4.93 4.93 14.14 14.14"/>
              <path d="m19.07 4.93-14.14 14.14"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
