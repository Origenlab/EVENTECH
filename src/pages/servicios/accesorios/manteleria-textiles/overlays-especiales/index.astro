---
/**
 * ─── Overlays y Telas Especiales — Pagina de Producto (Nivel 4) ───
 * Overlays de encaje, lentejuela y organza, telas para drapeado,
 * backdrops textiles y faldones de mesa para eventos en CDMX.
 *
 * Jerarquia: Servicios > Accesorios > Mantelería y Textiles > Overlays y Telas Especiales
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { label: "Overlays y Telas Especiales" },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre los tipos de overlay?", answer: 'Ofrecemos 4 tipos principales de overlay, cada uno con un efecto visual distinto: <strong>Encaje</strong> — textura delicada y romántica, ideal para bodas vintage y elegantes; se coloca sobre mantel liso para crear profundidad. <strong>Lentejuela</strong> — brillo completo que refleja la luz, perfecto para galas y eventos nocturnos; disponible en dorado, plateado, oro rosa y champagne. <strong>Organza cristal</strong> — transparencia sutil con brillo etéreo, crea capas de color sin ocultar el mantel base; 30+ colores. <strong>Tul bordado</strong> — textura delicada con patrones florales o geométricos, ideal para mesas de honor y postres.' },
  { question: "¿El drapeado incluye instalación con técnicos?", answer: 'Sí, todos los servicios de drapeado (techo, columnas y backdrops) <strong>incluyen instalación con técnicos de montaje</strong> sin costo adicional. Nuestro equipo lleva la estructura necesaria (rieles, ganchos, varillas), instala las telas con pliegues profesionales y las retira al finalizar el evento. El tiempo de instalación varía según la superficie: un drapeado de techo de 10x10 metros requiere aproximadamente 3-4 horas. Coordinamos el acceso al venue con anticipación para no interferir con otros proveedores.' },
  { question: "¿Cuál es la diferencia entre un backdrop textil y uno de señalización?", answer: 'Un <strong>backdrop textil</strong> utiliza telas como satín, terciopelo, gasa o lentejuela para crear un fondo decorativo con textura y movimiento — ideal para fondos de mesa de honor, photo booths y ceremonias. Un <strong>backdrop de <a href="/servicios/accesorios/senalizacion-alfombras/">señalización</a></strong> usa materiales rígidos (lona, vinil, acrílico) con diseños impresos como logos, nombres o gráficos — ideal para eventos corporativos, press walls y branding. Ambos pueden combinarse para crear instalaciones únicas.' },
  { question: "¿Qué medidas de faldones de mesa tienen disponibles?", answer: 'Nuestros faldones de mesa (buffet skirts) están disponibles en <strong>largo completo (hasta el piso)</strong> para mesas estándar de 75 cm de altura. El largo del faldón se adapta al perímetro de tu mesa: ofrecemos faldones de <strong>4, 5, 6 y 8 metros lineales</strong> que cubren mesas rectangulares de buffet completas. Disponibles en plisado box pleat (cuadrado) y shirred (fruncido). Colores principales: blanco, marfil, negro, navy y champagne. Se sujetan con clips de presión incluidos.' },
  { question: "¿Cuántos colores de overlays tienen disponibles?", answer: 'La disponibilidad de colores varía por tipo de overlay: <strong>Organza cristal</strong> — 30+ colores sólidos, la mayor variedad. <strong>Lentejuela</strong> — dorado, plateado, oro rosa, champagne, cobre, negro, blush y burgundy (8 colores). <strong>Encaje</strong> — blanco, marfil, champagne, negro y blush (5 colores clásicos). <strong>Tul bordado</strong> — blanco, marfil y champagne (3 tonos). Para drapeado de techo tenemos satín en 20+ colores y voile/gasa en 15+ colores. Enviamos muestras físicas de aprobación sin costo.' },
  { question: "¿Puedo combinar overlays con el resto de la mantelería?", answer: 'Absolutamente, es la forma más efectiva de elevar el montaje. Nuestro servicio de <strong>coordinación textil integral</strong> te permite combinar overlays con <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">manteles base</a>, <a href="/servicios/accesorios/manteleria-textiles/cubresillas-bandas/">cubresillas</a> y <a href="/servicios/accesorios/manteleria-textiles/servilletas-caminos/">servilletas</a> en la misma paleta. Las combinaciones más populares: mantel blanco + overlay lentejuela dorada para bodas glam, mantel lino + overlay encaje para estilo vintage, mantel negro + overlay organza champagne para galas. Un asesor te ayuda con muestras físicas.' },
];

const specs = [
  { label: "Overlays encaje", value: '72x72" y 90x90"' },
  { label: "Overlays lentejuela", value: '72x72" y 90x90" dorada/plateada' },
  { label: "Overlays organza", value: '72x72" y 90x90" 30+ colores' },
  { label: "Tul bordado", value: "Por metro, ancho 150 cm" },
  { label: "Faldones mesa", value: "Largo completo, plisado o liso" },
  { label: "Drapeado techo", value: "Satín/Voile, por metro lineal" },
  { label: "Drapeado columnas", value: "Kit con estructura" },
  { label: "Backdrop textil", value: "2.4x2.4 m y 3x2.4 m" },
  { label: "Instalación", value: "Técnicos de montaje incluidos para drapeados" },
  { label: "Pedido mínimo", value: "5 piezas overlays / 10 m drapeado" },
];

const sidebarNav = [
  { name: "Manteles y Cubremesas", href: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/" },
  { name: "Cubresillas y Bandas", href: "/servicios/accesorios/manteleria-textiles/cubresillas-bandas/" },
  { name: "Servilletas y Caminos", href: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/" },
  { name: "Overlays y Telas Especiales", href: null, active: true },
];

const sidebarRelated = [
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Mobiliario Sillas", href: "/servicios/mobiliario/sillas/" },
  { name: "Mobiliario Mesas", href: "/servicios/mobiliario/mesas/" },
  { name: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Gabriela Ríos", text: "Rentamos overlays de lentejuela dorada para las 25 mesas de nuestra boda de gala en Polanco. El efecto con la iluminación fue mágico — cada mesa brillaba como en una revista. La calidad de la lentejuela es excelente, bien cosida y sin desprendimientos. La entrega y recolección fueron impecables.", rating: 5, date: "2025-12-01" },
  { author: "Andrea Villalobos", text: "Contratamos drapeado de techo en satín blanco para un salón de 15x20 metros y un backdrop de terciopelo burgundy para la mesa de honor. El equipo de montaje fue extraordinario — transformaron el salón por completo en 4 horas. El resultado fue un espacio de ensueño que todos los invitados admiraron.", rating: 5, date: "2025-10-28" },
  { author: "Daniela Herrera", text: "Para los XV años de mi hija rentamos overlays de encaje marfil sobre manteles de satín blush y un backdrop textil con gasa y luces. El montaje quedó espectacular y las fotos se ven increíbles. El servicio de coordinación textil nos ayudó a elegir la combinación perfecta con muestras previas. Totalmente recomendable.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Overlays y Telas Especiales para Eventos en CDMX",
    description: "Renta de overlays de encaje, lentejuela y organza, telas para drapeado, backdrops textiles y faldones de mesa. Textura y profundidad visual. Desde $50 por pieza.",
    url: "/servicios/accesorios/manteleria-textiles/overlays-especiales/",
    priceRange: { min: 50, max: 300 },
    reviews,
    ratingValue: 5,
    reviewCount: 198,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Mantelería y Textiles", url: "/servicios/accesorios/manteleria-textiles/" },
    { name: "Overlays y Telas Especiales", url: "/servicios/accesorios/manteleria-textiles/overlays-especiales/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Overlays y Telas Especiales para Eventos en CDMX | EVENTECH"
  description="Renta de overlays de encaje, lentejuela y organza, telas para drapeado, backdrops textiles y faldones de mesa. Textura y profundidad visual. Desde $50 por pieza."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Texturas premium de alto impacto"
    title='Renta de <span class="highlight">Overlays y Telas Especiales</span> para Eventos'
    subtitle="Overlays de encaje, lentejuela, organza y tul bordado para mesas de alto impacto. Telas para drapeado de techo, backdrops textiles y faldones de mesa. Instalación con técnicos incluida."
    primaryCTA={{ label: "Cotiza tus textiles especiales", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar overlays y telas especiales para mi evento` }}
    cards={[
      {
        title: "Overlays y telas decorativas para montajes de alto impacto",
        content: "<strong>Renta de overlays decorativos</strong> de encaje vintage, lentejuela dorada/plateada, organza cristal y tul bordado para mesas de honor, postres y centros de mesa. Faldones de mesa en múltiples telas y largos para buffets y estaciones de servicio. Cada overlay transforma una mesa sencilla en un montaje de revista con textura y profundidad visual.",
      },
      {
        title: "Drapeado profesional con estructura e instalación incluida",
        content: "<strong>Telas para drapeado de techo, columnas y backdrops</strong> en satín, voile y gasa con servicio de instalación completo. Técnicos de montaje con estructura incluida para crear ambientes envolventes que transforman cualquier espacio. Backdrops textiles de 2.4x2.4 m y 3x2.4 m en terciopelo, lentejuela y gasa para ceremonias, mesas de honor y photo booths.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres transformar tu espacio con texturas premium?"
    subheadline="Cotiza sin compromiso — drapeados, overlays y backdrops que convierten cualquier venue en un escenario de ensueño"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Mantelería y Textiles</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas overlays y telas especiales para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar overlays y telas especiales para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Overlays y Telas Especiales</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Overlays de Lentejuela Dorada -->
          <section class="section section--alt" aria-labelledby="lentejuela-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Máximo brillo y glamour</span>
                <h2 class="showcase__title" id="lentejuela-heading">Overlays de Lentejuela Dorada</h2>
                <p class="showcase__subtitle">Overlays de lentejuela completa que reflejan la luz y transforman cada mesa en una pieza de gala.</p>
                <p class="showcase__text">Nuestros <strong>overlays de lentejuela</strong> son el elemento decorativo más impactante para mesas de eventos nocturnos y galas. Cada overlay está cubierto por <strong>lentejuelas cosidas individualmente sobre base de malla</strong> que reflejan la luz desde cualquier ángulo, creando un efecto de brillo deslumbrante. Disponibles en <strong>dorado, plateado, oro rosa, champagne, cobre, negro, blush y burgundy</strong>. Tamaños de 72x72" y 90x90".</p>
                <p class="showcase__text">Se colocan directamente sobre el <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">mantel base liso</a> (blanco, negro o color neutro) para crear un contraste de texturas que eleva todo el montaje. Son los favoritos para <strong>mesas de honor, mesa de novios, mesa de postres y mesas VIP</strong>. La combinación con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> multiplica el efecto visual, llenando el espacio de destellos dorados que crean una atmósfera mágica.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Lentejuela completa</span>
                  <span class="showcase__tag">8 colores metálicos</span>
                  <span class="showcase__tag">72x72" y 90x90"</span>
                  <span class="showcase__tag">Galas y bodas glam</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Overlays Lentejuela
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Overlays Lentejuela Dorada</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Overlays de Encaje Vintage -->
          <section class="section section--alt" aria-labelledby="encaje-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegancia romántica</span>
                <h2 class="showcase__title" id="encaje-heading">Overlays de Encaje Vintage</h2>
                <p class="showcase__subtitle">Overlays de encaje con patrones florales que aportan romanticismo y textura a mesas elegantes.</p>
                <p class="showcase__text">Nuestros <strong>overlays de encaje vintage</strong> son la elección perfecta para bodas románticas, eventos shabby chic y montajes con estética clásica. El encaje ofrece una <strong>textura delicada con patrones florales y geométricos</strong> que agregan profundidad visual a la mesa sin saturarla. Disponibles en <strong>blanco, marfil, champagne, negro y blush</strong>. Tamaños de 72x72" y 90x90" con bordes festoneados.</p>
                <p class="showcase__text">La combinación más solicitada es overlay de encaje marfil sobre <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">mantel de satín</a> en tono complementario (blush, champagne o lavanda) — creando un efecto vintage-elegante que fotografía extraordinariamente bien. Para mesas imperiales, dos overlays de encaje traslapados crean un <strong>efecto de alfombra textil</strong> a lo largo de toda la mesa. Complementa con <a href="/servicios/accesorios/manteleria-textiles/servilletas-caminos/">servilletas y servilleteros</a> coordinados.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Encaje vintage</span>
                  <span class="showcase__tag">Patrones florales</span>
                  <span class="showcase__tag">Bordes festoneados</span>
                  <span class="showcase__tag">Bodas románticas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Overlays Encaje
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Overlays Encaje Vintage</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Drapeado de Techo Satín -->
          <section class="section section--alt" aria-labelledby="drapeado-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Transformación total del espacio</span>
                <h2 class="showcase__title" id="drapeado-heading">Drapeado de Techo Satín</h2>
                <p class="showcase__subtitle">Telas para drapeado de techo en satín y voile que transforman cualquier salón en un espacio de ensueño.</p>
                <p class="showcase__text">Nuestro servicio de <strong>drapeado de techo</strong> es la forma más espectacular de transformar un salón o espacio industrial en un venue de gala. Utilizamos telas de <strong>satín premium, voile transparente y gasa etérea</strong> instaladas en pliegues profesionales que crean un efecto de nube o carpa interior. Se renta por metro lineal con instalación incluida. Disponible en <strong>20+ colores de satín y 15+ de voile</strong>.</p>
