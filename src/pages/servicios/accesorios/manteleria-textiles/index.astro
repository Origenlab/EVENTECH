---
/**
 * ─── Manteleria y Textiles para Eventos — Sub-subcategoria (Nivel 3) ───
 * Pagina especializada: Renta de Manteleria y Textiles para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import Gallery4x4 from "@components/Gallery4x4.astro";
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Mantelería y Textiles" },
];

const MANTELERIA = [
  {
    name: "Manteles y Cubremesas",
    price: "Desde $120 c/u",
    excerpt: "Manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino. Más de 50 colores disponibles para bodas, banquetes y eventos corporativos.",
    href: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/",
    image: "/images/accesorios/manteles-premium-boda-elegante.avif",
    tags: ["Poliéster 220g", "Satín", "Organza", "Lino", "+50 Colores"],
    badge: "Más solicitados",
  },
  {
    name: "Cubresillas y Bandas",
    price: "Desde $60 c/u",
    excerpt: "Fundas universales, spandex y cubresillas elegantes con bandas y moños en más de 40 colores. Transformación instantánea para sillas Chiavari, Tiffany y banqueteras.",
    href: "/servicios/accesorios/manteleria-textiles/cubresillas-bandas/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    tags: ["Spandex", "Funda Universal", "Moños", "+40 Colores"],
  },
  {
    name: "Servilletas y Caminos",
    price: "Desde $25 c/u",
    excerpt: "Servilletas de tela coordinadas con mantelería, caminos de mesa decorativos, servilleteros y doblado artístico para mesas de gala y eventos formales.",
    href: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    tags: ["50×50 cm", "Doblado Artístico", "Caminos Lentejuela", "Yute"],
  },
  {
    name: "Overlays y Telas Especiales",
    price: "Desde $90 c/u",
    excerpt: "Overlays de encaje, lentejuela y organza, telas para drapeado, backdrops y faldones de mesa. Textura y profundidad para montajes de alto impacto visual.",
    href: "/servicios/accesorios/manteleria-textiles/overlays-especiales/",
    image: "/images/accesorios/accesorio-evento-03.avif",
    tags: ["Encaje", "Lentejuela", "Organza Cristal", "Drapeado"],
  },
];

const faqs = [
  { question: "¿Cuál es el pedido mínimo de mantelería para eventos?", answer: "El pedido mínimo es de 10 piezas del mismo tipo (manteles, cubresillas o servilletas). Para paquetes completos de mantelería que incluyen manteles, cubresillas, bandas y servilletas no hay mínimo — armamos paquetes desde una sola mesa. En eventos grandes ofrecemos precios preferenciales por volumen a partir de 50 piezas, con descuentos progresivos según cantidad. Contáctanos para una cotización personalizada según el número de mesas e invitados de tu evento." },
  { question: "¿Pueden igualar los colores exactos de mi paleta de boda?", answer: "Sí, trabajamos con un catálogo de más de 50 colores base en manteles y más de 40 en bandas y moños. Además, ofrecemos un servicio de color matching donde nos envías tu paleta (código Pantone, muestra física o referencia fotográfica) y seleccionamos las combinaciones más cercanas de nuestro inventario. En caso de requerir un tono muy específico, contamos con proveedores de telas especiales con un tiempo de preparación de 2 a 3 semanas adicionales. Siempre enviamos muestras físicas para aprobación antes del evento." },
  { question: "¿Qué tipos de tela manejan y cuál es la diferencia?", answer: "Manejamos 8 tipos de tela principales: Poliéster estándar (económico, resistente a arrugas, ideal para eventos casuales), Satín (brillo elegante, caída suave, perfecto para bodas), Organza (transparente y delicada, ideal como overlay), Lino (textura natural premium, aspecto rústico-elegante), Tafeta (estructura rígida, brillo sutil), Encaje (decorativo, ideal para overlays vintage), Lentejuela (brillo completo, eventos de gala) y Spandex (elástico, ajuste perfecto en cubresillas). Nuestro asesor te recomienda la mejor opción según el estilo y presupuesto de tu evento." },
  { question: "¿La mantelería llega lavada y planchada?", answer: "Absolutamente sí. Toda nuestra mantelería se entrega recién lavada, desinfectada y planchada profesionalmente con vapor industrial. Cada pieza pasa por un control de calidad donde verificamos que no tenga manchas, rasgaduras ni decoloración. Se transporta en fundas individuales para mantener el planchado impecable hasta el momento del montaje. Al finalizar tu evento, recolectamos la mantelería sucia — no necesitas lavarla. El servicio de lavado y planchado está incluido en el precio de renta." },
  { question: "¿Cuándo entregan la mantelería antes del evento?", answer: "La entrega estándar es 1 día antes de tu evento (entre 9:00 y 14:00 horas) para que tengas tiempo de supervisar el montaje. Para eventos en viernes o sábado, entregamos el jueves o viernes respectivamente. También ofrecemos entrega el mismo día del evento con un cargo adicional de logística urgente. La recolección se realiza el día siguiente al evento. En todos los casos, nuestro equipo de logística coordina contigo o con tu wedding planner los horarios exactos." },
  { question: "¿Con cuánta anticipación debo reservar la mantelería?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación para garantizar disponibilidad en el color y tipo de tela que necesitas. En temporada alta (noviembre a febrero) lo ideal es apartar con 6 a 8 semanas, especialmente para colores populares como blanco, marfil, champagne y dorado. Los paquetes completos de mantelería (manteles + cubresillas + servilletas + caminos) requieren mayor anticipación porque coordinamos todas las piezas. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mantelería y Textiles CDMX",
    description: "Manteles, cubresillas, servilletas, caminos de mesa y overlays decorativos para bodas, banquetes y eventos. Lavado y planchado incluido.",
    url: "/servicios/accesorios/manteleria-textiles/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Mantelería y Textiles", url: "/servicios/accesorios/manteleria-textiles/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mantelería y Textiles CDMX"
  description="Renta de manteles, cubresillas, servilletas, caminos de mesa y overlays para eventos en CDMX. Lavado y planchado incluido. Desde $15/pieza. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="50+ colores y 8 tipos de tela"
    title='Renta de <span class="highlight">Mantelería y Textiles</span> para Eventos en CDMX'
    subtitle="Manteles, cubresillas, servilletas, caminos de mesa y overlays decorativos en más de 50 colores y 8 tipos de tela. Lavado, planchado profesional y entrega incluidos en cada renta."
    primaryCTA={{ label: "Cotiza tu mantelería", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mantelería y textiles para mi evento` }}
    cards={[
      {
        title: "Textiles de grado profesional para cada tipo de evento",
        content: "<strong>Renta de mantelería y textiles para eventos</strong> con el catálogo más completo de la Ciudad de México. Manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino premium para bodas, banquetes y galas. Cubresillas universales y spandex con bandas decorativas en más de 40 colores para transformar cualquier silla en una pieza elegante. Servilletas de tela coordinadas, caminos de mesa artesanales y overlays de encaje y lentejuela — cada pieza seleccionada por calidad, caída y acabado impecable.",
      },
      {
        title: "Servicio integral con lavado y planchado incluido",
        content: "<strong>Mantelería siempre impecable</strong> sin preocupaciones. Toda nuestra renta incluye lavado profesional, desinfección, planchado con vapor industrial y empaque individual de cada pieza. Entrega coordinada 1 día antes de tu evento con recolección al día siguiente. Control de calidad pieza por pieza para garantizar cero manchas y cero arrugas. Asesoría de color personalizada para igualar tu paleta de boda o tema corporativo con precisión.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la mantelería perfecta para tu evento?"
    subheadline="Cotiza sin compromiso y recibe asesoría de color personalizada con muestras físicas de tela"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de mantelería
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Mantelería y Textiles"
        subtitle="Cada detalle textil para una presentación impecable"
        description={[
          "Desde manteles básicos de poliéster hasta overlays de lentejuela y encaje para montajes de alta gama. Contamos con el inventario de textiles para eventos más completo de la Ciudad de México.",
          "Cada pieza incluye lavado profesional, planchado con vapor industrial y empaque individual. Más de 50 colores disponibles con servicio de color matching para tu paleta de boda o evento."
        ]}
      />

      <div class="grid grid--4">
        {MANTELERIA.map((item) => (
          <ProductCard
            name={item.name}
            price={item.price}
            excerpt={item.excerpt}
            href={item.href}
            image={item.image}
            tags={item.tags}
            badge={item.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MANTELES Y CUBREMESAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="manteles-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">50+ colores disponibles</span>
          <h2 class="showcase__title" id="manteles-heading">Manteles y Cubremesas</h2>
          <p class="showcase__subtitle">El lienzo perfecto para cada mesa de tu evento, disponible en formatos redondo, rectangular y cuadrado.</p>
          <p class="showcase__text">Nuestros <strong>manteles para eventos</strong> están disponibles en tres formatos principales: <strong>redondo (120", 132" y 156"), rectangular (60x102", 60x126", 90x132") y cuadrado (54x54", 72x72", 90x90")</strong>. Fabricados en 8 tipos de tela profesional: <strong>poliéster estándar, satín brillante, organza transparente, lino premium, tafeta estructurada, encaje decorativo, lentejuela y spandex</strong>. Cada formato disponible en más de 50 colores sólidos, desde blancos clásicos hasta tonos metálicos y colores de temporada.</p>
          <p class="showcase__text">Incluyen <strong>caída completa hasta el piso para montajes formales</strong> o media caída para eventos casuales y corporativos. Los manteles de satín y lino son los favoritos para <strong>bodas y galas</strong> por su caída elegante y brillo sofisticado. Para presentaciones corporativas, el poliéster premium ofrece resistencia y un acabado profesional. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario para eventos</a> para un montaje integral de mesas redondas, rectangulares y tipo banquete.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Redondo 120"-156"</span>
            <span class="showcase__tag">Rectangular</span>
            <span class="showcase__tag">Cuadrado</span>
            <span class="showcase__tag">8 tipos de tela</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Manteles
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CUBRESILLAS Y BANDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cubresillas-heading">
    <div class="container">
      <ServiceShowcase
    title="Cubresillas y Bandas"
    headingId="cubresillas-heading"
    badge="Transformación elegante"
    subtitle="Transforma sillas ordinarias en piezas elegantes con fundas profesionales y bandas decorativas en 40+ colores."
    tags={["Universal", "Spandex", "40+ colores", "Cojines Chiavari"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Cubresillas"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>fundas para sillas de evento</strong> están disponibles en tres estilos principales: <strong>universal (se adapta a sillas banqueteras estándar), spandex elástico (ajuste perfecto sin arrugas) y cubresillas tipo funda larga</strong> con caída elegante hasta el piso. Las bandas y moños complementarios vienen en <strong>más de 40 colores</strong> en satín, organza y tafeta, permitiéndote crear combinaciones únicas que refuercen la paleta cromática de tu evento.</p>
      <p class="showcase__text">Para <strong>sillas Chiavari y Tiffany</strong> ofrecemos cojines en colores coordinados que aportan confort y estilo sin necesidad de funda completa. Cada cubresilla se entrega <strong>lavada, planchada y en funda individual</strong> para facilitar el montaje. Ideales para <strong>bodas, galas, banquetes y eventos corporativos</strong> donde cada detalle cuenta. Combínalas con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para crear ambientes integrales con decoración textil coordinada.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVILLETAS Y CAMINOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="servilletas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Detalles que importan</span>
          <h2 class="showcase__title" id="servilletas-heading">Servilletas y Caminos de Mesa</h2>
          <p class="showcase__subtitle">Los detalles finales que elevan la presentación de cada lugar y centro de mesa.</p>
          <p class="showcase__text">Nuestras <strong>servilletas de tela para eventos</strong> están disponibles en los mismos colores y tipos de tela que nuestros manteles, garantizando <strong>coordinación perfecta en cada mesa</strong>. Tamaño estándar de 20x20 pulgadas en poliéster, satín y lino. Ofrecemos servicio de <strong>doblado artístico decorativo</strong> (abanico, lirio, corona, bolsillo para cubiertos) y complementamos con servilleteros metálicos en dorado, plateado y oro rosa.</p>
          <p class="showcase__text">Los <strong>caminos de mesa</strong> son el acento perfecto para agregar textura y dimensión. Disponibles en <strong>encaje vintage, yute rústico, satín liso, lentejuela brillante y gasa etérea</strong> con anchos de 12 a 14 pulgadas y largos personalizados según tu mesa. Para montajes tipo banquete largo, los caminos crean una línea visual impresionante. Combínalos con nuestros servicios de <a href="/servicios/catering/">catering y vajilla</a> para una presentación de mesa integral y profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Servilletas 20x20"</span>
            <span class="showcase__tag">Doblado artístico</span>
            <span class="showcase__tag">Caminos de mesa</span>
            <span class="showcase__tag">Servilleteros</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Servilletas y Caminos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       OVERLAYS Y TELAS ESPECIALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="overlays-heading">
    <div class="container">
      <ServiceShowcase
    title="Overlays y Telas Especiales"
    headingId="overlays-heading"
    badge="Textura y profundidad"
    subtitle="Capas decorativas de encaje, lentejuela y organza que aportan dimensión y lujo a cada montaje."
    tags={["Encaje", "Lentejuela", "Drapeado", "Faldones de mesa"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Overlays y Telas"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>overlays decorativos</strong> se colocan sobre el mantel base para crear composiciones de múltiples capas con textura y profundidad visual. Disponibles en <strong>encaje romántico, lentejuela completa (champagne, dorado, plateado, oro rosa), organza transparente y tul suave</strong>. Tamaños estándar de 72x72" y 90x90" que se adaptan a mesas redondas y cuadradas. Cada overlay transforma una mesa sencilla en un montaje de revista.</p>
      <p class="showcase__text">Para montajes de gran formato ofrecemos <strong>telas para drapeado de techos y paredes</strong> (gasa, voile y chiffon), <strong>telas para backdrop</strong> (satín, terciopelo y lentejuela) y <strong>faldones de mesa</strong> (buffet skirts) con pliegues profesionales. Las telas de drapeado se rentan por metro lineal y nuestro equipo de montaje se encarga de la instalación. Combínalos con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para crear ambientes envolventes donde la luz juegue con las texturas de cada tela.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo luce nuestra mantelería?</h2>
      <Gallery4x4 images={[
        { src: "/images/accesorios/alfombra-roja-red-carpet-evento.avif", alt: "Alfombra roja red carpet evento" },
        { src: "/images/accesorios/calentador-patio-terraza-evento.avif", alt: "Calentador patio terraza evento" },
        { src: "/images/accesorios/manteles-premium-boda-elegante.avif", alt: "Manteles premium boda elegante" },
        { src: "/images/accesorios/planta-luz-generador-evento.avif", alt: "Planta de luz generador evento" },
        { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Silla Tiffany dorada para boda de gala en CDMX" },
        { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas montaje banquete" },
        { src: "/images/mobiliario/lounge-moderno-terciopelo-evento-premium.avif", alt: "Sala lounge moderno terciopelo evento premium" },
        { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Barra de bebidas bartender madera para evento" },
      ]} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar mantelería y textiles?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por evento (+IVA). Incluye entrega y montaje en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$800",
          priceNote: "por evento",
          description: "Mantelería básica para eventos.",
          features: [
            { text: "Manteles lisos blancos", included: true },
            { text: "Entrega y recolección", included: true },
            { text: "Cubresillas", included: false },
