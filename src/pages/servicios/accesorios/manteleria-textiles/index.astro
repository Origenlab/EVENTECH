---
/**
 * ─── EVENTECH.MX — Renta de Mantelería y Textiles para Eventos (Hub L4, molde hm- 2026) ───
 * Manteles y Cubremesas · Cubresillas y Bandas · Servilletas y Caminos de Mesa · Overlays y Telas Especiales — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/accesorios — manteles-premium-boda-elegante.avif real/temática; accesorio-evento-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "manteles-cubremesas",
    name: "Manteles y Cubremesas",
    badge: "Los más solicitados",
    excerpt: "Manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino premium. Caída completa de 75 cm hasta el piso o media caída de 35 cm, en más de 50 colores para bodas, banquetes y eventos corporativos.",
    href: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/",
    image: "/images/accesorios/manteles-premium-boda-elegante.avif",
    specs: ["Redondo 305–396 cm", "8 tipos de tela", "Caída 75 o 35 cm", "+50 colores"],
  },
  {
    id: "cubresillas-bandas",
    name: "Cubresillas y Bandas",
    badge: "Transformación instantánea",
    excerpt: "Fundas universales, spandex de ajuste perfecto y cubresillas tipo funda larga, con bandas y moños en más de 40 colores. Cojines coordinados para sillas Chiavari y Tiffany.",
    href: "/servicios/accesorios/manteleria-textiles/cubresillas-bandas/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    specs: ["Universal y spandex", "Bandas +40 colores", "Cojines Chiavari/Tiffany", "Ajuste sin arrugas"],
  },
  {
    id: "servilletas-caminos",
    name: "Servilletas y Caminos de Mesa",
    badge: "El detalle final",
    excerpt: "Servilletas de tela de 50×50 cm coordinadas con tu mantelería y doblado artístico decorativo. Caminos de mesa en encaje, yute rústico y lentejuela, de 30 a 35 cm de ancho.",
    href: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    specs: ["Servilletas 50×50 cm", "Caminos 30–35 cm", "Doblado artístico", "Yute y lentejuela"],
  },
  {
    id: "overlays-especiales",
    name: "Overlays y Telas Especiales",
    badge: "Textura y profundidad",
    excerpt: "Overlays de encaje, lentejuela y organza cristal en 183×183 y 229×229 cm, más telas para drapeado, backdrops y faldones de mesa que suman dimensión a cada montaje.",
    href: "/servicios/accesorios/manteleria-textiles/overlays-especiales/",
    image: "/images/accesorios/accesorio-evento-03.avif",
    specs: ["183×183 y 229×229 cm", "Encaje y lentejuela", "Drapeado por metro", "Faldones de mesa"],
  },
];

const whyFeatures = [
  {
    title: "Catálogo de 8 tipos de tela y más de 50 colores",
    body: "No todas las telas se comportan igual: el satín brilla y cae distinto al lino, la organza es transparente y el spandex se ajusta sin arrugas. Manejamos 8 tipos de tela profesional — poliéster, satín, organza, lino, tafeta, encaje, lentejuela y spandex — en más de 50 colores, para que la elección responda al estilo real de tu evento y no a lo único disponible.",
  },
  {
    title: "Asesoría de color con muestras físicas",
    body: "Nos envías tu paleta — código Pantone, muestra física o referencia fotográfica — y seleccionamos las combinaciones más cercanas de nuestro inventario. Para tonos muy específicos trabajamos con proveedores de telas especiales. Siempre enviamos muestra física para tu aprobación antes del evento: nada se decide a distancia.",
  },
  {
    title: "Lavado y planchado profesional en cada pieza",
    body: "Toda la mantelería se entrega recién lavada, desinfectada y planchada con vapor industrial. Cada pieza pasa por control de calidad para verificar que no tenga manchas, rasgaduras ni decoloración, y se transporta en fundas individuales. Al finalizar tu evento nosotros recolectamos y lavamos — tú no tienes que hacerlo.",
  },
  {
    title: "Coordinación completa entre mantel, silla y servilleta",
    body: "Mantel, cubresilla, banda, servilleta y camino de mesa salen del mismo catálogo de colores y telas, así que coordinan entre sí sin adivinar. Un solo proveedor calcula las combinaciones, evita contrastes accidentales y entrega todo listo para el mismo montaje.",
  },
  {
    title: "Logística de entrega y recolección coordinada",
    body: "Entregamos un día antes de tu evento para que tengas tiempo de supervisar el montaje, y recolectamos al día siguiente — tú no cargas con la logística de regreso. Para viernes y sábados ajustamos los horarios de entrega, y atendemos solicitudes urgentes el mismo día sujetas a disponibilidad.",
  },
  {
    title: "Inventario para cualquier escala de evento",
    body: "Desde 10 manteles para una cena íntima hasta 200+ cubiertas para una boda grande, con precios preferenciales por volumen a partir de 50 piezas. Armamos paquetes completos de mantel, cubresilla, banda y servilleta sin pedido mínimo — la mantelería se adapta al tamaño real de tu evento.",
  },
];

const steps = [
  { n: 1, t: "Cotización y elección de color", p: "Cuéntanos el tipo de evento, número de mesas y sillas, y la paleta que tienes en mente — por WhatsApp o formulario. En menos de 24 horas te enviamos propuesta con las combinaciones de tela y color recomendadas para tu presupuesto." },
  { n: 2, t: "Muestras físicas y aparto", p: "Te enviamos muestras físicas de tela y color para que apruebes antes de comprometer tu fecha. Con el 30% de anticipo apartamos el inventario — colores populares como blanco, marfil, champagne y dorado se agotan primero en temporada alta." },
  { n: 3, t: "Lavado, planchado y empaque", p: "Cada pieza se lava, desinfecta y plancha con vapor industrial, pasa control de calidad y se empaca individualmente. Todo queda listo para transportarse sin arrugas ni manchas hasta el día de entrega." },
  { n: 4, t: "Entrega, montaje y recolección", p: "Entregamos un día antes de tu evento para que supervises el montaje con calma. Al finalizar, recolectamos toda la mantelería al día siguiente — tú no lavas ni regresas nada. Entrega y recolección incluidas dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuál es el pedido mínimo de mantelería para eventos?", answer: "El pedido mínimo es de 10 piezas del mismo tipo (manteles, cubresillas o servilletas). Para paquetes completos de mantelería que incluyen manteles, cubresillas, bandas y servilletas no hay mínimo — armamos paquetes desde una sola mesa. En eventos grandes ofrecemos precios preferenciales por volumen a partir de 50 piezas, con descuentos progresivos según cantidad. Contáctanos para una cotización personalizada según el número de mesas e invitados de tu evento." },
  { question: "¿Pueden igualar los colores exactos de mi paleta de boda?", answer: "Sí, trabajamos con un catálogo de más de 50 colores base en manteles y más de 40 en bandas y moños. Además, ofrecemos un servicio de color matching donde nos envías tu paleta (código Pantone, muestra física o referencia fotográfica) y seleccionamos las combinaciones más cercanas de nuestro inventario. En caso de requerir un tono muy específico, contamos con proveedores de telas especiales con un tiempo de preparación de 2 a 3 semanas adicionales. Siempre enviamos muestras físicas para aprobación antes del evento." },
  { question: "¿Qué tipos de tela manejan y cuál es la diferencia?", answer: "Manejamos 8 tipos de tela principales: Poliéster estándar (económico, resistente a arrugas, ideal para eventos casuales), Satín (brillo elegante, caída suave, perfecto para bodas), Organza (transparente y delicada, ideal como overlay), Lino (textura natural premium, aspecto rústico-elegante), Tafeta (estructura rígida, brillo sutil), Encaje (decorativo, ideal para overlays vintage), Lentejuela (brillo completo, eventos de gala) y Spandex (elástico, ajuste perfecto en cubresillas). Nuestro asesor te recomienda la mejor opción según el estilo y presupuesto de tu evento." },
  { question: "¿La mantelería llega lavada y planchada?", answer: "Absolutamente sí. Toda nuestra mantelería se entrega recién lavada, desinfectada y planchada profesionalmente con vapor industrial. Cada pieza pasa por un control de calidad donde verificamos que no tenga manchas, rasgaduras ni decoloración. Se transporta en fundas individuales para mantener el planchado impecable hasta el momento del montaje. Al finalizar tu evento, recolectamos la mantelería sucia — no necesitas lavarla. El servicio de lavado y planchado está incluido en el precio de renta." },
  { question: "¿Cuándo entregan la mantelería antes del evento?", answer: "La entrega estándar es 1 día antes de tu evento (entre 9:00 y 14:00 horas) para que tengas tiempo de supervisar el montaje. Para eventos en viernes o sábado, entregamos el jueves o viernes respectivamente. También ofrecemos entrega el mismo día del evento con un cargo adicional de logística urgente. La recolección se realiza el día siguiente al evento. En todos los casos, nuestro equipo de logística coordina contigo o con tu wedding planner los horarios exactos." },
  { question: "¿Con cuánta anticipación debo reservar la mantelería?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación para garantizar disponibilidad en el color y tipo de tela que necesitas. En temporada alta (noviembre a febrero) lo ideal es apartar con 6 a 8 semanas, especialmente para colores populares como blanco, marfil, champagne y dorado. Los paquetes completos de mantelería (manteles + cubresillas + servilletas + caminos) requieren mayor anticipación porque coordinamos todas las piezas. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
  { question: "¿Qué medida de mantel necesito según el tamaño de mi mesa?", answer: "Depende del tamaño de tu mesa y la caída que busques. Para mesas redondas banquete de 152 cm (60\") de diámetro, un mantel de 260 cm da caída media (35 cm) y uno de 305 cm da caída completa hasta el piso (75 cm); para mesas de 183 cm (72\") recomendamos manteles de 305 a 335 cm. En mesas rectangulares imperiales de 76×183 cm, el mantel de 152×259 cm cubre con caída media y el de 229×335 cm con caída completa. Si no estás seguro de la medida de tus mesas, envíanos una foto o las medidas exactas por WhatsApp y nuestro equipo te recomienda el mantel correcto sin que tengas que hacer el cálculo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mantelería y Textiles para Eventos en CDMX",
    description: "Renta de manteles, cubresillas, servilletas, caminos de mesa y overlays para bodas y eventos en CDMX. Lavado, planchado y asesoría de color incluidos.",
    url: "/servicios/accesorios/manteleria-textiles/",
    priceRange: { min: 35, max: 1500 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Mantelería y Textiles", url: "/servicios/accesorios/manteleria-textiles/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Mantelería y Textiles" },
];
---

<PageLayout
  title="Renta de Mantelería y Textiles para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/accesorios/manteles-premium-boda-elegante.avif"
  description="Renta de manteles, cubresillas, servilletas y overlays para eventos en CDMX. +50 colores, 8 tipos de tela, lavado y planchado incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="manteleria-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Mantelería y textiles · CDMX y ZMVM</p>
            <h1 id="manteleria-hero-heading">
              Mantelería y textiles que visten cada mesa con <em>más de 50 colores y 8 tipos de tela</em>
            </h1>
            <p class="hm-hero__lead">
              Manteles, cubresillas, servilletas, caminos de mesa y overlays decorativos en
              poliéster, satín, organza, lino, tafeta, encaje, lentejuela y spandex. Lavado,
              planchado profesional y asesoría de color incluidos en cada renta.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mantelería%20y%20textiles%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar mantelería
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>mantelería y textiles para eventos</strong> en CDMX y zona
              metropolitana con <strong>8 tipos de tela profesional</strong> — poliéster, satín,
              organza, lino, tafeta, encaje, lentejuela y spandex — en
              <strong>más de 50 colores</strong>. Manteles redondos, rectangulares y cuadrados con
              caída completa de 75 cm o media caída de 35 cm, dimensionados según el tamaño real
              de tu mesa.
            </p>
            <p>
              Sabemos que la mantelería es el primer detalle que se nota en el salón: por eso
              cada renta incluye lavado profesional, planchado con vapor industrial y asesoría
              de color con muestras físicas. Para un montaje integral combina con nuestro
              <a href="/servicios/mobiliario/">mobiliario</a>, las
              <a href="/servicios/mobiliario/mesas/">mesas para eventos</a> y el resto de
              <a href="/servicios/accesorios/">accesorios</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de mantelería y textiles disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mantelería%20y%20textiles%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo textil más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué mantelería necesita tu evento?</h2>
            <p class="hm__head-sub">Del mantel base al overlay decorativo — con la tela, el color y la caída correctos para cada mesa.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La mantelería es el lienzo de cada mesa: define el tono, la formalidad y hasta la
              temperatura visual del salón antes de que lleguen los centros de mesa. La elección
              correcta no es solo color — es el tipo de tela, la caída y la coordinación entre
              mantel, cubresilla y servilleta.
            </p>
            <p>
              Manteles y cubremesas para la base de cada mesa. Cubresillas y bandas para
              transformar el asiento. Servilletas y caminos para el detalle final. Overlays y
              telas especiales para sumar textura y profundidad. Una sola empresa para vestir tu
              evento completo.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones textiles — en detalle</h2>
            <p class="hm__head-sub">Medidas, materiales, colores y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada pieza de mantelería hay decisiones que afectan la presentación
              final: el tipo de tela que determina brillo y caída, la medida que decide si el
              mantel llega al piso o se queda a media altura, y el color que debe coordinar con
              todo lo demás.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- MANTELES Y CUBREMESAS -->
        <article class="hm-feat" aria-labelledby="feat-manteles-cubremesas">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Manteles y Cubremesas</p>
            <h3 class="hm-feat__title" id="feat-manteles-cubremesas">El lienzo perfecto para cada mesa, en redondo, rectangular y cuadrado</h3>
            <p class="hm-feat__lead">Antes de los centros de mesa, antes de la vajilla — el mantel define el tono del salón. La elección correcta no es solo color, es tela y caída.</p>
            <p>
              Disponibles en tres formatos: <strong>redondo (305, 335 y 396 cm de diámetro),
              rectangular (152×259, 152×320 y 229×335 cm) y cuadrado (137×137, 183×183 y
              229×229 cm)</strong>. Fabricados en <strong>8 tipos de tela profesional</strong>:
              poliéster estándar, satín brillante, organza transparente, lino premium, tafeta
              estructurada, encaje decorativo, lentejuela y spandex — cada uno con más de 50
              colores sólidos disponibles.
            </p>
            <p>
              Con <strong>caída completa de 75 cm hasta el piso</strong> para montajes formales
              o <strong>media caída de 35 cm</strong> para eventos casuales y corporativos. El
              satín y el lino son los favoritos para <strong>bodas y galas</strong> por su caída
              elegante; el poliéster premium ofrece resistencia para eventos corporativos.
              Combínalos con nuestras <a href="/servicios/mobiliario/mesas/">mesas para
              eventos</a> para un montaje integral.
            </p>
            <ul class="hm-feat__stats">
              {["Redondo 305–396 cm", "Rectangular y cuadrado", "8 tipos de tela", "Caída 75 o 35 cm", "+50 colores"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">
              Ver Manteles y Cubremesas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/accesorios/manteles-premium-boda-elegante.avif" alt="Manteles premium para boda elegante en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/accesorios/accesorio-evento-01.avif" alt="Mantelería montada en mesa de evento en CDMX" loading="lazy" decoding="async" />
              <img src="/images/accesorios/accesorio-evento-04.avif" alt="Detalle de mantel y cubremesa para evento en CDMX" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- CUBRESILLAS Y BANDAS -->
        <article class="hm-feat" aria-labelledby="feat-cubresillas-bandas">
          <div class="hm-feat__text">
