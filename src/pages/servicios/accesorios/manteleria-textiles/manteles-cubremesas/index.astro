---
/**
 * ─── Manteles y Cubremesas — Pagina de Producto (Nivel 4) ───
 * Manteles redondos, rectangulares y cuadrados en poliéster, satín,
 * organza y lino para bodas, banquetes y eventos corporativos.
 *
 * Jerarquia: Servicios > Accesorios > Mantelería y Textiles > Manteles y Cubremesas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { label: "Manteles y Cubremesas" },
];

const faqs = [
  { question: "¿Qué tipos de tela manejan para manteles y cuál es la diferencia?", answer: 'Manejamos 4 tipos principales de tela para manteles: <strong>Poliéster estándar</strong> — económico, resistente a arrugas, ideal para eventos casuales y corporativos. <strong>Satín</strong> — brillo elegante con caída suave, perfecto para bodas y galas. <strong>Organza</strong> — transparente y delicada, ideal como overlay sobre mantel base. <strong>Lino premium</strong> — textura natural con aspecto rústico-elegante. Cada tela tiene diferentes niveles de caída, brillo y textura. Nuestro asesor te recomienda la opción ideal según el estilo de tu evento y presupuesto.' },
  { question: "¿Pueden igualar el color exacto de mi paleta de evento?", answer: 'Sí, ofrecemos un servicio de <strong>color matching</strong> donde nos envías tu paleta (código Pantone, muestra física o referencia fotográfica) y seleccionamos las combinaciones más cercanas de nuestro inventario de más de 50 colores. Siempre enviamos <strong>muestras físicas para aprobación</strong> antes del evento sin costo adicional. En caso de requerir un tono muy específico fuera de catálogo, contamos con proveedores de telas especiales con un tiempo de preparación de 2 a 3 semanas.' },
  { question: "¿Cuál es el pedido mínimo de manteles?", answer: 'El pedido mínimo es de <strong>10 piezas por tipo</strong> (por ejemplo, 10 manteles redondos satín blanco). Para paquetes combinados que incluyen manteles + cubremesas de diferentes formatos no hay mínimo estricto — armamos paquetes desde 1 mesa. En eventos grandes ofrecemos <strong>precios preferenciales por volumen</strong> a partir de 50 piezas con descuentos progresivos.' },
  { question: "¿Los manteles llegan lavados y planchados?", answer: 'Absolutamente. Toda nuestra mantelería se entrega <strong>recién lavada, desinfectada y planchada profesionalmente</strong> con vapor industrial. Cada pieza pasa por un control de calidad verificando que no tenga manchas, rasgaduras ni decoloración. Se transporta en fundas individuales para mantener el planchado impecable. Al finalizar tu evento, <strong>recolectamos la mantelería sucia</strong> — el lavado de retorno está incluido sin costo adicional.' },
  { question: "¿Qué medidas de manteles necesito para mis mesas?", answer: 'Depende del formato de tu mesa: para <strong>mesas redondas de 150 cm</strong> recomendamos manteles de 120" (caída completa al piso) o 108" (media caída). Para <strong>mesas redondas de 180 cm</strong>, manteles de 132". Para <strong>mesas rectangulares estándar</strong>, 90x132" o 90x156". Los <strong>cubremesas cuadrados</strong> de 72x72" y 85x85" funcionan como overlay sobre el mantel base. Nuestro asesor calcula las medidas exactas según tus mesas.' },
  { question: "¿Con cuánta anticipación entregan los manteles?", answer: 'La entrega estándar es <strong>1 día antes de tu evento</strong> (entre 9:00 y 14:00 horas) para que tengas tiempo de supervisar el montaje. Para eventos en viernes o sábado, entregamos el jueves o viernes respectivamente. También ofrecemos entrega el mismo día con un cargo de logística urgente. La <strong>recolección se realiza el día siguiente</strong> al evento. Nuestro equipo coordina horarios con tu wedding planner o responsable del venue.' },
];

const specs = [
  { label: "Formas", value: "Redondo, Rectangular, Cuadrado" },
  { label: "Telas", value: "Poliéster, Satín, Organza, Lino" },
  { label: "Colores", value: "50+ tonos con color matching" },
  { label: "Medidas redondo", value: '120", 132" para mesas 150/180 cm' },
  { label: "Medidas rectangular", value: '90x132", 90x156" estándar' },
  { label: "Medidas cuadrado", value: '72x72", 85x85" overlay' },
  { label: "Pedido mínimo", value: "10 piezas por tipo" },
  { label: "Lavado", value: "Profesional incluido ida y vuelta" },
  { label: "Planchado", value: "Vapor industrial incluido" },
  { label: "Entrega", value: "1 día antes del evento" },
];

const sidebarNav = [
  { name: "Manteles y Cubremesas", href: null, active: true },
  { name: "Cubresillas y Bandas", href: "/servicios/accesorios/manteleria-textiles/cubresillas-bandas/" },
  { name: "Servilletas y Caminos", href: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/" },
  { name: "Overlays y Telas Especiales", href: "/servicios/accesorios/manteleria-textiles/overlays-especiales/" },
];

const sidebarRelated = [
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Mobiliario Sillas", href: "/servicios/mobiliario/sillas/" },
  { name: "Mobiliario Mesas", href: "/servicios/mobiliario/mesas/" },
  { name: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Carolina Méndez", text: "Rentamos 150 manteles de satín marfil para nuestra boda en un jardín de Coyoacán. El color matching fue perfecto — igualaron exactamente el tono de nuestras invitaciones. Llegaron planchados impecablemente y la recolección al día siguiente fue puntual. La caída del satín en las mesas redondas se veía espectacular en las fotos.", rating: 5, date: "2025-11-22" },
  { author: "Fernando Ruiz", text: "Usamos manteles rectangulares de lino gris oxford para un evento corporativo de 80 personas en Polanco. La textura del lino le dio un aspecto sofisticado y profesional a todo el montaje. El servicio de lavado incluido nos ahorró mucha logística. Excelente calidad y atención.", rating: 5, date: "2025-10-05" },
  { author: "Mariana López", text: "Contratamos manteles de poliéster blanco con overlays de organza dorada para un banquete formal de 200 personas. El inventario de EVENTECH nos permitió cubrir todas las mesas sin problema. La entrega fue un día antes como prometieron y cada mantel venía en su funda individual. Servicio impecable.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Manteles y Cubremesas para Eventos en CDMX",
    description: "Renta de manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino. Más de 50 colores. Lavados y planchados. Desde $35 por pieza.",
    url: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/",
    priceRange: { min: 35, max: 150 },
    reviews,
    ratingValue: 5,
    reviewCount: 312,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Mantelería y Textiles", url: "/servicios/accesorios/manteleria-textiles/" },
    { name: "Manteles y Cubremesas", url: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Manteles y Cubremesas para Eventos en CDMX | EVENTECH"
  description="Renta de manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino. Más de 50 colores. Lavados y planchados. Desde $35 por pieza."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 50 colores disponibles"
    title='Renta de <span class="highlight">Manteles y Cubremesas</span> para Eventos'
    subtitle="Manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino premium. Más de 50 colores con servicio de color matching, lavado y planchado profesional incluido."
    primaryCTA={{ label: "Cotiza tus manteles", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar manteles y cubremesas para mi evento` }}
    cards={[
      {
        title: "Manteles en poliéster, satín, organza y lino premium",
        content: "<strong>Renta de manteles y cubremesas</strong> para eventos en CDMX con el catálogo más amplio de formatos y telas. Manteles redondos, rectangulares y cuadrados en poliéster, satín, organza y lino premium. Más de 50 colores con servicio de color matching para tu paleta de evento. Medidas disponibles desde 72x72\" hasta 132\" redondo para cubrir mesas de 150 y 180 cm con caída completa al piso o media caída según tu preferencia.",
      },
      {
        title: "Entrega lavada, planchada y con recolección incluida",
        content: "<strong>Servicio integral sin preocupaciones</strong>. Cada mantel se entrega recién lavado, desinfectado y planchado profesionalmente con vapor industrial. Empaque individual en fundas para mantener el planchado impecable hasta el montaje. Recolección con lavado incluido sin costo adicional al día siguiente del evento. Inventario para hasta 500 mesas simultáneas con control de calidad pieza por pieza.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas manteles perfectos para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos muestras de color y textura para que apruebes antes de tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Mantelería y Textiles</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas manteles y cubremesas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar manteles y cubremesas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Manteles y Cubremesas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Manteles Satín Elegante -->
          <section class="section section--alt" aria-labelledby="satin-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El favorito para bodas</span>
                <h2 class="showcase__title" id="satin-heading">Manteles Satín Elegante</h2>
                <p class="showcase__subtitle">El brillo sofisticado del satín transforma cada mesa en una pieza de alta gama para bodas y galas.</p>
                <p class="showcase__text">Nuestros <strong>manteles de satín</strong> son la elección favorita para <strong>bodas, galas y eventos de etiqueta</strong> en la Ciudad de México. El satín ofrece un brillo elegante y una caída suave que enmarca cada mesa con sofisticación. Disponibles en formatos <strong>redondo (120" y 132"), rectangular (90x132" y 90x156") y cuadrado (72x72" y 85x85")</strong>. Más de 30 colores de satín disponibles, desde los clásicos blanco, marfil y champagne hasta tonos metálicos como dorado, plateado y oro rosa.</p>
                <p class="showcase__text">La caída completa hasta el piso crea un efecto visual impresionante en <strong>mesas de honor, mesa de novios y mesas de invitados</strong>. Cada mantel de satín se plancha con vapor industrial para un acabado sin arrugas. Combínalos con nuestros <a href="/servicios/accesorios/manteleria-textiles/cubresillas-bandas/">cubresillas y bandas</a> en colores coordinados para un montaje textil integral que luzca perfecto en cada fotografía de tu evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Satín premium</span>
                  <span class="showcase__tag">30+ colores</span>
                  <span class="showcase__tag">Caída elegante</span>
                  <span class="showcase__tag">Bodas y galas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Manteles Satín
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Manteles Satín Elegante</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Manteles Poliéster Clásico -->
          <section class="section section--alt" aria-labelledby="poliester-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Máxima resistencia y economía</span>
                <h2 class="showcase__title" id="poliester-heading">Manteles Poliéster Clásico</h2>
                <p class="showcase__subtitle">La opción más versátil y resistente para eventos corporativos, banquetes y celebraciones de gran formato.</p>
                <p class="showcase__text">Nuestros <strong>manteles de poliéster profesional</strong> son la base de cualquier montaje exitoso. Su principal ventaja: <strong>resistencia superior a arrugas y manchas</strong>, lo que los hace ideales para eventos con servicio de alimentos y bebidas. Disponibles en los tres formatos (redondo, rectangular, cuadrado) y en <strong>más de 50 colores sólidos</strong>. El poliéster premium que utilizamos tiene un gramaje de 200 GSM que ofrece peso y caída profesional.</p>
                <p class="showcase__text">Perfectos para <strong>eventos corporativos, conferencias, banquetes masivos y celebraciones sociales</strong> donde se necesita un acabado profesional a un precio accesible. Su resistencia permite que las mesas luzcan impecables durante todo el evento sin importar derrames o uso intensivo. Combínalos con <a href="/servicios/accesorios/manteleria-textiles/overlays-especiales/">overlays decorativos</a> de organza o lentejuela para elevar el look sin aumentar significativamente el presupuesto.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Poliéster 200 GSM</span>
                  <span class="showcase__tag">50+ colores</span>
                  <span class="showcase__tag">Anti-arrugas</span>
                  <span class="showcase__tag">Eventos grandes</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Manteles Poliéster
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Manteles Poliéster Clásico</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Manteles Lino Premium -->
          <section class="section section--alt" aria-labelledby="lino-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Textura natural premium</span>
                <h2 class="showcase__title" id="lino-heading">Manteles Lino Premium</h2>
                <p class="showcase__subtitle">La textura orgánica del lino aporta carácter y sofisticación natural para eventos rústico-elegantes.</p>
                <p class="showcase__text">Nuestros <strong>manteles de lino premium</strong> son la elección ideal para eventos con estética <strong>rústica, boho, campestre y orgánica</strong>. La textura natural del lino crea una atmósfera cálida y auténtica que fotografía extraordinariamente bien. Disponibles en tonos neutros y terrosos: <strong>natural, arena, gris claro, gris oxford, taupe, terracota y verde olivo</strong>. Formatos redondo y rectangular con caída completa o media caída.</p>
                <p class="showcase__text">El lino premium que utilizamos tiene un acabado <strong>suavizado (stone-washed)</strong> que le da esa textura desestructurada tan codiciada en bodas campestres y eventos al aire libre. Cada mantel de lino se plancha con temperatura controlada para conservar su textura característica sin arrugas excesivas. Combínalos con <a href="/servicios/accesorios/manteleria-textiles/servilletas-caminos/">caminos de yute</a> y servilletas coordinadas para un montaje rústico-elegante completo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Lino stone-washed</span>
                  <span class="showcase__tag">Tonos naturales</span>
                  <span class="showcase__tag">Rústico-elegante</span>
                  <span class="showcase__tag">Bodas campestres</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Manteles Lino
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
