---
/**
 * ─── Servilletas y Caminos de Mesa — Pagina de Producto (Nivel 4) ───
 * Servilletas de tela, caminos de mesa decorativos y servilleteros
 * elegantes con doblado artístico para eventos en CDMX.
 *
 * Jerarquia: Servicios > Accesorios > Mantelería y Textiles > Servilletas y Caminos
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { label: "Servilletas y Caminos" },
];

const faqs = [
  { question: "¿El servicio de doblado artístico está incluido en el precio?", answer: 'El doblado artístico básico (abanico y sobre) <strong>está incluido sin costo adicional</strong> cuando lo solicitas al momento de la reserva. Los doblados especiales (rosa, corona, lirio, bolsillo para cubiertos) tienen un pequeño cargo adicional por pieza debido al tiempo de preparación que requieren. Todas las servilletas se entregan ya dobladas y listas para colocar en cada lugar — no necesitas personal adicional para el montaje. Si prefieres un doblado personalizado o un diseño específico, nuestro equipo lo evalúa y cotiza por separado.' },
  { question: "¿Qué tipos de tela ofrecen para caminos de mesa?", answer: 'Ofrecemos 5 tipos de tela para caminos de mesa: <strong>Satín</strong> — brillo elegante, el más popular para bodas formales. <strong>Yute/Arpillera</strong> — textura rústica natural, perfecto para bodas campestres y estilo boho. <strong>Encaje</strong> — delicado y romántico, ideal como overlay sobre camino de satín o directamente sobre la mesa. <strong>Lentejuela</strong> — brillo completo en dorado, plateado, oro rosa y champagne para eventos de gala. <strong>Gasa/Chiffon</strong> — etéreo y transparente, crea un efecto flotante espectacular en mesas largas.' },
  { question: "¿Puedo coordinar servilletas con mis manteles?", answer: 'Absolutamente, es lo que más recomendamos. Nuestras servilletas están disponibles <strong>en los mismos 50+ colores y tipos de tela</strong> que nuestros <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">manteles y cubremesas</a>. Ofrecemos un servicio de <strong>coordinación textil</strong> donde un asesor selecciona las combinaciones ideales para tu paleta con muestras físicas de aprobación. Los paquetes de manteles + servilletas + caminos tienen precios especiales y se entregan juntos en un solo envío.' },
  { question: "¿Qué tipos de servilleteros ofrecen?", answer: 'Contamos con 4 estilos de servilleteros: <strong>Dorado</strong> — anillo metálico elegante, el más solicitado para bodas. <strong>Plateado</strong> — acabado cromado, ideal para eventos corporativos y temáticas modernas. <strong>Rose Gold</strong> — tono rosado metálico, tendencia en bodas y XV años. <strong>Madera natural</strong> — aros de madera rústica, perfectos para bodas campestres y estilo boho. Todos se rentan por pieza y se pueden combinar con cualquier servilleta de nuestro catálogo.' },
  { question: "¿Cuál es el pedido mínimo de servilletas y caminos?", answer: 'El pedido mínimo es de <strong>20 piezas para servilletas</strong> y <strong>10 piezas para caminos de mesa</strong>. Para servilleteros no hay mínimo — se agregan al pedido de servilletas por pieza. Los paquetes combinados (servilletas + caminos + servilleteros) no tienen mínimo adicional y se cotizan como paquete con precio preferencial. Para eventos grandes de más de 100 piezas ofrecemos descuentos progresivos por volumen.' },
  { question: "¿Los caminos de mesa se pueden personalizar en largo?", answer: 'Sí, nuestros caminos de mesa tienen un ancho estándar de <strong>35 cm</strong> y se ofrecen en dos largos base: <strong>200 cm</strong> (para mesas estándar de 6-8 personas) y <strong>300 cm</strong> (para mesas largas de 10-12 personas). Para mesas imperiales o formatos especiales, personalizamos el largo según las medidas exactas de tu mesa. Los caminos de tela se rentan por pieza completa, mientras que las telas para caminos especiales (gasa, chiffon) se cotizan por metro lineal con el largo que necesites.' },
];

const specs = [
  { label: "Servilletas tela", value: "50x50 cm, poliéster/satín/lino" },
  { label: "Colores servilletas", value: "50+ tonos coordinables" },
  { label: "Caminos de mesa", value: "35x200 cm y 35x300 cm" },
  { label: "Telas caminos", value: "Satín, Yute, Encaje, Lentejuela" },
  { label: "Servilleteros", value: "Dorado, Plateado, Rose Gold, Madera" },
  { label: "Doblado artístico", value: "Abanico, Rosa, Corona, Sobre, Lirio" },
  { label: "Pedido mínimo", value: "20 piezas" },
  { label: "Coordinación", value: "Color matching con mantelería" },
  { label: "Lavado", value: "Incluido ida y vuelta" },
  { label: "Entrega", value: "1 día antes con manteles" },
];

const sidebarNav = [
  { name: "Manteles y Cubremesas", href: "/servicios/accesorios/manteleria-textiles/manteles-cubremesas/" },
  { name: "Cubresillas y Bandas", href: "/servicios/accesorios/manteleria-textiles/cubresillas-bandas/" },
  { name: "Servilletas y Caminos", href: null, active: true },
  { name: "Overlays y Telas Especiales", href: "/servicios/accesorios/manteleria-textiles/overlays-especiales/" },
];

const sidebarRelated = [
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Mobiliario Sillas", href: "/servicios/mobiliario/sillas/" },
  { name: "Mobiliario Mesas", href: "/servicios/mobiliario/mesas/" },
  { name: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Sofía Hernández", text: "Rentamos 180 servilletas de satín champagne con doblado en rosa y servilleteros dorados para nuestra boda elegante en San Ángel. Cada servilleta llegó perfectamente doblada y lista para colocar. El efecto en las mesas fue espectacular — todas las fotos de la mesa se ven como de revista. Servicio impecable.", rating: 5, date: "2025-11-30" },
  { author: "Ricardo Fuentes", text: "Usamos caminos de lentejuela dorada sobre manteles blancos para un evento de diseño de 50 mesas. El brillo de la lentejuela con la iluminación del salón creó un efecto visual increíble. La coordinación de colores fue exacta y la entrega muy puntual. Excelente relación calidad-precio.", rating: 5, date: "2025-10-15" },
  { author: "Isabel Torres", text: "Para una cena de gala corporativa de 120 personas contratamos servilletas de lino con doblado en corona y caminos de satín navy. El nivel de detalle fue excepcional — cada servilleta impecable y los caminos perfectamente planchados. La recolección al día siguiente fue sin ningún problema. Totalmente recomendables.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Servilletas y Caminos de Mesa para Eventos en CDMX",
    description: "Renta de servilletas de tela coordinadas con mantelería, caminos de mesa decorativos y servilleteros elegantes. Doblado artístico disponible. Desde $8 por pieza.",
    url: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/",
    priceRange: { min: 8, max: 45 },
    reviews,
    ratingValue: 5,
    reviewCount: 245,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Mantelería y Textiles", url: "/servicios/accesorios/manteleria-textiles/" },
    { name: "Servilletas y Caminos", url: "/servicios/accesorios/manteleria-textiles/servilletas-caminos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Servilletas y Caminos de Mesa para Eventos en CDMX | EVENTECH"
  description="Renta de servilletas de tela coordinadas con mantelería, caminos de mesa decorativos y servilleteros elegantes. Doblado artístico disponible. Desde $8 por pieza."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Doblado artístico y coordinación total"
    title='Renta de <span class="highlight">Servilletas y Caminos</span> de Mesa para Eventos'
    subtitle="Servilletas de tela en poliéster, satín y lino coordinadas con tu mantelería. Caminos de mesa en satín, yute, encaje y lentejuela. Doblado artístico profesional y servilleteros elegantes."
    primaryCTA={{ label: "Cotiza tus servilletas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar servilletas y caminos de mesa para mi evento` }}
    cards={[
      {
        title: "Servilletas y caminos de mesa para decoración de alto impacto",
        content: "<strong>Renta de servilletas de tela</strong> en poliéster, satín y lino coordinadas con la mantelería de tu evento. Caminos de mesa en tela, yute, encaje y lentejuela para decoración de alto impacto visual. Más de 50 colores disponibles con servicio de coordinación textil para igualar tu paleta exacta. Medidas estándar de 50x50 cm en servilletas y 35x200/300 cm en caminos.",
      },
      {
        title: "Doblado artístico profesional y servilleteros elegantes",
        content: "<strong>Servicio de doblado artístico profesional</strong> en estilos abanico, rosa, corona, sobre y lirio. Servilleteros en acabados dorado, plateado y rose gold para un toque de distinción en cada lugar. Todas las piezas se entregan lavadas, planchadas y listas para colocar. Coordinación perfecta con manteles y cubresillas del mismo evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas los detalles que hacen la diferencia?"
    subheadline="Cotiza sin compromiso — servilletas con doblado artístico y caminos decorativos que elevan cada mesa"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Mantelería y Textiles</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas servilletas y caminos para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar servilletas y caminos de mesa para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Servilletas y Caminos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Servilletas Satín con Doblado Artístico -->
          <section class="section section--alt" aria-labelledby="satin-doblado-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Doblado profesional incluido</span>
                <h2 class="showcase__title" id="satin-doblado-heading">Servilletas Satín con Doblado Artístico</h2>
                <p class="showcase__subtitle">Servilletas de satín con doblado artístico profesional que elevan la presentación de cada lugar.</p>
                <p class="showcase__text">Nuestras <strong>servilletas de satín con doblado artístico</strong> son el complemento ideal para mesas de gala y eventos formales. El satín ofrece un brillo elegante que resalta cada pliegue del doblado, creando piezas decorativas que impresionan desde el primer momento. Disponibles en <strong>más de 30 colores de satín</strong> coordinables con tu mantelería. Tamaño generoso de 50x50 cm que permite doblados elaborados con volumen.</p>
                <p class="showcase__text">Ofrecemos 6 estilos de doblado artístico: <strong>abanico clásico, rosa decorativa, corona real, sobre para cubiertos, lirio elegante y bolsillo para menú</strong>. Cada servilleta se entrega ya doblada y lista para colocar directamente en el plato o junto al cubierto. El doblado básico (abanico y sobre) está incluido sin costo. Combínalas con servilleteros metálicos para un toque extra de distinción en cada lugar.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Satín premium</span>
                  <span class="showcase__tag">6 estilos de doblado</span>
                  <span class="showcase__tag">30+ colores</span>
                  <span class="showcase__tag">Listas para colocar</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Servilletas Satín
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Servilletas Satín Doblado</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Caminos de Mesa Lentejuela -->
          <section class="section section--alt" aria-labelledby="lentejuela-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Brillo y glamour total</span>
                <h2 class="showcase__title" id="lentejuela-heading">Caminos de Mesa Lentejuela</h2>
                <p class="showcase__subtitle">Caminos de lentejuela en dorado, plateado, oro rosa y champagne para mesas de gala y eventos de alto impacto.</p>
                <p class="showcase__text">Nuestros <strong>caminos de mesa de lentejuela</strong> son la opción más impactante para eventos de gala, bodas glamurosas y celebraciones donde el brillo es protagonista. Cada camino está cubierto por <strong>lentejuelas cosidas individualmente</strong> que reflejan la luz y crean un efecto visual deslumbrante. Disponibles en <strong>dorado, plateado, oro rosa, champagne, cobre y negro</strong>. Medidas de 35x200 cm y 35x300 cm.</p>
                <p class="showcase__text">Los caminos de lentejuela funcionan espectacularmente bien sobre <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">manteles lisos</a> en blanco, negro o colores neutros, creando un contraste de texturas que eleva todo el montaje. Son el complemento perfecto para <strong>mesas de honor, mesa de novios, mesa de postres y buffets</strong>. Combínalos con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para que cada lentejuela refleje la luz y llene el espacio de destellos.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Lentejuela completa</span>
                  <span class="showcase__tag">6 colores metálicos</span>
                  <span class="showcase__tag">35x200/300 cm</span>
                  <span class="showcase__tag">Eventos de gala</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Caminos Lentejuela
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Caminos Lentejuela</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Caminos de Yute Rústico -->
          <section class="section section--alt" aria-labelledby="yute-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Estilo rústico y natural</span>
                <h2 class="showcase__title" id="yute-heading">Caminos de Yute Rústico</h2>
                <p class="showcase__subtitle">Caminos de yute natural y arpillera para bodas campestres, estilo boho y montajes orgánicos.</p>
                <p class="showcase__text">Nuestros <strong>caminos de yute y arpillera</strong> son la elección perfecta para eventos con estética <strong>rústica, campestre, boho y orgánica</strong>. La textura natural del yute aporta calidez y autenticidad que contrasta bellamente con vajilla fina y centros de mesa florales. Disponibles en <strong>yute natural, yute blanqueado y arpillera con encaje</strong>. Medidas estándar de 35x200 cm y 35x300 cm con bordes deshilados o terminados.</p>
                <p class="showcase__text">La combinación más popular es yute natural sobre <a href="/servicios/accesorios/manteleria-textiles/manteles-cubremesas/">manteles de lino</a> en tonos neutros — creando un montaje campestre-elegante que fotografía extraordinariamente bien. También ofrecemos la versión <strong>yute con banda de encaje central</strong> que mezcla lo rústico con lo romántico. Perfectos para <strong>bodas en jardines, haciendas, viñedos y espacios al aire libre</strong>. Complementa con servilletas de lino y servilleteros de madera para un montaje rústico integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Yute natural</span>
                  <span class="showcase__tag">Arpillera con encaje</span>
                  <span class="showcase__tag">Boho/campestre</span>
                  <span class="showcase__tag">Bordes deshilados</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Caminos de Yute
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
