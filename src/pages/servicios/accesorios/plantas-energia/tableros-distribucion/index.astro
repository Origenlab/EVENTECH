---
/**
 * ─── Tableros de Distribución Eléctrica — Pagina de Producto (Nivel 4) ───
 * Tableros de distribución, spider boxes, interruptores termomagnéticos
 * y sistemas de protección eléctrica para eventos temporales.
 *
 * Jerarquia: Servicios > Accesorios > Plantas de Energía > Tableros de Distribución
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { label: "Tableros de Distribución" },
];

const faqs = [
  { question: "¿Qué certificaciones de seguridad tienen los tableros de distribución?", answer: 'Todos nuestros tableros cumplen con la <strong>NOM-001-SEDE-2012</strong> (Instalaciones Eléctricas) y la <strong>NOM-003-SCFI-2014</strong> (Productos Eléctricos). Cada tablero cuenta con <strong>certificación UL y CSA</strong>, interruptores termomagnéticos de marcas reconocidas (Square D, Siemens, ABB) y bus de cobre de alta conductividad. Antes de cada evento, nuestro técnico realiza pruebas de aislamiento con megóhmetro y verificación de continuidad del sistema de tierra física para garantizar una instalación 100% segura conforme a la normativa vigente.' },
  { question: "¿Cómo se balancea la carga entre circuitos?", answer: 'Nuestro ingeniero eléctrico realiza un <strong>levantamiento previo de cargas</strong> donde identifica el consumo de cada equipo del evento: sonido, iluminación, video, catering, climatización y servicios auxiliares. Con esta información diseña un <strong>diagrama unifilar</strong> que distribuye las cargas de forma equilibrada entre las fases del tablero principal. Durante el evento, el técnico monitorea el consumo por circuito con pinza amperimétrica y rebalancea si detecta desviaciones superiores al 15% entre fases, protegiendo los equipos contra sobrecalentamiento y caídas de voltaje.' },
  { question: "¿Cuántos circuitos puede manejar un tablero?", answer: 'Ofrecemos tableros desde <strong>6 hasta 42 circuitos</strong> según la complejidad del evento. Un tablero de 6 circuitos es ideal para eventos sociales de hasta 200 personas. Para <strong>expos y conciertos</strong>, instalamos tableros principales de 30-42 circuitos con tableros secundarios (spider boxes) distribuidos por zonas. Cada circuito cuenta con su propio <strong>interruptor termomagnético calibrado</strong> según la carga asignada, permitiendo aislar cualquier zona sin afectar el resto del evento. Los circuitos se identifican con etiquetas profesionales para facilitar la operación.' },
  { question: "¿Los tableros incluyen protección GFCI contra electrocución?", answer: 'Sí, todos nuestros tableros incluyen <strong>interruptores diferenciales (GFCI) de 30 mA</strong> en circuitos expuestos a humedad, intemperie o contacto con público. Esto es obligatorio por la <strong>NOM-001-SEDE</strong> para instalaciones temporales en eventos. Los GFCI detectan fugas de corriente a tierra de apenas 30 miliamperes y desconectan el circuito en menos de 30 milisegundos, previniendo electrocuciones. En eventos al aire libre o con presencia de agua (fuentes, nebulizadores), instalamos GFCI en el 100% de los circuitos como medida adicional de seguridad.' },
  { question: "¿Qué longitudes de cable manejan para la distribución?", answer: 'Disponemos de cables de distribución en longitudes de <strong>15, 30, 50, 75 y 100 metros</strong> con calibres desde 10 AWG hasta 4/0 AWG según el amperaje requerido. Para distancias mayores a 50 metros, utilizamos <strong>cables de mayor calibre</strong> para compensar la caída de voltaje y mantener la tensión dentro del rango de +/- 5% que exige la norma. Todo el cableado se instala con <strong>canalización profesional</strong>: rampas de paso vehicular, cubrecables peatonales y ductos aéreos para mantener la seguridad y estética del venue. El técnico calcula la caída de voltaje para cada tramo antes de la instalación.' },
  { question: "¿Es necesario contar con supervisión técnica durante todo el evento?", answer: 'Recomendamos y ofrecemos <strong>supervisión técnica permanente</strong> para eventos con tableros de 200A o más, o con más de 12 circuitos activos. El técnico electricista certificado por la <strong>STPS</strong> permanece en sitio durante toda la duración del evento, monitoreando cargas, temperatura de conexiones, estado de interruptores y calidad del voltaje. Para eventos menores, realizamos la instalación, pruebas y entrega al responsable del venue, con <strong>línea de emergencia 24/7</strong> y tiempo de respuesta menor a 45 minutos en CDMX. La supervisión incluye bitácora digital de mediciones cada hora.' },
];

const specs = [
  { label: "Tipos de tablero", value: "Principal, secundario y spider box" },
  { label: "Circuitos", value: "6, 12, 18, 24, 30 y 42 polos" },
  { label: "Amperaje", value: "100A, 200A, 400A y 600A" },
  { label: "Voltaje", value: "127/220V monofásico y trifásico" },
  { label: "Protección", value: "Termomagnéticos + GFCI 30 mA" },
  { label: "Calibre de cables", value: "10 AWG a 4/0 AWG" },
  { label: "Sistema de tierra", value: "Varilla copperweld 3m + conductor" },
  { label: "Gabinete", value: "NEMA 3R (intemperie) o NEMA 1 (interior)" },
  { label: "Dimensiones tablero", value: "Desde 40x30x15 hasta 120x80x30 cm" },
  { label: "Certificaciones", value: "NOM-001-SEDE, UL, CSA" },
];

const sidebarNav = [
  { name: "Generadores 20-50 kW", href: "/servicios/accesorios/plantas-energia/gen-20-50/" },
  { name: "Generadores 50-150 kW", href: "/servicios/accesorios/plantas-energia/gen-50-150/" },
  { name: "Generadores 150-500 kW", href: "/servicios/accesorios/plantas-energia/gen-150-500/" },
  { name: "Tableros de Distribución", href: null, active: true },
];

const sidebarRelated = [
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Audiovisual Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Carpas Estructurales", href: "/servicios/carpas/estructurales/" },
  { name: "Calefacción y Clima", href: "/servicios/accesorios/calefaccion-clima/" },
  { name: "Catering Cocina Móvil", href: "/servicios/catering/cocina-movil/" },
];

const reviews = [
  { author: "Alejandro Fuentes Garza", text: "Contratamos tableros de distribución de 400A para una expo industrial de 4 días en Centro Citibanamex. EVENTECH diseñó la distribución eléctrica para 28 stands con circuitos independientes, cada uno con su spider box y protección GFCI. El técnico monitoreó las cargas durante todo el evento y rebalanceó las fases el segundo día cuando un expositor conectó equipo adicional. Cero interrupciones en 4 días. Servicio impecable y totalmente profesional.", rating: 5, date: "2025-11-22" },
  { author: "Mariana Estrada Villarreal", text: "Para nuestra boda en un jardín de Coyoacán necesitábamos distribución eléctrica segura para iluminación, sonido, cocina y fuentes. EVENTECH instaló un tablero principal de 200A con 4 spider boxes distribuidos por zonas. Todo el cableado quedó oculto con rampas y canaletas. El técnico estuvo atento toda la noche y la instalación fue perfecta. Nos encantó la profesionalidad y la tranquilidad de saber que todo estaba bajo norma.", rating: 5, date: "2025-10-05" },
  { author: "Roberto Cantú Mendoza", text: "Organizamos un festival de música en un parque de la CDMX y EVENTECH proporcionó todo el sistema de distribución eléctrica: tablero principal de 400A, 6 spider boxes para escenario, sonido, iluminación, food trucks, zona VIP y servicios. La instalación cumplió al 100% con la norma NOM-001 que nos exigió Protección Civil. Los dos técnicos estuvieron atentos las 14 horas del evento. Profesionales de primer nivel.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Tableros de Distribución Eléctrica para Eventos en CDMX",
    description: "Renta de tableros de distribución eléctrica, spider boxes e instalación temporal certificada NOM-001 para eventos. Interruptores termomagnéticos, GFCI y supervisión técnica. Desde $3,000.",
    url: "/servicios/accesorios/plantas-energia/tableros-distribucion/",
    priceRange: { min: 3000, max: 25000 },
    reviews,
    ratingValue: 5,
    reviewCount: 134,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Plantas de Energía", url: "/servicios/accesorios/plantas-energia/" },
    { name: "Tableros de Distribución", url: "/servicios/accesorios/plantas-energia/tableros-distribucion/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Tableros de Distribución Eléctrica para Eventos en CDMX | EVENTECH"
  description="Renta de tableros de distribución eléctrica, spider boxes e instalación temporal certificada NOM-001 para eventos. Interruptores termomagnéticos, GFCI y supervisión técnica. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Distribución eléctrica certificada NOM-001"
    title='Renta de <span class="highlight">Tableros de Distribución</span> Eléctrica para Eventos'
    subtitle="Tableros principales, spider boxes e instalación eléctrica temporal con protección termomagnética, GFCI y sistema de tierra física. Técnicos electricistas certificados STPS y cumplimiento normativo total."
    primaryCTA={{ label: "Cotiza tu tablero", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar tableros de distribución eléctrica para mi evento` }}
    cards={[
      {
        title: "Tableros de 100A a 600A con protección termomagnética y GFCI",
        content: "<strong>Tableros de distribución eléctrica de 100A, 200A, 400A y 600A</strong> con interruptores termomagnéticos calibrados, protección diferencial GFCI de 30 mA y sistema de tierra física con varilla copperweld. Gabinetes NEMA 3R para intemperie y NEMA 1 para interior. De 6 a 42 circuitos independientes con bus de cobre de alta conductividad. Cumplimiento total con NOM-001-SEDE-2012 para instalaciones eléctricas temporales en eventos.",
      },
      {
        title: "Instalación profesional con diseño unifilar y supervisión técnica",
        content: "<strong>Ingeniero eléctrico diseña el diagrama unifilar</strong> según el layout de tu evento, distribuyendo cargas equilibradas entre fases. Spider boxes estratégicamente ubicados por zonas, cableado oculto con rampas vehiculares y cubrecables peatonales. Supervisión técnica permanente con monitoreo de cargas por circuito, temperatura de conexiones y calidad de voltaje. Bitácora digital de mediciones cada hora y línea de emergencia 24/7.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas distribución eléctrica segura para tu evento?"
    subheadline="Cotiza sin compromiso — diseñamos el diagrama unifilar y calculamos cargas según tu layout"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Plantas de Energía para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas distribución eléctrica profesional?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar tableros de distribución eléctrica para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Tableros de Distribución</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Tablero Principal 200A — Eventos Medianos -->
          <section class="section section--alt" aria-labelledby="tablero-200a-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas y eventos sociales</span>
                <h2 class="showcase__title" id="tablero-200a-heading">Tablero Principal 200A — Eventos Medianos</h2>
                <p class="showcase__subtitle">Distribución eléctrica profesional para bodas, XV años, fiestas corporativas y eventos sociales de hasta 500 personas.</p>
                <p class="showcase__text">El <strong>tablero principal de 200A</strong> es nuestra solución más solicitada para <strong>eventos sociales y corporativos de mediana escala</strong>. Con capacidad para alimentar simultáneamente <strong>iluminación decorativa, sonido profesional, pantallas LED, estaciones de catering, refrigeración y climatización</strong> a través de 12-18 circuitos independientes con protección termomagnética calibrada. El gabinete NEMA 3R permite instalación en exteriores sin riesgo, con bus de cobre de alta conductividad y barras de distribución balanceadas entre fases.</p>
                <p class="showcase__text">Incluye <strong>sistema de tierra física</strong> con varilla copperweld de 3 metros, conductor de cobre desnudo calibre 8 AWG y conexiones exotérmicas certificadas. Cada circuito se identifica con etiquetas profesionales que indican la zona, carga asignada y calibre del conductor. Combínalo con nuestros <a href="/servicios/accesorios/plantas-energia/gen-20-50/">generadores de 20-50 kW</a> para una instalación eléctrica autónoma completa en venues sin infraestructura eléctrica.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">200A</span>
                  <span class="showcase__tag">12-18 circuitos</span>
                  <span class="showcase__tag">NEMA 3R</span>
                  <span class="showcase__tag">Tierra física</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tablero 200A
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Tablero Principal 200A</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Tablero Industrial 400A — Grandes Eventos -->
          <section class="section section--alt" aria-labelledby="tablero-400a-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Expos y conciertos</span>
                <h2 class="showcase__title" id="tablero-400a-heading">Tablero Industrial 400A — Grandes Eventos</h2>
                <p class="showcase__subtitle">Sistema de distribución de alta capacidad para expos comerciales, conciertos, festivales y producciones de gran formato.</p>
                <p class="showcase__text">El <strong>tablero industrial de 400A</strong> es el centro de distribución eléctrica para <strong>eventos de gran escala</strong> que requieren alimentar múltiples zonas con cargas elevadas. Con <strong>30-42 circuitos independientes</strong>, interruptores termomagnéticos de marco moldeado (MCCB) para las alimentaciones principales y protección GFCI en todos los circuitos expuestos al público. Capacidad para distribuir energía a <strong>escenarios con line array, iluminación robotizada, pantallas LED de gran formato, áreas de catering industrial y sistemas de climatización</strong>.</p>
                <p class="showcase__text">El tablero incluye <strong>medidor de energía digital</strong> con registro de consumo por fase, factor de potencia y demanda máxima. Los interruptores principales de 400A cuentan con protección contra cortocircuito de 65 kA y ajuste de corriente térmica para optimizar la protección según la carga real. Ideal para <strong>expos de 3-5 días</strong> en venues como Centro Citibanamex, Expo Reforma o Expo Santa Fe. Complementa con nuestros <a href="/servicios/accesorios/plantas-energia/gen-150-500/">generadores de 150-500 kW</a> para eventos sin acometida eléctrica.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">400A</span>
                  <span class="showcase__tag">30-42 circuitos</span>
                  <span class="showcase__tag">MCCB 65 kA</span>
                  <span class="showcase__tag">Medidor digital</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tablero 400A
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Tablero Industrial 400A</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Spider Boxes y Distribución de Campo -->
          <section class="section section--alt" aria-labelledby="spider-boxes-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Distribución por zonas</span>
                <h2 class="showcase__title" id="spider-boxes-heading">Spider Boxes y Distribución de Campo</h2>
                <p class="showcase__subtitle">Cajas de distribución portátiles con protección individual para llevar energía segura a cada zona del evento.</p>
