---
/**
 * ─── Generadores 50-150 kW — Pagina de Producto (Nivel 4) ───
 * Plantas de energía de 50 a 150 kW para corporativos, conciertos
 * y expos con transferencia automática y múltiples zonas.
 *
 * Jerarquia: Servicios > Accesorios > Plantas de Energía > Generadores 50-150 kW
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { label: "Generadores 50-150 kW" },
];

const faqs = [
  { question: "¿Qué es la transferencia automática y por qué la necesito?", answer: 'La transferencia automática es un <strong>conmutador inteligente</strong> que detecta fallas en la fuente de energía principal y cambia automáticamente al generador de respaldo en menos de 10 segundos. Es indispensable para <strong>eventos corporativos con equipo de cómputo, conciertos con consolas digitales y expos con sistemas de seguridad</strong> donde un corte de energía puede dañar equipos o interrumpir la producción. Nuestros generadores de 50-150 kW incluyen conmutador de transferencia automática de serie.' },
  { question: "¿Cómo funciona la distribución por zonas?", answer: 'La distribución por zonas permite <strong>alimentar diferentes áreas del evento con circuitos independientes</strong>. Cada zona tiene su propio tablero secundario con protecciones individuales: escenario (sonido + iluminación), catering (cocina + refrigeración), exhibición (pantallas + stands), y climatización (AC + ventilación). Si una zona sufre una sobrecarga, solo se desconecta esa zona sin afectar las demás. Nuestro técnico diseña el mapa de distribución según el layout de tu evento.' },
  { question: "¿Cuántos técnicos se asignan a mi evento?", answer: 'Para generadores de <strong>50-75 kW asignamos 1 técnico electricista certificado</strong>. Para eventos con <strong>100 kW o más, asignamos 2 técnicos</strong> que se turnan para mantener monitoreo constante. En eventos de más de 12 horas, los técnicos rotan en turnos de 8 horas para garantizar atención alerta y profesional en todo momento. Cada técnico cuenta con equipo de medición, herramienta especializada y comunicación directa con nuestra central de operaciones.' },
  { question: "¿Tienen generadores con voltaje trifásico?", answer: 'Sí. Nuestros generadores de 75 kW en adelante están disponibles en <strong>configuración trifásica 220V</strong>, indispensable para alimentar <strong>equipos de sonido line array, motores de iluminación robotizada, compresores de aire acondicionado y maquinaria industrial</strong>. El técnico verifica la compatibilidad de voltaje de cada equipo antes de la conexión y configura las fases para una distribución equilibrada de cargas. También disponemos de transformadores para convertir entre monofásico y trifásico según necesidades.' },
  { question: "¿Pueden operar los generadores para eventos de varios días?", answer: 'Absolutamente. Nuestros generadores de 50-150 kW están diseñados para <strong>operación continua en eventos multi-día</strong>: expos de 3-5 días, ferias comerciales, rodajes de TV y festivales. Programamos <strong>reabastecimiento de diésel sin cortes de energía</strong> mediante tanques auxiliares. Para eventos de más de 24 horas, instalamos sistema de tanque extendido con bomba de transferencia. El equipo técnico rota en turnos para mantener vigilancia permanente.' },
  { question: "¿Es posible combinar dos generadores para mayor potencia?", answer: 'Sí, ofrecemos <strong>configuración en paralelo</strong> donde dos generadores operan sincronizados para sumar su capacidad. Por ejemplo, dos generadores de 75 kW proporcionan 150 kW de potencia total con la ventaja de <strong>redundancia automática</strong>: si uno falla, el otro mantiene la carga crítica. Esta configuración es popular para <a href="/servicios/accesorios/plantas-energia/gen-150-500/">eventos de gran formato</a> que requieren respaldo garantizado y para venues donde el acceso no permite un generador grande.' },
];

const specs = [
  { label: "Potencias", value: "50, 75, 100 y 150 kW" },
  { label: "Combustible", value: "Diésel con tanque incluido para 12 hrs" },
  { label: "Ruido", value: "70-75 dB a 7 metros" },
  { label: "Voltaje", value: "120/240V monofásico y 220V trifásico" },
  { label: "Transferencia", value: "Automática con conmutador" },
  { label: "Distribución", value: "Multi-zona: 4 a 8 circuitos" },
  { label: "Consumo", value: "15-40 litros/hora según carga" },
  { label: "Técnicos", value: "2 electricistas para 100+ kW" },
  { label: "Monitoreo", value: "Cargas en tiempo real con display" },
  { label: "Respaldo", value: "N+1 disponible bajo solicitud" },
];

const sidebarNav = [
  { name: "Generadores 20-50 kW", href: "/servicios/accesorios/plantas-energia/gen-20-50/" },
  { name: "Generadores 50-150 kW", href: null, active: true },
  { name: "Generadores 150-500 kW", href: "/servicios/accesorios/plantas-energia/gen-150-500/" },
  { name: "Tableros y Distribución", href: "/servicios/accesorios/plantas-energia/tableros-distribucion/" },
];

const sidebarRelated = [
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Audiovisual Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Calefacción y Clima", href: "/servicios/accesorios/calefaccion-clima/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
];

const reviews = [
  { author: "Fernando Ríos", text: "Contratamos un generador de 100 kW para un concierto al aire libre en un parque de CDMX. El equipo de EVENTECH coordinó toda la distribución eléctrica por zonas: escenario, sonido, iluminación y food trucks. La transferencia automática funcionó perfecto cuando hubo una fluctuación. Los dos técnicos estuvieron atentos toda la noche. Producción impecable.", rating: 5, date: "2025-11-08" },
  { author: "Sofía Morales", text: "Rentamos un generador de 75 kW para una expo comercial de 3 días en Santa Fe. El generador alimentó 12 stands con pantallas LED, iluminación y aire acondicionado sin ningún problema. El reabastecimiento de diésel fue transparente, nunca se interrumpió la energía. Excelente servicio técnico y logística profesional.", rating: 5, date: "2025-10-15" },
  { author: "Ricardo Domínguez", text: "Usamos dos generadores de 50 kW en paralelo para un evento corporativo de lanzamiento de producto en un jardín de Coyoacán. La configuración multi-zona permitió alimentar el escenario, el catering y las 6 pantallas LED de forma independiente. Todo funcionó perfecto durante 10 horas. EVENTECH es nuestro proveedor de confianza.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Generadores 50-150 kW CDMX",
    description: "Renta de plantas de energía de 50 a 150 kW para corporativos, conciertos y expos. Transferencia automática y múltiples zonas de alimentación. Desde $6,000.",
    url: "/servicios/accesorios/plantas-energia/gen-50-150/",
    priceRange: { min: 6000, max: 20000 },
    reviews,
    ratingValue: 5,
    reviewCount: 156,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Plantas de Energía", url: "/servicios/accesorios/plantas-energia/" },
    { name: "Generadores 50-150 kW", url: "/servicios/accesorios/plantas-energia/gen-50-150/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Generadores 50-150 kW en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de plantas de energía de 50 a 150 kW para corporativos, conciertos y expos. Transferencia automática y múltiples zonas de alimentación. Desde $6,000."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Múltiples zonas de alimentación"
    title='Renta de <span class="highlight">Generadores 50-150 kW</span> para Eventos'
    subtitle="Plantas de energía de mediana capacidad con transferencia automática, distribución multi-zona y monitoreo en tiempo real. Técnicos electricistas certificados y combustible incluido."
    primaryCTA={{ label: "Cotiza tu planta", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar generadores de 50-150 kW para mi evento` }}
    cards={[
      {
        title: "Plantas de energía de 50, 75, 100 y 150 kW con transferencia automática",
        content: "<strong>Plantas de energía de 50, 75, 100 y 150 kW</strong> con transferencia automática, múltiples circuitos de alimentación y distribución por zonas para eventos corporativos y conciertos. Voltaje monofásico 120/240V y trifásico 220V disponible para equipos industriales. Conmutador inteligente que detecta fallas y cambia al respaldo en menos de 10 segundos, protegiendo equipos sensibles como consolas de audio, servidores y pantallas LED.",
      },
      {
        title: "Equipo técnico profesional y monitoreo en tiempo real",
        content: "<strong>Equipo de 2 técnicos</strong> para eventos de 100+ kW, diésel para 12 horas incluido, tablero de distribución multi-zona y monitoreo de cargas en tiempo real. Los técnicos se encargan del diseño de distribución por zonas, instalación de tableros principales y secundarios, regulación de voltaje, canalización de cableado profesional y atención de contingencias. Display de monitoreo muestra consumo por circuito para optimizar la distribución de cargas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas energía multi-zona para tu producción?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta técnica con distribución por zonas y potencia dimensionada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Plantas de Energía para Eventos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas una planta de energía multi-zona?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar generadores de 50-150 kW para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Generadores 50-150 kW</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Generador 75 kW Corporativos -->
          <section class="section" aria-labelledby="gen-75-heading">
            <ServiceShowcase
    title="Generador 75 kW Corporativos"
    headingId="gen-75-heading"
    badge="Eventos corporativos"
    subtitle="Potencia versátil para lanzamientos de producto, conferencias de prensa y eventos empresariales de hasta 500 personas."
    tags={["75 kW", "Trifásico disponible", "6 circuitos", "Transferencia automática"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Generador 75 kW"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>generador de 75 kW</strong> es nuestra opción más popular para <strong>eventos corporativos de mediana escala</strong>. Con capacidad para alimentar simultáneamente un escenario completo con <strong>sonido profesional, iluminación de escenario, 4-6 pantallas LED, proyectores 4K, equipos de streaming y climatización</strong>. La transferencia automática protege equipos de cómputo y consolas digitales contra fluctuaciones. Disponible en configuración <strong>monofásica 240V y trifásica 220V</strong> según los requerimientos del equipo.</p>
      <p class="showcase__text">Incluye <strong>tablero de distribución de 6 circuitos</strong> con protecciones independientes, regulador de voltaje automático y display de monitoreo en tiempo real. El técnico diseña la distribución eléctrica según el plano del venue, asegurando que cada zona tenga su circuito dedicado. Combínalo con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para una producción corporativa integral.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
        <div class="showcase__gallery3-main"><img src="/images/accesorios/planta-luz-generador-evento.avif" alt="Generador 75 kW Corporativos para eventos en CDMX" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-01.avif" alt="Generador 75 kW Corporativos en CDMX — detalle" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-02.avif" alt="Generador 75 kW Corporativos en CDMX — opción" loading="lazy" decoding="async" /></div>
      </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Generador 100 kW Conciertos -->
          <section class="section" aria-labelledby="gen-100-heading">
            <ServiceShowcase
    title="Generador 100 kW Conciertos"
    headingId="gen-100-heading"
    badge="Producción de conciertos"
    subtitle="Potencia de producción para conciertos, festivales medianos y eventos en vivo con escenario profesional."
    tags={["100 kW", "Trifásico 220V", "2 técnicos", "8 circuitos"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Generador 100 kW"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>generador de 100 kW</strong> está dimensionado para <strong>producciones de conciertos y eventos en vivo</strong> que requieren alimentar un escenario completo: <strong>sonido line array, iluminación robotizada con moving heads, pantallas LED de gran formato, máquinas de humo, láseres y toda la infraestructura de backline</strong>. Con voltaje <strong>trifásico 220V</strong> para motores de iluminación y compresores, más circuitos monofásicos 120V para equipos de audio y video.</p>
      <p class="showcase__text">Incluye <strong>2 técnicos electricistas certificados</strong> que se turnan para mantener monitoreo constante durante toda la producción. El tablero de distribución de 8 circuitos permite separar cargas de audio, iluminación, video y servicios auxiliares con protecciones independientes. El display de monitoreo muestra el consumo en tiempo real por circuito. Combínalo con nuestras <a href="/servicios/iluminacion/escenario/">luces de escenario</a> para una producción de concierto completa.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
        <div class="showcase__gallery3-main"><img src="/images/accesorios/accesorio-evento-01.avif" alt="Generador 100 kW Conciertos para eventos en CDMX" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-02.avif" alt="Generador 100 kW Conciertos en CDMX — detalle" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-03.avif" alt="Generador 100 kW Conciertos en CDMX — opción" loading="lazy" decoding="async" /></div>
      </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: Generador 150 kW Expos -->
          <section class="section" aria-labelledby="gen-150-heading">
            <ServiceShowcase
    title="Generador 150 kW Expos"
    headingId="gen-150-heading"
    badge="Expos y ferias comerciales"
    subtitle="Máxima potencia de la gama media para expos, ferias comerciales y eventos multi-zona de gran escala."
    tags={["150 kW", "8 zonas", "Multi-día", "2 técnicos"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Generador 150 kW"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>generador de 150 kW</strong> es la opción premium de nuestra gama media, diseñado para <strong>expos comerciales, ferias industriales, convenciones y eventos multi-área</strong> que requieren alimentar docenas de stands, áreas de conferencia, zonas de demostración y toda la infraestructura auxiliar. Con <strong>distribución de hasta 8 zonas independientes</strong>, cada área del evento opera con su propio circuito protegido. El voltaje trifásico 220V permite conectar equipos industriales de exhibición.</p>
      <p class="showcase__text">Incluye <strong>2 técnicos en turno permanente</strong>, tablero de distribución principal con 8 circuitos y tableros secundarios por zona, regulador de voltaje de 20 kVA, monitoreo remoto de cargas y reabastecimiento de diésel programado para eventos de varios días. Ideal para <strong>expos de 3-5 días</strong> con operación continua de 10-14 horas diarias. Para eventos que superan los 150 kW, consulta nuestros <a href="/servicios/accesorios/plantas-energia/gen-150-500/">generadores industriales de 150-500 kW</a>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
        <div class="showcase__gallery3-main"><img src="/images/accesorios/accesorio-evento-02.avif" alt="Generador 150 kW Expos para eventos en CDMX" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-03.avif" alt="Generador 150 kW Expos en CDMX — detalle" loading="lazy" decoding="async" /></div>
        <div class="showcase__gallery3-thumb"><img src="/images/accesorios/accesorio-evento-04.avif" alt="Generador 150 kW Expos en CDMX — opción" loading="lazy" decoding="async" /></div>
      </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 7. SHOWCASE: Kit Multi-Zona con Tablero -->
          <section class="section" aria-labelledby="kit-multizona-heading">
            <ServiceShowcase
    title="Kit Multi-Zona con Tablero"
    headingId="kit-multizona-heading"
    badge="Distribución profesional por zonas"
    subtitle="Paquete completo de generador + distribución multi-zona con tableros independientes por área del evento."
    tags={["Generador + Tableros", "Zonas independientes", "Diseño personalizado", "Cableado oculto"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Kit Multi-Zona"
  >
    <Fragment slot="body">
