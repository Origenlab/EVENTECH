---
/**
 * ─── Generadores 20-50 kW — Pagina de Producto (Nivel 4) ───
 * Generadores diésel silenciados de 20, 30, 40 y 50 kW para bodas,
 * banquetes y eventos sociales de hasta 300 personas.
 *
 * Jerarquia: Servicios > Accesorios > Plantas de Energía > Generadores 20-50 kW
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
  { label: "Generadores 20-50 kW" },
];

const faqs = [
  { question: "¿Cómo calculo la potencia que necesito para mi evento?", answer: 'El cálculo depende del equipamiento total. Sumamos el consumo de iluminación, sonido, pantallas LED, refrigeración y cocina. Como regla general: un evento social para <strong>100 personas con iluminación y sonido</strong> requiere 20 kW. Para <strong>150-200 personas con audiovisual completo</strong> necesitas 30-40 kW. Una <strong>boda de 300 personas con catering y refrigeración</strong> requiere 50 kW. Nuestro ingeniero eléctrico realiza el cálculo exacto sin costo y recomienda la planta ideal con margen de seguridad del 20%.' },
  { question: "¿Qué nivel de ruido tienen los generadores de 20-50 kW?", answer: 'Nuestros generadores de 20-50 kW cuentan con <strong>cabina insonorizada de fábrica</strong> y operan a un máximo de <strong>65 dB a 7 metros</strong> de distancia — equivalente a una conversación normal. Para bodas y eventos donde el silencio es crítico, posicionamos el generador estratégicamente detrás de una barrera acústica natural (muro, vegetación) o instalamos pantallas acústicas adicionales para reducir aún más el nivel de ruido perceptible en el área de invitados.' },
  { question: "¿El diésel está incluido en la renta?", answer: 'Sí. Todos nuestros generadores de 20-50 kW llegan con <strong>tanque lleno de diésel para 12 horas de operación continua</strong>. El costo del combustible está incluido en la cotización para eventos estándar. Si tu evento dura más de 12 horas, programamos reabastecimiento sin cortes de energía por un costo adicional mínimo. Un generador de 20 kW consume aproximadamente 5-6 litros/hora, mientras que el de 50 kW consume 12-15 litros/hora al 75% de carga.' },
  { question: "¿El técnico permanece durante todo el evento?", answer: 'Sí. Cada renta incluye un <strong>técnico electricista certificado</strong> que permanece en tu evento de inicio a fin. El técnico se encarga del transporte, instalación, arranque con precalentamiento, conexión del tablero de distribución, verificación de conexión a tierra, monitoreo de cargas en tiempo real y atención de cualquier contingencia eléctrica. Al finalizar, realiza el desmontaje y recolección sin costo adicional.' },
  { question: "¿Los generadores funcionan en eventos al aire libre?", answer: 'Absolutamente. Nuestros generadores están <strong>diseñados para operar en exteriores</strong>: jardines, haciendas, terrazas, playas y cualquier venue sin acometida eléctrica. La cabina del generador es resistente a lluvia ligera y contamos con <strong>lonas de protección</strong> para condiciones de lluvia moderada. El generador se ubica en una zona alejada de los invitados con canalización de cableado oculto hasta el área del evento.' },
  { question: "¿Puedo combinar el generador con iluminación y sonido?", answer: 'Sí, es la configuración más común. Nuestro técnico calcula el consumo total de tu <a href="/servicios/iluminacion/">iluminación</a>, <a href="/servicios/audiovisual/sonido/">sonido</a>, <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y cualquier otro equipo para dimensionar el generador adecuado. Un generador de 30 kW alimenta cómodamente un sistema de sonido, iluminación decorativa y 2 pantallas LED. Para producciones más completas con iluminación robotizada y sonido line array, recomendamos <a href="/servicios/accesorios/plantas-energia/gen-50-150/">generadores de 50-150 kW</a>.' },
];

const specs = [
  { label: "Potencias", value: "20, 30, 40 y 50 kW" },
  { label: "Combustible", value: "Diésel con tanque incluido para 12 hrs" },
  { label: "Ruido", value: "Máximo 65 dB a 7 metros" },
  { label: "Motor", value: "Diésel turbo con gobernador electrónico" },
  { label: "Voltaje", value: "120/240V monofásico" },
  { label: "Consumo", value: "5-15 litros/hora según carga" },
  { label: "Protecciones", value: "Termomagnético + diferencial" },
  { label: "Técnico", value: "Electricista certificado incluido" },
  { label: "Conexión tierra", value: "Profesional con varilla copper" },
  { label: "Arranque", value: "Automático con precalentamiento" },
];

const sidebarNav = [
  { name: "Generadores 20-50 kW", href: null, active: true },
  { name: "Generadores 50-150 kW", href: "/servicios/accesorios/plantas-energia/gen-50-150/" },
  { name: "Generadores 150-500 kW", href: "/servicios/accesorios/plantas-energia/gen-150-500/" },
  { name: "Tableros y Distribución", href: "/servicios/accesorios/plantas-energia/tableros-distribucion/" },
];

const sidebarRelated = [
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Audiovisual Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Calefacción y Clima", href: "/servicios/accesorios/calefaccion-clima/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
];

const reviews = [
  { author: "Mariana López", text: "Rentamos un generador de 30 kW para nuestra boda en un jardín de Coyoacán donde no había suficiente electricidad. El generador fue tan silencioso que nadie se dio cuenta de que estaba funcionando. El técnico fue súper profesional, llegó temprano a instalar todo y monitoreó la energía toda la noche. Iluminación, sonido y refrigeración funcionaron perfecto.", rating: 5, date: "2025-11-20" },
  { author: "Carlos Mendoza", text: "Contratamos un generador de 40 kW para un evento corporativo en una terraza de Polanco sin acometida eléctrica suficiente. El equipo de EVENTECH calculó exactamente la potencia que necesitábamos y el generador operó sin problemas durante 8 horas alimentando pantallas LED, sonido y luces. Excelente servicio técnico.", rating: 5, date: "2025-10-12" },
  { author: "Laura Ramírez", text: "Usamos un generador de 50 kW para un banquete de 250 personas en una hacienda en Tlalpan. El generador alimentó toda la cocina móvil, refrigeradores, iluminación decorativa y el equipo de sonido. El técnico estuvo atento toda la noche y el combustible alcanzó de sobra para las 10 horas del evento. Muy recomendable.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Generadores 20-50 kW para Eventos en CDMX",
    description: "Renta de generadores diésel silenciados de 20, 30, 40 y 50 kW para bodas, banquetes y eventos sociales de hasta 300 personas. Técnico incluido. Desde $3,000.",
    url: "/servicios/accesorios/plantas-energia/gen-20-50/",
    priceRange: { min: 3000, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 187,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Plantas de Energía", url: "/servicios/accesorios/plantas-energia/" },
    { name: "Generadores 20-50 kW", url: "/servicios/accesorios/plantas-energia/gen-20-50/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Generadores 20-50 kW para Eventos en CDMX | EVENTECH"
  description="Renta de generadores diésel silenciados de 20, 30, 40 y 50 kW para bodas, banquetes y eventos sociales de hasta 300 personas. Técnico incluido. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Operación silenciosa: máximo 65 dB"
    title='Renta de <span class="highlight">Generadores 20-50 kW</span> para Eventos'
    subtitle="Generadores diésel silenciados de 20 a 50 kW con cabina insonorizada para bodas, banquetes y eventos sociales. Técnico electricista certificado y combustible incluido en cada renta."
    primaryCTA={{ label: "Cotiza tu generador", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar generadores de 20-50 kW para mi evento` }}
    cards={[
      {
        title: "Generadores diésel silenciados de 20, 30, 40 y 50 kW",
        content: "<strong>Generadores diésel silenciados de 20, 30, 40 y 50 kW</strong> con cabina insonorizada de fábrica. Operación máxima de 65 dB a 7 metros para eventos donde el silencio importa. Disponibles para bodas en jardín, banquetes al aire libre, recepciones en haciendas y eventos sociales de hasta 300 personas en la Ciudad de México. Motor diésel turbo con gobernador electrónico para estabilidad de voltaje constante y protección de equipos sensibles.",
      },
      {
        title: "Técnico electricista y combustible incluidos",
        content: "<strong>Técnico electricista certificado incluido</strong> durante todo el evento, diésel para 12 horas incluido, tablero de distribución básico y conexión a tierra profesional. El técnico se encarga del transporte, instalación con cableado oculto, arranque con precalentamiento, monitoreo de cargas en tiempo real y atención de contingencias eléctricas. Protecciones termomagnéticas y diferencial incluidas para máxima seguridad de equipos e invitados.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas energía confiable y silenciosa para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el generador ideal para tu consumo eléctrico"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Plantas de Energía para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un generador silenciado para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar generadores de 20-50 kW para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Generadores 20-50 kW</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Generador 20 kW Silenciado -->
          <section class="section section--alt" aria-labelledby="gen-20-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Eventos íntimos y reuniones</span>
                <h2 class="showcase__title" id="gen-20-heading">Generador 20 kW Silenciado</h2>
                <p class="showcase__subtitle">La opción más compacta y silenciosa para eventos de hasta 100 personas con requerimientos eléctricos básicos.</p>
                <p class="showcase__text">Nuestro <strong>generador diésel de 20 kW</strong> es la solución ideal para eventos íntimos que necesitan energía confiable sin comprometer la tranquilidad acústica. Con <strong>cabina insonorizada de fábrica</strong> y operación a solo <strong>60 dB a 7 metros</strong>, es prácticamente imperceptible durante tu evento. Alimenta cómodamente un sistema de iluminación decorativa, sonido ambiental, una pantalla LED y equipos de refrigeración básicos. Perfecto para <strong>bodas íntimas en jardín, cenas privadas en hacienda y reuniones empresariales al aire libre</strong>.</p>
                <p class="showcase__text">Incluye <strong>tablero de distribución de 4 circuitos</strong>, protección termomagnética individual, conexión a tierra con varilla copper y cableado oculto con canaleta de protección. El formato compacto permite ubicar el generador en espacios reducidos — detrás de un muro, junto a la vegetación o en un acceso vehicular — sin interferir con la decoración ni el montaje. Combínalo con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente mágico con energía garantizada.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">20 kW</span>
                  <span class="showcase__tag">60 dB</span>
                  <span class="showcase__tag">4 circuitos</span>
                  <span class="showcase__tag">Hasta 100 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Generador 20 kW
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Generador 20 kW Silenciado</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Generador 30 kW Eventos Sociales -->
          <section class="section section--alt" aria-labelledby="gen-30-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más solicitado para bodas</span>
                <h2 class="showcase__title" id="gen-30-heading">Generador 30 kW Eventos Sociales</h2>
                <p class="showcase__subtitle">Potencia equilibrada para bodas de 100 a 200 personas con iluminación, sonido y refrigeración simultáneos.</p>
                <p class="showcase__text">El <strong>generador de 30 kW</strong> es nuestra opción más popular para <strong>bodas y eventos sociales</strong> en jardines y haciendas de la Ciudad de México. Con capacidad para alimentar simultáneamente un sistema de <strong>sonido profesional, iluminación decorativa con fairy lights, 2 pantallas LED, refrigeradores de bebidas y equipos de cocina básicos</strong>. Su cabina insonorizada garantiza operación a <strong>máximo 63 dB a 7 metros</strong>, permitiendo que la música y las conversaciones fluyan sin interferencias.</p>
                <p class="showcase__text">Incluye <strong>tablero de distribución de 6 circuitos independientes</strong> con protección termomagnética por línea, regulador de voltaje para equipos sensibles y conexión a tierra certificada. El técnico distribuye los circuitos estratégicamente: uno para iluminación, otro para sonido, uno para pantallas, otro para refrigeración y dos de respaldo. Combínalo con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para una producción de boda completa con energía garantizada.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">30 kW</span>
                  <span class="showcase__tag">63 dB</span>
                  <span class="showcase__tag">6 circuitos</span>
                  <span class="showcase__tag">100-200 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Generador 30 kW
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Generador 30 kW Eventos Sociales</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Generador 40 kW Corporativos -->
          <section class="section section--alt" aria-labelledby="gen-40-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para corporativos</span>
                <h2 class="showcase__title" id="gen-40-heading">Generador 40 kW Corporativos</h2>
                <p class="showcase__subtitle">Potencia robusta para eventos corporativos, lanzamientos de producto y presentaciones ejecutivas de hasta 250 personas.</p>
                <p class="showcase__text">El <strong>generador de 40 kW</strong> está dimensionado para <strong>eventos corporativos de alto perfil</strong> donde la continuidad eléctrica es indispensable. Alimenta simultáneamente <strong>sistemas de sonido line array, iluminación de escenario con PAR LED, múltiples pantallas LED, proyectores 4K, equipos de streaming y aire acondicionado portátil</strong>. Ideal para lanzamientos de producto, conferencias de prensa, eventos de team building y presentaciones ejecutivas en terrazas y venues sin acometida eléctrica suficiente.</p>
                <p class="showcase__text">Incluye <strong>tablero de distribución de 8 circuitos</strong> con medidor de consumo por línea, regulador de voltaje automático y sistema de arranque con precalentamiento para encendido inmediato. La protección diferencial (GFCI) garantiza seguridad eléctrica para equipos de cómputo y pantallas sensibles. Combínalo con nuestro equipo de <a href="/servicios/audiovisual/">audiovisual profesional</a> para producciones corporativas impecables con energía estable y silenciosa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">40 kW</span>
                  <span class="showcase__tag">65 dB</span>
                  <span class="showcase__tag">8 circuitos</span>
                  <span class="showcase__tag">Hasta 250 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Generador 40 kW
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
