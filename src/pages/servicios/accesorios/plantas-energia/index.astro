---
/**
 * ─── Plantas de Energía para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Plantas de Energía para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const PLANTAS = [
  {
    name: "Generadores 20-50 kW",
    excerpt: "Generadores diésel silenciados de 20 a 50 kW para bodas, banquetes y eventos sociales de hasta 300 personas. Operación silenciosa con máximo 65 dB.",
    cta: "20-50 kW",
    href: "#gen-20-50-heading",
    icon: "shield",
  },
  {
    name: "Generadores 50-150 kW",
    excerpt: "Plantas de energía de mediana capacidad para eventos corporativos, conciertos y expos. Múltiples zonas de alimentación con transferencia automática.",
    cta: "50-150 kW",
    href: "#gen-50-150-heading",
    icon: "package",
  },
  {
    name: "Generadores 150-500 kW",
    excerpt: "Generadores de escala industrial para festivales, producciones masivas y eventos de gran formato. Sistemas de respaldo redundante y potencia total de producción.",
    cta: "150-500 kW",
    href: "#gen-150-500-heading",
    icon: "layers",
  },
  {
    name: "Tableros y Distribución",
    excerpt: "Tableros de distribución eléctrica, reguladores de voltaje, interruptores termomagnéticos, canalización de cableado y protección contra fallas a tierra.",
    cta: "Distribución",
    href: "#tableros-heading",
    icon: "award",
  },
];

const faqs = [
  { question: "¿Cómo calculo la potencia que necesito para mi evento?", answer: "El cálculo depende del equipamiento total que alimentarás. Sumamos el consumo en watts de iluminación, sonido, pantallas LED, refrigeración, cocina y cualquier otro equipo eléctrico. Como regla general: un evento social para 150 personas con iluminación y sonido básico requiere 20-30 kW. Un evento corporativo con audiovisual completo necesita 50-75 kW. Un festival con escenario de producción completa puede requerir 150-500 kW. Nuestro ingeniero eléctrico realiza el cálculo exacto sin costo y recomienda la planta ideal con margen de seguridad del 20%." },
  { question: "¿Qué nivel de ruido tienen los generadores?", answer: "Nuestros generadores diésel cuentan con cabina insonorizada de fábrica. Los modelos de 20-50 kW operan a un máximo de 65 dB a 7 metros de distancia, equivalente a una conversación normal. Los de 50-150 kW alcanzan 70-75 dB, y siempre se ubican a distancia prudente del área de invitados. Para bodas y eventos donde el silencio es crítico, utilizamos generadores super silenciados de 60 dB y los posicionamos estratégicamente con barreras acústicas adicionales." },
  { question: "¿Cuánto combustible consumen los generadores?", answer: "El consumo varía según la capacidad y la carga real. Un generador de 20 kW al 75% de carga consume aproximadamente 5-6 litros de diésel por hora. Uno de 50 kW consume 12-15 litros/hora, y los de 150 kW consumen 35-40 litros/hora. Todos nuestros generadores llegan con tanque lleno y calculamos el combustible necesario según la duración de tu evento más un margen de seguridad del 30%. El costo del diésel está incluido en la cotización para eventos de hasta 12 horas." },
  { question: "¿Pueden operar las 24 horas sin interrupciones?", answer: "Sí. Nuestros generadores están diseñados para operación continua. Para eventos que superan las 12 horas, programamos reabastecimiento de combustible sin cortes de energía. En eventos de varios días (festivales, expos, ferias), instalamos sistemas de tanque extendido o reabastecimiento automático. Para aplicaciones críticas, desplegamos generadores en configuración de respaldo (redundancia N+1) con transferencia automática, garantizando cero interrupciones incluso ante una falla mecánica." },
  { question: "¿Incluyen técnico de operación?", answer: "Sí, todos nuestros servicios de plantas de energía incluyen un técnico electricista certificado durante todo el evento. El técnico se encarga del arranque, monitoreo de cargas, distribución de circuitos, verificación de conexiones a tierra y atención de cualquier contingencia eléctrica. Para eventos de gran formato (150+ kW), asignamos un equipo de dos técnicos con turno rotativo. El técnico permanece en sitio desde el montaje hasta el desmontaje completo." },
  { question: "¿Con cuánta anticipación debo reservar una planta de energía?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para generadores de 20-50 kW. Para plantas de 50-150 kW o superior, lo ideal es apartar con 1 a 2 meses, especialmente en temporada alta (noviembre a febrero) cuando la demanda se triplica. Los generadores de 250-500 kW tienen disponibilidad limitada y requieren planificación logística especial por su tamaño. También atendemos emergencias y solicitudes de último momento sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Plantas de Energía para Eventos en CDMX",
    description: "Generadores diésel silenciados de 20 a 500 kW, tableros de distribución y reguladores de voltaje para eventos. Técnico electricista incluido.",
    url: "/servicios/accesorios/plantas-energia/",
    priceRange: { min: 3000, max: 50000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Plantas de Energía", url: "/servicios/accesorios/plantas-energia/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Plantas de Energía para Eventos en CDMX"
  description="Renta de generadores diésel silenciados de 20 a 500 kW, tableros de distribución y reguladores de voltaje para eventos en CDMX. Técnico incluido. Desde $3,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Energía confiable para tu evento"
    title='Renta de <span class="highlight">Plantas de Energía</span> para Eventos en CDMX'
    subtitle="Generadores diésel silenciados desde 20 kW hasta 500 kW con tableros de distribución profesional. Operación silenciosa, técnico electricista dedicado y combustible incluido en cada renta."
    primaryCTA={{ label: "Cotiza tu planta", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar plantas de energía para mi evento` }}
    cards={[
      {
        title: "Generadores de grado profesional para cada evento",
        content: "<strong>Renta de plantas de energía para eventos</strong> con generadores diésel de última generación disponibles en CDMX. Equipos silenciados de 20 a 50 kW con nivel de ruido máximo de 65 dB para bodas y eventos sociales. Plantas de mediana capacidad de 50 a 150 kW con transferencia automática para corporativos y conciertos. Generadores industriales de 150 a 500 kW con sistemas de respaldo redundante para festivales y producciones masivas — cada unidad revisada y verificada antes de cada entrega.",
      },
      {
        title: "Distribución eléctrica profesional con técnico dedicado",
        content: "<strong>Servicio técnico eléctrico completo</strong> incluido en cada renta de planta de energía. Nuestro ingeniero electricista certificado se encarga del transporte, instalación, conexión de tableros de distribución, reguladores de voltaje, protección contra fallas a tierra, canalización de cableado oculto y monitoreo de cargas en tiempo real durante todo el evento. Interruptores termomagnéticos y protección diferencial incluidos para máxima seguridad eléctrica.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas energía confiable para tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con la planta ideal para tu consumo eléctrico"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de planta
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Plantas de Energía"
        subtitle="La solución eléctrica perfecta para cada tipo de evento"
        description={[
          "Desde generadores compactos silenciados para bodas íntimas hasta plantas industriales para festivales masivos. Contamos con el inventario de generadores y equipos de distribución eléctrica más completo de la Ciudad de México.",
          "Cada planta incluye tablero de distribución, protecciones eléctricas, combustible y técnico electricista dedicado. Potencia, autonomía y seguridad certificadas para garantizar energía ininterrumpida."
        ]}
      />

      <div class="grid grid--4">
        {PLANTAS.map((planta) => (
          <Card
            name={planta.name}
            excerpt={planta.excerpt}
            cta={planta.cta}
            href={planta.href}
            icon={planta.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GENERADORES 20-50 kW — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="gen-20-50-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Eventos medianos</span>
          <h2 class="showcase__title" id="gen-20-50-heading">Generadores 20-50 kW</h2>
          <p class="showcase__subtitle">Generadores diésel silenciados para bodas y eventos sociales con hasta 300 personas.</p>
          <p class="showcase__text">Nuestros <strong>generadores de 20 a 50 kW</strong> son la solución ideal para eventos que requieren energía confiable sin sacrificar la tranquilidad acústica. Equipados con <strong>cabina insonorizada de fábrica</strong>, operan a un máximo de <strong>65 dB a 7 metros</strong> de distancia — equivalente a una conversación normal. Disponibles en capacidades de <strong>20, 30 y 50 kW</strong> para alimentar iluminación decorativa, sonido ambiental, pantallas LED, refrigeradores y equipos de cocina simultáneamente.</p>
          <p class="showcase__text">Ideales para <strong>bodas en jardín, recepciones en haciendas, banquetes al aire libre y eventos sociales</strong> donde no existe acometida eléctrica o la disponible es insuficiente. Cada generador llega con tanque lleno, tablero de distribución de 4 a 8 circuitos y conexión a tierra certificada. Combínalos con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para crear ambientes mágicos con energía garantizada durante todo el evento.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">20 kW</span>
            <span class="showcase__tag">30 kW</span>
            <span class="showcase__tag">50 kW</span>
            <span class="showcase__tag">65 dB máx</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Generador 20-50 kW
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <line x1="6" y1="7" x2="6" y2="3"/>
              <line x1="18" y1="7" x2="18" y2="3"/>
              <line x1="6" y1="3" x2="18" y2="3"/>
              <circle cx="12" cy="14" r="3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GENERADORES 50-150 kW — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="gen-50-150-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Gran formato</span>
          <h2 class="showcase__title" id="gen-50-150-heading">Generadores 50-150 kW</h2>
          <p class="showcase__subtitle">Plantas de energía de mediana capacidad para eventos corporativos, conciertos y expos con múltiples zonas de alimentación.</p>
          <p class="showcase__text">Los <strong>generadores de 50 a 150 kW</strong> están diseñados para eventos de gran formato que requieren alimentar <strong>múltiples zonas de potencia simultáneamente</strong>: escenario principal con sonido e iluminación, área de catering con equipos de cocina, zonas de exhibición con pantallas LED y climatización de carpas. Disponibles en capacidades de <strong>50, 75, 100 y 150 kW</strong> con <strong>transferencia automática</strong> que garantiza cero interrupciones ante cualquier fluctuación.</p>
          <p class="showcase__text">Incluyen <strong>tablero de distribución principal con hasta 16 circuitos independientes</strong>, regulador de voltaje integrado, medidor de consumo en tiempo real y sistema de arranque automático. Ideales para <strong>eventos corporativos, conciertos, lanzamientos de producto, congresos y expos comerciales</strong> donde la continuidad eléctrica es crítica. Combínalos con nuestros equipos de <a href="/servicios/audiovisual/">audiovisual profesional</a> para producciones de alto impacto con energía garantizada.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">50 kW</span>
            <span class="showcase__tag">75 kW</span>
            <span class="showcase__tag">100 kW</span>
            <span class="showcase__tag">150 kW</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Generador 50-150 kW
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="6" width="22" height="15" rx="2" ry="2"/>
              <line x1="5" y1="6" x2="5" y2="2"/>
              <line x1="19" y1="6" x2="19" y2="2"/>
              <line x1="5" y1="2" x2="19" y2="2"/>
              <path d="M9 13l2 2 4-4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GENERADORES 150-500 kW — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="gen-150-500-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Escala industrial</span>
          <h2 class="showcase__title" id="gen-150-500-heading">Generadores 150-500 kW</h2>
          <p class="showcase__subtitle">Potencia industrial para festivales, producciones masivas y eventos de gran escala con sistemas de respaldo redundante.</p>
          <p class="showcase__text">Nuestros <strong>generadores de 150 a 500 kW</strong> representan la máxima capacidad de generación eléctrica para <strong>eventos masivos, festivales de música, producciones de televisión y montajes de gran escala</strong>. Disponibles en capacidades de <strong>150, 250, 350 y 500 kW</strong> con configuración de <strong>respaldo redundante N+1</strong> que garantiza energía ininterrumpida incluso ante una falla mecánica. Potencia total de producción para alimentar escenarios completos con sonido line array, iluminación robotizada, pantallas LED gigantes y toda la infraestructura del evento.</p>
          <p class="showcase__text">Incluyen <strong>sistema de sincronización para operación en paralelo</strong>, tableros de distribución principal y secundarios, monitoreo remoto de cargas, tanque extendido para autonomía de 24+ horas y equipo técnico de dos ingenieros con turno rotativo. Ideales para <strong>festivales de 2-5 días, eventos deportivos, ferias industriales y producciones que requieren energía de grado comercial</strong>. Complementa con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para proteger el área técnica y crear zonas de producción cubiertas.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">150 kW</span>
            <span class="showcase__tag">250 kW</span>
            <span class="showcase__tag">350 kW</span>
            <span class="showcase__tag">500 kW</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Generador 150-500 kW
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="5" width="22" height="16" rx="2" ry="2"/>
              <line x1="4" y1="5" x2="4" y2="1"/>
              <line x1="20" y1="5" x2="20" y2="1"/>
              <line x1="4" y1="1" x2="20" y2="1"/>
              <line x1="8" y1="13" x2="16" y2="13"/>
              <line x1="12" y1="9" x2="12" y2="17"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TABLEROS Y DISTRIBUCIÓN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tableros-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Seguridad eléctrica</span>
          <h2 class="showcase__title" id="tableros-heading">Tableros y Distribución</h2>
          <p class="showcase__subtitle">Distribución eléctrica profesional con protecciones certificadas para eventos seguros y sin interrupciones.</p>
          <p class="showcase__text">Nuestros <strong>tableros de distribución eléctrica</strong> son el complemento esencial para cualquier instalación de energía en eventos. <strong>Tableros principales y secundarios</strong> con capacidad de 100 a 600 amperes, <strong>reguladores de voltaje automáticos</strong> que mantienen la tensión estable entre 118-122V, <strong>interruptores termomagnéticos</strong> por circuito independiente y <strong>protección diferencial contra fallas a tierra</strong> (GFCI) para máxima seguridad de asistentes y equipos.</p>
          <p class="showcase__text">Incluyen <strong>canalización de cableado profesional con tapetes de protección</strong>, cajas de conexión distribuidas, extensiones industriales certificadas y señalización de seguridad eléctrica. Todo el cableado se oculta y protege para eliminar riesgos de tropiezo. La <strong>gestión de cable management</strong> garantiza una instalación limpia y profesional que se integra con el montaje de tu evento. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario para eventos</a> para una producción integral con energía y equipamiento coordinados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Tableros 100-600A</span>
            <span class="showcase__tag">Reguladores</span>
            <span class="showcase__tag">GFCI</span>
            <span class="showcase__tag">Cable management</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Tableros
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
              <line x1="15" y1="3" x2="15" y2="21"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Plantas de Energía"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu planta de energía, es natural tener preguntas sobre potencia, ruido, combustible y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre plantas de energía al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de plantas de energía para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

