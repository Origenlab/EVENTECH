---
/**
 * ─── EVENTECH.MX — Renta de Plantas de Energía para Eventos (Hub L4, molde hm- 2026) ───
 * Generadores 20-50 kW · 50-150 kW · 150-500 kW · Tableros de Distribución — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/accesorios — planta-luz-generador-evento real; accesorio-evento-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "gen-20-50",
    name: "Generadores 20–50 kW",
    badge: "Eventos sociales",
    excerpt: "Generadores diésel con cabina insonorizada de fábrica, de 20 a 50 kW para bodas, banquetes y eventos sociales de hasta 300 personas. Operación silenciosa con máximo 65 dB(A) y técnico electricista incluido.",
    href: "/servicios/accesorios/plantas-energia/gen-20-50/",
    image: "/images/accesorios/planta-luz-generador-evento.avif",
    specs: ["20–50 kW", "65 dB(A) máx.", "Mono/Trifásico", "Técnico incluido"],
  },
  {
    id: "gen-50-150",
    name: "Generadores 50–150 kW",
    badge: "Gran formato",
    excerpt: "Plantas de mediana capacidad con transferencia automática para eventos corporativos, conciertos y expos. Alimentan escenario, catering y climatización de forma simultánea sin interrupciones.",
    href: "/servicios/accesorios/plantas-energia/gen-50-150/",
    image: "/images/accesorios/accesorio-evento-04.avif",
    specs: ["50–150 kW", "Transferencia automática", "16 circuitos", "Trifásico"],
  },
  {
    id: "gen-150-500",
    name: "Generadores 150–500 kW",
    badge: "Escala industrial",
    excerpt: "Generadores de escala industrial con respaldo redundante N+1 para festivales, producciones masivas y eventos de gran formato. Sincronización en paralelo y autonomía de 24+ horas.",
    href: "/servicios/accesorios/plantas-energia/gen-150-500/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    specs: ["150–500 kW", "Redundancia N+1", "Sincronización paralelo", "24+ hrs autonomía"],
  },
  {
    id: "tableros-distribucion",
    name: "Tableros de Distribución",
    badge: "Seguridad eléctrica",
    excerpt: "Tableros de distribución, reguladores de voltaje e interruptores termomagnéticos con protección diferencial contra fallas a tierra. Canalización de cableado profesional bajo norma NOM.",
    href: "/servicios/accesorios/plantas-energia/tableros-distribucion/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    specs: ["100–600 A", "GFCI 30mA", "NOM-001-SEDE", "Cable management"],
  },
];

const whyFeatures = [
  {
    title: "Cálculo eléctrico gratuito antes de cotizar",
    body: "Antes de recomendar una planta, un ingeniero suma el consumo real de tu evento: iluminación, sonido, pantallas LED, refrigeración, cocina y climatización, con un margen de seguridad del 20%. No cotizamos plantas de energía por estimados de teléfono — cotizamos por kW real, para que el día del evento nada se quede sin corriente.",
  },
  {
    title: "Generadores diésel con cabina insonorizada de fábrica",
    body: "Nuestros generadores de 20 a 50 kW operan a un máximo de 65 dB(A) a 7 metros — el volumen de una conversación normal — gracias a cabina insonorizada de fábrica, no adaptada. Las plantas de mayor capacidad alcanzan 70–75 dB y siempre se ubican a distancia prudente del área de invitados, con modelos súper silenciados de 60 dB disponibles para bodas.",
  },
  {
    title: "Técnico electricista certificado en cada evento",
    body: "Todos nuestros servicios incluyen un técnico electricista certificado que se encarga del arranque, monitoreo de cargas, distribución de circuitos y verificación de conexión a tierra durante todo el evento. En plantas de 150 kW o más asignamos un equipo de dos técnicos con turno rotativo, presentes del montaje al desmontaje.",
  },
  {
    title: "Tableros y protecciones bajo norma NOM",
    body: "Cada instalación incluye tablero de distribución con interruptores termomagnéticos, protección diferencial contra fallas a tierra (GFCI) y canalización oculta de cableado bajo norma NOM-001-SEDE. La seguridad eléctrica no es un extra: es parte de cada renta, revisada antes de que lleguen tus invitados.",
  },
  {
    title: "Combustible y autonomía calculados, no adivinados",
    body: "Cada generador llega con tanque lleno y el combustible necesario calculado según la duración de tu evento más un margen de seguridad del 30%. Para eventos de más de 12 horas programamos reabastecimiento sin cortes de energía, y para festivales de varios días instalamos tanque extendido o reabastecimiento automático.",
  },
  {
    title: "Redundancia N+1 para producciones que no admiten fallas",
    body: "En aplicaciones críticas desplegamos generadores en configuración de respaldo redundante (N+1) con transferencia automática y sincronización en paralelo, garantizando energía ininterrumpida incluso ante una falla mecánica. La opción para festivales, producciones de TV y eventos donde un corte de luz no es una opción.",
  },
];

const steps = [
  { n: 1, t: "Cálculo eléctrico y cotización", p: "Nos cuentas tu tipo de evento y equipos a alimentar (iluminación, sonido, cocina, climatización). Un ingeniero calcula el consumo real con margen de seguridad del 20% y en menos de 24 horas te enviamos la planta ideal, el tablero necesario y el precio." },
  { n: 2, t: "Confirmación, tablero y logística de combustible", p: "Definimos capacidad, configuración monofásica o trifásica, tablero de distribución y autonomía de combustible según la duración del evento. Con el 30% de anticipo apartamos el equipo y coordinamos acceso, horario de entrega y ubicación del generador." },
  { n: 3, t: "Instalación, conexión a tierra y prueba de carga", p: "Nuestro técnico instala el generador, conecta el tablero de distribución con protección diferencial, verifica la conexión a tierra y realiza una prueba de carga completa antes de que lleguen tus invitados. Todo queda verificado con anticipación." },
  { n: 4, t: "Operación en sitio, monitoreo y retiro", p: "El técnico permanece en el evento monitoreando cargas, combustible y circuitos en tiempo real, listo para cualquier contingencia. Al finalizar, desconectamos y retiramos el equipo sin interrupciones para tu cierre de evento." },
];

const faqs = [
  { question: "¿Cómo calculo la potencia que necesito para mi evento?", answer: "El cálculo depende del equipamiento total que alimentarás. Sumamos el consumo en watts de iluminación, sonido, pantallas LED, refrigeración, cocina y cualquier otro equipo eléctrico. Como regla general: un evento social para 150 personas con iluminación y sonido básico requiere 20-30 kW. Un evento corporativo con audiovisual completo necesita 50-75 kW. Un festival con escenario de producción completa puede requerir 150-500 kW. Nuestro ingeniero eléctrico realiza el cálculo exacto sin costo y recomienda la planta ideal con margen de seguridad del 20%." },
  { question: "¿Qué nivel de ruido tienen los generadores?", answer: "Nuestros generadores diésel cuentan con cabina insonorizada de fábrica. Los modelos de 20-50 kW operan a un máximo de 65 dB(A) a 7 metros de distancia, equivalente a una conversación normal. Los de 50-150 kW alcanzan 70-75 dB, y siempre se ubican a distancia prudente del área de invitados. Para bodas y eventos donde el silencio es crítico, utilizamos generadores súper silenciados de 60 dB y los posicionamos estratégicamente con barreras acústicas adicionales." },
  { question: "¿Cuánto combustible consumen los generadores?", answer: "El consumo varía según la capacidad y la carga real. Un generador de 20 kW al 75% de carga consume aproximadamente 5-6 litros de diésel por hora. Uno de 50 kW consume 12-15 litros/hora, y los de 150 kW consumen 35-40 litros/hora. Todos nuestros generadores llegan con tanque lleno y calculamos el combustible necesario según la duración de tu evento más un margen de seguridad del 30%. El costo del diésel está incluido en la cotización para eventos de hasta 12 horas." },
  { question: "¿Pueden operar las 24 horas sin interrupciones?", answer: "Sí. Nuestros generadores están diseñados para operación continua. Para eventos que superan las 12 horas, programamos reabastecimiento de combustible sin cortes de energía. En eventos de varios días (festivales, expos, ferias), instalamos sistemas de tanque extendido o reabastecimiento automático. Para aplicaciones críticas, desplegamos generadores en configuración de respaldo (redundancia N+1) con transferencia automática, garantizando cero interrupciones incluso ante una falla mecánica." },
  { question: "¿Incluyen técnico de operación?", answer: "Sí, todos nuestros servicios de plantas de energía incluyen un técnico electricista certificado durante todo el evento. El técnico se encarga del arranque, monitoreo de cargas, distribución de circuitos, verificación de conexiones a tierra y atención de cualquier contingencia eléctrica. Para eventos de gran formato (150+ kW), asignamos un equipo de dos técnicos con turno rotativo. El técnico permanece en sitio desde el montaje hasta el desmontaje completo." },
  { question: "¿Con cuánta anticipación debo reservar una planta de energía?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para generadores de 20-50 kW. Para plantas de 50-150 kW o superior, lo ideal es apartar con 1 a 2 meses, especialmente en temporada alta (noviembre a febrero) cuando la demanda se triplica. Los generadores de 250-500 kW tienen disponibilidad limitada y requieren planificación logística especial por su tamaño. También atendemos emergencias y solicitudes de último momento sujetas a disponibilidad." },
  { question: "¿Las plantas de energía son monofásicas o trifásicas?", answer: "Depende de la carga que vas a conectar. Los generadores de 20 a 50 kW suelen operar en configuración monofásica o trifásica a 220V, suficiente para iluminación, sonido y equipos de cocina en eventos sociales. A partir de 50 kW, y en toda instalación con climatización, motores o equipo de producción pesado, trabajamos en trifásico 220/380V para balancear cargas entre fases y evitar caídas de tensión. En la cotización, nuestro ingeniero define la configuración correcta según los equipos que vas a conectar, para que no haya sorpresas el día del evento." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Plantas de Energía para Eventos en CDMX",
    description: "Renta de plantas de energía y generadores diésel silenciados de 20 a 500 kW para eventos en CDMX. Tableros de distribución, técnico electricista y combustible incluidos.",
    url: "/servicios/accesorios/plantas-energia/",
    priceRange: { min: 3500, max: 60000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Plantas de Energía", url: "/servicios/accesorios/plantas-energia/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Plantas de Energía" },
];
---

<PageLayout
  title="Renta de Plantas de Energía para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/accesorios/planta-luz-generador-evento.avif"
  description="Renta de plantas de energía en CDMX: generadores diésel de 20 a 500 kW, tableros de distribución y técnico incluido. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="plantas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Plantas de energía · CDMX y ZMVM</p>
            <h1 id="plantas-hero-heading">
              Plantas de energía que entregan <em>de 20 a 500 kW sin interrupciones</em> a tu evento
            </h1>
            <p class="hm-hero__lead">
              Generadores diésel silenciados, tableros de distribución con protección normada
              y técnico electricista certificado en sitio. Desde bodas en jardín sin acometida
              eléctrica hasta festivales de producción completa — con cálculo eléctrico
              gratuito y combustible incluido.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20planta%20de%20energía%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar planta de energía
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>plantas de energía para eventos</strong> en CDMX y zona
              metropolitana: generadores diésel con cabina insonorizada de fábrica, desde
              <strong>20 kW hasta 500 kW</strong>, con tableros de distribución, reguladores de
              voltaje y protección diferencial certificada. Cada planta llega con tanque lleno
              y técnico electricista dedicado que calcula la carga real de tu evento antes de
              cotizar.
            </p>
            <p>
              Con <strong>más de 500 eventos</strong> resueltos en CDMX, sabemos que la energía
              no admite improvisación: por eso cada renta incluye cálculo eléctrico gratuito,
              margen de seguridad del 20% y técnico en sitio del montaje al desmontaje. Para
              una producción integral sumamos <a href="/servicios/audiovisual/">audiovisual</a>,
              <a href="/servicios/iluminacion/">iluminación</a> y
              <a href="/servicios/carpas/">carpas</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de planta de energía disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20planta%20de%20energía%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Energía profesional para cada evento</p>
            <h2 id="catalogo-heading">¿Qué planta de energía necesita tu evento?</h2>
            <p class="hm__head-sub">De la boda en jardín sin acometida al festival de producción completa — con el generador y la distribución correctos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La planta de energía correcta no es solo cuestión de kW: es el ruido que vas a
              tolerar junto a tus invitados, el número de circuitos que necesitas alimentar al
              mismo tiempo y la seguridad de la instalación eléctrica completa.
            </p>
            <p>
              Generadores de 20 a 50 kW para eventos sociales silenciosos. De 50 a 150 kW con
              transferencia automática para corporativos. De 150 a 500 kW con redundancia para
              festivales. Y los tableros de distribución que dejan toda la instalación segura y
              normada. Una sola empresa para toda la energía de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de energía — en detalle</h2>
            <p class="hm__head-sub">Capacidad, ruido, distribución y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada planta de energía hay decisiones que afectan la seguridad y la
              experiencia: la capacidad que determina cuánto equipo puedes alimentar sin
              riesgo, el nivel de ruido que conviven con tus invitados, y la distribución
              eléctrica que marca si la instalación es segura o improvisada.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- GENERADORES 20-50 kW -->
        <article class="hm-feat" aria-labelledby="feat-gen-20-50">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Generadores 20–50 kW</p>
            <h3 class="hm-feat__title" id="feat-gen-20-50">Energía silenciosa para bodas, banquetes y eventos sociales de hasta 300 invitados</h3>
            <p class="hm-feat__lead">Cuando el silencio importa tanto como la luz. Cabina insonorizada de fábrica para que el generador nunca compita con la música ni con la conversación.</p>
            <p>
              Generadores diésel con <strong>cabina insonorizada</strong> en capacidades de
              <strong>20, 30 y 50 kW</strong>, operando a un máximo de
              <strong>65 dB(A) a 7 metros</strong> — equivalente a una conversación normal.
              Configuración monofásica o trifásica según la carga, con tablero de distribución
              de 4 a 8 circuitos y conexión a tierra certificada.
            </p>
            <p>
              Ideales para <strong>bodas en jardín, haciendas, banquetes al aire libre y
              eventos sociales</strong> sin acometida eléctrica suficiente. Alimentan
              iluminación decorativa, sonido ambiental, pantallas LED, refrigeración y cocina
              de forma simultánea. Combina con nuestra
              <a href="/servicios/iluminacion/">iluminación profesional</a> para un montaje con
              energía garantizada.
            </p>
            <ul class="hm-feat__stats">
              {["20–50 kW", "65 dB(A) máx.", "Mono/Trifásico", "4–8 circuitos", "Técnico incluido"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/accesorios/plantas-energia/gen-20-50/">
              Ver Generadores 20–50 kW
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/accesorios/planta-luz-generador-evento.avif" alt="Planta de energía generador diésel silenciado para boda en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/accesorios/accesorio-evento-01.avif" alt="Generador de 20 a 50 kW instalado en evento social en CDMX" loading="lazy" decoding="async" />
              <img src="/images/accesorios/accesorio-evento-03.avif" alt="Tablero de distribución de generador para boda en CDMX" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- GENERADORES 50-150 kW -->
        <article class="hm-feat" aria-labelledby="feat-gen-50-150">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Generadores 50–150 kW</p>
            <h3 class="hm-feat__title" id="feat-gen-50-150">Mediana capacidad con transferencia automática para corporativos, conciertos y expos</h3>
            <p class="hm-feat__lead">Cuando un evento necesita alimentar varias zonas a la vez, la energía no puede depender de un solo circuito. Aquí es donde entra la transferencia automática.</p>
            <p>
              Plantas trifásicas de <strong>50, 75, 100 y 150 kW</strong> con
