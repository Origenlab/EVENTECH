---
/**
 * ─── Postes Separadores — Pagina de Producto (Nivel 4) ───
 * Postes con cinta de terciopelo y retráctiles en acabados
 * cromado, dorado y negro para control de flujo elegante.
 *
 * Jerarquia: Servicios > Accesorios > Señalización y Alfombras > Postes Separadores
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { label: "Postes Separadores" },
];

const faqs = [
  { question: "¿Cuál es el pedido mínimo de postes separadores?", answer: "El mínimo de renta es de <strong>4 postes separadores</strong>, que incluyen sus cordones o cintas retráctiles. Este mínimo permite crear una fila básica de dos tramos o delimitar un área pequeña. Para red carpets completos recomendamos un mínimo de 8 postes (4 por cada lado de la alfombra). Ofrecemos <strong>paquetes de 8, 12, 16 y 20 postes con descuento progresivo</strong>. No hay máximo — hemos instalado hasta 60 postes para eventos corporativos de gran formato." },
  { question: "¿Qué acabados de postes tienen disponibles?", answer: "Contamos con tres acabados profesionales: <strong>cromado espejo</strong> (el más popular, brillo intenso y elegante), <strong>dorado champagne</strong> (acabado cálido ideal para bodas y galas de lujo) y <strong>negro mate</strong> (moderno y discreto, perfecto para eventos corporativos y de marca). Los tres acabados están disponibles tanto en postes con cordón de terciopelo como en postes retráctiles. Todos incluyen base de contrapeso de 8 kg para máxima estabilidad." },
  { question: "¿Cuál es la diferencia entre cordón de terciopelo y cinta retráctil?", answer: "Los <strong>postes con cordón de terciopelo</strong> ofrecen un look clásico y elegante — ideales para red carpets, recepciones VIP, bodas y galas. El cordón se engancha con mosquetón premium y viene en colores rojo, negro y dorado. Los <strong>postes retráctiles</strong> tienen una cinta integrada de 2 metros que se extiende y retrae automáticamente — ideales para filas de registro, control de acceso en congresos y delimitación de zonas en expos. La cinta retráctil viene en negro, rojo y azul." },
  { question: "¿La instalación y distribución está incluida?", answer: "Sí, <strong>todas nuestras rentas incluyen transporte, instalación estratégica y desmontaje</strong> dentro de CDMX y área metropolitana. Nuestro equipo distribuye los postes según el layout de tu venue para optimizar el flujo de invitados. Para red carpets, colocamos los postes equidistantes a ambos lados de la alfombra con cordones perfectamente tensados. Para control de acceso, diseñamos la distribución según los puntos de entrada y registro de tu evento." },
  { question: "¿Los postes separadores funcionan en exteriores?", answer: "Sí. Nuestros postes están fabricados con <strong>acero inoxidable de alta resistencia</strong> y base de contrapeso de 8 kg que garantiza estabilidad en superficies exteriores como jardines, terrazas y explanadas. En condiciones de viento moderado, los postes se mantienen firmes. Para eventos al aire libre con viento fuerte, ofrecemos bases reforzadas de 12 kg sin costo adicional. Los cordones de terciopelo resisten humedad ambiental, aunque recomendamos cubrirlos en caso de lluvia." },
  { question: "¿Puedo combinar postes con alfombra roja?", answer: 'Es nuestra combinación más solicitada. Ofrecemos <strong>paquetes Red Carpet completos</strong> que incluyen alfombra roja + postes separadores con cordón a ambos lados. El paquete estándar: alfombra 10m + 8 postes cromados con cordón rojo. También disponible con postes dorados o negros. El precio del paquete incluye un descuento especial vs rentar por separado. Consulta nuestras <a href="/servicios/accesorios/senalizacion-alfombras/alfombras-premium/">alfombras rojas y premium</a> para ver todas las opciones de color y medida.' },
];

const specs = [
  { label: "Acabados poste", value: "Cromado espejo, Dorado champagne, Negro mate" },
  { label: "Altura", value: "95 cm estándar profesional" },
  { label: "Base", value: "Contrapeso 8 kg estable" },
  { label: "Cordón terciopelo", value: "1.5 y 2 metros, rojo/negro/dorado" },
  { label: "Cinta retráctil", value: "2 metros, negro/rojo/azul" },
  { label: "Ganchos", value: "Mosquetón premium de cierre suave" },
  { label: "Pedido mínimo", value: "4 postes" },
  { label: "Paquetes", value: "8, 12, 16, 20 postes con descuento" },
  { label: "Instalación", value: "Distribución estratégica incluida" },
  { label: "Transporte", value: "Incluido en CDMX" },
];

const sidebarNav = [
  { name: "Alfombras Rojas y Premium", href: "/servicios/accesorios/senalizacion-alfombras/alfombras-premium/" },
  { name: "Postes Separadores", href: null, active: true },
  { name: "Podiums y Atriles", href: "/servicios/accesorios/senalizacion-alfombras/podiums-atriles/" },
  { name: "Backdrops y Señalética", href: "/servicios/accesorios/senalizacion-alfombras/backdrops-senaletica/" },
];

const sidebarRelated = [
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Audiovisual Pantallas", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Mobiliario Barras", href: "/servicios/mobiliario/barras/" },
];

const reviews = [
  { author: "Andrea Villarreal", text: "Rentamos 16 postes cromados con cordón rojo para la premiere de una película en un cine de Polanco. El acabado cromado era impecable, los cordones de terciopelo gruesos y elegantes. El equipo de EVENTECH distribuyó todo perfectamente y el resultado fue espectacular. Nuestros invitados se sintieron como en Hollywood.", rating: 5, date: "2025-11-08" },
  { author: "Ricardo Mendoza", text: "Usamos 12 postes dorados con cordón negro para delimitar el área VIP de una gala benéfica en un salón de Lomas. La calidad del acabado dorado champagne era premium, las bases pesadas y estables. Todo quedó perfectamente instalado antes del evento. Servicio profesional de primera.", rating: 5, date: "2025-10-15" },
  { author: "Mariana López", text: "Contratamos 20 postes retráctiles para el registro de un congreso médico de 800 personas. La distribución estratégica que hizo el equipo de EVENTECH eliminó las aglomeraciones en las filas de registro. Las cintas retráctiles funcionaron perfecto todo el día. Muy profesional y puntual el servicio.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Postes Separadores para Eventos en CDMX",
    description: "Renta de postes con cinta de terciopelo y retráctiles en acabados cromado, dorado y negro. Control de flujo elegante para eventos VIP. Desde $150 por poste.",
    url: "/servicios/accesorios/senalizacion-alfombras/postes-separadores/",
    priceRange: { min: 150, max: 600 },
    reviews,
    ratingValue: 5,
    reviewCount: 165,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Señalización y Alfombras", url: "/servicios/accesorios/senalizacion-alfombras/" },
    { name: "Postes Separadores", url: "/servicios/accesorios/senalizacion-alfombras/postes-separadores/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Postes Separadores para Eventos en CDMX | EVENTECH"
  description="Renta de postes con cinta de terciopelo y retráctiles en acabados cromado, dorado y negro. Control de flujo elegante para eventos VIP. Desde $150 por poste."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Control de flujo elegante y profesional"
    title='Renta de <span class="highlight">Postes Separadores</span> para Eventos'
    subtitle="Postes separadores con cordón de terciopelo y cintas retráctiles en acabados cromado, dorado y negro. Control de flujo elegante para entradas VIP, red carpets y eventos corporativos."
    primaryCTA={{ label: "Cotiza tus postes", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar postes separadores para mi evento` }}
    cards={[
      {
        title: "Postes separadores con cordón de terciopelo y cinta retráctil",
        content: "<strong>Renta de postes separadores profesionales</strong> para eventos en CDMX. Postes separadores con cordón de terciopelo en acabados cromado espejo, dorado champagne y negro mate. Postes retráctiles con cinta de 2 metros para filas y control de acceso. Ideales para entradas VIP, red carpets, registro de congresos y delimitación de áreas exclusivas en cualquier tipo de evento.",
      },
      {
        title: "Bases estables, ganchos premium e instalación estratégica",
        content: "<strong>Servicio integral de postes separadores</strong> con bases de contrapeso de 8 kg para máxima estabilidad en interiores y exteriores. Cordones de 1.5 y 2 metros en rojo, negro y dorado. Ganchos tipo mosquetón premium de cierre suave. Servicio de instalación con distribución estratégica incluida según el layout de tu venue. Paquetes de 8, 12, 16 y 20 postes con descuento progresivo.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas control de flujo elegante en tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la cantidad y acabado ideal para tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Señalización y Alfombras</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas postes separadores para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar postes separadores para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Postes Separadores</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Postes Cromados con Cordón Terciopelo -->
          <section class="section section--alt" aria-labelledby="postes-cromados-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El clásico elegante</span>
                <h2 class="showcase__title" id="postes-cromados-heading">Postes Cromados con Cordón Terciopelo</h2>
                <p class="showcase__subtitle">El estándar de elegancia para red carpets, galas y recepciones VIP.</p>
                <p class="showcase__text">Nuestros <strong>postes cromados con cordón de terciopelo</strong> son la opción más solicitada para eventos de gala y red carpets. El acabado <strong>cromado espejo</strong> refleja la iluminación del venue creando un efecto visual premium. Cada poste mide 95 cm de altura con base de contrapeso de 8 kg que garantiza estabilidad total en cualquier superficie. Los cordones de terciopelo están disponibles en <strong>rojo clásico, negro elegante y dorado champagne</strong>, con longitudes de 1.5 y 2 metros.</p>
                <p class="showcase__text">Los ganchos tipo <strong>mosquetón premium de cierre suave</strong> permiten enganchar y desenganchar los cordones con una sola mano — ideal para momentos donde necesitas abrir el paso rápidamente. Perfectos para <strong>entradas de gala, pasillos de boda, áreas VIP, zonas de photo op y premiaciones</strong>. Combínalos con nuestra <a href="/servicios/accesorios/senalizacion-alfombras/alfombras-premium/">alfombra roja</a> para crear el red carpet completo que tus invitados recordarán.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cromado espejo</span>
                  <span class="showcase__tag">Terciopelo premium</span>
                  <span class="showcase__tag">Base 8 kg</span>
                  <span class="showcase__tag">3 colores cordón</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Postes Cromados
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Postes Cromados</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Postes Dorados para Red Carpet -->
          <section class="section section--alt" aria-labelledby="postes-dorados-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Lujo y calidez premium</span>
                <h2 class="showcase__title" id="postes-dorados-heading">Postes Dorados para Red Carpet</h2>
                <p class="showcase__subtitle">Acabado dorado champagne que aporta calidez y lujo a tu evento.</p>
                <p class="showcase__text">Los <strong>postes dorados champagne</strong> son la elección favorita para bodas de lujo, galas benéficas y eventos donde el dorado es parte de la paleta de color. El acabado <strong>dorado champagne mate</strong> ofrece un tono cálido y sofisticado que no refleja de forma agresiva, creando un ambiente elegante sin ser ostentoso. Misma altura de 95 cm y base de contrapeso de 8 kg que nuestra línea cromada.</p>
                <p class="showcase__text">Combinados con cordón de terciopelo dorado o rojo, crean un pasillo de entrada que evoca la grandeza de los grandes eventos internacionales. Especialmente populares para <strong>bodas con temática dorada, recepciones en haciendas y salones clásicos, premiaciones de la industria y eventos de moda de alta gama</strong>. Nuestro equipo instala y distribuye los postes según el diseño de tu evento. Combínalos con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> en tonos cálidos para un efecto visual envolvente.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Dorado champagne</span>
                  <span class="showcase__tag">Acabado mate</span>
                  <span class="showcase__tag">Bodas de lujo</span>
                  <span class="showcase__tag">Cordón dorado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Postes Dorados
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Postes Dorados</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Postes Retráctiles para Filas -->
          <section class="section section--alt" aria-labelledby="postes-retractiles-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Control de acceso eficiente</span>
                <h2 class="showcase__title" id="postes-retractiles-heading">Postes Retráctiles para Filas</h2>
                <p class="showcase__subtitle">Cinta retráctil de 2 metros para filas de registro, control de acceso y organización de zonas.</p>
                <p class="showcase__text">Nuestros <strong>postes retráctiles</strong> son la solución práctica y profesional para <strong>control de acceso, filas de registro, taquillas y delimitación de zonas</strong> en congresos, expos, ferias y eventos corporativos. La cinta retráctil de <strong>2 metros de extensión</strong> se enrolla automáticamente dentro del poste y se extiende con un mecanismo suave que permite conexión entre postes en segundos. Disponibles en acabados cromado, dorado y negro.</p>
                <p class="showcase__text">La cinta retráctil viene en colores <strong>negro, rojo y azul</strong>, y puede personalizarse con <strong>texto impreso</strong> como "VIP", "Acceso Restringido", "Área Privada" o el nombre de tu marca. Incluyen freno de seguridad que evita que la cinta se enrolle bruscamente. Ideales para <strong>mesas de registro en congresos, taquillas de eventos, líneas de buffet, acceso a zonas restringidas y organización de público</strong>. Combinan perfecto con nuestro <a href="/servicios/mobiliario/">mobiliario de recepción</a>.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cinta 2 metros</span>
                  <span class="showcase__tag">Retráctil automática</span>
                  <span class="showcase__tag">Texto personalizable</span>
                  <span class="showcase__tag">3 colores cinta</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Postes Retráctiles
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
