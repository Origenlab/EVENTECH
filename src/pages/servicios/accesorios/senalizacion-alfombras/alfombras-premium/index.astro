---
/**
 * ─── Alfombras Rojas y Premium — Pagina de Producto (Nivel 4) ───
 * Alfombras rojas de 1 a 15 metros, alfombras custom con logo
 * corporativo y opciones premium para recepciones VIP y galas.
 *
 * Jerarquia: Servicios > Accesorios > Señalización y Alfombras > Alfombras Premium
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { label: "Alfombras Rojas y Premium" },
];

const faqs = [
  { question: "¿Puedo solicitar alfombras en medidas personalizadas?", answer: 'Sí. Nuestras alfombras rojas y premium están disponibles en largos estándar de <strong>1, 3, 5, 8, 10 y 15 metros</strong> con ancho estándar de 1 metro. Si necesitas una medida especial — por ejemplo, 12 metros de largo o hasta 2 metros de ancho — podemos cortarla a la medida exacta de tu venue. Solo necesitamos confirmación con al menos 5 días de anticipación para medidas fuera de inventario. Consulta nuestras <a href="/servicios/accesorios/senalizacion-alfombras/postes-separadores/">opciones de postes separadores</a> para complementar tu red carpet.' },
  { question: "¿Cuánto tiempo toma producir una alfombra con logo corporativo?", answer: "Las alfombras con logo impreso o bordado requieren entre <strong>5 y 10 días hábiles</strong> de producción, dependiendo de la complejidad del diseño y las dimensiones. Necesitamos tu archivo de logo en formato vectorial (AI, EPS o PDF en alta resolución). Para logos sencillos en una sola tinta, el tiempo es de 5 días hábiles. Diseños multicolor o alfombras de gran formato (más de 5 metros) requieren hasta 10 días. Te enviamos prueba digital para aprobación antes de producir." },
  { question: "¿Qué colores de alfombra tienen disponibles?", answer: "Nuestro inventario permanente incluye <strong>rojo clásico, negro elegante, blanco nupcial, azul corporativo y dorado premium</strong>. El rojo es el más popular y está disponible en todos los largos (1 a 15 metros) con entrega inmediata. Los demás colores están disponibles en largos de hasta 10 metros. Para colores especiales (verde, morado, rosado, gris) fabricamos sobre pedido con 7-10 días de anticipación y pedido mínimo de 5 metros." },
  { question: "¿Las alfombras funcionan en exteriores?", answer: "Sí. Nuestras alfombras premium están fabricadas con <strong>fibra sintética resistente a humedad</strong> y cuentan con base antiderrapante de doble cara que se adhiere a superficies lisas y rugosas. Funcionan perfectamente en jardines, terrazas y explanadas. En caso de lluvia ligera, la fibra no absorbe agua y se seca rápidamente. Para eventos en pasto o tierra, recomendamos agregar una capa de protección base que proporcionamos sin costo adicional." },
  { question: "¿La instalación está incluida en la renta?", answer: "Sí, <strong>todas nuestras rentas incluyen transporte, instalación y desmontaje</strong> dentro de la CDMX y área metropolitana. Nuestro equipo llega con anticipación para fijar la alfombra con cinta profesional de doble cara, garantizando que quede completamente plana y segura. El proceso de instalación toma entre 15 y 45 minutos dependiendo del largo. Al finalizar tu evento, recogemos la alfombra sin costo adicional." },
  { question: "¿Puedo combinar alfombras con postes separadores?", answer: 'Es la combinación más popular. Ofrecemos <strong>paquetes Red Carpet completos</strong> que incluyen alfombra roja del largo que necesites + postes separadores con cordón de terciopelo a ambos lados. El paquete estándar incluye alfombra de 10 metros + 8 postes cromados con cordón rojo. También disponible con postes dorados o negros. Consulta nuestros <a href="/servicios/accesorios/senalizacion-alfombras/postes-separadores/">postes separadores</a> para ver todas las opciones de acabado.' },
];

const specs = [
  { label: "Largos estándar", value: "1, 3, 5, 8, 10 y 15 metros" },
  { label: "Ancho", value: "1 metro estándar / custom hasta 2 m" },
  { label: "Material", value: "Terciopelo sintético de alta densidad" },
  { label: "Colores", value: "Rojo, Negro, Blanco, Azul, Dorado" },
  { label: "Logo corporativo", value: "Impreso o bordado, 5-10 días producción" },
  { label: "Base", value: "Antiderrapante doble cara" },
  { label: "Grosor", value: "8 mm confort premium" },
  { label: "Corte a medida", value: "Disponible en cualquier largo" },
  { label: "Instalación", value: "Incluida con cinta de fijación" },
  { label: "Limpieza", value: "Aspirado y tratamiento incluido" },
];

const sidebarNav = [
  { name: "Alfombras Rojas y Premium", href: null, active: true },
  { name: "Postes Separadores", href: "/servicios/accesorios/senalizacion-alfombras/postes-separadores/" },
  { name: "Podiums y Atriles", href: "/servicios/accesorios/senalizacion-alfombras/podiums-atriles/" },
  { name: "Backdrops y Señalética", href: "/servicios/accesorios/senalizacion-alfombras/backdrops-senaletica/" },
];

const sidebarRelated = [
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Audiovisual Pantallas", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Mobiliario Barras", href: "/servicios/mobiliario/barras/" },
];

const reviews = [
  { author: "Claudia Ramírez", text: "Rentamos una alfombra roja de 15 metros para nuestra gala corporativa anual en un hotel de Polanco. La calidad del terciopelo era impresionante, quedó perfectamente fijada al piso y le dio un toque de elegancia increíble a la entrada. Nuestros invitados se sintieron como estrellas de cine. El equipo de EVENTECH fue puntual y profesional.", rating: 5, date: "2025-11-20" },
  { author: "Fernando Castillo", text: "Necesitábamos una alfombra negra con logo para la premiere de una serie en un foro de grabación. La impresión del logo quedó perfecta, colores vibrantes y alta definición. La producción tomó exactamente 7 días como nos prometieron. El montaje fue impecable y la alfombra resistió toda la noche de evento sin arrugarse.", rating: 5, date: "2025-10-12" },
  { author: "Valentina Soto", text: "Para nuestra boda en un jardín de Coyoacán rentamos una alfombra blanca de 8 metros para la entrada de la ceremonia. Nos preocupaba que se ensuciara en el pasto, pero el equipo colocó una base protectora y quedó impecable toda la tarde. Las fotos quedaron espectaculares. Muy recomendable el servicio completo.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Alfombras Rojas y Premium para Eventos en CDMX",
    description: "Renta de alfombras rojas de 1 a 15 metros, alfombras custom con logo corporativo y opciones premium para recepciones VIP y galas. Desde $500.",
    url: "/servicios/accesorios/senalizacion-alfombras/alfombras-premium/",
    priceRange: { min: 500, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 187,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Señalización y Alfombras", url: "/servicios/accesorios/senalizacion-alfombras/" },
    { name: "Alfombras Rojas y Premium", url: "/servicios/accesorios/senalizacion-alfombras/alfombras-premium/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Alfombras Rojas y Premium para Eventos en CDMX | EVENTECH"
  description="Renta de alfombras rojas de 1 a 15 metros, alfombras custom con logo corporativo y opciones premium para recepciones VIP y galas. Desde $500."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Red carpet para recepciones VIP"
    title='Renta de <span class="highlight">Alfombras Rojas y Premium</span> para Eventos'
    subtitle="Alfombras rojas profesionales de 1 a 15 metros en terciopelo de alta densidad. Colores custom, logo corporativo y opciones premium para entradas VIP, bodas y galas."
    primaryCTA={{ label: "Cotiza tu alfombra", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar alfombras rojas y premium para mi evento` }}
    cards={[
      {
        title: "Alfombras rojas de 1 a 15 metros en terciopelo profesional",
        content: "<strong>Renta de alfombras rojas y premium</strong> para eventos en CDMX con el catálogo más completo. Alfombras rojas de 1, 3, 5, 8, 10 y 15 metros en ancho estándar de 1 metro. Colores custom disponibles: negro, blanco, azul, dorado. Opción de logo corporativo impreso o bordado en alta resolución para lanzamientos, premiaciones y eventos de marca. Fabricadas con terciopelo sintético de alta densidad que mantiene su color vibrante durante todo el evento.",
      },
      {
        title: "Entrega, instalación y personalización completa incluida",
        content: "<strong>Servicio integral de alfombras premium</strong> con entrega e instalación incluida en CDMX. Base antiderrapante de doble cara para uso seguro en interiores y exteriores. Corte a medida personalizado en cualquier largo y ancho hasta 2 metros. Servicio de alfombras con logo corporativo con producción de 5 a 10 días. Nuestro equipo instala con cinta de fijación profesional y recoge al finalizar tu evento sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas una entrada VIP espectacular para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la alfombra ideal para tu espacio y ocasión"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Señalización y Alfombras</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas alfombras premium para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar alfombras rojas y premium para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Alfombras Rojas y Premium</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Alfombra Roja Clásica -->
          <section class="section section--alt" aria-labelledby="alfombra-roja-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">La favorita para red carpets</span>
                <h2 class="showcase__title" id="alfombra-roja-heading">Alfombra Roja Clásica</h2>
                <p class="showcase__subtitle">El estándar de elegancia para entradas VIP, premiaciones y recepciones de gala.</p>
                <p class="showcase__text">Nuestra <strong>alfombra roja clásica</strong> es la opción más solicitada para eventos de gala, premiaciones y red carpets en CDMX. Fabricada con <strong>terciopelo sintético de alta densidad de 8 mm</strong>, ofrece una textura suave al tacto y un color rojo vibrante que se mantiene impecable durante todo el evento. Disponible en largos de <strong>1, 3, 5, 8, 10 y 15 metros</strong> con ancho estándar de 1 metro, se adapta a cualquier espacio desde entradas de hotel hasta pasillos de salón de eventos.</p>
                <p class="showcase__text">La base <strong>antiderrapante de doble cara</strong> garantiza seguridad total en pisos de mármol, madera, concreto y cerámica. Incluye instalación profesional con cinta de fijación invisible y aspirado previo al evento. Ideal para <strong>galas corporativas, premiaciones, estrenos de cine, bodas de gala y recepciones VIP</strong>. Combínala con nuestros <a href="/servicios/accesorios/senalizacion-alfombras/postes-separadores/">postes separadores</a> para crear el red carpet completo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Rojo clásico</span>
                  <span class="showcase__tag">1-15 metros</span>
                  <span class="showcase__tag">8 mm grosor</span>
                  <span class="showcase__tag">Antiderrapante</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra Roja
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Alfombra Roja Clásica</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Alfombra Negra Elegante -->
          <section class="section section--alt" aria-labelledby="alfombra-negra-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Sofisticación en cada paso</span>
                <h2 class="showcase__title" id="alfombra-negra-heading">Alfombra Negra Elegante</h2>
                <p class="showcase__subtitle">Elegancia discreta y moderna para eventos corporativos y de alta gama.</p>
                <p class="showcase__text">La <strong>alfombra negra elegante</strong> es la elección premium para eventos donde la sofisticación y el estilo moderno son protagonistas. El <strong>terciopelo negro de alta densidad</strong> ofrece un contraste dramático que realza cualquier decoración y funciona perfectamente con esquemas de color monocromáticos, dorado y plata. Disponible en largos de <strong>1 a 10 metros</strong> con el mismo grosor de 8 mm y base antiderrapante que nuestra línea roja.</p>
                <p class="showcase__text">Perfecta para <strong>lanzamientos de producto de lujo, eventos de moda, premiaciones corporativas, galas de beneficencia y bodas de temática elegante</strong>. La alfombra negra disimula marcas de uso mejor que cualquier otro color, manteniéndose impecable durante eventos de alta afluencia. Combínala con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a> en tonos cálidos para crear una entrada espectacular que tus invitados recordarán.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Negro elegante</span>
                  <span class="showcase__tag">1-10 metros</span>
                  <span class="showcase__tag">Alta durabilidad</span>
                  <span class="showcase__tag">Eventos premium</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra Negra
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                    <polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>
                  </svg>
                  <span>Alfombra Negra Elegante</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Alfombra con Logo Corporativo -->
          <section class="section section--alt" aria-labelledby="alfombra-logo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tu marca en cada paso</span>
                <h2 class="showcase__title" id="alfombra-logo-heading">Alfombra con Logo Corporativo</h2>
                <p class="showcase__subtitle">Impresión de alta resolución con tu logotipo para eventos de marca y lanzamientos.</p>
                <p class="showcase__text">Nuestras <strong>alfombras con logo corporativo</strong> son la herramienta perfecta de branding experiencial. Disponibles con <strong>impresión en sublimación de alta resolución o bordado</strong>, reproducen tu logotipo, patrón de marca o diseño personalizado con fidelidad de color exacta. La impresión cubre toda la superficie de la alfombra o puede concentrarse en zonas específicas — logos repetidos estilo step and repeat, logo central destacado o diseño de patrón continuo.</p>
                <p class="showcase__text">El proceso de producción toma entre <strong>5 y 10 días hábiles</strong>. Necesitamos tu archivo de logo en formato vectorial (AI, EPS o PDF). Te enviamos prueba digital para aprobación antes de producción. Fabricadas sobre el mismo terciopelo de alta densidad con base antiderrapante. Ideales para <strong>lanzamientos de producto, convenciones, ferias comerciales, conferencias de prensa y eventos de patrocinio</strong>. Consulta nuestros <a href="/servicios/accesorios/senalizacion-alfombras/backdrops-senaletica/">backdrops step and repeat</a> para complementar tu branding visual.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Logo impreso/bordado</span>
                  <span class="showcase__tag">5-10 días producción</span>
                  <span class="showcase__tag">Alta resolución</span>
                  <span class="showcase__tag">Cualquier medida</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Alfombra con Logo
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
