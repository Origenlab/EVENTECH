---
/**
 * ─── Señalización y Alfombras para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Señalización y Alfombras para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import Gallery4x4 from "@components/Gallery4x4.astro";
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Señalización y Alfombras" },
];

const SENALIZACION = [
  {
    name: "Alfombras Rojas y Premium",
    price: "Desde $800",
    excerpt: "Alfombras rojas de 1 a 15 metros de largo en anchos estándar y personalizados. Colores custom, alfombras con logo corporativo y opciones premium para recepciones VIP, bodas y galas.",
    href: "/servicios/accesorios/senalizacion-alfombras/alfombras-premium/",
    image: "/images/accesorios/alfombra-roja-red-carpet-evento.avif",
    tags: ["Rojo Clásico", "Colores Custom", "Logo Corporativo", "1 a 15 m"],
    badge: "Más popular",
  },
  {
    name: "Postes Separadores",
    price: "Desde $300",
    excerpt: "Postes con cinta de terciopelo y retráctiles en acabados cromado, dorado y negro. Control de flujo elegante para entradas VIP, red carpets y áreas exclusivas en tu evento.",
    href: "/servicios/accesorios/senalizacion-alfombras/postes-separadores/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    tags: ["Cromado", "Dorado", "Negro", "Terciopelo", "Retráctil"],
  },
  {
    name: "Podiums y Atriles",
    price: "Desde $1,200",
    excerpt: "Podiums de acrílico transparente y madera ejecutiva con iluminación LED integrada. Mesas presidenciales y atriles profesionales para conferencias y ceremonias formales.",
    href: "/servicios/accesorios/senalizacion-alfombras/podiums-atriles/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    tags: ["Acrílico 12mm", "Madera Maple", "LED Integrado", "Presidencial"],
  },
  {
    name: "Backdrops y Señalética",
    price: "Desde $1,500",
    excerpt: "Backdrops step and repeat para photo ops, señalización direccional, letreros de bienvenida, pizarras de menú y sistemas wayfinding para eventos corporativos y sociales.",
    href: "/servicios/accesorios/senalizacion-alfombras/backdrops-senaletica/",
    image: "/images/accesorios/accesorio-evento-03.avif",
    tags: ["Step and Repeat", "Roll-Up 85×200", "Snap Frame", "Wayfinding"],
  },
];

const faqs = [
  { question: "¿Puedo solicitar alfombras en medidas personalizadas?", answer: "Sí. Nuestras alfombras rojas y premium están disponibles en largos estándar de 1, 3, 5, 8, 10 y 15 metros con ancho de 1 metro. Si necesitas una medida especial — por ejemplo, 12 metros de largo o 1.5 metros de ancho — podemos cortarla a la medida exacta de tu venue. Las alfombras personalizadas en colores distintos al rojo (negro, blanco, azul, dorado) también se fabrican en cualquier dimensión. Solo necesitamos confirmación con al menos 5 días de anticipación para medidas fuera de inventario." },
  { question: "¿Cuánto tiempo toma producir una alfombra con logo corporativo?", answer: "Las alfombras con logo impreso o bordado requieren entre 5 y 10 días hábiles de producción, dependiendo de la complejidad del diseño y las dimensiones. Necesitamos tu archivo de logo en formato vectorial (AI, EPS o PDF en alta resolución). Para logos sencillos en una sola tinta, el tiempo es de 5 días hábiles. Diseños multicolor o alfombras de gran formato (más de 5 metros) requieren hasta 10 días. Te enviamos prueba digital para aprobación antes de producir." },
  { question: "¿Cuál es el mínimo de postes separadores para rentar?", answer: "El mínimo de renta es de 4 postes separadores, que incluyen sus cordones o cintas retráctiles. Este mínimo permite crear una fila básica de dos tramos o delimitar un área pequeña. Para red carpets completos recomendamos un mínimo de 8 postes (4 por cada lado de la alfombra). Ofrecemos paquetes de 8, 12, 16 y 20 postes con descuento progresivo. No hay máximo — hemos instalado hasta 60 postes para eventos corporativos de gran formato." },
  { question: "¿Los podiums incluyen micrófono integrado?", answer: "Los podiums se rentan por separado del equipo de audio, pero ofrecemos paquetes combinados con micrófono de cuello de ganso integrado en el podium. El paquete incluye podium de acrílico o madera, micrófono de condensador de cuello de ganso, base flexible, cable XLR y conexión directa al sistema de sonido. Si ya cuentas con equipo de audio propio, el podium incluye orificio estándar para pasar cables de micrófono. Consulta nuestros paquetes con equipo audiovisual completo." },
  { question: "¿Qué opciones de impresión tienen para backdrops step and repeat?", answer: "Ofrecemos tres opciones de impresión para backdrops: sublimación textil (la más popular, sin brillos, calidad fotográfica, reutilizable), vinilo adhesivo sobre estructura rígida (alta durabilidad, ideal para uso repetitivo) y lona impresa con acabado mate o brillante (opción más económica). Las dimensiones estándar son 2.4×2.4 m y 3×2.4 m, pero fabricamos en cualquier medida. Necesitamos tu diseño en alta resolución (300 DPI) o podemos diseñarlo por un costo adicional." },
  { question: "¿Con cuánta anticipación debo reservar señalización y alfombras?", answer: "Para productos de inventario estándar (alfombras rojas, postes cromados, podiums), recomendamos reservar con 1 a 2 semanas de anticipación. Para productos personalizados — alfombras con logo, backdrops impresos, señalética custom — necesitamos mínimo 2 semanas, idealmente 3 semanas para garantizar producción y aprobación de diseño. En temporada alta (noviembre a febrero) sugerimos apartar con 1 mes de anticipación. Atendemos solicitudes urgentes sujetas a disponibilidad con cargo express." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Señalización y Alfombras CDMX",
    description: "Alfombras rojas, postes separadores, podiums ejecutivos y backdrops para bodas, congresos y eventos corporativos. Instalación incluida.",
    url: "/servicios/accesorios/senalizacion-alfombras/",
    priceRange: { min: 300, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Señalización y Alfombras", url: "/servicios/accesorios/senalizacion-alfombras/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Señalización y Alfombras CDMX"
  description="Renta de alfombras rojas, postes separadores, podiums ejecutivos y backdrops para eventos en CDMX. Instalación incluida. Desde $300. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La imagen profesional de tu evento"
    title='Renta de <span class="highlight">Señalización y Alfombras</span> para Eventos en CDMX'
    subtitle="Alfombras rojas premium, postes separadores elegantes, podiums ejecutivos y backdrops de marca. Todo lo que necesitas para dar presencia y dirección visual a tu evento."
    primaryCTA={{ label: "Cotiza tu señalización", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar señalización y alfombras para mi evento` }}
    cards={[
      {
        title: "Señalización profesional que eleva la experiencia de tu evento",
        content: "<strong>Renta de señalización y alfombras para eventos</strong> con el catálogo más completo de CDMX. Alfombras rojas y premium en largos de 1 a 15 metros para entradas VIP, recepciones de gala y bodas elegantes. Postes separadores con cinta de terciopelo y retráctiles en acabados cromado, dorado y negro para control de flujo impecable. Backdrops step and repeat para photo opportunities de marca — cada producto seleccionado para crear una primera impresión inolvidable.",
      },
      {
        title: "Instalación profesional y personalización completa",
        content: "<strong>Servicio integral de señalización</strong> que incluye transporte, instalación y desmontaje. Podiums de acrílico con iluminación LED y mesas presidenciales para conferencias ejecutivas. Señalética direccional, letreros de bienvenida y sistemas wayfinding personalizados con tu identidad de marca. Alfombras con logo corporativo impresas en alta resolución. Nuestro equipo coordina el montaje completo para que cada elemento esté perfectamente posicionado antes de tu evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas dar presencia profesional a tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con la señalización ideal para tu espacio y marca"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de señalización
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Señalización y Alfombras"
        subtitle="Presencia, dirección y elegancia para cada evento"
        description={[
          "Desde alfombras rojas para entradas VIP hasta sistemas de señalética corporativa completos. Contamos con el inventario de señalización para eventos más variado de la Ciudad de México.",
          "Cada producto incluye transporte, instalación profesional y asesoría de diseño. Personalización disponible con tu identidad de marca, colores corporativos y logotipos."
        ]}
      />

      <div class="grid grid--4">
        {SENALIZACION.map((item) => (
          <ProductCard
            name={item.name}
            price={item.price}
            excerpt={item.excerpt}
            href={item.href}
            image={item.image}
            tags={item.tags}
            badge={item.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ALFOMBRAS ROJAS Y PREMIUM — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="alfombras-heading">
    <div class="container">
      <ServiceShowcase
    title="Alfombras Rojas y Premium"
    headingId="alfombras-heading"
    badge="La entrada VIP"
    subtitle="La bienvenida que tus invitados merecen, con alfombras de grado profesional para cada ocasión."
    tags={["1-15 metros", "Colores custom", "Logo corporativo", "Interior/Exterior"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Alfombras"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>alfombras rojas y premium</strong> están disponibles en largos de <strong>1, 3, 5, 8, 10 y 15 metros</strong> con ancho estándar de 1 metro, ideales para red carpets, entradas VIP, pasarelas de boda y recepciones de gala. Fabricadas con fibra de alta densidad que mantiene su color vibrante y textura uniforme durante todo el evento. Disponibles en <strong>rojo clásico, negro elegante, blanco nupcial, azul corporativo y dorado premium</strong> para adaptarse a cualquier temática.</p>
      <p class="showcase__text">También ofrecemos <strong>alfombras con logo corporativo</strong> impresas en sublimación de alta resolución, perfectas para lanzamientos de producto, premiaciones y eventos de marca. Cada alfombra incluye cinta antideslizante en el reverso para uso seguro en interiores y exteriores. Combínalas con nuestra <a href="/servicios/iluminacion/">iluminación arquitectónica</a> para crear entradas espectaculares que tus invitados fotografiarán desde el primer paso.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="18" rx="2" ry="2"/>
              <line x1="2" y1="9" x2="22" y2="9"/>
              <line x1="2" y1="15" x2="22" y2="15"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       POSTES SEPARADORES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="postes-heading">
    <div class="container">
      <ServiceShowcase
    title="Postes Separadores"
    headingId="postes-heading"
    badge="Control de flujo elegante"
    subtitle="Delimita áreas VIP y controla el flujo de invitados con postes de acabado premium."
    tags={["Terciopelo", "Retráctiles", "Cromado/Dorado/Negro", "Cinta custom"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Postes Separadores"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>postes separadores con cinta de terciopelo</strong> son el estándar de elegancia para red carpets, recepciones y áreas exclusivas. Disponibles en acabados <strong>cromado, dorado y negro mate</strong>, cada poste incluye cordón de terciopelo en rojo, negro o dorado. Base de acero con peso integrado que garantiza estabilidad sin necesidad de fijación al piso — ideales para salones, jardines y espacios al aire libre.</p>
      <p class="showcase__text">También contamos con <strong>postes de cinta retráctil</strong> de 2 y 3 metros de extensión, perfectos para filas de registro, control de acceso en congresos y delimitación de zonas en ferias y expos. Los postes retráctiles están disponibles con <strong>cinta personalizada con texto impreso</strong> ("VIP", "Acceso Restringido", nombre de tu marca). Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario de recepción</a> para crear áreas VIP completas con lounge y barra.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="6" y1="4" x2="6" y2="20"/>
              <line x1="18" y1="4" x2="18" y2="20"/>
              <circle cx="6" cy="4" r="2"/>
              <circle cx="18" cy="4" r="2"/>
              <path d="M6 8 C10 6, 14 6, 18 8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PODIUMS Y ATRILES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="podiums-heading">
    <div class="container">
      <ServiceShowcase
    title="Podiums y Atriles"
    headingId="podiums-heading"
    badge="Presencia ejecutiva"
    subtitle="La presencia profesional que tus conferencias y ceremonias merecen."
    tags={["Acrílico LED", "Madera ejecutiva", "Mesas presidenciales", "Bases micrófono"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Podiums"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>podiums de acrílico transparente</strong> son la opción favorita para eventos corporativos de alto nivel: diseño limpio y moderno con <strong>iluminación LED integrada</strong> que resalta tu marca desde el escenario. También ofrecemos <strong>podiums de madera ejecutiva</strong> en acabados nogal, caoba y blanco, ideales para ceremonias formales, graduaciones y eventos gubernamentales. Cada podium incluye repisa para notas, espacio para botella de agua y orificio para cableado de micrófono.</p>
      <p class="showcase__text">Complementa tu montaje con nuestras <strong>mesas presidenciales</strong> para 3 a 8 ponentes, con faldón, mantel ejecutivo, tarjeteros de nombre y bases para micrófono individuales. También contamos con <strong>atriles portátiles y bases de micrófono</strong> de cuello de ganso para podiums y mesas de panel. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> — sonido, pantallas LED y proyección — para producciones ejecutivas de primer nivel.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="2" width="12" height="16" rx="1"/>
              <line x1="9" y1="6" x2="15" y2="6"/>
              <line x1="9" y1="10" x2="15" y2="10"/>
              <line x1="8" y1="18" x2="16" y2="18"/>
              <line x1="7" y1="22" x2="17" y2="22"/>
              <line x1="8" y1="18" x2="7" y2="22"/>
              <line x1="16" y1="18" x2="17" y2="22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BACKDROPS Y SEÑALÉTICA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="backdrops-heading">
    <div class="container">
      <ServiceShowcase
    title="Backdrops y Señalética"
    headingId="backdrops-heading"
    badge="Imagen de marca"
    subtitle="Refuerza tu identidad de marca con backdrops profesionales y señalización integral."
    tags={["Step & Repeat", "Señales direccionales", "Bienvenida", "Wayfinding"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Backdrops"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>backdrops step and repeat</strong> son el centro de atención en cualquier evento: estructura de aluminio portátil con impresión en sublimación textil de alta resolución que reproduce logos y patrones de marca con fidelidad de color exacta. Disponibles en tamaños estándar de <strong>2.4×2.4 m y 3×2.4 m</strong>, o fabricados a medida para escenarios de gran formato. Perfectos para <strong>photo opportunities, premiaciones, lanzamientos de producto y galas corporativas</strong>.</p>
      <p class="showcase__text">Complementa con nuestra <strong>señalética direccional</strong>: letreros de bienvenida personalizados, señales de dirección para estacionamiento, registro, salones y áreas de servicio, pizarras de menú para catering y <strong>sistemas wayfinding completos</strong> con mapas del venue impresos en gran formato. Todo fabricado con materiales premium e impresión de calidad. Ideal para eventos en <a href="/servicios/carpas/">carpas y espacios al aire libre</a> donde la orientación del invitado es fundamental.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="3" x2="9" y2="21"/>
              <line x1="15" y1="3" x2="15" y2="21"/>
              <line x1="3" y1="15" x2="21" y2="15"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo luce nuestra señalización?</h2>
      <Gallery4x4 images={[
        { src: "/images/accesorios/alfombra-roja-red-carpet-evento.avif", alt: "Alfombra roja red carpet evento" },
        { src: "/images/accesorios/calentador-patio-terraza-evento.avif", alt: "Calentador patio terraza evento" },
        { src: "/images/accesorios/manteles-premium-boda-elegante.avif", alt: "Manteles premium boda elegante" },
        { src: "/images/accesorios/planta-luz-generador-evento.avif", alt: "Planta de luz generador evento" },
        { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Silla Tiffany dorada para boda de gala en CDMX" },
        { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas montaje banquete" },
        { src: "/images/mobiliario/lounge-moderno-terciopelo-evento-premium.avif", alt: "Sala lounge moderno terciopelo evento premium" },
        { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Barra de bebidas bartender madera para evento" },
      ]} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar señalización y alfombras?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por evento (+IVA). Incluye entrega y montaje en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$1,200",
          priceNote: "por evento",
          description: "Señalización básica y alfombra.",
          features: [
            { text: "Alfombra roja 10m", included: true },
            { text: "4 postes separadores", included: true },
            { text: "Señalización básica", included: true },
            { text: "Backdrop", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Estándar",
          badge: "Más popular",
          highlight: true,
          price: "$2,500",
          priceNote: "por evento",
          description: "Red carpet completo para eventos.",
          features: [
            { text: "Alfombra premium 15m", included: true },
            { text: "8 postes con cinta", included: true },
