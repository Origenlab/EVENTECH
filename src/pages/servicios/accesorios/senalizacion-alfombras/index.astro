---
/**
 * ─── EVENTECH.MX — Renta de Señalización y Alfombras para Eventos (Hub L4, molde hm- 2026) ───
 * Alfombras y Red Carpet · Backdrops y Señalética · Podiums y Atriles · Postes Separadores — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro y carpas/estructurales/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/accesorios — alfombra-roja-red-carpet-evento real; accesorio-evento-0X genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "alfombras-premium",
    name: "Alfombras y Red Carpet",
    badge: "La entrada VIP",
    excerpt: "Alfombra roja de 1 a 15 m en anchos estándar y personalizados. Colores custom, alfombra con logo corporativo y acabado premium para recepciones VIP, bodas y galas.",
    href: "/servicios/accesorios/senalizacion-alfombras/alfombras-premium/",
    image: "/images/accesorios/alfombra-roja-red-carpet-evento.avif",
    specs: ["1 a 15 m", "Rojo o custom", "Logo corporativo", "Corte a medida"],
  },
  {
    id: "backdrops-senaletica",
    name: "Backdrops y Señalética",
    badge: "Photo op de marca",
    excerpt: "Backdrops step & repeat para photo ops, señalización direccional, letreros de bienvenida y wayfinding. Impresión por sublimación textil de calidad fotográfica.",
    href: "/servicios/accesorios/senalizacion-alfombras/backdrops-senaletica/",
    image: "/images/accesorios/accesorio-evento-03.avif",
    specs: ["Step & repeat", "Sublimación textil", "2.4×2.4 a medida", "Wayfinding"],
  },
  {
    id: "podiums-atriles",
    name: "Podiums y Atriles",
    badge: "Presencia formal",
    excerpt: "Podiums de acrílico transparente y madera ejecutiva con LED integrado, atriles profesionales y mesas presidenciales para conferencias, ruedas de prensa y ceremonias.",
    href: "/servicios/accesorios/senalizacion-alfombras/podiums-atriles/",
    image: "/images/accesorios/accesorio-evento-02.avif",
    specs: ["Acrílico 12 mm", "Madera maple", "LED integrado", "Cuello de ganso"],
  },
  {
    id: "postes-separadores",
    name: "Postes Separadores",
    badge: "Control de flujo",
    excerpt: "Postes con cinta de terciopelo y retráctiles en acabado cromado, dorado y negro. Control de flujo elegante para entradas VIP, red carpets y áreas exclusivas.",
    href: "/servicios/accesorios/senalizacion-alfombras/postes-separadores/",
    image: "/images/accesorios/accesorio-evento-01.avif",
    specs: ["Cromado / dorado / negro", "Terciopelo o retráctil", "Mínimo 4 postes", "Base 9 kg"],
  },
];

const whyFeatures = [
  {
    title: "Alfombra cortada a la medida exacta del venue",
    body: "No entregamos rollos genéricos que sobran o quedan cortos. Medimos el recorrido real de la entrada y cortamos la alfombra al largo exacto — 8, 12 o 15 metros — en el ancho que pida el espacio. La entrada se ve intencional, no improvisada, sin dobleces ni tramos que no cuadran.",
  },
  {
    title: "Logo y arte impresos con calidad fotográfica",
    body: "Alfombra con logo, backdrop step & repeat y señalética se imprimen por sublimación textil a partir de tu archivo vectorial — sin pixeleado, sin brillos, con color fiel a tu identidad. Enviamos prueba digital para aprobación antes de producir: lo que apruebas es lo que se instala.",
  },
  {
    title: "Red carpet completo, coordinado como un set",
    body: "Alfombra, postes separadores, cordón de terciopelo y backdrop de fotos se cotizan y montan como un solo conjunto visual. Los acabados combinan — cromado con cromado, dorado con dorado — para que la entrada se vea diseñada, no armada con piezas sueltas de distintos proveedores.",
  },
  {
    title: "Acabados premium, revisados pieza por pieza",
    body: "Postes sin rayones, acrílicos sin opacar, terciopelo sin desgaste. Cada pieza se revisa y limpia antes de salir de bodega porque en la entrada del evento todo se ve de cerca y con flash. La primera impresión del venue no admite equipo maltratado.",
  },
  {
    title: "Instalación segura y antiderrapante",
    body: "La alfombra se fija con cinta antiderrapante de doble cara y remates en las orillas para que nadie tropiece ni se levante con el paso de los invitados. Postes con base de contrapeso estable y señalética anclada. La entrada luce impecable y además es segura durante todo el evento.",
  },
  {
    title: "Todo en la misma logística del evento",
    body: "Alfombras, señalética, podiums y postes llegan en el mismo camión que carpas, mobiliario e iluminación — una entrega, un equipo de montaje, un responsable. Sin coordinar un proveedor aparte solo para la entrada y arriesgar que llegue tarde el día del evento.",
  },
];

const steps = [
  { n: 1, t: "Brief, medidas y diseño", p: "Definimos el recorrido de la entrada, las medidas de alfombra, el tipo de señalética y si lleva logo o arte. Si necesitas diseño, lo preparamos. En menos de 24 horas te enviamos propuesta con el conjunto ideal para tu evento." },
  { n: 2, t: "Aprobación de arte y aparto", p: "Para piezas personalizadas (alfombra con logo, backdrop, señalética custom) enviamos prueba digital para tu aprobación antes de producir. Con el anticipo apartamos el material y la fecha. Coordinamos con tu wedding planner o el venue si aplica." },
  { n: 3, t: "Producción e instalación", p: "Producimos las piezas impresas y preparamos el inventario estándar. El día del evento instalamos con anticipación: fijamos la alfombra con cinta antiderrapante, montamos postes, backdrop y señalética, y verificamos que todo quede alineado antes de abrir puertas." },
  { n: 4, t: "Evento y retiro", p: "Durante el evento la entrada luce impecable y segura. Al finalizar, nuestro equipo desmonta y retira todo. La entrega, la instalación y el retiro están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Puedo solicitar alfombras en medidas personalizadas?", answer: "Sí. Nuestras alfombras rojas y premium están disponibles en largos estándar de 1, 3, 5, 8, 10 y 15 metros con ancho de 1 metro. Si necesitas una medida especial — por ejemplo, 12 metros de largo o 1.5 metros de ancho — podemos cortarla a la medida exacta de tu venue. Las alfombras personalizadas en colores distintos al rojo (negro, blanco, azul, dorado) también se fabrican en cualquier dimensión. Solo necesitamos confirmación con al menos 5 días de anticipación para medidas fuera de inventario." },
  { question: "¿Cuánto tiempo toma producir una alfombra con logo corporativo?", answer: "Las alfombras con logo impreso o bordado requieren entre 5 y 10 días hábiles de producción, dependiendo de la complejidad del diseño y las dimensiones. Necesitamos tu archivo de logo en formato vectorial (AI, EPS o PDF en alta resolución). Para logos sencillos en una sola tinta, el tiempo es de 5 días hábiles. Diseños multicolor o alfombras de gran formato (más de 5 metros) requieren hasta 10 días. Te enviamos prueba digital para aprobación antes de producir." },
  { question: "¿Cuál es el mínimo de postes separadores para rentar?", answer: "El mínimo de renta es de 4 postes separadores, que incluyen sus cordones o cintas retráctiles. Este mínimo permite crear una fila básica de dos tramos o delimitar un área pequeña. Para red carpets completos recomendamos un mínimo de 8 postes (4 por cada lado de la alfombra). Ofrecemos paquetes de 8, 12, 16 y 20 postes con descuento progresivo. No hay máximo — hemos instalado hasta 60 postes para eventos corporativos de gran formato." },
  { question: "¿Los podiums incluyen micrófono integrado?", answer: "Los podiums se rentan por separado del equipo de audio, pero ofrecemos paquetes combinados con micrófono de cuello de ganso integrado en el podium. El paquete incluye podium de acrílico o madera, micrófono de condensador de cuello de ganso, base flexible, cable XLR y conexión directa al sistema de sonido. Si ya cuentas con equipo de audio propio, el podium incluye orificio estándar para pasar cables de micrófono. Consulta nuestros paquetes con equipo audiovisual completo." },
  { question: "¿Qué opciones de impresión tienen para backdrops step and repeat?", answer: "Ofrecemos tres opciones de impresión para backdrops: sublimación textil (la más popular, sin brillos, calidad fotográfica, reutilizable), vinilo adhesivo sobre estructura rígida (alta durabilidad, ideal para uso repetitivo) y lona impresa con acabado mate o brillante (opción más económica). Las dimensiones estándar son 2.4×2.4 m y 3×2.4 m, pero fabricamos en cualquier medida. Necesitamos tu diseño en alta resolución (300 DPI) o podemos diseñarlo por un costo adicional." },
  { question: "¿Con cuánta anticipación debo reservar señalización y alfombras?", answer: "Para productos de inventario estándar (alfombras rojas, postes cromados, podiums), recomendamos reservar con 1 a 2 semanas de anticipación. Para productos personalizados — alfombras con logo, backdrops impresos, señalética custom — necesitamos mínimo 2 semanas, idealmente 3 semanas para garantizar producción y aprobación de diseño. En temporada alta (noviembre a febrero) sugerimos apartar con 1 mes de anticipación. Atendemos solicitudes urgentes sujetas a disponibilidad con cargo express." },
  { question: "¿Cuánto cuesta rentar una alfombra roja o red carpet para un evento?", answer: "El precio depende de la medida, el acabado y si lleva logo. Como referencia, una alfombra roja estándar arranca desde $800 y un red carpet completo (alfombra + postes separadores + cordón) desde alrededor de $2,500 para una entrada de tamaño medio. Las alfombras con logo impreso, los backdrops step & repeat y los conjuntos de gran formato se cotizan según diseño y dimensiones. Para darte un precio exacto necesitamos las medidas de la entrada y si requieres personalización; te enviamos la cotización el mismo día por WhatsApp." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Señalización y Alfombras para Eventos en CDMX",
    description: "Renta de alfombra roja, red carpet, backdrops, señalética, podiums y postes separadores para eventos en CDMX. Producción de logo e instalación incluidas.",
    url: "/servicios/accesorios/senalizacion-alfombras/",
    priceRange: { min: 300, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Accesorios", url: "/servicios/accesorios/" },
    { name: "Señalización y Alfombras", url: "/servicios/accesorios/senalizacion-alfombras/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Accesorios", href: "/servicios/accesorios/" },
  { label: "Señalización y Alfombras" },
];
---

<PageLayout
  title="Renta de Señalización y Alfombras para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/accesorios/alfombra-roja-red-carpet-evento.avif"
  description="Renta de alfombra roja, red carpet, backdrops, señalética, podiums y postes separadores para eventos en CDMX. Producción de logo incluida. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="senalizacion-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Señalización y alfombras · CDMX y ZMVM</p>
            <h1 id="senalizacion-hero-heading">
              La entrada de tu evento, <em>de nivel alfombra roja</em>
            </h1>
            <p class="hm-hero__lead">
              Alfombra roja a la medida, backdrops step & repeat, señalética, podiums y postes
              separadores. Producción de logo y arte incluida, con instalación antiderrapante
              y retiro dentro de CDMX.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20señalización%20y%20alfombras%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar señalización y alfombras
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>alfombras rojas, red carpet y señalización para eventos</strong>
              en CDMX y zona metropolitana: alfombra cortada a la medida, <strong>backdrops step &
              repeat</strong> con logo, señalética direccional, podiums de acrílico y madera, y
              postes separadores con cordón de terciopelo. Todo con producción de arte propia e
              instalación antiderrapante incluida.
            </p>
            <p>
              Con <strong>más de 500 eventos</strong> montados en CDMX, sabemos que la entrada es
              lo primero que ven los invitados y la cámara: por eso coordinamos alfombra, postes y
              backdrop como un solo conjunto visual. Para una producción integral súmale nuestro
              <a href="/servicios/mobiliario/">mobiliario</a>,
              <a href="/servicios/iluminacion/">iluminación</a> y demás
              <a href="/servicios/accesorios/">accesorios</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de señalización y alfombras disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20señalización%20y%20alfombras%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La primera impresión del evento</p>
            <h2 id="catalogo-heading">¿Qué necesita la entrada de tu evento?</h2>
            <p class="hm__head-sub">De la alfombra roja al backdrop de fotos — cada pieza que hace que la llegada se sienta de otro nivel.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La entrada es el primer contacto del invitado con tu evento y el fondo de las
              primeras fotos. Una alfombra bien puesta, un backdrop con la marca y postes
              alineados cambian por completo la percepción del espacio antes de que empiece
              cualquier otra cosa.
            </p>
            <p>
              Alfombra y red carpet para la llegada. Backdrops y señalética para la marca y el
              flujo. Podiums y atriles para los momentos formales. Postes para el control VIP.
              Una sola empresa para toda la imagen de entrada de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada pieza, a fondo</p>
            <h2 id="detalle-heading">Las 4 piezas de la entrada — en detalle</h2>
            <p class="hm__head-sub">Medidas, materiales, acabados y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de una entrada impecable hay decisiones concretas: el largo de la alfombra
              que cuadra con el recorrido, el tipo de impresión que hace que el logo se vea
              nítido, el acabado de los postes que combina con la estética y la señalética que
              guía sin estorbar.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y armar un conjunto que se
              ve diseñado. A continuación, lo que realmente importa de cada pieza.
            </p>
          </div>
        </div>

        <!-- ALFOMBRAS Y RED CARPET -->
        <article class="hm-feat" aria-labelledby="feat-alfombras">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Alfombras y Red Carpet</p>
            <h3 class="hm-feat__title" id="feat-alfombras">Alfombra roja a la medida para una llegada de nivel gala</h3>
            <p class="hm-feat__lead">La pieza que marca el tono desde el primer paso. Una alfombra bien cortada y bien fijada convierte una entrada cualquiera en un momento de llegada.</p>
            <p>
              Alfombra roja de <strong>1 a 15 metros</strong> en anchos estándar y personalizados,
              con opción de <strong>colores custom</strong> (negro, blanco, azul, dorado) y
              <strong>logo corporativo impreso o bordado</strong>. Se corta a la medida exacta del
              recorrido de tu venue y se fija con cinta antiderrapante de doble cara con remate en
              orillas.
            </p>
            <p>
              Ideal para <strong>bodas, galas, recepciones VIP, alfombras corporativas y premieres</strong>.
              Combínala con postes separadores y backdrop para un red carpet completo, y súmale
              <a href="/servicios/iluminacion/">iluminación</a> de acento para que la entrada
              destaque en las fotos.
            </p>
            <ul class="hm-feat__stats">
              {["1 a 15 m", "Rojo o custom", "Logo corporativo", "Corte a medida", "Antiderrapante"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/accesorios/senalizacion-alfombras/alfombras-premium/">
              Ver Alfombras y Red Carpet
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/accesorios/alfombra-roja-red-carpet-evento.avif" alt="Alfombra roja y red carpet para entrada de evento en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/accesorios/accesorio-evento-04.avif" alt="Red carpet con postes separadores para recepción VIP" loading="lazy" decoding="async" />
              <img src="/images/accesorios/accesorio-evento-01.avif" alt="Alfombra roja instalada en entrada de evento social" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- BACKDROPS Y SEÑALÉTICA -->
        <article class="hm-feat" aria-labelledby="feat-backdrops">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Backdrops y Señalética</p>
            <h3 class="hm-feat__title" id="feat-backdrops">Backdrops step & repeat y señalización con tu marca impecable</h3>
            <p class="hm-feat__lead">El fondo de cada foto y la guía de cada invitado. Un backdrop bien impreso pone tu marca en todas las fotos; la señalética hace que nadie pregunte por dónde ir.</p>
            <p>
              <strong>Backdrops step & repeat</strong> para photo ops, <strong>señalización
              direccional</strong>, letreros de bienvenida, pizarras de menú y sistemas
              <strong>wayfinding</strong>. Impresión por <strong>sublimación textil</strong> de
              calidad fotográfica —sin brillos, reutilizable— o vinilo rígido y lona según el uso.
            </p>
            <p>
              Perfectos para <strong>eventos corporativos, activaciones de marca, ruedas de prensa,
              bodas y XV años</strong>. Enviamos prueba digital para aprobación antes de producir.
