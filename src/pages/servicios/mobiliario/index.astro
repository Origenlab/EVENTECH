---
/**
 * ─── Mobiliario — L3 Category Page (rediseño 2026) ───
 * Homologado al sistema Home-2026: importa home-2026.css, usa clases `hm-`.
 * Hero navy + sv-breadcrumb inline, hm-cat-grid, hm-feat zig-zag, stats,
 * hm-why navy, FAQ + formulario WhatsApp, CTA final.
 *
 * Keyword primaria: "renta de mobiliario para eventos CDMX"
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, FEATURES } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

/* ── Subcategorías ─────────────────────────────────────────────────── */
const SUB_SERVICES = [
  {
    id: "sillas",
    name: "Sillas para Eventos",
    badge: "Lo más solicitado",
    excerpt: "Tiffany desde $15 MXN, Chiavari, Ghost y Crossback. Más de 12 modelos con cojín incluido.",
    href: "/servicios/mobiliario/sillas/",
    image: "/images/mobiliario/sillas-chiavari-ghost-combinacion-estudio.avif",
    subcategories: [
      { name: "Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
      { name: "Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
      { name: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
      { name: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
    ],
  },
  {
    id: "mesas",
    name: "Mesas para Eventos",
    badge: "Múltiples formatos",
    excerpt: "Redondas 150/180 cm, imperiales 240 cm, cocktail y tablones. Layout incluido.",
    href: "/servicios/mobiliario/mesas/",
    image: "/images/mobiliario/mesa-redonda-overhead-chargers-boda.avif",
    subcategories: [
      { name: "Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
      { name: "Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
      { name: "Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
      { name: "Tablones", href: "/servicios/mobiliario/mesas/tablones/" },
    ],
  },
  {
    id: "salas-lounge",
    name: "Salas Lounge",
    badge: "VIP en 45 minutos",
    excerpt: "Sets completos en Moderno, Vintage, Boho y Elegante. Montaje express.",
    href: "/servicios/mobiliario/salas-lounge/",
    image: "/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif",
    subcategories: [
      { name: "Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
      { name: "Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
      { name: "Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
      { name: "Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
    ],
  },
  {
    id: "barras",
    name: "Barras y Complementos",
    badge: "Montaje incluido",
    excerpt: "Barras en madera, acrílico iluminado o acero. Candy bar, periqueras y accesorios.",
    href: "/servicios/mobiliario/barras/",
    image: "/images/mobiliario/barra-hexagonal-bartender-botanical.avif",
    subcategories: [
      { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
      { name: "Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
      { name: "Mesas de Postres", href: "/servicios/mobiliario/barras/postres/" },
      { name: "Accesorios", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
    ],
  },
];

/* ── FAQs ──────────────────────────────────────────────────────────── */
const faqs = [
  {
    question: "¿Qué tipos de sillas ofrecen para renta?",
    answer: "Tenemos Tiffany en cuatro acabados (dorada, plateada, blanca y transparente), Chiavari de aluminio, Ghost de acrílico, Crossback de madera, Avant Garde y plegables. Las Tiffany arrancan desde $15 MXN por pieza con cojín incluido. Si no estás seguro qué modelo va mejor con tu venue, mándanos fotos del salón por WhatsApp y te decimos al momento.",
  },
  {
    question: "¿Cuántas mesas necesito para mi evento?",
    answer: "Depende del tipo. Mesa redonda de 150 cm = 8 invitados; de 180 cm = 10. Mesa imperial de 240 cm = 10 personas con espacio holgado. Para bodas con buffet se agregan 2 o 3 tablones extra. Mándanos tu número de invitados y el plano del venue — te hacemos el layout en el día.",
  },
  {
    question: "¿Las salas lounge se pueden personalizar?",
    answer: "Sí, y es algo que hacemos seguido. Los sets prediseñados (Moderno, Vintage, Boho, Elegante) cubren el 90% de los eventos, pero si quieres mezclar piezas — por ejemplo, el sofá Chesterfield Vintage con los sillones de ratán Boho — lo armamos sin problema. También tenemos opciones de tapicería en colores específicos si tu evento tiene paleta definida.",
  },
  {
    question: "¿El montaje está incluido en el precio de renta?",
    answer: "Sí, dentro de las 16 alcaldías de CDMX el montaje y la recolección no tienen costo extra. Nuestro equipo llega antes del evento, instala todo según el layout acordado y regresa a recoger al terminar — tú no tienes que hacer nada. Para Naucalpan, Tlalnepantla o Ecatepec hay cargo por traslado que detallamos en la cotización desde el principio.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar el mobiliario?",
    answer: "Para eventos de hasta 100 personas, 2 semanas es suficiente casi siempre. Para eventos grandes — 200 invitados o más — recomendamos apartar con 4 a 6 semanas. En temporada alta (noviembre a febrero) el inventario de sillas Tiffany doradas y salas lounge se agota rápido. Con un anticipo del 30% ya queda apartado.",
  },
  {
    question: "¿Puedo ver el mobiliario antes de rentarlo?",
    answer: "Claro. Tenemos showroom en CDMX donde puedes ver las piezas en persona — útil cuando estás entre dos modelos de silla y quieres ver el acabado real. También mandamos catálogo digital con medidas exactas y fotos de montajes reales. Agenda tu visita por WhatsApp y confirmamos en menos de una hora.",
  },
];

/* ── Por qué elegirnos (6 features) ────────────────────────────────── */
const mobFeatures = [
  { name: "Inventario propio y verificado", excerpt: "Cada pieza revisada y retapizada antes de cada montaje. Sin sorpresas el día del evento." },
  { name: "Montaje profesional sin costo extra", excerpt: "Entregamos, instalamos y recogemos en las 16 alcaldías sin cargos ocultos." },
  { name: "Layout incluido en la cotización", excerpt: "Calculamos disposición de mesas, aforos y flujos de circulación para que el salón respire." },
  { name: "Cotización el mismo día", excerpt: "Respuesta por WhatsApp en menos de 30 minutos durante horario de atención." },
  { name: "Showroom disponible en CDMX", excerpt: "Ven a ver el mobiliario en persona antes de confirmar. Sin cita previa requerida." },
  { name: "+500 eventos realizados", excerpt: "Bodas, XV años, corporativos y celebraciones en haciendas, jardines y salones de lujo." },
];

/* ── Proceso (4 pasos) ──────────────────────────────────────────────── */
const steps = [
  { n: 1, t: "Cotiza", p: "Cuéntanos tu evento, venue y número de invitados. Respondemos con precio el mismo día." },
  { n: 2, t: "Confirmamos", p: "Diseñamos el layout de mesas, ajustamos el inventario y apartamos la fecha con anticipo del 30%." },
  { n: 3, t: "Montamos", p: "Llegamos antes del evento, instalamos todo según el plano aprobado y dejamos el venue listo." },
  { n: 4, t: "Recogemos", p: "Al terminar, nuestro equipo desmonta y retira el equipo. Tú solo disfrutas." },
];

/* ── JSON-LD ────────────────────────────────────────────────────────── */
const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mobiliario para Eventos en CDMX",
    description: "Sillas Tiffany, mesas, salas lounge y barras para bodas, XV años y corporativos. Entrega y montaje incluido en 16 alcaldías.",
    url: "/servicios/mobiliario/",
    priceRange: { min: 15, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario" },
];
---

<PageLayout
  title="Renta de Mobiliario para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/mobiliario/DUAL-tiffany-boda-2.avif"
  description="Renta de mobiliario para eventos en CDMX: sillas Tiffany y Chiavari, mesas, salas lounge y barras. Entrega, montaje y layout incluidos. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- ══════════════════════════════════════════════════════════════
         HERO
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm-hero" aria-labelledby="mob-hero-heading">
      <div class="hm__wrap hm-hero__wrap">


        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">
              Renta de mobiliario · CDMX y Estado de México
            </p>
            <h1 id="mob-hero-heading">
              Sillas, mesas, lounges y barras para <em>cualquier evento</em>
            </h1>
            <p class="hm-hero__lead">
              Tiffany desde $15 MXN, mesas en todos los formatos, salas lounge y barras de diseño —
              entrega, montaje y layout incluidos en las 16 alcaldías.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mobiliario%20para%20mi%20evento`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z" />
                </svg>
                Cotizar mobiliario
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5v14M5 12l7 7 7-7" />
                </svg>
              </a>
            </div>
          </div>

          <div class="hm-hero__seo">
            <p>
              <strong>Más de 500 eventos equipados en CDMX</strong> con mobiliario propio y verificado.
              Sillas Tiffany doradas, plateadas, blancas y transparentes; Chiavari de aluminio;
              Ghost y Crossback — más de 12 modelos disponibles con cojín incluido desde $15 MXN por pieza.
            </p>
            <p>
              Mesas redondas de 150 y 180 cm, imperiales de 240 cm, cocktail y tablones.
              Salas lounge en cuatro estilos (Moderno, Vintage, Boho, Elegante) y barras de bebidas
              en madera, acrílico iluminado o acero. Hemos montado en Hacienda Tlalpan,
              Salón Jardín Pedregal y salones del WTC CDMX. <strong>Entrega, montaje y layout sin costo
              adicional dentro de las 16 alcaldías.</strong>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         NAV DE SUBCATEGORÍAS
         ══════════════════════════════════════════════════════════════ -->
    <nav class="hm-menu" aria-label="Subcategorías de mobiliario">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li>
            <a class="hm-menu__item" href={s.href}>{s.name}</a>
          </li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mobiliario%20para%20mi%20evento`}
            target="_blank"
            rel="noopener noreferrer"
          >
            Cotizar ahora
          </a>
        </li>
      </ul>
    </nav>

    <!-- ══════════════════════════════════════════════════════════════
         CATÁLOGO — 4 subcategorías
         ══════════════════════════════════════════════════════════════ -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Todo en un solo proveedor</p>
            <h2 id="catalogo-heading">¿Qué mobiliario puedes rentar?</h2>
            <p class="hm__head-sub">4 categorías, inventario propio, montaje incluido.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Manejamos cada tipo de mobiliario que un evento requiere bajo un mismo contrato:
              sillas en más de 12 modelos, mesas en todos los formatos, salas lounge modulares y
              barras de diseño. Inventario propio, revisado pieza a pieza antes de cada montaje.
            </p>
            <p>
              Eso elimina la logística de coordinar múltiples proveedores. Un solo pedido, un solo
              equipo de montaje y un responsable que da seguimiento desde la cotización hasta que
              el último invitado se va. Más de 500 eventos en CDMX nos respaldan.
            </p>
          </div>
        </div>

        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img
                  class="hm-cat__img"
                  src={s.image}
                  alt={`Renta de ${s.name.toLowerCase()} para eventos en CDMX`}
                  loading="lazy"
                  decoding="async"
                />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18l6-6-6-6" />
                        </svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver todo en {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         MÓDULOS DESTACADOS — Zig-zag por subcategoría
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada categoría, a fondo</p>
            <h2 id="detalle-heading">Mobiliario en detalle</h2>
            <p class="hm__head-sub">Especificaciones, modelos y lo que incluye cada renta.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada categoría hay décadas de experiencia seleccionando el mobiliario correcto
              para cada tipo de evento y venue. Conoce en detalle qué rentamos, cómo lo instalamos
              y por qué concentrar todo en un solo proveedor simplifica toda la logística.
            </p>
            <p>
              Cada módulo incluye los modelos disponibles, casos de uso más frecuentes y un enlace
              directo a la subcategoría para que puedas explorar y cotizar sin dar vueltas.
            </p>
          </div>
        </div>

        <!-- ── Sillas ── -->
        <article class="hm-feat" aria-labelledby="feat-sillas">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Sillas para Eventos</p>
            <h3 class="hm-feat__title" id="feat-sillas">
              Más de 12 modelos de silla — para cada estilo de evento
            </h3>
            <p class="hm-feat__lead">
              La silla define el tono del montaje antes de que el invitado se siente. Tiffany dorada para bodas de gala; Crossback de madera para haciendas; Ghost acrílico para espacios modernos.
            </p>
            <p>
              Las <strong>sillas Tiffany</strong> van desde $15 MXN en acabado dorado, plateado, blanco
              y transparente — las más solicitadas en bodas en Salón Pedregal, Hacienda Tlalpan y
              salones del sur de la ciudad. Las <strong>sillas Chiavari</strong> de aluminio son
              preferidas cuando el venue tiene escaleras o acceso complicado por su peso ligero.
            </p>
            <p>
              Para bodas rústicas en haciendas y jardines, las <strong>sillas Crossback</strong> de
              madera natural son la elección clásica. Las <strong>sillas Ghost</strong> en acrílico
              transparente funcionan muy bien en eventos modernos donde quieres que la decoración
              sea el protagonista. Todas incluyen <strong>cojín acolchado</strong> en el color
              de tu elección. Complementa con nuestra
              <a href="/servicios/iluminacion/">iluminación arquitectónica</a> para resaltar cada detalle.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
                { name: "Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
                { name: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
                { name: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
              ].map((sc) => (
                <li>
                  <a href={sc.href}>{sc.name}</a>
                </li>
              ))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/mobiliario/sillas/">
              Ver todas las sillas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img
              class="hm-feat__g3-main"
              src="/images/mobiliario/sillas-chiavari-doradas-boda-lujo.avif"
              alt="Sillas Chiavari doradas en salón de lujo para bodas y eventos CDMX"
              loading="lazy"
              decoding="async"
            />
            <div class="hm-feat__g3-thumbs">
              <img
                src="/images/mobiliario/chiavari-jardin-noche-guirnaldas-exterior.avif"
                alt="Sillas Chiavari en jardín nocturno con guirnaldas de luz"
                loading="lazy"
                decoding="async"
              />
              <img
                src="/images/mobiliario/chiavari-mesas-patio-arcos-iluminado.avif"
                alt="Mesas y sillas Chiavari en patio con arcos iluminados"
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </article>

        <!-- ── Mesas ── -->
        <article class="hm-feat" aria-labelledby="feat-mesas">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Mesas para Eventos</p>
            <h3 class="hm-feat__title" id="feat-mesas">
              Redondas, imperiales, cocktail y tablones — con layout incluido
            </h3>
            <p class="hm-feat__lead">
              La distribución de mesas determina cómo fluye el evento. Te entregamos el layout calculado para tu aforo y venue, sin que tengas que hacer nada.
            </p>
            <p>
              Las <strong>mesas redondas de 150 cm</strong> son las más rentadas para bodas y XV años —
              caben 8 invitados con vajilla y centros de mesa. Las de <strong>180 cm</strong> aguantan
              hasta 10 personas y se usan en salones con techos altos, como Salón Jardín Pedregal o
              eventos en el WTC. Las <strong>mesas imperiales de 240 cm</strong> arman banquetes
              lineales con un impacto visual enorme.
            </p>
            <p>
              Para recepciones de cóctel, las <strong>periqueras de 110 cm</strong> funcionan sin
              sillas o con bancos altos — perfectas para la hora de bienvenida. Los
              <strong>tablones plegables</strong> resuelven buffets, mesas de registro y candy bars.
              Incluimos <strong>manteles y fundas opcionales</strong> en más de 20 colores. Coordina con nuestro equipo de <a href="/servicios/catering/">catering y barras</a> si necesitas también estaciones de servicio o candy bar sobre esas mesas.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Redondas 150 cm", href: "/servicios/mobiliario/mesas/redondas/" },
                { name: "Redondas 180 cm", href: "/servicios/mobiliario/mesas/redondas/" },
                { name: "Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
                { name: "Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
              ].map((sc) => (
                <li>
                  <a href={sc.href}>{sc.name}</a>
                </li>
              ))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/mobiliario/mesas/">
              Ver todas las mesas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>
