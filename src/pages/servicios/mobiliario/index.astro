---
/**
 * ─── Mobiliario Category Page ───
 * Página de categoría: Renta de Mobiliario para Eventos en CDMX.
 * Sigue el layout de categoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const SUB_SERVICES = [
  {
    name: "Sillas para Eventos",
    excerpt: "Sillas Tiffany, Chiavari, Ghost, Crossback y plegables. La silla perfecta para cada estilo y presupuesto.",
    cta: "Sillas",
    href: "#sillas-heading",
    icon: "chair",
  },
  {
    name: "Mesas para Eventos",
    excerpt: "Mesas redondas, rectangulares, cocktail y tablones. Configuraciones flexibles para cualquier número de invitados.",
    cta: "Mesas",
    href: "#mesas-heading",
    icon: "layers",
  },
  {
    name: "Salas Lounge",
    excerpt: "Sets completos en estilos Moderno, Vintage, Boho y Elegante. Crea espacios de conversación únicos en tu evento.",
    cta: "Salas Lounge",
    href: "#salas-heading",
    icon: "package",
  },
  {
    name: "Barras y Complementos",
    excerpt: "Barras de bebidas, periqueras, mesas de postres y accesorios decorativos. Todo para complementar tu montaje.",
    cta: "Barras",
    href: "#barras-heading",
    icon: "utensils",
  },
];

const faqs = [
  { question: "¿Qué tipos de sillas ofrecen para renta?", answer: "Contamos con sillas Tiffany (dorada, plateada, blanca y transparente), Chiavari, Ghost, Crossback, Avant Garde, plegables de madera y acrílicas. Cada modelo está disponible en múltiples colores y acabados para adaptarse a tu evento." },
  { question: "¿Cuántas mesas necesito para mi evento?", answer: "La regla general es 1 mesa redonda (150 cm) por cada 8-10 invitados, o 1 mesa rectangular (240 cm) por cada 8 invitados. Nuestro equipo te ayuda a calcular la cantidad exacta según el layout de tu venue y el número de asistentes." },
  { question: "¿Las salas lounge se pueden personalizar?", answer: "Sí. Nuestras salas lounge vienen en sets prediseñados (Moderno, Vintage, Boho, Elegante), pero puedes combinar piezas individuales para crear tu configuración ideal. También ofrecemos opciones de color en tapicería y accesorios complementarios." },
  { question: "¿El montaje está incluido en el precio de renta?", answer: "Sí, todos nuestros paquetes de mobiliario incluyen entrega, montaje profesional y recolección sin costo adicional dentro de CDMX. Para ubicaciones en Zona Metropolitana, el costo de envío se detalla en tu cotización." },
  { question: "¿Con cuánta anticipación debo reservar el mobiliario?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero). Para eventos grandes (+200 invitados), lo ideal es apartar con 1 a 2 meses de anticipación para garantizar disponibilidad." },
  { question: "¿Puedo ver el mobiliario antes de rentarlo?", answer: "Por supuesto. Puedes agendar una visita a nuestro showroom en CDMX para conocer las piezas en persona. También enviamos un catálogo digital con fotos de alta resolución y especificaciones de cada modelo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mobiliario para Eventos en CDMX",
    description: "Sillas Tiffany, mesas, salas lounge y barras para bodas, XV años y corporativos. Entrega y montaje incluido.",
    url: "/servicios/mobiliario/",
    priceRange: { min: 15, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mobiliario para Eventos en CDMX"
  description="Renta de sillas Tiffany, mesas, salas lounge y barras para eventos en CDMX. Entrega y montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 500 eventos realizados"
    title='Renta de <span class="highlight">Mobiliario para Eventos</span> en CDMX'
    subtitle="Sillas Tiffany, mesas, salas lounge y barras personalizadas. Transforma tu evento con mobiliario de primera calidad. Entrega, montaje y asesoría incluidos."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mobiliario para mi evento` }}
    cards={[
      {
        title: "Mobiliario premium que transforma tu evento",
        content: "<strong>Renta de mobiliario para eventos</strong> con la colección más completa de CDMX. Sillas Tiffany en acabado dorado, plateado y transparente, mesas redondas y rectangulares en todos los tamaños, salas lounge en estilos Moderno, Vintage, Boho y Elegante, más barras de bebidas y complementos decorativos. Cada pieza es seleccionada por su calidad, durabilidad y estética impecable — solo trabajamos con proveedores certificados que garantizan acabados de primera en cada evento.",
      },
      {
        title: "Entrega, montaje y asesoría incluidos",
        content: "<strong>Servicio integral de mobiliario</strong> que cubre cada detalle logístico. Nuestro equipo profesional realiza la entrega puntual en tu venue, el montaje cuidadoso de cada pieza según el layout aprobado y la recolección al finalizar tu celebración. Incluimos asesoría personalizada para calcular cantidades exactas, sugerir combinaciones de estilos y optimizar la distribución del espacio para que cada invitado disfrute la máxima comodidad.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para transformar tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con el mobiliario ideal para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Mobiliario"
        subtitle="El mobiliario que tu evento merece"
        description={[
          "Contamos con el inventario más completo de mobiliario para eventos en la Ciudad de México. Cada pieza es seleccionada por su calidad, durabilidad y estética para garantizar que tu evento luzca impecable.",
          "Desde la elegancia clásica de nuestras sillas Tiffany hasta el diseño contemporáneo de nuestras salas lounge, encontrarás el estilo perfecto para cualquier tipo de celebración."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <Card
            name={sub.name}
            excerpt={sub.excerpt}
            cta={sub.cta}
            href={sub.href}
            icon={sub.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="sillas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Lo más solicitado</span>
          <h2 class="showcase__title" id="sillas-heading">Sillas para Eventos</h2>
          <p class="showcase__subtitle">La silla que elijas define el carácter visual de tu evento. Tenemos la colección más completa de CDMX.</p>
          <p class="showcase__text">Desde la elegancia atemporal de las <strong>sillas Tiffany y Chiavari</strong> para bodas y galas formales, hasta el diseño vanguardista de las <strong>sillas Ghost</strong> para eventos contemporáneos. Cada modelo está disponible en múltiples colores y acabados.</p>
          <p class="showcase__text">Nuestras <strong>sillas Crossback</strong> son ideales para bodas rústicas en haciendas y jardines, mientras que las <strong>Avant Garde</strong> aportan un toque sofisticado a eventos corporativos. Todas incluyen <strong>cojín acolchado</strong> en el color de tu elección. Combínalas con nuestra <a href="/servicios/iluminacion/">iluminación arquitectónica</a> para resaltar cada detalle.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Tiffany</span>
            <span class="showcase__tag">Chiavari</span>
            <span class="showcase__tag">Ghost</span>
            <span class="showcase__tag">Crossback</span>
            <span class="showcase__tag">Avant Garde</span>
            <span class="showcase__tag">Plegables</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Sillas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="mesas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Configuraciones flexibles</span>
          <h2 class="showcase__title" id="mesas-heading">Mesas para Eventos</h2>
          <p class="showcase__subtitle">El layout de mesas determina el flujo y la experiencia de tu evento. Ofrecemos todos los tamaños y formatos.</p>
          <p class="showcase__text">Nuestras <strong>mesas redondas de 150 y 180 cm</strong> son el estándar para banquetes de bodas y XV años, con capacidad de 8 a 10 personas. Las <strong>mesas rectangulares de 240 cm</strong> son perfectas para banquetes imperiales y eventos corporativos con distribución lineal.</p>
          <p class="showcase__text">Para recepciones y cócteles, las <strong>mesas cocktail (periqueras)</strong> de 110 cm crean áreas de socialización elegantes. Complementa con <strong>tablones plegables</strong> para buffets y mesas de registro. Incluimos <strong>manteles y fundas opcionales</strong> en más de 20 colores — consulta nuestra <a href="/servicios/accesorios/">mantelería premium</a> con más de 50 opciones.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Redondas 150cm</span>
            <span class="showcase__tag">Redondas 180cm</span>
            <span class="showcase__tag">Rectangulares</span>
            <span class="showcase__tag">Cocktail</span>
            <span class="showcase__tag">Tablones</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Mesas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SALAS LOUNGE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="salas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Experiencia VIP</span>
          <h2 class="showcase__title" id="salas-heading">Salas Lounge</h2>
          <p class="showcase__subtitle">Transforma cualquier espacio en un área VIP de descanso y conversación. Sets completos para impresionar.</p>
          <p class="showcase__text">Nuestro <strong>Lounge Moderno</strong> con líneas limpias y cuero sintético premium es ideal para corporativos. El <strong>Lounge Vintage</strong> con terciopelo capitonado aporta sofisticación a bodas románticas. El <strong>Lounge Boho</strong> con ratán y textiles artesanales crea ambientes relajados para eventos al aire libre.</p>
          <p class="showcase__text">Cada set incluye <strong>sofá de 3 plazas, sillones individuales, mesa de centro y mesa lateral</strong>. Complementa con <a href="/servicios/iluminacion/">iluminación ambiental decorativa</a> incluida en cada configuración. El <strong>Lounge Elegante</strong> en tonos champagne y oro es la opción perfecta para galas y premiaciones.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Moderno</span>
            <span class="showcase__tag">Vintage</span>
            <span class="showcase__tag">Boho</span>
            <span class="showcase__tag">Elegante</span>
            <span class="showcase__tag">Personalizado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Salas Lounge
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16.5 9.4l-9-5.19"/>
              <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BARRAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="barras-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Complemento perfecto</span>
          <h2 class="showcase__title" id="barras-heading">Barras y Complementos</h2>
          <p class="showcase__subtitle">Barras de bebidas, periqueras, mesas de postres y accesorios decorativos para completar tu montaje.</p>
          <p class="showcase__text">Nuestras <strong>barras de bebidas</strong> están disponibles en madera, acrílico iluminado y estilo industrial, en formatos de 2 y 3 metros con respaldo para botellas. Las <strong>mesas de postres y candy bar</strong> con estructuras escalonadas son perfectas para exhibiciones gastronómicas.</p>
          <p class="showcase__text">Complementa con <strong>periqueras y bancos altos</strong> en madera, metal y acrílico para áreas de cóctel. Incluimos <strong>accesorios decorativos</strong> como bases para centros de mesa, portavelas, atriles y marcos. Instálalos bajo nuestras <a href="/servicios/carpas/">carpas profesionales</a> para eventos al aire libre.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Barras de Bebidas</span>
            <span class="showcase__tag">Candy Bar</span>
            <span class="showcase__tag">Periqueras</span>
            <span class="showcase__tag">Bancos Altos</span>
            <span class="showcase__tag">Accesorios</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Barras
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/>
              <path d="M7 2v20"/>
              <path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Mobiliario"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu mobiliario, es natural tener preguntas sobre modelos, precios, disponibilidad y logística. Aquí encontrarás las respuestas a las consultas más comunes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre mobiliario al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de mobiliario`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Mobiliario"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de mobiliario. Sin compromiso, sin costos ocultos.",
          "Ya sea que necesites 10 sillas o un montaje completo para 1,000 invitados, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="equipo">
                Mobiliario de interés
              </label>
              <select id="equipo" name="equipo" class="form-field__input form-field__select">
                <option value="">Selecciona el mobiliario que necesitas</option>
                <option value="Sillas Tiffany">Sillas Tiffany / Chiavari</option>
                <option value="Sillas Crossback">Sillas Crossback</option>
                <option value="Sillas Ghost">Sillas Ghost</option>
                <option value="Mesas Redondas">Mesas Redondas</option>
                <option value="Mesas Rectangulares">Mesas Rectangulares</option>
                <option value="Mesas Cocktail">Mesas Cocktail / Periqueras</option>
                <option value="Salas Lounge">Salas Lounge</option>
                <option value="Barras">Barras de Bebidas</option>
                <option value="Paquete Completo">Paquete Completo de Mobiliario</option>
                <option value="Otro">Otro / No estoy seguro</option>
