---
/**
 * ─── Silla Crossback Blanco Vintage — Página de Variante (Nivel 4) ───
 * Madera de álamo con acabado blanco decapado: el tono shabby chic
 * ideal para bodas en jardines, viñedos y espacios abiertos con
 * decoración romántica o provenzal.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Crossback > Blanco Vintage
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { label: "Blanco Vintage" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-vinedo-01.avif", alt: "Silla Crossback blanco vintage en viñedo boda al aire libre" },
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-bodega-02.avif", alt: "Crossback blanco vintage en bodega de viñedo evento" },
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-tent-03.avif", alt: "Sillas Crossback blanco vintage bajo carpa de boda" },
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-vinedo-lateral-04.avif", alt: "Vista lateral silla Crossback blanco vintage en viñedo" },
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-jardin-05.avif", alt: "Crossback blanco vintage en jardín romántico boda" },
  { src: "/images/mobiliario/silla-crossback-blanco-vintage-summer-06.avif", alt: "Sillas Crossback blanco vintage en boda verano jardín" },
];

const faqs = [
  {
    question: "¿Qué es exactamente el acabado 'blanco vintage' o decapado?",
    answer: "El <strong>blanco vintage decapado</strong> (también llamado whitewash o encalado) es una técnica de acabado donde se aplica una capa de pintura blanca sobre la madera y luego se retira parcialmente antes de secar, dejando que la veta y el tono natural del álamo se vea a través del blanco. El resultado es un blanco que no es plano ni uniforme — tiene profundidad, textura y esa imperfección controlada que define el estilo shabby chic o provenzal. No es el blanco mate liso de una silla plástica."
  },
  {
    question: "¿Para qué tipo de bodas es ideal la Crossback blanco vintage?",
    answer: "La <strong>Crossback blanco vintage</strong> es la silla definitiva para tres estilos de boda: <strong>shabby chic</strong> (rosas, encajes, detalles en rosa blush y crema), <strong>garden party provenzal</strong> (jardines con lavanda, flores silvestres, manteles de lino natural), y <strong>boda en viñedo o campo</strong> (cuando quieres un tono claro que contraste con el verde del paisaje sin el amarillo-arena del natural). También es muy popular para XV años con temáticas de jardín."
  },
  {
    question: "¿El blanco vintage se ve amarillento o grisáceo con el tiempo?",
    answer: "No. El acabado decapado de nuestras Crossback está sellado con barniz UV transparente que evita la amarillación por exposición solar. En interiores, el blanco vintage conserva su tono durante años. Para exteriores bajo exposición directa sostenida, la protección UV del barniz actúa como barrera. Inspeccionamos cada silla antes de entrega y retiramos de circulación las que muestran desgaste visible del acabado."
  },
  {
    question: "¿Con qué colores de flores y mantelería combina mejor?",
    answer: "El <strong>blanco vintage</strong> es el acabado más versátil de toda la línea Crossback porque el blanco base combina con prácticamente cualquier paleta. Las combinaciones más pedidas: <strong>Blanco vintage + flores en rosa blush + mantel lino</strong> (el combo shabby chic clásico), <strong>Blanco vintage + flores en lavanda y verde eucalipto + mantel blanco</strong> (boda provenzal), y <strong>Blanco vintage + flores en amarillo y naranja suave + mantel terracota</strong> para bodas verano en viñedos."
  },
  {
    question: "¿Cuánto cuesta rentar 100 sillas Crossback blanco vintage?",
    answer: "Para <strong>100 sillas Crossback blanco vintage</strong>, el precio está en el rango de $48-55 por unidad, con un total aproximado de $4,800-$5,500. Incluye entrega en CDMX, montaje según distribución del venue y desmontaje. Para 200 sillas el precio baja a $40-45/u. Para bodas en jardines fuera de CDMX (Estado de México, Morelos, Puebla) se calcula flete adicional por kilómetro. Solicita cotización exacta con dirección por WhatsApp."
  },
];

const specs = [
  { label: "Acabado", value: "Blanco vintage decapado — whitewash con veta natural visible, barniz UV" },
  { label: "Material", value: "Madera maciza de álamo (poplar) con ensambles en espiga" },
  { label: "Resistencia", value: "160 kg por silla (certificado)" },
  { label: "Peso", value: "5.2 kg" },
  { label: "Altura total", value: "92 cm (respaldo cruzado)" },
  { label: "Ancho asiento", value: "44 cm" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Precio desde", value: "$36/silla en lotes de 300+" },
  { label: "Uso exterior", value: "Con cubierta — no apta para lluvia directa" },
  { label: "Mantenimiento", value: "Inspección y limpieza pre-evento incluida" },
];

const reviews = [
  { author: "Lorena Pacheco", text: "Las Crossback blanco vintage fueron perfectas para nuestra boda shabby chic en jardín de Coyoacán. Con el arco de flores en rosas blush y la mantelería en lino natural, el resultado superó todas mis expectativas. EVENTECH llegó puntual y el montaje fue impecable.", rating: 5, date: "2025-11-02" },
  { author: "Mariana Solís", text: "Para nuestra boda en viñedo en Querétaro, el blanco vintage fue la elección perfecta. El color contrasta precioso con el verde de las viñas. 150 sillas en perfecto estado, el equipo conocía el venue y terminaron antes del horario.", rating: 5, date: "2025-10-18" },
  { author: "Gabriela Ríos", text: "Mis XV años en jardín con temática provenzal. Las Crossback blanco vintage con flores en lavanda y eucalipto fueron exactamente lo que imaginé. Mis invitadas seguían preguntando dónde conseguí esas sillas.", rating: 5, date: "2025-09-07" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Crossback Blanco Vintage para Bodas en CDMX",
    description: "Sillas Crossback blanco vintage decapado para bodas shabby chic en jardines y viñedos. Acabado whitewash con veta visible. Resistencia 160 kg. Desde $36/silla.",
    url: "/servicios/mobiliario/sillas/crossback/blanco-vintage/",
    priceRange: { min: 36, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 35,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Crossback", url: "/servicios/mobiliario/sillas/crossback/" },
    { name: "Blanco Vintage", url: "/servicios/mobiliario/sillas/crossback/blanco-vintage/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Natural", href: "/servicios/mobiliario/sillas/crossback/natural/" },
  { name: "Nogal Oscuro", href: "/servicios/mobiliario/sillas/crossback/nogal/" },
  { name: "Blanco Vintage", href: null, active: true },
  { name: "Caoba", href: "/servicios/mobiliario/sillas/crossback/caoba/" },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas Tablón", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Crossback Blanco Vintage"
  description="Renta sillas Crossback blanco vintage decapado en CDMX — acabado whitewash shabby chic para bodas en jardines y viñedos."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="Blanco decapado — el acabado shabby chic que define las bodas en jardín"
    title='Silla Crossback <span class="highlight">Blanco Vintage</span> — Renta en CDMX'
    subtitle="Madera de álamo con acabado whitewash decapado: blanco con veta natural visible que no es plano ni genérico. El tono perfecto para bodas shabby chic, bodas provenzales y garden parties en jardines y viñedos de CDMX y alrededores."
    primaryCTA={{ label: "Cotizar sillas Crossback blanco vintage", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback blanco vintage para mi evento` }}
    cards={[
      {
        title: "El acabado romántico que funciona en cualquier jardín",
        content: "La <strong>silla Crossback blanco vintage</strong> tiene ese blanco texturizado que parece que lleva años en una villa provenzal — y eso es exactamente lo que buscan las novias que eligen el estilo shabby chic. No es el blanco plástico de un salón genérico: es madera real con veta visible a través de la capa de whitewash, creando profundidad visual que la cámara captura perfectamente. Funciona con rosas blush, lavanda, eucalipto y casi cualquier paleta floral.",
      },
      {
        title: "Álamo macizo con acabado sellado y servicio completo",
        content: "Fabricada en <strong>madera maciza de álamo</strong> con ensambles en espiga y sellado UV que protege el blanco de la amarillación solar. Resistencia certificada de 160 kg. Entrega, montaje y desmontaje incluidos en CDMX. <strong>Desde $36/silla en lotes de 300+</strong>, con descuentos por volumen desde 50 unidades. También disponible en combo con mesas tablón en natural o mesas redondas de madera para el look jardín completo.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Crossback blanco vintage — el alma shabby chic de tu boda en jardín o viñedo"
    subheadline="Whitewash decapado · Álamo macizo · Montaje profesional · CDMX y alrededores"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Crossback</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Crossback blanco vintage para tu boda romántica</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback blanco vintage`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Crossback Blanco Vintage en Bodas y Eventos Reales</h2>
            <p class="section__subtitle">Jardines, viñedos y espacios románticos en CDMX y México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Crossback Blanco Vintage</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Crossback blanco vintage es la silla favorita de las bodas garden party?"
    headingId="descripcion-heading"
    badge="Whitewash decapado — romántico sin ser cursi"
    tags={["Blanco Vintage", "Shabby Chic", "Bodas Jardín", "Viñedos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El estilo shabby chic tiene un problema frecuente: que todo lo blanco se vea igual. La <strong>Crossback blanco vintage</strong> resuelve eso con su acabado decapado — el whitewash aplicado y retirado parcialmente deja que la veta del álamo dialogue con el blanco, creando esa textura visual de madera envejecida que fotografía diferente en cada ángulo.</p>
      <p class="showcase__text">Es la silla que las wedding planners de Coyoacán, San Ángel y Lomas de Chapultepec piden cuando el venue tiene jardín con vegetación densa, porque el <strong>blanco vintage resalta contra el verde</strong> sin el contraste duro del blanco plástico. También es la favorita para bodas en viñedos en Querétaro y Morelos, donde el paisaje pide un tono claro que no compita con las vides.</p>
      <p class="showcase__text">Madera maciza de álamo con ensambles en espiga, resistencia de 160 kg y acabado sellado con barniz UV. Inspección silla por silla antes de cada entrega. <strong>Entrega, montaje y desmontaje incluidos en CDMX</strong>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-crossback-blanco-vintage-vinedo-01.avif" alt="Silla Crossback blanco vintage en viñedo boda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-blanco-vintage-jardin-05.avif" alt="Crossback blanco vintage en jardín romántico" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-blanco-vintage-summer-06.avif" alt="Crossback blanco vintage boda verano jardín" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Crossback Blanco Vintage</h2>
            <p class="section__subtitle">Combinaciones de mesa, flores y mantelería que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Shabby Chic Clásico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback blanco vintage + <strong>mesa redonda</strong> + mantel de lino natural + flores en rosas blush, peonías blancas y eucalipto + velas votivas en frascos de vidrio. El combo más fotografiado de nuestra colección para bodas románticas íntimas.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Provenzal Jardín</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback blanco vintage + <strong>mesa tablón pino claro</strong> + corredor de flores en lavanda y verbena + mantel blanco marfil. El look provenzal completo para jardines grandes con espacio para tablones de 10+ personas por mesa.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Viñedo Verano</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback blanco vintage + <strong>mesa tablón pino natural</strong> + mantel de yute + flores en amarillo girasol, naranja y verde eucalipto + lámparas Edison. Para bodas en viñedos con luz natural de mediodía y paleta cálida verano.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Crossback Blanco Vintage</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Crossback Blanco Vintage"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Acabado whitewash decapado, resistencia de 160 kg y precio desde $36 por silla. Aquí resolvemos las dudas sobre nuestra Crossback blanco vintage.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Crossback te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Crossback blanco vintage`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Crossback y servicios relacionados">
          <div class="sidebar-card">
