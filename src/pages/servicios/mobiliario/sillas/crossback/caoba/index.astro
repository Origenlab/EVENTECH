---
/**
 * ─── Silla Crossback Caoba — Página de Variante (Nivel 4) ───
 * Madera de álamo con acabado caoba rojizo: el tono cálido con
 * presencia para haciendas coloniales, cenas de gala y eventos
 * donde se busca madera oscura con acento cálido rojizo.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Crossback > Caoba
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { label: "Caoba" },
];

const galleryImages = [
  { src: "/images/mobiliario/sillas-crossback-caoba-evento.avif", alt: "Sillas Crossback caoba en evento de gala hacienda colonial" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Silla Crossback madera caoba en montaje de evento" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Crossback caoba en cena formal iluminada" },
  { src: "/images/mobiliario/sillas-crossback-madera-boda-vineyard.avif", alt: "Sillas Crossback caoba en boda viñedo atardecer" },
  { src: "/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif", alt: "Crossback caoba con mesas tablón en jardín elegante" },
  { src: "/images/mobiliario/sillas-crossback-viñedo-atardecer-boda.avif", alt: "Sillas Crossback caoba en viñedo al atardecer boda" },
];

const faqs = [
  {
    question: "¿Qué hace especial al acabado caoba en la silla Crossback?",
    answer: "El <strong>acabado caoba</strong> es una tintura rojiza cálida que transforma el álamo claro en un tono profundo con destellos rojos y anaranjados — muy diferente al marrón neutro del nogal. La caoba tiene esa calidez visual que se asocia con <strong>maderas tropicales de lujo</strong> (como la caoba real), sin el costo y el impacto ambiental de usar especies protegidas. El resultado es una silla que parece fabricada en madera preciosa, con la resistencia y el precio del álamo macizo certificado."
  },
  {
    question: "¿Para qué tipo de eventos funciona mejor el Crossback caoba?",
    answer: "El <strong>Crossback caoba</strong> es la elección natural para tres tipos de eventos: <strong>Haciendas coloniales</strong> (el tono rojizo complementa los tezontle y la cantería de las haciendas mexicanas del siglo XVIII), <strong>cenas de gala formales</strong> (la caoba tiene ese peso visual de madera fina que comunica lujo sin gritar), y <strong>bodas con paleta burdeos-dorado</strong> (el rojo de la caoba armoniza perfectamente con estos tonos). También es muy solicitada para eventos de fin de año corporativos con decoración invernal."
  },
  {
    question: "¿Cómo se diferencia el Crossback caoba del Crossback nogal?",
    answer: "Ambos son acabados oscuros sobre álamo, pero con tonalidades muy distintas. El <strong>nogal oscuro</strong> es un marrón chocolate neutro-frío, sin rojo. La <strong>caoba</strong> tiene un marrón rojizo cálido con acento naranja-cobre que se aprecia especialmente bajo luz incandescente, velas o antorchas. En haciendas con iluminación cálida, la caoba literalmente brilla con tonos rojizos. El nogal se ve más contemporáneo y urbano; la caoba se ve más clásica y colonial."
  },
  {
    question: "¿Con qué manteles y flores combina mejor el Crossback caoba?",
    answer: "Las combinaciones más solicitadas: <strong>Caoba + mantel crema o marfil</strong> (el contraste rojo-crema evoca maderas coloniales con lino blanco — muy elegante), <strong>Caoba + mantel burdeos o vino</strong> (la analogía de tonos rojos-marrones crea una paleta profunda y sofisticada), y <strong>Caoba + mantel dorado o champagne</strong> (para galas con toques dorados — el calor del oro y el calor de la caoba se refuerzan mutuamente). Flores en burdeos, terracota o naranja quemado son el complemento perfecto."
  },
  {
    question: "¿Cuánto cuesta rentar 250 sillas Crossback caoba para una cena de gala?",
    answer: "Para <strong>250 sillas Crossback caoba</strong>, el precio está en el rango de $40-45 por unidad, con un total aproximado de $10,000-$11,250. Incluye entrega en CDMX, montaje según distribución del venue y desmontaje. Para eventos en haciendas fuera de CDMX (Morelos, Estado de México, Hidalgo), se calcula flete por kilómetro según acceso al venue. Los haciendas con acceso restringido requieren coordinación previa. Cotización exacta por WhatsApp en menos de 30 minutos."
  },
];

const specs = [
  { label: "Acabado", value: "Caoba rojizo — tintura penetrante cálida con destellos cobre, barniz satinado" },
  { label: "Material", value: "Madera maciza de álamo (poplar) con ensambles en espiga" },
  { label: "Resistencia", value: "160 kg por silla (certificado)" },
  { label: "Peso", value: "5.4 kg" },
  { label: "Altura total", value: "92 cm (respaldo cruzado)" },
  { label: "Ancho asiento", value: "44 cm" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Precio desde", value: "$38/silla en lotes de 300+" },
  { label: "Uso exterior", value: "Con cubierta — no apta para lluvia directa" },
  { label: "Mantenimiento", value: "Inspección y limpieza pre-evento incluida" },
];

const reviews = [
  { author: "Ricardo Mondragón", text: "Para la cena de gala de 300 personas en Hacienda San Gabriel de las Palmas, el Crossback caoba fue una elección que sorprendió a todos. El tono rojizo bajo los candelabros de la hacienda colonial fue simplemente magnífico. Profesionales de principio a fin.", rating: 5, date: "2025-11-28" },
  { author: "Patricia Zavala", text: "Mi boda en Hacienda Cocoyoc con 220 sillas Crossback caoba y manteles en color marfil fue el evento más elegante que he organizado. El contraste rojo-crema bajo la iluminación de velas era exactamente lo que imaginé. EVENTECH cumplió todo lo prometido.", rating: 5, date: "2025-10-31" },
  { author: "Carlos Mendívil", text: "Cena de fin de año corporativo en Hacienda de la Luz con 180 Crossback caoba + manteles burdeos. El ambiente era de gala de primer nivel. La madera caoba bajo las lámparas colgantes de la hacienda pareció siempre haber estado ahí.", rating: 5, date: "2025-12-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Crossback Caoba para Eventos en Haciendas CDMX",
    description: "Sillas Crossback caoba rojizo para cenas de gala y bodas en haciendas coloniales. Tintura penetrante con destellos cobre. Resistencia 160 kg. Desde $38/silla.",
    url: "/servicios/mobiliario/sillas/crossback/caoba/",
    priceRange: { min: 38, max: 68 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Crossback", url: "/servicios/mobiliario/sillas/crossback/" },
    { name: "Caoba", url: "/servicios/mobiliario/sillas/crossback/caoba/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Natural", href: "/servicios/mobiliario/sillas/crossback/natural/" },
  { name: "Nogal Oscuro", href: "/servicios/mobiliario/sillas/crossback/nogal/" },
  { name: "Blanco Vintage", href: "/servicios/mobiliario/sillas/crossback/blanco-vintage/" },
  { name: "Caoba", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas Tablón", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Crossback Caoba para Haciendas"
  description="Renta sillas Crossback caoba rojizo en CDMX — madera de álamo con tintura caoba cálida para haciendas coloniales y cenas de gala."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Caoba rojizo — madera colonial para haciendas y cenas de gala"
    title='Silla Crossback <span class="highlight">Caoba</span> — Renta en CDMX'
    subtitle="Madera de álamo con tintura caoba penetrante: tono rojizo cálido con destellos cobre que complementa la arquitectura colonial de haciendas mexicanas. La Crossback que evoca las maderas preciosas del México del siglo XVIII — con la resistencia certificada de 160 kg y el servicio completo de EVENTECH."
    primaryCTA={{ label: "Cotizar sillas Crossback caoba", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback caoba para mi evento` }}
    cards={[
      {
        title: "El tono colonial que pertenece a las haciendas mexicanas",
        content: "La <strong>silla Crossback caoba</strong> tiene ese rojo-marrón cálido que dialoga con el tezontle, la cantería y los pisos de barro cocido de las haciendas coloniales mexicanas. No es un color accidental — la caoba era la madera fina por excelencia en el México virreinal, y ese referente cultural hace que el acabado se sienta auténtico en espacios históricos. Bajo candelabros o velas, los destellos cobre de la tintura crean una presencia visual que ningún otro acabado de la línea tiene.",
      },
      {
        title: "Tintura penetrante y servicio completo para eventos de gala",
        content: "El acabado caoba se aplica como <strong>tintura penetrante en la fibra del álamo</strong>, no como pintura superficial. La veta de la madera queda visible bajo el tono rojizo, con un barniz satinado de sellado que protege y da un brillo suave. Resistencia certificada de 160 kg. Entrega, montaje y desmontaje incluidos en CDMX. <strong>Desde $38/silla en lotes de 300+</strong>. Para haciendas fuera de CDMX, se coordina flete y acceso con anticipación.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Crossback caoba — la madera colonial que hace que tu hacienda se vea en su mejor versión"
    subheadline="Tintura caoba penetrante · Álamo macizo · Montaje coordinado · Haciendas en CDMX y México"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Crossback</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Crossback caoba para tu gala en hacienda</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback caoba`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Crossback Caoba en Haciendas y Eventos de Gala</h2>
            <p class="section__subtitle">Haciendas coloniales, cenas de gala y bodas en CDMX y México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Crossback Caoba</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el Crossback caoba es la elección de las haciendas coloniales?"
    headingId="descripcion-heading"
    badge="Caoba rojizo — la madera preciosa que tu hacienda merece"
    tags={["Caoba Rojizo", "Haciendas Coloniales", "Cenas de Gala", "Bodas Formales"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una razón histórica detrás de la conexión entre la madera caoba y las haciendas mexicanas del siglo XVIII: la caoba era la madera fina por excelencia en los interiores del México virreinal, desde los altares barrocos hasta los muebles de las casas de campo de las familias más importantes. El <strong>Crossback caoba</strong> recupera ese referente — no con madera caoba real (una especie protegida), sino con una tintura rojiza sobre álamo macizo que evoca ese tono con fidelidad sorprendente.</p>
      <p class="showcase__text">La tintura penetra la fibra del álamo y resalta su veta con un tono rojo-marrón con destellos cobre que, bajo iluminación incandescente o de velas, <strong>parece encenderse</strong>. Es el tipo de efecto que los fotógrafos de bodas buscan activamente. En <strong>Hacienda San Gabriel de las Palmas, Hacienda Cocoyoc y Hacienda de la Luz</strong>, las Crossback caoba se mezclan visualmente con la arquitectura colonial como si hubieran sido diseñadas para ese espacio.</p>
      <p class="showcase__text">Cada silla está fabricada en álamo macizo con ensambles en espiga y barniz satinado de sellado que protege la tintura. Resistencia certificada de 160 kg. Inspección individual antes de cada entrega. <strong>Servicio completo: entrega, montaje y desmontaje en CDMX y haciendas en un radio de 200 km</strong>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sillas-crossback-caoba-evento.avif" alt="Sillas Crossback caoba en evento de gala hacienda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Crossback caoba detalle madera rojiza" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif" alt="Crossback caoba con tablones en jardín elegante" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Crossback Caoba</h2>
            <p class="section__subtitle">Combinaciones de mesa, mantelería e iluminación para haciendas y galas</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Hacienda Colonial</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback caoba + <strong>mesa tablón pino oscuro</strong> + mantel crema o marfil + candelabros de hierro + flores en burdeos y terracota. El setup que más se integra con la arquitectura colonial — el contraste rojo-crema evoca los interiores virreinales auténticos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Burdeos-Dorado</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback caoba + <strong>mantel burdeos</strong> + runner dorado satinado + centros de mesa con flores en rojo, naranja y flores blancas + velas pilares altas. La paleta análoga de tonos cálidos crea cohesión visual y profundidad impresionante.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena de Gala Invernal</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback caoba + <strong>mantel negro</strong> + vajilla dorada + candelabros altos + flores de nochebuena o rojo intenso. Para cenas de fin de año o eventos corporativos de invierno donde se busca atmósfera festiva con sobriedad elegante.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Crossback Caoba</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Crossback Caoba"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Tintura caoba penetrante con destellos cobre, resistencia de 160 kg y precio desde $38 por silla. Aquí resolvemos las dudas sobre nuestra Crossback caoba.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Crossback te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Crossback caoba`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
