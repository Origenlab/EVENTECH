---
/**
 * ─── Silla Crossback Natural — Página de Variante (Nivel 4) ───
 * Madera natural de álamo sin teñir: el acabado más auténtico para bodas
 * rústicas en haciendas, viñedos y jardines al aire libre.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Crossback > Natural
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { label: "Natural" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-crossback-natural-hacienda-boda-01.avif", alt: "Silla Crossback madera natural en boda hacienda CDMX" },
  { src: "/images/mobiliario/silla-crossback-natural-hacienda-exterior-02.avif", alt: "Sillas Crossback natural en exterior hacienda México" },
  { src: "/images/mobiliario/silla-crossback-natural-boda-atardecer-03.avif", alt: "Silla Crossback natural en boda al atardecer" },
  { src: "/images/mobiliario/silla-crossback-natural-ceremonia-exterior-04.avif", alt: "Ceremonia con sillas Crossback natural al aire libre" },
  { src: "/images/mobiliario/silla-crossback-natural-pasillo-boda-05.avif", alt: "Pasillo de boda con sillas Crossback madera natural" },
  { src: "/images/mobiliario/silla-crossback-natural-sunset-boda-06.avif", alt: "Sillas Crossback natural en boda sunset viñedo" },
];

const faqs = [
  {
    question: "¿Qué madera tiene la silla Crossback natural?",
    answer: "La <strong>Silla Crossback natural</strong> está fabricada en madera de álamo (poplar), una especie de grano fino y color claro que resiste bien la humedad y los cambios de temperatura. El acabado natural conserva el tono original de la madera sin barniz oscuro — verás las vetas suaves del álamo que le dan esa calidez orgánica que buscan las bodas rústicas. Cada silla pasa por un lijado y sellado natural que protege la superficie sin alterar el color."
  },
  {
    question: "¿Cuánto soporta la silla Crossback natural?",
    answer: "Cada silla Crossback natural tiene una capacidad certificada de <strong>160 kg</strong>. La estructura en madera maciza de álamo con ensambles en espiga y pegamento estructural garantiza rigidez sin deformaciones. El asiento tiene refuerzo central. Para eventos con invitados de talla grande, es el modelo que más recomendamos dentro de nuestra línea rústica."
  },
  {
    question: "¿La silla Crossback natural sirve para exteriores?",
    answer: "Sí, con algunas consideraciones. La madera de álamo tiene sellado natural resistente a humedad ambiental, pero <strong>no recomendamos exponerla a lluvia directa</strong>. Para bodas en jardines o haciendas al aire libre, se usa bajo carpa, pérgola o en zonas techadas. Si tu evento es completamente al exterior sin protección de techo, consulta si el pronóstico permite usar madera natural ese día. Siempre tenemos cobertura de contingencia."
  },
  {
    question: "¿Cuánto cuesta rentar sillas Crossback natural para una boda?",
    answer: "La renta de <strong>Silla Crossback madera natural</strong> tiene precio <strong>desde $35 por silla</strong> en lotes de 300 o más. Para 50-149 sillas el precio es $45-55/u, y para 150-299 sillas $38-45/u. El precio incluye entrega en CDMX, montaje en plano del salón y desmontaje. Para bodas en haciendas fuera de CDMX se calcula flete por kilómetro. Solicita tu cotización exacta por WhatsApp."
  },
  {
    question: "¿Con qué decoración combina mejor la Crossback natural?",
    answer: "La Crossback natural es el alma de las bodas rústicas. Combina perfecto con: <strong>manteles de lino o yute en tono natural</strong>, florería silvestre en tonos tierra (girasoles, lavanda, ranúnculos), iluminación con velas y lámparas Edison, y mesas de madera tablón. También funciona con paletas blancas y verdes eucalipto para bodas jardín más frescas. El álamo natural tiene ese tono beige-arena que equilibra cualquier decoración sin competir con ella."
  },
];

const specs = [
  { label: "Acabado", value: "Madera natural de álamo — sin teñir, veta visible, sellado natural" },
  { label: "Material", value: "Madera maciza de álamo (poplar) con ensambles en espiga" },
  { label: "Resistencia", value: "160 kg por silla (certificado)" },
  { label: "Peso", value: "5.2 kg" },
  { label: "Altura total", value: "92 cm (respaldo cruzado)" },
  { label: "Ancho asiento", value: "44 cm" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Precio desde", value: "$35/silla en lotes de 300+" },
  { label: "Uso exterior", value: "Con cubierta — no apta para lluvia directa" },
  { label: "Mantenimiento", value: "Inspección y limpieza pre-evento incluida" },
];

const reviews = [
  { author: "Sofía Mendoza", text: "Rentamos 180 sillas Crossback natural para nuestra boda en Hacienda Temixco. La madera quedó perfecta con las flores silvestres y los manteles de lino. El equipo llegó puntual y el montaje fue impecable.", rating: 5, date: "2025-11-08" },
  { author: "Diego Ramírez", text: "Para nuestra boda en viñedo en Valle de Guadalupe, la Crossback natural fue la elección ideal. El tono de madera combinó a la perfección con las barricas y el paisaje. 200 sillas sin un solo problema.", rating: 5, date: "2025-10-22" },
  { author: "Valentina Cruz", text: "Organizamos una boda boho en jardín privado con 120 Crossback natural. La calidez de la madera en las fotos es incomparable — mis invitados siguen preguntando dónde rentamos las sillas.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Crossback Madera Natural para Bodas en CDMX",
    description: "Sillas Crossback madera natural de álamo para bodas rústicas en haciendas y jardines. Resistencia 160 kg. Entrega y montaje incluidos. Desde $35/silla.",
    url: "/servicios/mobiliario/sillas/crossback/natural/",
    priceRange: { min: 35, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 42,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Crossback", url: "/servicios/mobiliario/sillas/crossback/" },
    { name: "Natural", url: "/servicios/mobiliario/sillas/crossback/natural/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Natural", href: null, active: true },
  { name: "Nogal Oscuro", href: "/servicios/mobiliario/sillas/crossback/nogal/" },
  { name: "Blanco Vintage", href: "/servicios/mobiliario/sillas/crossback/blanco-vintage/" },
  { name: "Caoba", href: "/servicios/mobiliario/sillas/crossback/caoba/" },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas Tablón", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Crossback Madera Natural"
  description="Renta sillas Crossback madera natural de álamo en CDMX — el modelo rústico #1 para bodas en haciendas y viñedos."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Madera de álamo natural — el alma rústica de las bodas en hacienda"
    title='Silla Crossback <span class="highlight">Madera Natural</span> — Renta en CDMX'
    subtitle="Álamo natural sin teñir con veta visible: la silla que define el estilo rústico en bodas, viñedos y haciendas. Resistencia certificada de 160 kg, estructura en madera maciza con ensambles en espiga. Entrega, montaje y desmontaje incluidos en CDMX."
    primaryCTA={{ label: "Cotizar sillas Crossback natural", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback madera natural para mi evento` }}
    cards={[
      {
        title: "El modelo rústico más auténtico para bodas en hacienda",
        content: "La <strong>silla Crossback madera natural</strong> tiene ese calor orgánico que ningún acabado artificial puede replicar. El álamo sin teñir muestra su veta suave con tono beige-arena que combina con lino, yute, flores silvestres y madera tablón. Para bodas en haciendas como Temixco, San Gabriel o San Ángel, o en viñedos en Valle de Guadalupe o Querétaro, la Crossback natural es la elección que hace que las fotos parezcan de revista.",
      },
      {
        title: "Calidad de madera maciza y servicio completo en CDMX",
        content: "Cada silla está fabricada en <strong>madera maciza de álamo con ensambles en espiga</strong> — no triplay, no MDF. Resistencia certificada de 160 kg. Sellado natural que protege sin alterar el color. Entrega, montaje según plano del salón y desmontaje incluidos en CDMX. <strong>Desde $35/silla en lotes de 300+</strong>, con descuentos por volumen desde 50 unidades. También rentamos mesas tablón en madera natural para el combo perfecto.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Sillas Crossback natural para la boda rústica que imaginaste — cotiza sin compromiso"
    subheadline="Álamo macizo · 160 kg · Montaje profesional · Haciendas y viñedos en CDMX y México"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Crossback</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Crossback natural para tu boda rústica</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback madera natural`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Crossback Natural en Bodas y Eventos Reales</h2>
            <p class="section__subtitle">Haciendas, viñedos y jardines en CDMX y México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Crossback Madera Natural</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Crossback natural es la silla rústica preferida para bodas?"
    headingId="descripcion-heading"
    badge="Álamo sin teñir — autenticidad que la cámara captura"
    tags={["Madera Natural", "Bodas Rústicas", "Haciendas", "Viñedos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay bodas donde la silla tiene que desaparecer entre la decoración y dejar que todo lo demás brille. Y hay bodas donde la silla <strong>es parte de la decoración</strong>. La Crossback natural pertenece a la segunda categoría: su veta de álamo visible, su tono beige-arena cálido y su respaldo cruzado en X son elementos de diseño en sí mismos.</p>
      <p class="showcase__text">Fabricada en <strong>madera maciza de álamo</strong> con ensambles en espiga y pegamento estructural, cada silla aguanta 160 kg sin flexionarse. El sellado natural protege la superficie sin alterar el color original. Antes de cada entrega, inspeccionamos silla por silla para detectar astillas, holguras o manchas — lo que llega a tu venue está en perfectas condiciones.</p>
      <p class="showcase__text">Nuestros clientes la piden para <strong>bodas en Hacienda Temixco, San Gabriel de las Palmas y San Ángel Inn</strong>, para viñedos en Valle de Guadalupe y Querétaro, y para jardines boutique en Coyoacán y San Ángel. El Crossback natural junto con una mesa tablón y manteles de lino es el setup rústico más fotografiado de nuestra colección.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-crossback-natural-hacienda-boda-01.avif" alt="Silla Crossback madera natural en boda hacienda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-natural-ceremonia-exterior-04.avif" alt="Ceremonia al exterior con sillas Crossback natural" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-natural-sunset-boda-06.avif" alt="Boda sunset con sillas Crossback natural" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Crossback Natural</h2>
            <p class="section__subtitle">Combinaciones de mesa, mantelería e iluminación que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Rústica Hacienda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback natural + <strong>mesa tablón pino</strong> + mantel de lino natural + florería silvestre con girasoles, lavanda y ranúnculos. El setup rústico clásico que funciona en cualquier hacienda con arquitectura colonial o jardín de tierra.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Viñedo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback natural + <strong>mesa tablón pino oscuro</strong> + mantel de yute + iluminación Edison + barricas decorativas. La combinación para viñedos en Valle de Guadalupe o San Luis Potosí que hace que cada foto parezca editorial.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Jardín Boho</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback natural + <strong>mesa redonda</strong> + mantel blanco con corredor de flores silvestres + velas en frascos de vidrio + macramé. Para bodas boho en jardines privados, fincas y espacios al aire libre con ambiente íntimo.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Crossback Madera Natural</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Crossback Natural"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Madera real de álamo, resistencia de 160 kg y precio desde $35 por silla. Aquí resolvemos las dudas más frecuentes sobre nuestra Crossback natural.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Crossback te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Crossback madera natural`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Crossback y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Crossback</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/sillas/" class="sidebar-nav__back">&uarr; Volver a Sillas</a>
              </li>
