---
/**
 * ─── Sillas Crossback — Página de Producto (Nivel 4) ───
 * Madera natural con respaldo entrecruzado para bodas rústicas.
 * Acabados natural, nogal oscuro, blanco vintage y caoba.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Crossback
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Crossback" },
];

const faqs = [
  { question: "¿Las sillas Crossback se pueden usar en jardín y exteriores?", answer: 'Sí. La madera de álamo recibe un tratamiento de barnizado resistente a la intemperie que la protege de la humedad y los rayos UV. Sin embargo, para eventos con pronóstico de lluvia prolongada, recomendamos ubicarlas bajo nuestras <a href="/servicios/carpas/">carpas profesionales</a>. Incluimos <strong>niveladores en las patas sin costo</strong> para garantizar estabilidad en superficies de pasto o terreno irregular.' },
  { question: "¿La madera resiste la lluvia?", answer: "El barnizado protector de nuestras sillas Crossback las hace <strong>resistentes a lluvia ligera y humedad ambiental</strong>. Sin embargo, la exposición prolongada a lluvia directa no es recomendable para preservar la calidad del acabado. Para eventos completamente al aire libre, la combinación ideal es Crossback bajo carpa — así proteges la madera y creas un ambiente rústico espectacular." },
  { question: "¿Se puede personalizar el cojín?", answer: "Sí. Por defecto, cada silla Crossback incluye <strong>cojín de arpillera</strong> que refuerza la estética rústica. También ofrecemos opciones en lino y algodón en tonos neutros: beige, crema, gris claro, blanco natural y arena. Para colores personalizados o telas especiales, consúltanos con anticipación y te preparamos una muestra." },
  { question: "¿Puedo combinar Crossback con mesas de madera?", answer: 'Sí, y es la combinación más solicitada. Ofrecemos <a href="/servicios/mobiliario/mesas/">mesas de madera</a> en acabados que hacen juego con los tonos natural, nogal y caoba de las Crossback. Complementa con <a href="/servicios/accesorios/manteleria-textiles/">caminos de mesa de yute</a>, portavelas de madera y centros de mesa con flores silvestres para un montaje rústico integral.' },
  { question: "¿Cuál es la cantidad mínima de renta?", answer: "No tenemos mínimo obligatorio — puedes rentar desde 1 silla Crossback. Sin embargo, para optimizar costos de logística, recomendamos pedidos de <strong>50 sillas en adelante</strong>. Para eventos grandes de 200+ sillas, ofrecemos descuentos por volumen que se detallan en tu cotización personalizada." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con <strong>2 a 4 semanas de anticipación</strong> para garantizar disponibilidad del acabado deseado. En temporada alta (noviembre a febrero), la demanda de Crossback natural y nogal se triplica, por lo que sugerimos apartar con <strong>1 a 2 meses de anticipación</strong>. Un anticipo del 30% confirma tu reserva y asegura tu fecha." },
];

const specs = [
  { label: "Material", value: "Madera de álamo macizo" },
  { label: "Resistencia", value: "160 kg" },
  { label: "Acabados", value: "Natural, Nogal oscuro, Blanco vintage, Caoba" },
  { label: "Peso", value: "4.2 kg" },
  { label: "Cojín", value: "Arpillera o tela lisa, tonos neutros" },
  { label: "Altura respaldo", value: "88 cm" },
  { label: "Ancho asiento", value: "42 cm" },
  { label: "Respaldo", value: "Entrecruzado tipo X-back" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Mantenimiento", value: "Barnizado y limpieza incluidos pre-evento" },
];

const sidebarNav = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Sillas Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Sillas Crossback", href: null, active: true },
  { name: "Sillas Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
];

const sidebarRelated = [
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Accesorios Decorativos", href: "/servicios/accesorios/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Patricia Lozano", text: "Rentamos 180 sillas Crossback natural para nuestra boda en Hacienda San Ángel. El ambiente rústico que crearon fue exactamente lo que soñábamos. Los cojines de arpillera le dieron el toque campestre perfecto y la logística fue impecable — montaron todo en tiempo récord.", rating: 5, date: "2025-11-10" },
  { author: "Miguel Ángel Reyes", text: "Elegimos 150 Crossback nogal oscuro para nuestra boda en un jardín en Coyoacán. Combinadas con fairy lights y arreglos de flores silvestres, las fotos quedaron espectaculares. La madera oscura le dio un toque de elegancia rústica que todos nuestros invitados comentaron.", rating: 5, date: "2025-10-02" },
  { author: "Isabela Fuentes", text: "Para mi boda provenzal en una terraza en la Condesa, rentamos 100 Crossback blanco vintage. La perfección del shabby chic — el acabado envejecido combinó hermosamente con la lavanda, los manteles de lino y las velas. Servicio puntual y profesional de principio a fin.", rating: 5, date: "2025-08-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Crossback para Eventos en CDMX",
    description: "Renta de sillas Crossback de madera de álamo con respaldo entrecruzado. La favorita para bodas rústicas en haciendas y jardines. Desde $40 por silla.",
    url: "/servicios/mobiliario/sillas/crossback/",
    priceRange: { min: 40, max: 130 },
    reviews,
    ratingValue: 5,
    reviewCount: 71,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Crossback", url: "/servicios/mobiliario/sillas/crossback/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Sillas Crossback para Eventos en CDMX"
  description="Renta de sillas Crossback de madera de álamo con respaldo entrecruzado. La favorita para bodas rústicas en haciendas y jardines. Desde $40 por silla."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Favorita para bodas rústicas y jardines"
    title='Renta de <span class="highlight">Sillas Crossback</span> para Eventos en CDMX'
    subtitle="Sillas Crossback de madera de álamo macizo con respaldo entrecruzado X-back. Acabados natural, nogal oscuro, blanco vintage y caoba. Resistencia de 160 kg. Cojín de arpillera o tela lisa incluido. Entrega y montaje profesional."
    primaryCTA={{ label: "Cotiza tus sillas Crossback", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sillas Crossback para mi evento` }}
    cards={[
      {
        title: "Madera de álamo macizo con respaldo X-back en 4 acabados",
        content: "<strong>Renta de sillas Crossback para eventos</strong> fabricadas en madera de álamo macizo con barnizado a mano y el icónico respaldo entrecruzado tipo X-back. 4 acabados: natural para bodas campestres, nogal oscuro para haciendas, blanco vintage para celebraciones shabby chic y caoba para eventos formales en jardines. Resistencia de <strong>160 kg por silla</strong>. Apilable hasta 8 unidades.",
      },
      {
        title: "Cojín de arpillera incluido y encanto campestre para haciendas",
        content: "<strong>Servicio completo de sillas Crossback</strong> con cojín de arpillera o tela lisa en tonos neutros incluido sin costo adicional. El encanto campestre de la Crossback es inigualable — su estética combina perfectamente con decoración de flores silvestres, caminos de mesa de yute, portavelas de madera y centros de mesa rústicos. Entrega puntual, montaje profesional y recolección al finalizar.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas sillas Crossback para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con acabado y precio por unidad"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Sillas para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas sillas Crossback para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/><path d="M5 21v-2"/><path d="M19 21v-2"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Sillas Crossback</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Crossback Natural -->
          <section class="section section--alt" aria-labelledby="natural-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">La favorita para jardines</span>
                <h2 class="showcase__title" id="natural-heading">Crossback Natural</h2>
                <p class="showcase__subtitle">Madera sin teñir con veta visible que aporta frescura natural para bodas campestres y haciendas.</p>
                <p class="showcase__text">La <strong>silla Crossback natural</strong> es el acabado más solicitado de nuestra colección, presente en más del 60% de las bodas rústicas que atendemos en CDMX. Su madera de álamo sin teñir deja visible la <strong>veta natural de la madera</strong>, aportando una frescura orgánica que ningún otro acabado puede igualar. El barnizado transparente protege la superficie sin alterar su tono claro y cálido — ideal para bodas al aire libre en jardines, haciendas campestres y venues con vegetación abundante.</p>
                <p class="showcase__text">Incluye <strong>cojín de arpillera</strong> que refuerza la estética campestre. Combínalas con nuestras <a href="/servicios/mobiliario/mesas/">mesas de madera</a> en tono natural para un montaje rústico integral. Las combinaciones más populares incluyen Crossback natural + caminos de yute + flores silvestres + portavelas de madera para un ambiente campestre auténtico que enamora en fotografías.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Natural</span>
                  <span class="showcase__tag">Jardines</span>
                  <span class="showcase__tag">Haciendas</span>
                  <span class="showcase__tag">Campestre</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Crossback Natural
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/><path d="M5 21v-2"/><path d="M19 21v-2"/></svg>
                  <span>Crossback Natural</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Crossback Nogal Oscuro -->
          <section class="section section--alt" aria-labelledby="nogal-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegancia rústica</span>
                <h2 class="showcase__title" id="nogal-heading">Crossback Nogal Oscuro</h2>
                <p class="showcase__subtitle">Tono oscuro profundo para haciendas coloniales y celebraciones con estética warm luxury.</p>
                <p class="showcase__text">La <strong>silla Crossback nogal oscuro</strong> aporta profundidad y formalidad a los montajes rústicos sin perder el encanto campestre que define a esta silla. Su tono nogal profundo es la elección predilecta para <strong>haciendas coloniales, viñedos y venues con arquitectura de madera oscura</strong>. El acabado resalta la textura de la veta del álamo con un barnizado oscuro que le da un aire de antigüedad elegante — perfecto para bodas con estética warm luxury.</p>
                <p class="showcase__text">La Crossback nogal oscuro combina espectacularmente con <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> cálida — las fairy lights y las velas crean reflejos dorados sobre la madera oscura que resultan extraordinariamente fotogénicos. Complementa con <a href="/servicios/accesorios/manteleria-textiles/">manteles de lino en tonos neutros</a> y centros de mesa con follaje verde para un contraste natural sofisticado.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Nogal Oscuro</span>
                  <span class="showcase__tag">Haciendas Coloniales</span>
                  <span class="showcase__tag">Viñedos</span>
                  <span class="showcase__tag">Warm Luxury</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Crossback Nogal
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/><path d="M5 21v-2"/><path d="M19 21v-2"/></svg>
                  <span>Crossback Nogal Oscuro</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Crossback Blanco Vintage -->
          <section class="section section--alt" aria-labelledby="blanco-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Encanto shabby chic</span>
                <h2 class="showcase__title" id="blanco-heading">Crossback Blanco Vintage</h2>
                <p class="showcase__subtitle">Acabado blanco envejecido que evoca romanticismo vintage para bodas y celebraciones intimistas.</p>
                <p class="showcase__text">La <strong>silla Crossback blanco vintage</strong> presenta un acabado blanco envejecido con sutil desgaste intencional que revela la madera natural en bordes y uniones. Este efecto de pátina le da un <strong>encanto romántico inconfundible</strong> — perfecto para bodas con estética shabby chic, boho o provenzal. La textura visual del desgaste controlado aporta autenticidad y calidez que las sillas pintadas de blanco uniforme simplemente no pueden igualar.</p>
                <p class="showcase__text">La Crossback blanco vintage es la favorita para <strong>bodas íntimas, baby showers, despedidas de soltera y celebraciones en terrazas</strong> con decoración de lavanda, suculentas y telas ligeras. Combina espectacularmente con <a href="/servicios/accesorios/">accesorios decorativos</a> en tonos pastel y texturas naturales. El cojín de lino en tono crema completa el look provenzal que tus invitados recordarán.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Blanco Vintage</span>
                  <span class="showcase__tag">Shabby Chic</span>
                  <span class="showcase__tag">Boho</span>
                  <span class="showcase__tag">Provenzal</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Crossback Blanco Vintage
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/><path d="M5 21v-2"/><path d="M19 21v-2"/></svg>
                  <span>Crossback Blanco Vintage</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Crossback Caoba -->
          <section class="section section--alt" aria-labelledby="caoba-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Formalidad campestre</span>
                <h2 class="showcase__title" id="caoba-heading">Crossback Caoba</h2>
                <p class="showcase__subtitle">Tono caoba rojizo que eleva la Crossback a eventos formales en jardines y haciendas de prestigio.</p>
                <p class="showcase__text">La <strong>silla Crossback caoba</strong> transforma la estética rústica de la Crossback en una propuesta formal y distinguida. Su tono rojizo profundo aporta <strong>calidez, riqueza visual y un aire de tradición</strong> que la convierte en la elección ideal para eventos de alto nivel en haciendas de prestigio, jardines de hoteles boutique y venues exclusivos. La caoba eleva la silla campestre a un nivel de sofisticación que sorprende sin perder su encanto natural.</p>
                <p class="showcase__text">Ideal para <strong>bodas formales en jardín, aniversarios, cenas de gala en haciendas y eventos corporativos premium</strong> donde se busca calidez sin sacrificar elegancia. Combina con <a href="/servicios/mobiliario/mesas/">mesas rectangulares de madera</a> en tono similar y <a href="/servicios/iluminacion/decorativa/">candiles y velas</a> para crear un ambiente de lujo campestre que impresiona. El cojín en tono arena o beige complementa el caoba con sobriedad.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Caoba</span>
