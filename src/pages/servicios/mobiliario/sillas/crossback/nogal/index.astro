---
/**
 * ─── Silla Crossback Nogal Oscuro — Página de Variante (Nivel 4) ───
 * Madera de álamo con acabado nogal oscuro: la Crossback para bodas
 * elegantes rústicas donde el tono oscuro da peso y carácter al montaje.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Crossback > Nogal
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { label: "Nogal Oscuro" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-crossback-nogal-jardin-noche-01.avif", alt: "Silla Crossback nogal oscuro en jardín nocturno elegante" },
  { src: "/images/mobiliario/silla-crossback-nogal-cena-exterior-02.avif", alt: "Cena exterior con sillas Crossback nogal oscuro" },
  { src: "/images/mobiliario/silla-crossback-nogal-edison-jardin-03.avif", alt: "Sillas Crossback nogal con luces Edison en jardín boda" },
  { src: "/images/mobiliario/silla-crossback-nogal-luces-cena-04.avif", alt: "Crossback nogal oscuro en cena con iluminación ambiental" },
  { src: "/images/mobiliario/silla-crossback-nogal-jardin-lateral-05.avif", alt: "Vista lateral silla Crossback nogal en jardín elegante" },
  { src: "/images/mobiliario/silla-crossback-nogal-guirnaldas-noche-06.avif", alt: "Crossback nogal oscuro bajo guirnaldas de luz nocturnas" },
];

const faqs = [
  {
    question: "¿Qué diferencia hay entre el Crossback nogal y el natural?",
    answer: "La diferencia está en el acabado. La <strong>Crossback nogal</strong> tiene la misma estructura de madera de álamo macizo, pero con una tintura nogal oscuro que penetra la fibra de la madera — no es pintura superficial, es un teñido que resalta la veta y da ese tono chocolate oscuro profundo. El natural deja ver el color original del álamo (beige-arena claro), mientras el nogal oscuro aporta peso visual, drama y sofisticación. La resistencia (160 kg) y el ensamble en espiga son idénticos."
  },
  {
    question: "¿Para qué tipo de eventos es mejor el Crossback nogal oscuro?",
    answer: "El <strong>Crossback nogal</strong> brilla en bodas con decoración que busca contraste y profundidad: manteles blancos sobre madera oscura, centros de mesa altos con flores blancas y eucalipto, iluminación con guirnaldas Edison o velas pilares. Es el modelo preferido para <strong>bodas elegantes rústicas</strong>, cenas de gala en jardines de noche, y cualquier evento donde el negro o el tono chocolate del nogal forma parte de la paleta de color intencional."
  },
  {
    question: "¿El acabado nogal se ve opaco o brillante?",
    answer: "El acabado nogal de nuestras sillas Crossback tiene un <strong>brillo satinado suave</strong> — ni opaco mate ni lacado brillante. Esto hace que la madera refleje levemente la iluminación ambiental de velas y luces Edison, lo que crea un efecto muy cálido y elegante en fotografías nocturnas. El acabado está sellado con barniz natural que protege la tintura sin alterar su profundidad de color."
  },
  {
    question: "¿Con qué mantelería combina mejor el Crossback nogal?",
    answer: "Las tres combinaciones más solicitadas: <strong>Nogal + mantel blanco lino</strong> (el contraste chocolate-blanco es el más dramático y fotogénico), <strong>Nogal + mantel terracota</strong> (para bodas otoñales en haciendas con paleta tierra), y <strong>Nogal + mantel negro</strong> para cenas de gala nocturnas con atmósfera íntima. También funciona muy bien con manteles verde musgo o burdeos para paletas con carácter."
  },
  {
    question: "¿Cuánto cuesta rentar 150 sillas Crossback nogal para una boda en jardín?",
    answer: "Para <strong>150 sillas Crossback nogal oscuro</strong>, el precio está en el rango de $40-45 por unidad, lo que da un total aproximado de $6,000-$6,750 por el lote. Incluye entrega en CDMX, montaje según distribución del venue y desmontaje. Para jardines en Lomas de Chapultepec, Coyoacán o San Ángel, es un precio que cubre todo el servicio. Solicita cotización exacta con fecha, dirección y distribución por WhatsApp."
  },
];

const specs = [
  { label: "Acabado", value: "Nogal oscuro — tintura penetrante chocolate profundo, satinado suave" },
  { label: "Material", value: "Madera maciza de álamo (poplar) con ensambles en espiga" },
  { label: "Resistencia", value: "160 kg por silla (certificado)" },
  { label: "Peso", value: "5.4 kg" },
  { label: "Altura total", value: "92 cm (respaldo cruzado)" },
  { label: "Ancho asiento", value: "44 cm" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Precio desde", value: "$38/silla en lotes de 300+" },
  { label: "Uso exterior", value: "Con cubierta — no apta para lluvia directa" },
  { label: "Mantenimiento", value: "Inspección y limpieza pre-evento incluida" },
];

const reviews = [
  { author: "Camila Herrera", text: "Las Crossback nogal con manteles blancos de lino en nuestro jardín nocturno fueron simplemente espectaculares. La madera oscura bajo las guirnaldas Edison creó una atmósfera que ninguna foto hace justicia. Todo el equipo de EVENTECH fue impecable.", rating: 5, date: "2025-11-15" },
  { author: "Andrés Villanueva", text: "Organizamos una cena de gala para 200 personas con Crossback nogal + mantel negro + runner dorado. El resultado fue exactamente el ambiente elegante oscuro que queríamos. Cero problemas logísticos, entrega puntual.", rating: 5, date: "2025-10-03" },
  { author: "Isabel Fuentes", text: "Para nuestra boda en Hacienda San Gabriel, el nogal oscuro contrastando con el arco de flores blancas fue la imagen del evento. 180 sillas en perfecto estado, el montaje terminó antes de lo prometido.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Crossback Nogal Oscuro para Bodas en CDMX",
    description: "Sillas Crossback nogal oscuro para bodas elegantes rústicas en jardines y haciendas. Resistencia 160 kg. Entrega y montaje incluidos. Desde $38/silla.",
    url: "/servicios/mobiliario/sillas/crossback/nogal/",
    priceRange: { min: 38, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Crossback", url: "/servicios/mobiliario/sillas/crossback/" },
    { name: "Nogal Oscuro", url: "/servicios/mobiliario/sillas/crossback/nogal/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Natural", href: "/servicios/mobiliario/sillas/crossback/natural/" },
  { name: "Nogal Oscuro", href: null, active: true },
  { name: "Blanco Vintage", href: "/servicios/mobiliario/sillas/crossback/blanco-vintage/" },
  { name: "Caoba", href: "/servicios/mobiliario/sillas/crossback/caoba/" },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas Tablón", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Crossback Nogal Oscuro"
  description="Renta sillas Crossback nogal oscuro en CDMX — madera de álamo con acabado chocolate profundo para bodas elegantes rústicas."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Nogal oscuro — profundidad y drama para bodas elegantes rústicas"
    title='Silla Crossback <span class="highlight">Nogal Oscuro</span> — Renta en CDMX'
    subtitle="Madera de álamo con tintura nogal penetrante: tono chocolate oscuro profundo con acabado satinado suave que refleja las luces de velas y guirnaldas Edison. La Crossback que define la boda elegante rústica en jardines nocturnos y haciendas de CDMX."
    primaryCTA={{ label: "Cotizar sillas Crossback nogal", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback nogal oscuro para mi evento` }}
    cards={[
      {
        title: "El tono oscuro que da carácter a bodas en jardín nocturno",
        content: "La <strong>silla Crossback nogal</strong> tiene ese color chocolate profundo que transforma por completo la lectura del espacio. Con manteles blancos de lino y flores en blanco-eucalipto, el nogal crea el contraste más limpio y fotogénico de toda nuestra colección rústica. Bajo guirnaldas de luz Edison o velas pilares, la madera oscura refleja los tonos dorados de manera que ningún acabado claro puede replicar.",
      },
      {
        title: "Madera maciza de álamo con tintura que penetra la fibra",
        content: "El acabado nogal no es pintura superficial — es una <strong>tintura penetrante que ingresa en la fibra del álamo</strong>, resalta la veta natural de la madera y le da ese tono chocolate con matices cálidos. El barniz satinado de sellado protege sin alterar el color. Resistencia certificada de 160 kg, ensambles en espiga y servicio completo: entrega, montaje y desmontaje en CDMX. <strong>Desde $38/silla en lotes de 300+</strong>.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Crossback nogal — el tono oscuro que hace que las bodas en jardín parezcan de revista"
    subheadline="Álamo macizo · Tintura nogal penetrante · Montaje profesional · CDMX y área metropolitana"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Crossback</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Crossback nogal para tu boda elegante</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Crossback nogal oscuro`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Crossback Nogal Oscuro en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en jardín, cenas de gala y haciendas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Crossback Nogal Oscuro</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el nogal oscuro transforma el ambiente de una boda en jardín?"
    headingId="descripcion-heading"
    badge="Nogal que da carácter — el rústico elegante"
    tags={["Nogal Oscuro", "Bodas Elegantes", "Jardín Nocturno", "Haciendas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una diferencia fundamental entre una boda rústica y una boda <em>elegante</em> rústica. La primera usa madera clara y flores silvestres. La segunda usa madera oscura, flores controladas en paleta específica, e iluminación de bajo impacto ambiental. La <strong>Crossback nogal oscuro</strong> pertenece a la segunda categoría: su tono chocolate profundo impone presencia sin gritar.</p>
      <p class="showcase__text">El acabado nogal se aplica como tintura penetrante en la fibra del álamo — no como capa de pintura. Esto significa que la veta natural de la madera queda visible bajo el tono oscuro, creando esa <strong>textura visual que hace que la madera se vea cara</strong>. El barniz satinado de sellado protege la tintura y le da ese brillo suave que capta perfectamente la iluminación de velas.</p>
      <p class="showcase__text">En jardines nocturnos en <strong>Lomas de Chapultepec, Coyoacán o San Ángel</strong>, las Crossback nogal bajo guirnaldas Edison producen imágenes que nuestros clientes siguen enviando meses después de su boda. Es el tipo de silla que aparece en las fotos aunque no sea el centro de atención.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-crossback-nogal-jardin-noche-01.avif" alt="Silla Crossback nogal oscuro en jardín nocturno" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-nogal-edison-jardin-03.avif" alt="Crossback nogal con luces Edison en jardín boda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-crossback-nogal-guirnaldas-noche-06.avif" alt="Crossback nogal bajo guirnaldas de luz nocturnas" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Crossback Nogal</h2>
            <p class="section__subtitle">Combinaciones de mesa, mantelería e iluminación que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Jardín Nocturna</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback nogal + <strong>mantel blanco lino hasta el piso</strong> + centro de mesa alto con flores blancas y ramas de eucalipto + guirnaldas Edison. El contraste chocolate-blanco bajo luz cálida es la combinación más solicitada para bodas jardín de noche.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Hacienda Otoñal</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback nogal + <strong>mantel terracota o burdeos</strong> + florería en tonos naranja, vino y dorado + velas pilares. Para haciendas con arquitectura colonial y eventos en temporada otoño-invierno (noviembre a febrero).
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Oscura</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Crossback nogal + <strong>mantel negro + runner dorado</strong> + candelabros de plata + flores blancas. Para cenas de gala corporativas o bodas con paleta monocromática oscura donde el nogal se mimetiza con el negro del mantel creando un efecto uniforme.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Crossback Nogal Oscuro</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Crossback Nogal Oscuro"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Tintura nogal penetrante, resistencia de 160 kg y precio desde $38 por silla. Aquí resolvemos las dudas sobre nuestra Crossback nogal oscuro.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Crossback te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Crossback nogal oscuro`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Crossback y servicios relacionados">
