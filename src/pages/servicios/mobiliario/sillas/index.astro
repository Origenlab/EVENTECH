---
/**
 * ─── EVENTECH.MX — Renta de Sillas para Eventos (L3, rediseño 2026) ───
 * Tiffany · Chiavari · Ghost · Crossback · Plegables — CDMX y ZMVM
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "tiffany",
    name: "Sillas Tiffany",
    badge: "La más solicitada",
    excerpt: "Resina reforzada con estructura de acero, 180 kg de resistencia y 4 acabados de alta demanda: dorado champagne, plateado espejo, blanco mate y transparente cristal. La silla que define la estética de bodas y galas en CDMX.",
    href: "/servicios/mobiliario/sillas/tiffany/",
    image: "/images/mobiliario/sillas-tiffany-salon-banquete-boda.avif",
    subcategories: [
      { name: "Dorada Champagne", href: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/" },
      { name: "Plateada Espejo", href: "/servicios/mobiliario/sillas/tiffany/plateada-espejo/" },
      { name: "Blanca Mate", href: "/servicios/mobiliario/sillas/tiffany/blanca-mate/" },
      { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/tiffany/transparente-cristal/" },
    ],
  },
  {
    id: "chiavari",
    name: "Sillas Chiavari",
    badge: "Calidad italiana",
    excerpt: "Aluminio anodizado de solo 1.8 kg por unidad con carga certificada de 200 kg — la mayor resistencia de nuestra colección. 4 acabados y más de 30 colores de cojín disponibles para personalización total.",
    href: "/servicios/mobiliario/sillas/chiavari/",
    image: "/images/mobiliario/sillas-chiavari-doradas-boda-lujo.avif",
    subcategories: [
      { name: "Chiavari Dorada", href: "/servicios/mobiliario/sillas/chiavari/dorada/" },
      { name: "Chiavari Plateada", href: "/servicios/mobiliario/sillas/chiavari/plateada/" },
      { name: "Chiavari Negra", href: "/servicios/mobiliario/sillas/chiavari/negra/" },
      { name: "Chiavari Bronce", href: "/servicios/mobiliario/sillas/chiavari/bronce/" },
    ],
  },
  {
    id: "ghost",
    name: "Sillas Ghost",
    badge: "Diseño contemporáneo",
    excerpt: "Policarbonato virgen de 3.5 mm inspirado en el Louis Ghost de Philippe Starck. Transparencia cristalina que amplía visualmente cualquier espacio. Resistente a UV para exteriores, disponible en cristal, humo y ámbar.",
    href: "/servicios/mobiliario/sillas/ghost/",
    image: "/images/mobiliario/sillas-ghost-transparentes-boda-exterior.avif",
    subcategories: [
      { name: "Ghost Transparente", href: "/servicios/mobiliario/sillas/ghost/transparente/" },
      { name: "Ghost Humo", href: "/servicios/mobiliario/sillas/ghost/humo/" },
      { name: "Ghost Ámbar", href: "/servicios/mobiliario/sillas/ghost/ambar/" },
      { name: "Ghost Exterior", href: "/servicios/mobiliario/sillas/ghost/exterior/" },
    ],
  },
  {
    id: "crossback",
    name: "Sillas Crossback",
    badge: "Favorita de jardines",
    excerpt: "Madera de álamo macizo con respaldo entrecruzado en X y resistencia de 160 kg. La favorita indiscutible para bodas rústicas en haciendas, viñedos y jardines. 4 acabados naturales con cojín de arpillera incluido.",
    href: "/servicios/mobiliario/sillas/crossback/",
    image: "/images/mobiliario/sillas-crossback-madera-boda-vineyard.avif",
    subcategories: [
      { name: "Crossback Natural", href: "/servicios/mobiliario/sillas/crossback/natural/" },
      { name: "Crossback Nogal", href: "/servicios/mobiliario/sillas/crossback/nogal/" },
      { name: "Crossback Blanco Vintage", href: "/servicios/mobiliario/sillas/crossback/blanco-vintage/" },
      { name: "Crossback Caoba", href: "/servicios/mobiliario/sillas/crossback/caoba/" },
    ],
  },
  {
    id: "plegables",
    name: "Sillas Plegables",
    badge: "Solución para masivos",
    excerpt: "Tres líneas para tres necesidades: plástico reforzado para eventos de 500+ personas, madera barnizada con asiento acolchado para ceremonias, y Napoleón en resina con acabado metálico para eventos que exigen elegancia con movilidad.",
    href: "/servicios/mobiliario/sillas/plegables/",
    image: "/images/mobiliario/sillas-plegables-kit-masivo-evento.avif",
    subcategories: [
      { name: "Plegable Plástico", href: "/servicios/mobiliario/sillas/plegables/plastico/" },
      { name: "Plegable Madera", href: "/servicios/mobiliario/sillas/plegables/madera/" },
      { name: "Plegable Napoleón", href: "/servicios/mobiliario/sillas/plegables/napoleon/" },
      { name: "Plegable Apilable", href: "/servicios/mobiliario/sillas/plegables/apilable/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🪑",
    title: "Inventario propio — sin subcontratistas",
    body: "Más de 10,000 sillas propias en bodega CDMX. No intermediamos con otros proveedores. Lo que cotizamos es lo que existe en nuestro almacén, verificado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    icon: "🎨",
    title: "Cojines incluidos en el precio",
    body: "Cada silla Tiffany, Chiavari y Crossback incluye cojín acolchado en el color de tu elección sin costo adicional. Más de 30 colores en tela y lycra disponibles. Las Ghost y Plegables llevan funda estándar si se requiere.",
  },
  {
    icon: "🚚",
    title: "Entrega puntual con colocación en mesa",
    body: "Nuestro equipo logístico entrega y coloca cada silla en la posición exacta según el layout aprobado — no dejamos la mercancía en la puerta. Llegamos con tiempo suficiente antes del evento para que el venue quede listo sin contratiempos.",
  },
  {
    icon: "🔍",
    title: "Revisión pieza por pieza antes de salir de bodega",
    body: "Toda silla pasa por protocolo de inspección: estructura, acabado, cojín, patas y sistema de apilado. Las unidades con rayones, manchas o fallas mecánicas se separan y reemplazan antes de cargar el camión. Lo que llega a tu evento está impecable.",
  },
  {
    icon: "🔄",
    title: "Reposición en sitio garantizada",
    body: "Si durante el montaje detectamos una silla dañada o un color incorrecto, la reponemos sin costo dentro de CDMX. Siempre cargamos un porcentaje de reposición en cada servicio para que no te descubras con una pieza faltante minutos antes del evento.",
  },
  {
    icon: "🎯",
    title: "Asesoría para combinar modelos",
    body: "Mezclar Tiffany en la mesa principal con Crossback para invitados es una decisión de diseño, no de presupuesto. Te asesoramos con referencias visuales reales de combinaciones que funcionan — para que el resultado sea coherente y fotogénico.",
  },
];

const steps = [
  { n: 1, t: "Cotización y aparto de inventario", p: "Nos indicas modelo, cantidad, color de cojín y fecha. En menos de 24 horas te confirmamos disponibilidad y te enviamos propuesta. Con el 30% de anticipo apartamos tu inventario — sin pago total por adelantado." },
  { n: 2, t: "Coordinación con venue y otros proveedores", p: "Si trabajas con decoradora, wedding planner o el propio salón, coordinamos directamente con ellos. Compartimos layout de entrega, horario de acceso y requerimientos logísticos para que el montaje sea limpio y sin conflictos." },
  { n: 3, t: "Entrega, montaje y verificación en sitio", p: "Llegamos el día del evento o la tarde anterior según acuerdo. Cada silla se coloca en su posición, el cojín se instala correctamente y hacemos verificación visual del montaje completo antes de retirarnos. Tú o tu coordinador firman conformidad." },
  { n: 4, t: "Recolección al finalizar el evento", p: "Al cierre, nuestro equipo recoge, apila y carga todas las sillas. Conteo final en conjunto para confirmar que no falta ninguna pieza. Sin presiones de tiempo si el evento se extiende — acordamos horario de recolección con anticipación." },
];

const faqs = [
  {
    question: "¿Cuál es la diferencia entre silla Tiffany y Chiavari?",
    answer: "Las Tiffany están fabricadas en resina de policarbonato con estructura de acero inoxidable — son más pesadas (aprox. 4.5 kg) y tienen el icónico respaldo ovalado con barras verticales. Las Chiavari son de aluminio anodizado (1.8 kg por unidad) con respaldo angular y barras torneadas de diseño italiano. Ambas son elegantes y admiten cojines de colores, pero las Chiavari son más ligeras para logística y las Tiffany tienen mayor presencia visual clásica. Para bodas formales en salón la diferencia es de estética personal; ambas son excelentes.",
  },
  {
    question: "¿Las sillas Ghost se pueden usar en exteriores?",
    answer: "Sí. El policarbonato es resistente a rayos UV y a temperatura. Sin embargo, en jardines con viento recomendamos no dejar las sillas desocupadas mucho tiempo antes del evento porque al ser ligeras (aprox. 4.2 kg) pueden moverse. Son ideales bajo carpa donde lucen espectaculares con iluminación. Para exteriores sin techo en zonas con viento fuerte, las Crossback o Chiavari ofrecen mayor estabilidad por su mayor peso.",
  },
  {
    question: "¿Cuántas sillas necesito para mi evento?",
    answer: "Regla general: una silla por invitado confirmado más 10% de colchón. Si tu evento tiene ceremonia y recepción en zonas separadas, necesitas sillas para ambas áreas. Para ceremonias en auditorio o iglesia donde se hacen filas, los plegables plásticos son los más eficientes logísticamente. Para recepción en mesas redondas, calcula la cantidad de sillas según la capacidad por mesa según el diámetro elegido — te ayudamos a hacer el cálculo exacto.",
  },
  {
    question: "¿Puedo mezclar diferentes modelos en el mismo evento?",
    answer: "Sí, y muchos de nuestros clientes lo hacen con excelentes resultados. Algunas combinaciones populares: Tiffany dorada en mesa principal + Chiavari dorada para invitados; Crossback natural para mesas + sillas Ghost para área lounge; Chiavari plateada para evento principal + Napoleón para área de cocktail. Lo importante es que los acabados sean coherentes entre sí. Te enviamos referencias visuales de combinaciones reales que hemos montado.",
  },
  {
    question: "¿El precio de renta incluye cojines, montaje y recolección?",
    answer: "Sí. El precio cotizado incluye la silla con cojín en el color elegido, entrega al venue, colocación en cada mesa según layout, verificación de montaje y recolección al finalizar. Dentro de CDMX no hay cargo logístico adicional. Para Zona Metropolitana (Naucalpan, Tlalnepantla, Ecatepec, Neza, etc.) el costo de transporte se especifica en la cotización.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Para eventos medianos (hasta 200 sillas), 2 a 3 semanas de anticipación es suficiente. Para eventos grandes (300+ sillas) o si requieres un modelo y color muy específico, recomendamos 4 a 6 semanas. En temporada alta de bodas (noviembre a febrero) y en fines de semana con múltiples eventos simultáneos, 6 a 8 semanas es lo ideal para garantizar el inventario completo en el modelo exacto.",
  },
  {
    question: "¿Qué pasa si se daña una silla durante el evento?",
    answer: "Daños accidentales durante el uso normal del evento están cubiertos dentro de un porcentaje de tolerancia estándar. Los daños mayores o negligentes se cobran según el valor de reposición especificado en el contrato — el cual se entrega junto con la cotización para que sea claro desde el inicio. Siempre hacemos el conteo y verificación de daños en conjunto con el cliente al momento de la recolección, no de forma unilateral.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Sillas para Eventos en CDMX",
    description: "Renta de sillas Tiffany, Chiavari, Ghost, Crossback y plegables para bodas, XV años, corporativos y eventos sociales en CDMX. Entrega, montaje y cojines incluidos.",
    url: "/servicios/mobiliario/sillas/",
    priceRange: { min: 15, max: 95 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas para Eventos", url: "/servicios/mobiliario/sillas/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas para Eventos" },
];
---

<PageLayout
  title="Renta de Sillas para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif"
  description="Renta de sillas Tiffany, Chiavari, Ghost, Crossback y plegables en CDMX. +10,000 unidades en inventario. Cojines y montaje incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="sillas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Sillas para eventos · CDMX y ZMVM</p>
            <h1 id="sillas-hero-heading">
              Más de <em>10,000 sillas en inventario</em> — el catálogo más completo de CDMX
            </h1>
            <p class="hm-hero__lead">
              Tiffany, Chiavari, Ghost, Crossback y Plegables. Cojines incluidos
              en el color que elijas, entrega puntual, montaje profesional y recolección
              al finalizar. Una sola empresa para todas las sillas que tu evento necesita.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20sillas%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar sillas
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>sillas para eventos</strong> con el inventario propio
              más grande de la Ciudad de México — más de 10,000 unidades en 5 líneas distintas,
              sin subcontratar ni intermediar. Tiffany en 4 acabados, Chiavari de aluminio
              italiano, Ghost de policarbonato transparente, Crossback de madera maciza y
              Plegables en 3 versiones para eventos masivos. Cada silla se entrega verificada,
              con cojín incluido y colocada en la posición exacta de tu layout.
            </p>
            <p>
              Con <strong>cientos de eventos montados</strong> en CDMX, conocemos las
              diferencias que separan un montaje bien ejecutado de uno que solo cumple con
              la cantidad: revisión pieza a pieza, reposición garantizada en sitio, y un
              equipo que llega a tiempo para que tu coordinadora o wedding planner no
              tenga que perseguir al proveedor de sillas. Para bodas que también requieren
              <a href="/servicios/mobiliario/mesas/">mesas redondas o rectangulares</a> te
              cotizamos el paquete completo desde una sola empresa, sin duplicar logística. Y si tu
              evento es campestre, las <a href="/servicios/mobiliario/mesas-picnic/">mesas picnic y
              farm de madera</a> combinan de forma natural con las sillas Crossback.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de silla disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20sillas%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué tipo de silla necesita tu evento?</h2>
            <p class="hm__head-sub">5 líneas, múltiples acabados y colores — la silla perfecta para cada estilo y presupuesto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La silla es el objeto que más tiempo ocupa un invitado durante cualquier
              evento. No es decoración de fondo — es el punto de contacto físico que
              define si alguien estuvo cómodo o incómodo, y si las fotos del salón
              transmiten la estética que planeaste. Elegir el modelo correcto no es
              cuestión de presupuesto solamente: es decidir qué historia visual
              quieres contar y cómo quieres que se sientan tus invitados.
            </p>
            <p>
              Tiffany para bodas de salón con acabado clásico. Chiavari cuando importa
              el detalle de calidad italiana. Ghost para eventos contemporáneos donde
              el espacio y la luz son protagonistas. Crossback cuando el venue es una
              hacienda o jardín y la madera natural forma parte del concepto. Plegables
              cuando la escala del evento exige practicidad sin sacrificar presentación.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada línea, a fondo</p>
            <h2 id="detalle-heading">Las 5 líneas de sillas — en detalle</h2>
            <p class="hm__head-sub">Materiales, resistencia, opciones de acabado y para qué tipo de evento funciona mejor cada modelo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada modelo de silla hay decisiones de diseño que afectan la
              experiencia del evento: el peso que determina qué tan rápido se puede
              montar y desmontar, el acabado que define si las fotos del salón tienen
              cohesión visual, la resistencia que marca cuánto tiempo dura sin
              deterioro, y el material que decide si puedes usarla en exteriores
              sin preocuparte por lluvia o rayos UV.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo
              por precio. A continuación, lo que realmente importa de cada línea.
            </p>
          </div>
        </div>

        <!-- TIFFANY -->
        <article class="hm-feat" aria-labelledby="feat-tiffany">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Sillas Tiffany</p>
            <h3 class="hm-feat__title" id="feat-tiffany">El clásico atemporal — la silla de bodas y galas más solicitada en la Ciudad de México</h3>
            <p class="hm-feat__lead">No existe salón de banquetes en CDMX que no haya recibido sillas Tiffany. Hay una razón para eso: ningún otro modelo combina esa presencia visual clásica con la practicidad operativa que los grandes eventos exigen.</p>
            <p>
              Fabricadas en <strong>resina de policarbonato con estructura interna de acero
              inoxidable</strong>, soportan hasta <strong>180 kg por unidad</strong> sin
              flexión perceptible. El icónico respaldo ovalado con barras verticales torneadas
              funciona igual bajo una iluminación de cóctel cálida que bajo los focos
              directos de una gala corporativa. Disponibles en <strong>dorado champagne,
              plateado espejo, blanco mate y transparente cristal</strong> — los cuatro
              acabados que cubren el 90% de los pedidos de boda en CDMX.
            </p>
            <p>
              Cada unidad incluye <strong>cojín acolchado premium de 4 cm de grosor</strong>
