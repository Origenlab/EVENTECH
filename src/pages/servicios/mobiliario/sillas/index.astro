    subheadline="Más de 10,000 sillas en inventario y 500+ eventos exitosos nos respaldan. Cotiza hoy y recibe asesoría sin compromiso."
    primaryCTA={{ label: "Cotizar sillas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sillas para mi evento` }}
    variant="accent"
  />
</PageLayout>

