---
/**
 * ─── Sillas para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Sillas para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas" },
];

const SILLAS = [
  {
    name: "Sillas Tiffany",
    excerpt: "El clásico atemporal en acabado dorado, plateado, blanco y transparente. Resistencia de 180 kg y diseño icónico para bodas y galas.",
    cta: "Tiffany",
    href: "/servicios/mobiliario/sillas/tiffany/",
    icon: "crown",
  },
  {
    name: "Sillas Chiavari",
    excerpt: "Aluminio ultraligero de 1.8 kg con carga de 200 kg. Más de 30 colores de cojín disponibles para personalizar tu evento.",
    cta: "Chiavari",
    href: "/servicios/mobiliario/sillas/chiavari/",
    icon: "award",
  },
  {
    name: "Sillas Ghost",
    excerpt: "Policarbonato transparente de 3.5 mm con diseño Philippe Starck. Perfectas para eventos contemporáneos y minimalistas.",
    cta: "Ghost",
    href: "/servicios/mobiliario/sillas/ghost/",
    icon: "layers",
  },
  {
    name: "Sillas Crossback",
    excerpt: "Madera de álamo con respaldo entrecruzado y resistencia de 160 kg. La favorita para bodas rústicas y jardines.",
    cta: "Crossback",
    href: "/servicios/mobiliario/sillas/crossback/",
    icon: "heart",
  },
  {
    name: "Sillas Plegables",
    excerpt: "La solución práctica en 3 líneas: plástico reforzado, madera barnizada y estilo Napoleón. Ideales para eventos masivos.",
    cta: "Plegables",
    href: "/servicios/mobiliario/sillas/plegables/",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre sillas Tiffany y Chiavari?", answer: "Las sillas Tiffany tienen un diseño con respaldo ovalado y barras verticales, generalmente fabricadas en resina reforzada con acero. Las Chiavari tienen un respaldo más angular con barras torneadas, fabricadas en aluminio ultraligero. Ambas son elegantes, pero las Tiffany tienen un look más clásico y las Chiavari son más ligeras y fáciles de apilar." },
  { question: "¿Cuántas sillas necesito para mi evento?", answer: "La regla general es 1 silla por invitado confirmado más un 10% adicional para imprevistos. Si tu evento incluye ceremonia y recepción en diferentes áreas, necesitarás sillas para ambos espacios. Nuestro equipo te ayuda a calcular la cantidad exacta según el layout de tu venue." },
  { question: "¿Las sillas Ghost se pueden usar al aire libre?", answer: "Sí. Las sillas Ghost están fabricadas en policarbonato de alta resistencia que soporta rayos UV y condiciones de intemperie. Sin embargo, recomendamos anclarlas o colocar peso adicional en jardines con viento, ya que son más ligeras que otros modelos. Son ideales bajo carpas donde lucen espectaculares." },
  { question: "¿Se pueden combinar diferentes modelos de sillas en un mismo evento?", answer: "Por supuesto. Muchos de nuestros clientes combinan modelos para crear zonas diferenciadas: Tiffany o Chiavari para la mesa principal, Crossback para las mesas de invitados en bodas rústicas, y Ghost para áreas lounge. Nuestros asesores te orientan para que la combinación sea armoniosa." },
  { question: "¿El precio de renta incluye montaje y desmontaje?", answer: "Sí, todos nuestros paquetes de sillas incluyen entrega, montaje profesional con colocación de cojines, y recolección posterior al evento sin costo adicional dentro de CDMX. Para ubicaciones en Zona Metropolitana, el costo de logística se detalla en tu cotización personalizada." },
  { question: "¿Con cuánta anticipación debo reservar las sillas?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente para modelos populares como Tiffany y Chiavari en temporada alta (noviembre a febrero). Para eventos grandes de más de 300 sillas, lo ideal es apartar con 1 a 2 meses de anticipación para garantizar disponibilidad del modelo y color exacto." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Sillas para Eventos en CDMX",
    description: "Sillas Tiffany, Chiavari, Ghost, Crossback y plegables para bodas, XV años y corporativos. Entrega y montaje incluido en CDMX.",
    url: "/servicios/mobiliario/sillas/",
    priceRange: { min: 15, max: 120 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Sillas para Eventos en CDMX"
  description="Renta de sillas Tiffany, Chiavari, Ghost, Crossback y plegables para eventos en CDMX. Desde $15 por silla. Entrega y montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 10,000 sillas en inventario"
    title='Renta de <span class="highlight">Sillas para Eventos</span> en CDMX'
    subtitle="Sillas Tiffany, Chiavari, Ghost, Crossback y plegables con cojines incluidos. La silla perfecta para cada estilo y presupuesto. Entrega, montaje y asesoría incluidos."
    primaryCTA={{ label: "Cotiza tus sillas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sillas para mi evento` }}
    cards={[
      {
        title: "La silla perfecta para cada tipo de evento",
        content: "<strong>Renta de sillas para eventos</strong> con el catálogo más completo de CDMX. Sillas Tiffany en acabado dorado, plateado, blanco y transparente para bodas y galas. Chiavari de aluminio ultraligero con más de 30 opciones de cojín. Ghost de policarbonato para diseños contemporáneos. Crossback de madera para celebraciones rústicas en haciendas y jardines. Plegables en tres líneas para eventos masivos — cada modelo verificado en resistencia, acabado y comodidad antes de cada entrega.",
      },
      {
        title: "Servicio integral con cojines y montaje incluidos",
        content: "<strong>Servicio completo de sillas</strong> que cubre cada detalle logístico. Cada silla incluye cojín acolchado en el color de tu elección sin costo extra. Nuestro equipo profesional realiza la entrega puntual, montaje en cada mesa según el layout aprobado y recolección al finalizar. Te asesoramos para calcular cantidades exactas, elegir el modelo ideal según tu estilo y optimizar la distribución para máxima comodidad de tus invitados.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la silla ideal para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con el modelo perfecto para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 5 tipos de silla
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Sillas"
        subtitle="El modelo ideal para cada estilo de evento"
        description={[
          "Contamos con el inventario de sillas más completo de la Ciudad de México. Más de 10,000 unidades disponibles en 5 líneas distintas, cada una con múltiples acabados y colores de cojín.",
          "Desde la elegancia clásica de las Tiffany hasta la funcionalidad de las plegables, encontrarás la silla perfecta para cualquier tipo de celebración y presupuesto."
        ]}
      />

      <div class="grid grid--4">
        {SILLAS.map((silla) => (
          <Card
            name={silla.name}
            excerpt={silla.excerpt}
            cta={silla.cta}
            href={silla.href}
            icon={silla.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS TIFFANY — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tiffany-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">La más popular</span>
          <h2 class="showcase__title" id="tiffany-heading">Sillas Tiffany</h2>
          <p class="showcase__subtitle">El clásico atemporal que define la elegancia en cualquier evento formal.</p>
          <p class="showcase__text">La <strong>silla Tiffany</strong> es el modelo más solicitado para bodas, XV años y galas corporativas en CDMX. Disponible en 4 acabados de alta demanda: <strong>dorado champagne, plateado espejo, blanco mate y transparente cristal</strong>. Cada unidad está fabricada en resina de policarbonato reforzada con estructura interna de acero inoxidable, garantizando una resistencia de <strong>180 kg por silla</strong>.</p>
          <p class="showcase__text">Incluye <strong>cojín acolchado premium</strong> en más de 20 colores de tela (blanco, marfil, negro, dorado, champagne, rosa blush y más). El diseño icónico con respaldo ovalado y barras verticales aporta sofisticación instantánea a tu montaje. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para un evento impecable.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Dorado Champagne</span>
            <span class="showcase__tag">Plateado Espejo</span>
            <span class="showcase__tag">Blanco Mate</span>
            <span class="showcase__tag">Transparente</span>
          </div>
          <a href="/servicios/mobiliario/sillas/tiffany/" class="btn btn--primary btn--lg">
            Ver Sillas Tiffany
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS CHIAVARI — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="chiavari-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Calidad italiana</span>
          <h2 class="showcase__title" id="chiavari-heading">Sillas Chiavari</h2>
          <p class="showcase__subtitle">Aluminio ultraligero con la elegancia del diseño clásico italiano.</p>
          <p class="showcase__text">La <strong>silla Chiavari</strong> combina tradición y tecnología: fabricada en <strong>aluminio anodizado de solo 1.8 kg</strong> por unidad, soporta hasta <strong>200 kg de carga</strong> — la mayor resistencia de nuestra colección. Su perfil angular con barras torneadas y acabado metalizado la convierte en la favorita para eventos corporativos premium y bodas de revista.</p>
          <p class="showcase__text">Disponible en acabados <strong>dorado, plateado, negro mate y bronce</strong>. Cada silla incluye <strong>cojín intercambiable en más de 30 colores</strong> de tela, lycra y terciopelo. Su diseño apilable facilita la logística en venues de gran formato. Realza su presencia con nuestra <a href="/servicios/iluminacion/">iluminación arquitectónica</a> para un efecto visual espectacular.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Aluminio 1.8 kg</span>
            <span class="showcase__tag">200 kg carga</span>
            <span class="showcase__tag">30+ colores cojín</span>
            <span class="showcase__tag">Apilable</span>
          </div>
          <a href="/servicios/mobiliario/sillas/chiavari/" class="btn btn--primary btn--lg">
            Ver Sillas Chiavari
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS GHOST — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="ghost-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Diseño contemporáneo</span>
          <h2 class="showcase__title" id="ghost-heading">Sillas Ghost</h2>
          <p class="showcase__subtitle">Policarbonato transparente que desaparece en el espacio y deja brillar tu decoración.</p>
          <p class="showcase__text">La <strong>silla Ghost</strong> (inspirada en el diseño Louis Ghost de Philippe Starck) es la elección predilecta para eventos contemporáneos, minimalistas y de diseño. Fabricada en <strong>policarbonato virgen de 3.5 mm de espesor</strong>, ofrece una resistencia de <strong>130 kg</strong> con transparencia cristalina que aporta amplitud visual a cualquier espacio.</p>
          <p class="showcase__text">Disponible en <strong>transparente cristal, humo y ámbar</strong>. Su perfil elegante con respaldo medallón la convierte en protagonista de sesiones fotográficas. Resistente a rayos UV para uso en exteriores. Combínalas bajo nuestras <a href="/servicios/carpas/">carpas profesionales</a> para un efecto visual que impresiona en cada ángulo.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Policarbonato 3.5mm</span>
            <span class="showcase__tag">Transparente Cristal</span>
            <span class="showcase__tag">Humo</span>
            <span class="showcase__tag">Ámbar</span>
          </div>
          <a href="/servicios/mobiliario/sillas/ghost/" class="btn btn--primary btn--lg">
            Ver Sillas Ghost
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS CROSSBACK — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="crossback-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Favorita bodas rústicas</span>
          <h2 class="showcase__title" id="crossback-heading">Sillas Crossback</h2>
          <p class="showcase__subtitle">Madera natural con respaldo entrecruzado que evoca calidez y autenticidad.</p>
          <p class="showcase__text">La <strong>silla Crossback</strong> (también conocida como "X-back" o "vineyard chair") es la favorita indiscutible para bodas rústicas en haciendas, jardines y viñedos. Fabricada en <strong>madera de álamo macizo</strong> con acabado barnizado a mano, soporta hasta <strong>160 kg</strong>. Su icónico respaldo en forma de X aporta un encanto campestre que no se logra con ningún otro modelo.</p>
          <p class="showcase__text">Disponible en acabados <strong>natural, nogal oscuro, blanco vintage y caoba</strong>. Incluye <strong>cojín de arpillera o tela lisa</strong> en tonos neutros. Es la compañera perfecta de mesas de madera y decoración con flores silvestres. Complementa con nuestros <a href="/servicios/accesorios/">accesorios decorativos</a> como caminos de mesa de yute y portavelas para un look rústico completo.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Madera de Álamo</span>
            <span class="showcase__tag">Natural</span>
            <span class="showcase__tag">Nogal Oscuro</span>
            <span class="showcase__tag">Blanco Vintage</span>
          </div>
          <a href="/servicios/mobiliario/sillas/crossback/" class="btn btn--primary btn--lg">
            Ver Sillas Crossback
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SILLAS PLEGABLES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="plegables-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">La solución práctica</span>
          <h2 class="showcase__title" id="plegables-heading">Sillas Plegables</h2>
          <p class="showcase__subtitle">Funcionalidad, resistencia y precio accesible en 3 líneas para eventos de cualquier tamaño.</p>
          <p class="showcase__text">Nuestras <strong>sillas plegables</strong> están disponibles en 3 líneas diseñadas para diferentes necesidades. La <strong>línea Plástico Reforzado</strong> es la más económica y resistente para eventos masivos de 500+ personas. La <strong>línea Madera Barnizada</strong> con asiento acolchado ofrece un look más cálido para ceremonias religiosas y conferencias. La <strong>línea Napoleón</strong> en resina con acabado metálico combina elegancia y portabilidad.</p>
          <p class="showcase__text">Todas las líneas son <strong>apilables y fáciles de transportar</strong>, ideales para montajes rápidos. La línea Plástico soporta <strong>150 kg</strong>, la Madera <strong>120 kg</strong> y la Napoleón <strong>140 kg</strong>. Son perfectas bajo nuestras <a href="/servicios/carpas/">carpas</a> para eventos al aire libre. Combínalas con <a href="/servicios/iluminacion/">iluminación</a> ambiental para elevar cualquier espacio con presupuesto accesible.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Plástico Reforzado</span>
            <span class="showcase__tag">Madera Barnizada</span>
            <span class="showcase__tag">Napoleón</span>
            <span class="showcase__tag">Apilables</span>
          </div>
          <a href="/servicios/mobiliario/sillas/plegables/" class="btn btn--primary btn--lg">
            Ver Sillas Plegables
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
              <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
              <path d="M5 21v-2"/>
              <path d="M19 21v-2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Sillas"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus sillas, es natural tener preguntas sobre modelos, capacidades, personalización y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor especializado te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre sillas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de sillas para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
