---
/**
 * ─── Silla Tiffany Transparente Cristal — Página de Variante (Nivel 4) ───
 * Silueta clásica Tiffany en policarbonato cristal transparente.
 * Rooftops CDMX, eventos contemporáneos, bodas modernas. Terraza WTC, Rooftop Condesa.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Tiffany > Transparente Cristal
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { label: "Transparente Cristal" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-tiffany-transparente-terraza-cdmx-01.avif", alt: "Silla Tiffany transparente cristal en terraza CDMX con skyline" },
  { src: "/images/mobiliario/silla-tiffany-transparente-skyline-02.avif", alt: "Tiffany transparente cristal con skyline de CDMX al fondo" },
  { src: "/images/mobiliario/silla-tiffany-transparente-cdmx-noche-03.avif", alt: "Sillas Tiffany transparentes en CDMX de noche" },
  { src: "/images/mobiliario/silla-tiffany-transparente-rooftop-cdmx-04.avif", alt: "Tiffany transparente cristal en rooftop CDMX" },
  { src: "/images/mobiliario/silla-tiffany-transparente-cdmx-dusk-05.avif", alt: "Silla Tiffany transparente en CDMX al atardecer" },
  { src: "/images/mobiliario/silla-tiffany-transparente-cdmx-night-06.avif", alt: "Tiffany transparente cristal en evento nocturno CDMX" },
];

const faqs = [
  {
    question: "¿Cuál es la diferencia entre la silla Tiffany transparente y la silla Ghost?",
    answer: "Es una pregunta que recibimos mucho. La <strong>silla Ghost</strong> tiene un respaldo medallón ovalado sólido y un diseño más orgánico inspirado en el Luis XVI — es un producto de diseño con silueta muy reconocible. La <strong>Tiffany transparente</strong> mantiene el respaldo característico de la Tiffany: ovalado con barras verticales y estructura angular — esa es su identidad. Ambas son policarbonato transparente, pero la silueta es completamente diferente. Si quieres el look Tiffany clásico en versión contemporánea, la transparente es tu opción."
  },
  {
    question: "¿Para qué tipo de eventos funciona mejor la Tiffany transparente cristal?",
    answer: "La Tiffany transparente es la elección ideal cuando <strong>el entorno es parte del diseño</strong>. En rooftops del WTC CDMX o Rooftop Condesa, el skyline de la ciudad se convierte en el fondo perfecto — la silla transparente no bloquea esa vista sino que la encuadra. Es también la favorita para <strong>lanzamientos de marca, showrooms, eventos de moda y bodas contemporáneas</strong> donde la fotografía es central. La transparencia hace que el mantel, las flores y la decoración sean los protagonistas absolutos."
  },
  {
    question: "¿La Tiffany transparente se ve bien con o sin cojín?",
    answer: "Las dos opciones tienen personalidad propia. <strong>Sin cojín</strong> es el look más contemporáneo y arquitectónico — la silla flota visualmente sobre el suelo y el espacio parece más abierto. Es la opción preferida para eventos de diseño, showrooms y venues con suelos muy especiales (mármol, madera premium) donde quieres que el piso sea visible. <strong>Con cojín</strong>, el blanco y el negro son los más pedidos por el contraste limpio. El cojín blanco da un look más suave; el negro da un look más dramático y editorial. Sin cojín es ideal para eventos de 2 horas o menos; con cojín para cenas largas."
  },
  {
    question: "¿La silla transparente se ensucia o raya fácilmente?",
    answer: "La resina policarbonato transparente de alta densidad que usamos es <strong>resistente a arañazos superficiales</strong> del uso normal. Cada silla se inspecciona antes de entregarse y se excluyen las unidades con marcas visibles. Dicho esto, el transparente muestra huellas de manos con más facilidad que el dorado o plateado — por eso cada silla se limpia con paño de microfibra antes de colocarla. Para eventos de 400+ personas donde la manipulación es frecuente, te recomendamos incluir un servicio de limpieza rápida durante el evento (disponible con cargo adicional)."
  },
  {
    question: "¿Cuánto cuesta rentar 100 sillas Tiffany transparentes para un rooftop en Condesa?",
    answer: "Para <strong>100 sillas Tiffany transparentes</strong>, el rango de precio estimado es $4,500-$5,500 (desde $45-55/unidad en ese volumen). Sin cojín el precio puede ser ligeramente menor; con cojín blanco o negro el precio incluye la tela. Para rooftops en Condesa, consideramos siempre el acceso (escaleras vs. elevador de servicio) en la logística — esto no genera cargo extra dentro de CDMX pero sí necesitamos saberlo al cotizar. Solicita tu cotización por WhatsApp y te respondemos con precio exacto en menos de 30 minutos."
  },
];

const specs = [
  { label: "Acabado", value: "Transparente Cristal — policarbonato cristal de alta densidad sin pigmento" },
  { label: "Material", value: "Resina policarbonato cristal + estructura interna de acero inoxidable" },
  { label: "Resistencia", value: "180 kg por silla (certificado)" },
  { label: "Peso", value: "4.5 kg" },
  { label: "Altura total", value: "90 cm (respaldo)" },
  { label: "Ancho asiento", value: "40 cm" },
  { label: "Apilable", value: "Sí, hasta 10 unidades" },
  { label: "Cojín", value: "Opcional (incluido sin costo) — blanco, negro y 18+ colores más" },
  { label: "Certificación", value: "Anti-UV, ignífugo, apto exterior e interior" },
  { label: "Mantenimiento", value: "Limpieza con microfibra e inspección individual pre-evento" },
];

const reviews = [
  { author: "Diego Fuentes", text: "Usamos 80 Tiffany transparentes para el lanzamiento de una nueva línea de moda en la Terraza WTC. Sin cojín. El efecto fue exactamente el look que necesitábamos — moderno, limpio, fotogénico. Las sillas llegaron perfectas, sin ninguna marca.", rating: 5, date: "2025-10-22" },
  { author: "Sofía Ríos", text: "Boda en rooftop Condesa. 60 transparentes en la terraza exterior, 40 doradas en el salón interior. La combinación funcionó perfecto — afuera se veía el skyline y las sillas no competían con esa vista. Absolutamente recomendados.", rating: 5, date: "2025-08-30" },
  { author: "Pablo Navarro", text: "Showroom de autos de lujo en Santa Fe. 50 Tiffany transparentes con cojín negro. El auto era el protagonista y las sillas parecían casi inexistentes — exactamente lo que buscábamos. La transparencia es impresionante en persona.", rating: 5, date: "2025-07-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Tiffany Transparente Cristal para Eventos CDMX",
    description: "Sillas Tiffany transparente cristal para rooftops, lanzamientos y bodas contemporáneas en CDMX. Silueta Tiffany en policarbonato cristal. 180 kg. Cojín opcional. Desde $35/silla.",
    url: "/servicios/mobiliario/sillas/tiffany/transparente-cristal/",
    priceRange: { min: 35, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 22,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Tiffany", url: "/servicios/mobiliario/sillas/tiffany/" },
    { name: "Transparente Cristal", url: "/servicios/mobiliario/sillas/tiffany/transparente-cristal/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Dorada Champagne", href: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/" },
  { name: "Plateada Espejo", href: "/servicios/mobiliario/sillas/tiffany/plateada-espejo/" },
  { name: "Blanca Mate", href: "/servicios/mobiliario/sillas/tiffany/blanca-mate/" },
  { name: "Transparente Cristal", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Tiffany Transparente Cristal CDMX"
  description="Renta sillas Tiffany transparente cristal en CDMX — ideal para rooftops, lanzamientos y bodas contemporáneas."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La silueta Tiffany en versión contemporánea — ideal para rooftops CDMX"
    title='Silla Tiffany <span class="highlight">Transparente Cristal</span> — Renta en CDMX'
    subtitle="La silueta clásica de la Tiffany en policarbonato cristal transparente — cuando el entorno es parte del diseño. Rooftops del WTC, Condesa y venues contemporáneos. La silla que no compite: amplía el espacio visual y deja que la vista, las flores y la decoración brillen."
    primaryCTA={{ label: "Cotizar sillas Tiffany transparentes", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany transparentes cristal para mi evento` }}
    cards={[
      {
        title: "La silueta Tiffany que deja ver el skyline de CDMX",
        content: "La <strong>silla Tiffany transparente cristal</strong> mantiene el respaldo ovalado con barras verticales que define al modelo Tiffany, pero en policarbonato cristal sin pigmento. En rooftops como la Terraza WTC o el Rooftop Condesa, la silla enmarca la vista de la ciudad sin bloquearla — un efecto visual que ningún otro acabado logra. <strong>180 kg de resistencia</strong> sobre la misma estructura de acero inoxidable que todos los modelos Tiffany. La silla que hace que las fotos del evento parezcan de revista de diseño.",
      },
      {
        title: "Lanzamientos, showrooms y bodas donde la fotografía es protagonista",
        content: "Para eventos de moda, lanzamientos de marca, showrooms de autos o bodas modernas donde cada foto y cada video cuenta, la Tiffany transparente es la apuesta inteligente. <strong>La transparencia deja que el mantel, el centro de mesa, el piso y la decoración sean lo que ves primero</strong> — la silla actúa como marco invisible. Disponible con o sin cojín. Cojín blanco para un look suave; cojín negro para un look dramático. <strong>Desde $35/silla en lotes de 300+</strong>. Limpieza con microfibra antes de cada entrega.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Tiffany transparente — la silla que convierte rooftops en escenas de película"
    subheadline="Terraza WTC, Rooftop Condesa, showrooms y bodas modernas · Cristal sin pigmento · 180 kg"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Tiffany</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Tiffany transparentes para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany transparentes cristal`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA (primera sección del main) -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Tiffany Transparente en Rooftops y Eventos CDMX</h2>
            <p class="section__subtitle">Terraza WTC, Rooftop Condesa y venues contemporáneos en la Ciudad de México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Tiffany Transparente Cristal</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Tiffany Transparente: cuando la silla se convierte en parte de la arquitectura"
    headingId="descripcion-heading"
    badge="El look de revista para rooftops y lanzamientos"
    tags={["Transparente Cristal", "Rooftops CDMX", "Lanzamientos", "Bodas Modernas"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Tiffany Transparente"
  >
    <Fragment slot="body">
      <p class="showcase__text">En el diseño de interiores de lujo, hay un principio que los mejores organizadores de eventos conocen bien: <strong>los mejores muebles son los que no compiten, sino los que encuadran</strong>. La silla Tiffany transparente aplica ese principio a la perfección. En la Terraza WTC con el skyline de Insurgentes al fondo, o en un rooftop en Condesa rodeado de vegetación, la silla de cristal actúa como marco invisible que deja que el entorno hable.</p>
      <p class="showcase__text">La diferencia técnica con la <a href="/servicios/mobiliario/sillas/ghost/">silla Ghost</a> es la silueta: la Tiffany transparente mantiene el respaldo ovalado con barras verticales y la estructura angular que la identifican. No es una silla de diseño de autor — es la Tiffany clásica interpretada en su versión más contemporánea. Para eventos donde tienes fans del diseño entre los invitados, ese matiz importa.</p>
      <p class="showcase__text">El policarbonato cristal de alta densidad que usamos tiene <strong>tratamiento anti-UV</strong> — no amarillea con el tiempo ni con la exposición solar en exteriores. Cada unidad se limpia con paño de microfibra antes de colocarla. La misma estructura de acero inoxidable que todos los modelos Tiffany: <strong>180 kg de resistencia</strong> por silla.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-tiffany-transparente-terraza-cdmx-01.avif" alt="Silla Tiffany transparente cristal en terraza CDMX con vista al skyline" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-transparente-rooftop-cdmx-04.avif" alt="Tiffany transparente en rooftop nocturno CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-transparente-cdmx-night-06.avif" alt="Sillas Tiffany transparentes en evento nocturno CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Tiffany Transparente</h2>
            <p class="section__subtitle">Con cojín, sin cojín y las combinaciones que mejor funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Sin Cojín — Look Arquitectónico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany transparente <strong>sin cojín</strong> + mesa rectangular con mantel negro hasta el piso + florería blanca minimalista. El look más contemporáneo y editorial posible — la silla casi desaparece y el fondo (skyline, jardín, decoración) es lo que ves. Ideal para lanzamientos de marca y showrooms.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Con Cojín Blanco — Boda Moderna</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany transparente + <strong>cojín blanco</strong> + mesa redonda con mantel blanco y centro floral tropical. En rooftops y jardines modernos, el cojín blanco añade comfort sin restar contemporaneidad. La combinación más pedida para bodas contemporáneas al aire libre.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Con Cojín Negro — Evento de Lujo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany transparente + <strong>cojín negro</strong> + mesa redonda con mantel negro y veladora de cristal. El contraste cristal-negro es el más dramático y fotogénico de la colección — hace que cada foto nocturna del evento parezca sacada de un editorial de moda de lujo.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Tiffany Transparente Cristal</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Tiffany Transparente Cristal"
              subtitle="Ghost vs Tiffany, cojín sí o no, rooftops y logística"
              description={[
                "La Tiffany transparente tiene matices importantes que conviene entender antes de reservar. Aquí van las respuestas directas a las 5 preguntas que más recibimos.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
