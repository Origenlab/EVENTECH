---
/**
 * ─── Silla Tiffany Dorada Champagne — Página de Variante (Nivel 4) ───
 * El acabado #1 para bodas en CDMX: dorado intermedio entre oro brillante y beige.
 * 65% de las bodas que atendemos eligen este acabado.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Tiffany > Dorada Champagne
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { label: "Dorada Champagne" },
];

// Solo imágenes que sean del producto REAL — las demás se generarán con Whisk Subject+Scene
const galleryImages = [
  { src: "/images/mobiliario/DUAL-tiffany-boda-2.avif", alt: "Silla Tiffany dorada champagne en boda al aire libre hacienda CDMX" },
  { src: "/images/mobiliario/DUAL-tiffany-recepcion-1.avif", alt: "Silla Tiffany dorada champagne en recepción elegante" },
  { src: "/images/mobiliario/DUAL-tiffany-recepcion-2.avif", alt: "Montaje sillas Tiffany doradas en salón de boda CDMX" },
  { src: "/images/mobiliario/tiffany-dorada-champagne-03.avif", alt: "Sillas Tiffany doradas en ceremonia hacienda mexicana" },
  { src: "/images/mobiliario/tiffany-dorada-champagne-05.avif", alt: "Recepción con sillas Tiffany dorada champagne" },
  { src: "/images/mobiliario/real-wedding-chiavari-01.avif", alt: "Sillas chiavari doradas en boda real CDMX" },
];

const faqs = [
  {
    question: "¿Por qué el dorado champagne es el acabado más popular para bodas?",
    answer: "El <strong>dorado champagne</strong> es ese tono cálido que queda a medio camino entre el oro brillante y el beige — lo suficientemente dorado para aportar sofisticación, lo suficientemente discreto para no saturar el espacio. El 65% de las bodas que atendemos en CDMX eligen este acabado porque combina sin esfuerzo con blanco, marfil, rosa blush y tonos tierra. No compite con los arreglos florales ni con los manteles: los complementa."
  },
  {
    question: "¿Qué color de cojín va mejor con la silla Tiffany dorada?",
    answer: "Las tres combinaciones más pedidas son: <strong>dorada + cojín blanco</strong> para bodas clásicas (el blanco resalta el dorado sin contrastes bruscos), <strong>dorada + cojín champagne</strong> para un look monocromático y envolvente muy elegante, y <strong>dorada + cojín negro</strong> para galas corporativas o bodas con paleta oscura. Si tu boda tiene flores en rosa blush o nude, ese color también queda espectacular. Te enviamos muestras digitales antes de confirmar."
  },
  {
    question: "¿Cuánto cuestan 200 sillas Tiffany doradas para una boda en Hacienda de los Morales?",
    answer: "Para <strong>200 sillas Tiffany doradas champagne</strong>, el precio es aproximadamente $8,000-$10,000 (desde $40-50 por unidad a ese volumen). Incluye cojín acolchado en el color que elijas, entrega en CDMX, montaje según el plano del salón y desmontaje al final. Hacienda de los Morales es uno de los venues donde hemos montado con mayor frecuencia — conocemos sus restricciones de carga y tiempos. Solicita tu cotización exacta por WhatsApp."
  },
  {
    question: "¿La silla Tiffany dorada se ve bien en haciendas y jardines?",
    answer: "Es el acabado ideal para haciendas como Los Morales o Salón Pedregal precisamente porque el dorado champagne tiene calidez orgánica. La resina policarbonato es <strong>resistente a rayos UV</strong> — no se decolora con la luz solar. En jardines, te recomendamos pedir los niveladores de pata incluidos, ya que el pasto puede generar inestabilidad si hay desniveles. En ambientes exteriores nocturnos, el dorado refleja la luz de las velas y la iluminación ambiental de forma espectacular."
  },
  {
    question: "¿Con cuánta anticipación hay que reservar las Tiffany doradas para temporada alta?",
    answer: "Noviembre a febrero es temporada alta de bodas en CDMX, y la Tiffany dorada es la primera en agotarse. Te recomendamos <strong>reservar con 6 a 8 semanas de anticipación</strong> para asegurar el cojín en el color exacto que necesitas. Un anticipo del 30% bloquea tu fecha. Si tu evento es en primavera-verano, con 3-4 semanas es suficiente. Para eventos de 400+ sillas, siempre recomendamos apartar con más tiempo."
  },
];

const specs = [
  { label: "Acabado", value: "Dorado Champagne — tono intermedio entre oro brillante y beige" },
  { label: "Material", value: "Resina policarbonato + estructura interna de acero inoxidable" },
  { label: "Resistencia", value: "180 kg por silla (certificado)" },
  { label: "Peso", value: "4.5 kg" },
  { label: "Altura total", value: "90 cm (respaldo)" },
  { label: "Ancho asiento", value: "40 cm" },
  { label: "Apilable", value: "Sí, hasta 10 unidades" },
  { label: "Cojín", value: "Incluido sin costo — 20+ colores en tela satinada" },
  { label: "Certificación", value: "Anti-UV, ignífugo, apto exterior" },
  { label: "Mantenimiento", value: "Limpieza e inspección pre-evento incluida" },
];

const reviews = [
  { author: "Fernanda Salazar", text: "Rentamos 200 sillas Tiffany doradas para nuestra boda en Hacienda de los Morales. Llegaron impecables, los cojines champagne combinaron perfecto. El equipo montó todo en menos de 2 horas, puntualísimos.", rating: 5, date: "2025-11-20" },
  { author: "Mariana Torres", text: "El dorado champagne hizo que el salón se viera completamente diferente. Mis invitados preguntaron todo el tiempo dónde rentamos las sillas. Con las flores en blush y las mesas en blanco, la combinación fue perfecta.", rating: 5, date: "2025-10-14" },
  { author: "Rodrigo Gutiérrez", text: "Organizamos una cena de gala en Salón Pedregal con 350 Tiffany doradas + cojín negro. Resultado impecable — elegante, consistente, sin problemas de logística. Repetiremos para el próximo evento anual.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Tiffany Dorada Champagne para Bodas en CDMX",
    description: "Sillas Tiffany acabado dorado champagne para bodas y galas en CDMX. El acabado #1 — presente en el 65% de las bodas. Resistencia 180 kg. Cojín incluido. Desde $35/silla.",
    url: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/",
    priceRange: { min: 35, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 57,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Tiffany", url: "/servicios/mobiliario/sillas/tiffany/" },
    { name: "Dorada Champagne", url: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Dorada Champagne", href: null, active: true },
  { name: "Plateada Espejo", href: "/servicios/mobiliario/sillas/tiffany/plateada-espejo/" },
  { name: "Blanca Mate", href: "/servicios/mobiliario/sillas/tiffany/blanca-mate/" },
  { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/tiffany/transparente-cristal/" },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Tiffany Dorada Champagne"
  description="Renta sillas Tiffany dorada champagne en CDMX — el acabado #1 para bodas clásicas y galas."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="El acabado #1 — presente en el 65% de las bodas"
    title='Silla Tiffany <span class="highlight">Dorada Champagne</span> — Renta en CDMX'
    subtitle="El acabado dorado más elegante para bodas clásicas y galas: tono cálido entre oro brillante y beige que combina con blanco, marfil, rosa blush y tonos tierra. Estructura resina policarbonato + acero inoxidable, resistencia de 180 kg, cojín incluido."
    primaryCTA={{ label: "Cotizar sillas Tiffany doradas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany doradas champagne para mi evento` }}
    cards={[
      {
        title: "El acabado que define la boda clásica en CDMX",
        content: "La <strong>silla Tiffany dorada champagne</strong> es el modelo más solicitado de nuestra colección — aparece en el 65% de las bodas que montamos en la Ciudad de México. El secreto está en su tono: no es el oro brillante que satura, ni el beige que pasa desapercibido. Es ese punto intermedio que aporta <strong>calidez y sofisticación sin robarle protagonismo a la decoración</strong>. Ideal para Hacienda de los Morales, Salón Pedregal y cualquier venue con arquitectura colonial o salones con techos altos.",
      },
      {
        title: "Cojín premium incluido y montaje profesional en CDMX",
        content: "Cada silla Tiffany dorada incluye <strong>cojín acolchado premium sin costo adicional</strong> en más de 20 colores: blanco, champagne, negro, rosa blush, marfil, burdeos y más. Entrega, montaje según layout aprobado y desmontaje incluidos en CDMX. Los tres combos más pedidos: dorada + cojín blanco (boda clásica), dorada + cojín champagne (monocromático elegante), dorada + cojín negro (gala corporativa). <strong>Desde $35/silla en lotes de 300+</strong>, $45-55 en 50-149 unidades.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La silla Tiffany dorada que eligen el 65% de las novias en CDMX — cotiza sin compromiso"
    subheadline="Cojín premium en tu color incluido · Montaje profesional · Haciendas y salones de lujo"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Tiffany</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Tiffany doradas para tu boda o gala</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany doradas champagne`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA (primera sección del main) -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Tiffany Dorada Champagne en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en Hacienda de los Morales, Salón Pedregal y venues de lujo en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Tiffany Dorada Champagne</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Tiffany Dorada es la silla más pedida para bodas?"
    headingId="descripcion-heading"
    badge="Dorado que no satura — elegancia que impresiona"
    tags={["Dorado Champagne", "Bodas Clásicas", "Galas y Cenas", "Haciendas CDMX"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una razón por la que el 65% de las novias que contactan con EVENTECH terminan eligiendo el acabado dorado champagne: <strong>no sobreactúa</strong>. Es el único acabado que funciona igual de bien en una hacienda de techos altos con candelabros, en un jardín al atardecer con flores blancas, o en un salón contemporáneo con decoración minimalista.</p>
      <p class="showcase__text">El acabado champagne es una capa de resina policarbonato pigmentada con tono oro envejecido — no es pintura, no se descascara, no se oxida. La misma estructura interna de <strong>acero inoxidable calibre grueso</strong> que aguanta 180 kg garantiza que la silla se mantiene sólida aunque el invitado más pesado se recargue en el respaldo. Cada unidad se limpia e inspecciona antes de entregarse.</p>
      <p class="showcase__text">Nuestros clientes en <strong>Hacienda de los Morales y Salón Pedregal</strong> repiten con nosotros porque saben que las sillas llegan en el mismo estado que fueron cotizadas — sin rasguños, sin manchas, sin sorpresas el día del evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif" alt="Silla Tiffany dorada champagne montada en boda gala" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-dorada-salon-lujo-02.avif" alt="Tiffany dorada en salón de lujo con cojín blanco" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-dorada-boda-candelabros-06.avif" alt="Sillas Tiffany doradas en boda con candelabros dorados" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Tiffany Dorada</h2>
            <p class="section__subtitle">Combinaciones de cojín, mesa y mantelería que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Clásica Blanca</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany dorada + <strong>cojín blanco satinado</strong> + mesa redonda vestida con mantel blanco marfil hasta el piso. El contraste entre el dorado y el blanco es limpio, clásico y extremadamente fotogénico. El más pedido para bodas en haciendas.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Monocromática</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany dorada + <strong>cojín champagne</strong> + mesa rectangular con mantel dorado satinado. El efecto monocromático crea profundidad visual y hace que el salón parezca más grande y más lujoso. Ideal para cenas de gala de 200+ personas.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Corporativo de Lujo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany dorada + <strong>cojín negro</strong> + mesa rectangular con mantel negro + runner dorado. El contraste dorado-negro proyecta poder y elegancia ejecutiva. Muy solicitado para cenas de fin de año y premiaciones corporativas en CDMX.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Tiffany Dorada Champagne</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Tiffany Dorada Champagne"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Dorado que combina con todo, resistencia real de 180 kg, y cojín en el color exacto que necesitas. Aquí resolvemos las dudas más frecuentes sobre la variante más popular de nuestra colección.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Tiffany te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Tiffany dorada champagne`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

