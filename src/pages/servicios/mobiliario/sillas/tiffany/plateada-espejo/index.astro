---
/**
 * ─── Silla Tiffany Plateada Espejo — Página de Variante (Nivel 4) ───
 * Acabado reflejo espejado plateado para paletas frías y eventos contemporáneos.
 * WTC CDMX, Hotel St. Regis, galas corporativas y XV años modernos.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Tiffany > Plateada Espejo
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { label: "Plateada Espejo" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-tiffany-plateada-gala-formal-01.avif", alt: "Silla Tiffany plateada espejo en gala formal CDMX" },
  { src: "/images/mobiliario/silla-tiffany-plateada-evento-lujo-02.avif", alt: "Tiffany plateada espejo en evento de lujo" },
  { src: "/images/mobiliario/silla-tiffany-plateada-gala-cortinas-03.avif", alt: "Sillas Tiffany plateadas en gala con cortinas elegantes" },
  { src: "/images/mobiliario/silla-tiffany-plateada-gala-navy-04.avif", alt: "Tiffany plateada en gala con decoración azul marino" },
  { src: "/images/mobiliario/silla-tiffany-plateada-evento-elegante-05.avif", alt: "Sillas Tiffany plateadas espejo en evento elegante nocturno" },
];

const faqs = [
  {
    question: "¿En qué tipo de eventos queda mejor la Tiffany plateada espejo?",
    answer: "La <strong>Tiffany plateada espejo</strong> sobresale en eventos con paleta de colores fríos: azul marino, gris acero, negro, lavanda, plata y blanco. Es la elección número uno para <strong>eventos corporativos de gala</strong> — premiaciones, cenas de fin de año, congresos de lujo y lanzamientos de marca. En el WTC CDMX y el Hotel St. Regis la hemos montado con frecuencia porque la iluminación LED de esos venues multiplica el efecto espejo de la silla. También es espectacular para XV años con temática de princesa moderna o galactic."
  },
  {
    question: "¿Qué hace diferente al acabado espejo de un plateado normal?",
    answer: "El acabado <strong>espejo</strong> tiene un nivel de pulido y reflectividad muy superior al plateado mate o al plateado estándar. La superficie de la resina policarbonato recibe múltiples capas de pigmento metálico y un sellador de alta brillo que logra un efecto de <strong>reflejo casi especular</strong> — como un espejo curvo. Esto significa que bajo iluminación directa, la silla literalmente multiplica la luz. Bajo iluminación suave, mantiene un brillo controlado y elegante. Cada unidad se pule antes de entregarse para garantizar consistencia."
  },
  {
    question: "¿Cuánto cuesta rentar 150 sillas Tiffany plateadas para un evento corporativo en WTC CDMX?",
    answer: "Para <strong>150 sillas Tiffany plateadas</strong>, el rango de precio es $6,750-$8,250 (desde $45-55/unidad en ese volumen). El precio incluye cojín acolchado estándar en el color que elijas (azul marino, negro y lavanda son los más pedidos para corporativos), entrega en CDMX, montaje según layout del salón y desmontaje al cierre del evento. Conocemos las restricciones de carga horaria y acceso del WTC CDMX. Solicita cotización exacta por WhatsApp y te respondemos en menos de 30 minutos."
  },
  {
    question: "¿La silla Tiffany plateada se ve bien sin cojín o necesita uno?",
    answer: "Depende del contexto. Para <strong>eventos minimalistas o de diseño</strong> donde quieres que la silueta sea el protagonista, la Tiffany plateada sin cojín funciona muy bien — el acabado espejo habla por sí solo. Sin embargo, para eventos de 3+ horas donde los invitados estarán sentados, el cojín añade comodidad real. Los cojines más solicitados con este acabado son <strong>azul marino</strong> (corporativo), <strong>negro</strong> (gala de lujo) y <strong>lavanda</strong> (XV años). El cojín blanco también es muy elegante si quieres un contraste neto."
  },
  {
    question: "¿Combina la Tiffany plateada con mesas y manteles de otros colores?",
    answer: "La Tiffany plateada es sorprendentemente versátil para paletas frías. Las combinaciones que más funcionan: <strong>mesa redonda + mantel azul marino + runner plata</strong> para corporativos (el plateado refleja los tonos del mantel de forma orgánica), <strong>mesa rectangular + mantel negro + runner plata</strong> para galas de premiación, y <strong>mesa redonda + mantel lavanda + florería blanca</strong> para XV años modernos. La regla es que cualquier color frío o neutro funciona — los colores cálidos como naranja o terracota no son la combinación ideal para este acabado."
  },
];

const specs = [
  { label: "Acabado", value: "Plateado Espejo — reflejo metálico especular de alta reflectividad" },
  { label: "Material", value: "Resina policarbonato + estructura interna de acero inoxidable" },
  { label: "Resistencia", value: "180 kg por silla (certificado)" },
  { label: "Peso", value: "4.5 kg" },
  { label: "Altura total", value: "90 cm (respaldo)" },
  { label: "Ancho asiento", value: "40 cm" },
  { label: "Apilable", value: "Sí, hasta 10 unidades" },
  { label: "Cojín", value: "Incluido sin costo — azul marino, negro, lavanda y 17+ colores más" },
  { label: "Certificación", value: "Anti-UV, ignífugo, apto para interiores y exteriores techados" },
  { label: "Mantenimiento", value: "Pulido e inspección pre-evento incluida" },
];

const reviews = [
  { author: "Andrea Mendoza", text: "Para los XV años de mi hija elegimos Tiffany plateada con cojín lavanda. El efecto fue espectacular — todas las fotos quedaron increíbles. La reflectividad bajo la iluminación del salón era impresionante.", rating: 5, date: "2025-10-05" },
  { author: "Luis Vargas", text: "Usamos 200 Tiffany plateadas para nuestra cena de fin de año corporativo en el WTC. Cojín azul marino. El look fue exactamente lo que buscábamos — profesional, moderno, sin excesos. El equipo fue muy eficiente con el montaje.", rating: 5, date: "2025-11-28" },
  { author: "Patricia Reyes", text: "Premiación de ejecutivos en Hotel St. Regis. 120 sillas Tiffany plateadas + cojín negro. Ningún defecto en ninguna silla, entrega puntual, y el acabado espejo dio exactamente el nivel de distinción que buscábamos.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Tiffany Plateada Espejo para Eventos en CDMX",
    description: "Sillas Tiffany acabado plateado espejo para corporativos, galas y XV años en CDMX. Reflejo metálico de alta reflectividad. 180 kg resistencia. Cojín incluido. Desde $35/silla.",
    url: "/servicios/mobiliario/sillas/tiffany/plateada-espejo/",
    priceRange: { min: 35, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Tiffany", url: "/servicios/mobiliario/sillas/tiffany/" },
    { name: "Plateada Espejo", url: "/servicios/mobiliario/sillas/tiffany/plateada-espejo/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Dorada Champagne", href: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/" },
  { name: "Plateada Espejo", href: null, active: true },
  { name: "Blanca Mate", href: "/servicios/mobiliario/sillas/tiffany/blanca-mate/" },
  { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/tiffany/transparente-cristal/" },
];

const sidebarRelated = [
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Tiffany Plateada Espejo CDMX"
  description="Renta sillas Tiffany plateada espejo en CDMX — ideal para corporativos, galas y XV años modernos."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Elegancia contemporánea — corporativos y galas de alto perfil"
    title='Silla Tiffany <span class="highlight">Plateada Espejo</span> — Renta en CDMX'
    subtitle="Acabado plateado con reflejo espejado de alta reflectividad — la elección para eventos con paletas frías: azul marino, gris, negro, lavanda. Estructura resina policarbonato + acero, 180 kg, cojín incluido. WTC CDMX, Hotel St. Regis y venues de alto perfil."
    primaryCTA={{ label: "Cotizar sillas Tiffany plateadas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany plateadas espejo para mi evento` }}
    cards={[
      {
        title: "Reflejo espejado que multiplica la luz y la elegancia",
        content: "La <strong>silla Tiffany plateada espejo</strong> tiene un acabado metálico de alta reflectividad que no tiene comparación con el plateado estándar. Bajo iluminación LED o spots directos, la superficie refleja como un espejo curvo — un efecto visual que eleva cualquier salón. Es la elección de venues como el <strong>WTC CDMX y Hotel St. Regis</strong> para galas de premiación, congresos corporativos y cenas de fin de año donde la estética ejecutiva es prioritaria.",
      },
      {
        title: "Cojín en paleta fría incluido y logística profesional",
        content: "Cada Tiffany plateada incluye <strong>cojín acolchado sin costo adicional</strong>. Los tres colores más pedidos para este acabado: azul marino para corporativos, negro para galas de lujo, y lavanda para XV años modernos. También disponible en blanco, gris y todas las paletas. <strong>Desde $35/silla en lotes de 300+</strong>, $45-55 en 50-149 unidades. Entrega, montaje según layout y desmontaje incluidos en CDMX. Cada silla se pule antes de entregar.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Tiffany plateada espejo — la silla que hace que tu evento corporativo se vea diferente"
    subheadline="Reflejo espejado bajo cualquier iluminación · Cojín azul marino, negro o lavanda incluido · WTC y St. Regis"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Tiffany</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Tiffany plateadas para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Tiffany plateadas espejo`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA (primera sección del main) -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Tiffany Plateada Espejo en Eventos Reales</h2>
            <p class="section__subtitle">Galas corporativas, premiaciones y XV años en WTC CDMX y Hotel St. Regis</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Tiffany Plateada Espejo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La Tiffany Plateada: cuando el acabado hace el trabajo visual por ti"
    headingId="descripcion-heading"
    badge="El acabado que distingue los eventos de alto perfil"
    tags={["Plateado Espejo", "Corporativos", "Premiaciones", "XV Años Modernos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">En el WTC CDMX o el Hotel St. Regis, donde los salones ya tienen arquitectura imponente, necesitas mobiliario que esté a la altura sin pelear con el espacio. La <strong>silla Tiffany plateada espejo</strong> logra exactamente eso: aporta presencia y distinción gracias a su acabado reflectante, sin sobrecargar la decoración.</p>
      <p class="showcase__text">El acabado espejo se obtiene aplicando múltiples capas de pigmento metálico sobre la resina policarbonato, seguidas de un sellador de brillo industrial. El resultado es una superficie que <strong>cambia visualmente según el ángulo de la luz</strong> — sutil en luz ambiental difusa, dramática bajo spots directos o iluminación LED de colores. Si tu evento tiene lighting design, esta silla se convierte en parte activa de ese diseño.</p>
      <p class="showcase__text">La estructura interna de acero inoxidable y la resistencia de <strong>180 kg</strong> son las mismas que en todos los modelos Tiffany — la diferencia es completamente estética. Cada silla se pule individualmente antes de la entrega. Para eventos en los que la consistencia visual importa, como premiaciones o galas de empresa, eso marca la diferencia.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-tiffany-plateada-gala-formal-01.avif" alt="Silla Tiffany plateada espejo en gala formal" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-plateada-evento-lujo-02.avif" alt="Tiffany plateada en evento de lujo con cojín negro" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-tiffany-plateada-gala-navy-04.avif" alt="Sillas Tiffany plateadas con cojín azul marino en gala" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Tiffany Plateada</h2>
            <p class="section__subtitle">Combinaciones de cojín, mesa y mantelería para paletas frías</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Corporativo Premium</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany plateada + <strong>cojín azul marino</strong> + mesa rectangular con mantel azul marino y runner plata. El azul marino proyecta autoridad y profesionalismo — el combo estándar para galas corporativas de alto nivel. Muy solicitado para eventos en WTC CDMX.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala de Premiación</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany plateada + <strong>cojín negro</strong> + mesa redonda con mantel negro y centro floral blanco. El contraste plateado-negro es maximalismo elegante — para eventos donde quieres que cada foto comunique exclusividad y distinción ejecutiva.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">XV Años Princesa Moderna</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Tiffany plateada + <strong>cojín lavanda</strong> + mesa redonda con mantel blanco y flores en tonos lila. La combinación plata-lavanda da un look de princesa contemporánea — no el dorado tradicional, sino algo más fresco y fotogénico para las redes sociales.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Tiffany Plateada Espejo</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Tiffany Plateada Espejo"
              subtitle="Lo que preguntan los organizadores antes de reservar"
              description={[
                "Acabado espejo, paletas frías, corporativos y XV años modernos. Aquí están las respuestas a las dudas más frecuentes sobre esta variante.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Más preguntas?</h3>
                  <p class="faq-sidebar-card__text">Un especialista en mobiliario corporativo te responde por WhatsApp de inmediato.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Tiffany plateada espejo`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
