---
/**
 * ─── Silla Ghost Exterior UV — Variante (Nivel 5) ───
 * Policarbonato UV resistente certificado para jardines, terrazas y exteriores.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Ghost > Exterior
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { label: "Exterior UV" },
];

const galleryImages = [
  { src: "/images/mobiliario/sillas-ghost-transparentes-boda-exterior.avif", alt: "Sillas Ghost transparentes en boda exterior jardín CDMX" },
  { src: "/images/mobiliario/silla-ghost-cristal-boda-banquete-exterior-13.avif", alt: "Banquete exterior con sillas Ghost cristal jardín" },
  { src: "/images/mobiliario/silla-ghost-cristal-terraza-ciudad-05.avif", alt: "Ghost en terraza con vista a la ciudad CDMX" },
  { src: "/images/mobiliario/silla-ghost-cristal-vista-panoramica-06.avif", alt: "Sillas Ghost en terraza con vista panorámica ciudad" },
  { src: "/images/mobiliario/silla-ghost-cristal-cdmx-atardecer-10.avif", alt: "Ghost exterior en jardín CDMX al atardecer" },
  { src: "/images/mobiliario/silla-ghost-cristal-boda-aire-libre-02.avif", alt: "Boda al aire libre con sillas Ghost cristal jardín hacienda" },
];

const faqs = [
  {
    question: "¿Cuál es la diferencia entre la Ghost exterior UV y las otras variantes para usar al aire libre?",
    answer: "Todas las Ghost tienen resistencia UV básica — el policarbonato virgen no se amarillenta con la luz solar. La <strong>Ghost Exterior UV</strong> añade un estándar de certificación más riguroso: está probada para exposición solar acumulada de 2,000+ horas sin degradación del color ni pérdida de resistencia. También incluye <strong>bases antideslizantes reforzadas</strong> para superficies de jardín irregulares (adoquín, pasto, gravilla) y se entrega con tapones de pata con mayor área de contacto para evitar hundimiento en pasto.",
  },
  {
    question: "¿La Ghost exterior aguanta la lluvia o humedad?",
    answer: "El policarbonato es un material <strong>impermeable y no poroso</strong> — el agua no lo afecta, no se oxida, no se hincha ni se deforma. Las sillas Ghost se pueden usar perfectamente en exteriores con riesgo de lluvia ligera. Sin embargo, para eventos con lluvia intensa o viento fuerte, siempre recomendamos combinarlas con <strong>carpa o toldo</strong> por la seguridad de los invitados. La silla aguanta el agua — el problema de la lluvia fuerte es el confort del evento, no la silla.",
  },
  {
    question: "¿La Ghost exterior se puede usar en jardines con pasto?",
    answer: "Sí, con una precaución: las patas de la Ghost son delgadas para mantener la estética del diseño Starck. En pasto blando o mojado, recomendamos colocar un tapete de base o usar las <strong>bases de pata reforzadas</strong> que incluimos en la versión exterior. Esto distribuye el peso y evita que las patas se hundan. Tenemos experiencia con jardines en Pedregal, Jardines del Pedregal y varias haciendas — conocemos las particularidades de cada superficie.",
  },
  {
    question: "¿Cuánto sol aguanta la Ghost exterior sin decolorarse?",
    answer: "La Ghost exterior UV está certificada para <strong>2,000 horas de exposición UV directa</strong> sin decoloración ni pérdida de propiedades mecánicas. Para contexto: un evento de 8 horas con sol pleno representa una fracción mínima de ese total. La degradación por UV en condiciones normales de renta es prácticamente inexistente. Nuestras sillas se revisan periódicamente y se retiran del inventario ante cualquier señal de degradación.",
  },
  {
    question: "¿Cuántas sillas Ghost exterior necesito para un jardín de hacienda?",
    answer: "La regla estándar es <strong>1.5 sillas por metro cuadrado de área de banquete</strong>. Para un jardín de 300 m² con mesas para 200 personas, necesitas 200 sillas + 10-15% de reserva = 220-230 unidades. Para jardines de hacienda, también considera el área de cocktail (si aplica) donde se usan sillas adicionales o barras estilo lounge. Te enviamos un layout con el número exacto por el plano del espacio.",
  },
];

const specs = [
  { label: "Color / Acabado", value: "Cristal transparente (también disponible en humo y ámbar)" },
  { label: "Material", value: "Policarbonato virgen 3.5mm con protección UV reforzada" },
  { label: "Certificación UV", value: "Resistente a 2,000+ horas de exposición solar directa" },
  { label: "Resistencia", value: "130 kg por silla" },
  { label: "Peso", value: "3.8 kg" },
  { label: "Altura total", value: "93 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Apilable", value: "Sí, hasta 6 unidades" },
  { label: "Bases de pata", value: "Tapones antideslizantes reforzados para pasto y adoquín" },
  { label: "Resistencia a lluvia", value: "Impermeable — apta para exposición a lluvia ligera" },
  { label: "Precio base", value: "Desde $50/unidad (varía según volumen y fecha)" },
  { label: "Incluye", value: "Bases reforzadas para exterior + limpieza pre-evento" },
];

const reviews = [
  {
    author: "Jimena Varela",
    text: "Organizamos una boda de jardín en hacienda con 180 Ghost exteriores. Sol todo el día, terreno irregular, evento de 8 horas. Las sillas perfectas en todo momento — ni una sola cedió ni se hundió en el pasto. El servicio fue de 10.",
    rating: 5,
    date: "2025-11-01",
  },
  {
    author: "Carlos Medina",
    text: "Evento corporativo en terraza al aire libre para 120 personas. Viento moderado durante el evento y las sillas se mantuvieron estables gracias a las bases reforzadas. EVENTECH llegó con todo el equipo puntual y montó en tiempo récord.",
    rating: 5,
    date: "2025-10-08",
  },
  {
    author: "Ana Flores",
    text: "Las Ghost exteriores en nuestro jardín con vista a Ajusco fueron el elemento más comentado. Con el sol filtrándose y el paisaje verde de fondo, las sillas transparentes crearon un efecto de visibilidad total hacia el jardín. Absolutamente recomendadas.",
    rating: 5,
    date: "2025-09-20",
  },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Ghost Exterior UV para Jardines y Terrazas en CDMX",
    description: "Sillas Ghost exterior UV para jardines, terrazas y haciendas en CDMX. Policarbonato certificado UV 3.5mm · 130 kg · Bases reforzadas para pasto · Desde $50/silla.",
    url: "/servicios/mobiliario/sillas/ghost/exterior/",
    priceRange: { min: 50, max: 80 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Ghost", url: "/servicios/mobiliario/sillas/ghost/" },
    { name: "Exterior UV", url: "/servicios/mobiliario/sillas/ghost/exterior/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/ghost/transparente/" },
  { name: "Humo / Gris", href: "/servicios/mobiliario/sillas/ghost/humo/" },
  { name: "Ámbar", href: "/servicios/mobiliario/sillas/ghost/ambar/" },
  { name: "Exterior UV", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Carpas y Toldos", href: "/servicios/carpas/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Sillas Ghost Exterior UV CDMX"
  description="Renta sillas Ghost exterior UV en CDMX — policarbonato certificado UV, bases reforzadas para pasto y adoquín."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Certificada UV — la Ghost que vive en jardines y terrazas sin perder un milímetro de elegancia"
    title='Silla Ghost <span class="highlight">Exterior UV</span> — Renta en CDMX'
    subtitle="Policarbonato virgen 3.5mm con certificación UV reforzada, bases antideslizantes para pasto y adoquín, resistencia de 130 kg. La silla Ghost pensada desde el origen para jardines, terrazas, haciendas y cualquier evento al aire libre en CDMX."
    primaryCTA={{ label: "Cotizar sillas Ghost exterior", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost exterior UV para mi evento` }}
    cards={[
      {
        title: "Diseñada para el exterior — no solo tolerante al exterior",
        content: "Hay una diferencia entre una silla que 'se puede usar afuera' y una silla <strong>diseñada para el exterior</strong>. La Ghost Exterior UV viene con certificación UV de 2,000+ horas, bases de pata reforzadas con mayor área de contacto para evitar hundimiento en pasto, tapones antideslizantes para adoquín y gravilla, y un proceso de inspección adicional pre-entrega para eventos al aire libre. No es la misma Ghost con otro nombre — es la versión preparada para lo que el jardín le va a exigir.",
      },
      {
        title: "La transparencia que amplía el jardín — no lo divide",
        content: "En un jardín con vista a un lago, a un bosque o a un skyline, las sillas sólidas actúan como paredes: <strong>dividen el espacio visual</strong>. La Ghost exterior transparente hace lo contrario: desaparece y deja que el jardín sea el escenario. Los invitados sentados no bloquean la vista a los que están de pie — el espacio se siente más abierto, más generoso, más fotogénico. Para eventos en haciendas y jardines privados en CDMX, ese detalle cambia completamente la percepción del espacio.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La Ghost exterior UV que convierte cualquier jardín en un escenario de primer nivel — cotiza ahora"
    subheadline="Certificación UV 2,000h · Bases para pasto y adoquín · Montaje profesional en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Ghost</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Ghost exterior UV para tu jardín o terraza</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost exterior UV para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Ghost Exterior en Jardines y Terrazas</h2>
            <p class="section__subtitle">Haciendas, jardines privados y terrazas con vista en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Ghost Exterior UV</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué las mejores bodas de jardín en CDMX usan Ghost exterior?"
    headingId="descripcion-heading"
    badge="UV certificada — el jardín como escenario, la silla como elemento invisible"
    tags={["Exterior UV", "Jardines y Haciendas", "Terrazas CDMX", "Bodas al Aire Libre"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Los coordinadores de bodas en haciendas y jardines privados de CDMX descubrieron algo hace años: <strong>la silla sólida destruye la fotografía de exterior</strong>. Cuando el fotógrafo captura la mesa desde un lateral, las sillas convencionales bloquean la vista al jardín. Con la Ghost exterior transparente, el jardín aparece detrás, entre y alrededor de los invitados — como si no hubiera sillas en absoluto.</p>
      <p class="showcase__text">El <strong>policarbonato UV reforzado de 3.5mm</strong> de la versión exterior está probado para 2,000+ horas de exposición solar directa sin degradación. El sol del mediodía no la amarillenta, el rocío de la mañana no la mancha y el calor del verano en CDMX no la deforma. Las <strong>bases de pata reforzadas</strong> distribuyen el peso en superficies irregulares: pasto, adoquín, gravilla o grava volcánica — las cuatro superficies más comunes en jardines de hacienda.</p>
      <p class="showcase__text">Tenemos experiencia montando en <strong>más de 40 haciendas y jardines privados</strong> en CDMX, Morelos y Estado de México. Conocemos los quirks de cada superficie y llevamos el equipo preparado para cada escenario.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sillas-ghost-transparentes-boda-exterior.avif" alt="Sillas Ghost transparentes en boda exterior jardín CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-cristal-boda-banquete-exterior-13.avif" alt="Banquete exterior con Ghost cristal en jardín" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-cristal-terraza-ciudad-05.avif" alt="Ghost en terraza con vista a la ciudad" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Ghost Exterior</h2>
            <p class="section__subtitle">Combinaciones que funcionan para jardines, haciendas y terrazas</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Hacienda Clásica</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost exterior + <strong>mesa redonda con mantel largo blanco</strong> + flores en blanco y verde + candelabros altos de vidrio. El look clásico de hacienda que nunca falla. La Ghost transparente sobre mantel blanco crea un efecto de flotación que las fotos capturan de forma espectacular.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Jardín Contemporánea</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost exterior + <strong>mesa imperial de madera</strong> + sin mantel + flores silvestres en tonos naturales. Para bodas con estética editorial-rústica donde el foco es la textura y la naturaleza. La Ghost transparente sobre madera desnuda crea un contraste industrial-orgánico muy solicitado.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Evento Corporativo Terraza</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost exterior + <strong>mesa rectangular negra o gris</strong> + branding corporativo en centro de mesa + iluminación LED perimetral. Para eventos de empresa en terrazas con vista a la ciudad. La Ghost transparente con skyline de CDMX de fondo es una imagen que se vende sola.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Ghost Exterior UV</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Ghost Exterior UV"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Certificación UV 2,000h, bases reforzadas para pasto y adoquín, resistencia de 130 kg. Resolvemos las dudas más frecuentes sobre la Ghost exterior.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en Ghost exterior te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Ghost exterior UV`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
