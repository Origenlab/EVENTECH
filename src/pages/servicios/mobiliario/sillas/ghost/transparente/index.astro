---
/**
 * ─── Silla Ghost Transparente Cristal — Variante (Nivel 5) ───
 * Policarbonato 3.5mm, diseño Philippe Starck, desde $45.
 * El ícono del diseño moderno: invisible, elegante, versátil.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Ghost > Transparente
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { label: "Transparente Cristal" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-ghost-cristal-boda-exterior-01.avif", alt: "Silla Ghost transparente cristal en boda al aire libre CDMX" },
  { src: "/images/mobiliario/silla-ghost-cristal-rooftop-cdmx-04.avif", alt: "Sillas Ghost transparentes en rooftop CDMX atardecer" },
  { src: "/images/mobiliario/silla-ghost-cristal-terraza-cdmx-atardecer-03.avif", alt: "Ghost cristal en terraza con vista a la ciudad CDMX" },
  { src: "/images/mobiliario/silla-ghost-cristal-boda-flores-blancas-09.avif", alt: "Sillas Ghost transparentes con flores blancas boda elegante" },
  { src: "/images/mobiliario/silla-ghost-cristal-boda-mesa-imperial-08.avif", alt: "Ghost cristal en mesa imperial banquete de lujo" },
  { src: "/images/mobiliario/silla-ghost-cristal-skyline-cdmx-11.avif", alt: "Sillas Ghost cristal con skyline CDMX de fondo" },
];

const faqs = [
  {
    question: "¿Por qué la Ghost transparente es la silla favorita para rooftops y eventos modernos?",
    answer: "La <strong>Ghost transparente</strong> tiene una ventaja única: no interrumpe visualmente el espacio. En un rooftop con vista a la ciudad, en una terraza con jardín iluminado o en un salón de arquitectura moderna, la silla desaparece y deja que el entorno sea el protagonista. Es el diseño original de Philippe Starck — concebido específicamente para que la silla no 'contamine' el espacio visual. No hay otro modelo que logre ese efecto.",
  },
  {
    question: "¿La Ghost transparente se ve bien en espacios con poca luz o eventos nocturnos?",
    answer: "En ambientes nocturnos, la Ghost transparente se transforma completamente: <strong>refleja y refracta la luz</strong> ambiente, las velas y la iluminación LED creando un efecto casi joyero. Sobre una mesa iluminada con luz cálida, cada silla parece un cristal tallado. Para eventos de noche, es probablemente la opción más impactante de toda nuestra colección.",
  },
  {
    question: "¿El policarbonato transparente de 3.5mm aguanta el uso intenso de un evento?",
    answer: "El <strong>policarbonato virgen de 3.5mm</strong> que usamos es el estándar de la industria para sillas Ghost de calidad premium. Soporta <strong>130 kg por unidad</strong> y es el mismo material que se usa en escudos antidisturbios y cascos industriales. No se astilla, no se quiebra ante impactos moderados y resiste temperaturas de -40°C a +120°C. Cada unidad pasa por pulido profesional antes de cada entrega — la recibirás con transparencia cristalina impecable.",
  },
  {
    question: "¿Con cuánta anticipación hay que reservar las Ghost transparentes para un rooftop?",
    answer: "Para rooftops y eventos de diseño, la Ghost transparente es la primera variante en agotarse. Te recomendamos <strong>reservar con 4 a 6 semanas de anticipación</strong> en temporada alta (octubre a febrero). Para eventos de 100+ sillas, siempre recomendamos apartar con más tiempo. Un anticipo del 30% bloquea tu fecha.",
  },
  {
    question: "¿Puedo combinar Ghost transparentes con otras sillas?",
    answer: "Sí, y es una combinación muy solicitada. La más pedida es <strong>Ghost transparente + silla Tiffany dorada o plateada</strong>: las Ghost en mesas secundarias y las Tiffany en el head table. El contraste entre lo transparente y el acabado metálico es visualmente espectacular. También funciona muy bien combinar Ghost con mesas acrílicas o de vidrio para un look completamente minimalista.",
  },
];

const specs = [
  { label: "Color / Acabado", value: "Cristal transparente — policarbonato virgen sin pigmento" },
  { label: "Material", value: "Policarbonato virgen 3.5mm de espesor" },
  { label: "Diseñador", value: "Philippe Starck — diseño original Ghost Chair" },
  { label: "Resistencia", value: "130 kg por silla" },
  { label: "Peso", value: "3.8 kg" },
  { label: "Altura total", value: "93 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Apilable", value: "Sí, hasta 6 unidades" },
  { label: "Resistencia UV", value: "Sí — no amarillenta con exposición solar" },
  { label: "Uso exterior", value: "Apto para jardines y terrazas cubiertas" },
  { label: "Precio base", value: "Desde $45/unidad (varía según volumen y fecha)" },
  { label: "Mantenimiento", value: "Pulido profesional e inspección pre-evento incluida" },
];

const reviews = [
  {
    author: "Camila Vega",
    text: "Las Ghost transparentes en nuestra boda en la terraza del hotel fueron el detalle que más comentaron los invitados. Con la ciudad de fondo y las velas encendidas, parecían flotes de cristal. Servicio puntual y sillas impecables.",
    rating: 5,
    date: "2025-11-08",
  },
  {
    author: "Andrés Montoya",
    text: "Organizamos el lanzamiento de producto en un rooftop en Polanco y las sillas Ghost transparentes elevaron completamente la estética del evento. Nadie podía creer que fueran rentadas — se veían como si fueran del espacio.",
    rating: 5,
    date: "2025-09-22",
  },
  {
    author: "Sofía Ramírez",
    text: "Rentamos 120 Ghost transparentes para una cena de gala moderna. El proceso fue muy fácil: cotización rápida, entrega a tiempo y sillas sin un solo rayón. Las recomiendo 100% para eventos de diseño.",
    rating: 5,
    date: "2025-08-14",
  },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Ghost Transparente Cristal para Eventos en CDMX",
    description: "Sillas Ghost transparente cristal diseño Philippe Starck para rooftops y eventos modernos en CDMX. Policarbonato 3.5mm · 130 kg resistencia · Resistente UV · Desde $45/silla.",
    url: "/servicios/mobiliario/sillas/ghost/transparente/",
    priceRange: { min: 45, max: 75 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Ghost", url: "/servicios/mobiliario/sillas/ghost/" },
    { name: "Transparente Cristal", url: "/servicios/mobiliario/sillas/ghost/transparente/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Transparente Cristal", href: null, active: true },
  { name: "Humo / Gris", href: "/servicios/mobiliario/sillas/ghost/humo/" },
  { name: "Ámbar", href: "/servicios/mobiliario/sillas/ghost/ambar/" },
  { name: "Exterior UV", href: "/servicios/mobiliario/sillas/ghost/exterior/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Sillas Ghost Transparente Cristal CDMX"
  description="Renta sillas Ghost transparente cristal en CDMX — diseño Philippe Starck, policarbonato 3.5mm. Perfectas para rooftops y eventos modernos."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Diseño Philippe Starck — el ícono transparente del evento moderno"
    title='Silla Ghost <span class="highlight">Transparente Cristal</span> — Renta en CDMX'
    subtitle="La silla invisible que convierte cualquier espacio en una experiencia visual. Policarbonato virgen 3.5mm, diseño original de Philippe Starck, resistencia de 130 kg. Perfecta para rooftops, terrazas y eventos de diseño contemporáneo en CDMX."
    primaryCTA={{ label: "Cotizar sillas Ghost", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost transparentes para mi evento` }}
    cards={[
      {
        title: "La silla que no compite — deja que el espacio hable",
        content: "La <strong>silla Ghost transparente cristal</strong> fue diseñada con un solo principio: no interrumpir. En un rooftop con vista al skyline de CDMX, en una terraza con jardín al atardecer o en un salón de arquitectura contemporánea, la Ghost desaparece y deja que el entorno sea el verdadero escenario. El <strong>policarbonato virgen de 3.5mm</strong> de Philippe Starck no es un capricho estético — es ingeniería del espacio. Cada evento donde aparece termina con los mismos comentarios de los invitados: '¿Dónde consiguieron esas sillas?'.",
      },
      {
        title: "Resistencia real y entrega profesional en CDMX",
        content: "Con <strong>130 kg de capacidad</strong> y resistencia UV certificada, la Ghost transparente no es solo bonita — es funcional. Apta para exterior, no amarillenta con el sol y aguanta el uso intenso de un evento. Cada unidad se pule y revisa antes de entregarse: llegarán con claridad cristalina impecable. Entrega, montaje y desmontaje incluidos en CDMX. <strong>Desde $45/silla</strong> en lotes de 100+, $55-65 en volúmenes menores.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La Ghost transparente que convierte rooftops en experiencias visuales — cotiza sin compromiso"
    subheadline="Diseño Starck · Policarbonato 3.5mm · Montaje profesional en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Ghost</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Ghost transparentes para tu evento moderno</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost transparentes para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Ghost Transparente en Eventos Reales</h2>
            <p class="section__subtitle">Rooftops, bodas en terraza y eventos de diseño en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Ghost Transparente Cristal</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué los mejores rooftops y eventos de diseño eligen la Ghost transparente?"
    headingId="descripcion-heading"
    badge="La silla que no interrumpe — deja ver el espacio"
    tags={["Cristal Transparente", "Rooftops", "Eventos Modernos", "Diseño Starck"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El diseño de Philippe Starck nació de una pregunta radical: ¿qué pasaría si la silla desapareciera? La respuesta es la <strong>Ghost transparente</strong> — un objeto que ocupa espacio físico sin ocupar espacio visual. En un rooftop con vista panorámica a la ciudad, en una terraza frente al jardín o en un salón con arquitectura contemporánea, la Ghost cristal amplifica el entorno en lugar de comprimirlo.</p>
      <p class="showcase__text">El <strong>policarbonato virgen de 3.5mm</strong> que usamos no es plástico ordinario. Es el mismo material de los visores de astronautas y los escudos de alta seguridad: resistente al impacto, estable a temperaturas extremas y <strong>completamente resistente a rayos UV</strong> — no se amarillenta, no se opaca. Cada pieza se pule profesionalmente antes de cada evento para garantizar claridad cristalina total.</p>
      <p class="showcase__text">En eventos nocturnos, la Ghost transparente hace algo que ningún otro modelo puede: <strong>captura y refracta la luz</strong> ambiente. Con velas sobre la mesa o iluminación LED perimetral, cada silla se convierte en un elemento luminoso que multiplica el efecto dramático del espacio.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-ghost-cristal-rooftop-lateral-12.avif" alt="Silla Ghost transparente en rooftop CDMX vista lateral" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-cristal-estudio-profesional-07.avif" alt="Ghost transparente fotografía de estudio profesional" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-cristal-terraza-cdmx-noche-18.avif" alt="Sillas Ghost cristal en terraza CDMX de noche" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Ghost Transparente</h2>
            <p class="section__subtitle">Combinaciones que funcionan para rooftops y eventos de diseño</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Rooftop Minimalista</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost transparente + <strong>mesa acrílica o de vidrio</strong> + mantel blanco o sin mantel. El look completamente transparente maximiza la vista y crea un efecto de mesa flotante. El favorito de los organizadores de eventos de diseño en Polanco y Santa Fe.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Jardín Contemporánea</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost transparente + <strong>mesa de madera rústica o mármol</strong> + flores silvestres en tono natural. El contraste entre lo orgánico de la madera y lo industrial del policarbonato es visualmente sorprendente y muy solicitado en bodas de estilo editorial.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Corporativo Vanguardista</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost transparente + <strong>mesa rectangular negra</strong> + iluminación LED bajo mesa. Para presentaciones de producto, lanzamientos y eventos corporativos que quieren proyectar innovación. El efecto nocturno con LED crea un ambiente de alta tecnología.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Ghost Transparente Cristal</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Ghost Transparente"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Policarbonato virgen de 3.5mm, resistencia de 130 kg, apta para exterior y UV resistente. Resolvemos las dudas más frecuentes sobre la Ghost cristal.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Ghost te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Ghost transparente cristal`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Ghost y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Ghost</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
