---
/**
 * ─── Silla Ghost Ámbar — Variante (Nivel 5) ───
 * Tono cálido dorado translúcido. Ideal para bodas otoñales y eventos con paleta cálida.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Ghost > Ámbar
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { label: "Ámbar" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-ghost-ambar-kartell-02.avif", alt: "Silla Ghost ámbar Kartell tono dorado translúcido" },
  { src: "/images/mobiliario/silla-ghost-ambar-studio-01.avif", alt: "Ghost ámbar fotografía de estudio luz cálida" },
  { src: "/images/mobiliario/silla-ghost-ambar-kartell-lateral-04.avif", alt: "Silla Ghost ámbar vista lateral detalles Starck" },
  { src: "/images/mobiliario/silla-ghost-ambar-studio-softbox-03.avif", alt: "Ghost ámbar con iluminación softbox boda otoñal" },
  { src: "/images/mobiliario/sillas-ghost-ambar-evento.avif", alt: "Montaje sillas Ghost ámbar en evento de boda" },
  { src: "/images/mobiliario/silla-ghost-ambar-studio-parodorte-06.avif", alt: "Ghost ámbar en contexto de jardín decorado otoñal" },
];

const faqs = [
  {
    question: "¿Para qué tipo de bodas está pensada la Ghost ámbar?",
    answer: "La <strong>Ghost ámbar</strong> es la silla de elección para bodas con paleta cálida: terracota, melocotón, dorado, vino, beige y toda la gama otoñal. En una boda de jardín con flores en tonos naranja, amarillo y vino, la Ghost ámbar se funde armoniosamente con la paleta en lugar de contrastar. Es especialmente hermosa en bodas de tarde — cuando la luz del atardecer toca el policarbonato ámbar, la silla literalmente brilla con tonos de miel.",
  },
  {
    question: "¿La Ghost ámbar es el mismo tono que el dorado de la Tiffany?",
    answer: "No, son tonos distintos con objetivos distintos. La <strong>Tiffany dorada es un acabado sólido y opaco</strong> — el dorado está en la superficie. La <strong>Ghost ámbar es translúcida</strong> — el pigmento está en la masa del policarbonato y deja pasar la luz. El efecto visual es completamente diferente: la Tiffany dorada refleja, la Ghost ámbar transmite. Son sillas que se complementan perfectamente en el mismo evento.",
  },
  {
    question: "¿Con qué flores y colores de mantelería combina mejor la Ghost ámbar?",
    answer: "Los <strong>tres combos más solicitados</strong>: (1) Ghost ámbar + flores en terracota, melocotón y rosa salmón + mantel en lino beige — la paleta otoñal definitiva. (2) Ghost ámbar + flores blancas en jarrones de vidrio + mantel nude — el ámbar calientifica el blanco puro sin saturar. (3) Ghost ámbar + flores amarillas y burdeos + mantel en tono tierra — bodas de jardín con atmósfera rústica-elegante.",
  },
  {
    question: "¿La Ghost ámbar funciona bien en bodas de noche?",
    answer: "En ambientes nocturnos, la Ghost ámbar con velas cercanas hace algo especial: <strong>el policarbonato atrapa la luz y la distribuye con un tono miel</strong> muy cálido. Es diferente a la transparente (que refleja) y al humo (que absorbe) — el ámbar transforma la luz en calidez. Con velas pilares sobre la mesa y la Ghost ámbar bajo esa luz, el efecto es de una hoguera íntima y elegante.",
  },
  {
    question: "¿Se puede usar la Ghost ámbar en exteriores?",
    answer: "Sí. El policarbonato ámbar es <strong>resistente a rayos UV</strong> — el pigmento dorado no se decolora con exposición solar. Es apta para jardines y terrazas cubiertas. Para bodas de jardín al mediodía en otoño, la Ghost ámbar se ve espectacular: el sol filtrándose a través del policarbonato crea sombras doradas en el piso que son imposibles de ignorar. Una nota de precaución: en jardines muy expuestos al viento, recomendamos anclarlas por su peso ligero (3.8 kg).",
  },
];

const specs = [
  { label: "Color / Acabado", value: "Ámbar — policarbonato con pigmento dorado translúcido integral" },
  { label: "Material", value: "Policarbonato virgen 3.5mm con tinte ámbar integral" },
  { label: "Diseñador", value: "Philippe Starck — diseño original Ghost Chair" },
  { label: "Resistencia", value: "130 kg por silla" },
  { label: "Peso", value: "3.8 kg" },
  { label: "Altura total", value: "93 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Apilable", value: "Sí, hasta 6 unidades" },
  { label: "Resistencia UV", value: "Sí — el pigmento ámbar no se decolora con exposición solar" },
  { label: "Uso exterior", value: "Apto para jardines y terrazas" },
  { label: "Precio base", value: "Desde $48/unidad (varía según volumen y fecha)" },
  { label: "Mantenimiento", value: "Limpieza profesional e inspección pre-evento incluida" },
];

const reviews = [
  {
    author: "Lucía Hernández",
    text: "Las Ghost ámbar en mi boda de otoño en el jardín del hotel fueron absolutamente perfectas. Con las flores en terracota y el atardecer de fondo, la luz atravesando el policarbonato creó un efecto de miel que ninguna foto hace justicia. Todos mis invitados preguntaron por las sillas.",
    rating: 5,
    date: "2025-10-25",
  },
  {
    author: "Mónica Aguilar",
    text: "Coordiné una cena de fin de año con temática otoñal y las Ghost ámbar fueron el elemento central. Con flores secas y velas en tonos dorados, el ambiente era de calidez absoluta. Servicio impecable de EVENTECH.",
    rating: 5,
    date: "2025-11-15",
  },
  {
    author: "Daniela Torres",
    text: "Mezclé Ghost ámbar con Ghost transparentes en mi boda y el contraste fue precioso. Las ámbar en el head table con velas alrededor, las transparentes en el resto. El resultado fue sofisticado y con mucha personalidad.",
    rating: 5,
    date: "2025-09-12",
  },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Ghost Ámbar para Bodas y Eventos en CDMX",
    description: "Sillas Ghost ámbar diseño Philippe Starck para bodas otoñales y eventos con paleta cálida en CDMX. Policarbonato dorado translúcido 3.5mm · 130 kg · Desde $48/silla.",
    url: "/servicios/mobiliario/sillas/ghost/ambar/",
    priceRange: { min: 48, max: 75 },
    reviews,
    ratingValue: 5,
    reviewCount: 24,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Ghost", url: "/servicios/mobiliario/sillas/ghost/" },
    { name: "Ámbar", url: "/servicios/mobiliario/sillas/ghost/ambar/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/ghost/transparente/" },
  { name: "Humo / Gris", href: "/servicios/mobiliario/sillas/ghost/humo/" },
  { name: "Ámbar", href: null, active: true },
  { name: "Exterior UV", href: "/servicios/mobiliario/sillas/ghost/exterior/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany Dorada", href: "/servicios/mobiliario/sillas/tiffany/dorada-champagne/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Ghost Ámbar CDMX"
  description="Renta sillas Ghost ámbar en CDMX — diseño Philippe Starck, policarbonato dorado translúcido 3.5mm. Ideales para bodas otoñales y eventos con paleta cálida."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="Luz de miel — la Ghost que transforma la paleta otoñal en magia visual"
    title='Silla Ghost <span class="highlight">Ámbar</span> — Renta en CDMX'
    subtitle="El tono dorado translúcido que se funde con la naturaleza y la luz cálida. Policarbonato virgen 3.5mm con pigmento ámbar integral, diseño Philippe Starck, resistencia de 130 kg. La variante preferida para bodas otoñales, jardines y eventos con paleta terracota-dorada en CDMX."
    primaryCTA={{ label: "Cotizar sillas Ghost ámbar", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost ámbar para mi evento` }}
    cards={[
      {
        title: "El ámbar que captura la luz y la convierte en calidez",
        content: "La <strong>Ghost ámbar</strong> tiene una propiedad que ningún otro modelo comparte: transmite la luz en lugar de reflejarla o bloquearla. En una boda de jardín a las cuatro de la tarde, el sol atraviesa el policarbonato dorado y proyecta sombras color miel en el piso. Con velas sobre la mesa, cada silla se convierte en una lámpara ámbar de diseño. Es el único material que hace que la luz del evento sea parte del mobiliario.",
      },
      {
        title: "Bodas otoñales y paletas cálidas — la combinación perfecta",
        content: "Terracota, melocotón, vino, beige dorado, flores de temporada otoñal — todos estos elementos de paleta cálida encuentran en la <strong>Ghost ámbar su complemento natural</strong>. No es una silla que contrasta con la decoración: es una que pertenece a ella. Policarbonato virgen de 3.5mm con pigmento integral resistente a UV, <strong>130 kg de capacidad</strong> y entrega profesional en CDMX. <strong>Desde $48/silla</strong> en lotes de 100+.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La Ghost ámbar que convierte la luz del atardecer en parte de tu boda — cotiza sin compromiso"
    subheadline="Diseño Starck · Policarbonato dorado translúcido · Montaje profesional en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Ghost</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Ghost ámbar para tu boda otoñal</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost ámbar para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Ghost Ámbar en Bodas y Eventos</h2>
            <p class="section__subtitle">Bodas otoñales, jardines y eventos con paleta cálida en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Ghost Ámbar</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Ghost ámbar es la silla favorita para bodas otoñales?"
    headingId="descripcion-heading"
    badge="Translúcida, cálida, orgánica — como la luz de octubre"
    tags={["Ámbar Dorado", "Bodas Otoñales", "Jardines", "Paleta Cálida"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El otoño tiene una paleta propia: terracota, naranja quemado, dorado viejo, vino, beige cálido. La mayoría de las sillas ignorán esa paleta — son blancas, negras o metálicas. La <strong>Ghost ámbar pertenece a la paleta otoñal</strong>. El policarbonato con pigmento dorado translúcido atrapa la luz de la tarde como lo hace una hoja seca a contraluz — con una belleza orgánica y efímera que ningún material sólido puede imitar.</p>
      <p class="showcase__text">El pigmento ámbar es <strong>integral en la masa del policarbonato</strong> — no es una capa de color, es el material mismo. Esto garantiza que el tono sea uniforme desde cualquier ángulo, que no se descascare con el uso y que mantenga su intensidad incluso con exposición solar prolongada. Con resistencia certificada de <strong>130 kg</strong>, es tan sólida como elegante.</p>
      <p class="showcase__text">Nuestra experiencia con bodas de jardín en CDMX nos ha enseñado que la Ghost ámbar funciona mejor entre las 15:00 y las 20:00 — justo cuando la luz natural del atardecer y la iluminación artificial del evento se encuentran. En esas horas, el policarbonato ámbar se convierte en un <strong>elemento de luz propio</strong>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-ghost-ambar-kartell-02.avif" alt="Silla Ghost ámbar tono dorado translúcido Kartell" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-ambar-studio-01.avif" alt="Ghost ámbar estudio fotográfico luz cálida" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sillas-ghost-ambar-evento.avif" alt="Montaje sillas Ghost ámbar en boda de jardín" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Ghost Ámbar</h2>
            <p class="section__subtitle">Combinaciones que funcionan para bodas otoñales y eventos de paleta cálida</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Otoñal Jardín</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost ámbar + <strong>mesa rústica de madera natural</strong> + flores en terracota, melocotón y eucalipto + mantel en lino beige crudo. La paleta completa del otoño en un solo setup. Las Ghost ámbar al atardecer con ese fondo son imposibles de olvidar.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena Íntima de Lujo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost ámbar + <strong>mesa de mármol blanco o crema</strong> + velas pilares altas + flores blancas y amarillas. El ámbar calientifica el blanco del mármol y crea una atmósfera de intimidad sin frialdad. Muy solicitado para bodas pequeñas de 60-80 personas donde cada detalle importa.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena de Fin de Año</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost ámbar + <strong>mesa rectangular con mantel dorado</strong> + centros de flores en vino y burdeos + velas en candelabros dorados. Para cenas de fin de año con estilo navideño-elegante, la Ghost ámbar es el elemento que unifica la paleta sin volverse kitsch.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Ghost Ámbar</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Ghost Ámbar"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Policarbonato dorado translúcido de 3.5mm, resistencia de 130 kg y pigmento integral resistente a UV. Resolvemos las dudas más frecuentes sobre la Ghost ámbar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Ghost te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Ghost ámbar`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
