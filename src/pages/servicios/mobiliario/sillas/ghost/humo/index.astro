---
/**
 * ─── Silla Ghost Humo / Gris — Variante (Nivel 5) ───
 * Tono ahumado sofisticado, ideal para galas nocturnas y eventos formales.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Ghost > Humo
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { label: "Humo / Gris" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-ghost-humo-gala-dramatica-01.avif", alt: "Silla Ghost humo en gala nocturna dramática iluminación tenue" },
  { src: "/images/mobiliario/silla-ghost-humo-evento-noche-02.avif", alt: "Sillas Ghost ahumadas en evento de noche CDMX" },
  { src: "/images/mobiliario/sillas-ghost-humo-evento.avif", alt: "Montaje sillas Ghost humo en salón de eventos" },
  { src: "/images/mobiliario/silla-ghost-cristal-estudio-dramatico-14.avif", alt: "Ghost humo en fotografía de estudio con iluminación dramática" },
  { src: "/images/mobiliario/silla-ghost-cristal-cdmx-dusk-16.avif", alt: "Sillas Ghost en evento crepuscular CDMX" },
  { src: "/images/mobiliario/sillas-chiavari-ghost-combinacion-estudio.avif", alt: "Combinación Chiavari y Ghost humo en montaje de estudio" },
];

const faqs = [
  {
    question: "¿En qué tipo de eventos funciona mejor la Ghost humo?",
    answer: "La <strong>Ghost humo</strong> es la variante pensada para ambientes donde se busca sofisticación sin la frialdad del blanco puro. Funciona excepcionalmente bien en galas nocturnas, cenas de gala corporativas, bodas con paleta oscura (negro, burdeos, azul marino) y eventos de premiación. El tono gris ahumado absorbe menos luz que el transparente, creando un efecto más denso y misterioso que se adapta perfecto a la iluminación de spot o velas.",
  },
  {
    question: "¿La Ghost humo se ve bien con decoración en tonos oscuros?",
    answer: "Es la combinación más solicitada. <strong>Ghost humo + mesa negra + mantel de terciopelo oscuro</strong> es el setup favorito de los coordinadores de galas nocturnas en CDMX. El policarbonato ahumado tiene un efecto espejo suave que refleja los centros de mesa y la iluminación ambiental de forma muy fotogénica. Con flores en tono vino, mauve o borgoña, el resultado es dramático y elegante.",
  },
  {
    question: "¿Cuál es la diferencia visual entre la Ghost transparente y la Ghost humo?",
    answer: "La Ghost transparente 'desaparece' y deja ver el entorno con claridad. La <strong>Ghost humo tiene presencia visual</strong> — el tono gris añade profundidad y define el espacio sin opacarlo. Si el transparente es invisible, el humo es discreto. Para eventos donde quieres que la silla tenga personalidad propia sin competir con la decoración, el humo es la elección correcta.",
  },
  {
    question: "¿La Ghost humo funciona para eventos corporativos?",
    answer: "Sí, es una de las variantes más pedidas para eventos corporativos de alto nivel. Cenas de premiación, lanzamientos de producto en salones oscuros, reuniones de directivos — la Ghost humo proyecta <strong>modernidad y seriedad</strong> sin la rigidez de una silla convencional. Combinada con mesas rectangulares negras o de mármol oscuro, el resultado es de sala de juntas convertida en escenario de gala.",
  },
  {
    question: "¿Se pueden mezclar Ghost humo con Ghost transparente?",
    answer: "Sí, y es una combinación con gran demanda para eventos con dos áreas distintas (ej: mesa de honor + mesas de invitados). La convención más solicitada: <strong>Ghost transparente en head table o área VIP</strong> + Ghost humo en las mesas del resto del salón. El contraste sutil entre el cristal puro y el ahumado añade jerarquía visual al espacio sin ser obvio.",
  },
];

const specs = [
  { label: "Color / Acabado", value: "Humo / Gris ahumado — policarbonato con pigmento gris translúcido" },
  { label: "Material", value: "Policarbonato virgen 3.5mm con tinte ahumado integral" },
  { label: "Diseñador", value: "Philippe Starck — diseño original Ghost Chair" },
  { label: "Resistencia", value: "130 kg por silla" },
  { label: "Peso", value: "3.8 kg" },
  { label: "Altura total", value: "93 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Apilable", value: "Sí, hasta 6 unidades" },
  { label: "Resistencia UV", value: "Sí — el pigmento no se decolora con exposición solar" },
  { label: "Uso exterior", value: "Apto para jardines y terrazas cubiertas" },
  { label: "Precio base", value: "Desde $48/unidad (varía según volumen y fecha)" },
  { label: "Mantenimiento", value: "Limpieza profesional e inspección pre-evento incluida" },
];

const reviews = [
  {
    author: "Patricia Ríos",
    text: "Las Ghost humo en nuestra cena de gala anual fueron un éxito total. Con la iluminación tenue del salón y las mesas negras, el ambiente quedó como de película. Puntualísimos en entrega y recogida.",
    rating: 5,
    date: "2025-12-03",
  },
  {
    author: "Eduardo Lara",
    text: "Organizamos una premiación corporativa para 250 personas. Las Ghost humo con mesas de mármol negro y flores en mauve: espectacular. Cada detalle fue cuidado y las sillas llegaron impecables.",
    rating: 5,
    date: "2025-10-18",
  },
  {
    author: "Valentina Cruz",
    text: "Combinamos Ghost transparentes en el head table con Ghost humo en el resto del salón para mi boda. El efecto de contraste fue exactamente lo que buscaba — sofisticado sin ser obvio. Todas mis amigas preguntaron dónde las rentamos.",
    rating: 5,
    date: "2025-09-30",
  },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Ghost Humo Gris para Galas y Eventos en CDMX",
    description: "Sillas Ghost humo gris diseño Philippe Starck para galas nocturnas y eventos formales en CDMX. Policarbonato ahumado 3.5mm · 130 kg resistencia · Desde $48/silla.",
    url: "/servicios/mobiliario/sillas/ghost/humo/",
    priceRange: { min: 48, max: 75 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Ghost", url: "/servicios/mobiliario/sillas/ghost/" },
    { name: "Humo / Gris", url: "/servicios/mobiliario/sillas/ghost/humo/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Transparente Cristal", href: "/servicios/mobiliario/sillas/ghost/transparente/" },
  { name: "Humo / Gris", href: null, active: true },
  { name: "Ámbar", href: "/servicios/mobiliario/sillas/ghost/ambar/" },
  { name: "Exterior UV", href: "/servicios/mobiliario/sillas/ghost/exterior/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Sillas Ghost Humo Gris CDMX"
  description="Renta sillas Ghost humo gris en CDMX — diseño Philippe Starck, policarbonato ahumado 3.5mm. Perfectas para galas nocturnas y eventos formales."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Sofisticación ahumada — la Ghost que define las galas nocturnas"
    title='Silla Ghost <span class="highlight">Humo / Gris</span> — Renta en CDMX'
    subtitle="El tono ahumado que añade profundidad y misterio sin opacar el espacio. Policarbonato virgen 3.5mm con pigmento gris integral, diseño Philippe Starck, resistencia de 130 kg. La variante preferida para galas nocturnas, cenas de premiación y eventos formales en CDMX."
    primaryCTA={{ label: "Cotizar sillas Ghost humo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost humo/gris para mi evento` }}
    cards={[
      {
        title: "El gris que no es gris — es la sofisticación en estado puro",
        content: "La <strong>Ghost humo</strong> tiene algo que la transparente cristal no puede lograr: presencia. No desaparece — se muestra con discreción. El policarbonato con pigmento gris ahumado integral crea un tono que en plena luz parece gris perla, y en ambientes nocturnos con iluminación tenue adquiere una profundidad casi metálica. Para galas donde cada elemento del montaje debe hablar del mismo lenguaje de sofisticación, la Ghost humo es la respuesta.",
      },
      {
        title: "Resistencia comprobada y entrega profesional en CDMX",
        content: "Con <strong>130 kg de capacidad</strong> y el mismo policarbonato virgen de 3.5mm del resto de la línea Ghost, la variante humo es tan resistente y duradera como la transparente. El pigmento es integral — no es pintura ni capa superficial, por lo que no se descascara ni decolora. Cada unidad se limpia e inspecciona antes de entregarse. Entrega, montaje y desmontaje incluidos en CDMX. <strong>Desde $48/silla</strong> en lotes de 100+.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La Ghost humo que define el ambiente de las galas más sofisticadas en CDMX — cotiza ahora"
    subheadline="Diseño Starck · Policarbonato ahumado 3.5mm · Montaje profesional incluido"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Ghost</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Ghost humo para tu gala nocturna</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Ghost humo/gris para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Ghost Humo en Galas y Eventos Nocturnos</h2>
            <p class="section__subtitle">Cenas de gala, premiaciones y bodas formales en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Ghost Humo / Gris</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Ghost humo es la silla elegida para las galas más elegantes?"
    headingId="descripcion-heading"
    badge="Presencia sin arrogancia — sofisticación en gris ahumado"
    tags={["Humo / Gris", "Galas Nocturnas", "Eventos Formales", "Diseño Starck"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Cuando el espacio requiere que cada elemento del montaje proyecte sofisticación con precisión quirúrgica, la <strong>Ghost humo</strong> toma el lugar que ninguna silla convencional puede ocupar. El tono gris ahumado tiene una cualidad única: es percibido inconscientemente como más caro, más curado, más intencional. No es el negro que divide, ni el blanco que ilumina — es el gris que une y profundiza.</p>
      <p class="showcase__text">El <strong>pigmento gris está integrado en la masa del policarbonato</strong> durante la fabricación — no es pintura ni capa superficial. Esto significa que el color es uniforme hasta el interior de la pieza, nunca se descascara y mantiene su tono estable incluso con exposición solar prolongada. La misma tecnología de <strong>policarbonato virgen de 3.5mm</strong> que comparte con el cristal transparente garantiza 130 kg de capacidad y décadas de durabilidad.</p>
      <p class="showcase__text">En ambiente nocturno con iluminación de spot o velas, la Ghost humo hace algo extraordinario: <strong>refleja la luz como un espejo suave</strong>. El efecto es dramático sin ser excesivo — exactamente lo que buscan los coordinadores de galas de alto nivel en CDMX.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-ghost-humo-gala-dramatica-01.avif" alt="Silla Ghost humo en gala dramática con iluminación tenue" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-ghost-humo-evento-noche-02.avif" alt="Ghost humo en evento nocturno CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sillas-ghost-humo-evento.avif" alt="Montaje sillas Ghost humo en salón de eventos" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Ghost Humo</h2>
            <p class="section__subtitle">Combinaciones que funcionan para galas nocturnas y eventos formales</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Nocturna Oscura</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost humo + <strong>mesa rectangular negra</strong> + mantel de terciopelo negro + centros de flores en vino o borgoña. El setup más dramático y fotogénico para premiaciones y cenas de gala. La reflexión del humo en el negro crea profundidad visual imposible de lograr con otro material.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Contemporánea</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost humo + <strong>mesa redonda de madera oscura</strong> + mantel gris grafito + flores en tono mauve o blanco roto. Para bodas con paleta fría y estilo editorial, esta combinación proyecta modernidad sin perder calidez. Muy solicitado en venues industriales convertidos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Corporativo de Élite</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Ghost humo + <strong>mesa de mármol negro o gris</strong> + centro de mesa minimalista con una sola orquídea blanca. Para directorios, cenas VIP y reuniones de alto nivel donde la austeridad es un mensaje. El humo proyecta seriedad y diseño sin estridencias.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Ghost Humo / Gris</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Ghost Humo"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Policarbonato ahumado de 3.5mm, resistencia de 130 kg y pigmento integral que no decolora. Resolvemos las dudas más frecuentes sobre la Ghost humo.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas Ghost te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Ghost humo gris`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Ghost y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Ghost</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
