---
/**
 * ─── Silla Chiavari Dorada — Página de Variante (Nivel 4) ───
 * Aluminio con acabado dorado anodizado: el clásico para bodas en haciendas y salones de lujo.
 * 1.8 kg, 200 kg resistencia, desde $40/silla.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Chiavari > Dorada
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { label: "Dorada" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-chiavari-dorada-boda-cdmx-01.avif", alt: "Silla Chiavari dorada en boda CDMX con decoración floral" },
  { src: "/images/mobiliario/chiavari-dorada-02.avif", alt: "Silla Chiavari dorada anodizada aluminio evento formal" },
  { src: "/images/mobiliario/silla-chiavari-dorada-salon-cdmx-07.avif", alt: "Chiavari dorada en salón de lujo CDMX" },
  { src: "/images/mobiliario/silla-chiavari-dorada-reception-salon-04.avif", alt: "Sillas Chiavari doradas en recepción de boda salón elegante" },
  { src: "/images/mobiliario/silla-chiavari-dorada-cena-gala-05.avif", alt: "Chiavari dorada cena de gala montaje formal CDMX" },
  { src: "/images/mobiliario/silla-chiavari-dorada-evento-formal-06.avif", alt: "Montaje sillas Chiavari doradas evento formal hacienda" },
  { src: "/images/mobiliario/silla-chiavari-dorada-salon-lujo-08.avif", alt: "Sillas Chiavari doradas en salón de lujo iluminación cálida" },
  { src: "/images/mobiliario/silla-chiavari-dorada-boda-salon-09.avif", alt: "Boda salón sillas Chiavari doradas con cojines blancos" },
];

const faqs = [
  {
    question: "¿Cuál es la diferencia entre la silla Chiavari dorada y la Tiffany dorada?",
    answer: "La <strong>Chiavari dorada</strong> es de aluminio anodizado: ligera (1.8 kg), estructura abierta con travesaños horizontales en el respaldo que le dan ese look clásico europeo. La <strong>Tiffany</strong> es de resina policarbonato, respaldo macizo en forma de medallón y asiento más amplio. La Chiavari es la preferida para bodas en haciendas coloniales y jardines históricos porque su silueta es más fina y tradicional. La Tiffany luce mejor en salones contemporáneos y eventos con decoración moderna."
  },
  {
    question: "¿Cuánto pesan las sillas Chiavari doradas y son fáciles de transportar?",
    answer: "Cada silla pesa <strong>1.8 kg</strong> — notablemente más ligera que la mayoría de las sillas de evento. Se apilan en grupos de 8-10 unidades y caben perfectamente en nuestras unidades de transporte. Para un evento de 200 personas necesitamos 2 viajes en camioneta. El peso reducido también facilita el montaje: un equipo de 2 personas puede montar 100 sillas Chiavari en aproximadamente 45 minutos."
  },
  {
    question: "¿Para qué tipos de eventos es ideal la Chiavari dorada?",
    answer: "La <strong>Chiavari dorada</strong> brilla especialmente en: bodas en haciendas coloniales (Hacienda San Juan, Hacienda Tlalpan, La Casona de Tlalpan), ceremonias religiosas con decoración clásica, cenas de gala en salones con arquitectura histórica, y eventos con paleta dorado-blanco-verde. También es la primera opción cuando el venue tiene piso de piedra o mármol porque la base de aluminio no daña superficies delicadas."
  },
  {
    question: "¿La Chiavari dorada incluye cojín o se renta por separado?",
    answer: "El <strong>cojín acolchado está incluido sin costo adicional</strong> en más de 20 colores: blanco, marfil, champagne, dorado, negro, rosa blush, terracota, verde salvia y más. Para bodas en haciendas las combinaciones más pedidas son dorada + cojín blanco (elegancia clásica), dorada + cojín marfil (tono cálido que complementa la piedra de hacienda) y dorada + cojín nude (look editorial de revista). Te enviamos muestras digitales para que elijas antes de confirmar."
  },
  {
    question: "¿Cuánto cuesta rentar 150 sillas Chiavari doradas para una boda en hacienda?",
    answer: "Para <strong>150 sillas Chiavari doradas</strong> con cojín incluido, el precio está alrededor de $7,500-$9,000 (desde $50-60 por unidad). Incluye entrega en CDMX y área metropolitana, montaje con layout aprobado, y desmontaje al término del evento. Para haciendas fuera de CDMX puede aplicar cargo de flete según ubicación. Con 90+ días de anticipación podemos bloquear tu fecha con el 30% de anticipo. Cotización exacta por WhatsApp en menos de 30 minutos."
  },
];

const specs = [
  { label: "Material", value: "Aluminio aeronáutico con acabado dorado anodizado" },
  { label: "Peso", value: "1.8 kg por silla" },
  { label: "Resistencia", value: "200 kg certificado" },
  { label: "Altura total", value: "92 cm (respaldo)" },
  { label: "Ancho asiento", value: "38 cm" },
  { label: "Acabado", value: "Dorado anodizado — no se descascara ni oxida" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Cojín", value: "Incluido sin costo — 20+ colores" },
  { label: "Precio referencia", value: "Desde $40/silla en lotes de 200+" },
  { label: "Mantenimiento", value: "Limpieza e inspección pre-evento incluida" },
];

const reviews = [
  { author: "Paulina Méndez", text: "Rentamos 180 sillas Chiavari doradas para nuestra boda en Hacienda San Juan. La calidad es impresionante — el aluminio dorado reflejó perfecto con las velas y los arreglos florales blancos. Todo el equipo fue puntual y profesional.", rating: 5, date: "2025-11-08" },
  { author: "Carlos Ibarra", text: "Organizamos una cena de gala corporativa con 220 Chiavari doradas. El montaje quedó impecable, las sillas llegaron sin un raspón. La ligereza del aluminio fue clave — el equipo terminó de montar en tiempo récord.", rating: 5, date: "2025-10-22" },
  { author: "Daniela Rojas", text: "Para mi boda de jardín nocturno las Chiavari doradas fueron perfectas. Con la iluminación cálida el dorado quedó espectacular. Los cojines marfil que pedimos combinaron exactamente como esperaba.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Chiavari Doradas para Bodas y Eventos en CDMX",
    description: "Sillas Chiavari aluminio acabado dorado anodizado. 1.8 kg, 200 kg resistencia. Cojín incluido en 20+ colores. Ideal para bodas en haciendas y salones clásicos. Desde $40/silla.",
    url: "/servicios/mobiliario/sillas/chiavari/dorada/",
    priceRange: { min: 40, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 43,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Chiavari", url: "/servicios/mobiliario/sillas/chiavari/" },
    { name: "Dorada", url: "/servicios/mobiliario/sillas/chiavari/dorada/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Dorada", href: null, active: true },
  { name: "Plateada", href: "/servicios/mobiliario/sillas/chiavari/plateada/" },
  { name: "Negra", href: "/servicios/mobiliario/sillas/chiavari/negra/" },
  { name: "Bronce", href: "/servicios/mobiliario/sillas/chiavari/bronce/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Chiavari Doradas para Bodas"
  description="Renta sillas Chiavari doradas en CDMX — aluminio anodizado dorado, 1.8 kg, 200 kg resistencia. Cojín en 20+ colores incluido."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Aluminio dorado anodizado — 200 kg resistencia — 1.8 kg peso"
    title='Silla Chiavari <span class="highlight">Dorada</span> — Renta en CDMX'
    subtitle="La Chiavari con acabado dorado anodizado: estructura de aluminio aeronáutico de 1.8 kg con resistencia de 200 kg. El modelo clásico europeo para bodas en haciendas coloniales, jardines históricos y salones de gran formato. Cojín en tu color preferido incluido."
    primaryCTA={{ label: "Cotizar sillas Chiavari doradas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari doradas para mi evento` }}
    cards={[
      {
        title: "Aluminio dorado que no se descascara ni oxida",
        content: "La <strong>silla Chiavari dorada</strong> tiene un proceso de anodizado electroquímico que integra el color directamente en el aluminio — no es pintura aplicada sobre la superficie. Eso significa que el acabado dorado <strong>no se descascara, no se oxida y no pierde brillo</strong> con el tiempo. A diferencia del acabado pintado, el anodizado aguanta el uso intensivo de eventos sin revelar el metal base. Cada silla llega a tu evento en el mismo estado en que se fabricó.",
      },
      {
        title: "El modelo preferido para bodas en haciendas coloniales",
        content: "La silueta de la Chiavari — con sus travesaños horizontales en el respaldo y patas torneadas — es el diseño de silla de evento más fotografiado en bodas de hacienda. <strong>Combina con todo</strong>: arcos florales, candelabros, guirnaldas de luz, manteles hasta el piso. El cojín acolchado en 20+ colores va incluido sin cargo extra. Para haciendas con piso de piedra o mármol, la base de aluminio protege las superficies y evita el rallado que producen las sillas con base de hierro.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Chiavari dorada — el clásico europeo para bodas en haciendas de CDMX"
    subheadline="Aluminio anodizado · 200 kg resistencia · Cojín incluido · Montaje profesional"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Chiavari</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Chiavari doradas para tu boda o evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari doradas`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Chiavari Dorada en Bodas y Eventos Reales</h2>
            <p class="section__subtitle">Haciendas coloniales, salones de lujo y jardines históricos en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Chiavari Dorada</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué la Chiavari dorada domina las bodas en haciendas"
    headingId="descripcion-heading"
    badge="1.8 kg · 200 kg resistencia · Anodizado permanente"
    tags={["Dorado Anodizado", "Bodas Hacienda", "Aluminio 6061", "200 kg Resistencia"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El diseño de la silla Chiavari nació en Italia en el siglo XIX y lleva más de 150 años siendo el estándar de referencia para eventos formales en todo el mundo. La razón es simple: <strong>su proporción es perfecta</strong>. No es ni muy recargada ni muy minimalista — tiene presencia sin dominar el espacio.</p>
      <p class="showcase__text">En EVENTECH fabricamos nuestra Chiavari en <strong>aluminio aeronáutico aleación 6061</strong> — el mismo usado en aviación por su relación resistencia-peso. Con 1.8 kg soporta 200 kg sin flexar ni crujir. El anodizado dorado penetra 10-25 micrones dentro del metal, creando una capa que <strong>no se puede descascarar</strong> porque literalmente es parte del aluminio.</p>
      <p class="showcase__text">Para haciendas coloniales como San Juan de Dios, Tlalpan o La Casona, el dorado anodizado captura la luz de las velas de forma única — el acabado metalizado crea destellos cálidos que ningún acabado pintado puede imitar. Con flores blancas o crema, el resultado es exactamente lo que ves en las revistas de bodas.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sillas-chiavari-doradas-boda-lujo.avif" alt="Sillas Chiavari doradas en boda de lujo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sillas-chiavari-doradas-terraza-cdmx.avif" alt="Chiavari doradas en terraza evento CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-chiavari-dorada-banquete-10.avif" alt="Montaje Chiavari dorada banquete de gala" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Chiavari Dorada</h2>
            <p class="section__subtitle">Combinaciones de cojín, mesa y mantelería que funcionan en haciendas</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Clásica en Hacienda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari dorada + <strong>cojín blanco satinado</strong> + mesa redonda con mantel marfil hasta el piso + arreglo floral alto en blanco y verde. La combinación más fotografiada en haciendas coloniales de CDMX.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Jardín al Atardecer</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari dorada + <strong>cojín nude o terracota</strong> + mesa de madera natural + velas flotantes. El cojín en tono tierra complementa el dorado cálido y crea una atmósfera orgánica y romántica en exteriores.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Dorada Total</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari dorada + <strong>cojín champagne</strong> + mesa con mantel dorado satinado + candelabros altos. Look monocromático de revista: todo en la misma paleta dorado-champagne, lujoso sin recargarse.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Chiavari Dorada</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Chiavari Dorada"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Aluminio anodizado que no se descascara, 200 kg de resistencia real, y el diseño clásico europeo que lleva 150 años en bodas de lujo. Aquí resolvemos las dudas más frecuentes.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla Chiavari dorada`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sillas, fecha y venue — cotización en menos de 30 minutos.</p>
