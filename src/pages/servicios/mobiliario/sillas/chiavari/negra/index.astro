---
/**
 * ─── Silla Chiavari Negra — Página de Variante (Nivel 4) ───
 * Aluminio con acabado negro mate: elegancia oscura para galas nocturnas y eventos premium.
 * 1.8 kg, 200 kg resistencia.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Chiavari > Negra
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { label: "Negra" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-chiavari-negro-mate-boda-floral-01.avif", alt: "Silla Chiavari negra mate en boda con arreglos florales" },
  { src: "/images/mobiliario/silla-chiavari-negro-mate-elegante-02.avif", alt: "Chiavari negra mate acabado elegante evento nocturno" },
  { src: "/images/mobiliario/silla-chiavari-negro-mate-arreglo-03.avif", alt: "Silla Chiavari negra con arreglo floral blanco y negro" },
  { src: "/images/mobiliario/silla-chiavari-negro-mate-flores-04.avif", alt: "Chiavari negra mate con flores montaje gala premium" },
  { src: "/images/mobiliario/silla-chiavari-negro-mate-cojin-06.avif", alt: "Silla Chiavari negra mate con cojín blanco gala" },
  { src: "/images/mobiliario/real-wedding-chiavari-05.avif", alt: "Boda real con sillas Chiavari negras montaje nocturno" },
  { src: "/images/mobiliario/real-wedding-chiavari-07.avif", alt: "Evento premium sillas Chiavari negras salón de lujo" },
  { src: "/images/mobiliario/real-wedding-chiavari-08.avif", alt: "Chiavari negras en boda real CDMX iluminación dramática" },
];

const faqs = [
  {
    question: "¿La silla Chiavari negra es adecuada para bodas o solo para eventos corporativos?",
    answer: "La <strong>Chiavari negra</strong> tiene presencia en ambos tipos de evento, pero con usos distintos. En bodas, se usa para ceremonias con paleta oscura — negro, blanco y dorado, o negro con flores de temporada en tonos profundos como burdeos y esmeralda. Es la elección de novias que quieren romper con el blanco tradicional y crear un ambiente dramático y sofisticado. En eventos corporativos, la negra es estándar para galas de premiación, eventos de lujo de marcas premium y cenas con red carpet."
  },
  {
    question: "¿El acabado negro mate se raya fácilmente con el uso en eventos?",
    answer: "El acabado negro mate anodizado es uno de los más resistentes de la línea porque los pequeños rayones superficiales son <strong>prácticamente invisibles</strong> — sobre negro mate, las marcas de uso se ven mucho menos que sobre dorado brillante o plateado. El anodizado electroquímico penetra en el aluminio (no es pintura aplicada), por lo que el negro no se descascara ni se desprende. Cada unidad se inspecciona antes del evento y las sillas con desgaste visible se retiran del inventario premium."
  },
  {
    question: "¿Qué cojín va mejor con la silla Chiavari negra para una gala de lujo?",
    answer: "Depende del efecto que busques. <strong>Negro + cojín blanco</strong>: contraste clásico, muy fotogénico, nunca falla. <strong>Negro + cojín dorado</strong>: el combo más lujoso visualmente, ideal cuando tienes detalles dorados en el resto del montaje. <strong>Negro + cojín burdeos</strong>: dramático y sofisticado, perfecto para galas nocturnas con iluminación cálida. <strong>Negro + cojín negro</strong>: efecto total-black, minimalista y de alto impacto para lanzamientos de marca premium. Todos los cojines van incluidos sin costo adicional."
  },
  {
    question: "¿Para eventos al aire libre de noche funciona la Chiavari negra?",
    answer: "Funciona extraordinariamente bien en exteriores nocturnos. El negro mate <strong>no refleja la luz ambiente de forma agresiva</strong> — crea siluetas limpias que con iluminación puntual (velas, spots o guirnaldas) generan un efecto visual muy cinematográfico. La estructura de aluminio resiste la humedad de la noche sin oxidarse. Para jardines oscuros con iluminación tenue, la Chiavari negra prácticamente desaparece como mobiliario y deja que la decoración floral y la iluminación sean el protagonista."
  },
  {
    question: "¿Cuánto cuesta rentar 100 sillas Chiavari negras para una gala en CDMX?",
    answer: "Para <strong>100 sillas Chiavari negras</strong> con cojín incluido, el precio referencia está entre $5,500-$6,500 (desde $55-65 por unidad a ese volumen). Incluye entrega en CDMX, montaje según layout del venue y desmontaje al término. Para galas nocturnas con logística especial (entradas restringidas, montaje fuera de horario, múltiples pisos), coordinamos directamente con el responsable del venue. Anticipo del 30% para bloquear tu fecha. Cotización exacta en menos de 30 minutos por WhatsApp."
  },
];

const specs = [
  { label: "Material", value: "Aluminio aeronáutico con acabado negro mate anodizado" },
  { label: "Peso", value: "1.8 kg por silla" },
  { label: "Resistencia", value: "200 kg certificado" },
  { label: "Altura total", value: "92 cm (respaldo)" },
  { label: "Ancho asiento", value: "38 cm" },
  { label: "Acabado", value: "Negro mate anodizado — sin brillos, máxima elegancia" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Cojín", value: "Incluido sin costo — 20+ colores disponibles" },
  { label: "Precio referencia", value: "Desde $50/silla en lotes de 150+" },
  { label: "Usos recomendados", value: "Galas nocturnas, bodas premium, lanzamientos de marca" },
];

const reviews = [
  { author: "Valentina Cruz", text: "Rentamos 120 Chiavari negras para mi boda en paleta negro, blanco y oro. El resultado fue exactamente lo que imaginé — dramático, elegante, cinematográfico. Las fotos quedaron increíbles con el fondo oscuro.", rating: 5, date: "2025-11-15" },
  { author: "Miguel Ángel Torres", text: "Para la gala anual de nuestra empresa usamos 280 Chiavari negras con cojín dorado. El contraste negro-dorado en el salón fue impresionante. Cero problemas de logística, entrega perfecta, sillas en estado impecable.", rating: 5, date: "2025-10-08" },
  { author: "Andrea Morales", text: "Organizamos el lanzamiento de una colección de moda con 90 sillas Chiavari negras. El look total-black del mobiliario era exactamente lo que necesitábamos para la producción fotográfica. Perfecto para marcas de lujo.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Chiavari Negras para Galas y Eventos Premium en CDMX",
    description: "Sillas Chiavari aluminio acabado negro mate anodizado. 1.8 kg, 200 kg resistencia. Elegancia oscura para galas nocturnas, bodas premium y lanzamientos de marca. Cojín incluido. Desde $50/silla.",
    url: "/servicios/mobiliario/sillas/chiavari/negra/",
    priceRange: { min: 50, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Chiavari", url: "/servicios/mobiliario/sillas/chiavari/" },
    { name: "Negra", url: "/servicios/mobiliario/sillas/chiavari/negra/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Dorada", href: "/servicios/mobiliario/sillas/chiavari/dorada/" },
  { name: "Plateada", href: "/servicios/mobiliario/sillas/chiavari/plateada/" },
  { name: "Negra", href: null, active: true },
  { name: "Bronce", href: "/servicios/mobiliario/sillas/chiavari/bronce/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Chiavari Negras para Galas"
  description="Renta sillas Chiavari negras en CDMX — aluminio negro mate anodizado, 1.8 kg, 200 kg resistencia."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="Negro mate anodizado — elegancia oscura para eventos de alto impacto"
    title='Silla Chiavari <span class="highlight">Negra</span> — Renta en CDMX'
    subtitle="La Chiavari con acabado negro mate anodizado: el mobiliario que define las galas nocturnas y los eventos premium en CDMX. Aluminio aeronáutico de 1.8 kg con resistencia de 200 kg. Para bodas con paleta oscura, lanzamientos de marca y cenas de gala donde la elegancia tiene que ser contundente."
    primaryCTA={{ label: "Cotizar sillas Chiavari negras", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari negras para mi evento` }}
    cards={[
      {
        title: "Negro mate que crea atmósferas dramáticas y cinematográficas",
        content: "El negro mate anodizado tiene una cualidad única: <strong>absorbe la luz en lugar de reflejarla</strong>. En una gala nocturna con iluminación puntual, las sillas Chiavari negras prácticamente desaparecen como elemento estructural y el ojo del visitante va directo a los arreglos florales, la vajilla y la decoración de mesa. El resultado es un ambiente que se siente <strong>producido</strong>, como una sesión fotográfica de revista. Ningún otro acabado logra ese efecto de profundidad.",
      },
      {
        title: "Versatilidad oscura: bodas, galas y lanzamientos de marca",
        content: "La Chiavari negra es la elección de clientes que saben exactamente lo que quieren — una estética oscura, elegante y con carácter. No es para quienes buscan lo seguro y convencional: <strong>es para quienes quieren que su evento se recuerde</strong>. Cojín en 20+ colores incluido: el contraste negro + blanco es el más fotogénico, negro + dorado el más lujoso, negro + burdeos el más dramático. Para lanzamientos de producto de marcas premium o galas de premiación con producción de alto nivel.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Chiavari negra — elegancia oscura para galas nocturnas y eventos premium en CDMX"
    subheadline="Negro mate anodizado · 200 kg resistencia · Cojín incluido · Montaje profesional"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Chiavari</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Chiavari negras para tu gala o evento premium</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari negras`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Chiavari Negra en Galas y Eventos Premium Reales</h2>
            <p class="section__subtitle">Bodas nocturnas, galas de lujo y lanzamientos de marca en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Chiavari Negra</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La Chiavari negra: cuando el mobiliario define el concepto del evento"
    headingId="descripcion-heading"
    badge="Negro mate · Atmósfera dramática · Alto impacto visual"
    tags={["Negro Mate", "Galas Nocturnas", "Bodas Premium", "Lanzamientos Marca"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay eventos donde el dorado o el plateado simplemente no son la respuesta correcta. Cuando la identidad del evento exige sofisticación oscura — una boda nocturna en jardín con velas, una gala de premiación con red carpet, un lanzamiento de producto de una marca de moda de lujo — la <strong>Chiavari negra mate</strong> es la pieza que completa el concepto.</p>
      <p class="showcase__text">El negro mate anodizado tiene propiedades ópticas únicas: no genera reflexiones ni brillos, lo que hace que la silla se integre visualmente al espacio sin llamar la atención sobre sí misma. <strong>El invitado se sienta en una silla elegante sin saber exactamente por qué el salón se siente tan lujoso</strong> — y es precisamente porque el mobiliario oscuro actúa como fondo que hace destacar todo lo demás.</p>
      <p class="showcase__text">En EVENTECH mantenemos este inventario en condiciones impecables porque sabemos que el negro es el acabado que menos perdona el descuido. Cada silla se inspecciona con luz directa antes de salir a evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-chiavari-negro-mate-boda-floral-01.avif" alt="Silla Chiavari negra mate en boda con decoración floral" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-chiavari-negro-mate-elegante-02.avif" alt="Chiavari negra mate acabado elegante evento nocturno" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-chiavari-negro-mate-cojin-06.avif" alt="Silla Chiavari negra con cojín blanco gala" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Chiavari Negra</h2>
            <p class="section__subtitle">Combinaciones de impacto visual máximo para galas y eventos de lujo</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Contraste Clásico B&N</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari negra + <strong>cojín blanco</strong> + mantel blanco hasta el piso + flores blancas. El contraste negro y blanco es el look más fotogénico: limpio, editorial, atemporal. Ideal para bodas minimalistas y eventos de moda.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Negro y Oro</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari negra + <strong>cojín dorado</strong> + mantel negro con runner dorado + candelabros dorados. El combo más opulento visualmente — impacto inmediato al entrar al salón. Para galas de premiación y cenas de fin de año premium.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Total Black Premium</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari negra + <strong>cojín negro</strong> + mantel negro + flores en colores joya (burdeos, esmeralda, púrpura). El look más dramático y sofisticado — para lanzamientos de marca premium donde la estética oscura es parte del concepto.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Chiavari Negra</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Chiavari Negra"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Negro mate que crea atmósferas cinematográficas, 200 kg de resistencia, y el acabado que define los eventos premium de CDMX. Aquí respondemos las dudas más frecuentes.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
