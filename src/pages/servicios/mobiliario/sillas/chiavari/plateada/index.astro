---
/**
 * ─── Silla Chiavari Plateada — Página de Variante (Nivel 4) ───
 * Aluminio con acabado plata anodizado: moderna, versátil, ideal para corporativos y galas.
 * 1.8 kg, 200 kg resistencia.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Chiavari > Plateada
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { label: "Plateada" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-chiavari-plateada-terraza-jardin-01.avif", alt: "Silla Chiavari plateada en terraza jardín evento elegante" },
  { src: "/images/mobiliario/silla-chiavari-plateada-jardin-exterior-02.avif", alt: "Chiavari plateada jardín exterior evento formal CDMX" },
  { src: "/images/mobiliario/sillas-chiavari-plateada-evento.avif", alt: "Montaje sillas Chiavari plateadas en evento corporativo" },
  { src: "/images/mobiliario/silla-chiavari-plateada-guirnaldas-noche-04.avif", alt: "Sillas Chiavari plateadas con guirnaldas luz nocturna" },
  { src: "/images/mobiliario/silla-chiavari-plateada-evento-premium-07.avif", alt: "Chiavari plateada en evento premium iluminación sofisticada" },
  { src: "/images/mobiliario/silla-chiavari-plateada-guirnaldas-exterior-06.avif", alt: "Sillas Chiavari plateadas con guirnaldas exterior jardín" },
  { src: "/images/mobiliario/real-wedding-chiavari-04.avif", alt: "Boda real con sillas Chiavari plateadas montaje elegante" },
  { src: "/images/mobiliario/sillas-chiavari-terraza-vista-panoramica.avif", alt: "Vista panorámica terraza con sillas Chiavari plateadas" },
];

const faqs = [
  {
    question: "¿La Chiavari plateada funciona para eventos corporativos de gala?",
    answer: "Es posiblemente la mejor opción para <strong>eventos corporativos de gala</strong>. El plateado anodizado proyecta modernidad y profesionalismo sin la connotación nupcial del dorado. Se usa frecuentemente en: cenas de fin de año de empresas Fortune 500, premiaciones y entregas de reconocimientos, lanzamientos de producto de alto perfil y convenciones ejecutivas con dress code formal. La plata refleja la luz de los sistemas de iluminación LED de forma espectacular, creando un ambiente que se siente de producción televisiva."
  },
  {
    question: "¿Qué colores de cojín combinan mejor con la silla Chiavari plateada?",
    answer: "La Chiavari plateada tiene la mayor versatilidad cromática de toda la línea. Las 4 combinaciones más pedidas: <strong>plateada + cojín blanco</strong> (limpieza total, muy fotogénico), <strong>plateada + cojín azul marino o gris</strong> (corporativo refinado), <strong>plateada + cojín negro</strong> (gala de alto impacto), y <strong>plateada + cojín rosa blush</strong> (boda moderna en tonos fríos). A diferencia del dorado, el plateado no compite con ningún color — es literalmente neutro y complementa cualquier paleta de decoración."
  },
  {
    question: "¿La silla Chiavari plateada es apta para exteriores y jardines?",
    answer: "Sí. El aluminio anodizado es <strong>resistente a la corrosión y a los rayos UV</strong> — no se oxida aunque quede expuesto a la humedad de la noche o a la lluvia ligera. Para jardines, la plata tiene una ventaja adicional sobre el dorado: refleja menos el calor solar durante eventos diurnos, lo que la hace más cómoda para invitados en exteriores. La base de aluminio no daña el pasto ni las superficies de piedra o cerámica. Para eventos en terrazas y jardines de hacienda es una elección frecuente."
  },
  {
    question: "¿Cuántas sillas Chiavari plateadas puedo rentar para una gala de 300 personas?",
    answer: "Para <strong>300 personas</strong> necesitas exactamente 300 sillas para los comensales, más 10-15% adicional para ceremonias o espacios de registro (si aplica). Contamos con stock suficiente para galas de hasta 600 sillas plateadas en una sola entrega. El precio para 300 unidades está en el rango de $13,500-$16,500 (desde $45-55 por unidad a ese volumen), con cojín en el color que elijas incluido. Para galas corporativas trabajamos con coordinadores de evento y podemos integrarnos a los timings de producción del venue."
  },
  {
    question: "¿Qué diferencia tiene la Chiavari plateada respecto a la versión 'espejo' que ofrecen otros proveedores?",
    answer: "La versión <strong>'espejo'</strong> es una pintura cromada que se aplica sobre la superficie — da un reflejo muy intenso tipo espejo, pero se descascara con el uso intensivo y es más frágil. Nuestra <strong>Chiavari plateada anodizada</strong> tiene un acabado mate/satinado más discreto que no se descascara porque el proceso electroquímico integra el acabado en el aluminio. El resultado es un plateado más sofisticado y duradero — menos 'espejo de baño', más 'accesorio de lujo'. Para eventos de alto presupuesto donde la calidad visual importa, la diferencia es visible."
  },
];

const specs = [
  { label: "Material", value: "Aluminio aeronáutico con acabado plata anodizado" },
  { label: "Peso", value: "1.8 kg por silla" },
  { label: "Resistencia", value: "200 kg certificado" },
  { label: "Altura total", value: "92 cm (respaldo)" },
  { label: "Ancho asiento", value: "38 cm" },
  { label: "Acabado", value: "Plata anodizado satinado — versátil y neutro" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Cojín", value: "Incluido sin costo — 20+ colores" },
  { label: "Precio referencia", value: "Desde $45/silla en lotes de 200+" },
  { label: "Usos recomendados", value: "Corporativos, galas, bodas modernas, eventos formales" },
];

const reviews = [
  { author: "Alejandro Fuentes", text: "Rentamos 250 Chiavari plateadas para la cena de gala anual de nuestra empresa. El resultado fue espectacular — con la iluminación azul y los manteles blancos, el salón quedó como producción de televisión. 100% lo repetimos.", rating: 5, date: "2025-12-05" },
  { author: "Sofía Alvarado", text: "Para mi boda modernista en tons fríos, la Chiavari plateada con cojín gris claro fue exactamente lo que buscaba. Nada de oro tradicional — quería algo diferente y lo conseguimos. Todas mis amigas preguntaron por las sillas.", rating: 5, date: "2025-10-30" },
  { author: "Héctor Ramírez", text: "Organizamos el lanzamiento de producto de una marca premium con 180 Chiavari plateadas. La entrega fue en tiempo, el montaje limpio, y las sillas aguantaron perfectamente el evento de 6 horas. Excelente servicio.", rating: 5, date: "2025-09-12" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Chiavari Plateadas para Corporativos y Galas en CDMX",
    description: "Sillas Chiavari aluminio acabado plata anodizado. 1.8 kg, 200 kg resistencia. Cojín incluido en 20+ colores. Ideal para eventos corporativos, galas y bodas modernas. Desde $45/silla.",
    url: "/servicios/mobiliario/sillas/chiavari/plateada/",
    priceRange: { min: 45, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Chiavari", url: "/servicios/mobiliario/sillas/chiavari/" },
    { name: "Plateada", url: "/servicios/mobiliario/sillas/chiavari/plateada/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Dorada", href: "/servicios/mobiliario/sillas/chiavari/dorada/" },
  { name: "Plateada", href: null, active: true },
  { name: "Negra", href: "/servicios/mobiliario/sillas/chiavari/negra/" },
  { name: "Bronce", href: "/servicios/mobiliario/sillas/chiavari/bronce/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Chiavari Plateadas"
  description="Renta sillas Chiavari plateadas en CDMX — aluminio anodizado plata, 1.8 kg, 200 kg resistencia."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="Plata anodizada — neutra y versátil para cualquier paleta de color"
    title='Silla Chiavari <span class="highlight">Plateada</span> — Renta en CDMX'
    subtitle="La Chiavari con acabado plata anodizado: moderna, neutra y universalmente versátil. Aluminio aeronáutico de 1.8 kg con resistencia de 200 kg. La primera opción para eventos corporativos de gala, bodas modernas y eventos formales donde el dorado resultaría demasiado tradicional."
    primaryCTA={{ label: "Cotizar sillas Chiavari plateadas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari plateadas para mi evento` }}
    cards={[
      {
        title: "Plata anodizada — el acabado más versátil de la línea",
        content: "El plateado anodizado es neutral por naturaleza — combina con cualquier color sin competir ni dominar. <strong>Azul marino, blanco, negro, gris, rosa blush, verde esmeralda</strong>: la silla Chiavari plateada se adapta a todas las paletas. Es por eso que es la primera opción para coordinadores de eventos corporativos que trabajan con paletas de color distintas en cada cliente. Un inventario de Chiavari plateadas sirve para la gala roja de una empresa, el lanzamiento blanco de un producto y la boda azul de otra en el mismo mes.",
      },
      {
        title: "Galas corporativas, bodas modernas, eventos de alto perfil",
        content: "Mientras que la Chiavari dorada define la boda de hacienda clásica, la <strong>Chiavari plateada define el evento de producción contemporánea</strong>. Se usa en cenas de fin de año de empresas transnacionales, lanzamientos de producto con escenografía LED, bodas de estilo editorial con paleta fría, y premiaciones con red carpet. La plata refleja los sistemas de iluminación dinámica de forma espectacular — con iluminación LED azul o blanca, el efecto es impresionante. Cojín incluido en 20+ colores sin cargo adicional.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Chiavari plateada — la silla de evento más versátil para cualquier tipo de gala"
    subheadline="Plata anodizada · 200 kg resistencia · Cojín incluido · Montaje profesional"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Chiavari</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Chiavari plateadas para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari plateadas`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Chiavari Plateada en Corporativos y Galas Reales</h2>
            <p class="section__subtitle">Eventos corporativos, galas nocturnas y bodas formales en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Chiavari Plateada</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La Chiavari plateada: cuando la versatilidad es el diferenciador"
    headingId="descripcion-heading"
    badge="Plata anodizada · Neutra · Para cualquier paleta"
    tags={["Plata Anodizada", "Corporativos", "Galas Formales", "Bodas Modernas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">En producción de eventos profesional, la elección de mobiliario tiene que ser flexible. Un coordinador corporativo no puede tener sillas doradas para todos los eventos — el dorado transmite calidez y tradición, pero para una empresa de tecnología o una marca de lujo contemporánea puede sentirse <strong>anticuado</strong>. La Chiavari plateada resuelve ese problema: proyecta modernidad sin sacrificar elegancia.</p>
      <p class="showcase__text">La plata anodizada es cromáticamente neutra — no añade temperatura de color al espacio. Eso significa que la iluminación del venue tiene control total sobre el ambiente: con luz cálida la plata se vuelve ligeramente dorada, con luz fría se vuelve azulada y espectacular. Los <strong>coordinadores de producción de eventos</strong> que trabajan con sistemas de iluminación dinámica prefieren la Chiavari plateada precisamente por esta razón.</p>
      <p class="showcase__text">Cada silla llega limpia, sin rayones y con cojín en el color que elijas. Para eventos corporativos donde la coherencia visual es parte del mensaje de la empresa, la consistencia en la calidad de nuestro inventario es parte del servicio.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-chiavari-plateada-terraza-jardin-01.avif" alt="Sillas Chiavari plateadas en terraza jardín evento elegante" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-chiavari-plateada-evento-premium-07.avif" alt="Chiavari plateada en evento premium iluminación sofisticada" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-chiavari-plateada-guirnaldas-noche-04.avif" alt="Sillas Chiavari plateadas con guirnaldas nocturnas" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Chiavari Plateada</h2>
            <p class="section__subtitle">Combinaciones que funcionan en eventos corporativos y bodas modernas</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Corporativa Azul</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari plateada + <strong>cojín azul marino</strong> + mesa rectangular con mantel blanco + centro de mesa con flores azul y plata. El combo estándar para cenas anuales de empresas transnacionales en CDMX.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Editorial Fría</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari plateada + <strong>cojín gris claro o blanco</strong> + mesa con base metálica + flores en blanco y verde eucalipto. Para novias que buscan algo diferente al oro clásico — resultado editorial, moderno, muy fotogénico.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Lanzamiento Premium</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari plateada + <strong>cojín negro</strong> + mesa con mantel negro + iluminación LED puntual en plata y blanco. El setup preferido para lanzamientos de marca y eventos de alto impacto visual.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Chiavari Plateada</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Chiavari Plateada"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Plata anodizada que no se descascara, 200 kg de resistencia real, y la versatilidad cromática que necesitan los eventos corporativos de alto nivel. Aquí respondemos las preguntas más frecuentes.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
