---
/**
 * ─── Silla Chiavari Bronce — Página de Variante (Nivel 4) ───
 * Aluminio con acabado bronce envejecido: ideal para bodas vintage y haciendas coloniales.
 * 1.8 kg, 200 kg resistencia.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Chiavari > Bronce
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { label: "Bronce" },
];

const galleryImages = [
  { src: "/images/mobiliario/real-wedding-chiavari-01.avif", alt: "Silla Chiavari bronce en boda vintage hacienda colonial" },
  { src: "/images/mobiliario/real-wedding-chiavari-02.avif", alt: "Chiavari bronce envejecido boda real hacienda CDMX" },
  { src: "/images/mobiliario/real-wedding-chiavari-03.avif", alt: "Montaje sillas Chiavari bronce en evento jardín hacienda" },
  { src: "/images/mobiliario/chiavari-jardin-noche-guirnaldas-exterior.avif", alt: "Sillas Chiavari bronce en jardín nocturno guirnaldas cálidas" },
  { src: "/images/mobiliario/wedding-chiavari-01.avif", alt: "Boda vintage con sillas Chiavari bronce decoración floral" },
  { src: "/images/mobiliario/wedding-chiavari-02.avif", alt: "Chiavari bronce boda hacienda colonial con velas" },
  { src: "/images/mobiliario/wedding-chiavari-03.avif", alt: "Sillas Chiavari bronce en boda jardín romántico" },
  { src: "/images/mobiliario/wedding-chiavari-04.avif", alt: "Montaje Chiavari bronce envejecido boda al atardecer" },
];

const faqs = [
  {
    question: "¿Qué hace diferente al acabado bronce envejecido respecto al dorado estándar?",
    answer: "El <strong>bronce envejecido</strong> tiene un tono más profundo, oscuro y cálido que el dorado estándar. Mientras el dorado anodizado es brillante y limpio, el bronce envejecido tiene una pátina que simula el desgaste del tiempo — tonos cobrizo-marrón con reflejos dorados en los bordes. El resultado es un acabado que se siente <strong>orgánico y con historia</strong>, como un objeto de valor heredado. Combina mejor con maderas oscuras, piedra natural, flores silvestres y decoración bohemia que el dorado brillante."
  },
  {
    question: "¿Para qué estilos de boda es ideal la silla Chiavari bronce?",
    answer: "La Chiavari bronce es <strong>la elección natural para bodas bohemias y vintage</strong>: bodas en jardines con arcos de flores silvestres, bodas en haciendas coloniales con mesas de madera natural, bodas boho-chic con macramé y plantas, y bodas rústicas-elegantes con vajilla de barro y candelabros de hierro. También funciona muy bien para bodas de otoño donde la paleta incluye terracota, ocre, vino y verde olivo. En bodas formales con decoración muy moderna, generalmente el dorado o el plateado quedan mejor."
  },
  {
    question: "¿Los cojines disponibles combinan bien con el acabado bronce?",
    answer: "El bronce envejecido tiene calidez marrón-cobriza, por lo que los mejores cojines son los de <strong>tonos tierra y naturales</strong>: terracota, nude, marfil crudo, vino, verde musgo y marrón chocolate. El cojín blanco funciona pero pierde la integración cromática con el acabado — si tienes flores en tonos tierra y quieres coherencia visual, el cojín nude o terracota es la mejor opción. El cojín dorado también funciona muy bien para un look más opulento dentro del estilo vintage."
  },
  {
    question: "¿La Chiavari bronce funciona en haciendas con iluminación de velas?",
    answer: "Es literalmente el acabado que mejor reacciona a la luz de velas. Las <strong>llamas cálidas (2700-3000K)</strong> hacen que el bronce envejecido cobre vida — los reflejos cobrizos se intensifican y el acabado parece brillar desde adentro. En una hacienda con candelabros y velas en la mesa, las sillas Chiavari bronce se ven mejores que en cualquier fotografía diurna. Si tu boda en hacienda incluye iluminación de velas como elemento principal, esta es sin duda la silla correcta."
  },
  {
    question: "¿Puedo mezclar Chiavari bronce con otras variantes en el mismo evento?",
    answer: "Sí, y de hecho hay combinaciones muy pedidas: <strong>bronce + dorado</strong> para mesas con distinto significado (novios vs. invitados), o <strong>bronce en ceremonia + dorado en recepción</strong> para crear una transición visual entre los dos momentos del evento. Algunos organizadores usan bronce para las sillas de los novios y dorado para los demás invitados, creando un punto focal. La única combinación que no recomendamos es bronce + plateado, porque los tonos fríos y cálidos compiten entre sí."
  },
];

const specs = [
  { label: "Material", value: "Aluminio aeronáutico con acabado bronce envejecido anodizado" },
  { label: "Peso", value: "1.8 kg por silla" },
  { label: "Resistencia", value: "200 kg certificado" },
  { label: "Altura total", value: "92 cm (respaldo)" },
  { label: "Ancho asiento", value: "38 cm" },
  { label: "Acabado", value: "Bronce envejecido — tono cobrizo-marrón con reflejos dorados" },
  { label: "Apilable", value: "Sí, hasta 8 unidades" },
  { label: "Cojín", value: "Incluido sin costo — 20+ colores (tierra y naturales recomendados)" },
  { label: "Precio referencia", value: "Desde $45/silla en lotes de 150+" },
  { label: "Usos recomendados", value: "Bodas vintage, haciendas coloniales, eventos bohemios" },
];

const reviews = [
  { author: "Lucía Hernández", text: "Para mi boda boho en Hacienda Tlalpan las Chiavari bronce fueron perfectas. Con las flores silvestres en terracota y musgo, y la iluminación de velas, el conjunto quedó de revista. Todos mis invitados preguntaron por ellas.", rating: 5, date: "2025-10-18" },
  { author: "Jorge Ramírez", text: "Organizamos una cena romántica al aire libre en un jardín histórico con 80 Chiavari bronce. El acabado envejecido combinó exactamente con las mesas de madera y las flores de temporada. Servicio puntual y sillas impecables.", rating: 5, date: "2025-09-06" },
  { author: "Isabel Vega", text: "Rentamos 160 Chiavari bronce para una boda de hacienda con paleta otoñal. La luz de las antorchas y los candelabros hacían que el bronce brillara de una manera increíble. El fotógrafo dijo que era el mobiliario más fotogénico que había visto.", rating: 5, date: "2025-11-02" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Chiavari Bronce para Bodas Vintage y Haciendas en CDMX",
    description: "Sillas Chiavari aluminio acabado bronce envejecido. 1.8 kg, 200 kg resistencia. Ideal para bodas vintage, haciendas coloniales y eventos bohemios. Cojín incluido. Desde $45/silla.",
    url: "/servicios/mobiliario/sillas/chiavari/bronce/",
    priceRange: { min: 45, max: 65 },
    reviews,
    ratingValue: 5,
    reviewCount: 24,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Chiavari", url: "/servicios/mobiliario/sillas/chiavari/" },
    { name: "Bronce", url: "/servicios/mobiliario/sillas/chiavari/bronce/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Dorada", href: "/servicios/mobiliario/sillas/chiavari/dorada/" },
  { name: "Plateada", href: "/servicios/mobiliario/sillas/chiavari/plateada/" },
  { name: "Negra", href: "/servicios/mobiliario/sillas/chiavari/negra/" },
  { name: "Bronce", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Sillas Chiavari Bronce para Bodas"
  description="Renta sillas Chiavari bronce envejecido en CDMX — aluminio anodizado cobrizo-marrón, 1.8 kg, 200 kg resistencia."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Bronce envejecido — el acabado que cobra vida con la luz de velas"
    title='Silla Chiavari <span class="highlight">Bronce</span> — Renta en CDMX'
    subtitle="La Chiavari con acabado bronce envejecido: tono cobrizo-marrón con reflejos dorados que reacciona de forma extraordinaria a la luz de velas. Aluminio aeronáutico de 1.8 kg con resistencia de 200 kg. El acabado preferido para bodas vintage, haciendas coloniales y eventos bohemios en CDMX."
    primaryCTA={{ label: "Cotizar sillas Chiavari bronce", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari bronce para mi evento` }}
    cards={[
      {
        title: "Bronce envejecido: el acabado que tiene carácter y profundidad",
        content: "El bronce envejecido no es simplemente un tono entre el dorado y el marrón — es un acabado con <strong>pátina y profundidad</strong> que evoca la riqueza de los objetos con historia. A diferencia del dorado brillante que es limpio y contemporáneo, el bronce envejecido tiene variaciones tonales que hacen que cada silla tenga su propio carácter. En fotografía, ese acabado genera texturas y reflexiones que el dorado estándar no puede replicar. <strong>Para bodas donde la estética importa tanto como la logística</strong>, la Chiavari bronce marca la diferencia.",
      },
      {
        title: "Haciendas, jardines y la magia de la luz cálida",
        content: "El bronce envejecido está diseñado para funcionar con <strong>iluminación cálida</strong>: velas, antorchas, guirnaldas Edison y spots ambar. En esas condiciones, el acabado cobrizo-marrón se transforma — los reflejos dorados se intensifican y la silla parece emanar calidez. Es el acabado que los fotógrafos de bodas aman porque crea composiciones naturalmente hermosas sin necesidad de edición. Cojín en tonos tierra incluido sin cargo adicional.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Chiavari bronce — el acabado con historia que eligen las bodas vintage de CDMX"
    subheadline="Bronce envejecido · 200 kg resistencia · Cojín incluido · Montaje profesional"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Chiavari</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Chiavari bronce para tu boda vintage o evento bohemio</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas Chiavari bronce`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Chiavari Bronce en Bodas Vintage y Haciendas Reales</h2>
            <p class="section__subtitle">Haciendas coloniales, jardines históricos y bodas bohemias en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Chiavari Bronce</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el bronce es el acabado favorito de las bodas de hacienda"
    headingId="descripcion-heading"
    badge="Bronce envejecido · Bodas vintage · Haciendas coloniales"
    tags={["Bronce Envejecido", "Bodas Vintage", "Haciendas Coloniales", "Bodas Boho"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Las haciendas coloniales de CDMX y el Estado de México tienen una estética específica: piedra tezontle, madera oscura, arcos, muros encalados y patios con vegetación. El dorado brillante puede sentirse <strong>demasiado moderno</strong> en ese contexto — es un metal limpio y contemporáneo. El bronce envejecido, en cambio, habla el mismo idioma que la arquitectura colonial: es un acabado que parece <strong>haber siempre estado ahí</strong>.</p>
      <p class="showcase__text">La pátina del bronce envejecido se produce con un proceso de anodizado en múltiples capas que crea variaciones tonales — en algunas zonas más oscuro como el chocolate, en los bordes más cobrizo y cálido. Esa variación es lo que hace que el acabado se sienta vivo y tridimensional, no plano como una pintura. Con <strong>iluminación cálida de velas o antorchas</strong>, esas variaciones se intensifican y el resultado es simplemente único.</p>
      <p class="showcase__text">Para bodas boho-chic con flores de temporada en tonos terracota, mostaza y verde eucalipto, las sillas Chiavari bronce son la pieza de mobiliario que hace que todo el conjunto se sienta coherente y curado.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/chiavari-jardin-noche-guirnaldas-exterior.avif" alt="Sillas Chiavari bronce en jardín nocturno con guirnaldas cálidas" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/real-wedding-chiavari-02.avif" alt="Chiavari bronce en boda real hacienda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/wedding-chiavari-05.avif" alt="Boda vintage sillas Chiavari bronce decoración boho" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Chiavari Bronce</h2>
            <p class="section__subtitle">Combinaciones que capturan la esencia de las bodas vintage y hacienda</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Boho en Hacienda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari bronce + <strong>cojín nude o terracota</strong> + mesa de madera natural + flores silvestres en ocre, terracota y verde eucalipto. La combinación más pedida para bodas bohemias en haciendas con jardín.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Jardín Nocturno Romántico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari bronce + <strong>cojín marfil crudo</strong> + guirnaldas Edison + velas en la mesa + flores colgantes. Para bodas al aire libre donde la iluminación cálida es el elemento central del ambiente.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Otoñal de Lujo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Chiavari bronce + <strong>cojín vino o burdeos</strong> + mesa con mantel en tono musgo + centros de flores en rojo, naranja y marrón. El combo de temporada alta (octubre-noviembre) para bodas con paleta otoñal.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Chiavari Bronce</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Chiavari Bronce"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Bronce envejecido que reacciona a la luz de velas como ningún otro acabado, 200 kg de resistencia, y el look vintage que buscan las mejores bodas de hacienda en CDMX.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
