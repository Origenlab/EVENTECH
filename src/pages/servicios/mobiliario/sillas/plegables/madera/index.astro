---
/**
 * ─── Silla Plegable Madera Barnizada — Página de Variante (Nivel 4) ───
 * Acabado elegante de madera sólida barnizada para bodas y conferencias premium.
 * Desde $25/silla — el balance perfecto entre estética y precio.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Plegables > Madera Barnizada
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { label: "Madera Barnizada" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-plegable-madera-ceremonia-iglesia-01.avif", alt: "Sillas plegables madera barnizada en boda salón elegante CDMX" },
  { src: "/images/mobiliario/silla-plegable-madera-iglesia-vista-02.avif", alt: "Sillas madera barnizada en conferencia corporativa premium" },
  { src: "/images/mobiliario/silla-plegable-madera-iglesia-lateral-03.avif", alt: "Ceremonia boda con sillas plegables de madera barnizada" },
  { src: "/images/mobiliario/silla-plegable-madera-ceremonia-iglesia-01.avif", alt: "Sillas plegables madera en hacienda CDMX con decoración floral" },
  { src: "/images/mobiliario/silla-plegable-madera-boda-iglesia-04.avif", alt: "Banquete de boda con sillas plegables de madera natural" },
  { src: "/images/mobiliario/silla-plegable-madera-boda-iglesia-04.avif", alt: "Detalle acabado barniz natural silla plegable madera" },
];

const faqs = [
  {
    question: "¿Qué tipo de madera tienen las sillas plegables barnizadas?",
    answer: "Las sillas plegables de <strong>madera barnizada</strong> están fabricadas en madera de haya sólida — una especie de dureza media-alta, muy usada en muebles europeos por su veta uniforme y su receptividad al barniz. La capa de barniz es poliuretánico al agua, lo que da un acabado satinado que resalta la veta natural sin dejar la superficie pegajosa. No es madera reconstituida ni MDF — es madera maciza en respaldo y estructura.",
  },
  {
    question: "¿Las sillas de madera barnizada son adecuadas para bodas en haciendas?",
    answer: "Son una de las elecciones más frecuentes para haciendas precisamente porque el <strong>tono cálido de la madera natural</strong> complementa la arquitectura colonial. A diferencia de la silla Tiffany metálica, la plegable de madera aporta textura orgánica — algo que fotógrafos y wedding planners valoran porque la madera no refleja la luz de los flashes. Para uso en jardín o terraza cubierta es perfecta; para uso a la intemperie bajo lluvia directa, recomendamos el interior.",
  },
  {
    question: "¿Cuánto cuesta rentar 150 sillas plegables de madera para una boda?",
    answer: "Para <strong>150 sillas plegables de madera barnizada</strong>, el precio total aproximado es de <strong>$4,500 – $5,250</strong> (desde $30-35 por unidad a ese volumen). Incluye entrega en CDMX, montaje según layout y desmontaje. En lotes de 50-99 unidades, el precio sube a $35-40/unidad. Para bodas más íntimas de 50 personas, desde $2,000 aproximadamente. Solicita cotización exacta por WhatsApp.",
  },
  {
    question: "¿La silla plegable de madera viene con cojín?",
    answer: "La silla plegable de madera tiene asiento de madera curvada con tratamiento ergonómico — cómoda para eventos de 3-4 horas sin cojín. Si tu evento es más largo o prefieres un acabado más lujoso, <strong>ofrecemos cojín opcional</strong> en tela natural (crudo, beige, blanco) por un cargo adicional. Para bodas con decoración rústica o boho, muchos clientes eligen la silla sola con lazo de yute o macramé.",
  },
  {
    question: "¿Se puede usar la silla plegable de madera en conferencias?",
    answer: "Sí, y es una excelente elección para <strong>conferencias y seminarios premium</strong> donde se quiere un ambiente más cálido y menos corporativo que la silla metálica o plástica. Muchas empresas la usan para retiros directivos, talleres creativos y presentaciones de producto donde la estética es parte del mensaje. El peso de 4.8 kg la hace ligeramente más pesada que la plástica, pero sigue siendo manejable para montajes de 100-300 sillas.",
  },
];

const specs = [
  { label: "Material", value: "Madera de haya sólida — respaldo y estructura" },
  { label: "Acabado", value: "Barniz poliuretánico satinado al agua — veta natural visible" },
  { label: "Resistencia", value: "110 kg (carga estática)" },
  { label: "Peso", value: "4.8 kg" },
  { label: "Altura total", value: "88 cm" },
  { label: "Ancho asiento", value: "41 cm" },
  { label: "Asiento", value: "Madera curvada ergonómica — cojín opcional disponible" },
  { label: "Plegado", value: "Sistema bisagra de acero — plegado en 4 segundos" },
  { label: "Apilable", value: "Sí, hasta 8 unidades plegadas" },
  { label: "Uso recomendado", value: "Interior o exterior cubierto — no exposición directa a lluvia" },
];

const reviews = [
  { author: "Valeria Jiménez", text: "Usamos 120 sillas de madera barnizada para nuestra boda en una hacienda en Coyoacán. El aspecto era exactamente lo que buscábamos — cálido, natural, elegante. Combinaron perfecto con la decoración boho que teníamos.", rating: 5, date: "2025-11-05" },
  { author: "Dr. Alejandro Cruz", text: "Las rentamos para un seminario de liderazgo de 80 personas. Queríamos algo diferente a las sillas de plástico típicas. El resultado fue excelente — los participantes comentaron el ambiente más cálido del salón.", rating: 5, date: "2025-09-22" },
  { author: "Claudia Vargas", text: "Para mi ceremonia civil de 100 personas en jardín cubierto fueron perfectas. Ligeras, elegantes y el montaje fue rapidísimo. Las fotos quedaron preciosas con la madera natural de fondo.", rating: 5, date: "2025-08-14" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Plegables Madera Barnizada para Bodas y Conferencias CDMX",
    description: "Sillas plegables de madera barnizada para bodas y conferencias premium en CDMX. Madera de haya sólida · Acabado barniz satinado · 110 kg · Desde $25/silla.",
    url: "/servicios/mobiliario/sillas/plegables/madera/",
    priceRange: { min: 25, max: 40 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Plegables", url: "/servicios/mobiliario/sillas/plegables/" },
    { name: "Madera Barnizada", url: "/servicios/mobiliario/sillas/plegables/madera/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { name: "Plástico Reforzado", href: "/servicios/mobiliario/sillas/plegables/plastico/" },
  { name: "Madera Barnizada", href: null, active: true },
  { name: "Napoleón Resina", href: "/servicios/mobiliario/sillas/plegables/napoleon/" },
  { name: "Apilable Metal+Resina", href: "/servicios/mobiliario/sillas/plegables/apilable/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];
---

<PageLayout
  title="Renta Sillas Plegables Madera Barnizada"
  description="Renta sillas plegables de madera barnizada en CDMX — elegantes para bodas y conferencias premium."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La elegancia natural para bodas y conferencias premium"
    title='Silla Plegable <span class="highlight">Madera Barnizada</span> — Renta en CDMX'
    subtitle="El equilibrio perfecto entre estética cálida y funcionalidad plegable: madera de haya sólida con barniz satinado que resalta la veta natural. La elección de bodas con decoración rústica-elegante, conferencias de alto nivel y eventos donde la madera aporta calidez que el metal no puede dar."
    primaryCTA={{ label: "Cotizar sillas de madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables de madera barnizada para mi evento` }}
    cards={[
      {
        title: "Madera sólida que se ve y se siente diferente",
        content: "La <strong>silla plegable de madera barnizada</strong> está fabricada en haya sólida — no enchapado, no MDF. La veta natural de la madera es visible bajo la capa de barniz poliuretánico satinado, lo que crea una textura visual que la silla metálica o plástica nunca puede replicar. El resultado es un ambiente más cálido y orgánico, muy buscado para bodas con temática rústica, boho o mexicana contemporánea. Los fotógrafos la prefieren porque la madera no refleja el flash.",
      },
      {
        title: "Plegable práctica, precio accesible, acabado premium",
        content: "A pesar de su aspecto de mueble fino, la plegable de madera mantiene toda la practicidad del sistema plegable: se monta y desmonta en segundos, se apila hasta 8 unidades y dos personas pueden equipar un salón de 100 personas en 15 minutos. <strong>Desde $25/silla en lotes de 150+</strong> — significativamente menos que una silla Chiavari o Tiffany premium, con un aspecto que compite directamente. Ideal cuando el presupuesto es ajustado pero la estética no puede serlo.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Madera natural que transforma la atmósfera de tu boda o conferencia"
    subheadline="Haya sólida barnizada · Cálida y elegante · Interior y exterior cubierto · Desde $25/silla"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Plegables</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas plegables de madera para tu boda o conferencia</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables de madera barnizada`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Silla Plegable Madera en Bodas y Conferencias</h2>
            <p class="section__subtitle">Haciendas, jardines cubiertos y salones de conferencias en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Plegable Madera Barnizada</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la silla de madera transforma el ambiente de tu evento?"
    headingId="descripcion-heading"
    badge="Haya sólida barnizada — calidez que el metal no puede igualar"
    tags={["Madera Haya Sólida", "Bodas Rústico-Elegantes", "Conferencias Premium", "Decoración Boho"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una diferencia que se nota antes de sentarse: la madera crea presencia en el espacio. No es solo la veta, es la textura visual, la calidez del tono natural y la forma en que la luz cae sobre ella sin reflejar. En un salón de 150 personas con <strong>sillas plegables de madera barnizada</strong>, el ambiente se percibe más íntimo y más curado — aunque el presupuesto sea el mismo que con cualquier otra silla.</p>
      <p class="showcase__text">La haya sólida que usamos es <strong>estable dimensional mente</strong> — no se deforma con cambios de temperatura o humedad en entornos cerrados. La capa de barniz poliuretánico protege la madera de manchas de vino, café y agua sin necesidad de mantenimiento especial entre eventos. Cada unidad se revisa antes de entregarse para asegurar que el acabado está impecable.</p>
      <p class="showcase__text">Para <strong>conferencias de alto nivel y retiros directivos</strong>, la plegable de madera proyecta cuidado en los detalles — algo que los participantes registran aunque no lo verbalicen, y que distingue tu evento de una conferencia convencional con sillas de plástico genéricas.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-plegable-madera-boda-iglesia-04.avif" alt="Sillas plegables madera barnizada en boda hacienda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-plegable-madera-iglesia-lateral-03.avif" alt="Detalle veta natural madera barnizada silla plegable" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-plegable-madera-iglesia-vista-02.avif" alt="Sillas madera plegables en ceremonia boda jardín CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Plegable Madera</h2>
            <p class="section__subtitle">Combinaciones que funcionan para bodas y conferencias</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Rústico-Elegante</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable madera natural + <strong>lazo de yute o macramé</strong> + mesa de madera rústica con camino de lino. Sin mantelería blanca — la madera combina con verde eucalipto y flores silvestres. La opción boho favorita para haciendas y jardines cubiertos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Ceremonia Civil Íntima</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable madera + <strong>cojín en crudo o beige</strong> + flores en los brazos de la silla (si aplica) + pasillo de pétalos. Para ceremonias de 50-120 personas en espacios con techos altos o jardines con vegetación densa. Muy fotogénico.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Conferencia Creativa</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable madera + <strong>mesa rectangular de madera</strong> + papelería kraft + plants de escritorio. El ambiente cálido y no corporativo es ideal para talleres creativos, retiros de equipo y presentaciones de marca donde se quiere un tono diferente al salón de hotel tradicional.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Silla Plegable Madera Barnizada</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Plegable Madera Barnizada"
              subtitle="Lo que nos preguntan antes de reservar para bodas y conferencias"
              description={[
                "Madera de haya sólida barnizada, sistema plegable práctico y precio accesible para un acabado premium. Aquí resolvemos las dudas más frecuentes.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla plegable de madera barnizada`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
