---
/**
 * ─── Silla Plegable Plástico Reforzado — Página de Variante (Nivel 4) ───
 * La opción más resistente y económica para eventos masivos de 500+ personas.
 * Plástico de alta densidad, capacidad 120 kg, desde $15/silla.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Plegables > Plástico Reforzado
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { label: "Plástico Reforzado" },
];

const galleryImages = [
  { src: "/images/mobiliario/plegable-plastico-evento-masivo-01.avif", alt: "Sillas plegables plástico reforzado en evento masivo 500 personas CDMX" },
  { src: "/images/mobiliario/plegable-plastico-auditorio-02.avif", alt: "Montaje sillas plegables blancas en auditorio CDMX" },
  { src: "/images/mobiliario/plegable-plastico-conferencia-03.avif", alt: "Sillas plegables plástico en conferencia empresarial" },
  { src: "/images/mobiliario/plegable-plastico-exterior-04.avif", alt: "Sillas plegables plástico en evento al aire libre" },
  { src: "/images/mobiliario/plegable-plastico-fila-05.avif", alt: "Filas de sillas plegables blancas en evento corporativo" },
  { src: "/images/mobiliario/plegable-plastico-apiladas-06.avif", alt: "Sillas plegables plástico apiladas para logística de evento" },
];

const faqs = [
  {
    question: "¿Cuánto peso soporta la silla plegable de plástico reforzado?",
    answer: "La <strong>silla plegable de plástico reforzado</strong> tiene una capacidad certificada de <strong>120 kg</strong>. El cuerpo es polipropileno de alta densidad con aditivos de refuerzo estructural — el mismo material usado en mobiliario hospitalario y escolar. Las patas de acero galvanizado llevan gomas antideslizantes que evitan el movimiento en superficies lisas o pisos de madera.",
  },
  {
    question: "¿Es la silla plegable de plástico adecuada para eventos de 500 o más personas?",
    answer: "Sí — es exactamente el modelo diseñado para eso. Gracias a su <strong>sistema de plegado en 3 segundos</strong>, dos personas pueden montar 100 sillas en menos de 10 minutos. Se apila en grupos de 12 unidades para optimizar el transporte. Para eventos de 500+, coordinamos con tu equipo de logística los tiempos de entrega y disponemos de unidades adicionales como margen de seguridad.",
  },
  {
    question: "¿Se puede usar la silla plegable de plástico en exteriores?",
    answer: "Sí. El polipropileno con aditivos UV no se decolora con el sol y no absorbe humedad — puede quedar montada en un jardín o explanada todo el día sin problemas. Las patas de acero galvanizado resisten la humedad del pasto. En superficies irregulares recomendamos pedir los calzos niveladores incluidos en el servicio sin costo adicional.",
  },
  {
    question: "¿Cuánto cuesta rentar 500 sillas plegables blancas para un evento en CDMX?",
    answer: "Para <strong>500 sillas plegables de plástico</strong>, el precio total aproximado es de <strong>$7,500 – $9,000</strong> (desde $15-18 por unidad a ese volumen). Incluye entrega en CDMX, montaje en filas o layout que definas, y desmontaje. A menor volumen (50-149 unidades), el precio sube a $20-25/unidad. Solicita cotización exacta por WhatsApp con la fecha y venue.",
  },
  {
    question: "¿Se pueden personalizar las sillas plegables con cubiertas o lazos?",
    answer: "Sí. Aunque la silla plegable de plástico es funcional tal como viene, muchos clientes la complementan con <strong>cubre-sillas de tela</strong> o lazos decorativos para eventos sociales. En EVENTECH podemos incluir ese accesorio en el mismo pedido. Para conferencias y eventos corporativos, la mayoría prefiere la silla limpia sin cubierta — es más práctica y ahorra tiempo de montaje.",
  },
];

const specs = [
  { label: "Material", value: "Polipropileno alta densidad con refuerzo estructural UV" },
  { label: "Estructura", value: "Patas de acero galvanizado con tapones antideslizantes" },
  { label: "Resistencia", value: "120 kg (certificado de carga estática)" },
  { label: "Peso", value: "3.2 kg" },
  { label: "Altura total", value: "85 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Plegado", value: "Sistema de 1 movimiento — plegado en 3 segundos" },
  { label: "Apilable", value: "Sí, hasta 12 unidades plegadas" },
  { label: "Color", value: "Blanco (disponible también en negro y gris)" },
  { label: "Uso", value: "Interior y exterior — resistente a UV y humedad" },
];

const reviews = [
  { author: "Carlos Mendoza", text: "Rentamos 600 sillas plegables para una feria empresarial. Entrega puntual, sillas en perfecto estado y el equipo montó todo el auditorio en 45 minutos. Precio muy competitivo para esa cantidad.", rating: 5, date: "2025-11-10" },
  { author: "Sofía Herrera", text: "Las usamos para una conferencia de 400 personas al aire libre. Aguantaron perfectamente el peso y el sol todo el día. Fáciles de limpiar, el equipo las recogió rápido al terminar.", rating: 5, date: "2025-10-02" },
  { author: "Ing. Ramírez", text: "Para congresos de 500+ siempre pedimos estas plegables. Son económicas, resistentes y se montan rapidísimo. El servicio de EVENTECH es muy profesional y puntual.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Plegables Plástico Reforzado para Eventos Masivos CDMX",
    description: "Sillas plegables de plástico reforzado para eventos de 500+ personas en CDMX. 120 kg de capacidad · Sistema de plegado rápido · Exterior e interior · Desde $15/silla.",
    url: "/servicios/mobiliario/sillas/plegables/plastico/",
    priceRange: { min: 15, max: 25 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Plegables", url: "/servicios/mobiliario/sillas/plegables/" },
    { name: "Plástico Reforzado", url: "/servicios/mobiliario/sillas/plegables/plastico/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { name: "Plástico Reforzado", href: null, active: true },
  { name: "Madera Barnizada", href: "/servicios/mobiliario/sillas/plegables/madera/" },
  { name: "Napoleón Resina", href: "/servicios/mobiliario/sillas/plegables/napoleon/" },
  { name: "Apilable Metal+Resina", href: "/servicios/mobiliario/sillas/plegables/apilable/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Sillas Plegables Plástico Reforzado"
  description="Renta sillas plegables de plástico reforzado en CDMX — ideales para eventos de 500+ personas."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="La opción #1 para eventos masivos — desde 500 personas"
    title='Silla Plegable <span class="highlight">Plástico Reforzado</span> — Renta en CDMX'
    subtitle="La silla más robusta y económica para eventos de gran formato: polipropileno de alta densidad con capacidad certificada de 120 kg, sistema de plegado en 3 segundos y uso interior/exterior. La opción definitiva para auditorios, ferias y conferencias masivas."
    primaryCTA={{ label: "Cotizar sillas plegables", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables de plástico reforzado para mi evento` }}
    cards={[
      {
        title: "120 kg de resistencia para el evento más exigente",
        content: "La <strong>silla plegable de plástico reforzado</strong> está construida con polipropileno de alta densidad — el mismo material que se usa en mobiliario hospitalario y escolar porque aguanta uso intensivo. La capacidad certificada de <strong>120 kg</strong> con patas de acero galvanizado garantiza que ningún invitado, sin importar su talla, va a sentir inestabilidad. La goma antideslizante en cada pata la ancla al piso sin rayar superficies de madera o mármol.",
      },
      {
        title: "Logística sin fricción para 500+ personas",
        content: "Cada silla pesa <strong>3.2 kg</strong> y se pliega en un solo movimiento. Apiladas en grupos de 12, dos personas pueden descargar y posicionar 100 sillas en menos de 10 minutos. Para eventos de 500+, esto es la diferencia entre terminar el montaje a tiempo o llegar tarde. Entregamos, montamos según tu layout y recogemos al terminar — sin que tu equipo tenga que mover nada. <strong>Desde $15/silla en lotes de 300+.</strong>",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Sillas plegables para 500+ personas — logística profesional sin complicaciones"
    subheadline="Entrega puntual · Montaje en tu layout · Interior y exterior · Desde $15/silla"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Plegables</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas plegables plástico para tu evento masivo</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables de plástico reforzado`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Silla Plegable Plástico en Eventos Reales</h2>
            <p class="section__subtitle">Conferencias, ferias, auditorios y eventos al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Plegable Plástico Reforzado</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La silla para cuando el número importa tanto como la resistencia"
    headingId="descripcion-heading"
    badge="Polipropileno reforzado — 120 kg certificados"
    tags={["Eventos Masivos", "Plástico Reforzado", "120 kg", "Interior y Exterior"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Cuando organizas un evento de 500 o más personas, necesitas dos cosas al mismo tiempo: <strong>sillas que aguanten</strong> y sillas que se monten rápido. La plegable de plástico reforzado es la única opción que cumple ambas condiciones sin comprometer el presupuesto. El polipropileno de alta densidad no se quiebra, no se dobla y no pierde color — con el mismo lote hemos servido eventos durante 3 años consecutivos sin reemplazos.</p>
      <p class="showcase__text">El sistema de plegado de un solo movimiento fue diseñado para operarios, no para técnicos. Cualquier persona de tu equipo puede armar o desarmar 100 sillas en minutos. Apiladas en torres de 12, caben en la mitad del espacio que necesitarías con cualquier silla estándar — lo que permite que nuestros camiones traigan más unidades en menos viajes.</p>
      <p class="showcase__text">Para <strong>ferias, congresos, graduaciones y eventos religiosos</strong> de gran formato, esta es la silla que eligen promotores profesionales de eventos en CDMX una y otra vez.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/plegable-plastico-showcase-main.avif" alt="Sillas plegables plástico reforzado en auditorio grande CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/plegable-plastico-showcase-02.avif" alt="Detalle estructura plegable plástico reforzado" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/plegable-plastico-showcase-03.avif" alt="Montaje rápido sillas plegables evento masivo" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Plegable Plástico</h2>
            <p class="section__subtitle">Configuraciones para eventos masivos que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Congreso o Conferencia</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable blanca + <strong>mesas rectangulares de 6 pies</strong> en configuración salón o teatro. Sin mantelería adicional para máxima practicidad. Ideal para 300-1000 personas con presentaciones y talleres simultáneos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Evento al Aire Libre</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable blanca + <strong>carpas o toldos</strong> para sol y lluvia + piso de madera provisional. La combinación más solicitada para ferias, graduaciones en jardín y eventos religiosos al aire libre con 500+ asistentes.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Evento Social Amplio</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Plegable blanca + <strong>cubre-silla de tela blanca</strong> + lazo de organza. Convierte la silla funcional en algo decorativo para bodas civiles económicas, XV años o eventos sociales donde el presupuesto es ajustado pero se busca estética cuidada.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Plegable Plástico Reforzado</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Plegable Plástico Reforzado"
              subtitle="Lo que nos preguntan antes de reservar para eventos masivos"
              description={[
                "120 kg de capacidad, plegado en 3 segundos y precio accesible para cualquier volumen. Aquí resolvemos las dudas más frecuentes sobre la silla más versátil de nuestra colección.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en logística de eventos te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla plegable de plástico reforzado`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Plegables y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Plegables</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
