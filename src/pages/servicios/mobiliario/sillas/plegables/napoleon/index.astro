---
/**
 * ─── Silla Plegable Napoleón Resina con Cojín — Página de Variante (Nivel 4) ───
 * Estilo Napoleón clásico en resina policarbonato con cojín acolchado incluido.
 * El modelo premium de las plegables — desde $30. Bodas y galas.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Plegables > Napoleón Resina
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { label: "Napoleón Resina" },
];

const galleryImages = [
  { src: "/images/mobiliario/plegable-napoleon-boda-gala-01.avif", alt: "Silla Napoleón resina con cojín en boda de gala CDMX" },
  { src: "/images/mobiliario/plegable-napoleon-recepcion-02.avif", alt: "Recepción elegante con sillas Napoleón plegables blancas" },
  { src: "/images/mobiliario/plegable-napoleon-ceremonia-03.avif", alt: "Ceremonia nupcial con sillas plegables estilo Napoleón" },
  { src: "/images/mobiliario/plegable-napoleon-salon-04.avif", alt: "Salón de gala con sillas Napoleón resina y cojín dorado" },
  { src: "/images/mobiliario/plegable-napoleon-detalle-05.avif", alt: "Detalle respaldo medallón silla Napoleón plegable" },
  { src: "/images/mobiliario/plegable-napoleon-banquete-06.avif", alt: "Banquete de boda con sillas Napoleón elegantes CDMX" },
];

const faqs = [
  {
    question: "¿Qué distingue a la silla Napoleón de otras sillas plegables?",
    answer: "La <strong>silla Napoleón</strong> se distingue por su respaldo en forma de medallón ovalado — un diseño inspirado en el mobiliario francés del siglo XIX que da una silueta mucho más elegante que cualquier silla plegable convencional. En resina policarbonato, conserva ese perfil clásico con la durabilidad del plástico técnico y la ventaja del sistema plegable. El cojín acolchado incluido la hace también la más cómoda de la línea plegable.",
  },
  {
    question: "¿La silla Napoleón plegable soporta el mismo peso que una silla de banquete estándar?",
    answer: "Sí. La <strong>silla Napoleón en resina</strong> tiene una capacidad de <strong>130 kg</strong> con estructura de acero inoxidable en las bisagras de plegado — el punto de mayor tensión. Las patas de resina reforzada resisten la misma carga que las patas metálicas pero sin el riesgo de oxidación en superficies mojadas. La hemos usado en galas de 400 personas durante 8 horas consecutivas sin incidentes.",
  },
  {
    question: "¿Qué colores de cojín están disponibles para la silla Napoleón?",
    answer: "El <strong>cojín acolchado</strong> está incluido sin costo adicional en todos los pedidos. Los colores más pedidos son: blanco (para bodas clásicas), champagne o crudo (para bodas elegantes sin sobreactuación), y negro (para galas corporativas). También disponemos de marfil, rosa blush y burdeos. Para bodas, recomendamos ver muestras digitales antes de confirmar — te las enviamos por WhatsApp.",
  },
  {
    question: "¿Cuánto cuesta rentar 200 sillas Napoleón para una boda?",
    answer: "Para <strong>200 sillas Napoleón resina con cojín</strong>, el precio aproximado es de <strong>$7,000 – $8,000</strong> (desde $35-40 por unidad a ese volumen). El cojín en el color que elijas está incluido. Para lotes de 50-99 unidades, el precio sube a $40-45/unidad. Solicita cotización exacta por WhatsApp con la fecha y venue para precio final con entrega y montaje incluidos.",
  },
  {
    question: "¿La silla Napoleón plegable es buena para galas corporativas?",
    answer: "Es excelente para <strong>galas corporativas y cenas de premiación</strong>. El diseño medallón en blanco o negro tiene una presencia que los plásticos genéricos no logran. Para galas donde se quiere un nivel estético alto sin el costo de una Tiffany o Chiavari, la Napoleón resina es la alternativa más solicitada. El sistema plegable facilita la logística en venues con espacios de almacenamiento limitados.",
  },
];

const specs = [
  { label: "Diseño", value: "Estilo Napoleón — respaldo medallón ovalado, inspiración francesa" },
  { label: "Material", value: "Resina policarbonato de alta resistencia con refuerzo interno" },
  { label: "Estructura", value: "Bisagras de acero inoxidable — patas de resina reforzada" },
  { label: "Resistencia", value: "130 kg (certificado de carga estática)" },
  { label: "Peso", value: "5.1 kg" },
  { label: "Altura total", value: "92 cm" },
  { label: "Ancho asiento", value: "42 cm" },
  { label: "Cojín", value: "Acolchado premium incluido — 12 colores disponibles" },
  { label: "Colores disponibles", value: "Blanco, negro, dorado champagne" },
  { label: "Uso", value: "Interior y exterior cubierto — apto UV, no exposición directa a lluvia" },
];

const reviews = [
  { author: "Andrea Morales", text: "Para mi boda en Salón Pedregal pedimos 250 sillas Napoleón blancas con cojín champagne. La diferencia visual con las plegables comunes fue brutal. Mis invitados pensaron que eran sillas de banquete estándar.", rating: 5, date: "2025-12-01" },
  { author: "Empresa TechFest CDMX", text: "Las usamos para la gala anual de premiación de 300 personas. En negro con cojín negro, el resultado fue muy elegante y el montaje fue rapidísimo por el sistema plegable. Las recomendamos completamente.", rating: 5, date: "2025-10-20" },
  { author: "Lupita Sánchez", text: "No sabía que existía una silla plegable tan bonita. El respaldo medallón le da una clase diferente. Para mi XV años con 180 invitados quedaron perfectas y costaron mucho menos de lo que esperaba.", rating: 5, date: "2025-09-11" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Napoleón Plegables Resina para Bodas y Galas CDMX",
    description: "Sillas plegables estilo Napoleón en resina policarbonato con cojín incluido para bodas y galas en CDMX. Respaldo medallón · 130 kg · Cojín acolchado · Desde $30/silla.",
    url: "/servicios/mobiliario/sillas/plegables/napoleon/",
    priceRange: { min: 30, max: 45 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Plegables", url: "/servicios/mobiliario/sillas/plegables/" },
    { name: "Napoleón Resina", url: "/servicios/mobiliario/sillas/plegables/napoleon/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { name: "Plástico Reforzado", href: "/servicios/mobiliario/sillas/plegables/plastico/" },
  { name: "Madera Barnizada", href: "/servicios/mobiliario/sillas/plegables/madera/" },
  { name: "Napoleón Resina", href: null, active: true },
  { name: "Apilable Metal+Resina", href: "/servicios/mobiliario/sillas/plegables/apilable/" },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Sillas Chiavari", href: "/servicios/mobiliario/sillas/chiavari/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Sillas Plegables Napoleón Resina"
  description="Renta sillas plegables estilo Napoleón en resina con cojín acolchado incluido en CDMX — la plegable más elegante para bodas y galas."
  jsonLd={jsonLd}
>
  <!-- BREADCRUMBS -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- 1. HERO -->
  <HeroPage
    badge="La silla plegable más elegante — respaldo medallón estilo francés"
    title='Silla Plegable <span class="highlight">Napoleón Resina</span> — Renta en CDMX'
    subtitle="El diseño Napoleón clásico en resina policarbonato moderna: el respaldo medallón ovalado de inspiración francesa que transforma cualquier montaje plegable en un evento de gala. Cojín acolchado premium incluido, 130 kg de capacidad y sistema plegable para logística sin fricción."
    primaryCTA={{ label: "Cotizar sillas Napoleón", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables estilo Napoleón para mi evento` }}
    cards={[
      {
        title: "El respaldo medallón que cambia todo",
        content: "El <strong>respaldo medallón ovalado</strong> es el elemento que distingue a la silla Napoleón de cualquier plegable genérica. Ese detalle de inspiración francesa le da una silueta reconocible y elegante que la resina policarbonato replica con precisión — el mismo perfil, sin el peso ni el mantenimiento de la madera torneada original. Tus invitados no van a percibir que es una silla plegable hasta que la vean cerrada. Y eso, para un evento de boda o gala, vale mucho.",
      },
      {
        title: "Cojín premium incluido — listo para bodas y galas",
        content: "A diferencia de otras plegables, la <strong>silla Napoleón resina incluye cojín acolchado</strong> sin costo adicional. El cojín en tela satinada viene en 12 colores: blanco, champagne, negro, marfil, rosa blush, burdeos y más. La combinación blanco + cojín blanco es la más pedida para bodas clásicas; negro + cojín negro domina las galas corporativas. La estructura de resina policarbonato soporta <strong>130 kg certificados</strong> y no se oxida, no se raspa, no se colorea. <strong>Desde $30/silla en lotes de 200+.</strong>",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La plegable más elegante de CDMX — con cojín incluido para tu boda o gala"
    subheadline="Respaldo medallón · Resina policarbonato · 130 kg · Cojín en 12 colores · Desde $30/silla"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Plegables</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas Napoleón para tu boda o gala en CDMX</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables estilo Napoleón`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Silla Napoleón Plegable en Bodas y Galas</h2>
            <p class="section__subtitle">Bodas, galas corporativas y XV años en salones y haciendas de CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Plegable Napoleón Resina</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La silla plegable que tus invitados no van a identificar como plegable"
    headingId="descripcion-heading"
    badge="Diseño Napoleón — elegancia francesa en resina moderna"
    tags={["Estilo Napoleón", "Bodas y Galas", "Resina Policarbonato", "Cojín Incluido"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una prueba sencilla que aplicamos con clientes: mostramos una foto de un salón montado con sillas Napoleón y preguntamos qué tipo de silla es. Casi nadie dice "plegable". El respaldo medallón ovalado tiene una presencia tan definida que la mente asocia la silla con mobiliario de banquete premium — aunque el precio sea un tercio del original.</p>
      <p class="showcase__text">La <strong>resina policarbonato técnica</strong> que usamos tiene una formulación diferente al plástico genérico: mayor densidad, mayor resistencia a impactos y una superficie que no muestra rayones con el uso normal. Las bisagras de acero inoxidable son el corazón del sistema plegable — ahí concentramos la mayor parte de la ingeniería de esta silla, porque son el único punto de tensión real en 130 kg de carga.</p>
      <p class="showcase__text">Para <strong>XV años, bodas y galas corporativas</strong> donde se quiere un nivel estético por encima de la plegable estándar pero sin el costo de una Tiffany o Chiavari, la Napoleón resina es la respuesta correcta. El cojín acolchado incluido completa el cuadro.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/plegable-napoleon-showcase-main.avif" alt="Sillas Napoleón plegables en gala elegante CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/plegable-napoleon-showcase-02.avif" alt="Detalle respaldo medallón silla Napoleón resina" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/plegable-napoleon-showcase-03.avif" alt="Sillas Napoleón blancas con cojín champagne en boda" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Silla Napoleón</h2>
            <p class="section__subtitle">Las combinaciones que más elegancia aportan por cada peso invertido</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Clásica Blanca</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Napoleón blanca + <strong>cojín blanco satinado</strong> + mesa redonda con mantel blanco al piso + centros de flor blanca. La combinación más solicitada para bodas en salones con iluminación cálida. El medallón blanco refleja la luz ambiental de forma muy fotogénica.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Gala Corporativa Oscura</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Napoleón negra + <strong>cojín negro o charcoal</strong> + mesa rectangular con mantel negro + runner metálico dorado o plateado. El acabado oscuro con el medallón negro proyecta una sofisticación seria que las galas corporativas necesitan. Muy pedido para premiaciones y cenas de fin de año.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">XV Años Romántico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Napoleón blanca + <strong>cojín rosa blush o lila</strong> + globo en respaldo + lazo de organza. La silla Napoleón blanca es perfectamente neutra para decorar — acepta lazos, flores, globos y cualquier accesorio sin perder su elegancia base. La más solicitada para XV años en paleta pastel.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Silla Napoleón Plegable</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Plegable Napoleón Resina"
              subtitle="Lo que nos preguntan antes de reservar para bodas y galas"
              description={[
                "Diseño medallón, resina policarbonato, 130 kg y cojín incluido. Aquí resolvemos las dudas más frecuentes sobre la plegable más elegante de nuestra colección.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista en sillas de evento te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la silla plegable Napoleón resina`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el número de sillas, color y fecha — precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes Plegables y servicios relacionados">
