---
/**
 * ─── Silla Plegable Apilable Metal+Resina — Página de Variante (Nivel 4) ───
 * La silla más versátil: plegable Y apilable, estructura metal+resina.
 * Ideal para conferencias corporativas y eventos que maximizan el espacio.
 * Desde $20/silla.
 *
 * Jerarquía: Servicios > Mobiliario > Sillas > Sillas Plegables > Apilable Metal+Resina
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Sillas", href: "/servicios/mobiliario/sillas/" },
  { label: "Sillas Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { label: "Apilable Metal+Resina" },
];

const galleryImages = [
  { src: "/images/mobiliario/silla-plegable-plastico-carpa-event-16.avif", alt: "Sillas plegables apilables metal resina en conferencia corporativa CDMX" },
  { src: "/images/mobiliario/silla-plegable-plastico-carpa-evento-04.avif", alt: "Evento corporativo con sillas plegables apilables grises" },
  { src: "/images/mobiliario/silla-plegable-plastico-evento-exterior-03.avif", alt: "Salón de conferencias con sillas apilables plegables en filas" },
  { src: "/images/mobiliario/silla-plegable-plastico-event-rows-15.avif", alt: "Sillas apilables plegables en evento al aire libre corporativo" },
  { src: "/images/mobiliario/silla-plegable-plastico-carpa-escenario-06.avif", alt: "Sillas plegables apilables en torres para almacenamiento eficiente" },
  { src: "/images/mobiliario/silla-plegable-plastico-ceremonia-13.avif", alt: "Detalle estructura metal resina silla plegable apilable" },
];

const faqs = [
  {
    question: "¿Qué diferencia a la silla apilable metal+resina de otras plegables?",
    answer: "La <strong>silla apilable metal+resina</strong> tiene una ventaja logística única: no solo se pliega, también se puede apilar en torres de hasta 15 unidades en estado desplegado. Esto significa que en un espacio de almacenamiento de 2m², caben 30 sillas listas para usar — sin plegar ni desplegar en el momento del evento. Es la opción favorita de coordinadores de eventos que necesitan flexibilidad rápida: reconfigurar un salón de conferencias en 10 minutos requiere mover torres, no desplegar sillas una por una.",
  },
  {
    question: "¿La combinación metal+resina es más resistente que solo plástico?",
    answer: "Sí. El <strong>marco de acero tubular galvanizado</strong> aporta rigidez estructural que el plástico solo no puede replicar en formato plegable-apilable. La resina cubre el asiento y respaldo para comodidad térmica (el metal puro en verano se calienta) y protección al acabado. La capacidad certificada es de <strong>125 kg</strong> con patas de acero galvanizado anti-corrosión. La combinación también es más silenciosa — el metal no cruje como el plástico con cambios de temperatura.",
  },
  {
    question: "¿Cuánto cuesta rentar 300 sillas apilables plegables para una conferencia?",
    answer: "Para <strong>300 sillas apilables metal+resina</strong>, el precio aproximado es de <strong>$6,000 – $7,500</strong> (desde $20-25 por unidad a ese volumen). Incluye entrega en CDMX, montaje y desmontaje. Para eventos de 500+, bajamos a $18-20/unidad. Para 50-149 unidades, el precio es de $28-32/unidad. Es el rango de precio intermedio entre la plegable plástica y la Napoleón — con mayor versatilidad logística que ambas.",
  },
  {
    question: "¿Se puede usar la silla apilable en exteriores?",
    answer: "Sí. El acero tubular galvanizado y la resina técnica del asiento son resistentes a UV y humedad ambiental. Para uso en jardines, explanadas o terrazas cubiertas no hay problema. Para lluvia directa intensa o contacto con agua acumulada en el suelo, recomendamos la versión con tapones de goma en las patas (incluidos sin costo). Los acabados gris antracita y negro son los más pedidos para exteriores corporativos.",
  },
  {
    question: "¿La silla apilable metal+resina es adecuada para eventos corporativos de imagen?",
    answer: "Sí, es la primera opción de muchos coordinadores corporativos precisamente porque el acabado metálico proyecta <strong>seriedad y profesionalismo</strong> sin el costo de las sillas de banquete premium. El gris antracita con estructura negra es el combo favorito para tecnológicas, financieras y empresas consultoras. Para eventos donde la imagen de la empresa está en juego y el plástico blanco genérico no comunica el nivel correcto, la apilable metal+resina es la respuesta estándar.",
  },
];

const specs = [
  { label: "Estructura", value: "Marco tubular acero galvanizado — resistencia y ligereza" },
  { label: "Asiento y respaldo", value: "Resina técnica polipropileno — confort térmico y protección" },
  { label: "Resistencia", value: "125 kg (carga estática certificada)" },
  { label: "Peso", value: "4.1 kg" },
  { label: "Altura total", value: "87 cm" },
  { label: "Ancho asiento", value: "43 cm" },
  { label: "Apilable desplegada", value: "Sí, hasta 15 unidades en torre" },
  { label: "Plegable", value: "Sí — sistema de 1 movimiento" },
  { label: "Colores", value: "Gris antracita / negro / blanco" },
  { label: "Uso", value: "Interior y exterior — galvanizado anti-corrosión, resistente UV" },
];

const reviews = [
  { author: "Coordinadora MexicoTech Summit", text: "Para un congreso de tecnología de 400 personas, las sillas apilables metal+resina fueron perfectas. Reconfiguramos tres salones en 20 minutos durante los breaks. Gris antracita con estructura negra — imagen muy profesional.", rating: 5, date: "2025-11-15" },
  { author: "Ricardo Fuentes", text: "Para nuestra cena corporativa anual de 250 personas rentamos estas sillas. El acabado metálico les da un aspecto ejecutivo que las plásticas no tienen. Precio muy accesible para lo que recibimos.", rating: 5, date: "2025-10-08" },
  { author: "Daniela Rojas, Planificadora", text: "Las uso en todos mis eventos corporativos de mediano formato. Son fáciles de apilar, el equipo de entrega siempre llega puntual y la resistencia es real — sin incidentes en 18 meses de trabajo con EVENTECH.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sillas Plegables Apilables Metal+Resina para Conferencias Corporativas CDMX",
    description: "Sillas plegables apilables metal+resina para conferencias y eventos corporativos en CDMX. Marco acero galvanizado · Apilable 15 unidades · 125 kg · Desde $20/silla.",
    url: "/servicios/mobiliario/sillas/plegables/apilable/",
    priceRange: { min: 20, max: 32 },
    reviews,
    ratingValue: 5,
    reviewCount: 42,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Sillas", url: "/servicios/mobiliario/sillas/" },
    { name: "Sillas Plegables", url: "/servicios/mobiliario/sillas/plegables/" },
    { name: "Apilable Metal+Resina", url: "/servicios/mobiliario/sillas/plegables/apilable/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Plegables", href: "/servicios/mobiliario/sillas/plegables/" },
  { name: "Plástico Reforzado", href: "/servicios/mobiliario/sillas/plegables/plastico/" },
  { name: "Madera Barnizada", href: "/servicios/mobiliario/sillas/plegables/madera/" },
  { name: "Napoleón Resina", href: "/servicios/mobiliario/sillas/plegables/napoleon/" },
  { name: "Apilable Metal+Resina", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas Ghost", href: "/servicios/mobiliario/sillas/ghost/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Iluminación Corporativa", href: "/servicios/iluminacion/corporativa/" },
];
---

<PageLayout
  title="Renta Sillas Plegables Apilables Metal+Resina"
  description="Renta sillas plegables apilables metal+resina en CDMX — la opción más versátil para conferencias y eventos corporativos."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Plegable Y apilable — la máxima versatilidad logística para eventos corporativos"
    title='Silla Plegable <span class="highlight">Apilable Metal+Resina</span> — Renta en CDMX'
    subtitle="La única silla que optimiza espacio en dos modos: plegada para transporte y apilada en torre de 15 unidades para reconfiguraciones rápidas en venue. Marco de acero galvanizado con asiento de resina técnica — 125 kg de capacidad, acabado profesional y precio corporativo desde $20/silla."
    primaryCTA={{ label: "Cotizar sillas apilables", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables apilables metal+resina para mi evento` }}
    cards={[
      {
        title: "Plegable Y apilable — dos ventajas logísticas en una silla",
        content: "La mayoría de las sillas plegables solo se pueden apilar dobladas. La <strong>silla apilable metal+resina</strong> va más lejos: en estado desplegado, hasta 15 unidades se apilan en torre estable. Esto permite reconfigurar un salón de 300 personas en teatral, en salón o en banquete en menos de 15 minutos — sin tener que plegar, mover y desplegar cada silla. Para coordinadores de eventos con múltiples configuraciones por día, esto no es un detalle menor: es la diferencia entre el caos y la fluidez.",
      },
      {
        title: "Estructura metálica — imagen corporativa sin el precio premium",
        content: "El <strong>marco de acero tubular galvanizado</strong> aporta una percepción visual de mayor solidez que las sillas de plástico genérico. En gris antracita o negro mate, proyecta el nivel de seriedad que los eventos corporativos necesitan: congresos tecnológicos, cenas de premiación, presentaciones de producto y retiros directivos. El asiento y respaldo en resina técnica añaden confort térmico (el metal solo se calienta en verano) y protegen la estructura de rayones visibles. <strong>Desde $20/silla en lotes de 300+.</strong>",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="La silla que reconfigura tu evento en 15 minutos — plegable y apilable en uno"
    subheadline="Metal galvanizado + resina técnica · 125 kg · Torres de 15 unidades · Desde $20/silla"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Plegables</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sillas apilables para tu conferencia o evento corporativo</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sillas plegables apilables metal+resina`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Silla Apilable Metal+Resina en Eventos Corporativos</h2>
            <p class="section__subtitle">Congresos, conferencias y eventos empresariales en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Silla Plegable Apilable Metal+Resina</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué los coordinadores de eventos corporativos eligen la apilable metal+resina?"
    headingId="descripcion-heading"
    badge="Metal galvanizado + resina técnica — ingeniería para eventos exigentes"
    tags={["Conferencias Corporativas", "Metal Galvanizado", "Apilable 15 Unidades", "Imagen Ejecutiva"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La respuesta está en el tiempo. Un coordinador de eventos que tiene que transformar un salón de conferencias en comedor ejecutivo durante el lunch tiene exactamente 20 minutos. Con sillas que solo se pliegan, eso requiere plegar, mover, desplegar, posicionar — una operación que con 200 sillas puede tomar 40 minutos con un equipo de 4 personas. Con <strong>torres apilables de 15 unidades</strong>, el mismo equipo lo hace en la mitad del tiempo.</p>
      <p class="showcase__text">El <strong>marco de acero tubular galvanizado</strong> no es solo resistencia — es estabilidad silenciosa. A diferencia del polipropileno, el acero no emite crujidos con cambios de temperatura y no pierde rigidez estructural con el calor del verano en CDMX. Las apilamos 15 unidades de alto sin que la torre tiemble. El acabado galvanizado resiste la corrosión de la humedad del pasto y los pisos de concreto húmedo en bodegas de events.</p>
      <p class="showcase__text">Para <strong>congresos anuales, cenas de premiación, retiros directivos y lanzamientos de producto</strong>, la apilable metal+resina es el estándar de la industria en CDMX por una razón: funciona, se ve profesional y su precio no compromete el presupuesto de producción.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/silla-plegable-plastico-filas-carpa-10.avif" alt="Sillas apilables metal resina en congreso corporativo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-plegable-plastico-evento-masivo-01.avif" alt="Torres de sillas apilables plegables en almacenamiento eficiente" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/silla-plegable-plastico-evento-outdoor-11.avif" alt="Detalle estructura metal galvanizado silla apilable plegable" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBOS SUGERIDOS -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Combos más pedidos con Apilable Metal+Resina</h2>
            <p class="section__subtitle">Configuraciones para eventos corporativos que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Congreso Tecnológico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Apilable gris antracita + <strong>mesas rectangulares de 6 pies</strong> en configuración salón con pasillo central + pantalla y podium al frente. La configuración estándar para congresos de 200-500 personas con múltiples ponentes. El gris proyecta neutralidad tecnológica.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena de Premiación</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Apilable negra + <strong>mesa redonda de 5 pies</strong> con mantel negro + runner plateado + centro de flores blancas. La versión más elegante de esta silla — el negro mate con estructura negra desaparece visualmente y deja que la decoración de mesa sea la protagonista.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Retiro Directivo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Apilable gris o blanca + <strong>mesas de trabajo en U o herradura</strong> + papelería corporativa + coffee station lateral. Para retiros de 20-80 personas donde la dinámica de trabajo requiere reconfiguraciones frecuentes durante el día — ahí la apilabilidad vale oro.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Silla Apilable Metal+Resina</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Silla Plegable Apilable Metal+Resina"
              subtitle="Lo que nos preguntan antes de reservar para conferencias y eventos corporativos"
              description={[
                "Metal galvanizado, resina técnica, 125 kg y apilable en torres de 15. Aquí resolvemos las dudas más frecuentes sobre la silla más versátil para eventos corporativos.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
