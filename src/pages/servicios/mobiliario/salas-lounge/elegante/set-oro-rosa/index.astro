---
/**
 * ─── Set Oro Rosa Lounge Elegante — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Elegante > Set Oro Rosa
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { label: "Set Oro Rosa" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-elegante-plata-rose.avif", alt: "Set lounge oro rosa en XV años de lujo CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-marfil-perlado.avif", alt: "Lounge elegante oro rosa en salón de XV años CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-blanco-cristal.avif", alt: "Zona lounge oro rosa en boda romántica CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Set oro rosa en boda con paleta rosada CDMX" },
  { src: "/images/mobiliario/silla-chiavari-plateada-evento-premium-07.avif", alt: "Mobiliario oro rosa en evento de XV años premium" },
  { src: "/images/mobiliario/silla-chiavari-dorada-boda-elegante-03.avif", alt: "Set lounge rose gold en celebración de lujo" },
];

const faqs = [
  {
    question: "¿Qué incluye el set lounge oro rosa?",
    answer: "El <strong>set lounge oro rosa</strong> incluye sofá de 3 plazas tapizado en tela satinada rosa pálido con lentejuelas discretas, 2 sillones individuales a juego, mesa de centro con tapa de mármol sintético y patas rose gold, y 2 cojines decorativos con encaje dorado. Todo diseñado para crear la zona soñada en XV años, bodas románticas y eventos con paleta rosada."
  },
  {
    question: "¿Para qué eventos es ideal el set oro rosa?",
    answer: "El <strong>set oro rosa</strong> es el favorito absoluto para <strong>XV años</strong> con paleta rosa-dorada o rose gold, bodas románticas, bridal showers de lujo, baby showers elegantes y eventos femeninos de alto perfil. La combinación de rosa pálido con detalles rose gold es la más solicitada por planners de XV años en CDMX."
  },
  {
    question: "¿Las lentejuelas del tapiz se caen durante el evento?",
    answer: "No. Las lentejuelas del tapiz están <strong>cosidas con doble costura industrial</strong>, no pegadas. Están diseñadas para resistir el uso intensivo de un evento de 6 a 8 horas sin que se desprendan. Inspeccionamos cada pieza antes de cada entrega para garantizar que llegue en condiciones perfectas."
  },
  {
    question: "¿La mesa de mármol sintético rose gold es pesada?",
    answer: "La mesa de centro del set tiene tapa en <strong>mármol sintético ultraligero</strong> (composite) con acabado blanco veteado. Las patas en rose gold son de metal tratado. El peso total es de 12 kg — mucho más manejable que el mármol natural, lo que permite ubicarla y reublicarla fácilmente durante el montaje."
  },
  {
    question: "¿Cuántas personas acomoda el set oro rosa?",
    answer: "El set oro rosa estándar está diseñado para <strong>5 a 7 personas</strong>. Para la zona de honor en XV años, recomendamos complementar con 2 sillones trono adicionales para la quinceañera y sus acompañantes. El set puede expandirse con piezas coordinadas para crear zonas de diferente capacidad según el venue."
  },
];

const specs = [
  { label: "Contenido del set", value: "Sofá 3 plazas + 2 sillones + mesa mármol + patas rose gold + cojines encaje" },
  { label: "Tapiz principal", value: "Tela satinada rosa pálido con lentejuelas discretas" },
  { label: "Estructura", value: "Madera maciza con patas en acabado rose gold" },
  { label: "Mesa de centro", value: "Mármol sintético blanco veteado, patas rose gold, 110 × 65 cm" },
  { label: "Cojines decorativos", value: "2 cojines con encaje dorado incluidos" },
  { label: "Capacidad", value: "5 a 7 personas por set" },
  { label: "Paleta", value: "Rosa pálido / Rose gold — coordina con blanco, marfil y dorado" },
  { label: "Estilo", value: "Romántico elegante — lentejuelas, rose gold, encaje" },
  { label: "Precio", value: "Desde $5,500 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje profesional y recolección en CDMX" },
];

const reviews = [
  { author: "Gabriela Sánchez", text: "Para los XV años de mi hija elegimos el set oro rosa y fue la decisión perfecta. El brillo de las lentejuelas con la iluminación del salón fue mágico. Todas las invitadas querían su foto en el sofá. Montaje impecable.", rating: 5, date: "2025-11-02" },
  { author: "Mariana López", text: "El set oro rosa para nuestra boda romántica superó todas las expectativas. La mesa de mármol con patas rose gold fue el detalle más comentado de la noche. El equipo llegó puntual y el cuidado con el mobiliario fue excepcional.", rating: 5, date: "2025-10-19" },
  { author: "Fernanda Torres", text: "Los cojines con encaje dorado y el tapiz de lentejuelas hicieron que la zona lounge de nuestro evento se viera de revista. El rosa pálido combinó perfectamente con nuestra decoración floral. Muy recomendado.", rating: 5, date: "2025-12-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Lounge Oro Rosa para XV Años y Bodas CDMX",
    description: "Renta set lounge oro rosa CDMX. Sofá lentejuelas rosa + sillones + mesa mármol rose gold. Ideal para XV años y bodas románticas. Desde $5,500.",
    url: "/servicios/mobiliario/salas-lounge/elegante/set-oro-rosa/",
    priceRange: { min: 5500, max: 11000 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Elegante", url: "/servicios/mobiliario/salas-lounge/elegante/" },
    { name: "Set Oro Rosa", url: "/servicios/mobiliario/salas-lounge/elegante/set-oro-rosa/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Set Champagne", href: "/servicios/mobiliario/salas-lounge/elegante/set-champagne/" },
  { name: "Set Oro Rosa", href: null, active: true },
  { name: "Set Premium", href: "/servicios/mobiliario/salas-lounge/elegante/premium/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Sillas de Diseño", href: "/servicios/mobiliario/sillas/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Set Lounge Oro Rosa para XV Años CDMX"
  description="Renta set lounge oro rosa CDMX. Sofá satinado con lentejuelas + sillones + mesa mármol rose gold. La zona VIP perfecta para XV años y bodas románticas."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="La zona soñada para XV años y bodas románticas en CDMX"
    title='Set Lounge <span class="highlight">Oro Rosa</span> — Renta para XV Años CDMX'
    subtitle="Sofá de 3 plazas en satín rosa pálido con lentejuelas + 2 sillones + mesa de mármol sintético con patas rose gold + cojines con encaje dorado. La zona VIP más fotografiada en XV años y bodas románticas."
    primaryCTA={{ label: "Cotizar set oro rosa", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge oro rosa para XV años` }}
    cards={[
      {
        title: "Lentejuelas cosidas — el brillo que convierte tu zona en set fotográfico",
        content: "Las <strong>lentejuelas de doble costura industrial</strong> del tapiz rosa pálido crean destellos sutiles con cualquier iluminación — especialmente potentes con el estroboscopio o la iluminación teatral típica de los XV años. No son un accesorio extra: son parte del tapiz, lo que garantiza que el brillo sea uniforme y permanente.",
      },
      {
        title: "Mesa de mármol con patas rose gold — el detalle que las mamás notan",
        content: "La <strong>mesa de mármol sintético blanco veteado</strong> con patas rose gold es el elemento más elogiado del set. El mármol aporta una sensación de lujo que el cristal o la madera no pueden igualar. Los cojines con encaje dorado que incluye el set completan una estética coherente que los fotógrafos de XV años agradecen.",
      },
    ]}
  />

  <CTABanner
    headline="Set oro rosa — la zona VIP que los XV años de tu hija merecen"
    subheadline="Satín con lentejuelas · Mesa mármol rose gold · Montaje profesional en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Elegante</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set oro rosa para los XV años o boda que sueñas</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge oro rosa para XV años`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            WhatsApp
          </a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Lounge Oro Rosa en XV Años y Bodas</h2>
            <p class="section__subtitle">XV años, bodas románticas y eventos femeninos de lujo en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Lounge Oro Rosa</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el set oro rosa es el favorito de los XV años en CDMX?"
    headingId="descripcion-heading"
    badge="Romántico y sofisticado — el set que define los XV años de ensueño"
    tags={["Set Oro Rosa", "XV Años", "Bodas Románticas", "Rose Gold"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>set lounge oro rosa</strong> captura exactamente la estética que las quinceañeras sueñan: romántica pero sofisticada, femenina pero con clase. El rosa pálido evita la apariencia infantil del rosa chicle, mientras que las lentejuelas y el rose gold aportan el glamour que un evento de celebración merece.</p>
      <p class="showcase__text">La combinación de materiales es lo que distingue este set. La tela satinada con lentejuelas tiene textura y movimiento — refleja la luz de maneras distintas según el ángulo, lo que hace que ninguna foto sea igual a otra. La mesa de mármol con patas rose gold aporta el elemento de lujo que siempre aparece en primer plano en las fotos del evento.</p>
      <p class="showcase__text">En <strong>CDMX</strong> hemos entregado este set en salones de Polanco, Santa Fe, Pedregal y Satélite para XV años que van de los 100 a los 500 invitados. Lo que nunca cambia: la zona lounge oro rosa siempre termina siendo el punto de reunión donde las invitadas pasan más tiempo y donde se toman las mejores fotos de la noche.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-elegante-plata-rose.avif" alt="Set lounge oro rosa en XV años de lujo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-elegante-marfil-perlado.avif" alt="Lounge elegante oro rosa en salón premium" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-elegante-blanco-cristal.avif" alt="Set oro rosa en boda romántica CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Lounge Oro Rosa</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Lounge Oro Rosa"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre la renta del set lounge oro rosa para XV años y bodas en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el set lounge oro rosa para XV años`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sets, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge elegante y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Elegante</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Set oro rosa para los XV años o boda en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge oro rosa para XV años`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Set Lounge Oro Rosa"
        subtitle="Cuéntanos sobre los XV años o boda y te respondemos de inmediato"
        description={[
          "Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso.",
        ]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="XV Años">XV Años</option>
                <option value="Boda Romántica">Boda Romántica</option>
                <option value="Bridal Shower">Bridal Shower</option>
                <option value="Baby Shower Elegante">Baby Shower Elegante</option>
                <option value="Cumpleaños de Lujo">Cumpleaños de Lujo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sets, venue, número de invitados y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
