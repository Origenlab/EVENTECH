---
/**
 * ─── Set Champagne Lounge Elegante — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Elegante > Set Champagne
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { label: "Set Champagne" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-elegante-blanco-cristal.avif", alt: "Set lounge champagne dorado en gala de lujo CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-marfil-perlado.avif", alt: "Lounge elegante champagne en salón de eventos premium" },
  { src: "/images/mobiliario/sala-lounge-elegante-plata-rose.avif", alt: "Set champagne dorado en gala corporativa CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Zona lounge champagne en boda de lujo CDMX" },
  { src: "/images/mobiliario/silla-chiavari-dorada-boda-elegante-03.avif", alt: "Mobiliario champagne dorado en evento de gala CDMX" },
  { src: "/images/mobiliario/silla-tiffany-dorada-salon-champagne-05-hires.avif", alt: "Set lounge champagne en salón de ceremonias" },
];

const faqs = [
  {
    question: "¿Qué incluye el set lounge champagne para galas?",
    answer: "El <strong>set lounge champagne</strong> incluye sofá de 3 plazas tapizado en tela satinada champagne con hilo metálico, 2 sillones individuales a juego, mesa de centro con tapa de espejo y patas doradas, y 2 mesas laterales con acabado dorado. Todo el set está diseñado para crear una zona VIP de alto impacto visual en galas, premiaciones y eventos de etiqueta."
  },
  {
    question: "¿Para qué tipo de eventos es ideal el set lounge champagne?",
    answer: "El <strong>set champagne dorado</strong> es la elección número uno para galas de premiación, cenas de gala, eventos corporativos de alto perfil, lanzamientos de productos de lujo y bodas con paleta champagne-dorado. Sus tonos cálidos y el hilo metálico del tapiz crean reflejos con la iluminación que potencian el ambiente festivo y de exclusividad."
  },
  {
    question: "¿El tapiz champagne es difícil de mantener durante el evento?",
    answer: "El tapiz champagne de nuestro set tiene <strong>tratamiento antimanchas</strong> que lo protege durante el evento. En caso de derrame accidental, la limpieza es rápida con paño húmedo. Para mayor tranquilidad, entregamos el set con fundas protectoras que se retiran justo antes del evento y se vuelven a colocar al finalizar."
  },
  {
    question: "¿Cuántas personas acomoda el set champagne?",
    answer: "El set champagne está diseñado para <strong>5 a 8 personas</strong> — el sofá de 3 plazas más 2 sillones crean la zona VIP perfecta. Para galas con múltiples zonas VIP recomendamos configuraciones de 2 o 3 sets con distribución estratégica del espacio. También disponible con sillones trono adicionales para zona de honor."
  },
  {
    question: "¿El set champagne incluye iluminación?",
    answer: "El set lounge champagne no incluye iluminación propia, pero está diseñado para aprovechar al máximo la iluminación del venue. El <strong>hilo metálico del tapiz</strong> y el acabado espejo de las mesas multiplican la luz ambiente, creando un efecto de brillo natural sin necesitar iluminación adicional. Se potencia especialmente con luz cálida (3000K)."
  },
];

const specs = [
  { label: "Contenido del set", value: "Sofá 3 plazas + 2 sillones + mesa espejo + 2 mesas laterales doradas" },
  { label: "Tapiz principal", value: "Tela satinada champagne con hilo metálico dorado" },
  { label: "Estructura", value: "Madera maciza con patas en acabado dorado mate" },
  { label: "Mesa de centro", value: "Tapa de espejo biselado, patas doradas, 110 × 65 cm" },
  { label: "Capacidad", value: "5 a 8 personas por set" },
  { label: "Resistencia", value: "110 kg por asiento" },
  { label: "Paleta", value: "Champagne / Dorado — coordina con blanco, negro y marfil" },
  { label: "Estilo", value: "Elegante de gala — satín, dorado, líneas clásicas" },
  { label: "Precio", value: "Desde $6,000 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje profesional y recolección en CDMX" },
];

const reviews = [
  { author: "Lorena Fuentes", text: "El set champagne dorado fue la estrella de nuestra gala anual. Los hilos metálicos brillaban con la iluminación del salón y cada foto quedó impresionante. El equipo fue impecable en tiempo y cuidado.", rating: 5, date: "2025-12-15" },
  { author: "Patricia Olvera", text: "Para nuestra premiación corporativa el set champagne elevó completamente el ambiente. Los ejecutivos homenajeados quedaron impresionados con la zona VIP. Definitivamente a la altura del evento.", rating: 5, date: "2025-10-28" },
  { author: "Roberto Garza", text: "La mesa de espejo con el sofá champagne creó el punto focal perfecto del salón. Las fotos del evento parecen de revista. Calidad de lujo a un precio muy competitivo.", rating: 5, date: "2025-11-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Lounge Champagne para Galas y Eventos de Lujo CDMX",
    description: "Renta set lounge champagne dorado en CDMX. Sofá satinado + sillones + mesa espejo. Hilo metálico, patas doradas. Ideal para galas y premiaciones. Desde $6,000.",
    url: "/servicios/mobiliario/salas-lounge/elegante/set-champagne/",
    priceRange: { min: 6000, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Elegante", url: "/servicios/mobiliario/salas-lounge/elegante/" },
    { name: "Set Champagne", url: "/servicios/mobiliario/salas-lounge/elegante/set-champagne/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Set Champagne", href: null, active: true },
  { name: "Set Oro Rosa", href: "/servicios/mobiliario/salas-lounge/elegante/set-oro-rosa/" },
  { name: "Set Premium", href: "/servicios/mobiliario/salas-lounge/elegante/premium/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Sillas de Diseño", href: "/servicios/mobiliario/sillas/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Set Lounge Champagne para Galas CDMX"
  description="Renta set lounge champagne dorado en CDMX. Sofá satinado + sillones + mesa espejo. Hilo metálico, patas doradas. La zona VIP perfecta para galas. Desde $6,000."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="La zona VIP más sofisticada para galas y premiaciones"
    title='Set Lounge <span class="highlight">Champagne</span> — Renta para Galas CDMX'
    subtitle="Sofá de 3 plazas en satín champagne con hilo metálico + 2 sillones + mesa de centro con tapa de espejo y patas doradas. El set que convierte cualquier gala en un evento de clase mundial."
    primaryCTA={{ label: "Cotizar set champagne", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge champagne para mi gala` }}
    cards={[
      {
        title: "El brillo del satín champagne que multiplica la iluminación de tu gala",
        content: "El <strong>tapiz satinado champagne con hilo metálico dorado</strong> tiene una propiedad especial: multiplica la luz ambiente. En salones con iluminación cálida, el set crea destellos sutiles que enriquecen cada fotografía. Es el mobiliario que los fotógrafos de eventos prefieren porque siempre queda perfecto sin necesitar trabajo de post-producción.",
      },
      {
        title: "Mesa espejo biselado — el detalle de lujo que marca la diferencia",
        content: "La <strong>mesa de centro con tapa de espejo biselado</strong> es el diferenciador del set champagne. El espejo refleja las flores, las velas y la iluminación del salón, creando profundidad visual y multiplicando el impacto de cualquier decoración. Con patas doradas que combinan perfectamente con el tapiz del sofá.",
      },
    ]}
  />

  <CTABanner
    headline="Set champagne dorado — la zona VIP que tu gala merece"
    subheadline="Satín con hilo metálico · Mesa espejo biselado · Montaje profesional en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Elegante</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set champagne dorado para tu gala o evento de lujo</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge champagne para mi gala`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            WhatsApp
          </a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Lounge Champagne en Galas y Eventos Premium</h2>
            <p class="section__subtitle">Galas, premiaciones y bodas de lujo en salones de CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Lounge Champagne</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el set champagne es el favorito de las galas en CDMX?"
    headingId="descripcion-heading"
    badge="Elegancia de gala — el mobiliario que define eventos de alto perfil"
    tags={["Set Champagne", "Galas de Lujo", "Premiaciones", "Mesa Espejo"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>set lounge champagne</strong> tiene el equilibrio perfecto entre opulencia y refinamiento. No es tan ostentoso como el blanco cristal puro ni tan sobrio como el gris Oxford. El tono champagne con sus destellos dorados crea una elegancia cálida — sofisticada sin ser fría — que funciona en cualquier salón de lujo.</p>
      <p class="showcase__text">La mesa de espejo biselado es el secreto del set. Refleja las flores de la decoración, las velas del salón y la iluminación del venue, multiplicando el impacto visual de cada elemento decorativo. Es la razón por la que las fotos del evento siempre quedan excepcionales — hay profundidad y brillo que solo el espejo puede dar.</p>
      <p class="showcase__text">En <strong>CDMX</strong> hemos instalado este set en los principales hoteles de cinco estrellas, salones de convenciones y venues de lujo. Lo usamos para galas de premiación de empresas Fortune 500, bodas de alto perfil y eventos gubernamentales. La consistencia en calidad es lo que nos ha convertido en el proveedor preferido de los mejores event planners de la ciudad.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-elegante-blanco-cristal.avif" alt="Set lounge champagne en gala de lujo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-elegante-marfil-perlado.avif" alt="Lounge champagne dorado en salón premium" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-elegante-plata-rose.avif" alt="Set elegante champagne en evento corporativo" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Lounge Champagne</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Lounge Champagne"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre la renta del set lounge champagne para galas y eventos de lujo en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el set lounge champagne para gala`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sets, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge elegante y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Elegante</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Set champagne dorado para tu gala en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set lounge champagne para mi gala`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Set Lounge Champagne"
        subtitle="Cuéntanos sobre tu gala o evento de lujo y te respondemos de inmediato"
        description={[
          "Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso.",
        ]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Gala de Premiación">Gala de Premiación</option>
                <option value="Cena de Gala">Cena de Gala</option>
                <option value="Evento Corporativo Premium">Evento Corporativo Premium</option>
                <option value="Boda de Lujo">Boda de Lujo</option>
                <option value="Lanzamiento de Producto">Lanzamiento de Producto</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sets, venue, número de invitados y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
