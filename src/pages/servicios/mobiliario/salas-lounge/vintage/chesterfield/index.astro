---
/**
 * ─── Sofá Chesterfield Lounge Vintage — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Vintage > Chesterfield
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { label: "Sofá Chesterfield" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-vintage-azul-marino-neon.avif", alt: "Sofá Chesterfield en terciopelo vino para boda en hacienda CDMX" },
  { src: "/images/mobiliario/sala-lounge-vintage-esmeralda-neon.avif", alt: "Chesterfield capitonado en zona lounge de evento vintage" },
  { src: "/images/mobiliario/lounge-moderno-01.avif", alt: "Sofá Chesterfield esmeralda en recepción de lujo CDMX" },
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Chesterfield en salón de boda con decoración clásica" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Sofá Chesterfield en zona VIP de gala temática" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Chesterfield vintage en evento de lujo CDMX" },
];

const faqs = [
  {
    question: "¿Qué hace especial al sofá Chesterfield para eventos?",
    answer: "El <strong>sofá Chesterfield</strong> es el único modelo de sofá que tiene presencia escénica por sí solo. Su silueta inconfundible — respaldo y brazos al mismo nivel, capitonado profundo, botones dorados — crea un punto focal en cualquier salón. Los invitados lo reconocen instintivamente como símbolo de lujo y elegancia, lo que hace que se acerquen y quieran tomarse una foto."
  },
  {
    question: "¿En qué colores está disponible el Chesterfield?",
    answer: "El sofá Chesterfield está disponible en <strong>cuatro colores de terciopelo premium</strong>: Vino Borgoña (el más solicitado para bodas), Esmeralda Profundo (para paletas verdes y doradas), Azul Petróleo (para galas con ambiente dramático) y Mostaza Ámbar (para bodas otoñales y eventos con paleta cálida). Todos con botones dorados y patas torneadas en acabado dorado."
  },
  {
    question: "¿Cuántas personas sienta el sofá Chesterfield?",
    answer: "El sofá Chesterfield de <strong>3 plazas</strong> acomoda cómodamente a 3 personas con espacio generoso. A diferencia de los sofás modernos, el Chesterfield invita a sentarse de forma más formal y erguida, lo que hace que los 3 espacios se usen con frecuencia. Para zonas de mayor capacidad, lo combinamos con 1 o 2 sillones capitonados."
  },
  {
    question: "¿El Chesterfield se puede rentar sin el set completo?",
    answer: "Sí, el sofá Chesterfield se renta de forma independiente <strong>desde $2,500</strong>. Es una excelente opción para crear un punto focal único en tu evento sin necesidad del set completo. Puedes combinarlo con sillones que ya tengas en el venue, con mesas auxiliares o simplemente usarlo como pieza escultórica para fotografías."
  },
  {
    question: "¿El terciopelo se puede dañar en eventos al aire libre?",
    answer: "El <strong>terciopelo premium</strong> de nuestro Chesterfield está tratado para resistir la humedad moderada, pero no recomendamos usarlo en exteriores con lluvia o en zonas muy expuestas al sol directo por períodos prolongados. Para jardines, recomendamos colocarlo bajo toldos, carpas o en áreas cubiertas. El terciopelo no transpira excesivamente — es más fresco de lo que parece a simple vista."
  },
];

const specs = [
  { label: "Tipo de pieza", value: "Sofá Chesterfield 3 plazas" },
  { label: "Material tapicería", value: "Terciopelo premium con capitonado artesanal profundo" },
  { label: "Colores disponibles", value: "Vino Borgoña / Esmeralda / Azul Petróleo / Mostaza Ámbar" },
  { label: "Dimensiones", value: "210 cm largo × 90 cm profundo × 80 cm alto (respaldo y brazos nivelados)" },
  { label: "Capacidad", value: "3 personas" },
  { label: "Acabados decorativos", value: "Botones dorados capitonados, patas torneadas doradas" },
  { label: "Resistencia", value: "100 kg por asiento" },
  { label: "Estilo", value: "Victoriano clásico — silueta inconfundible" },
  { label: "Precio", value: "Desde $2,500 por pieza / evento" },
  { label: "Incluye", value: "Entrega, montaje y recolección en CDMX" },
];

const reviews = [
  { author: "Paulina Reyes", text: "El Chesterfield en vino borgoña fue el protagonista de nuestra boda en hacienda. Todos nuestros invitados se sentaron ahí en algún momento de la noche. Es una pieza que habla sola.", rating: 5, date: "2025-10-12" },
  { author: "Eduardo Blanco", text: "Lo rentamos solo para una sesión de fotos en nuestra boda — sin el set completo. El resultado fue espectacular. La calidad del terciopelo y los botones dorados son de primer nivel.", rating: 5, date: "2025-11-20" },
  { author: "Lorena Castellanos", text: "Para nuestra gala temática años 20, el Chesterfield en esmeralda con el fondo dorado del salón fue la combinación perfecta. Muy profesionales en la entrega y el montaje.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Sofá Chesterfield Lounge Vintage para Eventos CDMX",
    description: "Sofá Chesterfield 3 plazas en terciopelo premium. Capitonado artesanal con botones dorados. Vino, esmeralda, azul y mostaza. Desde $2,500.",
    url: "/servicios/mobiliario/salas-lounge/vintage/chesterfield/",
    priceRange: { min: 2500, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Vintage", url: "/servicios/mobiliario/salas-lounge/vintage/" },
    { name: "Sofá Chesterfield", url: "/servicios/mobiliario/salas-lounge/vintage/chesterfield/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/vintage/set-completo/" },
  { name: "Sofá Chesterfield", href: null, active: true },
  { name: "Sillón Capitonado", href: "/servicios/mobiliario/salas-lounge/vintage/capitonado/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Sofá Chesterfield CDMX — Vintage"
  description="Renta sofá Chesterfield en CDMX. 3 plazas en terciopelo premium con capitonado artesanal y botones dorados. Vino, esmeralda, azul y mostaza. Desde $2,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La pieza más fotografiada de cualquier boda en hacienda"
    title='Sofá <span class="highlight">Chesterfield</span> Vintage — Renta en CDMX'
    subtitle="Sofá Chesterfield de 3 plazas en terciopelo premium con capitonado artesanal profundo y botones dorados. Disponible en vino borgoña, esmeralda, azul petróleo y mostaza ámbar. El punto focal que tus invitados recordarán toda la noche."
    primaryCTA={{ label: "Cotizar Chesterfield", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá Chesterfield vintage para mi evento` }}
    cards={[
      {
        title: "Silueta inconfundible — el sofá que define el estilo del evento",
        content: "El <strong>Chesterfield capitonado</strong> no es solo un mueble — es una declaración de estilo. Su silueta victoriana con brazos y respaldo al mismo nivel, el capitonado profundo y los botones dorados crean una presencia escénica que ningún otro sofá tiene. Desde el momento en que tus invitados lo ven al entrar, saben que están en un evento de otro nivel.",
      },
      {
        title: "Cuatro colores de terciopelo para cada paleta de evento",
        content: "El vino borgoña es el color más solicitado para bodas con flores blancas y decoración dorada. El esmeralda profundo es ideal para eventos con paleta verde y naturales. El azul petróleo crea un ambiente dramático perfecto para galas nocturnas. El mostaza ámbar conecta con bodas otoñales y paletas tierra. Todos con el mismo capitonado artesanal y botones dorados.",
      },
    ]}
  />

  <CTABanner
    headline="El Chesterfield que convierte tu zona lounge en la foto más compartida del evento"
    subheadline="Terciopelo premium · Capitonado artesanal · Botones dorados · CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Vintage</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sofá Chesterfield para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá Chesterfield vintage`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Sofá Chesterfield en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en hacienda, galas temáticas y cenas de lujo en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Sofá Chesterfield Vintage</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el Chesterfield es el sofá más memorable de todos los estilos"
    headingId="descripcion-heading"
    badge="Silueta victoriana · capitonado profundo · presencia escénica única"
    tags={["Chesterfield", "Lounge Vintage", "Terciopelo", "Bodas Hacienda CDMX"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>Chesterfield capitonado</strong> tiene 250 años de historia — y todavía sigue siendo el sofá más reconocible del mundo. La razón es su diseño: la combinación de capitonado profundo, brazos y respaldo al mismo nivel, y patas torneadas crea una silueta que el ojo humano lee inmediatamente como "lujo" y "elegancia".</p>
      <p class="showcase__text">En eventos, esta legibilidad visual inmediata es su mayor ventaja. Los invitados no necesitan mirar dos veces para entender que están ante algo especial. El terciopelo amplifica este efecto — absorbe y refleja la luz de forma diferente a cualquier otra tela, creando profundidad y textura que en fotografías resulta espectacular.</p>
      <p class="showcase__text">Lo rentamos en <strong>bodas en haciendas y mansiones de CDMX</strong> con frecuencia semanal. El resultado es siempre el mismo: esa esquina donde está el Chesterfield se convierte en el rincón más fotografiado del evento. Los invitados pasan la noche yendo y volviendo a esa zona.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-vintage-azul-marino-neon.avif" alt="Sofá Chesterfield vino en boda hacienda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-vintage-esmeralda-neon.avif" alt="Chesterfield capitonado en evento vintage" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-moderno-01.avif" alt="Sofá Chesterfield en gala de lujo" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Sofá Chesterfield Vintage</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Sofá Chesterfield Vintage"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre el sofá Chesterfield para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el sofá Chesterfield vintage`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Color de terciopelo, fecha y venue — precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge vintage y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Vintage</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Sofá Chesterfield para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá Chesterfield vintage`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Sofá Chesterfield Vintage"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="Gala Temática">Gala Temática</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Sesión de Fotos">Sesión de Fotos</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Color de terciopelo preferido (vino/esmeralda/azul/mostaza), venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
