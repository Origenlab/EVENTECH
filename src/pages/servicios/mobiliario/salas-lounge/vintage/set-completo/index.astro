---
/**
 * ─── Set Completo Lounge Vintage — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Vintage > Set Completo
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { label: "Set Completo" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-vintage-terciopelo-evento.avif", alt: "Set completo lounge vintage con sofá Chesterfield en terciopelo para boda en hacienda CDMX" },
  { src: "/images/mobiliario/lounge-vintage-chesterfield-boda-hacienda.avif", alt: "Set lounge vintage completo en boda hacienda con decoración clásica" },
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Zona lounge vintage con capitonado y mesas de madera en evento" },
  { src: "/images/mobiliario/lounge-moderno-terciopelo-evento-premium.avif", alt: "Set vintage completo en salón de eventos clásico CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Lounge vintage en recepción de boda elegante" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Set completo lounge vintage en gala de lujo CDMX" },
];

const faqs = [
  {
    question: "¿Qué incluye el set completo de lounge vintage?",
    answer: "El <strong>set completo lounge vintage</strong> incluye sofá Chesterfield de 3 plazas en terciopelo (colores vino, esmeralda, azul petróleo o mostaza), 2 sillones capitonados a juego, mesa de centro con cubierta de madera y patas torneadas, y mesa lateral. Todo en estética victoriana con acabados dorados. Diseñado para crear una zona de conversación íntima y elegante para 5 a 7 personas."
  },
  {
    question: "¿Para qué tipo de eventos es ideal el set lounge vintage?",
    answer: "El <strong>lounge vintage</strong> es perfecto para bodas en haciendas, mansiones y venues con arquitectura colonial; cenas de gala temáticas; cumpleaños de lujo con estilo retro; cocteles en espacios con decoración clásica. El terciopelo y los acabados dorados crean un ambiente cálido e íntimo que los invitados recuerdan como uno de los detalles más especiales del evento."
  },
  {
    question: "¿En qué colores está disponible el terciopelo?",
    answer: "El set vintage completo está disponible en <strong>cuatro colores de terciopelo</strong>: Vino Borgoña (el más solicitado para bodas clásicas), Esmeralda Profundo (para eventos con paleta verde y dorado), Azul Petróleo (para galas y corporativos con toque dramático) y Mostaza Ámbar (para bodas otoñales y bohemias). Todos con capitonado artesanal y botones dorados."
  },
  {
    question: "¿Las piezas del set vintage están en buen estado?",
    answer: "Todas las piezas del set vintage se inspeccionan y limpian profesionalmente antes de cada evento. El <strong>terciopelo se trata con limpiador especializado</strong> que restaura su textura y brillo. Las costuras y botones capitonados se revisan para garantizar que lleguen en condiciones perfectas. Cada pieza se protege con fundas durante el transporte."
  },
  {
    question: "¿El set vintage combina con sillas Tiffany doradas?",
    answer: "Sí, es una de las combinaciones más fotogénicas. <strong>Set lounge vintage + sillas Tiffany doradas</strong> crea un espacio coherente donde el dorado de las patas del Chesterfield conecta con el dorado de las sillas. Si tus mesas de banquete tienen mantelería en blanco o marfil, el contraste del terciopelo vino o esmeralda es espectacular."
  },
];

const specs = [
  { label: "Contenido del set", value: "Sofá Chesterfield 3 plazas + 2 sillones capitonados + mesa centro + mesa lateral" },
  { label: "Material tapicería", value: "Terciopelo premium de alta densidad con capitonado artesanal" },
  { label: "Colores disponibles", value: "Vino Borgoña / Esmeralda / Azul Petróleo / Mostaza Ámbar" },
  { label: "Dimensiones sofá", value: "210 cm largo × 90 cm profundo × 80 cm alto (respaldo)" },
  { label: "Capacidad", value: "5 a 7 personas por set" },
  { label: "Acabados decorativos", value: "Botones dorados capitonados, patas torneadas con acabado dorado" },
  { label: "Mesa centro", value: "Cubierta de madera con herrajes dorados, 90 × 55 cm" },
  { label: "Estilo", value: "Victoriano / vintage — líneas curvas, capitonado clásico" },
  { label: "Precio", value: "Desde $4,500 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje profesional y recolección en CDMX" },
];

const reviews = [
  { author: "Isabella Moreno", text: "El set vintage en terciopelo vino fue la zona más fotografiada de toda la boda. Cada invitado quiso tomarse una foto ahí. La calidad del terciopelo y el acabado dorado son espectaculares.", rating: 5, date: "2025-11-02" },
  { author: "Roberto Guzmán", text: "Lo usamos para la zona VIP de una cena de gala temática años 20. El efecto fue increíble — los asistentes no querían levantarse. Montaje impecable y el transporte no dañó ninguna pieza.", rating: 5, date: "2025-09-18" },
  { author: "Carmen Vidal", text: "Para una boda en hacienda del centro histórico, el lounge vintage en esmeralda fue perfecto. Combinó con las paredes de cantera y la decoración floral. Totalmente recomendable.", rating: 5, date: "2025-10-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Completo Lounge Vintage para Eventos en CDMX",
    description: "Set completo lounge vintage: sofá Chesterfield + 2 sillones capitonados + mesas. Terciopelo premium en vino, esmeralda, azul y mostaza. Desde $4,500.",
    url: "/servicios/mobiliario/salas-lounge/vintage/set-completo/",
    priceRange: { min: 4500, max: 9000 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Vintage", url: "/servicios/mobiliario/salas-lounge/vintage/" },
    { name: "Set Completo", url: "/servicios/mobiliario/salas-lounge/vintage/set-completo/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Set Completo", href: null, active: true },
  { name: "Sofá Chesterfield", href: "/servicios/mobiliario/salas-lounge/vintage/chesterfield/" },
  { name: "Sillón Capitonado", href: "/servicios/mobiliario/salas-lounge/vintage/capitonado/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Set Completo Lounge Vintage CDMX"
  description="Renta set completo lounge vintage en CDMX. Sofá Chesterfield + 2 sillones capitonados + mesas. Terciopelo premium en vino, esmeralda y azul. Desde $4,500."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="Set completo — 5 a 7 personas · capitonado artesanal · botones dorados"
    title='Set Completo <span class="highlight">Lounge Vintage</span> — Renta en CDMX'
    subtitle="Sofá Chesterfield de 3 plazas + 2 sillones capitonados + mesa de centro y lateral. Terciopelo premium en cuatro colores con acabados dorados. La zona lounge más fotogénica para bodas en haciendas, galas temáticas y eventos con estética clásica en CDMX."
    primaryCTA={{ label: "Cotizar set lounge vintage", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge vintage para mi evento` }}
    cards={[
      {
        title: "El set lounge más fotogénico — el rincón que todos quieren retratar",
        content: "El <strong>set completo lounge vintage</strong> crea uno de esos espacios que los invitados buscan para tomarse la foto del evento. El terciopelo capitonado con botones dorados, las patas torneadas y la mesa de madera con herrajes crean un conjunto visualmente coherente que evoca lujo atemporal. Disponible en vino borgoña, esmeralda profundo, azul petróleo y mostaza ámbar.",
      },
      {
        title: "Perfecto para haciendas, mansiones y venues con historia",
        content: "El <strong>lounge vintage</strong> no compite con la arquitectura clásica — la complementa. En haciendas del centro histórico o mansiones porfirianas, el Chesterfield en terciopelo se integra como si siempre hubiera estado ahí. El capitonado artesanal y los botones dorados reflejan la luz de las velas y la iluminación ambiental de forma espectacular.",
      },
    ]}
  />

  <CTABanner
    headline="El set vintage que convierte tu zona lounge en el rincón más fotografiado"
    subheadline="Terciopelo premium · Capitonado artesanal · Botones dorados · Haciendas CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Vintage</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set completo lounge vintage para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge vintage`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Completo Lounge Vintage en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en haciendas, galas temáticas y cenas de lujo en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Completo Lounge Vintage</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el lounge vintage es el más solicitado para bodas en hacienda"
    headingId="descripcion-heading"
    badge="Victoriano · capitonado artesanal · botones dorados"
    tags={["Lounge Vintage", "Bodas en Hacienda", "Chesterfield", "Terciopelo Premium"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay algo en el <strong>Chesterfield capitonado</strong> que genera una reacción inmediata: los invitados lo ven y quieren sentarse, quedarse, conversar. El terciopelo tiene esa cualidad táctil y visual que ningún otro material replica — absorbe la luz suavemente, crea profundidad con el capitonado, y mantiene su apariencia lujosa durante toda la noche.</p>
      <p class="showcase__text">El set vintage completo está curado para que todas las piezas tengan coherencia estética: el Chesterfield y los capitonados comparten la misma tela, el mismo nivel de capitonado y los mismos botones dorados. La mesa de centro con cubierta de madera y patas torneadas conecta con la estética sin interrumpirla.</p>
      <p class="showcase__text">En <strong>haciendas del centro histórico de CDMX</strong>, el set vintage se integra con la arquitectura de cantera, los techos de viga, los patios con fuente. Es el único estilo de lounge que mejora cuando el venue tiene historia — no compite con ella, la potencia.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-vintage-terciopelo-evento.avif" alt="Set completo lounge vintage Chesterfield en boda hacienda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-vintage-chesterfield-boda-hacienda.avif" alt="Lounge vintage en boda hacienda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-moderno-terciopelo-evento-premium.avif" alt="Sillón capitonado vintage en zona lounge" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Completo Lounge Vintage</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Completo Lounge Vintage"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre el set completo lounge vintage para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el set completo lounge vintage`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sets, color de terciopelo, fecha y venue — precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge vintage y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Vintage</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Set completo lounge vintage para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge vintage para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Set Completo Lounge Vintage"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="Gala Temática">Gala Temática</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Cumpleaños de Lujo">Cumpleaños de Lujo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sets, color de terciopelo preferido, venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
