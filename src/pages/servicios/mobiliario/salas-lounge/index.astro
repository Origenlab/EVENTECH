---
/**
 * ─── EVENTECH.MX — Renta de Salas Lounge para Eventos (L4 hub, sistema hm-) ───
 * Moderno · Vintage · Boho · Elegante — CDMX y ZMVM
 * Homólogo del hub de sillas (mismo layout, complementos y dorado institucional).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "moderno",
    name: "Lounge Moderno",
    badge: "Favorito corporativo",
    excerpt: "Líneas limpias y cuero sintético premium en blanco, negro y gris. La zona VIP para corporativos, lanzamientos de marca y ferias comerciales. Sets modulares que se adaptan a cualquier planta. Desde $3,500 el set.",
    href: "/servicios/mobiliario/salas-lounge/moderno/",
    image: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif",
    subcategories: [
      { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/moderno/set-completo/" },
      { name: "Sofá Individual", href: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/" },
      { name: "Mesa de Centro", href: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/" },
    ],
  },
  {
    id: "vintage",
    name: "Lounge Vintage",
    badge: "Elegancia clásica",
    excerpt: "Terciopelo capitonado en esmeralda, borgoña y azul marino con detalles dorados. Sofisticación de otra época para bodas románticas y galas. El sello Chesterfield que eleva cualquier fotografía. Desde $4,500 el set.",
    href: "/servicios/mobiliario/salas-lounge/vintage/",
    image: "/images/mobiliario/sala-lounge-vintage-tufted-boda.avif",
    subcategories: [
      { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/vintage/set-completo/" },
      { name: "Chesterfield", href: "/servicios/mobiliario/salas-lounge/vintage/chesterfield/" },
      { name: "Capitonado", href: "/servicios/mobiliario/salas-lounge/vintage/capitonado/" },
    ],
  },
  {
    id: "boho",
    name: "Lounge Boho",
    badge: "Favorito de jardines",
    excerpt: "Ratán natural, textiles artesanales y macramé. Ambientes cálidos y relajados para bodas al aire libre, jardines y haciendas. El estilo que define las recepciones campestres y bohemias. Desde $3,800 el set.",
    href: "/servicios/mobiliario/salas-lounge/boho/",
    image: "/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif",
    subcategories: [
      { name: "Set Ratán", href: "/servicios/mobiliario/salas-lounge/boho/set-ratan/" },
      { name: "Peacock Chair", href: "/servicios/mobiliario/salas-lounge/boho/peacock-chair/" },
      { name: "Macramé", href: "/servicios/mobiliario/salas-lounge/boho/macrame/" },
    ],
  },
  {
    id: "elegante",
    name: "Lounge Elegante",
    badge: "Línea premium",
    excerpt: "Tonos champagne y oro rosa con acabados metálicos y cristal. La opción premium para galas, premiaciones y bodas de lujo donde la zona lounge es un statement visual. Desde $6,000 el set.",
    href: "/servicios/mobiliario/salas-lounge/elegante/",
    image: "/images/mobiliario/sala-lounge-chesterfield-neon-eternally.avif",
    subcategories: [
      { name: "Set Champagne", href: "/servicios/mobiliario/salas-lounge/elegante/set-champagne/" },
      { name: "Set Oro Rosa", href: "/servicios/mobiliario/salas-lounge/elegante/set-oro-rosa/" },
    ],
  },
];

const whyFeatures = [
  {
    title: "Sets propios — sin subcontratistas",
    body: "Inventario propio de salas lounge en bodega CDMX en los 4 estilos. No intermediamos con otros proveedores. Lo que cotizamos es lo que existe en nuestro almacén, verificado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    title: "Mobiliario limpio y sanitizado",
    body: "Cada sofá, sillón y puff se limpia y sanitiza entre eventos — no entregamos tapicería con manchas o desgaste visible. Las fundas y cojines se lavan, y las piezas con deterioro se retapizan o retiran del inventario. Tus invitados se sientan en mobiliario impecable.",
  },
  {
    title: "Entrega y montaje de la zona completa",
    body: "Nuestro equipo entrega y arma la sala lounge en la posición exacta de tu layout — sofás, mesas de centro, tapetes, puffs y decoración. No dejamos la mercancía en la puerta. Llegamos con tiempo antes del evento para que la zona VIP quede lista sin contratiempos.",
  },
  {
    title: "Diseño de la zona lounge",
    body: "Una sala lounge no es solo poner sofás: es crear una zona de descanso y conversación que fluya con el resto del evento. Diseñamos la distribución según tu venue, número de invitados y estilo — con referencias visuales reales de montajes que funcionan.",
  },
  {
    title: "Reposición en sitio garantizada",
    body: "Si durante el montaje detectamos una pieza dañada o un acabado incorrecto, la reponemos sin costo dentro de CDMX. Siempre cargamos piezas de respaldo en cada servicio para que tu zona lounge quede completa sin importar imprevistos de último minuto.",
  },
  {
    title: "Asesoría para combinar estilos",
    body: "Mezclar un Chesterfield vintage con una mesa de centro moderna es una decisión de diseño, no de azar. Te asesoramos para que la zona lounge sea coherente con tu paleta, tu mobiliario de banquete y la estética general del evento — para un resultado fotogénico.",
  },
];

const steps = [
  { n: 1, t: "Cotización y aparto de inventario", p: "Nos indicas estilo, número de invitados de la zona lounge, fecha y venue. En menos de 24 horas te confirmamos disponibilidad y te enviamos propuesta. Con el 30% de anticipo apartamos tu set — sin pago total por adelantado." },
  { n: 2, t: "Diseño de la distribución y coordinación", p: "Diseñamos la distribución de la sala lounge según tu venue y la coordinamos con decoradora, wedding planner o el salón. Compartimos layout de montaje, horario de acceso y requerimientos logísticos para que todo encaje sin conflictos." },
  { n: 3, t: "Entrega, montaje y verificación en sitio", p: "Llegamos el día del evento o la tarde anterior según acuerdo. Armamos la zona completa — sofás, mesas, tapetes y decoración — y hacemos verificación visual del montaje antes de retirarnos. Tú o tu coordinador firman conformidad." },
  { n: 4, t: "Recolección al finalizar el evento", p: "Al cierre, nuestro equipo desarma y carga toda la sala lounge. Revisión en conjunto del estado de las piezas al momento de la recolección, no de forma unilateral. Sin presiones de tiempo si el evento se extiende — acordamos horario con anticipación." },
];

const faqs = [
  {
    question: "¿Qué incluye un set de sala lounge?",
    answer: "Un set completo estándar incluye sofá de 2 o 3 plazas, uno o dos sillones individuales, mesa de centro y cojines decorativos. Según el estilo y el tamaño del set, puede sumar puffs, tapete, mesas laterales y decoración complementaria. En la cotización detallamos exactamente qué piezas componen cada set para que sepas qué recibes — sin ambigüedades.",
  },
  {
    question: "¿Para cuántas personas es una sala lounge?",
    answer: "Un set estándar acomoda cómodamente de 6 a 8 personas sentadas. Para eventos grandes recomendamos varias salas lounge distribuidas en distintas zonas en lugar de una sola muy grande — crea más puntos de descanso y mejora la circulación. Calculamos cuántos sets necesitas según tu número de invitados y el tipo de evento (boda, corporativo, XV años).",
  },
  {
    question: "¿Las salas lounge se pueden usar en exteriores?",
    answer: "Sí, especialmente el estilo Boho de ratán, pensado para jardines y terrazas. Para los estilos con tapicería de tela o terciopelo (Vintage, Elegante) recomendamos ubicarlos bajo carpa o techo para proteger el mobiliario de humedad y rocío. En exteriores siempre montamos sobre superficie firme o tapete para preservar las piezas.",
  },
  {
    question: "¿Puedo combinar diferentes estilos de lounge?",
    answer: "Sí, y muchos clientes lo hacen con buen resultado cuando hay coherencia de paleta. Combinaciones frecuentes: Moderno en zona corporativa + Elegante en área VIP; Boho en jardín + Vintage en interior. Lo importante es que los colores y acabados dialoguen entre sí. Te asesoramos con la mezcla que mejor funciona para tu evento y venue.",
  },
  {
    question: "¿El precio incluye montaje y recolección?",
    answer: "Sí. El precio cotizado del set incluye entrega al venue, armado completo de la zona lounge según layout, verificación de montaje y recolección al finalizar. Dentro de CDMX no hay cargo logístico adicional. Para Zona Metropolitana (Naucalpan, Tlalnepantla, Ecatepec, Neza, etc.) el costo de transporte se especifica en la cotización.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Para una o dos salas lounge, 2 a 3 semanas de anticipación suele ser suficiente. Para eventos grandes con múltiples sets o si requieres un estilo y color muy específicos, recomendamos 4 a 6 semanas. En temporada alta de bodas (noviembre a febrero) y fines de semana con eventos simultáneos, 6 a 8 semanas garantiza el set exacto que buscas.",
  },
  {
    question: "¿Puedo personalizar colores y decoración?",
    answer: "Sí. Ofrecemos cojines y fundas en distintos colores para ajustar el set a tu paleta, además de complementos como tapetes, mesas laterales, lámparas y decoración. Si tienes una referencia visual o un mood board, lo usamos como base para armar una zona lounge a la medida de tu evento. Consúltanos las opciones disponibles para cada estilo.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Salas Lounge para Eventos en CDMX",
    description: "Renta de salas lounge en estilos moderno, vintage, boho y elegante para bodas, XV años, corporativos y eventos sociales en CDMX. Diseño, montaje y asesoría de distribución incluidos.",
    url: "/servicios/mobiliario/salas-lounge/",
    priceRange: { min: 3500, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge" },
];
---

<PageLayout
  title="Renta de Salas Lounge para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif"
  description="Renta de salas lounge en estilos moderno, vintage, boho y elegante en CDMX. Sets completos con diseño, montaje y asesoría de distribución incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="lounge-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Salas lounge para eventos · CDMX y ZMVM</p>
            <h1 id="lounge-hero-heading">
              La <em>zona VIP que tu evento necesita</em> — sets lounge en 4 estilos
            </h1>
            <p class="hm-hero__lead">
              Moderno, Vintage, Boho y Elegante. Sets completos con sofás, mesas de centro
              y decoración, diseño de la distribución, montaje profesional y recolección
              al finalizar. Una sola empresa para transformar cualquier espacio en zona de descanso.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20sala%20lounge%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar sala lounge
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>salas lounge para eventos</strong> con inventario propio
              en la Ciudad de México — sets completos en 4 estilos distintos, sin subcontratar
              ni intermediar. Moderno de líneas limpias para corporativos, Vintage de terciopelo
              capitonado para bodas románticas, Boho de ratán para jardines y Elegante en
              champagne y oro para galas de lujo. Cada set se entrega limpio, sanitizado y
              armado en la posición exacta de tu layout.
            </p>
            <p>
              Con <strong>cientos de eventos montados</strong> en CDMX, sabemos que una zona
              lounge no es solo poner sofás: es crear un punto de descanso y conversación que
              fluya con el resto del evento. Por eso incluimos diseño de la distribución,
              asesoría de estilo y reposición garantizada en sitio. Para eventos que también
              requieren <a href="/servicios/mobiliario/sillas/">sillas</a> y
              <a href="/servicios/mobiliario/mesas/">mesas</a> te cotizamos el paquete
              completo desde una sola empresa, sin duplicar logística.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Estilos de sala lounge disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20sala%20lounge%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Sets para cada ambiente</p>
            <h2 id="catalogo-heading">¿Qué estilo de lounge necesita tu evento?</h2>
            <p class="hm__head-sub">4 estilos, múltiples configuraciones — el ambiente perfecto para cada celebración y presupuesto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La zona lounge es donde tus invitados conversan, descansan y se toman las
              mejores fotos espontáneas del evento. No es relleno: es un espacio que define
              la atmósfera y da respiro a la pista de baile y al banquete. Elegir el estilo
              correcto es decidir qué sensación quieres que tenga ese rincón — sofisticado,
              relajado, contemporáneo o romántico.
            </p>
            <p>
              Moderno para corporativos y lanzamientos donde importa la imagen limpia.
              Vintage cuando la boda pide elegancia clásica y terciopelo. Boho para jardines
              y recepciones campestres. Elegante cuando la zona lounge es un statement de lujo
              en galas y premiaciones.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada estilo, a fondo</p>
            <h2 id="detalle-heading">Los 4 estilos de lounge — en detalle</h2>
            <p class="hm__head-sub">Materiales, piezas, paleta y para qué tipo de evento funciona mejor cada estilo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada estilo de lounge hay decisiones que afectan la atmósfera del
              evento: el material de la tapicería que define si el ambiente se siente cálido
              o contemporáneo, la paleta que debe dialogar con tu decoración, y la
              configuración de piezas que determina cuánta gente conversa cómoda en la zona.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada estilo.
            </p>
          </div>
        </div>

        <!-- MODERNO -->
        <article class="hm-feat" aria-labelledby="feat-moderno">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Lounge Moderno</p>
            <h3 class="hm-feat__title" id="feat-moderno">Líneas limpias y materiales premium — la zona VIP de los eventos corporativos de alto impacto</h3>
            <p class="hm-feat__lead">El lounge moderno es la elección cuando la imagen importa: superficies limpias, geometría definida y una paleta neutra que proyecta profesionalismo sin distraer de tu marca.</p>
            <p>
              Sets en <strong>cuero sintético premium en blanco, negro y gris</strong> con
              estructura modular que se reconfigura según la planta del venue. Cada set incluye
              sofás, sillones individuales y mesa de centro de líneas rectas, con la opción de
              sumar puffs y mesas laterales. La tapicería sintética <strong>resiste el uso
              intensivo</strong> de ferias y eventos de varios días sin perder presentación.
            </p>
            <p>
              Ideal para <strong>corporativos, lanzamientos de marca, ferias comerciales y
              activaciones</strong>. Combina con nuestras
              <a href="/servicios/mobiliario/mesas/cocktail/">mesas cocktail</a> para zonas de
              networking y con <a href="/servicios/iluminacion/">iluminación arquitectónica</a>
              para realzar el acabado limpio del montaje.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/moderno/set-completo/" },
                { name: "Sofá Individual", href: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/" },
                { name: "Mesa de Centro", href: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/mobiliario/salas-lounge/moderno/">
              Ver Lounge Moderno completo
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Sala lounge moderna en blanco y dorado para evento corporativo en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/mobiliario/lounge-moderno-01.avif" alt="Set de lounge moderno en evento premium" loading="lazy" decoding="async" />
              <img src="/images/mobiliario/lounge-moderno-02.avif" alt="Set de lounge moderno en evento corporativo" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- VINTAGE -->
        <article class="hm-feat" aria-labelledby="feat-vintage">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Lounge Vintage</p>
            <h3 class="hm-feat__title" id="feat-vintage">Terciopelo capitonado y detalles dorados — la elegancia de otra época para bodas románticas y galas</h3>
            <p class="hm-feat__lead">El lounge vintage evoca los salones clásicos: terciopelo profundo, botones capitonados y patas torneadas. Es el estilo que convierte una esquina del evento en el rincón más fotografiado de la noche.</p>
            <p>
