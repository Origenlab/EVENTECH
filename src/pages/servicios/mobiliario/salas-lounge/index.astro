---
/**
 * ─── Salas Lounge para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Salas Lounge para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge" },
];

const SALAS = [
  {
    name: "Lounge Moderno",
    excerpt: "Líneas limpias y cuero sintético premium en blanco, negro y gris. Ideal para corporativos, lanzamientos y ferias comerciales.",
    cta: "Moderno",
    href: "/servicios/mobiliario/salas-lounge/moderno/",
    icon: "briefcase",
    image: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif",
  },
  {
    name: "Lounge Vintage",
    excerpt: "Terciopelo capitonado en tonos esmeralda, borgoña y azul marino. Sofisticación clásica para bodas románticas y galas.",
    cta: "Vintage",
    href: "/servicios/mobiliario/salas-lounge/vintage/",
    icon: "crown",
    image: "/images/mobiliario/sala-lounge-vintage-tufted-boda.avif",
  },
  {
    name: "Lounge Boho",
    excerpt: "Ratán natural, textiles artesanales y cojines de macramé. Ambientes relajados y cálidos para eventos al aire libre.",
    cta: "Boho",
    href: "/servicios/mobiliario/salas-lounge/boho/",
    icon: "heart",
    image: "/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif",
  },
  {
    name: "Lounge Elegante",
    excerpt: "Tonos champagne y oro con acabados metálicos. La opción premium para galas, premiaciones y bodas de lujo.",
    cta: "Elegante",
    href: "/servicios/mobiliario/salas-lounge/elegante/",
    icon: "award",
    image: "/images/mobiliario/sala-lounge-chesterfield-neon-eternally.avif",
  },
];

const faqs = [
  { question: "¿Qué incluye un set completo de sala lounge?", answer: "Cada set estándar incluye sofá de 3 plazas, 2 sillones individuales, mesa de centro y mesa lateral. Dependiendo del estilo, puede incluir accesorios adicionales como cojines decorativos, alfombra de área y elementos ornamentales. También ofrecemos piezas individuales si necesitas armar una configuración personalizada." },
  { question: "¿Cuántas salas lounge necesito para mi evento?", answer: "La recomendación es 1 sala lounge por cada 40-50 invitados para crear zonas de descanso adecuadas. Para un evento de 200 personas, sugerimos 4 a 5 sets distribuidos estratégicamente. En eventos corporativos con networking, puedes necesitar más. Nuestros asesores diseñan la distribución ideal según tu venue." },
  { question: "¿Se pueden personalizar los colores de la tapicería?", answer: "Los sets vienen en configuraciones de color prediseñadas por estilo. Sin embargo, puedes intercambiar cojines, mantas y accesorios entre estilos para personalizar la paleta. Para eventos corporativos, ofrecemos fundas con colores institucionales bajo pedido especial con 3 semanas de anticipación." },
  { question: "¿Las salas lounge funcionan para exteriores?", answer: "El Lounge Boho está diseñado específicamente para exteriores con materiales resistentes a intemperie. Los demás estilos se pueden instalar al aire libre siempre que estén bajo techo (carpa, terraza cubierta o jardín techado). Recomendamos evitar la exposición directa a lluvia o humedad extrema en piezas de terciopelo y cuero." },
  { question: "¿El montaje y la distribución están incluidos?", answer: "Sí, el servicio incluye entrega, montaje profesional con distribución según el plano aprobado, y recolección posterior al evento dentro de CDMX. Nuestro equipo coloca cada pieza, acomoda cojines y accesorios, y verifica que la disposición sea perfecta antes de retirarse. Para Zona Metropolitana, el envío se cotiza por separado." },
  { question: "¿Puedo combinar diferentes estilos de lounge en un mismo evento?", answer: "Absolutamente. Muchos de nuestros clientes crean zonas temáticas combinando estilos: Moderno para el área de networking, Vintage para la zona VIP, y Boho para el jardín exterior. La clave es mantener coherencia en cada zona. Nuestros asesores te guían para que la combinación sea armoniosa y fotogénica." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Salas Lounge para Eventos en CDMX",
    description: "Salas lounge Moderno, Vintage, Boho y Elegante para bodas, corporativos y fiestas. Sets completos con montaje incluido en CDMX.",
    url: "/servicios/mobiliario/salas-lounge/",
    priceRange: { min: 2500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Salas Lounge para Eventos en CDMX"
  description="Renta de salas lounge Moderno, Vintage, Boho y Elegante para eventos en CDMX. Sets completos desde $2,500. Montaje y asesoría incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 60 sets disponibles"
    title='Renta de <span class="highlight">Salas Lounge para Eventos</span> en CDMX'
    subtitle="Sets completos en estilos Moderno, Vintage, Boho y Elegante. Transforma cualquier espacio en una zona VIP de descanso y conversación. Montaje y asesoría de distribución incluidos."
    primaryCTA={{ label: "Cotiza tu sala lounge", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar salas lounge para mi evento` }}
    cards={[
      {
        title: "Cuatro estilos para cada personalidad de evento",
        content: "<strong>Renta de salas lounge para eventos</strong> con la colección más completa de CDMX. Lounge Moderno con cuero sintético premium para corporativos y lanzamientos. Lounge Vintage con terciopelo capitonado para bodas románticas y galas de gala. Lounge Boho con ratán y macramé para celebraciones al aire libre. Lounge Elegante en tonos champagne y oro para premiaciones y bodas de lujo — cada set curado por profesionales del diseño de eventos para garantizar coherencia estética y confort excepcional.",
      },
      {
        title: "Zonas VIP que tus invitados recordarán",
        content: "<strong>Servicio integral de salas lounge</strong> que transforma espacios vacíos en áreas de experiencia. Cada set incluye sofá de 3 plazas, sillones individuales, mesa de centro y accesorios decorativos. Nuestro equipo profesional diseña la distribución según las dimensiones de tu venue, flujo de invitados y zonas de actividad. Entrega puntual, montaje con ajuste de cada cojín y accesorio, y recolección incluida — todo dentro de CDMX sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres crear zonas VIP en tu evento?"
    subheadline="Nuestros asesores diseñan la distribución ideal de lounges para tu venue. Cotiza sin compromiso."
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 estilos de lounge
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestros Estilos de Sala Lounge"
        subtitle="El ambiente perfecto para cada tipo de evento"
        description={[
          "Ofrecemos 4 estilos de sala lounge diseñados por profesionales del interiorismo para eventos. Más de 60 sets completos en inventario permanente, cada uno con una identidad visual definida y materiales de primera calidad.",
          "Desde la sobriedad ejecutiva del Lounge Moderno hasta la calidez artesanal del Lounge Boho, encontrarás el estilo perfecto para crear la atmósfera que tu evento merece."
        ]}
      />

      <div class="grid grid--4">
        {SALAS.map((sala) => (
          <Card
            name={sala.name}
            excerpt={sala.excerpt}
            cta={sala.cta}
            href={sala.href}
            icon={sala.icon}
            image={sala.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LOUNGE MODERNO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="moderno-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Ejecutivo y versátil</span>
          <h2 class="showcase__title" id="moderno-heading">Lounge Moderno</h2>
          <p class="showcase__subtitle">Líneas limpias y materiales premium para eventos corporativos de alto impacto.</p>
          <p class="showcase__text">El <strong>Lounge Moderno</strong> es la elección predilecta para eventos corporativos, lanzamientos de producto, ferias comerciales y conferencias de prensa. Fabricado en <strong>cuero sintético premium</strong> de alta resistencia con estructura interna de madera y espuma de alta densidad. Disponible en 3 configuraciones de color: <strong>blanco minimalista, negro ejecutivo y gris Oxford</strong>.</p>
          <p class="showcase__text">Cada set incluye <strong>sofá de 3 plazas (200 cm), 2 sillones individuales, mesa de centro cromada y mesa lateral</strong>. El diseño geométrico de líneas rectas se integra naturalmente en espacios de convenciones, hoteles y salones empresariales. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para crear una experiencia corporativa integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Cuero Sintético</span>
            <span class="showcase__tag">Blanco</span>
            <span class="showcase__tag">Negro</span>
            <span class="showcase__tag">Gris Oxford</span>
          </div>
          <a href="/servicios/mobiliario/salas-lounge/moderno/" class="btn btn--primary btn--lg">
            Ver Lounge Moderno
          </a>
        </div>
        <div class="showcase__image">
          <img
            src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif"
            alt="Sala lounge moderna con sofá blanco y mesas doradas para evento"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif" alt="Sala lounge boho con sillones de ratán en jardín de evento" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/mesas-cocktail-negras-networking-vista.avif" alt="Mesas cocktail en zona de networking con vista panorámica" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LOUNGE VINTAGE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="vintage-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Sofisticación clásica</span>
          <h2 class="showcase__title" id="vintage-heading">Lounge Vintage</h2>
          <p class="showcase__subtitle">Terciopelo capitonado y detalles dorados que evocan la elegancia de otra época.</p>
          <p class="showcase__text">El <strong>Lounge Vintage</strong> transporta a tus invitados a una era de sofisticación atemporal. Tapizado en <strong>terciopelo capitonado de alta densidad</strong> con botones forrados y patas torneadas en madera con acabado dorado envejecido. Disponible en 4 paletas de color: <strong>esmeralda profundo, borgoña real, azul marino y rosa empolvado</strong>.</p>
          <p class="showcase__text">El set completo incluye <strong>sofá Chesterfield de 3 plazas (210 cm), 2 sillones orejeros, mesa de centro tipo baúl y mesa auxiliar con espejo</strong>. Ideal para bodas románticas en haciendas, galas de premiación y sesiones fotográficas de alta gama. Realza cada detalle con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> en tonos cálidos para crear atmósferas envolventes.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Terciopelo Capitonado</span>
            <span class="showcase__tag">Esmeralda</span>
            <span class="showcase__tag">Borgoña</span>
            <span class="showcase__tag">Azul Marino</span>
          </div>
          <a href="/servicios/mobiliario/salas-lounge/vintage/" class="btn btn--primary btn--lg">
            Ver Lounge Vintage
          </a>
        </div>
        <div class="showcase__image">
          <img
            src="/images/mobiliario/sala-lounge-vintage-tufted-boda.avif"
            alt="Sala lounge vintage con sofá tufted blanco y letreros de boda"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/sala-lounge-chesterfield-neon-forever.avif" alt="Sala lounge elegante con sofás Chesterfield y letrero neon boda" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/sala-lounge-chesterfield-neon-eternally.avif" alt="Sofás Chesterfield blancos con letrero Eternally Yours para boda" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LOUNGE BOHO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="boho-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Natural y artesanal</span>
          <h2 class="showcase__title" id="boho-heading">Lounge Boho</h2>
          <p class="showcase__subtitle">Ratán, macramé y textiles artesanales para ambientes cálidos y relajados.</p>
          <p class="showcase__text">El <strong>Lounge Boho</strong> es la opción ideal para bodas en jardines, fiestas al aire libre y eventos con estética natural. Fabricado en <strong>ratán natural tejido a mano</strong> con cojines de algodón orgánico y accesorios de macramé. Diseñado específicamente para exteriores con <strong>materiales resistentes a intemperie y protección UV</strong>.</p>
          <p class="showcase__text">Cada set incluye <strong>sofá de ratán de 3 plazas, 2 sillones Peacock, mesa de centro de madera reciclada y alfombra de yute</strong>. Los cojines están disponibles en tonos <strong>terracota, crema, mostaza y verde salvia</strong>. Es el complemento perfecto bajo nuestras <a href="/servicios/carpas/">carpas árabes</a> para crear espacios bohemios que enamoran en cada fotografía.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Ratán Natural</span>
            <span class="showcase__tag">Macramé</span>
            <span class="showcase__tag">Apto Exteriores</span>
            <span class="showcase__tag">Eco-friendly</span>
          </div>
          <a href="/servicios/mobiliario/salas-lounge/boho/" class="btn btn--primary btn--lg">
            Ver Lounge Boho
          </a>
        </div>
        <div class="showcase__image">
          <img
            src="/images/mobiliario/sala-lounge-boho-ratan-terracota.avif"
            alt="Sala lounge boho chic con sillones de ratán y cojines terracota"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif" alt="Sala lounge boho con ratán y macramé en interior de venue" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/sala-lounge-boho-ratan-exterior-atardecer.avif" alt="Sala lounge boho con ratán en jardín al atardecer" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LOUNGE ELEGANTE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="elegante-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Lujo y exclusividad</span>
          <h2 class="showcase__title" id="elegante-heading">Lounge Elegante</h2>
          <p class="showcase__subtitle">Tonos champagne, oro y acabados metálicos para las celebraciones más exclusivas.</p>
          <p class="showcase__text">El <strong>Lounge Elegante</strong> es nuestra línea premium, diseñada para galas de premiación, bodas de lujo y eventos de alta sociedad. Tapizado en <strong>tela satinada con hilos metálicos</strong> que capturan la luz de forma espectacular. Estructura reforzada con <strong>acabados en dorado champagne y detalles en espejo</strong>. Disponible en tonos <strong>champagne dorado, plata rosé, marfil perlado y blanco cristal</strong>.</p>
          <p class="showcase__text">El set premium incluye <strong>sofá curvo de 3 plazas (220 cm), 2 sillones tipo trono, mesa de centro espejada, mesa lateral dorada y 4 cojines decorativos con lentejuelas</strong>. Cada pieza es una declaración de estilo que eleva cualquier venue a categoría de lujo. Complementa con nuestros <a href="/servicios/accesorios/">accesorios premium</a> como candelabros dorados y centros de mesa florales.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Champagne Dorado</span>
            <span class="showcase__tag">Plata Rosé</span>
            <span class="showcase__tag">Marfil Perlado</span>
            <span class="showcase__tag">Blanco Cristal</span>
          </div>
          <a href="/servicios/mobiliario/salas-lounge/elegante/" class="btn btn--primary btn--lg">
            Ver Lounge Elegante
          </a>
        </div>
        <div class="showcase__image">
          <img
            src="/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif"
            alt="Sala lounge elegante con sofá moderno y neón Forever & Always"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/sala-lounge-chesterfield-neon-forever.avif" alt="Sala lounge elegante con sofás premium y letrero neon para bodas" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif" alt="Sala lounge boho en jardín como contraste de estilo relajado" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Salas Lounge"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus salas lounge, es natural tener preguntas sobre estilos, personalización, capacidades y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor especializado te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre salas lounge al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de salas lounge para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Sala Lounge"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de salas lounge. Sin compromiso, sin costos ocultos.",
          "Ya sea que necesites 1 set para una zona VIP o 10 sets para un evento masivo, estamos aquí para diseñar la distribución perfecta."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="estiloLounge">
                Estilo de lounge
              </label>
              <select id="estiloLounge" name="estiloLounge" class="form-field__input form-field__select">
                <option value="">Selecciona el estilo de lounge</option>
                <option value="Moderno Blanco">Moderno Blanco</option>
                <option value="Moderno Negro">Moderno Negro</option>
                <option value="Moderno Gris">Moderno Gris Oxford</option>
                <option value="Vintage Esmeralda">Vintage Esmeralda</option>
                <option value="Vintage Borgoña">Vintage Borgoña</option>
                <option value="Vintage Azul Marino">Vintage Azul Marino</option>
                <option value="Boho Natural">Boho Natural</option>
                <option value="Elegante Champagne">Elegante Champagne</option>
                <option value="Elegante Plata Rosé">Elegante Plata Rosé</option>
                <option value="Combinación de estilos">Combinación de estilos</option>
                <option value="Varios estilos">Varios estilos / No estoy seguro</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de invitados, cantidad de zonas lounge, estilo de tu evento, si es interior o exterior..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Diseño de distribución</h3>
            <p class="reserva-card__text">Te ayudamos a planificar la ubicación óptima de cada zona lounge según tu venue.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para tu presupuesto.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const estiloLounge = document.getElementById('estiloLounge').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — Salas Lounge para Eventos*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (estiloLounge) texto += `*Estilo de lounge:* ${estiloLounge}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Crea zonas VIP que tus invitados recordarán"
    subheadline="Más de 60 sets en inventario y 500+ eventos exitosos nos respaldan. Cotiza hoy y recibe asesoría de distribución sin compromiso."
    primaryCTA={{ label: "Cotizar salas lounge", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar salas lounge para mi evento` }}
    variant="accent"
  />
</PageLayout>

