---
/**
 * ─── Lounge Moderno — Página de Producto (Nivel 4) ───
 * Cuero sintético premium para corporativos en blanco,
 * negro y gris Oxford. Sets completos desde $3,500.
 *
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Lounge Moderno
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Moderno" },
];

const faqs = [
  { question: "¿Qué incluye el set completo de Lounge Moderno?", answer: 'Cada set estándar incluye <strong>sofá de 3 plazas (200 cm), 2 sillones individuales, mesa de centro de cristal templado con base cromada y mesa lateral</strong>. Opcionalmente puedes agregar cojines decorativos, alfombra de área y mesas auxiliares adicionales por un cargo extra. También ofrecemos piezas individuales si necesitas una configuración personalizada.' },
  { question: "¿El cuero sintético es resistente a derrames?", answer: 'Sí. Nuestro cuero sintético es <strong>repelente a líquidos y fácil de limpiar</strong>. Derrames de bebidas, manchas de comida y marcas se eliminan con un paño húmedo. Cada pieza se <strong>sanitiza profesionalmente</strong> antes de cada entrega y se inspecciona al detalle para garantizar que llegue en condiciones impecables.' },
  { question: "¿Cuántos sets necesito para mi evento corporativo?", answer: 'La regla general es <strong>1 set por cada 40-50 asistentes</strong> para crear zonas de descanso adecuadas. Para un congreso de 200 personas, sugerimos 4-5 sets. Para networking intensivo, puedes aumentar a 1 por cada 25-30 personas. Nuestros asesores diseñan la distribución ideal según tu venue y formato de evento.' },
  { question: "¿Se puede personalizar con branding corporativo?", answer: 'Sí. Ofrecemos opciones de <strong>personalización con branding</strong>: cojines con logo bordado, fundas con colores institucionales y wraps vinílicos para las mesas. Requiere pedido especial con <strong>3 semanas de anticipación</strong>. Consulta con tu asesor las opciones disponibles para tu marca.' },
  { question: "¿Puedo combinar Lounge Moderno con otros estilos?", answer: 'Absolutamente. Muchos clientes crean <strong>zonas temáticas</strong>: Moderno para networking, Elegante para VIP y Vintage para recepción. La clave es mantener coherencia en cada zona. También puedes combinar con nuestras <a href="/servicios/mobiliario/sillas/">sillas de diseño</a> y <a href="/servicios/mobiliario/mesas/">mesas</a> para un montaje integral.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos reservar con <strong>2 a 3 semanas de anticipación</strong> para garantizar disponibilidad del color deseado. En temporada alta (octubre a diciembre), la demanda se duplica y sugerimos apartar con <strong>1 mes de anticipación</strong>. Un anticipo del 30% confirma tu reserva.' },
];

const specs = [
  { label: "Material", value: "Cuero sintético premium + espuma alta densidad" },
  { label: "Estructura", value: "Madera de pino reforzada" },
  { label: "Configuraciones", value: "Blanco minimalista, Negro ejecutivo, Gris Oxford" },
  { label: "Set incluye", value: "Sofá 3 plazas + 2 sillones + mesa centro + mesa lateral" },
  { label: "Sofá", value: "200 cm largo × 85 cm profundidad × 75 cm alto" },
  { label: "Sillones", value: "85 cm ancho × 85 cm profundidad × 75 cm alto" },
  { label: "Mesa centro", value: "Cristal templado + base cromada (80 × 80 cm)" },
  { label: "Capacidad", value: "Set para 5-7 personas sentadas" },
  { label: "Resistencia", value: "120 kg por asiento" },
  { label: "Mantenimiento", value: "Limpieza y sanitización incluida pre-evento" },
];

const sidebarNav = [
  { name: "Lounge Moderno", href: null, active: true },
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
];

const sidebarRelated = [
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas de Diseño", href: "/servicios/mobiliario/sillas/" },
  { name: "Audiovisual", href: "/servicios/audiovisual/" },
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Roberto Castañeda", text: "Rentamos 6 sets de lounge Moderno blanco para el lanzamiento de nuestra marca en Polanco. El equipo montó todo en 2 horas, la distribución quedó perfecta para el networking y los asistentes no paraban de elogiar la zona VIP. Excelente inversión.", rating: 5, date: "2025-11-15" },
  { author: "Diana Herrera", text: "Para nuestra conferencia anual en Centro Citibanamex necesitábamos lounge negro ejecutivo para las áreas de prensa. El resultado fue impecable — el cuero sintético se ve premium, las mesas cromadas combinaron con nuestra identidad y la limpieza post-evento fue impecable.", rating: 5, date: "2025-09-28" },
  { author: "Alejandro Torres", text: "Usamos lounge gris Oxford en 4 stands de nuestra feria comercial. La versatilidad del gris permitió que cada stand personalizara con su branding sin conflicto visual. El montaje fue profesional y puntual. Repetiremos definitivamente.", rating: 5, date: "2025-08-10" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Lounge Moderno para Eventos en CDMX",
    description: "Salas lounge Moderno en cuero sintético premium blanco, negro y gris Oxford para corporativos y lanzamientos en CDMX. Sets completos desde $3,500. Montaje incluido.",
    url: "/servicios/mobiliario/salas-lounge/moderno/",
    priceRange: { min: 3500, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 142,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Moderno", url: "/servicios/mobiliario/salas-lounge/moderno/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Lounge Moderno para Eventos en CDMX"
  description="Renta de salas lounge Moderno en cuero sintético premium blanco, negro y gris Oxford para corporativos y lanzamientos en CDMX. Sets completos desde $3,500. Montaje incluido."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El favorito para eventos corporativos"
    title='Renta de <span class="highlight">Lounge Moderno</span> para Eventos en CDMX'
    subtitle="Sets completos de sala lounge Moderno en cuero sintético premium: blanco minimalista, negro ejecutivo y gris Oxford. Sofá de 3 plazas, sillones individuales, mesa de centro cromada y mesa lateral. Montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tu lounge Moderno", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar lounge Moderno para mi evento` }}
    cards={[
      {
        title: "Cuero sintético premium en 3 configuraciones ejecutivas",
        content: "<strong>Renta de lounge Moderno</strong> con la línea más solicitada para eventos corporativos en CDMX. Tapizado en cuero sintético de alta resistencia con estructura interna de madera y espuma de alta densidad. Disponible en 3 configuraciones: <strong>blanco minimalista</strong> para lanzamientos de producto, <strong>negro ejecutivo</strong> para conferencias de prensa y <strong>gris Oxford</strong> para ferias y convenciones. Diseño de líneas rectas geométricas que se integra naturalmente en cualquier espacio empresarial.",
      },
      {
        title: "Sets completos con montaje profesional y diseño de distribución",
        content: "<strong>Servicio integral de lounge Moderno</strong> con set completo incluido: sofá de 3 plazas (200 cm), 2 sillones individuales, mesa de centro cromada y mesa lateral. Nuestro equipo profesional diseña la distribución óptima según las dimensiones de tu venue y flujo de asistentes. Entrega puntual, montaje profesional con ajuste de cada pieza y recolección incluida — todo dentro de CDMX sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas lounge Moderno para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con configuración, color y precio por set"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Salas Lounge para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas lounge Moderno para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar lounge Moderno para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/><path d="M5 21v-2"/><path d="M19 21v-2"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Lounge Moderno</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Lounge Moderno Blanco -->
          <section class="section section--alt" aria-labelledby="blanco-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Lanzamientos y showrooms</span>
                <h2 class="showcase__title" id="blanco-heading">Lounge Moderno Blanco</h2>
                <p class="showcase__subtitle">Cuero sintético blanco minimalista para lanzamientos de producto, showrooms y eventos de moda.</p>
                <p class="showcase__text">El <strong>lounge Moderno blanco</strong> es la configuración estrella para lanzamientos de producto y showrooms en CDMX. Su tapizado en cuero sintético blanco minimalista refleja la luz y <strong>amplía visualmente el espacio</strong>, creando un ambiente limpio y sofisticado que permite que tu marca sea la protagonista. La estructura de madera de pino reforzada con espuma de alta densidad garantiza comodidad durante sesiones prolongadas de networking.</p>
                <p class="showcase__text">Ideal para combinarse con <a href="/servicios/audiovisual/">audiovisual como pantallas LED</a> y stands de marca. El blanco funciona como lienzo neutro que se adapta a cualquier identidad corporativa. Cada set incluye <strong>sofá de 3 plazas, 2 sillones individuales, mesa de centro cromada y mesa lateral</strong>. El cuero sintético es repelente a líquidos, lo que lo hace perfecto para eventos con servicio de bebidas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Blanco Minimalista</span>
                  <span class="showcase__tag">Cuero Sintético</span>
                  <span class="showcase__tag">Lanzamientos</span>
                  <span class="showcase__tag">Showrooms</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Lounge Blanco
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Sala lounge moderno blanco dorado para evento" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-gris-oxford.avif" alt="Sala lounge moderno gris oxford corporativo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-negro-evento.avif" alt="Sala lounge moderno negro para evento premium" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Lounge Moderno Negro -->
          <section class="section section--alt" aria-labelledby="negro-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Conferencias y galas</span>
                <h2 class="showcase__title" id="negro-heading">Lounge Moderno Negro</h2>
                <p class="showcase__subtitle">Negro ejecutivo que transmite seriedad y poder para conferencias de prensa y galas de premiación.</p>
                <p class="showcase__text">El <strong>lounge Moderno negro ejecutivo</strong> es la elección predilecta para eventos que demandan presencia y autoridad. El cuero sintético negro transmite <strong>seriedad y poder</strong> — la combinación perfecta para conferencias de prensa, presentaciones corporativas y galas de premiación. Su acabado mate de alta calidad resiste el uso intensivo sin perder elegancia durante todo el evento.</p>
                <p class="showcase__text">El negro combina con <strong>prácticamente cualquier identidad corporativa</strong>, lo que lo convierte en la opción más segura para eventos multiempresa. Complementa con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a> para crear ambientes dramáticos con uplighting. Cada pieza se inspecciona y sanitiza antes de la entrega para garantizar un aspecto impecable que esté a la altura de tu marca.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Negro Ejecutivo</span>
                  <span class="showcase__tag">Conferencias</span>
                  <span class="showcase__tag">Galas</span>
                  <span class="showcase__tag">Corporativos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Lounge Negro
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-moderno-negro-evento.avif" alt="Sala lounge moderno negro para evento premium" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Sala lounge moderno blanco dorado boda lujo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-kit-networking.avif" alt="Kit sala lounge moderno para networking" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Lounge Moderno Gris Oxford -->
          <section class="section section--alt" aria-labelledby="gris-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ferias y convenciones</span>
                <h2 class="showcase__title" id="gris-heading">Lounge Moderno Gris Oxford</h2>
                <p class="showcase__subtitle">El tono intermedio gris Oxford aporta elegancia discreta sin competir con la señalización corporativa.</p>
                <p class="showcase__text">El <strong>lounge Moderno gris Oxford</strong> es el equilibrio perfecto entre la neutralidad del blanco y la formalidad del negro. Su tono intermedio aporta <strong>elegancia discreta sin competir con la señalización corporativa</strong> de tu stand o zona de exhibición. Perfecto para ferias comerciales, convenciones y áreas VIP donde la señalética y los materiales de marca deben ser el centro de atención.</p>
                <p class="showcase__text">El gris Oxford es especialmente popular para <strong>stands de exposición, zonas de networking y áreas de descanso</strong> en eventos de gran formato. Su versatilidad permite que cada empresa personalice su espacio con branding propio sin conflicto visual. Combina con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para crear espacios corporativos completos en exterior.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Gris Oxford</span>
                  <span class="showcase__tag">Ferias</span>
                  <span class="showcase__tag">Convenciones</span>
                  <span class="showcase__tag">Networking</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Lounge Gris Oxford
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-moderno-gris-oxford.avif" alt="Sala lounge moderno gris oxford evento corporativo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-negro-evento.avif" alt="Sala lounge moderno negro evento premium CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Sala lounge moderno blanco dorado evento" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Networking Moderno -->
          <section class="section section--alt" aria-labelledby="networking-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Espacios de conexión</span>
                <h2 class="showcase__title" id="networking-heading">Kit Networking Moderno</h2>
                <p class="showcase__subtitle">Configuración especial para zonas de networking: sofás enfrentados con mesa de centro intermedia.</p>
                <p class="showcase__text">El <strong>Kit Networking Moderno</strong> es una configuración especial diseñada para fomentar la conversación y las conexiones profesionales. Consiste en <strong>2 sofás de 3 plazas enfrentados con mesa de centro intermedia</strong>, creando un espacio íntimo para reuniones informales dentro de eventos de gran formato. Ideal para congresos, workshops y eventos de teambuilding donde el objetivo principal es la interacción entre asistentes.</p>
                <p class="showcase__text">Nuestro equipo diseña la <strong>distribución profesional</strong> según las dimensiones de tu venue y el número de zonas de networking requeridas. Cada kit incluye montaje con ajuste preciso de distancias para garantizar comodidad y fluidez en la conversación. Disponible en los 3 colores: blanco, negro y gris Oxford. Combina con <a href="/servicios/mobiliario/mesas/">mesas auxiliares</a> para crear estaciones de café o documentación.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Networking</span>
