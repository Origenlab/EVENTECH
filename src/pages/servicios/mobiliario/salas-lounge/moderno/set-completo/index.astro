---
/**
 * ─── Lounge Moderno Set Completo — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Moderno > Set Completo
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { label: "Set Completo" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Set completo lounge moderno con sofá blanco y mesas doradas para evento" },
  { src: "/images/mobiliario/lounge-moderno-01.avif", alt: "Lounge moderno completo en evento corporativo premium CDMX" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif", alt: "Set lounge moderno en salón de eventos CDMX" },
  { src: "/images/mobiliario/mesas-cocktail-negras-networking-vista.avif", alt: "Zona lounge moderna con mesas y sofás en networking corporativo" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Set completo lounge moderno en boda contemporánea" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Mobiliario moderno en evento gala CDMX" },
];

const faqs = [
  {
    question: "¿Qué incluye el set completo de lounge moderno?",
    answer: "El <strong>set completo lounge moderno</strong> incluye sofá de 3 plazas en cuero sintético premium (200 cm), 2 sillones individuales, mesa de centro cromada y mesa lateral. Todo en acabado blanco, negro o gris Oxford según tu elección. El set está diseñado para crear una zona VIP funcional para 5 a 8 personas."
  },
  {
    question: "¿Para qué tipo de eventos es ideal el lounge moderno?",
    answer: "El lounge moderno es perfecto para <strong>eventos corporativos</strong>, lanzamientos de producto, ferias comerciales, conferencias y cocteles empresariales. Sus líneas limpias y materiales premium en blanco, negro y gris crean un ambiente ejecutivo y sofisticado que combina con cualquier venue contemporáneo."
  },
  {
    question: "¿En qué colores está disponible el set completo moderno?",
    answer: "El set completo lounge moderno está disponible en tres configuraciones: <strong>blanco minimalista</strong> para eventos con paleta clara, <strong>negro ejecutivo</strong> para galas y corporativos de alto perfil, y <strong>gris Oxford</strong> para un look neutro y versátil. Las mesas de centro y laterales vienen en acabado cromado o dorado según el color del sofá."
  },
  {
    question: "¿Cuántas personas acomoda el set completo?",
    answer: "El set completo está diseñado para <strong>5 a 8 personas</strong> cómodamente. El sofá de 3 plazas más los 2 sillones individuales crean un área de socialización perfecta. Para zonas de mayor capacidad, recomendamos configuraciones de 2 o 3 sets conectados con mesas adicionales."
  },
  {
    question: "¿El montaje del set completo está incluido?",
    answer: "Sí, el <strong>servicio de montaje profesional</strong> está incluido en la renta. Nuestro equipo entrega, arma y acomoda cada pieza según el plano aprobado de tu venue. Al finalizar el evento, recogemos todo sin que te preocupes por nada. Servicio disponible en toda la Ciudad de México."
  },
];

const specs = [
  { label: "Contenido del set", value: "Sofá 3 plazas + 2 sillones individuales + mesa centro + mesa lateral" },
  { label: "Material tapicería", value: "Cuero sintético premium de alta resistencia" },
  { label: "Colores disponibles", value: "Blanco Minimalista / Negro Ejecutivo / Gris Oxford" },
  { label: "Dimensiones sofá", value: "200 cm largo × 85 cm profundo × 75 cm alto" },
  { label: "Capacidad", value: "5 a 8 personas por set" },
  { label: "Resistencia", value: "120 kg por asiento" },
  { label: "Mesa centro", value: "Acabado cromado o dorado, 100 × 60 cm" },
  { label: "Estilo", value: "Moderno contemporáneo — líneas rectas, geométrico" },
  { label: "Precio", value: "Desde $3,500 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje profesional y recolección en CDMX" },
];

const reviews = [
  { author: "Marcela Sánchez", text: "El set completo moderno transformó nuestra sala de networking en un espacio premium. Líneas perfectas, materiales impecables. Los ejecutivos internacionales quedaron impresionados.", rating: 5, date: "2025-10-18" },
  { author: "Rodrigo Fuentes", text: "Rentamos 4 sets completos para el lanzamiento de producto. La calidad del cuero sintético y el acabado cromado de las mesas hicieron que el venue se viera de lujo.", rating: 5, date: "2025-09-22" },
  { author: "Daniela Herrera", text: "Perfectos para la zona cóctel de nuestra boda contemporánea. El blanco combinó perfecto con nuestra paleta. Montaje rápido y profesional.", rating: 5, date: "2025-11-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Completo Lounge Moderno para Eventos en CDMX",
    description: "Set completo lounge moderno: sofá 3 plazas + 2 sillones + mesas. Cuero sintético premium en blanco, negro y gris. Montaje incluido. Desde $3,500.",
    url: "/servicios/mobiliario/salas-lounge/moderno/set-completo/",
    priceRange: { min: 3500, max: 7000 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Moderno", url: "/servicios/mobiliario/salas-lounge/moderno/" },
    { name: "Set Completo", url: "/servicios/mobiliario/salas-lounge/moderno/set-completo/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Set Completo", href: null, active: true },
  { name: "Sofá Individual", href: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/" },
  { name: "Mesa Centro", href: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/" },
];

const sidebarRelated = [
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
];
---

<PageLayout
  title="Renta Set Completo Lounge Moderno CDMX"
  description="Renta set completo lounge moderno en CDMX. Sofá 3 plazas + 2 sillones + mesas. Cuero sintético premium en blanco, negro y gris. Montaje incluido. Desde $3,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="Set completo — zona VIP para 5 a 8 personas"
    title='Set Completo <span class="highlight">Lounge Moderno</span> — Renta en CDMX'
    subtitle="Sofá de 3 plazas + 2 sillones individuales + mesa de centro + mesa lateral. Cuero sintético premium en blanco, negro y gris Oxford. El set completo para crear zonas VIP ejecutivas en corporativos, lanzamientos y bodas contemporáneas."
    primaryCTA={{ label: "Cotizar set lounge moderno", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge moderno para mi evento` }}
    cards={[
      {
        title: "El set ejecutivo más solicitado para eventos corporativos",
        content: "El <strong>set completo lounge moderno</strong> es la elección número uno para eventos donde la imagen profesional es prioridad. El cuero sintético de alta resistencia mantiene su acabado perfecto incluso con uso intensivo. Las líneas geométricas y rectas crean un espacio visualmente coherente que eleva cualquier venue. Disponible en blanco minimalista, negro ejecutivo y gris Oxford.",
      },
      {
        title: "Todo incluido para tu zona VIP — entrega y montaje sin costo",
        content: "Cada set incluye el <strong>sofá de 200 cm, 2 sillones individuales, mesa de centro cromada y mesa lateral</strong> — todo lo necesario para crear una zona de socialización completa. El servicio incluye entrega puntual, montaje profesional según tu layout y recolección al finalizar el evento. Sin costos ocultos, sin sorpresas el día del evento.",
      },
    ]}
  />

  <CTABanner
    headline="Set completo lounge moderno — la zona VIP que tu evento corporativo necesita"
    subheadline="Cuero sintético premium · Montaje profesional · Entrega en CDMX incluida"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set completo lounge moderno para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge moderno`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            WhatsApp
          </a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Completo Lounge Moderno en Eventos Reales</h2>
            <p class="section__subtitle">Corporativos, lanzamientos de producto y bodas contemporáneas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Completo Lounge Moderno</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué elegir el set completo lounge moderno?"
    headingId="descripcion-heading"
    badge="Ejecutivo y versátil — ideal para corporativos y bodas modernas"
    tags={["Lounge Moderno", "Corporativos", "Bodas Contemporáneas", "Set Completo"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>set completo lounge moderno</strong> es la solución más eficiente para crear zonas VIP con impacto visual inmediato. A diferencia de armar piezas por separado, el set viene curado para que todo combine perfectamente — el sofá, los sillones y las mesas tienen una coherencia estética que no se puede lograr mezclando piezas de diferentes estilos.</p>
      <p class="showcase__text">El cuero sintético premium resiste el uso intensivo sin perder su apariencia impecable. La estructura interna de madera maciza garantiza estabilidad y confort durante eventos de 8 a 12 horas. Cada pieza se limpia e inspecciona antes de cada entrega para asegurar que llegue en condiciones perfectas.</p>
      <p class="showcase__text">En <strong>CDMX</strong> hemos instalado este set en hoteles de cinco estrellas, salas de convenciones y haciendas contemporáneas. El resultado siempre es el mismo: una zona que invita a quedarse, a conversar y a crear las conexiones que hacen exitoso cualquier evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Set completo lounge moderno blanco en evento premium CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-moderno-01.avif" alt="Lounge moderno en salón corporativo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-cocktail-negras-networking-vista.avif" alt="Zona lounge moderna en networking empresarial" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Completo Lounge Moderno</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Completo Lounge Moderno"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre el set completo lounge moderno para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el set completo lounge moderno`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sets, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge moderno y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Set completo lounge moderno para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set completo lounge moderno para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Set Completo Lounge Moderno"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={[
          "Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso.",
        ]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Lanzamiento de Producto">Lanzamiento de Producto</option>
                <option value="Gala / Cena Formal">Gala / Cena Formal</option>
                <option value="XV Años">XV Años</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sets, color preferido (blanco/negro/gris), venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
