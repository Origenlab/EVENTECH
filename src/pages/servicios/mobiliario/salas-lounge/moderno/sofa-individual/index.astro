---
/**
 * ─── Sofá Individual Lounge Moderno — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Moderno > Sofá Individual
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { label: "Sofá Individual" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Sofá individual lounge moderno blanco en evento corporativo CDMX" },
  { src: "/images/mobiliario/lounge-moderno-01.avif", alt: "Sofá moderno individual en zona VIP de evento premium" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Sillón individual moderno en boda contemporánea CDMX" },
  { src: "/images/mobiliario/mesas-cocktail-negras-networking-vista.avif", alt: "Sofá individual moderno en área de networking empresarial" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif", alt: "Sofá lounge moderno en jardín de eventos" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Zona lounge moderna con sofá individual en gala CDMX" },
];

const faqs = [
  {
    question: "¿Para qué sirve rentar sólo el sofá individual moderno?",
    answer: "El <strong>sofá individual moderno</strong> es ideal cuando necesitas completar una zona lounge ya existente, crear puntos de descanso dispersos por el venue, o cuando el espacio no permite un set completo. Es perfecto para lobbies de hotel, áreas de registro en corporativos y zonas de espera en eventos con flujo constante de personas."
  },
  {
    question: "¿Cuántas personas sienta el sofá individual moderno?",
    answer: "El sofá individual moderno tiene capacidad para <strong>2 personas</strong> con total comodidad. A diferencia del sofá de 3 plazas del set completo, sus dimensiones compactas (140 cm de largo) lo hacen ideal para espacios más reducidos o para crear configuraciones más íntimas y conversacionales."
  },
  {
    question: "¿En qué colores está disponible?",
    answer: "El sofá individual moderno está disponible en <strong>blanco minimalista</strong>, <strong>negro ejecutivo</strong> y <strong>gris Oxford</strong>. El acabado en cuero sintético premium mantiene su apariencia impecable durante todo el evento. Para zonas de cocktail, el blanco es el más solicitado; para eventos nocturnos y galas, el negro."
  },
  {
    question: "¿Puedo rentar el sofá individual sin el set completo?",
    answer: "Sí, el sofá individual moderno se renta de forma independiente <strong>desde $1,500</strong>. Es una excelente opción para complementar mesas cocktail, sillas Tiffany u otro mobiliario que ya tengas reservado. También lo rentamos en configuraciones de 2, 4 o más unidades para crear zonas lounge personalizadas."
  },
  {
    question: "¿Qué diferencia hay entre el sofá individual y el set completo?",
    answer: "El <strong>set completo</strong> incluye sofá de 3 plazas + 2 sillones + mesas de centro y lateral, diseñado como una zona lounge autónoma. El <strong>sofá individual</strong> es una pieza única de 2 plazas, más compacta y flexible, ideal para complementar otros elementos o para espacios donde no cabe el set completo. El precio del individual es significativamente menor."
  },
];

const specs = [
  { label: "Tipo de pieza", value: "Sofá individual 2 plazas" },
  { label: "Material tapicería", value: "Cuero sintético premium de alta resistencia" },
  { label: "Colores disponibles", value: "Blanco Minimalista / Negro Ejecutivo / Gris Oxford" },
  { label: "Dimensiones", value: "140 cm largo × 80 cm profundo × 72 cm alto" },
  { label: "Capacidad", value: "2 personas cómodamente" },
  { label: "Resistencia", value: "120 kg por asiento" },
  { label: "Estilo", value: "Moderno contemporáneo — líneas rectas, geométrico" },
  { label: "Precio", value: "Desde $1,500 por pieza / evento" },
  { label: "Incluye", value: "Entrega, montaje y recolección en CDMX" },
  { label: "Compatible con", value: "Mesas de centro, mesa lateral, set completo lounge moderno" },
];

const reviews = [
  { author: "Alejandro Vega", text: "Rentamos 6 sofás individuales para dispersarlos en el lobby de la conferencia. Cada uno con su mesa lateral. El resultado fue una zona de networking muy fluida y visualmente coherente.", rating: 5, date: "2025-10-08" },
  { author: "Sofía Ramírez", text: "Lo usamos para la zona de firma de documentos en nuestra boda. El sofá blanco individual con flores encima quedó perfecto en las fotos. Muy cómodo y de excelente calidad.", rating: 5, date: "2025-11-15" },
  { author: "Carlos Mendez", text: "Para el lanzamiento de la colección necesitábamos piezas individuales que pudiéramos reconfigurar durante el evento. Estos sofás son ligeros, elegantes y fáciles de mover. Exactamente lo que buscábamos.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Sofá Individual Lounge Moderno para Eventos CDMX",
    description: "Sofá individual lounge moderno 2 plazas en cuero sintético premium. Blanco, negro y gris. Ideal para zonas VIP y networking. Desde $1,500.",
    url: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/",
    priceRange: { min: 1500, max: 3000 },
    reviews,
    ratingValue: 5,
    reviewCount: 22,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Moderno", url: "/servicios/mobiliario/salas-lounge/moderno/" },
    { name: "Sofá Individual", url: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/moderno/set-completo/" },
  { name: "Sofá Individual", href: null, active: true },
  { name: "Mesa Centro", href: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/" },
];

const sidebarRelated = [
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
];
---

<PageLayout
  title="Renta Sofá Individual Lounge Moderno CDMX"
  description="Renta sofá individual lounge moderno en CDMX. 2 plazas en cuero sintético premium. Blanco, negro y gris. Montaje incluido. Desde $1,500 por pieza."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="Pieza individual — 2 plazas · flexible · fácil de configurar"
    title='Sofá Individual <span class="highlight">Lounge Moderno</span> — Renta en CDMX'
    subtitle="Sofá de 2 plazas en cuero sintético premium. Diseño moderno con líneas rectas y geométricas. Disponible en blanco, negro y gris Oxford. Ideal para completar zonas lounge, crear puntos de descanso o configurar áreas de networking flexibles."
    primaryCTA={{ label: "Cotizar sofá individual", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá individual lounge moderno para mi evento` }}
    cards={[
      {
        title: "Flexibilidad total — renta por pieza, configura a tu medida",
        content: "El <strong>sofá individual lounge moderno</strong> es la pieza más versátil de la colección moderna. Sus 140 cm de largo permiten ubicarlo en espacios donde el set completo no cabe. Puedes rentar una, cuatro o diez unidades y crear la configuración exacta que tu venue requiere. Cuero sintético de alta resistencia que mantiene su apariencia impecable durante eventos de larga duración.",
      },
      {
        title: "Entrega, montaje y recolección incluidos en CDMX",
        content: "Cada sofá individual llega <strong>limpio, inspeccionado y listo para usarse</strong>. Nuestro equipo lo acomoda según el plano del venue y lo recoge al finalizar el evento. Compatible con las mesas de centro y laterales de la colección moderna — renta solo el sofá o combínalo con otros elementos para armar tu zona lounge perfecta.",
      },
    ]}
  />

  <CTABanner
    headline="El sofá moderno que se adapta a cualquier espacio — renta por pieza"
    subheadline="Cuero sintético premium · Blanco, negro o gris · Entrega y montaje en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Sofá individual lounge moderno para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá individual lounge moderno`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Sofá Individual Lounge Moderno en Eventos</h2>
            <p class="section__subtitle">Corporativos, cocteles y bodas contemporáneas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Sofá Individual Lounge Moderno</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el sofá individual moderno es la pieza más flexible del catálogo"
    headingId="descripcion-heading"
    badge="Compacto, versátil y de apariencia premium"
    tags={["Sofá Individual", "Lounge Moderno", "Corporativos CDMX", "Zona Networking"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">A diferencia del set completo, el <strong>sofá individual lounge moderno</strong> te da control total sobre la configuración de tu espacio. Puedes crear islas de conversación de 2 personas, alinear varios sofás para una zona más amplia, o dispersarlos por el venue para crear puntos de descanso en eventos de gran formato.</p>
      <p class="showcase__text">El cuero sintético de alta resistencia soporta el uso intensivo sin decolorarse ni rasgarse. La estructura interna de madera maciza y metal garantiza que la pieza mantenga su forma y firmeza durante toda la jornada del evento. Cada unidad se inspecciona y limpia antes de la entrega.</p>
      <p class="showcase__text">En eventos corporativos en <strong>CDMX</strong>, lo usamos frecuentemente en zonas de registro, áreas de firma, lobbies y pasillos VIP. En bodas, crea puntos fotogénicos que invitan a los invitados a tomarse un descanso sin perder el estilo del evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Sofá individual lounge moderno en evento corporativo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-moderno-01.avif" alt="Sofá individual moderno negro en zona VIP" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-cocktail-negras-networking-vista.avif" alt="Configuración de sofás individuales en networking" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Sofá Individual Lounge Moderno</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Sofá Individual Lounge Moderno"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre el sofá individual lounge moderno para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el sofá individual lounge moderno`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de piezas, color, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge moderno y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Sofá individual lounge moderno para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el sofá individual lounge moderno`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Sofá Individual Lounge Moderno"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Lanzamiento de Producto">Lanzamiento de Producto</option>
                <option value="Gala / Cena Formal">Gala / Cena Formal</option>
                <option value="XV Años">XV Años</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sofás, color preferido (blanco/negro/gris), venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar por WhatsApp
          </button>
        </form>
        <aside class="reserva-sidebar">
