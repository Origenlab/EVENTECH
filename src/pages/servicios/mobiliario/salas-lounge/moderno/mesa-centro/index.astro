---
/**
 * ─── Mesa Centro Lounge Moderno — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Moderno > Mesa Centro
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { label: "Mesa Centro" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesas-cocktail-negras-networking-vista.avif", alt: "Mesa centro moderna cromada en zona lounge de evento corporativo CDMX" },
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Mesa de centro moderna en set lounge blanco y dorado" },
  { src: "/images/mobiliario/lounge-moderno-01.avif", alt: "Mesa centro cromada en lounge premium de evento" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Mesa de centro moderna en zona VIP de boda" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif", alt: "Mesa centro en zona lounge de jardín para evento" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Mesa de centro moderna en salón de gala CDMX" },
];

const faqs = [
  {
    question: "¿Cuáles son las dimensiones de la mesa de centro moderna?",
    answer: "La <strong>mesa de centro moderna</strong> mide 100 × 60 cm de superficie y 45 cm de altura — la altura estándar para zonas lounge que permite colocar bebidas y decoración sin interrumpir la conversación. Disponible en acabado cromado espejo o dorado según el color del sofá que acompañe."
  },
  {
    question: "¿La mesa de centro incluye montaje y recolección?",
    answer: "Sí. La renta de la <strong>mesa de centro moderna</strong> incluye entrega, colocación y recolección sin costo adicional. Nuestro equipo la posiciona según el plano del venue para que quede perfectamente alineada con el sofá o sillones. No necesitas preocuparte por armado ni desmontaje."
  },
  {
    question: "¿Se puede rentar la mesa de centro sin el sofá?",
    answer: "Sí, la mesa de centro se renta de forma independiente <strong>desde $500</strong>. Es perfecta para completar sets de lounge que ya tengas en otro lugar, para zonas de exhibición de productos, o para crear estaciones decorativas en eventos. También combina perfectamente con sillas Tiffany y sillas Ghost."
  },
  {
    question: "¿Qué acabado tiene la mesa de centro moderna?",
    answer: "La mesa de centro moderna tiene superficie de <strong>vidrio templado transparente</strong> y estructura metálica disponible en <strong>cromado espejo</strong> o <strong>dorado champagne</strong>. El vidrio templado de 8mm es resistente a impactos y fácil de limpiar. El cromado refleja el ambiente y hace que el espacio parezca más luminoso y amplio."
  },
  {
    question: "¿Qué diferencia hay entre mesa de centro y mesa lateral?",
    answer: "La <strong>mesa de centro</strong> (100×60 cm, 45 cm alto) se coloca en el espacio central de la zona lounge, accesible desde el sofá y los sillones. La <strong>mesa lateral</strong> (45×45 cm, 55 cm alto) se ubica al lado de un sillón individual para colocar una copa o teléfono sin levantarse. Ambas se complementan en el set completo."
  },
];

const specs = [
  { label: "Tipo de pieza", value: "Mesa de centro lounge" },
  { label: "Superficie", value: "Vidrio templado transparente 8mm" },
  { label: "Estructura", value: "Metal — cromado espejo o dorado champagne" },
  { label: "Dimensiones", value: "100 cm largo × 60 cm ancho × 45 cm alto" },
  { label: "Peso máximo", value: "30 kg sobre la superficie" },
  { label: "Estilo", value: "Moderno contemporáneo — líneas geométricas" },
  { label: "Acabados disponibles", value: "Cromado Espejo / Dorado Champagne" },
  { label: "Precio", value: "Desde $500 por pieza / evento" },
  { label: "Incluye", value: "Entrega, colocación y recolección en CDMX" },
  { label: "Compatible con", value: "Set completo moderno, sofá individual, sillones individuales" },
];

const reviews = [
  { author: "Valentina Cruz", text: "La mesa de centro cromada fue el complemento perfecto para nuestros sofás blancos. El vidrio templado reflejó las velas de la mesa y creó un efecto visual espectacular durante la cena.", rating: 5, date: "2025-10-22" },
  { author: "Miguel Torres", text: "Rentamos 8 mesas de centro para el área de expo. Cada una con su set de sofás. El acabado cromado aguantó perfectamente el movimiento constante de bebidas y materiales.", rating: 5, date: "2025-09-14" },
  { author: "Adriana López", text: "Buen precio para la calidad que ofrece. El vidrio no se raya y la estructura cromada se mantiene impecable. La entrega fue puntual y el equipo de montaje muy profesional.", rating: 5, date: "2025-11-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Centro Lounge Moderno para Eventos CDMX",
    description: "Mesa de centro lounge moderna con vidrio templado y estructura cromada o dorada. Compatible con sofás y sillones modernos. Desde $500.",
    url: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/",
    priceRange: { min: 500, max: 1500 },
    reviews,
    ratingValue: 5,
    reviewCount: 18,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Moderno", url: "/servicios/mobiliario/salas-lounge/moderno/" },
    { name: "Mesa Centro", url: "/servicios/mobiliario/salas-lounge/moderno/mesa-centro/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Set Completo", href: "/servicios/mobiliario/salas-lounge/moderno/set-completo/" },
  { name: "Sofá Individual", href: "/servicios/mobiliario/salas-lounge/moderno/sofa-individual/" },
  { name: "Mesa Centro", href: null, active: true },
];

const sidebarRelated = [
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
];
---

<PageLayout
  title="Renta Mesa Centro Lounge Moderno CDMX"
  description="Renta mesa de centro lounge moderna en CDMX. Vidrio templado + estructura cromada o dorada. Compatible con sofás modernos. Desde $500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="Mesa de centro — vidrio templado · cromado o dorado · desde $500"
    title='Mesa Centro <span class="highlight">Lounge Moderno</span> — Renta en CDMX'
    subtitle="Mesa de centro con superficie de vidrio templado 8mm y estructura metálica en acabado cromado espejo o dorado champagne. Dimensiones 100×60 cm ideales para zonas lounge. Complemento perfecto para sofás y sillones de la colección moderna."
    primaryCTA={{ label: "Cotizar mesa de centro", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la mesa de centro lounge moderna para mi evento` }}
    cards={[
      {
        title: "Diseño que complementa sin competir — vidrio + metal premium",
        content: "La <strong>mesa de centro lounge moderna</strong> está diseñada para ser el ancla visual de la zona lounge sin robarle protagonismo al sofá. El vidrio templado transparente permite ver el piso y crea la ilusión de más espacio. La estructura cromada o dorada aporta el toque metálico que conecta con la estética moderna del resto del set.",
      },
      {
        title: "Renta independiente — complementa cualquier zona lounge",
        content: "No necesitas rentar el set completo para aprovechar esta mesa. Funciona perfectamente como <strong>complemento de sofás ya existentes</strong>, como estación de bebidas en áreas de cocktail, o como elemento decorativo para zonas de exhibición. Desde $500 por pieza con entrega, colocación y recolección incluidas en CDMX.",
      },
    ]}
  />

  <CTABanner
    headline="Mesa de centro moderna — el detalle que hace coherente tu zona lounge"
    subheadline="Vidrio templado · Cromado o dorado · Desde $500 con montaje incluido"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa de centro lounge moderna para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la mesa de centro lounge moderna`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Centro Lounge Moderno en Eventos</h2>
            <p class="section__subtitle">Corporativos, cocteles y bodas contemporáneas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Centro Lounge Moderno</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué la mesa de centro define la funcionalidad del lounge"
    headingId="descripcion-heading"
    badge="El complemento que une el set — discreta pero indispensable"
    tags={["Mesa Centro", "Lounge Moderno", "Vidrio Templado", "Cromado / Dorado"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Una zona lounge sin mesa de centro es solo un sofá en el medio del salón. La <strong>mesa de centro lounge moderna</strong> convierte el conjunto en un espacio funcional: un lugar donde los invitados pueden dejar su copa, revisar el menú, apoyar el bolso. Esa funcionalidad es lo que hace que la gente se quede en la zona y genere conversación.</p>
      <p class="showcase__text">El vidrio templado de 8mm es 5 veces más resistente que el vidrio estándar — soporta el uso intensivo de eventos sin romperse ni rayarse. La estructura metálica viene pre-ensamblada y se estabiliza en segundos. No hay tornillos ni herramientas: el equipo de montaje la coloca en su posición exacta en menos de un minuto.</p>
      <p class="showcase__text">En acabado cromado, la mesa refleja el ambiente y multiplica la sensación de lujo. En acabado dorado, complementa los sofás en blanco o negro creando contraste cálido. Ambas opciones combinan perfectamente con los otros elementos de la colección moderna de EVENTECH.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/mesas-cocktail-negras-networking-vista.avif" alt="Mesa de centro moderna cromada en zona lounge" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Mesa centro dorada con sofá blanco en evento" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/lounge-moderno-01.avif" alt="Mesa de centro en zona lounge premium" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Centro Lounge Moderno</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Centro Lounge Moderno"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre la mesa de centro lounge moderna para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la mesa de centro lounge moderna`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de mesas, acabado, fecha y venue — te respondemos en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge moderno y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Moderno</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Mesa centro lounge moderna para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la mesa de centro lounge moderna`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Mesa Centro Lounge Moderno"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Lanzamiento de Producto">Lanzamiento de Producto</option>
                <option value="Gala / Cena Formal">Gala / Cena Formal</option>
                <option value="XV Años">XV Años</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de mesas, acabado preferido (cromado/dorado), venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
