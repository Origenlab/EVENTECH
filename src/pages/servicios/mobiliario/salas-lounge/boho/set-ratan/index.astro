---
/**
 * ─── Set Ratán Lounge Boho — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Boho > Set Ratán
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { label: "Set Ratán" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif", alt: "Set ratán completo en jardín para boda boho CDMX" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-exterior-atardecer.avif", alt: "Lounge boho ratán en terraza de evento al aire libre" },
  { src: "/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif", alt: "Set completo ratán en boda boho con flores naturales" },
  { src: "/images/mobiliario/lounge-moderno-01.avif", alt: "Zona lounge boho ratán en evento de jardín CDMX" },
  { src: "/images/mobiliario/sala-lounge-elegante-sofa-neon-boda.avif", alt: "Set ratán boho en boda al aire libre" },
  { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Lounge ratán boho en evento con decoración natural" },
];

const faqs = [
  {
    question: "¿Qué incluye el set ratán completo boho?",
    answer: "El <strong>set ratán completo boho</strong> incluye sofá de ratán de 2 plazas con cojines en lino natural, 2 sillones individuales de ratán, mesa de centro de madera maciza y manta tejida de decoración. Todo en la estética boho que combina materiales naturales, texturas orgánicas y paleta tierra/crema. Diseñado para 4 a 6 personas."
  },
  {
    question: "¿El ratán es resistente para eventos al aire libre?",
    answer: "El <strong>ratán sintético</strong> de nuestro set (no ratán natural) está diseñado específicamente para exteriores. Es resistente a la humedad, al sol y a los cambios de temperatura. No se deforma, no se pudre ni se decolora con la exposición. Los cojines de lino tienen tratamiento impermeable básico para protección moderada contra la lluvia."
  },
  {
    question: "¿Para qué tipo de eventos es ideal el set ratán boho?",
    answer: "El <strong>set ratán boho</strong> es perfecto para bodas en jardines, haciendas con áreas verdes, bodas en playa o campo, eventos con estética boho-chic, bridal showers y baby showers con paleta natural. También funciona muy bien en terrazas con techos de palapa o de estructura natural. Cualquier evento donde quieras integrar materiales orgánicos en la decoración."
  },
  {
    question: "¿En qué colores vienen los cojines del set ratán?",
    answer: "Los cojines del set ratán vienen en tres paletas: <strong>Lino Natural</strong> (crema y beige, el más solicitado para bodas), <strong>Terra</strong> (terracota, naranja quemado y ocre para bodas otoñales o paletas cálidas) y <strong>Sage</strong> (verde salvia y blanco roto para bodas con paleta verde natural). Las mantas tejidas incluidas complementan cualquiera de las tres opciones."
  },
  {
    question: "¿El set ratán boho combina con flores silvestres y pampas grass?",
    answer: "Es la combinación más solicitada. El <strong>set ratán con pampas grass, flores silvestres y eucalipto</strong> crea la estética boho más fotogénica. El ratán tiene esa textura orgánica que dialoga naturalmente con elementos vegetales. Si tu decoración floral incluye estas plantas, el set ratán es prácticamente el único mobiliario lounge que no compite visualmente con ellas — las potencia."
  },
];

const specs = [
  { label: "Contenido del set", value: "Sofá ratán 2 plazas + 2 sillones + mesa centro + manta tejida" },
  { label: "Material estructura", value: "Ratán sintético premium resistente a exteriores" },
  { label: "Cojines", value: "Lino natural con tratamiento impermeable" },
  { label: "Paletas de cojines", value: "Lino Natural / Terra / Sage" },
  { label: "Capacidad", value: "4 a 6 personas por set" },
  { label: "Mesa de centro", value: "Madera maciza natural, 90 × 55 cm" },
  { label: "Uso", value: "Interior y exterior (resistente a humedad y UV)" },
  { label: "Estilo", value: "Boho-chic — materiales naturales, texturas orgánicas" },
  { label: "Precio", value: "Desde $3,800 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje y recolección en CDMX" },
];

const reviews = [
  { author: "Valeria Mora", text: "El set ratán con pampas grass y flores silvestres fue exactamente lo que imaginamos para nuestra boda boho en jardín. La calidad del ratán es impresionante — llegó perfecto y el montaje fue rápido.", rating: 5, date: "2025-10-05" },
  { author: "Sebastián Torres", text: "Para el bridal shower de mi hermana, el set ratán con cojines lino fue la elección perfecta. El espacio quedó como una editorial de revista. Muy profesionales.", rating: 5, date: "2025-09-28" },
  { author: "Gabriela Ríos", text: "El ratán sintético aguantó perfectamente una tarde de sol en el jardín. Los cojines no se decoloraron ni se deformaron. Una calidad muy superior a lo que esperaba por el precio.", rating: 5, date: "2025-11-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Ratán Completo Lounge Boho para Eventos CDMX",
    description: "Set ratán completo boho: sofá 2 plazas + 2 sillones + mesa madera + manta. Resistente a exteriores. Cojines en lino, terra o sage. Desde $3,800.",
    url: "/servicios/mobiliario/salas-lounge/boho/set-ratan/",
    priceRange: { min: 3800, max: 7600 },
    reviews,
    ratingValue: 5,
    reviewCount: 26,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Boho", url: "/servicios/mobiliario/salas-lounge/boho/" },
    { name: "Set Ratán", url: "/servicios/mobiliario/salas-lounge/boho/set-ratan/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Set Ratán", href: null, active: true },
  { name: "Peacock Chair", href: "/servicios/mobiliario/salas-lounge/boho/peacock-chair/" },
  { name: "Set Macramé", href: "/servicios/mobiliario/salas-lounge/boho/macrame/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Sillas Tiffany", href: "/servicios/mobiliario/sillas/tiffany/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Set Ratán Lounge Boho para Eventos CDMX"
  description="Renta set ratán completo boho en CDMX. Sofá + 2 sillones + mesa madera + manta. Resistente a exteriores. Cojines en lino, terra o sage. Desde $3,800."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="Ratán sintético premium — apto exteriores · 4 a 6 personas"
    title='Set Ratán <span class="highlight">Lounge Boho</span> — Renta en CDMX'
    subtitle="Set completo boho con sofá de ratán, 2 sillones, mesa de madera maciza y manta tejida. Ratán sintético resistente a sol y humedad. Cojines en lino natural, terra o sage. El set ideal para bodas en jardín, bodas boho-chic y bridal showers con paleta natural en CDMX."
    primaryCTA={{ label: "Cotizar set ratán boho", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set ratán lounge boho para mi evento` }}
    cards={[
      {
        title: "El set que hace tu boda boho look editorial sin esfuerzo",
        content: "El <strong>set ratán boho</strong> no necesita decoración adicional para verse bien — el ratán y la madera ya aportan toda la textura y calidez que una zona boho requiere. Añade flores silvestres, pampas grass o eucalipto alrededor del set y tendrás una zona de fotos que parece sacada de Pinterest. Es el efecto boho más auténtico con el menor esfuerzo decorativo.",
      },
      {
        title: "Resistente a exteriores — diseñado para jardines y eventos al aire libre",
        content: "A diferencia del ratán natural que se deteriora con la humedad, el <strong>ratán sintético premium</strong> de este set está tratado para resistir sol, humedad y cambios de temperatura sin perder su apariencia. Lo rentamos en bodas de jardín bajo el sol de CDMX con el mismo resultado que en interiores. Los cojines de lino tienen tratamiento impermeable básico.",
      },
    ]}
  />

  <CTABanner
    headline="Set ratán boho — la zona lounge más natural y fotogénica para tu boda en jardín"
    subheadline="Ratán sintético premium · Apto exteriores · Cojines en 3 paletas · CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Boho</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set ratán boho para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set ratán lounge boho`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Ratán Boho en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en jardín, bridal showers y eventos boho en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Ratán Completo Boho</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el set ratán es el favorito para bodas boho en jardín"
    headingId="descripcion-heading"
    badge="Natural · orgánico · perfecto para exterior"
    tags={["Set Ratán", "Lounge Boho", "Bodas en Jardín", "Bridal Shower"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>set ratán boho</strong> tiene una ventaja sobre cualquier otro estilo de lounge: se integra con el entorno natural en lugar de contrastar con él. En un jardín con pasto, flores y árboles, el ratán y la madera son extensiones visuales del ambiente. El resultado es un espacio que parece diseñado por la naturaleza, no instalado sobre ella.</p>
      <p class="showcase__text">Los cojines de lino natural tienen esa textura mate y ligera que complementa el ratán sin competir. La manta tejida que incluye el set agrega la capa textural que hace que la zona sea irresistible para fotógrafos — en fotografía de bodas, las texturas múltiples crean profundidad visual que el ojo interpreta como riqueza y cuidado.</p>
      <p class="showcase__text">En <strong>bodas boho-chic en CDMX</strong>, el set ratán se convierte frecuentemente en el punto donde la novia y el novio pasan más tiempo durante el coctel, porque es el espacio que más se siente como "ellos". No es mobiliario de evento genérico — es un ambiente que cuenta una historia.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif" alt="Set ratán boho en jardín de boda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-boho-ratan-exterior-atardecer.avif" alt="Lounge ratán en terraza de evento boho" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-moderno-blanco-dorado.avif" alt="Set ratán con decoración floral boho" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Ratán Lounge Boho</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Ratán Lounge Boho"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre el set ratán boho para eventos en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el set ratán lounge boho`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sets, paleta de cojines, fecha y venue — precio en 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge boho y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Boho</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Set ratán boho para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el set ratán lounge boho`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">WhatsApp</a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Set Ratán Lounge Boho"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate data-wa-number={SITE.contact.whatsapp} data-wa-title="Set Ratán Lounge Boho — Cotización">
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda Boho">Boda Boho</option>
                <option value="Boda en Jardín">Boda en Jardín</option>
                <option value="Bridal Shower">Bridal Shower</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="XV Años">XV Años</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sets, paleta de cojines preferida (lino natural/terra/sage), venue y cualquier detalle..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
