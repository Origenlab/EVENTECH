---
/**
 * ─── Peacock Chair Lounge Boho — Página de Variante (Nivel 4) ───
 * Jerarquía: Servicios > Mobiliario > Salas Lounge > Boho > Peacock Chair
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { label: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { label: "Peacock Chair" },
];

const galleryImages = [
  { src: "/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif", alt: "Peacock chair ratán en jardín para boda boho CDMX" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-exterior-atardecer.avif", alt: "Silla pavo real ratán en terraza de boda boho al atardecer" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif", alt: "Peacock chair ratán con macramé en boda boho interior CDMX" },
  { src: "/images/mobiliario/sala-lounge-boho-ratan-terracota.avif", alt: "Set lounge boho con peacock chair y cojines terracota" },
  { src: "/images/mobiliario/sala-lounge-boho-crema-macrame.avif", alt: "Peacock chair boho crema en zona lounge de boda garden" },
  { src: "/images/mobiliario/sala-lounge-boho-mostaza-exterior.avif", alt: "Silla pavo real ratán en evento exterior boho mostaza" },
];

const faqs = [
  {
    question: "¿Qué incluye la renta del set con Peacock Chair?",
    answer: "El set <strong>Peacock Chair boho</strong> incluye 2 sillas pavo real de ratán (la silla icónica del estilo boho), cojines en lino natural o terracota, mesa de centro en madera maciza y manta tejida decorativa. Opcionalmente se puede complementar con puff adicional de ratán. El set es ideal para crear la zona fotográfica más solicitada en bodas boho."
  },
  {
    question: "¿Para qué tipo de eventos funciona mejor la Peacock Chair?",
    answer: "La <strong>silla pavo real ratán</strong> es el elemento estrella de bodas boho, bridal showers, baby showers con estética natural y eventos garden. Funciona perfectamente tanto en exteriores (jardines, haciendas, terrazas de palapa) como en interiores con decoración botánica. Es la pieza más fotografiada en bodas boho — cada invitada quiere su foto en ella."
  },
  {
    question: "¿La Peacock Chair resiste el uso en exteriores?",
    answer: "Sí. Nuestras <strong>sillas pavo real</strong> están fabricadas en ratán sintético de alta resistencia UV, diseñado para exteriores. No se deforman con la humedad ni se decoloran con el sol. La estructura interna de acero galvanizado garantiza estabilidad incluso en jardines o terrazas. Los cojines cuentan con tratamiento impermeable básico."
  },
  {
    question: "¿Cuántas personas acomoda el set con Peacock Chair?",
    answer: "El set estándar con <strong>2 Peacock Chairs y mesa de centro</strong> es perfecto para 2 a 4 personas — ideal como zona fotográfica para los novios o para la quinceañera con chambelanes. Para zonas de mayor capacidad recomendamos complementar con sillones de ratán adicionales o puffs bohemios."
  },
  {
    question: "¿El set de Peacock Chair combina con decoración de flores secas y pampas?",
    answer: "Es la combinación más elegida. La <strong>Peacock Chair con pampas grass, flores secas y velas pilares</strong> crea la estética boho más fotogénica y atemporal. El ratán dialoga perfectamente con materiales naturales: lino, algodón, yute y elementos botánicos. Es prácticamente imposible lograr una mala foto con este set."
  },
];

const specs = [
  { label: "Contenido del set", value: "2 sillas Peacock Chair ratán + mesa centro madera + cojines + manta" },
  { label: "Material estructura", value: "Ratán sintético premium con base interna de acero galvanizado" },
  { label: "Cojines", value: "Lino natural con tratamiento impermeable" },
  { label: "Paletas disponibles", value: "Crema Natural / Terracota / Sage Verde" },
  { label: "Capacidad", value: "2 a 4 personas (zona fotográfica o lounge íntimo)" },
  { label: "Dimensiones silla", value: "70 cm ancho × 70 cm profundo × 150 cm alto (respaldo)" },
  { label: "Mesa de centro", value: "Madera maciza natural, 80 × 50 cm" },
  { label: "Uso", value: "Interior y exterior (resistente a humedad y UV)" },
  { label: "Estilo", value: "Boho-chic — ratán, lino, materiales naturales" },
  { label: "Precio", value: "Desde $800 por set / evento" },
  { label: "Incluye", value: "Entrega, montaje y recolección en CDMX" },
];

const reviews = [
  { author: "Isabella Vargas", text: "Las Peacock Chairs fueron la sensación de nuestra boda en jardín. Todas las invitadas querían su foto — incluso yo me quedé sentada todo lo que pude. El ratán es de excelente calidad y el montaje fue perfecto.", rating: 5, date: "2025-11-22" },
  { author: "Camila Reyes", text: "Para el bridal shower elegimos 2 sets de Peacock Chair con cojines crema. El resultado fue una zona fotográfica increíble. El ramo de novia combinó perfecto con el ratán. Muy recomendadas.", rating: 5, date: "2025-10-12" },
  { author: "Sofía Mendoza", text: "Rentamos 4 Peacock Chairs para la boda boho de mi hija. Con pampas grass y flores secas quedaron perfectas. La calidad superó mis expectativas — llegaron impecables y el equipo fue muy profesional.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Peacock Chair Ratán Lounge Boho para Bodas CDMX",
    description: "Renta Peacock Chair ratán boho en CDMX. Set con 2 sillas pavo real + mesa madera + cojines. Ideal para bodas boho, bridal showers y eventos garden. Desde $800.",
    url: "/servicios/mobiliario/salas-lounge/boho/peacock-chair/",
    priceRange: { min: 800, max: 2000 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Salas Lounge", url: "/servicios/mobiliario/salas-lounge/" },
    { name: "Lounge Boho", url: "/servicios/mobiliario/salas-lounge/boho/" },
    { name: "Peacock Chair", url: "/servicios/mobiliario/salas-lounge/boho/peacock-chair/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Lounge Boho", href: "/servicios/mobiliario/salas-lounge/boho/" },
  { name: "Set Ratán", href: "/servicios/mobiliario/salas-lounge/boho/set-ratan/" },
  { name: "Peacock Chair", href: null, active: true },
  { name: "Set Macramé", href: "/servicios/mobiliario/salas-lounge/boho/macrame/" },
];

const sidebarRelated = [
  { name: "Lounge Moderno", href: "/servicios/mobiliario/salas-lounge/moderno/" },
  { name: "Lounge Vintage", href: "/servicios/mobiliario/salas-lounge/vintage/" },
  { name: "Lounge Elegante", href: "/servicios/mobiliario/salas-lounge/elegante/" },
  { name: "Carpas Árabes", href: "/servicios/carpas/carpas-arabes/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Peacock Chair Ratán para Bodas Boho CDMX"
  description="Renta Peacock Chair ratán boho en CDMX. 2 sillas pavo real + mesa madera + cojines lino. La zona fotográfica más solicitada en bodas boho. Desde $800."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La zona fotográfica más solicitada en bodas boho"
    title='<span class="highlight">Peacock Chair Ratán</span> — Renta para Bodas Boho CDMX'
    subtitle="2 sillas pavo real de ratán + mesa de centro de madera maciza + cojines en lino natural. La pieza icónica del estilo boho que convierte cualquier rincón en la zona más fotografiada de tu boda o evento garden."
    primaryCTA={{ label: "Cotizar Peacock Chair", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Peacock Chair ratán boho para mi evento` }}
    cards={[
      {
        title: "La silla más fotografiada en bodas boho — icónica y atemporal",
        content: "La <strong>Peacock Chair</strong> (silla pavo real) es el símbolo del estilo boho en eventos. Su respaldo alto en forma de abanico de ratán crea un encuadre natural perfecto para las fotos de los novios, la quinceañera o cualquier momento especial. El ratán sintético premium mantiene su textura y color impecables evento tras evento.",
      },
      {
        title: "Set completo para zona fotográfica — todo incluido con montaje",
        content: "El set incluye <strong>2 Peacock Chairs, mesa de centro de madera maciza, cojines de lino y manta tejida</strong> — todos los elementos para crear una zona boho coherente y lista para fotografiar. Entrega puntual, montaje según tu plano y recolección al finalizar. Sin estrés el día de tu evento.",
      },
    ]}
  />

  <CTABanner
    headline="Peacock Chair ratán — la zona fotográfica que todas las novias quieren"
    subheadline="Ratán sintético premium · Cojines lino natural · Montaje incluido en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Lounge Boho</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Peacock Chair boho para tu boda o evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Peacock Chair ratán boho para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            WhatsApp
          </a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Peacock Chair Ratán en Bodas y Eventos Boho</h2>
            <p class="section__subtitle">Jardines, haciendas y terrazas en CDMX y área metropolitana</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Peacock Chair Ratán Boho</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Peacock Chair es la pieza favorita de las bodas boho?"
    headingId="descripcion-heading"
    badge="La pieza icónica del lounge boho — bodas, garden parties y bridal showers"
    tags={["Peacock Chair", "Bodas Boho", "Zona Fotográfica", "Ratán Premium"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>Peacock Chair</strong> tiene algo mágico: convierte cualquier espacio ordinario en escenario. Su respaldo alto en forma de abanico enmarca naturalmente a la persona sentada, creando el encuadre fotográfico perfecto sin necesitar ningún elemento adicional. Es por eso que los fotógrafos de bodas la piden específicamente — saben que las fotos en Peacock Chair son las que los clientes enmarcan.</p>
      <p class="showcase__text">El ratán sintético de alta resistencia UV que usamos en nuestras sillas mantiene su textura natural y su color cálido incluso después de muchas horas bajo el sol. A diferencia del ratán natural, no se agrieta, no absorbe humedad y no requiere mantenimiento especial. Llega a tu evento impecable y regresa igual.</p>
      <p class="showcase__text">En <strong>CDMX</strong> hemos instalado Peacock Chairs en jardines de Coyoacán, haciendas de Tlalpan, rooftops de Polanco y terrazas de San Ángel. El resultado siempre es el mismo: la zona más concurrida del evento y las mejores fotos del álbum.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/sala-lounge-boho-ratan-jardin-evento.avif" alt="Peacock Chair ratán boho en jardín para boda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-boho-ratan-exterior-atardecer.avif" alt="Silla pavo real en boda boho al atardecer" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/sala-lounge-boho-ratan-macrame-interior.avif" alt="Peacock chair con macramé en boda interior boho" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Peacock Chair Ratán Boho</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Peacock Chair Ratán Boho"
              subtitle="Todo lo que necesitas saber antes de reservar"
              description={["Resolvemos las dudas más frecuentes sobre la renta de Peacock Chair ratán para bodas y eventos boho en CDMX."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — un especialista te responde al instante.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la Peacock Chair ratán boho`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Número de sillas, fecha y venue — te respondemos con precio en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes lounge boho y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Lounge Boho</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/salas-lounge/" class="sidebar-nav__back">&uarr; Volver a Salas Lounge</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Otros Estilos de Lounge</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Peacock Chair ratán boho para tu boda en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Peacock Chair ratán boho para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza tu Peacock Chair Ratán Boho"
        subtitle="Cuéntanos sobre tu boda o evento y te respondemos de inmediato"
        description={[
          "Completa el formulario y un asesor te enviará cotización personalizada por WhatsApp. Sin compromiso.",
        ]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda Boho">Boda Boho</option>
                <option value="Bridal Shower">Bridal Shower</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="XV Años">XV Años</option>
                <option value="Garden Party">Garden Party</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Detalles del pedido <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Número de sillas, paleta de cojines (crema/terracota/sage), venue y cualquier detalle adicional..." rows="4" required></textarea>
            </div>
          </div>
          <button type="submit" class="reserva-form__submit" id="btnEnviar">
