---
/**
 * ─── Mesa Picnic Infantil — Ficha de Producto (Nivel 6) ───
 * Banca picnic de pino en versión reducida, 1.20×1.00 m, 8-10 niños de 3 a 10 años.
 * El modelo más seguro del catálogo — sin astillas, bordes redondeados.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Para Niños > Mesa Picnic Infantil
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Para Niños", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
  { label: "Mesa Picnic Infantil" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa de madera de pino para evento al aire libre — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa de madera natural barnizada a mano — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mobiliario de madera en jardín exterior — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mobiliario de madera rústica para evento — imagen de referencia" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Accesorios decorativos de madera sobre mesa de evento — imagen de referencia" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa de madera vintage para postres en evento — imagen de referencia" },
];

const faqs = [
  {
    question: "¿Para qué edades está pensada la Mesa Picnic Infantil?",
    answer: "La <strong>Mesa Picnic Infantil</strong> está diseñada para niños de <strong>3 a 10 años</strong> y acomoda de <strong>8 a 10 pequeños</strong>. Su altura reducida permite que los niños se sienten y se levanten solos, con comodidad y seguridad, sin necesidad de sillas de adulto ni de que alguien los suba. Es la mesa ideal para la merienda de un cumpleaños o el comedor infantil dentro de un evento familiar."
  },
  {
    question: "¿Es realmente segura? ¿No tiene astillas?",
    answer: "Es el modelo más seguro de todo nuestro catálogo. Cada mesa pasa por un <strong>lijado ultrafino que elimina astillas</strong> y todos los bordes y esquinas van redondeados. Antes de cada evento revisamos pieza por pieza la estructura, las uniones y el acabado — si una mesa tiene una astilla, una grieta o el barniz deteriorado, no sale de bodega. Las bancas integradas son estables y aguantan el uso rudo de los niños durante toda la fiesta."
  },
  {
    question: "¿Cuántas mesas infantiles necesito para mi fiesta?",
    answer: "Cada Mesa Picnic Infantil acomoda de 8 a 10 niños, así que para un cumpleaños de <strong>unos 20 niños necesitas 2 mesas</strong> y para <strong>40 niños, entre 4 y 5</strong>. Para kermeses escolares o eventos grandes te ayudamos a calcular la cantidad exacta según el número de pequeños y el espacio disponible. Contamos con inventario para eventos de 100 o más personas combinando modelos."
  },
  {
    question: "¿Se puede usar en jardín y al aire libre?",
    answer: "Sí. La Mesa Picnic Infantil funciona igual de bien en <strong>interior y exterior</strong>: jardines, terrazas, patios de escuela y salones. La madera de pino va lijada y barnizada a mano para resistir sol, pasto y humedad durante el evento. Para una zona de niños completa al aire libre, combínala con nuestros <a href=\"/servicios/inflables/\">inflables infantiles</a> — mesas para comer y brincolines para jugar, todo en una sola entrega."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos apartar con <strong>1 semana de anticipación</strong>, y con <strong>2 semanas o más en temporada alta</strong> (noviembre a febrero) o para fechas de fin de semana muy solicitadas. La mesa infantil es muy pedida para cumpleaños y kermeses, así que reservar temprano asegura disponibilidad de la cantidad de piezas que necesitas. Un anticipo confirma tu fecha y la recolección ya va incluida en el precio."
  },
];

const specs = [
  { label: "Medidas", value: "1.20 × 1.00 m" },
  { label: "Altura", value: "Reducida, adaptada a estatura infantil" },
  { label: "Capacidad", value: "8 a 10 niños" },
  { label: "Edad recomendada", value: "3 a 10 años" },
  { label: "Material", value: "Pino natural lijado a grano fino" },
  { label: "Acabado", value: "Lijado ultrafino sin astillas ni bordes filosos" },
  { label: "Bancas", value: "Integradas, esquinas redondeadas" },
  { label: "Uso", value: "Interior y exterior — jardín, terraza y salón" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $350 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Mariana Cervantes", text: "Rentamos dos mesas picnic infantiles para el cumpleaños de mi hijo en el jardín. Los niños comieron cómodos y seguros, sin astillas ni bordes que me preocuparan. El montaje fue puntual y la madera se veía preciosa entre los globos.", rating: 5, date: "2025-11-14" },
  { author: "Óscar Beltrán", text: "La altura es perfecta para los peques, se sentaban y paraban solos sin ayuda. Aguantaron todo el día de kermés con niños subiéndose y bajándose. Muy resistentes y el equipo las recogió sin que moviéramos nada.", rating: 5, date: "2025-10-11" },
  { author: "Renata Gil", text: "Para la zona de niños de nuestra boda pedimos mesas infantiles y quedaron divinas con la decoración de madera. Los papás estuvieron tranquilos porque no había astillas ni bordes filosos. Repetiremos sin duda.", rating: 5, date: "2025-09-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa Picnic Infantil de Madera en CDMX",
    description: "Mesa picnic infantil de madera 1.20×1.00 m para 8-10 niños de 3 a 10 años. Altura reducida, bordes redondeados, lijado ultrafino sin astillas. El modelo más seguro del catálogo. Desde $350.",
    url: "/servicios/mobiliario/mesas-picnic/infantil/mesa-infantil/",
    priceRange: { min: 350, max: 800 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Para Niños", url: "/servicios/mobiliario/mesas-picnic/infantil/" },
    { name: "Mesa Picnic Infantil", url: "/servicios/mobiliario/mesas-picnic/infantil/mesa-infantil/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Toda la línea Infantil", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
  { name: "Mesa Picnic Infantil", href: null, active: true },
  { name: "Set Infantil Temático", href: "/servicios/mobiliario/mesas-picnic/infantil/set-tematico/" },
];

const sidebarRelated = [
  { name: "Inflables Infantiles", href: "/servicios/inflables/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
];
---

<PageLayout
  title="Renta de Mesa Picnic Infantil de Madera"
  description="Renta mesa picnic infantil de madera en CDMX — 1.20×1.00 m para 8-10 niños de 3 a 10 años. Altura reducida, sin astillas, bordes redondeados. Desde $350."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El modelo más seguro del catálogo"
    title='Mesa Picnic <span class="highlight">Infantil</span> de Madera — Renta CDMX'
    subtitle="La banca picnic de pino natural en versión reducida (1.20 × 1.00 m): altura adaptada para que los niños se sienten solos, bordes redondeados y lijado ultrafino sin astillas. Para 8-10 niños de 3 a 10 años. Entrega, montaje y recolección incluidos. Desde $350."
    primaryCTA={{ label: "Cotizar mesa picnic infantil", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Infantil de madera para mi evento` }}
    cards={[
      {
        title: "Diseñada alrededor de la seguridad de los niños",
        content: "La <strong>Mesa Picnic Infantil</strong> es la más segura de todo el catálogo. Su <strong>altura reducida</strong> permite que los niños de 3 a 10 años se sienten y se levanten solos, sin sillas de adulto ni ayuda. El <strong>lijado ultrafino elimina astillas</strong> y todos los bordes y esquinas van redondeados. Las bancas integradas son estables y acomodan de 8 a 10 pequeños con comodidad — perfecta para la merienda de un cumpleaños.",
      },
      {
        title: "Madera real que aguanta el uso rudo de los niños",
        content: "Fabricada en <strong>pino natural lijado a grano fino</strong> y barnizado a mano, resiste sol, pasto y humedad, y funciona igual en jardín, terraza o salón. Cada mesa se revisa pieza por pieza antes de salir de bodega: estructura, uniones y acabado. Montaje, entrega y recolección incluidos en CDMX y Edomex, sin límite de tiempo durante tu evento y sin cargos ocultos por traslado.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Cuántas mesas infantiles necesitas? Te ayudamos a calcularlo"
    subheadline="Asesoría sin costo — calculamos la cantidad exacta según el número de niños y tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Línea Infantil</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa picnic infantil para tu fiesta</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Infantil de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Picnic Infantil en Eventos</h2>
            <p class="section__subtitle">Cumpleaños, kermeses y zonas de niños en jardines y salones de CDMX</p>
            <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Picnic Infantil</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Mesa Picnic Infantil es el modelo más seguro?"
    headingId="descripcion-heading"
    badge="Sin astillas · altura reducida"
    tags={["1.20 × 1.00 m", "8-10 niños", "3 a 10 años", "Madera de pino"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La seguridad no es un detalle, es el punto de partida del diseño. La <strong>altura reducida</strong> está calculada para que los niños de 3 a 10 años apoyen bien los pies y se sienten o se levanten solos, sin trepar ni depender de un adulto. El <strong>lijado a grano ultrafino</strong> elimina astillas y todos los bordes y esquinas van redondeados, así que no hay filos que rasguñen. Las bancas integradas dan estabilidad incluso cuando los niños se recargan o se mueven.</p>
      <p class="showcase__text">El tablero y las bancas son de <strong>pino natural barnizado a mano</strong>, una madera cálida que combina con globos, manteles y cualquier temática. Resiste el uso rudo de una fiesta completa y funciona igual en jardín, terraza o salón. Es la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">MESPIC — mesaspicnic.com</a>, con más de 500 eventos montados en madera real.</p>
      <p class="showcase__text">Cada mesa se limpia e inspecciona antes de entregarse: estructura, uniones y acabado. Si algo no está impecable, no sale de bodega. Montaje, entrega y recolección incluidos en CDMX y Edomex — tú no acomodas ni desmontas nada, solo disfrutas la fiesta con los peques.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa de madera de pino para evento al aire libre — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Mobiliario de madera en jardín exterior — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Mesa de madera natural barnizada a mano — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Mesa Picnic Infantil</h2>
            <p class="section__subtitle">Combinaciones que arman una zona de niños completa</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cumpleaños en jardín</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas Picnic Infantiles para la merienda + <strong><a href="/servicios/inflables/">inflables infantiles</a></strong> para jugar + globos. La zona de niños completa que mantiene a los peques felices y seguros toda la tarde.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Zona de niños en boda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas infantiles para los peques + <strong><a href="/servicios/mobiliario/sillas/">sillas para eventos</a></strong> para los adultos. Los niños comen a su altura y los papás disfrutan tranquilos, todo coordinado en madera natural.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Kermés escolar</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Varias Mesas Picnic Infantiles resistentes al uso rudo de todo un día. Fáciles de distribuir en el patio y sin astillas ni bordes filosos — pensadas para que suban y bajen sin riesgo.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Picnic Infantil</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Picnic Infantil"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El modelo más seguro del catálogo. Altura reducida, sin astillas, bordes redondeados — pensado para niños de 3 a 10 años."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas mesas necesitas para el número de niños de tu fiesta.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Picnic Infantil`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de niños y te calculamos mesas y precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Línea infantil y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Línea Infantil</h2>
