---
/**
 * ─── Set Infantil Temático — Ficha de Producto (Nivel 6) ───
 * Set de madera 1.00×0.70 m, 52 cm de alto, pintura atóxica certificada en 5 colores.
 * Para 8 niños de 3 a 8 años. Color a la medida de la temática de la fiesta.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Para Niños > Set Infantil Temático
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Para Niños", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
  { label: "Set Infantil Temático" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mobiliario de madera rústica para evento — imagen de referencia" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa de madera vintage para postres en evento — imagen de referencia" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Accesorios decorativos de madera sobre mesa de evento — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mobiliario de madera en jardín exterior — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa de madera natural barnizada a mano — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa de madera de pino para evento al aire libre — imagen de referencia" },
];

const faqs = [
  {
    question: "¿En qué colores está disponible el Set Infantil Temático?",
    answer: "El set está disponible en <strong>5 colores</strong> con pintura atóxica certificada: <strong>blanco, azul cielo, rosa palo, verde menta y lila</strong>. Puedes elegir el tono que combine con la temática del cumpleaños, el baby shower o la sesión de fotos. Si tu evento tiene una paleta específica, indícanoslo al cotizar y te confirmamos disponibilidad del color que buscas."
  },
  {
    question: "¿La pintura es segura para los niños?",
    answer: "Sí. El Set Infantil Temático va terminado con <strong>pintura atóxica certificada</strong>, apta para el contacto con niños pequeños. Además, como toda la línea infantil, va <strong>lijado a grano ultrafino y con los bordes redondeados</strong>, sin astillas ni filos. Revisamos cada set antes de entregarlo para asegurar que el acabado y la estructura estén impecables."
  },
  {
    question: "¿Para qué edades y cuántos niños es el set?",
    answer: "El Set Infantil Temático mide <strong>1.00 × 0.70 m con 52 cm de alto</strong> y está pensado para niños de <strong>3 a 8 años</strong>. Acomoda hasta <strong>8 niños</strong> con comodidad. La altura de 52 cm está calculada para que los pequeños se sienten y se levanten solos, apoyando bien los pies — ideal para merienda, manualidades o mesa de dulces a escala infantil."
  },
  {
    question: "¿Puedo combinarlo con otros colores o con la Mesa Picnic Infantil?",
    answer: "Claro. Muchos clientes combinan <strong>varios sets en distintos colores</strong> para armar un rincón infantil vistoso, o suman la <a href=\"/servicios/mobiliario/mesas-picnic/infantil/mesa-infantil/\">Mesa Picnic Infantil</a> de pino natural para tener más lugares. También puedes coordinar el set con nuestros <a href=\"/servicios/inflables/\">inflables infantiles</a> para una zona de niños completa. Te ayudamos a definir la combinación según el número de peques y la temática."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos apartar con <strong>1 semana de anticipación</strong>, y con <strong>2 semanas o más en temporada alta</strong> (noviembre a febrero) o si necesitas un color específico para varias piezas. El set temático es muy solicitado para fiestas de tonos pastel, así que reservar temprano asegura la disponibilidad del color y la cantidad. Un anticipo confirma tu fecha; la recolección va incluida en el precio."
  },
];

const specs = [
  { label: "Medidas", value: "1.00 × 0.70 m" },
  { label: "Altura", value: "52 cm" },
  { label: "Capacidad", value: "8 niños" },
  { label: "Edad recomendada", value: "3 a 8 años" },
  { label: "Material", value: "Madera con pintura atóxica certificada" },
  { label: "Colores", value: "Blanco, azul cielo, rosa palo, verde menta y lila (5)" },
  { label: "Acabado", value: "Lijado ultrafino, bordes redondeados" },
  { label: "Uso", value: "Interior y exterior — jardín, terraza y salón" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $450 por set / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Diego Fuentes", text: "El set infantil temático en tonos pastel fue un éxito en el baby shower. La pintura atóxica me dio mucha tranquilidad con los peques y los colores combinaron perfecto con la decoración. Muy recomendables y súper atentos.", rating: 5, date: "2025-11-08" },
  { author: "Valeria Ontiveros", text: "Pedimos tres sets en rosa palo, lila y verde menta para el cumpleaños de mi hija y el rincón de niños quedó precioso. La altura era perfecta para que se sentaran solitos. Llegaron impecables y a tiempo.", rating: 5, date: "2025-10-16" },
  { author: "Héctor Palomares", text: "Rentamos el set en azul cielo para la mesa de manualidades de una fiesta temática. Resistió pintura, plastilina y todo lo que los niños le hicieron. Se limpió fácil y el servicio de montaje fue puntual.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Set Infantil Temático de Madera en CDMX",
    description: "Set infantil temático de madera 1.00×0.70 m, 52 cm de alto, con pintura atóxica certificada en 5 colores para 8 niños de 3 a 8 años. Color a la medida de la temática. Desde $450.",
    url: "/servicios/mobiliario/mesas-picnic/infantil/set-tematico/",
    priceRange: { min: 450, max: 1000 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Para Niños", url: "/servicios/mobiliario/mesas-picnic/infantil/" },
    { name: "Set Infantil Temático", url: "/servicios/mobiliario/mesas-picnic/infantil/set-tematico/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Toda la línea Infantil", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
  { name: "Mesa Picnic Infantil", href: "/servicios/mobiliario/mesas-picnic/infantil/mesa-infantil/" },
  { name: "Set Infantil Temático", href: null, active: true },
];

const sidebarRelated = [
  { name: "Inflables Infantiles", href: "/servicios/inflables/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
];
---

<PageLayout
  title="Renta de Set Infantil Temático de Madera"
  description="Renta set infantil temático de madera en CDMX — 1.00×0.70 m, 52 cm de alto, pintura atóxica en 5 colores para 8 niños de 3 a 8 años. Desde $450."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Pintura atóxica certificada · 5 colores"
    title='Set Infantil <span class="highlight">Temático</span> de Madera — Renta CDMX'
    subtitle="El set que suma color a la seguridad: 1.00 × 0.70 m con 52 cm de alto y pintura atóxica certificada en 5 colores (blanco, azul cielo, rosa palo, verde menta y lila). Para hasta 8 niños de 3 a 8 años. Entrega, montaje y recolección incluidos. Desde $450."
    primaryCTA={{ label: "Cotizar set infantil temático", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Infantil Temático de madera para mi evento` }}
    cards={[
      {
        title: "Color a la medida de la temática — con pintura atóxica",
        content: "El <strong>Set Infantil Temático</strong> viene en <strong>5 colores</strong> con pintura atóxica certificada: blanco, azul cielo, rosa palo, verde menta y lila. Elige el tono que combine con la fiesta y súmalo a globos, manteles y decoración. La pintura es apta para el contacto con niños pequeños y, como toda la línea, va lijado ultrafino y con bordes redondeados, sin astillas ni filos.",
      },
      {
        title: "A la altura de los peques: 52 cm para 8 niños de 3 a 8 años",
        content: "Con <strong>1.00 × 0.70 m y 52 cm de alto</strong>, el set está calculado para que los niños de 3 a 8 años se sienten y se levanten solos, apoyando bien los pies. Acomoda hasta <strong>8 niños</strong> y es ideal para merienda, rincón de manualidades o mesa de dulces a escala infantil. Entrega, montaje y recolección incluidos en CDMX y Edomex, sin límite de tiempo durante tu evento.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Qué color combina con tu fiesta? Elige entre 5 tonos atóxicos"
    subheadline="Asesoría sin costo — te ayudamos con el color y la cantidad de sets según tu temática"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Línea Infantil</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set infantil temático para tu fiesta</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Infantil Temático de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Infantil Temático en Eventos</h2>
            <p class="section__subtitle">Cumpleaños, baby showers y rincones de niños en tonos pastel</p>
            <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Infantil Temático</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el Set Infantil Temático es el favorito para fiestas con temática?"
    headingId="descripcion-heading"
    badge="Color + seguridad en una pieza"
    tags={["1.00 × 0.70 m", "52 cm de alto", "8 niños", "5 colores atóxicos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Cuando la fiesta tiene una temática, el color importa. El <strong>Set Infantil Temático</strong> resuelve eso sin sacrificar seguridad: viene en <strong>5 tonos con pintura atóxica certificada</strong> — blanco, azul cielo, rosa palo, verde menta y lila — para que combine con globos, manteles y decoración. Elige un solo color o mezcla varios para armar un rincón infantil vistoso y coordinado.</p>
      <p class="showcase__text">Con <strong>52 cm de altura</strong>, el set está a la medida de los niños de 3 a 8 años: se sientan y se levantan solos, apoyando bien los pies. Acomoda hasta 8 pequeños y es perfecto para merienda, mesa de manualidades o dulces a escala infantil. Como toda la línea, va lijado a grano ultrafino y con bordes redondeados. Es la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">MESPIC — mesaspicnic.com</a>, con cientos de eventos montados en madera real.</p>
      <p class="showcase__text">Cada set se limpia e inspecciona antes de entregarse: estructura, uniones, pintura y acabado. Montaje, entrega y recolección incluidos en CDMX y Edomex, sin límite de tiempo durante tu evento y sin cargos ocultos. Si tu fiesta mezcla peques y adultos, combínalo con nuestras <a href="/servicios/mobiliario/sillas/">sillas para eventos</a> para los grandes.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Mobiliario de madera rústica para evento — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mesa de madera vintage para postres en evento — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Accesorios decorativos de madera sobre mesa de evento — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con el Set Infantil Temático</h2>
            <p class="section__subtitle">Ideas de color y combinación para tu fiesta temática</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cumpleaños temático</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Sets en el color del personaje o paleta de la fiesta + <strong><a href="/servicios/inflables/">inflables infantiles</a></strong>. Los niños comen y juegan en un rincón coordinado con toda la decoración.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Baby shower pastel</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Sets en rosa palo, azul cielo o verde menta para la mesa de los peques, coordinados con <strong><a href="/servicios/mobiliario/sillas/">sillas para eventos</a></strong> para los adultos. Tonos suaves que se ven divinos en fotos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Rincón de manualidades</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Varios sets en distintos colores + la <strong><a href="/servicios/mobiliario/mesas-picnic/infantil/mesa-infantil/">Mesa Picnic Infantil</a></strong>. Una zona vistosa para pintar, dibujar y jugar, resistente al uso rudo.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Infantil Temático</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Infantil Temático"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["5 colores con pintura atóxica certificada, 52 cm de alto, para 8 niños de 3 a 8 años. Color a la medida de tu temática."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a elegir el color y la cantidad de sets según tu temática.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta del Set Infantil Temático`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el color y el número de niños y te calculamos sets y precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
