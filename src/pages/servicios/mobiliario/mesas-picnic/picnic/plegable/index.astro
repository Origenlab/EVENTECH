---
/**
 * ─── Mesa Picnic Plegable — Página de Variante (Nivel 6) ───
 * 1.50×1.20 m, 4-6 personas, pino tratado con bancas integradas plegables.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Mesas Picnic > Plegable
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { label: "Plegable — 4-6 personas" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Mesa Picnic Plegable de pino con bancas integradas plegables — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Detalle de madera de pino tratada de la Mesa Picnic Plegable — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mesa Picnic Plegable montada en un bazar al aire libre — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa Picnic Plegable en un pop-up de fin de semana — imagen de referencia" },
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Mesa Picnic Plegable ligera para venue con acceso restringido — imagen de referencia" },
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Bancas plegables integradas de la Mesa Picnic Plegable — imagen de referencia" },
];

const faqs = [
  {
    question: "¿Cómo se pliega la Mesa Picnic Plegable?",
    answer: "La mesa se pliega gracias a sus <strong>bisagras de acero galvanizado</strong>, reduciéndose a apenas <strong>12 cm de grosor</strong>. Las <strong>bancas integradas también son plegables</strong> y viajan con la mesa en una sola pieza compacta, lo que facilita muchísimo el traslado y el almacenamiento entre eventos."
  },
  {
    question: "¿Por qué es ideal para venues con acceso restringido?",
    answer: "Porque pliega a <strong>12 cm</strong> y es <strong>25% más ligera que la Estándar</strong>: sube escaleras, entra en elevadores pequeños y pasa por pasillos estrechos donde una mesa rígida no cabría. Es la opción preferida para <strong>bazares, pop-ups y venues difíciles de acceder</strong>. Para exteriores sin techo, complementa con nuestras <a href=\"/servicios/carpas/\">carpas profesionales</a>."
  },
  {
    question: "¿Qué tan ligera es comparada con la Mesa Estándar?",
    answer: "La Mesa Picnic Plegable es <strong>25% más ligera</strong> que la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/estandar/\">Mesa Estándar</a>, sin sacrificar la firmeza de la madera de pino tratada. Esa diferencia de peso hace que una sola persona pueda maniobrarla y que el montaje y desmontaje sean mucho más rápidos."
  },
  {
    question: "¿Cuántas personas caben en la Mesa Picnic Plegable?",
    answer: "La <strong>Mesa Picnic Plegable de 1.50×1.20 m</strong> acomoda <strong>4-6 personas</strong> en sus dos bancas plegables integradas. Si necesitas mayor capacidad por mesa, revisa la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/grande/\">Mesa Grande</a> (10-12) o la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/xl/\">Mesa XL</a> (14-16)."
  },
  {
    question: "¿El precio incluye montaje y entrega?",
    answer: "Sí. El precio <strong>desde $400 por mesa / evento</strong> — el más económico de la familia — incluye entrega, montaje, nivelación y recolección en CDMX y zona metropolitana. El precio final depende del volumen y la ubicación del venue. Un anticipo del 30% confirma tu fecha y cantidad."
  },
];

const specs = [
  { label: "Medidas", value: "1.50 × 1.20 m (mesa + 2 bancas)" },
  { label: "Capacidad", value: "4-6 personas" },
  { label: "Material", value: "Madera de pino tratada para exterior" },
  { label: "Herrajes", value: "Bisagras de acero galvanizado" },
  { label: "Peso", value: "25% más ligera que la Estándar" },
  { label: "Plegado", value: "Pliega a 12 cm de grosor" },
  { label: "Bancas", value: "2 integradas plegables" },
  { label: "Uso", value: "Bazares, pop-ups, acceso restringido" },
  { label: "Logística", value: "Entrega, montaje, nivelación y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $400 por pieza / evento" },
];

// PLACEHOLDER reviews — reemplazar por reseñas reales
const reviews = [
  { author: "Renata V.", text: "Montamos un bazar de fin de semana en un patio con acceso solo por escaleras. Estas mesas plegables subieron sin problema y pliegan tan compactas que las guardamos en un clóset entre días. Ligeras y muy firmes.", rating: 5, date: "2025-11-08" },
  { author: "Óscar L.", text: "Para un pop-up de moda de 3 días necesitábamos mesas de armar y desarmar rápido. Las plegables fueron perfectas: dos personas montaban una en segundos y a 12 cm de grosor cupieron todas en la camioneta.", rating: 5, date: "2025-10-11" },
  { author: "Tania S.", text: "Nuestro venue está en un tercer piso con elevador pequeño. Ninguna mesa de madera nos entraba… hasta estas. Plegadas pasaron sin drama y se ven igual de bonitas. Además fueron la opción más económica.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Picnic Plegable para Eventos en CDMX — 4-6 Personas",
    description: "Mesa picnic plegable de 1.50×1.20 m para 4-6 personas en madera de pino con bancas plegables. Pliega a 12 cm y es 25% más ligera — ideal para bazares, pop-ups y venues con acceso restringido en CDMX. Desde $400.",
    url: "/servicios/mobiliario/mesas-picnic/picnic/plegable/",
    priceRange: { min: 400, max: 950 },
    reviews,
    ratingValue: 5,
    reviewCount: 49,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Picnic", url: "/servicios/mobiliario/mesas-picnic/picnic/" },
    { name: "Plegable — 4-6 Personas", url: "/servicios/mobiliario/mesas-picnic/picnic/plegable/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Estándar", href: "/servicios/mobiliario/mesas-picnic/picnic/estandar/" },
  { name: "Mesa Grande", href: "/servicios/mobiliario/mesas-picnic/picnic/grande/" },
  { name: "Mesa XL", href: "/servicios/mobiliario/mesas-picnic/picnic/xl/" },
  { name: "Mesa Premium", href: "/servicios/mobiliario/mesas-picnic/picnic/premium/" },
  { name: "Mesa Rústica", href: "/servicios/mobiliario/mesas-picnic/picnic/rustica/" },
  { name: "Mesa Hexagonal", href: "/servicios/mobiliario/mesas-picnic/picnic/hexagonal/" },
  { name: "Mesa Plegable", href: null, active: true },
  { name: "Mesa Farm Americana", href: "/servicios/mobiliario/mesas-picnic/picnic/farm-americana/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Mesa Picnic Plegable para Eventos CDMX"
  description="Renta mesa picnic plegable 1.50×1.20 m en CDMX — 4-6 personas, pino con bancas plegables. Pliega a 12 cm, ideal para bazares y venues con acceso restringido. Desde $400."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El modelo más ligero y compacto de la familia"
    title='Mesa Picnic <span class="highlight">Plegable</span> — 4-6 Personas — Renta CDMX'
    subtitle="La Mesa Picnic Plegable de 1.50×1.20 m es el modelo más ligero y compacto de la familia: 4-6 comensales en bancas de pino plegables. Pliega a 12 cm gracias a sus bisagras de acero galvanizado y es 25% más ligera que la Estándar — ideal para bazares, pop-ups y venues con acceso restringido. Montaje incluido. Desde $400."
    primaryCTA={{ label: "Cotizar mesa plegable", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Plegable para mi evento` }}
    cards={[
      {
        title: "La mesa picnic más ligera y fácil de transportar",
        content: "La <strong>Mesa Picnic Plegable</strong> es el modelo más compacto y económico de nuestra familia de mesas de madera. Con <strong>1.50×1.20 m para 4-6 personas</strong>, pliega a apenas 12 cm de grosor gracias a sus bisagras de acero galvanizado — ideal para bazares, pop-ups y venues con acceso restringido. Trabajamos con el <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">sitio especializado en mesas picnic</a> para garantizar madera de pino de calidad, y la combinas con <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas crossback</a> cuando necesitas asientos adicionales.",
      },
      {
        title: "Pino tratado, bisagras galvanizadas y bancas plegables",
        content: "Fabricada en <strong>madera de pino tratada para exterior</strong>, es <strong>25% más ligera que la Estándar</strong> y sus <strong>bancas integradas plegables</strong> viajan en una sola pieza compacta, perfecta para montajes rápidos y temporales. Complementa con <a href=\"/servicios/iluminacion/\">iluminación</a> para la noche y con <a href=\"/servicios/carpas/\">carpas</a> como respaldo ante el clima.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Tu venue tiene escaleras o acceso difícil? La mesa plegable entra donde otras no"
    subheadline="Asesoría de distribución sin costo — ideal para bazares, pop-ups y espacios con acceso restringido"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Modelos de Mesa Picnic</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa Picnic Plegable para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Plegable`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Picnic Plegable en Eventos</h2>
            <p class="section__subtitle">Bazares, pop-ups y venues con acceso restringido en CDMX</p>
            <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Picnic Plegable</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Plegable es la mesa picnic más práctica?"
    headingId="descripcion-heading"
    badge="El formato compacto y ligero de la madera"
    tags={["1.50×1.20 m", "4-6 personas", "Pliega a 12 cm", "25% más ligera"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El formato de 1.50×1.20 m está pensado para la practicidad: <strong>4-6 comensales</strong> con mesa y bancas que pliegan en una sola pieza. Es la mesa picnic más compacta de nuestra familia, ideal cuando el reto no es el tamaño del evento sino cómo meter el mobiliario al venue.</p>
      <p class="showcase__text">Sus <strong>bisagras de acero galvanizado</strong> permiten que pliegue a apenas <strong>12 cm de grosor</strong>, y al ser <strong>25% más ligera que la Estándar</strong>, una sola persona la maniobra. Sube escaleras, entra en elevadores y pasa por pasillos estrechos — el mobiliario de madera que llega donde otros no pueden.</p>
      <p class="showcase__text">Fabricada en <strong>madera de pino tratada para exterior</strong>, mantiene la calidez rústica y la resistencia al sol y la humedad. Es además la opción <strong>más económica</strong> de la familia, desde $400, sin renunciar al acabado profesional. Cada mesa se limpia e inspecciona antes de entregarse.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Mesa Picnic Plegable de pino montada en evento — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Mesa Picnic Plegable en bazar al aire libre — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Detalle de bancas plegables de la Mesa Picnic Plegable — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Mesa Plegable</h2>
            <p class="section__subtitle">Combinaciones de estilo, textiles y complementos que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Bazar / Pop-up</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas plegables que armas y desarmas en segundos + <a href="/servicios/iluminacion/">iluminación</a> ligera. El montaje ideal para bazares de fin de semana y pop-ups temporales que cambian de sede.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Venue con Acceso Difícil</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas plegadas a 12 cm que suben escaleras y entran en elevadores + <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> apilables. La solución para venues en pisos altos o con pasillos estrechos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Montaje Rápido Temporal</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas plegables + <a href="/servicios/carpas/">carpa</a> de respaldo para eventos de un día. Montaje y desmontaje exprés cuando el tiempo de instalación es corto.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Picnic Plegable</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Picnic Plegable"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El modelo más ligero y compacto de la familia. 4-6 personas, pliega a 12 cm, ideal para bazares, pop-ups y venues con acceso restringido."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas mesas necesitas para tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Picnic Plegable`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados y te calculamos mesas y layout al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
