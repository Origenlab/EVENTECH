---
/**
 * ─── Mesas Picnic — Página de Familia (Nivel 5) ───
 * 8 modelos de mesa picnic de madera de pino para eventos al aire libre.
 * Desde el formato estándar de 6 personas hasta la XL de 16 y la Farm americana.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Mesas Picnic
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Picnic" },
];

const faqs = [
  { question: "¿Qué es una mesa picnic y para qué tipo de evento sirve?", answer: 'La <strong>mesa picnic</strong> es una mesa de madera de pino con <strong>bancas integradas</strong> en una sola pieza — no necesita sillas por separado. Es el mobiliario estrella para eventos al aire libre: bodas campestres, festivales, ferias gastronómicas, jardines, terrazas y venues rústicos. Ofrecemos una familia completa de <strong>8 modelos</strong>, desde la estándar de 6 personas hasta la XL de 16 comensales.' },
  { question: "¿Cuántos modelos de mesa picnic tienen y cuál me conviene?", answer: 'Ofrecemos <strong>8 modelos</strong>: la <strong>Estándar</strong> (1.80×1.50 m, 6 personas) es la más solicitada; la <strong>Grande</strong> (10-12 personas) y la <strong>XL</strong> (14-16 personas) para grupos numerosos; la <strong>Premium</strong> y la <strong>Rústica</strong> para bodas; la <strong>Hexagonal</strong> para montajes fotogénicos; la <strong>Plegable</strong> para venues con acceso restringido; y la <strong>Farm Americana</strong> sin bancas para combinar con sillas. Te asesoramos según tu número de invitados, el estilo del evento y las dimensiones del venue.' },
  { question: "¿Las mesas picnic son aptas para exterior y aguantan la intemperie?", answer: 'Sí. Están fabricadas en <strong>madera de pino tratada para exterior</strong> con barniz protector que resiste sol, humedad y roce. Recomendamos no dejarlas expuestas a lluvia prolongada, pero soportan perfectamente un día completo de evento en jardín o terraza. Para eventos largos o clima incierto, complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> y con <a href="/servicios/iluminacion/">iluminación</a> para la noche.' },
  { question: "¿El montaje y la logística están incluidos?", answer: 'Sí. El servicio incluye <strong>entrega, montaje, nivelación y recolección</strong> en CDMX y zona metropolitana. Nuestro equipo transporta las mesas protegidas, las coloca según el layout aprobado y verifica la estabilidad de cada banca antes de tu evento. Por su peso y volumen, la logística de mesas de madera requiere coordinación previa — por eso recomendamos reservar con anticipación.' },
  { question: "¿Necesito sillas si rento mesas picnic?", answer: 'La mayoría de los modelos incluyen <strong>bancas integradas</strong>, así que no necesitas sillas adicionales. La excepción es la <strong>Mesa Farm Americana</strong>, que se entrega sin bancas para que la combines con sillas de tu elección — es la opción favorita para bodas campestres formales con <a href="/servicios/mobiliario/sillas/crossback/">sillas Crossback</a>, Tiffany o Ghost. Te ayudamos a coordinar mesa + sillas en un solo pedido.' },
  { question: "¿Cuántas mesas picnic necesito para mi evento?", answer: 'Depende del modelo: la Estándar acomoda 6 personas, la Grande 10-12 y la XL 14-16. Para un evento de <strong>120 invitados</strong> necesitarías aproximadamente 20 mesas Estándar, 10-12 Grandes u 8 XL. Envíanos tu número de invitados y las dimensiones del venue y diseñamos el layout óptimo con pasillos de circulación, sin costo.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos reservar con <strong>2 a 4 semanas de anticipación</strong>. En temporada alta (primavera y otoño para bodas al aire libre) y para eventos de 200+ invitados, sugerimos apartar con <strong>1 a 2 meses</strong>. El inventario de mesas de madera es más limitado que el de mobiliario apilable, por lo que los modelos Premium y Farm se agotan primero. Un anticipo del 30% confirma tu fecha.' },
];

const specs = [
  { label: "Material", value: "Madera de pino tratada para exterior" },
  { label: "Acabado", value: "Lijado y barnizado a mano (protección UV y humedad)" },
  { label: "Formatos disponibles", value: "7 tamaños de mesa picnic + Farm americana" },
  { label: "Capacidad", value: "De 4 a 16 personas según modelo" },
  { label: "Bancas", value: "Integradas (excepto Farm Americana)" },
  { label: "Altura de mesa", value: "75 cm (estándar de banquete)" },
  { label: "Uso", value: "Interior y exterior — jardín, terraza, salón" },
  { label: "Logística", value: "Entrega, montaje, nivelación y recolección incluidos" },
  { label: "Mantenimiento", value: "Limpieza e inspección de barniz pre-evento" },
  { label: "Precio referencial", value: "Desde $400 por pieza / evento (según modelo)" },
];

const sidebarNav = [
  { name: "Mesas Picnic", href: null, active: true },
  { name: "Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { name: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Para Niños", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];

// PLACEHOLDER reviews — reemplazar por reseñas reales
const reviews = [
  { author: "Mariana G.", text: "Rentamos 18 mesas picnic para una boda campestre en un jardín de Tepoztlán. La madera se veía preciosa en las fotos y las bancas integradas nos ahorraron rentar sillas. Montaje impecable y puntual.", rating: 5, date: "2025-11-14" },
  { author: "Diego R.", text: "Para un festival gastronómico necesitábamos mesas resistentes para exterior. Las mesas picnic aguantaron todo el día bajo el sol sin problema. Excelente logística y asesoría de layout.", rating: 5, date: "2025-10-19" },
  { author: "Paulina M.", text: "Combinamos mesas Farm americanas con sillas Crossback para una boda de rancho. El resultado fue de revista. El equipo nos ayudó a calcular cantidades exactas para 140 invitados.", rating: 5, date: "2025-09-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesas Picnic de Madera para Eventos en CDMX",
    description: "Renta de mesas picnic de madera de pino para eventos al aire libre en CDMX: 8 modelos con bancas integradas, de 4 a 16 personas. Montaje incluido. Desde $400 por pieza.",
    url: "/servicios/mobiliario/mesas-picnic/picnic/",
    priceRange: { min: 400, max: 2100 },
    reviews,
    ratingValue: 5,
    reviewCount: 58,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Picnic", url: "/servicios/mobiliario/mesas-picnic/picnic/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mesas Picnic de Madera para Eventos en CDMX"
  description="Renta de mesas picnic de madera de pino para eventos al aire libre en CDMX: 8 modelos con bancas integradas, de 4 a 16 personas. Montaje incluido."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Madera de pino con bancas integradas"
    title='Renta de <span class="highlight">Mesas Picnic</span> de Madera para Eventos en CDMX'
    subtitle="Mesas picnic de madera de pino tratada para exterior, con bancas integradas en una sola pieza. 8 modelos desde 6 hasta 16 personas — estándar, grande, XL, premium, rústica, hexagonal, plegable y Farm americana. Entrega, montaje y nivelación incluidos. Desde $400 por pieza."
    primaryCTA={{ label: "Cotiza tus mesas picnic", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mesas picnic de madera para mi evento` }}
    cards={[
      {
        title: "Una familia completa de 8 modelos de mesa picnic",
        content: "<strong>Renta de mesas picnic de madera para eventos</strong> en 8 formatos que cubren cualquier necesidad: desde la <strong>Estándar de 6 personas</strong> —la más solicitada— hasta la <strong>XL de 14-16</strong> para banquetes masivos, más versiones premium, rústica, hexagonal, plegable y la Farm americana sin bancas. Somos aliados del <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">sitio especializado en mesas picnic</a>, lo que nos permite garantizar madera de calidad y acabado profesional en cada pieza.",
      },
      {
        title: "Pino tratado para exterior, montaje y logística incluidos",
        content: "<strong>Servicio integral de mesas picnic</strong> en madera de pino lijada y barnizada a mano, tratada para resistir sol y humedad. Cada pieza se entrega, monta y nivela por nuestro equipo según el layout aprobado. Ideales para jardines, terrazas y haciendas — combínalas con <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas Crossback</a>, <a href=\"/servicios/carpas/\">carpas</a> e <a href=\"/servicios/iluminacion/\">iluminación</a> para un montaje campestre completo.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas mesas picnic para tu evento al aire libre?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con layout personalizado"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MODELOS — Cards que linkan a cada ficha
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="modelos-heading">
    <div class="container">
      <SectionHeader
        id="modelos-heading"
        title="8 modelos de mesa picnic — elige el tuyo"
        subtitle="Cada modelo para un tipo de evento"
        description={[
          "Explora los detalles, capacidades y usos de cada modelo. Todos comparten la misma madera de pino tratada para exterior con bancas integradas (excepto la Farm) — la diferencia está en el tamaño, el acabado y el estilo."
        ]}
      />

      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="grid grid--4">
        <ProductCard
          name="Mesa Picnic Estándar"
          price="Desde $450"
          excerpt="1.80×1.50 m para 6 personas. Pino lijado y barnizado a mano con bancas integradas. El modelo más solicitado para jardines y ferias."
          href="/servicios/mobiliario/mesas-picnic/picnic/estandar/"
          image="/images/mobiliario/crossback-madera-01.avif"
          badge="Más solicitada"
          tags={["6 personas", "1.80×1.50 m", "Bancas integradas", "Exterior"]}
        />
        <ProductCard
          name="Mesa Picnic Grande"
          price="Desde $650"
          excerpt="2.40×1.50 m para 10-12 personas. Estructura reforzada para mesa principal, corporativos y festivales de larga duración."
          href="/servicios/mobiliario/mesas-picnic/picnic/grande/"
          image="/images/mobiliario/crossback-madera-02.avif"
          tags={["10-12 personas", "2.40×1.50 m", "Reforzada", "Festivales"]}
        />
        <ProductCard
          name="Mesa Picnic XL"
          price="Desde $900"
          excerpt="3.00×1.50 m para 14-16 personas. Refuerzo de acero y 4 bancas. Pensada para banquetes masivos y head tables imponentes."
          href="/servicios/mobiliario/mesas-picnic/picnic/xl/"
          image="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif"
          tags={["14-16 personas", "3.00×1.50 m", "Refuerzo acero", "Banquetes"]}
        />
        <ProductCard
          name="Mesa Picnic Premium"
          price="Desde $700"
          excerpt="1.80×1.50 m para 6 personas en pino seleccionado sin nudos y 4 manos de barniz. Acabado impecable para bodas VIP y fotografía."
          href="/servicios/mobiliario/mesas-picnic/picnic/premium/"
          image="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif"
          badge="Bodas VIP"
          tags={["6 personas", "Sin nudos", "4 manos barniz", "Fotografía"]}
        />
        <ProductCard
          name="Mesa Picnic Rústica"
          price="Desde $550"
          excerpt="1.80×1.50 m para 6 personas con barniz que resalta veta y nudos. La favorita del estilo boho, campestre y de haciendas."
          href="/servicios/mobiliario/mesas-picnic/picnic/rustica/"
          image="/images/mobiliario/candy-bar-boda-rustica-madera.avif"
          tags={["6 personas", "Veta natural", "Boho", "Haciendas"]}
        />
        <ProductCard
          name="Mesa Picnic Hexagonal"
          price="Desde $850"
          excerpt="Ø 1.80 m inscrito para 6-8 personas con 6 bancas sectoriales. Formato fotogénico favorito para bodas boho y sesiones de fotos."
          href="/servicios/mobiliario/mesas-picnic/picnic/hexagonal/"
          image="/images/mobiliario/barras-postres-mesa-vintage.avif"
          tags={["6-8 personas", "Hexagonal", "6 bancas", "Boho"]}
        />
        <ProductCard
          name="Mesa Picnic Plegable"
          price="Desde $400"
          excerpt="1.50×1.20 m para 4-6 personas. Bisagras de acero galvanizado, 25% más ligera y pliega a 12 cm. Ideal para bazares y pop-ups."
          href="/servicios/mobiliario/mesas-picnic/picnic/plegable/"
          image="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif"
          badge="Más económica"
          tags={["4-6 personas", "Plegable", "Ligera", "Pop-ups"]}
        />
        <ProductCard
          name="Mesa Farm Americana"
          price="Desde $750"
          excerpt="2.40×1.10 m para 8-10 personas SIN bancas. Se combina con sillas Tiffany, Crossback o Ghost para bodas campestres formales."
          href="/servicios/mobiliario/mesas-picnic/picnic/farm-americana/"
          image="/images/mobiliario/barras-postres-mesa-madera-rustica.avif"
          tags={["8-10 personas", "Sin bancas", "2.40×1.10 m", "Bodas formales"]}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Picnic y Madera</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas mesas picnic para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas picnic de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Mesas Picnic</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Mesa Picnic Estándar -->
          <section class="section section--alt" aria-labelledby="estandar-heading">
            <ServiceShowcase
    title="Mesa Picnic Estándar — La más solicitada"
    headingId="estandar-heading"
    badge="El modelo más pedido"
    subtitle="1.80×1.50 m para 6 personas: el formato clásico de pino con bancas integradas para jardines y ferias."
    tags={["6 Personas", "1.80×1.50 m", "Bancas integradas", "Exterior"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Mesa Estándar"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>Mesa Picnic Estándar</strong> es el corazón de la familia — presente en la mayoría de los eventos al aire libre que montamos. Con <strong>1.80×1.50 m acomoda 6 personas</strong> en dos bancas integradas de pino lijado y barnizado a mano. No necesitas rentar sillas: la mesa y las bancas viajan y se montan como una sola unidad, lo que agiliza la logística y reduce costos.</p>
      <p class="showcase__text">Fabricada en <strong>madera de pino tratada para exterior</strong>, resiste sol y humedad durante todo el día de evento. Es ideal para ferias gastronómicas, jardines, terrazas y bodas campestres informales. Conoce la ficha completa de la <a href="/servicios/mobiliario/mesas-picnic/picnic/estandar/">Mesa Picnic Estándar</a> o combínala con nuestra <a href="/servicios/iluminacion/">iluminación</a> para ambientar la noche.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa Picnic Estándar de pino con bancas integradas — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Detalle de madera de pino barnizada de la Mesa Picnic Estándar — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Mesa Picnic Estándar montada en jardín exterior — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Formatos Grande y XL -->
          <section class="section section--alt" aria-labelledby="grande-xl-heading">
            <ServiceShowcase
    title="Formatos Grande y XL — para grupos numerosos"
    headingId="grande-xl-heading"
    badge="Banquetes masivos"
    subtitle="De 10 a 16 comensales por mesa: la solución para festivales, corporativos y head tables imponentes."
