---
/**
 * ─── Mesa Farm Americana — Página de Variante (Nivel 6) ───
 * 2.40×1.10 m, 8-10 personas, pino barnizado SIN bancas — se combina con sillas.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Mesas Picnic > Farm Americana
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { label: "Farm Americana — 8-10 personas" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Mesa Farm Americana de pino para banquete de boda campestre — imagen de referencia" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Mesa Farm Americana montada en boda campestre formal — imagen de referencia" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Centros de mesa y candelabros sobre Mesa Farm Americana — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa Farm Americana combinada con sillas Crossback de madera — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa Farm Americana de madera en boda de rancho — imagen de referencia" },
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Detalle de madera de pino barnizada de la Mesa Farm Americana — imagen de referencia" },
];

const faqs = [
  {
    question: "¿Por qué la Mesa Farm Americana no trae bancas?",
    answer: "A diferencia de las mesas picnic tradicionales, la <strong>Mesa Farm Americana se entrega sin bancas integradas</strong> a propósito: su formato imperial de 2.40 m está pensado para <strong>bodas campestres formales</strong> donde las sillas definen el estilo. Esto te da libertad total para combinarla con sillas <a href=\"/servicios/mobiliario/sillas/crossback/\">Crossback</a>, Tiffany o Ghost según el look que busques. <strong>Las sillas se cotizan por separado.</strong>"
  },
  {
    question: "¿Con qué sillas combino la Mesa Farm Americana?",
    answer: "Las tres opciones más pedidas son las sillas <a href=\"/servicios/mobiliario/sillas/crossback/\">Crossback</a> de madera (para un look de rancho rústico-formal), las Tiffany (elegancia clásica de banquete) y las Ghost transparentes (montaje moderno y ligero). Cada silla transforma por completo el estilo de la mesa. <strong>Recuerda que las sillas se rentan y cotizan aparte de la mesa</strong> — dinos cuál prefieres y armamos el paquete completo."
  },
  {
    question: "¿Cuántas personas caben en la Mesa Farm Americana?",
    answer: "La <strong>Mesa Farm Americana de 2.40×1.10 m</strong> acomoda cómodamente <strong>8-10 personas</strong> con sus sillas: 4-5 comensales por lado. Su ancho de 1.10 m permite montar centros de mesa amplios y vajilla completa sin sacrificar espacio de servicio. Para otros formatos por mesa, revisa el resto de la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/\">familia de mesas picnic</a>."
  },
  {
    question: "¿Cuál es la diferencia con las mesas picnic con bancas?",
    answer: "Las mesas picnic tradicionales, como la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/estandar/\">Mesa Estándar</a>, llevan <strong>bancas integradas</strong> en una sola pieza, ideales para ferias y eventos casuales. La <strong>Farm Americana no trae bancas</strong>: es más larga, más ancha y está diseñada para banquetes formales con sillas independientes. Distinto propósito, distinto nivel de formalidad — y las sillas siempre se cotizan aparte."
  },
  {
    question: "¿El precio incluye montaje? ¿Y las sillas?",
    answer: "El precio <strong>desde $750 por mesa / evento</strong> incluye entrega, montaje, nivelación y recolección en CDMX y zona metropolitana. <strong>Las sillas NO están incluidas y se cotizan por separado</strong> según el modelo que elijas (Tiffany, Crossback o Ghost). Envíanos tu número de invitados y te armamos el paquete completo de mesas más sillas. Un anticipo del 30% confirma tu fecha y cantidad."
  },
];

const specs = [
  { label: "Medidas", value: "2.40 × 1.10 m" },
  { label: "Capacidad", value: "8-10 personas" },
  { label: "Material", value: "Madera de pino tratada para exterior" },
  { label: "Acabado", value: "Lijado y barnizado a mano" },
  { label: "Bancas", value: "SIN bancas — se combina con sillas" },
  { label: "Sillas sugeridas", value: "Tiffany, Crossback, Ghost (se cotizan aparte)" },
  { label: "Altura de mesa", value: "75 cm (estándar de banquete)" },
  { label: "Uso", value: "Bodas campestres formales — estilo farm/rancho" },
  { label: "Logística", value: "Entrega, montaje, nivelación y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $750 por pieza / evento" },
];

// PLACEHOLDER reviews — reemplazar por reseñas reales
const reviews = [
  { author: "Mariana G.", text: "Para nuestra boda de rancho rentamos 12 mesas Farm Americana con sillas Crossback. El look imperial quedó espectacular y la madera combinó perfecto con el estilo campestre formal. Nos encantó poder elegir las sillas aparte.", rating: 5, date: "2025-11-15" },
  { author: "Rodrigo M.", text: "Montamos hileras largas de mesas Farm Americana para un banquete de 100 personas. El formato de 2.40 m se ve imponente y elegante. El equipo nos asesoró con las sillas Tiffany y la iluminación colgante.", rating: 5, date: "2025-10-22" },
  { author: "Valeria T.", text: "Boda campestre formal con mesas Farm Americana y sillas Ghost transparentes. Que no traigan bancas fue justo lo que buscábamos para un montaje más sofisticado. Puntuales con la entrega y el montaje.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Farm Americana para Bodas en CDMX — 8-10 Personas",
    description: "Mesa Farm Americana de 2.40×1.10 m para 8-10 personas en madera de pino, sin bancas para combinar con sillas Tiffany, Crossback o Ghost. Formato imperial para bodas campestres formales en CDMX. Desde $750.",
    url: "/servicios/mobiliario/mesas-picnic/picnic/farm-americana/",
    priceRange: { min: 750, max: 1750 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Picnic", url: "/servicios/mobiliario/mesas-picnic/picnic/" },
    { name: "Farm Americana — 8-10 Personas", url: "/servicios/mobiliario/mesas-picnic/picnic/farm-americana/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Estándar", href: "/servicios/mobiliario/mesas-picnic/picnic/estandar/" },
  { name: "Mesa Grande", href: "/servicios/mobiliario/mesas-picnic/picnic/grande/" },
  { name: "Mesa XL", href: "/servicios/mobiliario/mesas-picnic/picnic/xl/" },
  { name: "Mesa Premium", href: "/servicios/mobiliario/mesas-picnic/picnic/premium/" },
  { name: "Mesa Rústica", href: "/servicios/mobiliario/mesas-picnic/picnic/rustica/" },
  { name: "Mesa Hexagonal", href: "/servicios/mobiliario/mesas-picnic/picnic/hexagonal/" },
  { name: "Mesa Plegable", href: "/servicios/mobiliario/mesas-picnic/picnic/plegable/" },
  { name: "Mesa Farm Americana", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Mesa Farm Americana para Bodas CDMX"
  description="Renta mesa Farm Americana 2.40×1.10 m en CDMX — 8-10 personas, madera de pino sin bancas para combinar con sillas Tiffany, Crossback o Ghost. Ideal bodas campestres formales. Desde $750."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El formato imperial para bodas de rancho"
    title='Mesa <span class="highlight">Farm Americana</span> — 8-10 Personas — Renta CDMX'
    subtitle="La Mesa Farm Americana de 2.40×1.10 m es el formato imperial para bodas campestres formales: mesa de 8-10 comensales en madera de pino, sin bancas integradas para que elijas tus sillas (Tiffany, Crossback o Ghost). Madera lijada y barnizada a mano, tratada para exterior. Montaje incluido. Desde $750."
    primaryCTA={{ label: "Cotizar mesa Farm Americana", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Farm Americana para mi evento` }}
    cards={[
      {
        title: "La mesa que eleva las bodas campestres formales",
        content: "La <strong>Mesa Farm Americana</strong> es nuestro formato imperial de madera: <strong>2.40×1.10 m para 8-10 personas</strong>, pensada para banquetes de rancho y bodas campestres de estilo formal. Se entrega <strong>sin bancas</strong> para que la combines con <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas Crossback</a>, Tiffany o Ghost (las sillas se cotizan aparte). Trabajamos con el <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">sitio especializado en mesas picnic</a> para garantizar madera de pino de calidad y acabado profesional en cada pieza.",
      },
      {
        title: "Pino tratado para exterior, sin bancas integradas",
        content: "Fabricada en <strong>madera de pino lijada y barnizada a mano</strong>, resiste sol y humedad durante todo el día de evento. Al no llevar bancas, tienes libertad total para definir el estilo del montaje con la silla que elijas. Complétala con <a href=\"/servicios/iluminacion/\">iluminación</a> colgante para la noche y con <a href=\"/servicios/carpas/\">carpas</a> como respaldo ante el clima.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Cuántas mesas Farm Americana necesitas? Te ayudamos con el layout y las sillas"
    subheadline="Asesoría de distribución sin costo — calculamos mesas, sillas y layout según tu venue y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Modelos de Mesa Picnic</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa Farm Americana para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Farm Americana`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Farm Americana en Bodas</h2>
            <p class="section__subtitle">Bodas campestres formales, banquetes y montajes de rancho en CDMX</p>
            <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Farm Americana</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué elegir la Farm Americana para tu boda campestre?"
    headingId="descripcion-heading"
    badge="El formato imperial de la madera para banquetes formales"
    tags={["2.40×1.10 m", "8-10 personas", "SIN bancas", "Se combina con sillas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El formato de 2.40×1.10 m tiene una presencia imponente. Con <strong>8-10 comensales</strong>, la Farm Americana es la mesa de las <strong>bodas campestres formales</strong> donde la madera y las sillas de diseño mandan. Su longitud permite montar hileras imperiales que se ven espectaculares, y su ancho de 1.10 m deja sitio holgado para centros de mesa amplios y servicio completo.</p>
      <p class="showcase__text">A diferencia de las mesas picnic con bancas, la Farm Americana se entrega <strong>sin bancas integradas</strong>: eso te da libertad total para combinarla con sillas <a href="/servicios/mobiliario/sillas/crossback/">Crossback</a> de rancho, Tiffany clásicas o Ghost transparentes. Cada elección de silla transforma el estilo del montaje. <strong>Ten presente que las sillas se cotizan por separado de la mesa.</strong></p>
      <p class="showcase__text">La <strong>madera de pino lijada y barnizada a mano</strong> aporta calidez rústica-formal, y el barniz protege la superficie contra manchas y humedad ambiental. Cada mesa se limpia e inspecciona antes de entregarse; si el barniz presenta desgaste notable, se retira del evento.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barras-postres-mesa-madera-rustica.avif" alt="Mesa Farm Americana de pino en banquete de boda campestre — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa Farm Americana combinada con sillas Crossback — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Centros de mesa y candelabros sobre la Mesa Farm Americana — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Mesa Farm Americana</h2>
            <p class="section__subtitle">Combinaciones con sillas, textiles e iluminación que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda de Rancho Formal</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas Farm Americana + sillas <a href="/servicios/mobiliario/sillas/crossback/">Crossback</a> de madera + camino de mesa de lino. El montaje que define las bodas campestres de estilo rancho. Las sillas se cotizan aparte.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Mesa Imperial Campestre</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Hileras largas de mesas Farm Americana en formato imperial + <a href="/servicios/iluminacion/">iluminación</a> colgante + <a href="/servicios/carpas/">carpa</a> de respaldo. Presencia total para banquetes numerosos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Banquete con Sillas de Diseño</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesa Farm Americana + sillas Tiffany o Ghost transparentes + centros florales altos. Elegancia moderna para bodas sofisticadas. Recuerda que las sillas se cotizan por separado.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Farm Americana</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Farm Americana"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El formato imperial de nuestra familia. 8-10 personas, sin bancas y lista para combinar con sillas Tiffany, Crossback o Ghost en bodas campestres formales."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas mesas y sillas necesitas para tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Farm Americana`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
