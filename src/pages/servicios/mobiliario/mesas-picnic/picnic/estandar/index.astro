---
/**
 * ─── Mesa Picnic Estándar — Página de Variante (Nivel 6) ───
 * 1.80×1.50 m, 6 personas, pino barnizado con bancas integradas.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Mesas Picnic > Estándar
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { label: "Estándar — 6 personas" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa Picnic Estándar de pino con bancas integradas — imagen de referencia" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Detalle de madera de pino barnizada de la Mesa Picnic Estándar — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mesa Picnic Estándar montada en jardín exterior — imagen de referencia" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa Picnic Estándar en boda campestre rústica — imagen de referencia" },
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Mesa Picnic Estándar de madera en evento al aire libre — imagen de referencia" },
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Bancas integradas de pino de la Mesa Picnic Estándar — imagen de referencia" },
];

const faqs = [
  {
    question: "¿Cuántas personas caben en la Mesa Picnic Estándar?",
    answer: "La <strong>Mesa Picnic Estándar de 1.80×1.50 m</strong> acomoda cómodamente <strong>6 personas</strong> — 3 en cada banca integrada. Es el formato ideal para distribuir grupos en jardines y ferias sin necesidad de sillas adicionales. Para grupos más numerosos por mesa, revisa la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/grande/\">Mesa Grande</a> (10-12) o la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/xl/\">Mesa XL</a> (14-16)."
  },
  {
    question: "¿Las bancas vienen integradas o se rentan aparte?",
    answer: "Las <strong>bancas vienen integradas</strong> a la estructura de la mesa en una sola pieza de madera de pino. No necesitas rentar sillas por separado, lo que simplifica la logística y reduce el costo total. Si prefieres mesa con sillas independientes, considera la <a href=\"/servicios/mobiliario/mesas-picnic/picnic/farm-americana/\">Mesa Farm Americana</a>, que se entrega sin bancas."
  },
  {
    question: "¿Es apta para exterior y aguanta el sol?",
    answer: "Sí. La Mesa Picnic Estándar está fabricada en <strong>madera de pino lijada y barnizada a mano</strong>, con tratamiento para exterior que resiste sol, roce y humedad ambiental durante toda la jornada de evento. Recomendamos no exponerla a lluvia prolongada; para clima incierto, complementa con nuestras <a href=\"/servicios/carpas/\">carpas profesionales</a>."
  },
  {
    question: "¿Cuántas mesas estándar necesito para 120 invitados?",
    answer: "Con 6 personas por mesa, para <strong>120 invitados</strong> necesitas <strong>20 mesas Picnic Estándar</strong>. La fórmula es invitados ÷ 6 = número de mesas. Te recomendamos 1-2 mesas extra de reserva. Envíanos las dimensiones de tu venue y diseñamos el layout con pasillos de circulación adecuados, sin costo."
  },
  {
    question: "¿El precio incluye montaje y entrega?",
    answer: "Sí. El precio <strong>desde $450 por mesa / evento</strong> incluye entrega, montaje, nivelación y recolección en CDMX y zona metropolitana. El precio final depende del volumen y la ubicación del venue. Un anticipo del 30% confirma tu fecha y cantidad."
  },
];

const specs = [
  { label: "Medidas", value: "1.80 × 1.50 m (mesa + 2 bancas)" },
  { label: "Capacidad", value: "6 personas" },
  { label: "Material", value: "Madera de pino tratada para exterior" },
  { label: "Acabado", value: "Lijado y barnizado a mano" },
  { label: "Bancas", value: "2 bancas integradas en una sola pieza" },
  { label: "Altura de mesa", value: "75 cm (estándar de banquete)" },
  { label: "Uso", value: "Interior y exterior — jardín, terraza, feria" },
  { label: "Logística", value: "Entrega, montaje, nivelación y recolección incluidos" },
  { label: "Mantenimiento", value: "Limpieza e inspección de barniz pre-evento" },
  { label: "Precio referencial", value: "Desde $450 por pieza / evento" },
];

// PLACEHOLDER reviews — reemplazar por reseñas reales
const reviews = [
  { author: "Renata V.", text: "Rentamos 15 mesas picnic estándar para una feria gastronómica en un parque. Las bancas integradas fueron un acierto: cero sillas sueltas y montaje rapidísimo. La madera se veía muy bien.", rating: 5, date: "2025-11-08" },
  { author: "Óscar L.", text: "Para el cumpleaños de mi papá en el jardín usamos 8 mesas estándar. Cabían 6 holgados y aguantaron todo el día bajo el sol sin problema. Excelente relación calidad-precio.", rating: 5, date: "2025-10-11" },
  { author: "Tania S.", text: "Boda campestre íntima de 90 personas con 15 mesas estándar. El equipo calculó las cantidades exactas y montó todo puntual. Las fotos quedaron preciosas con la madera natural.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Picnic Estándar para Eventos en CDMX — 6 Personas",
    description: "Mesa picnic estándar de 1.80×1.50 m para 6 personas en madera de pino con bancas integradas. El modelo más solicitado para jardines y ferias en CDMX. Desde $450.",
    url: "/servicios/mobiliario/mesas-picnic/picnic/estandar/",
    priceRange: { min: 450, max: 1000 },
    reviews,
    ratingValue: 5,
    reviewCount: 54,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Picnic", url: "/servicios/mobiliario/mesas-picnic/picnic/" },
    { name: "Estándar — 6 Personas", url: "/servicios/mobiliario/mesas-picnic/picnic/estandar/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Estándar", href: null, active: true },
  { name: "Mesa Grande", href: "/servicios/mobiliario/mesas-picnic/picnic/grande/" },
  { name: "Mesa XL", href: "/servicios/mobiliario/mesas-picnic/picnic/xl/" },
  { name: "Mesa Premium", href: "/servicios/mobiliario/mesas-picnic/picnic/premium/" },
  { name: "Mesa Rústica", href: "/servicios/mobiliario/mesas-picnic/picnic/rustica/" },
  { name: "Mesa Hexagonal", href: "/servicios/mobiliario/mesas-picnic/picnic/hexagonal/" },
  { name: "Mesa Plegable", href: "/servicios/mobiliario/mesas-picnic/picnic/plegable/" },
  { name: "Mesa Farm Americana", href: "/servicios/mobiliario/mesas-picnic/picnic/farm-americana/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Mesa Picnic Estándar 6 Personas CDMX"
  description="Renta mesa picnic estándar 1.80×1.50 m en CDMX — 6 personas, pino con bancas integradas. El modelo más solicitado para jardines y ferias. Desde $450."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El modelo más solicitado de la familia"
    title='Mesa Picnic <span class="highlight">Estándar</span> — 6 Personas — Renta CDMX'
    subtitle="La Mesa Picnic Estándar de 1.80×1.50 m es el formato clásico para eventos al aire libre: 6 comensales en bancas de pino integradas, sin necesidad de sillas. Madera lijada y barnizada a mano, tratada para exterior. Montaje incluido. Desde $450."
    primaryCTA={{ label: "Cotizar mesa estándar", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Estándar para mi evento` }}
    cards={[
      {
        title: "El caballo de batalla de los eventos al aire libre",
        content: "La <strong>Mesa Picnic Estándar</strong> es el modelo más pedido de nuestra familia de mesas de madera. Con <strong>1.80×1.50 m y 6 personas</strong>, resuelve jardines, ferias, bodas campestres y reuniones sin rentar sillas por separado. Trabajamos con el <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">sitio especializado en mesas picnic</a> para garantizar madera de pino de calidad y acabado profesional en cada pieza.",
      },
      {
        title: "Pino tratado para exterior con bancas integradas",
        content: "Fabricada en <strong>madera de pino lijada y barnizada a mano</strong>, resiste sol y humedad durante todo el día de evento. Las <strong>bancas integradas</strong> viajan y se montan como una sola unidad, agilizando la logística. Combínala con <a href=\"/servicios/iluminacion/\">iluminación</a> para la noche y con <a href=\"/servicios/carpas/\">carpas</a> como respaldo ante el clima.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Cuántas mesas estándar necesitas? Te ayudamos a calcular el layout"
    subheadline="Asesoría de distribución sin costo — calcula cantidad exacta según tu venue y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Modelos de Mesa Picnic</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa Picnic Estándar para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic Estándar`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Picnic Estándar en Eventos</h2>
            <p class="section__subtitle">Ferias, jardines y bodas campestres en CDMX</p>
            <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Picnic Estándar</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la Estándar es la mesa picnic más elegida?"
    headingId="descripcion-heading"
    badge="El formato clásico de la madera para eventos"
    tags={["1.80×1.50 m", "6 personas", "Bancas integradas", "Jardines y ferias"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El formato de 1.80×1.50 m no es casual: es el equilibrio perfecto entre capacidad y espacio de circulación. Con <strong>6 comensales</strong>, cada persona tiene sitio holgado para plato, bebida y convivencia, mientras la mesa sigue siendo lo bastante compacta para distribuir muchas unidades en un jardín o feria sin saturar los pasillos.</p>
      <p class="showcase__text">La <strong>madera de pino lijada y barnizada a mano</strong> aporta la calidez rústica que buscan las bodas campestres y los eventos al aire libre. El barniz protege la superficie contra manchas de bebida y la humedad ambiental, y las <strong>bancas integradas</strong> eliminan la necesidad de sillas, simplificando el montaje y la logística.</p>
      <p class="showcase__text">Cada mesa se limpia e inspecciona antes de entregarse; si el barniz presenta desgaste notable, se retira del evento. Es nuestro modelo con mayor inventario, por lo que garantiza disponibilidad incluso para eventos simultáneos en temporada alta.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa Picnic Estándar de pino montada en evento — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Mesa Picnic Estándar en jardín exterior — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Detalle de bancas integradas de la Mesa Picnic Estándar — imagen de referencia" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Mesa Estándar</h2>
            <p class="section__subtitle">Combinaciones de estilo, textiles y complementos que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Feria Gastronómica</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas estándar en hileras estilo <strong>mesa comunal</strong> + <a href="/servicios/iluminacion/">iluminación</a> colgante. El montaje que domina las ferias de comida y los food-truck parks al aire libre.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Campestre</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesa estándar + camino de mesa de lino + centros florales silvestres + <a href="/servicios/carpas/">carpa</a> de respaldo. Calidez rústica sin necesidad de sillas extra.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Jardín Familiar</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas estándar dispersas por el jardín + <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a> como zona de descanso. El formato ideal para cumpleaños y reuniones informales.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Picnic Estándar</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Picnic Estándar"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El formato más pedido de nuestra familia. 6 personas, bancas integradas, listo para jardines y ferias al aire libre."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas mesas necesitas para tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Picnic Estándar`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados y te calculamos mesas y layout al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Modelos de mesa picnic y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Modelos de Mesa Picnic</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
