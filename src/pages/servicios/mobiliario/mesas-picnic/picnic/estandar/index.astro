            Enviar por WhatsApp
          </button>
        </form>
        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta en 30 min</h3>
            <p class="reserva-card__text">Te contactamos por WhatsApp con precio exacto y layout sugerido en menos de 30 minutos.</p>
          </div>
          <div class="reserva-card">
            <h3 class="reserva-card__title">Asesoría de layout</h3>
            <p class="reserva-card__text">Te calculamos la cantidad exacta de mesas según tu venue y número de invitados, sin costo.</p>
          </div>
          <div class="reserva-card">
            <h3 class="reserva-card__title">Montaje incluido</h3>
            <p class="reserva-card__text">Entrega, montaje, nivelación y recolección incluidos en CDMX y zona metropolitana.</p>
          </div>
          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <ReservaFormScript />

