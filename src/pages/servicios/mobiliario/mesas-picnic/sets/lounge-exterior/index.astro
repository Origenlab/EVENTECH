---
/**
 * ─── Set Lounge Exterior — Ficha de Producto (Nivel 6) ───
 * Mesa baja de pino (45 cm) + 4 módulos tapizados en lona impermeable 600D.
 * 6 personas, zona VIP, 4 colores: crudo, negro, beige y terracota.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Set Lounge Exterior
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Set Lounge Exterior" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Zona lounge de madera en jardín exterior para evento (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa baja de madera rústica para zona VIP al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mobiliario de madera vintage en área de descanso (imagen de referencia)" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Set de madera elegante para lounge de boda (imagen de referencia)" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Ambientación decorativa sobre mesa baja de madera (imagen de referencia)" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mobiliario de pino natural para zona lounge exterior (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Qué incluye el Set Lounge Exterior?",
    answer: "Incluye una <strong>mesa baja de pino de 45 cm de altura</strong> y <strong>4 módulos tapizados en lona impermeable 600D</strong> para 6 personas. Es una zona de estar completa al aire libre: la mesa de centro y los asientos modulares que crean el área VIP o chill-out de tu evento.",
  },
  {
    question: "¿De qué colores está disponible?",
    answer: "Los módulos tapizados están disponibles en <strong>4 colores</strong>: <strong>crudo, negro, beige y terracota</strong>. Elige el que mejor combine con tu paleta — el crudo y el beige para bodas y estilos claros, el negro para eventos corporativos o de noche, y el terracota para ambientes cálidos y boho. La mesa baja es de pino natural en todos los casos.",
  },
  {
    question: "¿La tapicería aguanta estar al aire libre?",
    answer: "Sí. Los módulos están tapizados en <strong>lona impermeable 600D</strong>, una tela resistente pensada para exteriores que soporta sol y humedad durante toda la jornada del evento. Aun así, recomendamos ubicar el lounge bajo carpa o sombra si se prevé lluvia intensa. Consulta nuestras <a href=\"/servicios/carpas/\">carpas</a> como respaldo.",
  },
  {
    question: "¿Para cuántas personas es el set?",
    answer: "El Set Lounge Exterior está dimensionado para <strong>6 personas</strong> alrededor de la mesa baja. Si necesitas una zona de estar más amplia, puedes rentar varios sets o combinarlo con nuestras <a href=\"/servicios/mobiliario/salas-lounge/\">salas lounge</a> para ampliar los asientos en la misma línea estética.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, montaje profesional y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Montamos la mesa y acomodamos los 4 módulos donde definas tu zona VIP, y recogemos todo al terminar.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. Los sets con asientos tapizados son de los primeros en agotarse, así que en temporada alta (noviembre a febrero) sugerimos apartar con 3 a 4 semanas. Un anticipo confirma tu fecha y el color de tapicería que elijas.",
  },
];

const specs = [
  { label: "Incluye", value: "Mesa baja de pino (45 cm) + 4 módulos tapizados" },
  { label: "Altura de la mesa", value: "45 cm (mesa baja de centro)" },
  { label: "Módulos", value: "4 tapizados en lona impermeable 600D" },
  { label: "Colores de tapicería", value: "Crudo, negro, beige y terracota" },
  { label: "Capacidad", value: "6 personas" },
  { label: "Material", value: "Pino natural (mesa) + lona 600D (módulos)" },
  { label: "Ideal para", value: "Zona VIP, chill-out y área de descanso al aire libre" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $2,500 por set / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Ximena Robles", text: "El Set Lounge Exterior en terracota fue el rincón favorito de nuestra boda en jardín. Los módulos son cómodos de verdad y aguantaron todo el día bajo el sol sin decolorarse. La mesa baja de pino le dio un toque cálido precioso.", rating: 5, date: "2025-11-12" },
  { author: "Fernando Aguilar", text: "Rentamos dos sets en negro para la zona VIP de un evento corporativo de noche. Se veían elegantísimos y la lona impermeable resistió el sereno sin problema. Montaje y recolección impecables.", rating: 5, date: "2025-10-08" },
  { author: "Lucía Bernal", text: "Pedí el lounge en crudo para el chill-out de un cumpleaños en terraza. Combinó perfecto con la decoración clara y los invitados no querían levantarse de ahí. Muy recomendable para crear una zona de descanso.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Lounge Exterior de Madera en CDMX — Zona VIP 6 Personas",
    description: "Set Lounge Exterior: mesa baja de pino (45 cm) + 4 módulos tapizados en lona impermeable 600D para 6 personas. Zona VIP en 4 colores. Desde $2,500.",
    url: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/",
    priceRange: { min: 2500, max: 5500 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Set Lounge Exterior", url: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  { name: "Set Comedor Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  { name: "Set Lounge Exterior", href: null, active: true },
  { name: "Mesa Alta Cocktail", href: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  { name: "Banca Picnic Individual", href: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  { name: "Barra de Madera", href: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Set Lounge Exterior de Madera CDMX"
  description="Renta Set Lounge Exterior en CDMX: mesa baja de pino (45 cm) + 4 módulos tapizados en lona impermeable 600D para 6 personas. Zona VIP en 4 colores. Desde $2,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Tu zona VIP al aire libre"
    title='Set Lounge <span class="highlight">Exterior</span> de Madera — Zona VIP — Renta CDMX'
    subtitle="El Set Lounge Exterior combina una mesa baja de pino de 45 cm con 4 módulos tapizados en lona impermeable 600D para 6 personas. Crea la zona VIP o chill-out de tu evento al aire libre, en 4 colores: crudo, negro, beige y terracota. Desde $2,500."
    primaryCTA={{ label: "Cotizar Set Lounge Exterior", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Lounge Exterior de madera para mi evento` }}
    cards={[
      {
        title: "Una zona de estar completa para el aire libre",
        content: "El <strong>Set Lounge Exterior</strong> es una zona de descanso lista para usar: una <strong>mesa baja de pino de 45 cm de altura</strong> con <strong>4 módulos tapizados</strong> para 6 personas. Es el rincón donde los invitados se relajan entre baile y baile, el chill-out de un cumpleaños o el área VIP de una boda. La combinación de madera natural y asientos suaves crea un ambiente acogedor en cualquier jardín o terraza.",
      },
      {
        title: "Lona impermeable 600D en 4 colores",
        content: "Los módulos están tapizados en <strong>lona impermeable 600D</strong>, resistente al sol y la humedad, disponible en <strong>crudo, negro, beige y terracota</strong> para adaptarse a tu paleta. <strong>Entrega, montaje y recolección incluidos</strong> dentro de CDMX y Edomex, sin cargos por traslado ni tiempo extra. Montamos tu zona VIP donde la definas y la recogemos al terminar. Desde $2,500 el set.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Quieres una zona VIP o chill-out que enamore a tus invitados?"
    subheadline="Cotiza el Set Lounge Exterior — mesa baja de pino y 4 módulos tapizados, en el color que elijas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set Lounge Exterior para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Lounge Exterior de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Lounge Exterior en Eventos Reales</h2>
            <p class="section__subtitle">Zonas VIP, chill-out y áreas de descanso al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Lounge Exterior</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué una zona lounge cambia por completo tu evento?"
    headingId="descripcion-heading"
    badge="Mesa baja + 4 módulos tapizados"
    tags={["Mesa baja 45 cm", "Lona 600D", "4 colores", "Zona VIP"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Un evento no vive solo de la pista y las mesas de comida: la <strong>zona de estar</strong> es donde los invitados conversan, descansan y se toman las mejores fotos relajadas. El <strong>Set Lounge Exterior</strong> crea ese rincón con una <strong>mesa baja de pino de 45 cm</strong> y <strong>4 módulos tapizados</strong> para 6 personas, todo montado y listo en tu ubicación.</p>
      <p class="showcase__text">Los módulos van en <strong>lona impermeable 600D</strong> —resistente al sol y la humedad— en cuatro colores para adaptarse a tu paleta: crudo, negro, beige y terracota. La mesa de pino natural comparte el acabado del resto de la línea, especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>. Si tu zona VIP necesita más asientos, amplíala con nuestras <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a>.</p>
      <p class="showcase__text">Ideal para el chill-out de bodas, el área VIP de un corporativo de noche o un rincón de descanso en un cumpleaños en terraza. Súmale una <a href="/servicios/mobiliario/barras/">barra</a> cerca para que sea la zona más concurrida del evento. Entrega, montaje y recolección incluidos, sin límite de tiempo.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Zona lounge de madera en jardín exterior para evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Mesa baja de madera rústica para zona VIP al aire libre (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mobiliario de madera vintage en área de descanso (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con el Set Lounge Exterior</h2>
            <p class="section__subtitle">Ideas de zona VIP y chill-out que funcionan al aire libre</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Chill-out de Boda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Lounge en crudo o beige + <a href="/servicios/iluminacion/">iluminación cálida</a> + cojines extra. El rincón donde los invitados descansan entre baile y baile, con estética boho-chic.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Área VIP Corporativa</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Lounge en negro + <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a> adicionales. Una zona ejecutiva de descanso o networking para eventos de noche, elegante y cómoda.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Terraza Boho</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Lounge en terracota + <a href="/servicios/carpas/">carpa</a> ligera + plantas. El ambiente cálido para un cumpleaños o reunión en terraza, resguardado del sol y muy fotogénico.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Lounge Exterior</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Lounge Exterior"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["La zona VIP al aire libre. Mesa baja de pino y 4 módulos tapizados en lona 600D, 4 colores, montaje y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a elegir el color y calcular cuántos sets necesita tu zona VIP.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el Set Lounge Exterior de madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el color y el tamaño de tu zona de estar y te enviamos precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

