---
/**
 * ─── Set Comedor Exterior — Ficha de Producto (Nivel 6) ───
 * Mesa rectangular 1.80×0.90 m + 6 sillas crossback de haya lacada en blanco.
 * 6 personas, cena formal al aire libre — el set más fotogénico.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Set Comedor Exterior
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Set Comedor Exterior" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa rectangular de madera con sillas para cena al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Comedor de madera de pino natural montado en jardín (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa de madera rústica para cena formal de boda (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa de madera vintage servida para comedor exterior (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Mesa de madera rústica como comedor al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Comedor de madera en jardín exterior para evento (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Qué incluye el Set Comedor Exterior?",
    answer: "Incluye una <strong>mesa rectangular de 1.80 × 0.90 m</strong> de pino natural y <strong>6 sillas crossback de haya lacada en blanco</strong>, para 6 comensales sentados. Es un set de comedor formal completo: mesa y sillas coordinadas que llegan montadas en tu ubicación.",
  },
  {
    question: "¿De qué material y color son las sillas?",
    answer: "Las 6 sillas son <strong>crossback de haya lacada en blanco</strong>, con el respaldo cruzado característico que aporta un aire rústico-elegante. Combinan de forma natural con la mesa de pino y con paletas de boda claras. Si prefieres el crossback en otro acabado, revisa nuestra sección de <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas crossback</a>.",
  },
  {
    question: "¿Por qué es 'el más fotogénico'?",
    answer: "La combinación de <strong>mesa rectangular de madera + sillas crossback blancas</strong> es una de las imágenes más buscadas para bodas y cenas al aire libre: líneas limpias, madera natural y el respaldo cruzado de la crossback crean una composición muy equilibrada en cámara. Es el set que mejor luce en fotos de mesa larga y banquetes tipo farm.",
  },
  {
    question: "¿Cuántos sets necesito para mi número de invitados?",
    answer: "Cada Set Comedor Exterior sienta a <strong>6 personas</strong>. Para 24 invitados necesitas 4 sets, para 36 invitados 6 sets, y así sucesivamente. Puedes montar varias mesas en línea para un efecto de mesa larga o distribuirlas por el espacio. Te ayudamos a calcular la cantidad y el layout según tu venue.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, montaje profesional y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Montamos la mesa y acomodamos las 6 sillas donde indiques, y recogemos todo al terminar el evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. En temporada alta de bodas (noviembre a febrero) los sets con sillas incluidas se agotan primero, así que sugerimos apartar con 3 a 4 semanas. Un anticipo confirma tu fecha y bloquea las piezas.",
  },
];

const specs = [
  { label: "Incluye", value: "Mesa rectangular 1.80 × 0.90 m + 6 sillas crossback" },
  { label: "Sillas", value: "6 crossback de haya lacada en blanco" },
  { label: "Medidas de la mesa", value: "1.80 × 0.90 m" },
  { label: "Capacidad", value: "6 personas sentadas" },
  { label: "Material", value: "Pino natural (mesa) + haya lacada (sillas)" },
  { label: "Acabado", value: "Lijado y barnizado a mano · sillas lacadas en blanco" },
  { label: "Ideal para", value: "Cena formal al aire libre, bodas — el más fotogénico" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $1,800 por set / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Andrea Lozano", text: "Montamos 5 Sets Comedor Exterior en línea para la cena de nuestra boda en una hacienda. La mesa larga de madera con las sillas crossback blancas se veía espectacular, justo la foto que teníamos en Pinterest. Todo llegó montado y perfecto.", rating: 5, date: "2025-11-16" },
  { author: "Rodrigo Peña", text: "Rentamos 3 sets para una cena formal en jardín. Las sillas crossback son muy cómodas y la mesa de pino aguantó toda la noche sin problema. El equipo montó y recogió sin que nos ocupáramos de nada.", rating: 5, date: "2025-10-10" },
  { author: "Sofía Camacho", text: "El set más bonito para fotos, sin duda. La madera y el blanco de las sillas combinaron con nuestra decoración clara. Muy recomendable para una cena al aire libre con estilo.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Comedor Exterior de Madera en CDMX — 6 Personas",
    description: "Set Comedor Exterior: mesa rectangular 1.80×0.90 m + 6 sillas crossback de haya lacada en blanco. El set más fotogénico para cenas al aire libre y bodas. Desde $1,800.",
    url: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/",
    priceRange: { min: 1800, max: 4000 },
    reviews,
    ratingValue: 5,
    reviewCount: 41,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Set Comedor Exterior", url: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  { name: "Set Comedor Exterior", href: null, active: true },
  { name: "Set Lounge Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  { name: "Mesa Alta Cocktail", href: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  { name: "Banca Picnic Individual", href: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  { name: "Barra de Madera", href: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Set Comedor Exterior de Madera CDMX"
  description="Renta Set Comedor Exterior en CDMX: mesa rectangular 1.80×0.90 m + 6 sillas crossback de haya lacada en blanco. El set más fotogénico para cenas al aire libre. Desde $1,800."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El set más fotogénico para cena formal"
    title='Set Comedor <span class="highlight">Exterior</span> de Madera — 6 Personas — Renta CDMX'
    subtitle="El Set Comedor Exterior combina una mesa rectangular de 1.80 × 0.90 m de pino natural con 6 sillas crossback de haya lacada en blanco. Es el set más fotogénico para una cena formal al aire libre y el favorito para bodas de mesa larga. Desde $1,800."
    primaryCTA={{ label: "Cotizar Set Comedor Exterior", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Comedor Exterior de madera para mi evento` }}
    cards={[
      {
        title: "Mesa de pino y 6 sillas crossback, coordinadas",
        content: "El <strong>Set Comedor Exterior</strong> es un comedor formal completo: una <strong>mesa rectangular de 1.80 × 0.90 m</strong> en pino natural y <strong>6 sillas crossback de haya lacada en blanco</strong>. Todo llega montado y coordinado, listo para servir una cena de 6 comensales al aire libre. La combinación de madera cálida y el blanco de las sillas es una de las imágenes más buscadas para bodas.",
      },
      {
        title: "El set que mejor luce en fotos de mesa larga",
        content: "Cuando montas <strong>varios sets en línea</strong> creas una mesa larga tipo farm que domina cualquier jardín o hacienda. Las líneas limpias de la mesa rectangular y el respaldo cruzado de la <strong>silla crossback</strong> componen una escena muy equilibrada en cámara. <strong>Entrega, montaje y recolección incluidos</strong> en CDMX y Edomex, sin cargos por traslado. Desde $1,800 el set.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Una cena formal al aire libre o una boda de mesa larga?"
    subheadline="Cotiza el Set Comedor Exterior — mesa de pino y 6 sillas crossback, montadas y listas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set Comedor Exterior para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Comedor Exterior de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Comedor Exterior en Eventos Reales</h2>
            <p class="section__subtitle">Cenas formales, bodas de mesa larga y banquetes al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Comedor Exterior</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué el Set Comedor Exterior es el favorito de las bodas?"
    headingId="descripcion-heading"
    badge="Mesa de pino + 6 sillas crossback"
    tags={["1.80 × 0.90 m", "6 sillas crossback", "Cena formal", "El más fotogénico"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Este set resuelve mesa y asientos de un tirón: una <strong>mesa rectangular de 1.80 × 0.90 m</strong> en pino natural con <strong>6 sillas crossback de haya lacada en blanco</strong> ya coordinadas. No tienes que rentar la mesa por un lado y las sillas por otro ni preocuparte por que combinen — llegan pensadas como conjunto y montadas en tu ubicación.</p>
      <p class="showcase__text">La estética es su gran fuerte. La madera de pino barnizada a mano, misma línea que la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>, junto al respaldo cruzado de la <strong>silla crossback blanca</strong>, componen la imagen de mesa larga que domina las bodas al aire libre. Si quieres variar el acabado de las sillas, revisa nuestras <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> en otros tonos.</p>
      <p class="showcase__text">Monta varios sets en línea para una mesa imperial, o distribúyelos por el jardín para grupos. Complementa el montaje con una <a href="/servicios/mobiliario/barras/">barra</a> para el coctel de recepción. Entrega, montaje y recolección incluidos, sin límite de tiempo durante tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Mesa rectangular de madera con sillas para cena al aire libre (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Comedor de madera de pino natural montado en jardín (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Mesa de madera rústica para cena formal de boda (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con el Set Comedor Exterior</h2>
            <p class="section__subtitle">Ideas que funcionan para bodas, cenas y eventos al aire libre</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda de Mesa Larga</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Varios sets en línea + <a href="/servicios/accesorios/manteleria-textiles/">camino de mesa</a> + centros florales bajos. La imperial de madera y sillas crossback blancas que llena las fotos de boda.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena Corporativa</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Sets distribuidos por grupos + <a href="/servicios/iluminacion/">iluminación cálida</a> colgante. Una cena de empresa al aire libre con estética cuidada y sin aire de salón.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Recepción con Coctel</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Set Comedor Exterior para la cena + <a href="/servicios/mobiliario/barras/">barra de madera</a> para el coctel. Un montaje completo que fluye del recibimiento a la mesa sin cambiar de estilo.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Comedor Exterior</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Comedor Exterior"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El comedor formal al aire libre. Mesa de pino de 1.80 × 0.90 m y 6 sillas crossback blancas, montaje y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántos sets necesitas para tu mesa larga.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el Set Comedor Exterior de madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados y te calculamos sets, layout y precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
