---
/**
 * ─── Sets y Complementos de Madera — Hub de Familia (Nivel 5) ───
 * 6 modelos llave en mano: set picnic completo, comedor exterior, lounge
 * exterior VIP, mesa alta cocktail, banca individual y barra de madera.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos" },
];

const faqs = [
  { question: "¿Qué diferencia hay entre un set y una mesa suelta?", answer: 'Un <strong>set</strong> resuelve el montaje completo en una sola cotización: no rentas solo la mesa, sino la mesa más los complementos que la acompañan. El <strong>Set Picnic Completo</strong> llega con mantelería de algodón, cojines, centro decorativo y ambientación; el <strong>Set Comedor Exterior</strong> incluye la mesa rectangular y 6 sillas crossback; el <strong>Set Lounge Exterior</strong> combina mesa baja de pino y 4 módulos tapizados. Los complementos —<strong>mesa alta cocktail</strong>, <strong>banca individual</strong> y <strong>barra de madera</strong>— se rentan sueltos para sumar a cualquier montaje. Toda la familia comparte el mismo pino natural lijado y barnizado a mano.' },
  { question: "¿Cuántas personas cubre cada set?", answer: 'El <strong>Set Picnic Completo</strong>, el <strong>Comedor Exterior</strong> y el <strong>Lounge Exterior</strong> están pensados para <strong>6 personas</strong> cada uno. La <strong>Mesa Alta Cocktail</strong> acomoda hasta <strong>5 personas de pie</strong> sin sillas, ideal para coctel de recepción. La <strong>Banca Picnic Individual</strong> sienta a <strong>3 personas</strong> y funciona como asiento autónomo o complemento de las mesas. La <strong>Barra de Madera</strong> es una estación de servicio, no de comensales. Puedes combinar varios sets en un mismo evento —te ayudamos a calcular cuántos necesitas según tu número de invitados.' },
  { question: "¿Los sets incluyen entrega y montaje?", answer: 'Sí. Todos los sets y complementos incluyen <strong>entrega, montaje profesional y recolección</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Nuestro equipo lleva las piezas a tu ubicación —jardín, terraza, hacienda, parque o salón—, las monta donde indiques y las recoge al finalizar. El precio que cotizamos es el precio final. La entrega promedio toma de 2 a 3 horas antes del evento.' },
  { question: "¿De qué colores está disponible el Set Lounge Exterior?", answer: 'El <strong>Set Lounge Exterior</strong> usa módulos tapizados en <strong>lona impermeable 600D</strong> disponible en <strong>4 colores</strong>: crudo, negro, beige y terracota. La mesa baja es de pino natural (45 cm de altura). Es la opción para crear una zona VIP o de descanso al aire libre. Complementa perfectamente con nuestras <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a> cuando necesitas más asientos en la misma estética.' },
  { question: "¿La Barra de Madera incluye bartender o servicio de bebidas?", answer: 'No. La <strong>Barra de Madera</strong> (2.00 × 0.60 × 1.10 m con estante trasero) se renta como <strong>mueble de estación</strong>: la estructura de madera para coctelería, candy bar o activación de marca. No incluye bartender, cristalería ni servicio de bebidas. Si necesitas una barra equipada con personal, revisa nuestra sección de <a href="/servicios/mobiliario/barras/">barras para eventos</a>, donde encontrarás opciones con servicio integral.' },
  { question: "¿Puedo combinar los sets con otras mesas de madera?", answer: 'Sí, es lo más habitual. Los sets y complementos comparten el mismo acabado de pino natural que el resto del catálogo de <a href="/servicios/mobiliario/mesas-picnic/">mesas picnic y madera</a>, por lo que combinan sin romper la estética. Un montaje típico usa mesas picnic estándar para los invitados, un Set Lounge Exterior para la zona VIP y una Barra de Madera para el coctel. Todo se cotiza y entrega en una sola visita.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong> para garantizar disponibilidad del set completo. En temporada alta (<strong>noviembre a febrero</strong>) y para eventos grandes, sugerimos apartar con <strong>3 a 4 semanas</strong>. Los sets con asientos —comedor y lounge— son los que se agotan primero. Un anticipo confirma tu fecha y bloquea las piezas para tu evento.' },
];

const specs = [
  { label: "Familia", value: "6 sets y complementos de madera" },
  { label: "Material base", value: "Pino nacional lijado y barnizado a mano" },
  { label: "Capacidad", value: "De 3 a 6 personas según el set" },
  { label: "Sets con asiento", value: "Comedor (6 sillas crossback) y Lounge (4 módulos)" },
  { label: "Mantelería y cojines", value: "Incluidos en el Set Picnic Completo" },
  { label: "Tapicería lounge", value: "Lona impermeable 600D · 4 colores" },
  { label: "Mesa alta cocktail", value: "Ø 70 cm × 110 cm · base de acero negro mate" },
  { label: "Barra de madera", value: "2.00 × 0.60 × 1.10 m · estante trasero incluido" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $200 (banca) a $2,500 (lounge)" },
];

const sidebarNav = [
  { name: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { name: "Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { name: "Sets y Complementos", href: null, active: true },
  { name: "Para Niños", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Mariana Cortés", text: "Rentamos el Set Picnic Completo para una pedida de mano en un parque. Llegó con mantelería, cojines y hasta el centro decorativo montado. No tuvimos que preocuparnos por nada, todo estaba listo cuando llegamos. Precioso y muy romántico.", rating: 5, date: "2025-11-14" },
  { author: "Diego Fuentes", text: "Para nuestra boda en jardín usamos el Set Comedor Exterior con las sillas crossback y una Barra de Madera para el coctel. La estética de la madera combinó perfecto con la decoración. Montaje puntual y recolección al terminar sin que moviéramos un dedo.", rating: 5, date: "2025-10-19" },
  { author: "Regina Ávalos", text: "El Set Lounge Exterior en terracota fue el hit de la zona VIP de un evento corporativo. Los módulos tapizados aguantaron todo el día al aire libre y se veían increíbles. Repetiremos sin duda.", rating: 5, date: "2025-09-27" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sets y Complementos de Madera para Eventos en CDMX",
    description: "Renta de sets y complementos de madera en CDMX: set picnic completo, comedor exterior, lounge VIP, mesa alta cocktail, banca individual y barra de madera. Entrega y montaje incluidos. Desde $200.",
    url: "/servicios/mobiliario/mesas-picnic/sets/",
    priceRange: { min: 200, max: 5500 },
    reviews,
    ratingValue: 5,
    reviewCount: 52,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Sets y Complementos de Madera CDMX"
  description="Renta de sets y complementos de madera en CDMX: set picnic completo, comedor, lounge VIP, mesa alta cocktail, banca y barra. Entrega y montaje incluidos."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Llave en mano · 6 sets y complementos"
    title='Renta de <span class="highlight">Sets y Complementos</span> de Madera para Eventos'
    subtitle="Seis sets y complementos de madera que resuelven el montaje completo: set picnic con mantelería, comedor con sillas crossback, lounge exterior VIP, mesa alta cocktail, banca individual y barra de madera. Entrega, montaje y recolección incluidos. Desde $200."
    primaryCTA={{ label: "Cotiza tu set de madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sets y complementos de madera para mi evento` }}
    cards={[
      {
        title: "Sets completos que resuelven el montaje sin decoradora",
        content: "<strong>Renta de sets de madera llave en mano</strong> para que no tengas que armar tu montaje pieza por pieza. El <strong>Set Picnic Completo</strong> llega con mesa, mantelería de algodón, cojines, centro decorativo y ambientación para 6 personas. El <strong>Set Comedor Exterior</strong> suma una mesa rectangular de 1.80 × 0.90 m y 6 sillas crossback de haya lacada en blanco. El <strong>Set Lounge Exterior</strong> combina mesa baja de pino y 4 módulos tapizados en lona impermeable 600D para tu zona VIP. Toda la madera es pino natural lijado y barnizado a mano.",
      },
      {
        title: "Complementos sueltos para sumar a cualquier evento",
        content: "<strong>Complementos de madera</strong> que se rentan por separado: la <strong>Mesa Alta Cocktail</strong> (Ø 70 cm, 110 cm de alto) para networking y coctel de recepción, la <strong>Banca Picnic Individual</strong> (1.80 × 0.35 m, 350 kg de resistencia) como asiento autónomo o complemento, y la <strong>Barra de Madera</strong> (2.00 × 0.60 × 1.10 m con estante trasero) para coctelería, candy bar o activación de marca. Entrega puntual, montaje profesional y recolección incluidos en CDMX y Edomex.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un set de madera llave en mano para tu evento?"
    subheadline="Cotiza sin compromiso — te armamos la combinación de sets ideal para tu número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MODELOS — Cards que linkan a cada ficha
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="modelos-heading">
    <div class="container">
      <SectionHeader
        id="modelos-heading"
        title="6 sets y complementos — elige el tuyo"
        subtitle="Cada modelo resuelve un momento del evento"
        description={[
          "Explora los detalles, medidas y precios de cada set y complemento. Todos comparten el mismo pino natural lijado y barnizado a mano — la diferencia está en qué incluye cada uno y para qué momento del evento sirve."
        ]}
      />

      <div class="grid grid--3">
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Set Picnic Completo"
          price="Desde $1,200"
          excerpt="Mesa estándar + mantelería de algodón + cojines + centro decorativo + ambientación para 6 personas. Llave en mano para picnics románticos, pedidas de mano y aniversarios."
          href="/servicios/mobiliario/mesas-picnic/sets/picnic-completo/"
          image="/images/mobiliario/crossback-madera-01.avif"
          badge="Más romántico"
          tags={["6 personas", "Mantelería incluida", "Picnics", "Pedidas de mano"]}
        />
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Set Comedor Exterior"
          price="Desde $1,800"
          excerpt="Mesa rectangular 1.80 × 0.90 m + 6 sillas crossback de haya lacada en blanco. El set más fotogénico para una cena formal al aire libre."
          href="/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/"
          image="/images/mobiliario/crossback-madera-02.avif"
          badge="El más fotogénico"
          tags={["6 personas", "6 sillas crossback", "Cena formal", "Bodas"]}
        />
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Set Lounge Exterior"
          price="Desde $2,500"
          excerpt="Mesa baja de pino (45 cm) + 4 módulos tapizados en lona impermeable 600D. Zona VIP en 4 colores: crudo, negro, beige y terracota."
          href="/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/"
          image="/images/mobiliario/candy-bar-jardin-exterior.avif"
          tags={["6 personas", "Zona VIP", "4 colores", "Lona 600D"]}
        />
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Mesa Alta Cocktail"
          price="Desde $350"
          excerpt="Ø 70 cm, 110 cm de alto. Chapa de pino sobre MDF con base de acero negro mate. Para 5 personas de pie, sin sillas — networking, coctel y activaciones."
          href="/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/"
          image="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif"
          tags={["5 de pie", "Coctel", "Networking", "Activaciones"]}
        />
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Banca Picnic Individual"
          price="Desde $200"
          excerpt="1.80 × 0.35 m para 3 personas. 350 kg de resistencia, mismo pino y barniz que las mesas. Complemento de tus mesas o asiento autónomo."
          href="/servicios/mobiliario/mesas-picnic/sets/banca-individual/"
          image="/images/mobiliario/barras-postres-mesa-madera-rustica.avif"
          tags={["3 personas", "350 kg", "Complemento", "Asiento autónomo"]}
        />
        <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
        <ProductCard
          name="Barra de Madera"
          price="Desde $1,200"
          excerpt="2.00 × 0.60 × 1.10 m, altura de barra ergonómica y estante trasero incluido. Para coctelería, candy bar o activación de marca (no incluye bartender)."
          href="/servicios/mobiliario/mesas-picnic/sets/barra-madera/"
          image="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif"
          tags={["Coctelería", "Candy bar", "Activación", "Estante trasero"]}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Picnic y Madera</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas un set de madera para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sets y complementos de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Sets y Complementos de Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Sets todo incluido -->
          <section class="section section--alt" aria-labelledby="todo-incluido-heading">
            <ServiceShowcase
    title="Sets todo incluido para picnics y comedores"
    headingId="todo-incluido-heading"
    badge="Llave en mano"
    subtitle="El Set Picnic Completo y el Set Comedor Exterior resuelven mesa, textiles y asientos en una sola cotización."
    tags={["Set Picnic Completo", "Set Comedor Exterior", "6 personas", "Montaje incluido"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar sets completos"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>Set Picnic Completo</strong> está pensado para quienes quieren un montaje impecable sin armar nada: llega con mesa de pino, <strong>mantelería de algodón, cojines, centro decorativo y ambientación</strong> para 6 personas. Es el favorito para picnics románticos, pedidas de mano y aniversarios, donde cada detalle cuenta y no hay tiempo para improvisar. El <strong>Set Comedor Exterior</strong> sube el nivel con una mesa rectangular de 1.80 × 0.90 m y <strong>6 sillas crossback de haya lacada en blanco</strong> — el set más fotogénico para una cena formal al aire libre.</p>
      <p class="showcase__text">Ambos sets comparten el pino natural lijado y barnizado a mano que define toda nuestra línea de madera, una estética que es la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>. Si prefieres elegir tus propias sillas, combina la mesa con nuestras <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> en el acabado que necesites. Entrega, montaje y recolección incluidos, sin límite de tiempo durante tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Set de madera con mantelería para evento al aire libre (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Complementos decorativos de madera sobre mesa de evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mesa de madera vintage montada para evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Lounge exterior y mesa alta cocktail -->
          <section class="section section--alt" aria-labelledby="lounge-cocktail-heading">
            <ServiceShowcase
