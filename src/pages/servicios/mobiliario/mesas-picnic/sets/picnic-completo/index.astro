---
/**
 * ─── Set Picnic Completo — Ficha de Producto (Nivel 6) ───
 * Mesa estándar + mantelería de algodón + cojines + centro decorativo +
 * ambientación para 6 personas. Llave en mano para picnics románticos.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Set Picnic Completo
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Set Picnic Completo" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa de madera para picnic al aire libre montada con textiles (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Set de madera rústica con mantelería para picnic romántico (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mobiliario de madera en jardín exterior para picnic (imagen de referencia)" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Centro decorativo y ambientación sobre mesa de madera (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa de madera vintage ambientada para picnic (imagen de referencia)" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa de pino natural barnizada a mano para picnic (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Qué incluye exactamente el Set Picnic Completo?",
    answer: "El set incluye <strong>mesa picnic estándar de pino</strong>, <strong>mantelería de algodón</strong>, <strong>cojines</strong>, <strong>centro decorativo</strong> y <strong>ambientación</strong> para 6 personas. Todo llega montado y listo en tu ubicación — no tienes que armar ni decorar nada. Es la opción llave en mano para picnics románticos, pedidas de mano y aniversarios.",
  },
  {
    question: "¿Para cuántas personas es el set?",
    answer: "El Set Picnic Completo está dimensionado para <strong>6 personas</strong> alrededor de la mesa estándar. Si necesitas cubrir más invitados, puedes rentar varios sets o combinar con mesas picnic sueltas y bancas individuales — te ayudamos a calcular la cantidad según tu número de asistentes.",
  },
  {
    question: "¿La mantelería y los cojines vienen incluidos en el precio?",
    answer: "Sí. A diferencia de la renta de mesa suelta, este set <strong>incluye la mantelería de algodón, los cojines, el centro decorativo y la ambientación</strong> en el precio. Por eso se llama completo: resuelve el look del picnic sin que tengas que contratar decoradora por separado.",
  },
  {
    question: "¿Sirve para una pedida de mano o picnic romántico?",
    answer: "Es justamente su uso estrella. El Set Picnic Completo se diseñó para <strong>picnics románticos, pedidas de mano y aniversarios</strong>: montaje cuidado, textiles suaves y ambientación decorativa que crean la escena perfecta. Muchos clientes lo combinan con flores y velas para un momento inolvidable.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, montaje profesional y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Llegamos a tu ubicación —parque, jardín, terraza o playa urbana—, montamos el set donde indiques y lo recogemos al terminar.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. Para fechas especiales (14 de febrero, fines de semana largos) y temporada alta de noviembre a febrero, sugerimos apartar con 3 a 4 semanas. Un anticipo confirma tu fecha y bloquea el set para tu evento.",
  },
];

const specs = [
  { label: "Incluye", value: "Mesa + mantelería de algodón + cojines + centro decorativo + ambientación" },
  { label: "Capacidad", value: "6 personas" },
  { label: "Material de la mesa", value: "Pino nacional lijado y barnizado a mano" },
  { label: "Mantelería", value: "Algodón — incluida en el set" },
  { label: "Cojines", value: "Incluidos en el set" },
  { label: "Ambientación", value: "Centro decorativo y ambientación incluidos" },
  { label: "Ideal para", value: "Picnics románticos, pedidas de mano, aniversarios" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $1,200 por set / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Valeria Ríos", text: "Rentamos el Set Picnic Completo para una pedida de mano en el bosque de Chapultepec. Llegó todo montado: mantel, cojines y hasta el centro decorativo. No tuvimos que preocuparnos por nada, solo llegar y disfrutar. Fue perfecto.", rating: 5, date: "2025-11-08" },
  { author: "Emilio Navarro", text: "Sorprendí a mi pareja con un picnic de aniversario y el set quedó de revista. La mantelería de algodón y los cojines le dieron un toque súper cálido. El equipo montó y recogió sin que moviéramos un dedo.", rating: 5, date: "2025-10-12" },
  { author: "Paola Guerrero", text: "Ideal para una sesión de fotos al aire libre. La mesa de madera con la ambientación incluida se veía preciosa en cámara. Muy buen precio por todo lo que trae el set.", rating: 5, date: "2025-09-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Set Picnic Completo de Madera en CDMX — 6 Personas",
    description: "Set Picnic Completo de madera: mesa + mantelería de algodón + cojines + centro decorativo + ambientación para 6 personas. Llave en mano para picnics románticos. Desde $1,200.",
    url: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/",
    priceRange: { min: 1200, max: 2800 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Set Picnic Completo", url: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: null, active: true },
  { name: "Set Comedor Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  { name: "Set Lounge Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  { name: "Mesa Alta Cocktail", href: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  { name: "Banca Picnic Individual", href: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  { name: "Barra de Madera", href: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Set Picnic Completo de Madera CDMX"
  description="Renta Set Picnic Completo de madera en CDMX: mesa + mantelería de algodón + cojines + centro decorativo para 6 personas."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Llave en mano — todo montado y listo"
    title='Set Picnic <span class="highlight">Completo</span> de Madera — 6 Personas — Renta CDMX'
    subtitle="El Set Picnic Completo llega con mesa de pino, mantelería de algodón, cojines, centro decorativo y ambientación para 6 personas. Es la opción llave en mano para picnics románticos, pedidas de mano y aniversarios: no montas ni decoras nada. Desde $1,200."
    primaryCTA={{ label: "Cotizar Set Picnic Completo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Picnic Completo de madera para mi evento` }}
    cards={[
      {
        title: "Un picnic de revista sin contratar decoradora",
        content: "El <strong>Set Picnic Completo</strong> resuelve el look completo del picnic en una sola cotización: mesa de pino natural, <strong>mantelería de algodón, cojines, centro decorativo y ambientación</strong> para 6 personas. Llega montado en tu ubicación y listo para disfrutar. Es el favorito para <strong>picnics románticos, pedidas de mano y aniversarios</strong>, donde cada detalle cuenta y no hay margen para improvisar.",
      },
      {
        title: "Madera natural y servicio completo incluido",
        content: "La mesa es de <strong>pino nacional lijado a grano fino y barnizado a mano</strong>, con la calidez de la madera real que combina con flores, velas y textiles. <strong>Entrega, montaje y recolección incluidos</strong> dentro de CDMX y Edomex, sin cargos por traslado ni tiempo extra. Montamos donde indiques —parque, jardín o terraza— y recogemos al terminar. Desde $1,200 el set.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Un picnic romántico o una pedida de mano en puerta?"
    subheadline="Cotiza el Set Picnic Completo — llega montado y listo, sin que decores nada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Set Picnic Completo para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el Set Picnic Completo de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Set Picnic Completo en Eventos Reales</h2>
            <p class="section__subtitle">Picnics románticos, pedidas de mano y aniversarios al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Picnic Completo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué elegir un set completo en lugar de rentar la mesa suelta?"
    headingId="descripcion-heading"
    badge="Todo incluido para 6 personas"
    tags={["Mantelería de algodón", "Cojines", "Centro decorativo", "Picnics románticos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Rentar solo la mesa te obliga a conseguir mantel, cojines y decoración por separado — y a montarlo todo el día del evento. El <strong>Set Picnic Completo</strong> elimina ese trabajo: llega con <strong>mantelería de algodón, cojines, centro decorativo y ambientación</strong> ya montados sobre una mesa de pino natural para 6 personas. Es la diferencia entre improvisar y tener una escena de revista lista cuando llegas.</p>
      <p class="showcase__text">La mesa es de <strong>pino nacional lijado a grano fino y barnizado a mano</strong>, la misma madera natural que define toda la línea y que es la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>. La textura cálida de la madera combina con flores, velas y textiles suaves para crear el ambiente romántico perfecto.</p>
      <p class="showcase__text">Si tu evento crece y quieres una cena formal, considera el <a href="/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/">Set Comedor Exterior</a> con 6 sillas crossback, o suma <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> sueltas. Entrega, montaje y recolección incluidos, sin límite de tiempo durante tu picnic.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa de madera montada para picnic con textiles y ambientación (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Set de madera rústica con mantelería para picnic romántico (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Centro decorativo y ambientación sobre mesa de madera (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con el Set Picnic Completo</h2>
            <p class="section__subtitle">Ideas que funcionan para picnics, pedidas de mano y sesiones de foto</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Pedida de Mano</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Set Picnic Completo + <strong>flores y velas</strong> + globos o letrero. La escena lista para el "sí" en un parque o jardín, con la ambientación decorativa ya incluida en el set.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Picnic Romántico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Set Picnic Completo + <strong>canasta gourmet</strong> + <a href="/servicios/iluminacion/">iluminación cálida</a> al atardecer. El plan perfecto para un aniversario o una cita especial al aire libre.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Sesión de Fotos</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Set Picnic Completo + <a href="/servicios/accesorios/manteleria-textiles/">mantelería adicional</a> en tu paleta. La madera natural y los textiles crean un fondo cálido y fotogénico para cualquier sesión.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Set Picnic Completo</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Set Picnic Completo"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El set llave en mano para picnics románticos. 6 personas, mantelería y ambientación incluidas, montaje y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a planear tu picnic o pedida de mano paso a paso.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre el Set Picnic Completo de madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos la fecha y el lugar y te enviamos precio y disponibilidad del set al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Sets y complementos y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Sets y Complementos</h2>
            <ul class="sidebar-nav">
