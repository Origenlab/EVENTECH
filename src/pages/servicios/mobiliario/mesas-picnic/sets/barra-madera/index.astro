---
/**
 * ─── Barra de Madera — Ficha de Producto (Nivel 6) ───
 * 2.00 × 0.60 × 1.10 m, altura de barra ergonómica, estante trasero incluido.
 * Para coctelería, candy bar o activación de marca (no incluye bartender ni servicio).
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Barra de Madera
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Barra de Madera" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Barra de madera para bebidas en evento (imagen de referencia)" },
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Barra de madera para coctelería de lujo en evento (imagen de referencia)" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Barra de madera como candy bar elegante de boda (imagen de referencia)" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Detalle decorativo sobre barra de madera (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Barra de madera rústica para candy bar al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Barra de madera vintage para activación de marca (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Cuáles son las medidas de la Barra de Madera?",
    answer: "La barra mide <strong>2.00 m de largo × 0.60 m de fondo × 1.10 m de alto</strong>, la altura de barra ergonómica estándar para atender de pie. Incluye un <strong>estante trasero</strong> para colocar botellas, cristalería, dulces o material de la activación.",
  },
  {
    question: "¿Incluye bartender o servicio de bebidas?",
    answer: "No. La Barra de Madera se renta como <strong>mueble de estación</strong>: la estructura de madera para montar tu coctelería, candy bar o activación. <strong>No incluye bartender, cristalería ni servicio de bebidas</strong>. Si necesitas una barra con personal y servicio integral, revisa nuestra sección de <a href=\"/servicios/mobiliario/barras/\">barras para eventos</a>.",
  },
  {
    question: "¿Para qué se usa la barra?",
    answer: "Es muy versátil: funciona como <strong>barra de coctelería</strong> (montas tu bar con botellas y cristalería), como <strong>candy bar o mesa de postres</strong> y como <strong>barra de activación de marca</strong> para stands y lanzamientos. El estante trasero facilita organizar todo lo que necesites tener a la mano.",
  },
  {
    question: "¿De qué material está hecha?",
    answer: "De <strong>pino nacional lijado y barnizado a mano</strong>, el mismo acabado de madera natural que el resto de la línea de <a href=\"/servicios/mobiliario/mesas-picnic/\">mesas picnic y madera</a>. La textura cálida de la madera funciona como elemento decorativo en sí mismo, lo que reduce la necesidad de decoración adicional.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, montaje y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Colocamos la barra en el punto que definas —coctel, candy bar o stand— y la recogemos al terminar el evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. En temporada alta (noviembre a febrero) y para eventos con activación de marca, sugerimos apartar con 3 a 4 semanas. Un anticipo confirma tu fecha y bloquea la pieza para tu evento.",
  },
];

const specs = [
  { label: "Medidas", value: "2.00 × 0.60 × 1.10 m" },
  { label: "Altura", value: "1.10 m (altura de barra ergonómica)" },
  { label: "Estante trasero", value: "Incluido" },
  { label: "Material", value: "Pino nacional lijado y barnizado a mano" },
  { label: "Uso", value: "Coctelería, candy bar, activación de marca" },
  { label: "No incluye", value: "Bartender ni servicio de bebidas" },
  { label: "Función", value: "Mueble de estación (estructura de madera)" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $1,200 por barra / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Bárbara Del Río", text: "Rentamos la Barra de Madera como candy bar para una boda rústica. El estante trasero fue perfecto para acomodar los frascos de dulces y la madera se veía preciosa sin necesidad de decorar mucho. Llegó montada y lista.", rating: 5, date: "2025-11-11" },
  { author: "Iván Cervantes", text: "La usamos para montar nuestro bar de coctelería en un evento en terraza. Amplia, resistente y con muy buen acabado de madera. El estante de atrás ayudó a tener todo ordenado. Muy recomendable como estructura.", rating: 5, date: "2025-10-13" },
  { author: "Karla Estrada", text: "Perfecta para la activación de marca de un lanzamiento. La barra de madera dio un aire cálido y natural al stand, justo lo que buscábamos. Montaje y recolección puntuales, sin complicaciones.", rating: 5, date: "2025-09-24" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Barra de Madera para Eventos en CDMX — Coctelería y Candy Bar",
    description: "Barra de Madera 2.00 × 0.60 × 1.10 m con estante trasero, en pino natural. Para coctelería, candy bar o activación de marca (no incluye bartender). Desde $1,200.",
    url: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/",
    priceRange: { min: 1200, max: 2800 },
    reviews,
    ratingValue: 5,
    reviewCount: 39,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Barra de Madera", url: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  { name: "Set Comedor Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  { name: "Set Lounge Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  { name: "Mesa Alta Cocktail", href: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  { name: "Banca Picnic Individual", href: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  { name: "Barra de Madera", href: null, active: true },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Barra de Madera para Eventos CDMX"
  description="Renta Barra de Madera en CDMX: 2.00 × 0.60 × 1.10 m con estante trasero, en pino natural. Para coctelería, candy bar o activación de marca. Desde $1,200."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Coctelería, candy bar y activación"
    title='Renta de <span class="highlight">Barra de Madera</span> para Eventos — CDMX'
    subtitle="La Barra de Madera mide 2.00 × 0.60 × 1.10 m, con altura de barra ergonómica y estante trasero incluido. Es la estructura de pino natural para tu coctelería, candy bar o activación de marca — no incluye bartender ni servicio de bebidas. Desde $1,200."
    primaryCTA={{ label: "Cotizar Barra de Madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una barra de madera para mi evento` }}
    cards={[
      {
        title: "La estructura de madera para tu barra o candy bar",
        content: "La <strong>Barra de Madera</strong> (2.00 × 0.60 × 1.10 m) es el mueble de estación que da carácter a tu coctel: <strong>altura de barra ergonómica</strong> para atender de pie y <strong>estante trasero incluido</strong> para botellas, cristalería o dulces. Se renta como estructura —<strong>no incluye bartender ni servicio de bebidas</strong>—, lista para que montes tu coctelería, candy bar o activación de marca.",
      },
      {
        title: "Pino natural que decora por sí solo",
        content: "Fabricada en <strong>pino nacional lijado y barnizado a mano</strong>, la barra tiene la calidez de la madera real que funciona como elemento decorativo en sí mismo —reduce la necesidad de adornos extra—. Combina con montajes rústicos, boho y de marca. <strong>Entrega, montaje y recolección incluidos</strong> dentro de CDMX y Edomex, sin cargos por traslado. Desde $1,200 la barra.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Montas una coctelería, un candy bar o una activación de marca?"
    subheadline="Cotiza tu Barra de Madera — la estructura de pino con estante trasero, montada y lista"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Barra de Madera para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una barra de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Barra de Madera en Eventos Reales</h2>
            <p class="section__subtitle">Cocteles, candy bars y activaciones de marca en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Barra de Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué una barra de madera transforma tu coctel o candy bar?"
    headingId="descripcion-heading"
    badge="Estructura de pino con estante trasero"
    tags={["2.00 × 0.60 × 1.10 m", "Estante trasero", "Coctelería", "Candy bar"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Una barra es el punto focal de la recepción — y la <strong>Barra de Madera</strong> lo resuelve con estilo. Con <strong>2.00 × 0.60 × 1.10 m</strong>, tiene la altura ergonómica para atender de pie y un <strong>estante trasero</strong> donde organizas botellas, cristalería o los frascos del candy bar. Se renta como <strong>estructura de madera</strong>: tú montas el contenido y decides si es bar de coctelería, mesa de postres o barra de activación.</p>
      <p class="showcase__text">Está hecha de <strong>pino natural lijado y barnizado a mano</strong> —la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>—, con una textura cálida que decora por sí sola y ahorra adornos. Importante: <strong>no incluye bartender ni servicio de bebidas</strong>; si buscas una barra con personal, revisa nuestras <a href="/servicios/mobiliario/barras/">barras para eventos</a> con servicio integral.</p>
      <p class="showcase__text">Combínala con nuestras <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> como bancos de bar o con mesas altas cocktail alrededor para armar la zona de coctel completa. Entrega, montaje y recolección incluidos, sin límite de tiempo durante tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Barra de madera para bebidas en evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Barra de madera para coctelería de lujo en evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif" alt="Barra de madera como candy bar elegante de boda (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Barra de Madera</h2>
            <p class="section__subtitle">Ideas de coctelería, candy bar y activación que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Bar de Coctelería</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Barra de Madera + <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> como bancos + <a href="/servicios/iluminacion/">iluminación</a>. Monta tu bar con botellas en el estante trasero y crea el punto de reunión del evento.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Candy Bar de Boda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Barra de Madera + frascos de dulces + <a href="/servicios/accesorios/manteleria-textiles/">textiles</a>. La mesa de postres rústica que combina con la decoración natural de una boda al aire libre.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Activación de Marca</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Barra de Madera + branding + <a href="/servicios/mobiliario/barras/">barras</a> complementarias. La estructura cálida y natural para stands, degustaciones y lanzamientos con personalidad.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Barra de Madera</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Barra de Madera"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["La estructura de madera para tu barra. 2.00 × 0.60 × 1.10 m con estante trasero, sin bartender, montaje y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te decimos si necesitas una o varias barras y cómo montarlas.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la barra de madera para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el uso (bar, candy bar o activación) y el número de invitados y te enviamos precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Sets y complementos y servicios relacionados">
