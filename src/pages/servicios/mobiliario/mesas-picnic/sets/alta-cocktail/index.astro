---
/**
 * ─── Mesa Alta Cocktail — Ficha de Producto (Nivel 6) ───
 * Ø 70 cm, 110 cm de alto, chapa de pino sobre MDF + base de acero negro mate.
 * 5 personas de pie, sin sillas — networking, coctel y activaciones.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Mesa Alta Cocktail
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Mesa Alta Cocktail" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Mesa alta de madera para coctelería en evento (imagen de referencia)" },
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Estación alta de madera para bebidas en coctel de recepción (imagen de referencia)" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Mueble de madera elegante para coctel de pie (imagen de referencia)" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Detalle decorativo sobre mesa alta de madera (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa de madera rústica para coctel al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mesa de madera en jardín exterior para networking (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Cuáles son las medidas de la Mesa Alta Cocktail?",
    answer: "La mesa tiene <strong>70 cm de diámetro</strong> (Ø 70 cm) y <strong>110 cm de alto</strong>, la altura estándar de mesa periquera para coctel. El tablero es de <strong>chapa de pino sobre MDF</strong> y la base es de <strong>acero negro mate</strong>, que aporta estabilidad y un contraste industrial-cálido muy actual.",
  },
  {
    question: "¿Cuántas personas caben alrededor?",
    answer: "Alrededor de cada Mesa Alta Cocktail se acomodan <strong>hasta 5 personas de pie</strong>. Es una mesa de coctel, por lo que <strong>no incluye sillas</strong>: está pensada para que los invitados apoyen su bebida y conversen de pie durante el recibimiento o el networking. Para un coctel de 50 personas, calcula unas 10 mesas.",
  },
  {
    question: "¿Sirve para eventos corporativos y activaciones?",
    answer: "Es uno de sus usos principales. La Mesa Alta Cocktail funciona perfecto para <strong>networking, coctel de recepción y activaciones de marca</strong>: ocupa poco espacio, invita a la conversación y la base de acero negro le da un aire contemporáneo que combina con montajes corporativos. También se usa en bodas para el coctel previo a la cena.",
  },
  {
    question: "¿Es estable en pasto o superficies irregulares?",
    answer: "Sí. La <strong>base de acero negro mate</strong> tiene peso suficiente para mantener la mesa estable en salón, terraza, duela y pasto. Al ser una mesa de pie con carga ligera (bebidas y bocadillos), no requiere niveladores complejos. Para pasto muy irregular, nuestro equipo verifica cada mesa durante el montaje.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, montaje y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Distribuimos las mesas por tu área de coctel según el layout que definas y las recogemos al terminar el evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. Para eventos corporativos grandes y temporada alta (noviembre a febrero), sugerimos apartar con 3 a 4 semanas para asegurar la cantidad de mesas que necesitas. Un anticipo confirma tu fecha.",
  },
];

const specs = [
  { label: "Diámetro", value: "Ø 70 cm" },
  { label: "Altura", value: "110 cm (altura periquera de coctel)" },
  { label: "Tablero", value: "Chapa de pino sobre MDF" },
  { label: "Base", value: "Acero negro mate" },
  { label: "Capacidad", value: "5 personas de pie (sin sillas)" },
  { label: "Uso", value: "Networking, coctel de recepción, activaciones" },
  { label: "Estabilidad", value: "Base de acero para salón, terraza, duela y pasto" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $350 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Daniela Ochoa", text: "Rentamos 12 Mesas Alta Cocktail para el coctel de recepción de un evento corporativo. La base de acero negro se veía muy elegante y las mesas aguantaron perfecto el ir y venir de bebidas. Montaje puntual y sin complicaciones.", rating: 5, date: "2025-11-06" },
  { author: "Arturo Salcedo", text: "Para una activación de marca en un rooftop pedimos 8 mesas altas. El contraste de la madera con el acero negro le dio justo el look contemporáneo que buscábamos. Repetiremos para el próximo lanzamiento.", rating: 5, date: "2025-10-14" },
  { author: "Renata Villalobos", text: "Usamos las mesas altas para el coctel previo a la cena de boda. Perfectas para que los invitados conversaran de pie con su copa. Estables incluso en el pasto del jardín. Muy buen precio por mesa.", rating: 5, date: "2025-09-29" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Alta Cocktail de Madera en CDMX — Periquera para Coctel",
    description: "Mesa Alta Cocktail Ø 70 cm, 110 cm de alto, chapa de pino sobre MDF con base de acero negro mate. Para 5 personas de pie. Networking, coctel y activaciones. Desde $350.",
    url: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/",
    priceRange: { min: 350, max: 800 },
    reviews,
    ratingValue: 5,
    reviewCount: 46,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Mesa Alta Cocktail", url: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  { name: "Set Comedor Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  { name: "Set Lounge Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  { name: "Mesa Alta Cocktail", href: null, active: true },
  { name: "Banca Picnic Individual", href: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  { name: "Barra de Madera", href: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Mesa Alta Cocktail de Madera CDMX"
  description="Renta Mesa Alta Cocktail en CDMX: Ø 70 cm, 110 cm de alto, chapa de pino sobre MDF con base de acero negro mate. Para 5 personas de pie. Coctel y networking. Desde $350."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La periquera del coctel y el networking"
    title='Mesa Alta <span class="highlight">Cocktail</span> de Madera — Renta CDMX'
    subtitle="La Mesa Alta Cocktail mide Ø 70 cm y 110 cm de alto, con tablero de chapa de pino sobre MDF y base de acero negro mate. Acomoda a 5 personas de pie, sin sillas — perfecta para networking, coctel de recepción y activaciones de marca. Desde $350."
    primaryCTA={{ label: "Cotizar Mesa Alta Cocktail", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas altas cocktail de madera para mi evento` }}
    cards={[
      {
        title: "La mesa que activa la conversación en el coctel",
        content: "La <strong>Mesa Alta Cocktail</strong> (Ø 70 cm, 110 cm de alto) es la periquera clásica del coctel de recepción: los invitados se acercan, apoyan su bebida y conversan de pie. Acomoda <strong>hasta 5 personas</strong> alrededor y <strong>no incluye sillas</strong>, porque su función es mantener el ambiente dinámico. Ideal para el recibimiento de bodas, el networking de un corporativo y las activaciones de marca.",
      },
      {
        title: "Chapa de pino y base de acero negro mate",
        content: "El tablero es de <strong>chapa de pino sobre MDF</strong> y la base de <strong>acero negro mate</strong>, un contraste industrial-cálido muy actual que combina lo mismo con un montaje rústico que con uno corporativo. La base metálica aporta estabilidad en salón, terraza, duela y pasto. <strong>Entrega, montaje y recolección incluidos</strong> en CDMX y Edomex, sin cargos por traslado. Desde $350 por mesa.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Un coctel de recepción, networking o activación de marca?"
    subheadline="Cotiza tus Mesas Alta Cocktail — periqueras de madera y acero, montadas y listas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesas Alta Cocktail para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas altas cocktail de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Alta Cocktail en Eventos Reales</h2>
            <p class="section__subtitle">Cocteles de recepción, networking y activaciones de marca en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Alta Cocktail</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué las mesas altas hacen que un coctel funcione?"
    headingId="descripcion-heading"
    badge="Periquera de madera y acero"
    tags={["Ø 70 cm", "110 cm de alto", "5 de pie", "Coctel y networking"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">En un coctel de recepción no quieres que la gente se siente y se quede quieta — quieres que circule y converse. Ahí entra la <strong>Mesa Alta Cocktail</strong>: con <strong>Ø 70 cm y 110 cm de alto</strong>, es la altura perfecta para apoyar la copa y el bocadillo mientras se charla de pie. Acomoda <strong>hasta 5 personas</strong> y, al no tener sillas, mantiene el ambiente dinámico durante todo el recibimiento.</p>
      <p class="showcase__text">El tablero de <strong>chapa de pino sobre MDF</strong> conserva la calidez de madera de toda la línea —especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>— y la <strong>base de acero negro mate</strong> añade un contraste industrial muy actual que encaja tanto en bodas rústicas como en activaciones de marca. La base metálica da estabilidad en pasto, duela y terraza.</p>
      <p class="showcase__text">Colócalas junto a una <a href="/servicios/mobiliario/barras/">barra</a> para que el coctel fluya, o combínalas con nuestras <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a> para alternar zonas de pie y de descanso. Entrega, montaje y recolección incluidos, sin límite de tiempo durante tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Mesa alta de madera para coctelería en evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Estación alta de madera para bebidas en coctel de recepción (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif" alt="Mueble de madera elegante para coctel de pie (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Mesa Alta Cocktail</h2>
            <p class="section__subtitle">Ideas de coctel, networking y activación que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Coctel de Boda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Varias mesas altas + <a href="/servicios/mobiliario/barras/">barra de madera</a> + <a href="/servicios/accesorios/manteleria-textiles/">manteles cortos</a>. El recibimiento donde los invitados brindan de pie antes de pasar a la cena.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Networking Corporativo</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas altas distribuidas + <a href="/servicios/iluminacion/">iluminación</a> puntual. La base de acero negro proyecta un aire ejecutivo ideal para congresos, coffee breaks y afterworks.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Activación de Marca</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Mesas altas + vinilos o displays de marca. El contraste madera-acero da un look contemporáneo perfecto para lanzamientos y stands en rooftops o showrooms.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Alta Cocktail</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Alta Cocktail"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["La periquera del coctel. Ø 70 cm, 110 cm de alto, madera y acero negro, para 5 personas de pie, montaje y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas mesas altas necesita tu coctel.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre las mesas altas cocktail de madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados al coctel y te calculamos mesas y precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Sets y complementos y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Sets y Complementos</h2>
