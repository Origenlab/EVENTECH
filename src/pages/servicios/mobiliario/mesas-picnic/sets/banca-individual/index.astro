---
/**
 * ─── Banca Picnic Individual — Ficha de Producto (Nivel 6) ───
 * 1.80 × 0.35 m, 3 personas, 350 kg de resistencia, mismo pino y barniz
 * que las mesas. Complemento de las mesas o asiento autónomo.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Sets y Complementos > Banca Picnic Individual
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { label: "Banca Picnic Individual" },
];

const galleryImages = [
  // PLACEHOLDER: reemplazar por foto real del modelo
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Banca de madera rústica de pino para evento al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mobiliario de pino natural con banca para picnic (imagen de referencia)" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Banca de pino barnizada a mano como asiento de evento (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Madera rústica de pino en montaje de evento (imagen de referencia)" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Banca de madera vintage para reunión al aire libre (imagen de referencia)" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Bancas de madera en jardín exterior para evento (imagen de referencia)" },
];

const faqs = [
  {
    question: "¿Cuáles son las medidas de la Banca Picnic Individual?",
    answer: "La banca mide <strong>1.80 × 0.35 m</strong> y sienta cómodamente a <strong>3 personas</strong>. Es el mismo largo que la mesa picnic estándar, por lo que se alinea perfecto como asiento a los lados de la mesa o funciona como banca independiente en cualquier rincón del evento.",
  },
  {
    question: "¿Cuánto peso soporta?",
    answer: "Cada banca tiene una <strong>resistencia de 350 kg</strong>, más que suficiente para 3 adultos sentados con margen de seguridad. Está fabricada en el <strong>mismo pino y con el mismo barniz que las mesas picnic</strong>, con uniones reforzadas que garantizan estabilidad durante todo el evento.",
  },
  {
    question: "¿Sirve como complemento o como asiento independiente?",
    answer: "Ambos. La Banca Picnic Individual funciona como <strong>complemento</strong> para sumar lugares a las mesas picnic, o como <strong>asiento autónomo</strong>: alrededor de una fogata, en una zona de espera, junto a la pista o como banca de ceremonia. Su versatilidad la hace uno de los complementos más rentados.",
  },
  {
    question: "¿La banca combina con las mesas y otros modelos?",
    answer: "Sí. Al compartir el <strong>mismo pino natural lijado y barnizado a mano</strong> que el resto de la línea de <a href=\"/servicios/mobiliario/mesas-picnic/\">mesas picnic y madera</a>, la banca combina sin romper la estética. También puedes alternarla con <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas crossback</a> para variar el montaje de asientos.",
  },
  {
    question: "¿Incluye entrega y montaje?",
    answer: "Sí. Entrega, colocación y recolección están <strong>incluidos</strong> dentro de CDMX y Estado de México, sin cargos por traslado ni tiempo extra. Colocamos las bancas donde indiques y las recogemos al terminar el evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. En temporada alta (noviembre a febrero) sugerimos apartar con 3 a 4 semanas, sobre todo si necesitas muchas bancas para eventos grandes. Un anticipo confirma tu fecha y bloquea las piezas.",
  },
];

const specs = [
  { label: "Medidas", value: "1.80 × 0.35 m" },
  { label: "Capacidad", value: "3 personas" },
  { label: "Resistencia", value: "350 kg" },
  { label: "Material", value: "Pino nacional lijado y barnizado a mano" },
  { label: "Acabado", value: "Mismo pino y barniz que las mesas picnic" },
  { label: "Uso", value: "Complemento de las mesas o asiento autónomo" },
  { label: "Ideal para", value: "Bodas, picnics, ceremonias y reuniones al aire libre" },
  { label: "Servicio", value: "Entrega, colocación y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $200 por banca / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Marcela Ibáñez", text: "Rentamos 20 Bancas Picnic Individuales para la ceremonia civil de una boda en jardín. Se veían preciosas alineadas y aguantaron perfecto a los invitados. La madera combinó con las mesas que también rentamos. Todo llegó a tiempo.", rating: 5, date: "2025-11-09" },
  { author: "Héctor Palomar", text: "Las usamos como asiento extra alrededor de una fogata en una reunión al aire libre. Muy resistentes y cómodas, y el barniz igual al de las mesas. Un complemento perfecto y a muy buen precio.", rating: 5, date: "2025-10-16" },
  { author: "Nadia Fuentes", text: "Sumé varias bancas a las mesas picnic para acomodar a más invitados en un cumpleaños. Prácticas, estables y con el mismo acabado de madera. El equipo las colocó y recogió sin ningún problema.", rating: 5, date: "2025-09-21" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Banca Picnic Individual de Madera en CDMX — 3 Personas",
    description: "Banca Picnic Individual 1.80 × 0.35 m para 3 personas, 350 kg de resistencia, mismo pino y barniz que las mesas. Complemento o asiento autónomo. Desde $200.",
    url: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/",
    priceRange: { min: 200, max: 450 },
    reviews,
    ratingValue: 5,
    reviewCount: 44,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Sets y Complementos", url: "/servicios/mobiliario/mesas-picnic/sets/" },
    { name: "Banca Picnic Individual", url: "/servicios/mobiliario/mesas-picnic/sets/banca-individual/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Set Picnic Completo", href: "/servicios/mobiliario/mesas-picnic/sets/picnic-completo/" },
  { name: "Set Comedor Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/comedor-exterior/" },
  { name: "Set Lounge Exterior", href: "/servicios/mobiliario/mesas-picnic/sets/lounge-exterior/" },
  { name: "Mesa Alta Cocktail", href: "/servicios/mobiliario/mesas-picnic/sets/alta-cocktail/" },
  { name: "Banca Picnic Individual", href: null, active: true },
  { name: "Barra de Madera", href: "/servicios/mobiliario/mesas-picnic/sets/barra-madera/" },
];

const sidebarRelated = [
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Banca Picnic Individual de Madera CDMX"
  description="Renta Banca Picnic Individual en CDMX: 1.80 × 0.35 m para 3 personas, 350 kg de resistencia, mismo pino y barniz que las mesas. Complemento o asiento autónomo. Desde $200."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El complemento más versátil"
    title='Banca Picnic <span class="highlight">Individual</span> de Madera — Renta CDMX'
    subtitle="La Banca Picnic Individual mide 1.80 × 0.35 m, sienta a 3 personas y soporta 350 kg. Está hecha con el mismo pino y barniz que las mesas picnic, y funciona como complemento de tus mesas o como asiento autónomo. Desde $200."
    primaryCTA={{ label: "Cotizar Banca Picnic Individual", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar bancas picnic individuales de madera para mi evento` }}
    cards={[
      {
        title: "Suma asientos sin romper la estética de madera",
        content: "La <strong>Banca Picnic Individual</strong> (1.80 × 0.35 m) sienta a <strong>3 personas</strong> y está fabricada con el <strong>mismo pino y barniz que las mesas picnic</strong>. Es la forma más sencilla de sumar lugares a tu montaje: se alinea a los lados de las mesas o se usa como banca independiente. Con <strong>350 kg de resistencia</strong>, aguanta el uso intenso de cualquier evento.",
      },
      {
        title: "Complemento o asiento autónomo, tú decides",
        content: "Úsala como <strong>complemento</strong> para acomodar más invitados en las mesas, o como <strong>asiento autónomo</strong>: en una ceremonia al aire libre, alrededor de una fogata, en una zona de espera o junto a la pista. Su versatilidad y el acabado de madera natural la convierten en uno de los complementos más rentados. <strong>Entrega, colocación y recolección incluidos</strong> en CDMX y Edomex. Desde $200 por banca.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Necesitas sumar asientos de madera a tu evento?"
    subheadline="Cotiza tus Bancas Picnic Individuales — 3 personas, 350 kg, mismo acabado que las mesas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sets y Complementos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Bancas Picnic Individuales para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar bancas picnic individuales de madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Banca Picnic Individual en Eventos Reales</h2>
            <p class="section__subtitle">Ceremonias, picnics y reuniones al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Banca Picnic Individual</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la banca individual es el complemento que todos suman?"
    headingId="descripcion-heading"
    badge="Mismo pino y barniz que las mesas"
    tags={["1.80 × 0.35 m", "3 personas", "350 kg", "Complemento versátil"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">A veces no necesitas otra mesa, solo más lugares para sentarse. La <strong>Banca Picnic Individual</strong> (1.80 × 0.35 m, 3 personas) resuelve exactamente eso: se alinea a los lados de las mesas picnic para sumar comensales, o se coloca sola donde haga falta un asiento. Con <strong>350 kg de resistencia</strong>, aguanta el trajín de cualquier celebración sin problema.</p>
      <p class="showcase__text">Está hecha con el <strong>mismo pino natural lijado y barnizado a mano</strong> que las mesas —la especialidad de nuestro sitio hermano <a href="https://mesaspicnic.com/" target="_blank" rel="noopener">mesaspicnic.com</a>—, así que nunca desentona: el acabado es idéntico. Es la pieza que da flexibilidad al montaje sin sumar costo de mesa completa.</p>
      <p class="showcase__text">Úsala como banca de ceremonia civil, asiento alrededor de una fogata o lugar extra junto a la pista. Si quieres variar los asientos, altérnala con nuestras <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a>. Entrega, colocación y recolección incluidos, sin límite de tiempo durante tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barras-postres-mesa-madera-rustica.avif" alt="Banca de madera rústica de pino para evento al aire libre (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mobiliario de pino natural con banca para picnic (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Banca de pino barnizada a mano como asiento de evento (imagen de referencia)" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la Banca Picnic Individual</h2>
            <p class="section__subtitle">Ideas de asiento que funcionan al aire libre</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Ceremonia al Aire Libre</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Bancas alineadas hacia el altar + <a href="/servicios/accesorios/manteleria-textiles/">textiles</a> o cojines. Una ceremonia civil o simbólica con asientos de madera cálidos y muy fotogénicos.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Zona de Fogata</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Bancas alrededor de la fogata + <a href="/servicios/iluminacion/">iluminación cálida</a>. El rincón de sobremesa donde los invitados se quedan hasta el final de la noche.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Asientos Extra</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Bancas junto a las mesas picnic + alternancia con <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a>. La forma económica de acomodar a más invitados sin sumar mesas.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Banca Picnic Individual</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Banca Picnic Individual"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El complemento de asiento más versátil. 1.80 × 0.35 m, 3 personas, 350 kg, mismo acabado que las mesas, colocación y recolección sin costo extra."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas bancas necesitas para tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre las bancas picnic individuales de madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos cuántos asientos necesitas y te calculamos bancas y precio al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Sets y complementos y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Sets y Complementos</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
