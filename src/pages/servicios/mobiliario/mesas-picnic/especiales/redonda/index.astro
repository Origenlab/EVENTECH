---
/**
 * ─── Mesa Redonda de Madera — Página de Ficha (Nivel 6) ───
 * Ø 1.50 m, 8-10 personas. Sin cabecera: formato de conversación.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Especiales & Farm > Redonda
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { label: "Mesa Redonda de Madera" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa redonda de madera de 1.50 m para boda íntima en CDMX" },
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Mesa redonda de madera natural sin cabecera para conversación" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Mesa redonda de madera vestida con centro de mesa para cena de honor" },
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mesa redonda de madera montada en jardín para evento al aire libre" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Detalle de la veta de la mesa redonda de madera barnizada a mano" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Mesa redonda de madera para 8-10 personas en montaje corporativo" },
];

const faqs = [
  {
    question: "¿Cuántas personas caben en la mesa redonda de madera?",
    answer: "La <strong>Mesa Redonda de Madera</strong> mide <strong>1.50 m de diámetro</strong> y acomoda de <strong>8 a 10 personas</strong> con comodidad. Con 8 comensales queda holgada para platos, copas y centro de mesa; con 10 es ideal para cenas donde prima la cercanía y la conversación. Al no tener cabecera, el formato circular reparte a todos por igual."
  },
  {
    question: "¿Por qué elegir una mesa redonda en lugar de una rectangular?",
    answer: "La mesa redonda <strong>elimina las jerarquías de la cabecera</strong> y logra que todos los comensales se vean de frente, lo que favorece la conversación durante toda la cena. Es la elección natural para <strong>bodas íntimas, cenas de honor y mesas corporativas</strong> donde la interacción importa. En madera, además, aporta una calidez que el mismo formato en otros materiales no consigue."
  },
  {
    question: "¿La mesa redonda de madera necesita mantelería?",
    answer: "No es obligatoria. Puedes <strong>dejarla desnuda para lucir la veta</strong> de la madera barnizada a mano, o vestirla con mantelería ligera, runner de lino o centro de mesa floral según tu estilo. Muchos clientes de bodas rústicas y boho la prefieren sin mantel. Si quieres mantelería coordinada, consulta nuestra <a href=\"/servicios/accesorios/manteleria-textiles/\">mantelería y textiles</a>."
  },
  {
    question: "¿Funciona en jardines y exteriores?",
    answer: "Sí. Está barnizada a mano para uso en jardín, terraza, hacienda y salón. Para eventos totalmente al aire libre recomendamos complementar con nuestras <a href=\"/servicios/carpas/\">carpas profesionales</a> como respaldo ante lluvia e <a href=\"/servicios/iluminacion/\">iluminación</a> cálida para ambientar la noche. El montaje incluye la nivelación de la mesa en cualquier superficie."
  },
  {
    question: "¿Incluye sillas?",
    answer: "La mesa redonda se renta como mesa para que elijas la silla que mejor combine con tu evento. Nuestra recomendación para un look de madera integral son las <a href=\"/servicios/mobiliario/sillas/crossback/\">sillas crossback</a>. Podemos cotizar mesa + sillas en un solo paquete con montaje incluido."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Recomendamos apartar con <strong>1 a 2 semanas de anticipación</strong>, y con <strong>3 a 4 semanas en temporada alta de bodas</strong> (noviembre a febrero). Un anticipo confirma tu fecha. Entrega, montaje y recolección incluidos, sin límite de tiempo durante el evento. Desde $550 por mesa."
  },
];

const specs = [
  { label: "Diámetro", value: "1.50 m" },
  { label: "Capacidad", value: "8 a 10 personas" },
  { label: "Formato", value: "Redonda sin cabecera — favorece la conversación" },
  { label: "Material", value: "Madera de pino lijada a grano fino" },
  { label: "Acabado", value: "Barnizada a mano para interior y exterior" },
  { label: "Uso ideal", value: "Bodas íntimas, cenas de honor, mesas corporativas" },
  { label: "Sillas", value: "Se combina con la silla que elijas (crossback recomendada)" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Tiempo de uso", value: "Sin límite durante el evento" },
  { label: "Precio referencial", value: "Desde $550 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Renata Villalobos", text: "Escogimos dos mesas redondas de madera para la cena de honor de nuestra boda. El formato sin cabecera hizo que la plática fluyera toda la noche y la madera se veía preciosa sin necesidad de mantel. Montaje puntual.", rating: 5, date: "2025-11-12" },
  { author: "Emilio Cárdenas", text: "Rentamos una redonda para una cena corporativa de 10 directivos. Todos de frente, sin la típica jerarquía de la mesa larga. La calidez de la madera cambió por completo el ambiente de la reunión.", rating: 5, date: "2025-10-09" },
  { author: "Paulina Rivas", text: "Boda boho en jardín con mesas redondas de madera y sillas crossback. Quedó justo como en mis fotos de referencia. La atención y el montaje, impecables.", rating: 5, date: "2025-09-21" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa Redonda de Madera para Eventos en CDMX",
    description: "Mesa redonda de madera Ø 1.50 m para 8-10 personas. Formato de conversación sin cabecera, barnizada a mano, para bodas íntimas y eventos corporativos en CDMX. Desde $550.",
    url: "/servicios/mobiliario/mesas-picnic/especiales/redonda/",
    priceRange: { min: 550, max: 1300 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Especiales & Farm", url: "/servicios/mobiliario/mesas-picnic/especiales/" },
    { name: "Mesa Redonda de Madera", url: "/servicios/mobiliario/mesas-picnic/especiales/redonda/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Redonda de Madera", href: null, active: true },
  { name: "Mesa Biergarten", href: "/servicios/mobiliario/mesas-picnic/especiales/biergarten/" },
  { name: "Mesa Madera Teka", href: "/servicios/mobiliario/mesas-picnic/especiales/teka/" },
  { name: "Mesa Farm Patas de Horquilla", href: "/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/" },
  { name: "Mesa Sweetheart para Novios", href: "/servicios/mobiliario/mesas-picnic/especiales/sweetheart/" },
  { name: "Mesa de Parota", href: "/servicios/mobiliario/mesas-picnic/especiales/parota/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta de Mesa Redonda de Madera para Eventos en CDMX"
  description="Renta mesa redonda de madera Ø 1.50 m en CDMX — 8 a 10 personas. Formato de conversación sin cabecera para bodas íntimas y eventos corporativos. Desde $550."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Formato de conversación — sin cabecera"
    title='Mesa Redonda de <span class="highlight">Madera</span> — 8 a 10 Personas — Renta CDMX'
    subtitle="Mesa redonda de madera de 1.50 m de diámetro para 8 a 10 personas. Al no tener cabecera, elimina jerarquías y logra que todos se vean de frente — el formato ideal para bodas íntimas y mesas corporativas. Barnizada a mano, con montaje incluido. Desde $550."
    primaryCTA={{ label: "Cotizar mesa redonda", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Redonda de Madera para mi evento` }}
    cards={[
      {
        title: "El formato circular que favorece la conversación",
        content: "La <strong>Mesa Redonda de Madera</strong> de 1.50 m acomoda de <strong>8 a 10 personas</strong> y, al carecer de cabecera, hace que todos los comensales se vean de frente. Es la elección natural para <strong>bodas íntimas, cenas de honor y mesas corporativas</strong> donde la interacción importa tanto como la estética. La madera aporta una calidez que el mismo formato en cristal o metal no consigue.",
      },
      {
        title: "Madera barnizada a mano, lista para lucir sin mantel",
        content: "Fabricada en <strong>pino lijado a grano fino</strong> y barnizada a mano para uso en interior y exterior. Puedes dejarla desnuda para lucir la veta o vestirla con runner y centro de mesa. Es parte de la línea especializada de nuestro sitio hermano <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">mesaspicnic.com — sitio especializado en mesas picnic</a>. Entrega, montaje y recolección incluidos.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Cuántas mesas redondas necesitas? Te ayudamos a diseñar el montaje"
    subheadline="Asesoría de formato sin costo — combinamos mesa, sillas y layout según tu venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Especiales & Farm</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa Redonda de Madera para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Redonda de Madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Redonda de Madera en Eventos Reales</h2>
            <p class="section__subtitle">Bodas íntimas, cenas de honor y mesas corporativas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Redonda de Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la redonda de madera es ideal para bodas íntimas?"
    headingId="descripcion-heading"
    badge="Formato de conversación en madera natural"
    tags={["Ø 1.50 m", "8-10 personas", "Sin cabecera", "Bodas íntimas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">El diámetro de 1.50 m está calculado para que <strong>8 a 10 personas</strong> compartan la mesa sin que nadie quede "en la esquina". Al ser redonda, <strong>no hay cabecera</strong>: la conversación fluye entre todos y la distancia visual es la misma para cualquier comensal. Es el formato que las bodas íntimas y las cenas de honor prefieren por encima de la mesa larga.</p>
      <p class="showcase__text">La superficie es de <strong>pino lijado a grano fino y barnizado a mano</strong>, pensada para lucir la veta natural incluso sin mantelería. Resiste el uso en jardín, terraza y salón. La calidez de la madera transforma una cena corporativa formal en una reunión cercana, y una boda de jardín en una escena de revista.</p>
      <p class="showcase__text">Cada mesa se inspecciona pieza por pieza antes de entregar: estructura, uniones y barniz. Si una pieza tiene una astilla o el barniz deteriorado, no sale de bodega. Combínala con <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> de madera para un montaje 100% natural. Desde $550 por mesa con montaje incluido.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/candy-bar-boda-rustica-madera.avif" alt="Mesa redonda de madera montada para boda íntima" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-madera-rustica.avif" alt="Mesa redonda de madera natural con veta visible" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Mesa redonda de madera vestida con centro de mesa" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la mesa redonda de madera</h2>
            <p class="section__subtitle">Combinaciones de sillas, mantelería y decoración que funcionan</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda Íntima en Jardín</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Redonda de madera + <strong>silla crossback natural</strong> + runner de lino + flores silvestres. Sin mantel para lucir la veta. El montaje boho-chic más fotogénico para bodas de 8-10 en jardín.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Cena de Honor</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Redonda de madera + <strong>silla tapizada</strong> + mantel corto + candelabros. El formato sin cabecera pone a novios, padrinos o directivos en igualdad, favoreciendo la charla.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Mesa Corporativa</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Redonda de madera + <strong>sillas de comedor</strong> + iluminación cálida. Para cenas de directivos y consejos donde todos deben verse de frente sin la jerarquía de la mesa larga.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Redonda de Madera</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Redonda de Madera"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["Formato de conversación en madera natural. Capacidad 8-10 personas, sin cabecera, barnizada a mano y con montaje incluido."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a definir cuántas mesas redondas necesitas y con qué sillas combinarlas.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Redonda de Madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados y te calculamos mesas, sillas y layout al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Modelos especiales y servicios relacionados">
          <div class="sidebar-card">
