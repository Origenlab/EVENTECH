---
/**
 * ─── Mesa Madera Teka — Página de Ficha (Nivel 6) ───
 * 2.00 × 1.00 m, 8 personas. Aceite de teca que penetra la fibra: resistente a UV y humedad.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Especiales & Farm > Teka
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { label: "Mesa Madera Teka" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Mesa de madera teka de 2.00 m para boda de lujo en CDMX" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Mesa de teka con acabado de aceite para evento VIP" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa de madera teka para 8 personas resistente a UV y humedad" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Detalle de la veta de la mesa de teka barnizada" },
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Mesa de teka montada al aire libre en boda VIP" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa de madera teka vestida para banquete de lujo" },
];

const faqs = [
  {
    question: "¿Qué hace especial a la madera de teca?",
    answer: "La teca se trata con <strong>aceite de teca que penetra la fibra</strong> de la madera, no solo la recubre en superficie. Ese tratamiento la vuelve <strong>resistente a los rayos UV y a la humedad</strong>, evita que se agriete o decolore con el sol y le da esa pátina cálida y aterciopelada tan característica. Es la razón por la que la teca es la madera preferida para mobiliario de exterior de alta gama en el mundo."
  },
  {
    question: "¿Cuántas personas caben en la mesa de teka?",
    answer: "La <strong>Mesa Madera Teka</strong> mide <strong>2.00 × 1.00 m</strong> y acomoda cómodamente a <strong>8 personas</strong> — 3 por lado y 1 en cada cabecera. El metro de ancho permite colocar vajilla completa, cristalería y un centro de mesa generoso sin que nadie quede apretado. Es un formato pensado para banquetes de lujo donde cada comensal tiene su espacio."
  },
  {
    question: "¿Es apta para eventos al aire libre?",
    answer: "Es precisamente su fortaleza. Gracias al <strong>aceite de teca que penetra la fibra</strong>, resiste el sol directo y la humedad mejor que cualquier otra madera del catálogo, por lo que es la opción ideal para <strong>bodas de lujo en jardín, terraza y hacienda</strong>. Aun así, para eventos de varias horas recomendamos complementar con nuestras <a href=\"/servicios/carpas/\">carpas</a> como respaldo ante lluvia."
  },
  {
    question: "¿Necesita mantelería?",
    answer: "No la necesita — al contrario. La madera de teca tiene una <strong>veta y un color tan bellos</strong> que la mayoría de los clientes la deja desnuda para lucirla como elemento de diseño. Un caminito de mesa o un centro floral bastan. Si prefieres mantel, consulta nuestra <a href=\"/servicios/accesorios/manteleria-textiles/\">mantelería y textiles</a>, aunque nuestra recomendación es dejar que la teca hable por sí sola."
  },
  {
    question: "¿En qué se diferencia de la mesa de parota?",
    answer: "Ambas son maderas macizas premium. La <strong>teca</strong> destaca por su resistencia a la intemperie gracias al aceite que penetra la fibra — es la reina del exterior. La <a href=\"/servicios/mobiliario/mesas-picnic/especiales/parota/\">parota</a> mexicana destaca por su dureza (Janka 1,480 lbf) y su veta única e irrepetible. La teka es ligeramente más accesible (desde $1,800 vs. $2,200); la parota es el modelo tope del catálogo."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "La teca es una pieza de <strong>inventario limitado</strong>, por lo que recomendamos apartar con <strong>3 a 6 semanas de anticipación</strong>, especialmente en temporada alta de bodas (noviembre a febrero). Un anticipo confirma tu fecha. Entrega, montaje y recolección incluidos, sin límite de tiempo durante el evento. Desde $1,800 por mesa."
  },
];

const specs = [
  { label: "Medidas", value: "2.00 × 1.00 m" },
  { label: "Capacidad", value: "8 personas" },
  { label: "Madera", value: "Teka maciza tratada con aceite de teca" },
  { label: "Tratamiento", value: "Aceite que penetra la fibra — resistente a UV y humedad" },
  { label: "Acabado", value: "Veta natural realzada, apta para lucir sin mantel" },
  { label: "Uso ideal", value: "Bodas de lujo, mesas de honor, eventos VIP" },
  { label: "Exterior", value: "La madera más resistente a intemperie del catálogo" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Tiempo de uso", value: "Sin límite durante el evento" },
  { label: "Precio referencial", value: "Desde $1,800 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Isabela Montes", text: "Rentamos tres mesas de teka para la boda de lujo de mi hermana en una hacienda. La madera es impresionante, no necesitó mantel y aguantó el sol de la tarde sin problema. Fue el detalle que más comentaron los invitados.", rating: 5, date: "2025-11-16" },
  { author: "Fernando Elías", text: "Para un evento VIP corporativo al aire libre elegimos teka por su resistencia. Estuvo montada seis horas bajo sol y sereno y quedó impecable. La calidez de la madera elevó todo el montaje. Servicio de primera.", rating: 5, date: "2025-10-07" },
  { author: "Camila Bermúdez", text: "Mesa de honor de teka para nuestra boda en jardín. La veta y el color son una belleza real, se robó todas las fotos. Entrega puntual y montaje cuidadoso. Vale cada peso.", rating: 5, date: "2025-09-19" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa de Madera Teka para Eventos en CDMX",
    description: "Mesa de madera teka maciza 2.00 × 1.00 m para 8 personas. Aceite de teca que penetra la fibra, resistente a UV y humedad, para bodas de lujo y eventos VIP en CDMX. Desde $1,800.",
    url: "/servicios/mobiliario/mesas-picnic/especiales/teka/",
    priceRange: { min: 1800, max: 4200 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Especiales & Farm", url: "/servicios/mobiliario/mesas-picnic/especiales/" },
    { name: "Mesa Madera Teka", url: "/servicios/mobiliario/mesas-picnic/especiales/teka/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Redonda de Madera", href: "/servicios/mobiliario/mesas-picnic/especiales/redonda/" },
  { name: "Mesa Biergarten", href: "/servicios/mobiliario/mesas-picnic/especiales/biergarten/" },
  { name: "Mesa Madera Teka", href: null, active: true },
  { name: "Mesa Farm Patas de Horquilla", href: "/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/" },
  { name: "Mesa Sweetheart para Novios", href: "/servicios/mobiliario/mesas-picnic/especiales/sweetheart/" },
  { name: "Mesa de Parota", href: "/servicios/mobiliario/mesas-picnic/especiales/parota/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta de Mesa de Madera Teka para Eventos en CDMX"
  description="Renta mesa de madera teka maciza 2.00 × 1.00 m en CDMX — 8 personas. Aceite de teca resistente a UV y humedad para bodas de lujo y eventos VIP. Desde $1,800."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Madera premium de exterior — bodas de lujo y VIP"
    title='Mesa de Madera <span class="highlight">Teka</span> — 8 Personas — Renta CDMX'
    subtitle="Mesa de teka maciza de 2.00 × 1.00 m para 8 personas, tratada con aceite de teca que penetra la fibra y la vuelve resistente a rayos UV y humedad. La opción de lujo para bodas y eventos VIP al aire libre. Desde $1,800."
    primaryCTA={{ label: "Cotizar mesa de teka", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa de Madera Teka para mi evento` }}
    cards={[
      {
        title: "Aceite de teca que penetra la fibra: resistencia real al exterior",
        content: "La <strong>Mesa de Madera Teka</strong> se trata con <strong>aceite de teca que penetra la fibra</strong> —no solo la recubre— y la vuelve resistente a rayos UV y humedad. Por eso es la madera preferida en el mundo para mobiliario de exterior de alta gama: resiste sol directo y sereno sin agrietarse ni decolorar, conservando su cálida pátina. La elección natural para <strong>bodas de lujo en jardín y hacienda</strong>.",
      },
      {
        title: "Una veta tan bella que no necesita mantel",
        content: "Con <strong>2.00 × 1.00 m para 8 personas</strong>, el metro de ancho da espacio holgado para vajilla y centro de mesa. La belleza de su veta hace que la mayoría la deje desnuda como elemento de diseño. Es parte de la línea especializada de nuestro sitio hermano <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">mesaspicnic.com — sitio especializado en mesas picnic</a>. Entrega, montaje y recolección incluidos, sin límite de tiempo.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Buscas una mesa premium que resista tu boda al aire libre?"
    subheadline="Asesoría sin costo — te decimos cuántas mesas de teka necesitas y cómo combinarlas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Especiales & Farm</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa de Madera Teka para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa de Madera Teka`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa de Madera Teka en Eventos Reales</h2>
            <p class="section__subtitle">Bodas de lujo, mesas de honor y eventos VIP al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.2 4.2l1.4 1.4M18.4 18.4l1.4 1.4M1 12h2M21 12h2M4.2 19.8l1.4-1.4M18.4 5.6l1.4-1.4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Madera Teka</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la teka es la madera reina del exterior?"
    headingId="descripcion-heading"
    badge="Madera maciza premium para bodas de lujo"
    tags={["2.00 × 1.00 m", "8 personas", "Resistente UV", "Bodas VIP"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La teca es la madera que la industria del mobiliario de exterior de alta gama eligió hace siglos, y por una razón: el <strong>aceite de teca penetra la fibra</strong> en lugar de quedarse en la superficie. Eso la vuelve <strong>resistente a los rayos UV y a la humedad</strong>, evita que se agriete o pierda color con el sol y le regala esa pátina cálida y aterciopelada que define su carácter premium.</p>
      <p class="showcase__text">Con <strong>2.00 × 1.00 m para 8 comensales</strong>, el metro de ancho garantiza que cada invitado tenga espacio de sobra para vajilla, cristalería y un centro de mesa generoso. La veta de la teca es tan bella que la mayoría de las bodas de lujo la deja desnuda: la mesa misma es la decoración.</p>
      <p class="showcase__text">Cada pieza se inspecciona antes de entregar. Es una madera de inventario limitado, por lo que conviene reservarla con anticipación. Combínala con <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> y <a href="/servicios/iluminacion/">iluminación</a> cálida para un montaje VIP inolvidable. Desde $1,800 por mesa con montaje incluido.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Mesa de madera teka montada para boda de lujo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif" alt="Mesa de teka con veta realzada para evento VIP" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-02.avif" alt="Mesa de teka resistente a UV en montaje al aire libre" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la mesa de teka</h2>
            <p class="section__subtitle">Combinaciones de sillas, iluminación y decoración de alto perfil</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda de Lujo en Jardín</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Teka desnuda + <strong>silla crossback natural</strong> + runner de lino + velas. La resistencia UV permite montarla desde la tarde sin miedo al sol. Estética premium sin necesidad de mantel.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Mesa de Honor VIP</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Teka + <strong>sillas tapizadas</strong> + centro floral bajo + iluminación cálida. La calidez de la madera y su veta convierten la mesa principal en el punto focal del banquete.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Evento Corporativo VIP</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Teka + <strong>sillas de diseño</strong> + montaje minimalista. Para cenas ejecutivas al aire libre donde se busca proyectar categoría con materiales nobles y duraderos.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa de Madera Teka</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa de Madera Teka"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["Madera maciza premium para exterior. Capacidad 8 personas, aceite de teca resistente a UV y humedad, para bodas de lujo y eventos VIP."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te asesoramos sobre disponibilidad, cantidad y combinación de mesas de teka.</p>
