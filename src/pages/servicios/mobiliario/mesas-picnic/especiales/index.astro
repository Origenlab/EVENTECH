---
/**
 * ─── Mesas Especiales & Farm — Página de Familia (Nivel 5) ───
 * Formatos de autor en madera: redonda, biergarten, teka, farm de horquilla,
 * sweetheart y parota maciza. El centro visual del evento.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Mesas Especiales & Farm
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Especiales & Farm" },
];

const faqs = [
  { question: "¿Qué diferencia a las Mesas Especiales & Farm de la mesa picnic clásica?", answer: 'La línea clásica de <a href="/servicios/mobiliario/mesas-picnic/picnic/">mesas picnic</a> resuelve la mayoría de los invitados con bancas integradas de pino. Las <strong>Mesas Especiales & Farm</strong> son formatos de autor pensados para ser el <strong>centro visual del evento</strong>: la redonda que elimina cabeceras y favorece la conversación, la biergarten europea de festival, la farm de patas de horquilla en hierro forjado, la sweetheart exclusiva para los novios y las maderas macizas premium de teca y parota. Se eligen por diseño, no solo por capacidad.' },
  { question: "¿Cuál es el modelo de mayor categoría?", answer: 'La <strong>Mesa Picnic de Parota</strong> es el modelo tope de la colección — parota maciza mexicana con una dureza Janka de <strong>1,480 lbf</strong>, veta única en cada pieza y acabado de aceite de teca más barniz. Le sigue la <strong>Mesa Madera Teka</strong>, tratada con aceite de teca que penetra la fibra y la vuelve resistente a rayos UV y humedad. Ambas son las opciones preferidas para bodas de lujo, mesas de honor y eventos VIP. Desde $1,800 (teka) y $2,200 (parota).' },
  { question: "¿Estos formatos incluyen sillas o bancas?", answer: 'Depende del modelo. La <strong>Biergarten</strong> incluye 2 bancas removibles al estilo cervecería europea. La <strong>Redonda</strong>, la <strong>Teka</strong>, la <strong>Sweetheart</strong> y la <strong>Parota</strong> se rentan como mesa para combinar con la silla que elijas. La <strong>Farm Patas de Horquilla</strong> se diseñó específicamente sin bancas para vestirse con sillas libres — combina de maravilla con nuestras <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> de madera para un look industrial-natural.' },
  { question: "¿Funcionan en exteriores y jardines?", answer: 'Sí. Todas las piezas están barnizadas a mano para uso en jardín, terraza, hacienda y salón. Los modelos de <strong>teca y parota</strong> son los más resistentes a la intemperie gracias al aceite de teca que penetra la fibra y protege contra sol y humedad. Para eventos completamente al aire libre recomendamos complementar con nuestras <a href="/servicios/carpas/">carpas profesionales</a> y <a href="/servicios/iluminacion/">iluminación</a> como respaldo ante lluvia y para ambientar la noche.' },
  { question: "¿Puedo combinar varios modelos especiales en un mismo evento?", answer: 'Sí, es lo más común en bodas de alto perfil: una <strong>Sweetheart</strong> para los novios, mesas <strong>Redondas</strong> o de <strong>Parota</strong> para los invitados de honor y una <strong>Farm de horquilla</strong> como mesa de firmas o candy bar. Todo entra en una sola cotización y una sola entrega. Nuestro equipo te ayuda a diseñar la combinación que mejor aprovecha tu espacio y presupuesto.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Las maderas macizas de <strong>teca y parota</strong> son piezas de inventario limitado, por lo que recomendamos apartar con <strong>3 a 6 semanas de anticipación</strong>, especialmente en temporada alta de bodas (noviembre a febrero). Para los demás formatos, de 1 a 2 semanas suele ser suficiente. Un anticipo confirma tu fecha. Entrega, montaje y recolección incluidos, sin límite de tiempo durante el evento.' },
];

const specs = [
  { label: "Maderas", value: "Pino nacional, teca y parota maciza mexicana" },
  { label: "Formatos", value: "Redonda, biergarten, farm de horquilla, sweetheart y macizas" },
  { label: "Capacidad", value: "De 2 (sweetheart) a 10 personas por mesa" },
  { label: "Acabado", value: "Lijado a grano fino + barniz de exterior (hasta 4 manos)" },
  { label: "Maderas premium", value: "Teca (resistente UV/humedad) y parota (Janka 1,480 lbf)" },
  { label: "Uso", value: "Interior y exterior — jardín, terraza, hacienda, salón" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Tiempo de uso", value: "Sin límite durante el evento" },
  { label: "Inventario", value: "Piezas inspeccionadas una a una antes de entregar" },
  { label: "Precio referencial", value: "Desde $500 por mesa / evento" },
];

const sidebarNav = [
  { name: "Mesas Picnic", href: "/servicios/mobiliario/mesas-picnic/picnic/" },
  { name: "Especiales & Farm", href: null, active: true },
  { name: "Sets y Complementos", href: "/servicios/mobiliario/mesas-picnic/sets/" },
  { name: "Para Niños", href: "/servicios/mobiliario/mesas-picnic/infantil/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Valeria Fuentes", text: "Rentamos una Sweetheart para nosotros y dos mesas de Parota para los papás en nuestra boda en una hacienda. La madera es una belleza real, la veta de la parota se robó las fotos. Montaje impecable y sin límite de tiempo.", rating: 5, date: "2025-11-22" },
  { author: "Diego Alcántara", text: "Para un festival gastronómico montamos 12 biergarten. Formato perfecto de cervecería, las bancas removibles facilitaron la logística y la madera aguantó todo el fin de semana al aire libre. Repetimos seguro.", rating: 5, date: "2025-10-14" },
  { author: "Mariana Ochoa", text: "La mesa farm de patas de horquilla fue el centro visual de nuestra activación de marca. Combinada con sillas crossback quedó justo con el look industrial-natural que buscábamos. Súper profesionales.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesas Especiales y Farm de Madera para Eventos en CDMX",
    description: "Renta de mesas especiales de madera en CDMX: redonda, biergarten, farm de patas de horquilla, sweetheart, teca y parota maciza. Formatos de autor para bodas y eventos VIP. Desde $500.",
    url: "/servicios/mobiliario/mesas-picnic/especiales/",
    priceRange: { min: 500, max: 5500 },
    reviews,
    ratingValue: 5,
    reviewCount: 46,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Especiales & Farm", url: "/servicios/mobiliario/mesas-picnic/especiales/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mesas Especiales y Farm de Madera para Eventos en CDMX"
  description="Renta de mesas especiales de madera en CDMX: redonda, biergarten, farm de horquilla, sweetheart, teca y parota maciza. Formatos de autor para bodas y eventos VIP. Desde $500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diseño de autor — el centro visual del evento"
    title='Renta de <span class="highlight">Mesas Especiales & Farm</span> de Madera en CDMX'
    subtitle="Seis formatos de madera que se vuelven protagonistas: redonda de conversación, biergarten de festival, farm de patas de horquilla, sweetheart para novios y maderas macizas de teca y parota. Barnizadas a mano, con entrega, montaje y recolección incluidos. Desde $500."
    primaryCTA={{ label: "Cotiza tu mesa especial", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una mesa especial o farm de madera para mi evento` }}
    cards={[
      {
        title: "Formatos de autor que se convierten en el punto focal",
        content: "<strong>Renta de mesas especiales y farm de madera</strong> para eventos donde la mesa tiene que ser protagonista. La <strong>Redonda</strong> elimina cabeceras y facilita la conversación, la <strong>Biergarten</strong> recrea la cervecería europea con bancas removibles, la <strong>Farm de patas de horquilla</strong> aporta un look industrial-natural en hierro forjado negro mate, y la <strong>Sweetheart</strong> es la mesa exclusiva para los novios. Todas en madera lijada a grano fino y barnizada a mano.",
      },
      {
        title: "Maderas macizas premium de teca y parota mexicana",
        content: "<strong>Servicio integral de mobiliario de madera</strong> con las piezas de mayor categoría del catálogo: la <strong>Teca</strong>, tratada con aceite que penetra la fibra y la vuelve resistente a UV y humedad, y la <strong>Parota</strong> maciza mexicana con dureza Janka de 1,480 lbf y veta única en cada tabla. Es la línea especializada de nuestro sitio hermano <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">mesaspicnic.com — sitio especializado en mesas picnic</a>. Entrega, montaje y recolección incluidos, sin límite de tiempo.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas una mesa de madera que sea el centro de tu evento?"
    subheadline="Cotiza sin compromiso — te asesoramos con el formato y la combinación ideal para tu venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MODELOS — Cards que linkan a cada ficha L6
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="modelos-heading">
    <div class="container">
      <SectionHeader
        id="modelos-heading"
        title="6 modelos especiales — elige el tuyo"
        subtitle="Cada formato tiene su personalidad"
        description={[
          "Explora los detalles, medidas, capacidad y para qué evento funciona mejor cada modelo. Desde la redonda de conversación hasta las maderas macizas de teca y parota — todas barnizadas a mano y con montaje incluido."
        ]}
      />

      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="grid grid--3">
        <ProductCard
          name="Mesa Redonda de Madera"
          price="Desde $550"
          excerpt="Ø 1.50 m para 8-10 personas. Sin cabecera: el formato de conversación que elimina jerarquías. Ideal para bodas íntimas y mesas corporativas donde todos se ven de frente."
          href="/servicios/mobiliario/mesas-picnic/especiales/redonda/"
          image="/images/mobiliario/candy-bar-boda-rustica-madera.avif"
          badge="Conversación"
          tags={["Ø 1.50 m", "8-10 personas", "Bodas íntimas", "Corporativo"]}
        />
        <ProductCard
          name="Mesa Biergarten"
          price="Desde $500"
          excerpt="2.20 × 0.60 m para 10 personas. Formato europeo de cervecería con 2 bancas removibles. El favorito de food markets, ferias y festivales gastronómicos."
          href="/servicios/mobiliario/mesas-picnic/especiales/biergarten/"
          image="/images/mobiliario/candy-bar-jardin-exterior.avif"
          badge="Festival"
          tags={["2.20 × 0.60 m", "10 personas", "2 bancas", "Festivales"]}
        />
        <ProductCard
          name="Mesa Madera Teka"
          price="Desde $1,800"
          excerpt="2.00 × 1.00 m para 8 personas. Aceite de teca que penetra la fibra y la vuelve resistente a UV y humedad. La opción de lujo para bodas VIP al aire libre."
          href="/servicios/mobiliario/mesas-picnic/especiales/teka/"
          image="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif"
          badge="Lujo VIP"
          tags={["2.00 × 1.00 m", "8 personas", "Resistente UV", "Bodas de lujo"]}
        />
        <ProductCard
          name="Mesa Farm Patas de Horquilla"
          price="Desde $950"
          excerpt="2.40 × 0.84 m para 10 personas. Tablero de pino + patas de hierro forjado negro mate, sin bancas para vestir con sillas libres. Look industrial-natural, la más fotogénica."
          href="/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/"
          image="/images/mobiliario/crossback-madera-01.avif"
          badge="La más fotogénica"
          tags={["2.40 × 0.84 m", "10 personas", "Hierro forjado", "Activaciones"]}
        />
        <ProductCard
          name="Mesa Sweetheart para Novios"
          price="Desde $650"
          excerpt="1.50 × 0.84 m para 2 personas. Barniz a 4 manos, exclusiva para la pareja. El centro visual de la boda: donde los novios presiden la celebración."
          href="/servicios/mobiliario/mesas-picnic/especiales/sweetheart/"
          image="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif"
          badge="Solo para novios"
          tags={["1.50 × 0.84 m", "2 personas", "Barniz 4 manos", "Bodas"]}
        />
        <ProductCard
          name="Mesa Picnic de Parota"
          price="Desde $2,200"
          excerpt="2.00 × 0.90 m para 8 personas. Parota maciza mexicana (dureza Janka 1,480 lbf) con veta única, aceite de teca y barniz. El modelo de mayor categoría del catálogo."
          href="/servicios/mobiliario/mesas-picnic/especiales/parota/"
          image="/images/mobiliario/barras-postres-mesa-vintage.avif"
          badge="Máxima categoría"
          tags={["2.00 × 0.90 m", "8 personas", "Parota maciza", "Eventos VIP"]}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre modelos y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Picnic y Madera</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas una mesa especial de madera para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una mesa especial o farm de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesas Especiales & Farm</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Mesa Picnic de Parota -->
          <section class="section section--alt" aria-labelledby="parota-heading">
            <ServiceShowcase
    title="Mesa Picnic de Parota — la de mayor categoría"
    headingId="parota-heading"
    badge="Máxima categoría"
    subtitle="Parota maciza mexicana con veta única: la pieza tope del catálogo para eventos VIP."
    tags={["Parota maciza", "Janka 1,480 lbf", "8 personas", "Eventos VIP"]}
    ctaHref="/servicios/mobiliario/mesas-picnic/especiales/parota/"
    ctaLabel="Ver Mesa de Parota"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>Mesa Picnic de Parota</strong> (2.00 × 0.90 m, 8 personas) es el modelo de mayor categoría de la colección. Fabricada en <strong>parota maciza mexicana</strong> —una madera con dureza Janka de <strong>1,480 lbf</strong> que la hace extraordinariamente estable y duradera— cada tabla muestra una <strong>veta única</strong> imposible de replicar. El acabado combina aceite de teca y barniz para realzar el color natural de la madera y protegerla en exteriores.</p>
      <p class="showcase__text">Es la elección para bodas de lujo, mesas de honor y eventos VIP donde la mesa misma es un objeto de diseño. La parota no necesita mantelería: su superficie es el centro visual. Combínala con <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> de madera e <a href="/servicios/iluminacion/">iluminación</a> cálida para un montaje que se roba las fotos. Desde $2,200 por mesa con montaje incluido.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mesa de parota maciza para evento VIP en CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Mesa de parota con veta única para boda de lujo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-madera-rustica.avif" alt="Detalle de madera maciza de parota barnizada a mano" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Mesa Farm Patas de Horquilla -->
          <section class="section section--alt" aria-labelledby="farm-heading">
            <ServiceShowcase
    title="Mesa Farm Patas de Horquilla — la más fotogénica"
    headingId="farm-heading"
    badge="Look industrial-natural"
    subtitle="Tablero de pino + patas de hierro forjado negro mate, sin bancas para vestir con sillas libres."
    tags={["2.40 × 0.84 m", "10 personas", "Hierro forjado", "Activaciones"]}
    ctaHref="/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/"
    ctaLabel="Ver Farm de Horquilla"
  >
    <Fragment slot="body">
