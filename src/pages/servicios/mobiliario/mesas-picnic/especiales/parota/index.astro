---
/**
 * ─── Mesa Picnic de Parota — Página de Ficha (Nivel 6) ───
 * 2.00 × 0.90 m, 8 personas. Parota maciza mexicana (Janka 1,480 lbf), veta única.
 * El modelo de mayor categoría del catálogo. Jerarquía:
 * Servicios > Mobiliario > Mesas Picnic y Madera > Especiales & Farm > Parota
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { label: "Mesa Picnic de Parota" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa de parota maciza de 2.00 m para evento VIP en CDMX" },
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Mesa de parota mexicana con veta única para boda de lujo" },
  { src: "/images/mobiliario/barras-postres-mesa-madera-rustica.avif", alt: "Detalle de la veta única de la mesa de parota maciza" },
  { src: "/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif", alt: "Mesa de parota como mesa de honor en banquete VIP" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa de parota maciza barnizada con aceite de teca" },
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Mesa de parota mexicana montada al aire libre para evento de lujo" },
];

const faqs = [
  {
    question: "¿Qué es la madera de parota y por qué es tan valorada?",
    answer: "La <strong>parota</strong> (también llamada guanacaste) es una madera maciza <strong>mexicana</strong> apreciada por su gran tamaño de tabla, su estabilidad y su <strong>veta única e irrepetible</strong> con vetas oscuras que atraviesan tonos miel. Tiene una dureza Janka de <strong>1,480 lbf</strong>, lo que la hace extraordinariamente resistente y duradera. Es la madera preferida para piezas de autor y muebles de alta gama en México."
  },
  {
    question: "¿Por qué es el modelo de mayor categoría del catálogo?",
    answer: "Porque combina lo mejor de todo: una <strong>madera maciza mexicana</strong> de dureza excepcional (Janka 1,480 lbf), un tamaño de tabla que permite piezas enteras sin uniones visibles, una <strong>veta única</strong> que convierte a cada mesa en un objeto irrepetible, y un acabado premium de <strong>aceite de teca más barniz</strong>. No hay otra mesa en el catálogo con esta combinación — es la elección para los eventos más exclusivos. Desde $2,200."
  },
  {
    question: "¿Cuántas personas caben en la mesa de parota?",
    answer: "La <strong>Mesa Picnic de Parota</strong> mide <strong>2.00 × 0.90 m</strong> y acomoda a <strong>8 personas</strong> con holgura. El ancho de 90 cm da espacio de sobra para vajilla completa, cristalería y centro de mesa, mientras la parota luce su veta como protagonista. Es ideal como mesa de honor o para las mesas principales de un evento VIP."
  },
  {
    question: "¿Qué acabado tiene y aguanta el exterior?",
    answer: "Lleva <strong>aceite de teca que nutre y protege la fibra</strong>, más barniz para sellar y realzar la veta. Esta combinación la hace resistente y apta para jardín, terraza y hacienda, además de interiores. La densidad de la parota (Janka 1,480 lbf) la vuelve muy estable ante cambios de humedad. Para eventos largos al aire libre, complementa con nuestras <a href=\"/servicios/carpas/\">carpas</a> como respaldo."
  },
  {
    question: "¿En qué se diferencia de la mesa de teka?",
    answer: "Ambas son maderas macizas premium. La <a href=\"/servicios/mobiliario/mesas-picnic/especiales/teka/\">teka</a> es la reina del exterior por su aceite que penetra la fibra (resistente a UV y humedad, desde $1,800). La <strong>parota</strong> es el tope del catálogo por su dureza (Janka 1,480 lbf), su tamaño de tabla y su veta única mexicana (desde $2,200). Si buscas la pieza más exclusiva y con más carácter, es la parota."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "La parota es la pieza más exclusiva del catálogo y de <strong>inventario muy limitado</strong>, por lo que recomendamos apartar con <strong>4 a 6 semanas de anticipación</strong>, y con más tiempo en temporada alta de bodas. Un anticipo confirma tu fecha. Entrega, montaje y recolección incluidos, sin límite de tiempo durante el evento. Desde $2,200 por mesa."
  },
];

const specs = [
  { label: "Medidas", value: "2.00 × 0.90 m" },
  { label: "Capacidad", value: "8 personas" },
  { label: "Madera", value: "Parota maciza mexicana (guanacaste)" },
  { label: "Dureza", value: "Janka 1,480 lbf — extraordinariamente resistente" },
  { label: "Veta", value: "Única e irrepetible en cada pieza" },
  { label: "Acabado", value: "Aceite de teca + barniz que realza la veta" },
  { label: "Categoría", value: "El modelo de mayor categoría del catálogo" },
  { label: "Uso ideal", value: "Bodas de lujo, mesas de honor, eventos VIP" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Precio referencial", value: "Desde $2,200 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Alejandra del Río", text: "La mesa de parota fue el lujo de nuestra boda. La veta es una obra de arte, cada quien preguntaba de dónde la habíamos sacado. La usamos como mesa de honor sin mantel y fue el centro absoluto del banquete. Impecable de principio a fin.", rating: 5, date: "2025-11-21" },
  { author: "Patricio Lémus", text: "Para un evento VIP corporativo buscábamos la mesa más exclusiva y la parota lo cumplió. Su tamaño, su dureza y esa veta única proyectaron exactamente la categoría que queríamos. Servicio y montaje de primer nivel.", rating: 5, date: "2025-10-06" },
  { author: "Sofía Everardo", text: "Como planner, la parota es mi carta fuerte para bodas de alto perfil. Es de inventario limitado pero vale cada peso: no hay dos mesas iguales y siempre roba las fotos. Entrega puntual y en condiciones perfectas.", rating: 5, date: "2025-09-16" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa de Parota Maciza para Eventos en CDMX",
    description: "Mesa picnic de parota maciza mexicana 2.00 × 0.90 m para 8 personas. Dureza Janka 1,480 lbf, veta única, aceite de teca + barniz. El modelo de mayor categoría para eventos VIP en CDMX. Desde $2,200.",
    url: "/servicios/mobiliario/mesas-picnic/especiales/parota/",
    priceRange: { min: 2200, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Especiales & Farm", url: "/servicios/mobiliario/mesas-picnic/especiales/" },
    { name: "Mesa Picnic de Parota", url: "/servicios/mobiliario/mesas-picnic/especiales/parota/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Redonda de Madera", href: "/servicios/mobiliario/mesas-picnic/especiales/redonda/" },
  { name: "Mesa Biergarten", href: "/servicios/mobiliario/mesas-picnic/especiales/biergarten/" },
  { name: "Mesa Madera Teka", href: "/servicios/mobiliario/mesas-picnic/especiales/teka/" },
  { name: "Mesa Farm Patas de Horquilla", href: "/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/" },
  { name: "Mesa Sweetheart para Novios", href: "/servicios/mobiliario/mesas-picnic/especiales/sweetheart/" },
  { name: "Mesa de Parota", href: null, active: true },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta de Mesa de Parota Maciza para Eventos en CDMX"
  description="Renta mesa de parota maciza mexicana 2.00 × 0.90 m en CDMX — 8 personas. Dureza Janka 1,480 lbf, veta única, el modelo de mayor categoría para eventos VIP. Desde $2,200."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El modelo de mayor categoría — parota maciza mexicana"
    title='Mesa Picnic de <span class="highlight">Parota</span> — 8 Personas — Renta CDMX'
    subtitle="Mesa de parota maciza mexicana de 2.00 × 0.90 m para 8 personas: dureza Janka de 1,480 lbf, veta única e irrepetible y acabado de aceite de teca más barniz. Es el modelo de mayor categoría del catálogo, reservado para los eventos más exclusivos. Desde $2,200."
    primaryCTA={{ label: "Cotizar mesa de parota", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic de Parota para mi evento` }}
    cards={[
      {
        title: "Parota maciza mexicana con veta única e irrepetible",
        content: "La <strong>Mesa Picnic de Parota</strong> está hecha de <strong>parota maciza mexicana</strong> —una de las maderas más nobles del país—, con una dureza Janka de <strong>1,480 lbf</strong> que la hace extraordinariamente estable y duradera. Su gran tamaño de tabla permite piezas enteras y su <strong>veta única</strong>, con vetas oscuras que atraviesan tonos miel, convierte a cada mesa en un objeto irrepetible. Es <strong>el modelo tope del catálogo</strong>.",
      },
      {
        title: "Acabado de aceite de teca + barniz para eventos VIP",
        content: "Tratada con <strong>aceite de teca que nutre la fibra</strong> y barniz que sella y realza la veta, resiste interior y exterior. Con 2.00 × 0.90 m para 8 personas, es la mesa de honor perfecta. Es la pieza estrella de la línea especializada de nuestro sitio hermano <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">mesaspicnic.com — sitio especializado en mesas picnic</a>. Entrega, montaje y recolección incluidos.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Buscas la mesa más exclusiva para tu evento? La parota no tiene igual"
    subheadline="Inventario muy limitado — confirma disponibilidad y asegura tu fecha con anticipación"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Especiales & Farm</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa de Parota para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Picnic de Parota`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Picnic de Parota en Eventos Reales</h2>
            <p class="section__subtitle">Bodas de lujo, mesas de honor y eventos VIP en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Picnic de Parota</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la parota es la mesa más exclusiva del catálogo?"
    headingId="descripcion-heading"
    badge="Madera maciza mexicana de máxima categoría"
    tags={["2.00 × 0.90 m", "8 personas", "Janka 1,480 lbf", "Eventos VIP"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La parota —o guanacaste— es una de las maderas más nobles de México. Lo que la distingue es la combinación de tres virtudes: una <strong>dureza excepcional (Janka 1,480 lbf)</strong> que la hace estable y duradera, un <strong>tamaño de tabla</strong> que permite fabricar la mesa con piezas enteras sin uniones visibles, y una <strong>veta única e irrepetible</strong>, con vetas oscuras que atraviesan tonos miel y hacen que no existan dos mesas iguales.</p>
      <p class="showcase__text">Con <strong>2.00 × 0.90 m para 8 comensales</strong> y un acabado de <strong>aceite de teca más barniz</strong> que nutre la fibra y realza la veta, la parota no necesita mantelería: la mesa misma es la obra de arte. Es la elección para mesas de honor y las mesas principales de los eventos más exclusivos, donde el material habla por sí solo.</p>
      <p class="showcase__text">Es una pieza de <strong>inventario muy limitado</strong> —el modelo tope del catálogo— por lo que conviene reservarla con anticipación. Combínala con <a href="/servicios/mobiliario/sillas/crossback/">sillas crossback</a> de madera e <a href="/servicios/iluminacion/">iluminación</a> cálida para un montaje VIP que nadie olvidará. Desde $2,200 por mesa con montaje incluido.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mesa de parota maciza montada para evento VIP" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Mesa de parota con veta única para boda de lujo" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-madera-rustica.avif" alt="Detalle de la veta de la parota maciza mexicana" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la mesa de parota</h2>
            <p class="section__subtitle">Combinaciones de alto perfil para eventos VIP</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Mesa de Honor VIP</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Parota desnuda + <strong>sillas crossback</strong> + camino floral bajo. La veta única como protagonista, sin mantel. El montaje que convierte a la mesa principal en el punto focal del evento.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Boda de Lujo en Hacienda</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Varias parotas para invitados de honor + <strong>iluminación cálida</strong>. La madera maciza aporta una categoría que ningún otro material iguala en bodas de alto perfil al aire libre.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Evento Corporativo VIP</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Parota + <strong>sillas de diseño</strong> + montaje minimalista. Para cenas ejecutivas y presentaciones donde proyectar exclusividad con materiales nobles es la prioridad.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Picnic de Parota</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Picnic de Parota"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El modelo de mayor categoría del catálogo. Parota maciza mexicana, dureza Janka 1,480 lbf, veta única y con montaje incluido."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
