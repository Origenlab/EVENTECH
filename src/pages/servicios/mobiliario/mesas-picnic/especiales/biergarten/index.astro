---
/**
 * ─── Mesa Biergarten — Página de Ficha (Nivel 6) ───
 * 2.20 × 0.60 m, 10 personas. Formato europeo de cervecería, 2 bancas removibles.
 * Jerarquía: Servicios > Mobiliario > Mesas Picnic y Madera > Especiales & Farm > Biergarten
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas Picnic y Madera", href: "/servicios/mobiliario/mesas-picnic/" },
  { label: "Mesas Especiales & Farm", href: "/servicios/mobiliario/mesas-picnic/especiales/" },
  { label: "Mesa Biergarten" },
];

// PLACEHOLDER: reemplazar por foto real del modelo
const galleryImages = [
  { src: "/images/mobiliario/candy-bar-jardin-exterior.avif", alt: "Mesa biergarten de madera con bancas para festival al aire libre en CDMX" },
  { src: "/images/mobiliario/crossback-madera-01.avif", alt: "Mesa biergarten de cervecería europea de 2.20 m para 10 personas" },
  { src: "/images/mobiliario/barras-postres-mesa-vintage.avif", alt: "Mesa biergarten con bancas removibles para food market" },
  { src: "/images/mobiliario/crossback-madera-02.avif", alt: "Mesa biergarten de madera montada en feria gastronómica" },
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Mesa biergarten de pino barnizada para festival de cerveza" },
  { src: "/images/mobiliario/candy-bar-boda-rustica-madera.avif", alt: "Mesa biergarten de madera en montaje de convivencia grupal" },
];

const faqs = [
  {
    question: "¿Qué es una mesa biergarten y cuántas personas caben?",
    answer: "La <strong>Mesa Biergarten</strong> es el formato clásico de las cervecerías al aire libre alemanas: una <strong>mesa larga y angosta de 2.20 × 0.60 m</strong> con dos bancas corridas, una a cada lado. Acomoda <strong>10 personas</strong> (5 por banca) y fomenta la convivencia grupal codo a codo. Es el mueble por excelencia de food markets, ferias y festivales."
  },
  {
    question: "¿Las bancas se pueden quitar?",
    answer: "Sí. Las <strong>2 bancas son removibles</strong>, lo que facilita muchísimo la logística: se transportan y almacenan aparte, se montan en segundos y permiten reconfigurar el espacio según el evento. Puedes usarlas a ambos lados para el formato clásico, o retirar una para arrimar la mesa a una pared o barra."
  },
  {
    question: "¿Para qué tipo de eventos funciona mejor?",
    answer: "Es ideal para <strong>food markets, ferias, festivales gastronómicos y de cerveza artesanal</strong>, kermeses, convivencias corporativas informales y fiestas de jardín donde se busca ambiente relajado y de convivencia. El formato largo aprovecha muy bien espacios alargados y permite sentar a mucha gente en poco metraje."
  },
  {
    question: "¿Aguanta el uso en exteriores todo el día?",
    answer: "Sí. Está fabricada en <strong>madera barnizada a mano</strong> pensada para uso intensivo al aire libre. Para eventos de todo el día o varios días, recomendamos complementar con nuestras <a href=\"/servicios/carpas/\">carpas profesionales</a> para dar sombra y proteger de la lluvia, e <a href=\"/servicios/iluminacion/\">iluminación</a> para la parte nocturna del festival."
  },
  {
    question: "¿Cuántas mesas biergarten necesito para mi evento?",
    answer: "Cada mesa sienta a 10 personas, así que divide tu número de asistentes entre 10 para una estimación rápida. Para un festival de 200 personas necesitarías unas 20 mesas, dejando pasillos de circulación. Contamos con inventario para montajes grandes y te ayudamos a calcular la cantidad exacta y el layout."
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Para festivales y ferias con muchas mesas, recomendamos apartar con <strong>2 a 3 semanas de anticipación</strong>. Un anticipo confirma tu fecha y la cantidad. Entrega, montaje y recolección incluidos, sin límite de tiempo durante el evento. Desde $500 por mesa con sus 2 bancas."
  },
];

const specs = [
  { label: "Medidas", value: "2.20 × 0.60 m" },
  { label: "Capacidad", value: "10 personas (5 por banca)" },
  { label: "Formato", value: "Cervecería europea — mesa larga con 2 bancas" },
  { label: "Bancas", value: "2 removibles, incluidas" },
  { label: "Material", value: "Madera de pino lijada a grano fino" },
  { label: "Acabado", value: "Barnizada a mano para interior y exterior" },
  { label: "Uso ideal", value: "Food markets, ferias, festivales, convivencias" },
  { label: "Servicio", value: "Entrega, montaje y recolección incluidos" },
  { label: "Tiempo de uso", value: "Sin límite durante el evento" },
  { label: "Precio referencial", value: "Desde $500 por mesa / evento" },
];

// PLACEHOLDER reviews
const reviews = [
  { author: "Sebastián Guerra", text: "Montamos 18 biergarten para un festival de cerveza artesanal. El formato es perfecto: la gente convive, caben muchos en poco espacio y las bancas removibles nos salvaron en la logística de armado. Repetimos el próximo año.", rating: 5, date: "2025-11-08" },
  { author: "Ana Karen Ríos", text: "Food market de fin de semana con 12 mesas biergarten. Aguantaron dos días completos al aire libre sin problema y el ambiente de convivencia fue justo lo que buscábamos. Entrega y recolección puntuales.", rating: 5, date: "2025-10-11" },
  { author: "Rodrigo Nava", text: "Convivencia corporativa informal en jardín. Las biergarten le dieron ese aire de festival relajado que queríamos. Bancas cómodas y madera en excelente estado. Muy recomendables.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa Biergarten de Madera para Eventos en CDMX",
    description: "Mesa biergarten de madera 2.20 × 0.60 m para 10 personas con 2 bancas removibles. Formato europeo de cervecería para food markets, ferias y festivales en CDMX. Desde $500.",
    url: "/servicios/mobiliario/mesas-picnic/especiales/biergarten/",
    priceRange: { min: 500, max: 1200 },
    reviews,
    ratingValue: 5,
    reviewCount: 38,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas Picnic y Madera", url: "/servicios/mobiliario/mesas-picnic/" },
    { name: "Mesas Especiales & Farm", url: "/servicios/mobiliario/mesas-picnic/especiales/" },
    { name: "Mesa Biergarten", url: "/servicios/mobiliario/mesas-picnic/especiales/biergarten/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Mesa Redonda de Madera", href: "/servicios/mobiliario/mesas-picnic/especiales/redonda/" },
  { name: "Mesa Biergarten", href: null, active: true },
  { name: "Mesa Madera Teka", href: "/servicios/mobiliario/mesas-picnic/especiales/teka/" },
  { name: "Mesa Farm Patas de Horquilla", href: "/servicios/mobiliario/mesas-picnic/especiales/farm-hairpin/" },
  { name: "Mesa Sweetheart para Novios", href: "/servicios/mobiliario/mesas-picnic/especiales/sweetheart/" },
  { name: "Mesa de Parota", href: "/servicios/mobiliario/mesas-picnic/especiales/parota/" },
];

const sidebarRelated = [
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Barras", href: "/servicios/mobiliario/barras/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Iluminación", href: "/servicios/iluminacion/" },
  { name: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta de Mesa Biergarten de Madera para Eventos en CDMX"
  description="Renta mesa biergarten de madera 2.20 × 0.60 m en CDMX — 10 personas, 2 bancas removibles. Formato de cervecería para food markets, ferias y festivales. Desde $500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="Formato europeo de cervecería — festival y convivencia"
    title='Mesa <span class="highlight">Biergarten</span> — 10 Personas, 2 Bancas — Renta CDMX'
    subtitle="Mesa biergarten de madera de 2.20 × 0.60 m para 10 personas, con 2 bancas removibles al estilo de las cervecerías al aire libre europeas. El formato favorito de food markets, ferias y festivales. Barnizada a mano, con montaje incluido. Desde $500."
    primaryCTA={{ label: "Cotizar mesa biergarten", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Biergarten para mi evento` }}
    cards={[
      {
        title: "El formato de cervecería que fomenta la convivencia",
        content: "La <strong>Mesa Biergarten</strong> recrea el ambiente de las cervecerías al aire libre alemanas: una <strong>mesa larga y angosta con dos bancas corridas</strong> que sienta a 10 personas codo a codo. El formato invita a la convivencia grupal y aprovecha al máximo espacios alargados — por eso es el mueble estrella de <strong>food markets, ferias y festivales gastronómicos</strong>.",
      },
      {
        title: "Bancas removibles y madera lista para uso intensivo",
        content: "Sus <strong>2 bancas son removibles</strong>, lo que simplifica el transporte, el montaje y la reconfiguración del espacio. Fabricada en <strong>pino barnizado a mano</strong> para aguantar jornadas completas al aire libre. Es parte de la línea especializada de nuestro sitio hermano <a href=\"https://mesaspicnic.com/\" target=\"_blank\" rel=\"noopener\">mesaspicnic.com — sitio especializado en mesas picnic</a>. Entrega, montaje y recolección incluidos.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Montas un festival o food market? Calculamos tus mesas biergarten"
    subheadline="Asesoría de layout sin costo — cantidad de mesas, pasillos y distribución según tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Mesas Especiales & Farm</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa Biergarten para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la Mesa Biergarten`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Biergarten en Eventos Reales</h2>
            <p class="section__subtitle">Food markets, ferias y festivales al aire libre en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="9" width="20" height="6" rx="1"/><path d="M6 15v3M18 15v3M6 9V6M18 9V6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Biergarten</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- DESCRIPCIÓN DE VENTA -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la biergarten es el formato rey de los festivales?"
    headingId="descripcion-heading"
    badge="Convivencia grupal en madera natural"
    tags={["2.20 × 0.60 m", "10 personas", "2 bancas removibles", "Festivales"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La geometría de la biergarten no es casualidad: la <strong>mesa larga y angosta (2.20 × 0.60 m)</strong> con bancas corridas a los lados sienta a <strong>10 personas codo a codo</strong> y las obliga a convivir. Es el mueble que popularizaron las cervecerías al aire libre alemanas precisamente porque genera ambiente de comunidad — imposible de lograr con mesas individuales.</p>
      <p class="showcase__text">Sus <strong>2 bancas removibles</strong> son la clave logística: se montan en segundos, se apilan para transportar y permiten reconfigurar el espacio sobre la marcha. Fabricada en <strong>pino lijado a grano fino y barnizado a mano</strong>, resiste jornadas completas al aire libre en food markets y festivales de varios días.</p>
      <p class="showcase__text">Cada mesa y banca se inspecciona antes de entregar. Para festivales grandes, contamos con inventario para montajes de decenas de mesas en una sola entrega. Complementa con nuestras <a href="/servicios/carpas/">carpas</a> para sombra e <a href="/servicios/iluminacion/">iluminación</a> para la noche. Desde $500 por mesa con sus 2 bancas.</p>
    </Fragment>
    <Fragment slot="media">
      <!-- PLACEHOLDER: reemplazar por foto real del modelo -->
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/candy-bar-jardin-exterior.avif" alt="Mesa biergarten montada en festival al aire libre" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/crossback-madera-01.avif" alt="Mesa biergarten de madera con 2 bancas removibles" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barras-postres-mesa-vintage.avif" alt="Mesa biergarten para food market en CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- COMBINACIONES -->
          <section class="section" aria-labelledby="combos-heading">
            <h2 id="combos-heading" class="section__title">Montajes más pedidos con la mesa biergarten</h2>
            <p class="section__subtitle">Configuraciones que funcionan para festivales y convivencias</p>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Festival Gastronómico</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Filas de biergarten + <strong>carpas de sombra</strong> + barra de madera para bebidas. La distribución en hileras aprovecha el espacio y ordena la circulación entre stands de comida.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Food Market</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Biergarten en zona central + <strong>iluminación colgante</strong> para la tarde-noche. Ambiente relajado de convivencia que invita a quedarse a comer y beber en grupo.
                </p>
              </div>
              <div class="sidebar-card">
                <h3 class="sidebar-card__title">Convivencia Corporativa</h3>
                <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text);">
                  Biergarten + <strong>barra de cerveza artesanal</strong> + área de juegos. El formato informal rompe jerarquías y funciona perfecto para integración de equipos en jardín.
                </p>
              </div>
            </div>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Biergarten</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Mesa Biergarten"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["Formato de cervecería europea en madera natural. Capacidad 10 personas, 2 bancas removibles, barnizada a mano y con montaje incluido."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te ayudamos a calcular cuántas biergarten necesitas para tu festival o food market.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la renta de la Mesa Biergarten`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el aforo esperado y te calculamos mesas, pasillos y distribución al instante.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Modelos especiales y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Mesas Especiales & Farm</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
