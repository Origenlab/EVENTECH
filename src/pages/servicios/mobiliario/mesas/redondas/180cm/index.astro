---
/**
 * ─── Mesa Redonda 180cm — Página de Variante (Nivel 4) ───
 * Mesa redonda 180cm, 10 personas, banquetes VIP en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { label: "180cm — 10 personas" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesas-redondas-180cm-banquete-vip.avif", alt: "Mesa redonda 180cm en banquete VIP con 10 personas CDMX" },
  { src: "/images/mobiliario/mesas-redondas-montaje-dorado-bodas.avif", alt: "Mesas redondas en montaje dorado para bodas elegantes" },
  { src: "/images/mobiliario/mesa-redonda-detalle-chargers-dorados-flores.avif", alt: "Detalle mesa redonda 180cm con chargers y arreglo floral" },
  { src: "/images/mobiliario/mesa-redonda-overhead-chargers-boda.avif", alt: "Vista aérea mesa redonda con chargers dorados para boda VIP" },
  { src: "/images/mobiliario/mesas-redondas-jardin-exterior.avif", alt: "Mesas redondas 180cm en jardín exterior para boda" },
  { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas 180cm en montaje completo" },
];

const faqs = [
  {
    question: "¿Cuántas personas caben en una mesa redonda de 180cm?",
    answer: "Una <strong>mesa redonda de 180 cm</strong> tiene capacidad cómoda para <strong>10 personas</strong> — 5 de cada lado con holgura adecuada entre comensales. Con el mismo espacio que una mesa de 150 cm con 8 personas, la de 180 cm permite sentar 2 personas más sin sacrificar comodidad. Es la opción preferida para banquetes VIP donde se quiere sensación de amplitud y generosidad."
  },
  {
    question: "¿Cuál es la ventaja de usar 180cm sobre 150cm?",
    answer: "La mesa de 180 cm permite sentar <strong>10 personas vs 8</strong> de la de 150 cm, lo que significa que para 200 invitados necesitas 20 mesas en lugar de 25 — ahorrando espacio para más pista de baile, áreas de barra o decoración. También crea una sensación de mesa más generosa y espaciosa, ideal para bodas de lujo donde la experiencia del comensal es prioritaria."
  },
  {
    question: "¿La mesa de 180cm cabe en salones estándar?",
    answer: "Sí, pero requiere más planificación de layout. Con pasillos de servicio de 1.5 m, una mesa de 180 cm necesita un área de aproximadamente 3.3 × 3.3 metros por mesa. Para 20 mesas necesitas aproximadamente 500 m² de salón. Para salones más compactos, recomendamos la mesa de 150 cm que permite mejor densidad de distribución sin sacrificar pasillos."
  },
  {
    question: "¿El mantelero para 180cm es diferente al de 150cm?",
    answer: "Sí. La mesa de 180 cm requiere un <strong>mantel de mayor circunferencia</strong> — aproximadamente 420 cm de diámetro para que llegue al piso. Tenemos mantelería específica para 180 cm en todos nuestros colores y texturas. Al cotizar, especifica siempre el diámetro de la mesa para que te enviemos las medidas correctas."
  },
  {
    question: "¿Puedo combinar mesas de 150cm y 180cm en el mismo evento?",
    answer: "Totalmente recomendado. Una estrategia popular para bodas es usar <strong>mesas de 180 cm para los invitados principales</strong> y de 150 cm para el resto del salón. Esto crea jerarquía visual sutil y permite maximizar el espacio sin renunciar al formato VIP para ciertas mesas. Nuestro equipo diseña el layout combinado para que la distribución sea coherente visualmente."
  },
];

const specs = [
  { label: "Diámetro", value: "180 cm" },
  { label: "Altura", value: "75 cm (estándar banquete)" },
  { label: "Capacidad", value: "10 personas cómodas" },
  { label: "Material tablero", value: "Triplay alta densidad con melamínico resistente" },
  { label: "Estructura", value: "Base metálica plegable con niveladores ajustables" },
  { label: "Resistencia", value: "120 kg distribuidos sobre la superficie" },
  { label: "Sistema", value: "Plegable — fácil traslado y almacenamiento" },
  { label: "Mantel recomendado", value: "420 cm de circunferencia (hasta el piso)" },
  { label: "Precio referencial", value: "Desde $150 por mesa / evento" },
];

const reviews = [
  { author: "Patricia Vargas", text: "Las mesas de 180cm le dieron un nivel premium a nuestra boda. Los 10 invitados por mesa cabían con holgura y el espacio para el arreglo floral del centro quedó generoso.", rating: 5, date: "2025-12-05" },
  { author: "Gerardo Sandoval", text: "Para el evento corporativo quisimos dar sensación de lujo y elegimos las de 180cm. Con 18 mesas para 180 personas el salón quedó perfecto. Muy satisfecho con el servicio.", rating: 5, date: "2025-11-18" },
  { author: "Daniela Cruz", text: "Combinamos mesas de 150 y 180cm. Las de 180 para familiares directos y 150 para el resto. El equipo de EVENTECH diseñó el layout perfecto y todo quedó impecable.", rating: 5, date: "2025-10-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Redonda 180cm para Bodas en CDMX — 10 Personas",
    description: "Mesa redonda 180cm para 10 personas. El formato VIP para banquetes de bodas y galas en CDMX. Tablero melamínico, niveladores ajustables. Desde $150.",
    url: "/servicios/mobiliario/mesas/redondas/180cm/",
    priceRange: { min: 150, max: 250 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Mesas Redondas", url: "/servicios/mobiliario/mesas/redondas/" },
    { name: "180cm — 10 Personas", url: "/servicios/mobiliario/mesas/redondas/180cm/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "150cm (8 personas)", href: "/servicios/mobiliario/mesas/redondas/150cm/" },
  { name: "180cm (10 personas)", href: null, active: true },
];

const sidebarRelated = [
  { name: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Tablones y Buffet", href: "/servicios/mobiliario/mesas/tablones/" },
];
---

<PageLayout
  title="Renta Mesa Redonda 180cm para Bodas CDMX"
  description="Renta mesa redonda 180cm en CDMX — capacidad 10 personas. El formato VIP para banquetes de bodas, galas y corporativos. Tablero melamínico, niveladores."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="El formato VIP — máxima holgura para 10 comensales"
    title='Mesa Redonda <span class="highlight">180cm</span> — 10 Personas — Renta CDMX'
    subtitle="La mesa redonda de 180 cm ofrece el máximo espacio por comensal en formato circular: 10 personas con holgura, centro de mesa generoso y sensación de lujo en cada asiento. Tablero melamínico de alta densidad, niveladores ajustables. Desde $150."
    primaryCTA={{ label: "Cotizar mesas redondas 180cm", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas redondas de 180cm para mi evento` }}
    cards={[
      {
        title: "El formato que eleva la experiencia de tus invitados",
        content: "La <strong>mesa redonda de 180 cm</strong> es la opción premium para banquetes donde la comodidad de los comensales es prioridad. Con espacio para <strong>10 personas sin apreturas</strong>, permite centros de mesa más altos y elaborados, mayor espacio para cristalería y chargers, y conversación fluida entre todos los asistentes. Ideal para bodas de lujo, galas corporativas y celebraciones donde se quiere impresionar.",
      },
      {
        title: "Menos mesas, más impacto visual",
        content: "Con mesas de 180 cm necesitas <strong>20% menos mesas</strong> para el mismo número de invitados que con 150 cm. Eso significa más espacio libre para pista de baile, barra, lounge o jardín. El resultado visual es un salón que se ve más amplio, más lujoso y mejor organizado — con centros de mesa que lucen más al tener más espacio circular para brillar.",
      },
    ]}
  />

  <CTABanner
    headline="¿180cm o 150cm? Te ayudamos a elegir el formato ideal para tu venue"
    subheadline="Asesoría de layout sin costo — calcula el formato óptimo según espacio y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Redondas</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesas redondas 180cm para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas redondas de 180cm`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Redonda 180cm en Eventos Reales</h2>
            <p class="section__subtitle">Bodas y galas VIP en salones y jardines de CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Redonda 180cm</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="180cm: el formato que eligen las bodas de alto nivel"
    headingId="descripcion-heading"
    badge="Formato VIP — 2 personas más por mesa"
    tags={["180 cm diámetro", "10 personas", "Banquetes VIP", "Bodas de lujo"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La diferencia entre 150 y 180 cm no es solo de tamaño — es de experiencia. Con 180 cm, cada comensal tiene <strong>56 cm de espacio lateral</strong>, pero el impacto visual de la mesa es notablemente más generoso: los centros de mesa pueden ser más elaborados, hay espacio para más cristalería y el mantel que llega al piso crea una presentación más lujosa.</p>
      <p class="showcase__text">El tablero de <strong>triplay de alta densidad con melamínico</strong> tiene las mismas propiedades que el modelo de 150 cm: resistente a manchas, agua y raspaduras. La base plegable reforzada soporta hasta <strong>120 kg distribuidos</strong> con niveladores de precisión para superficies irregulares.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/mesas-redondas-180cm-banquete-vip.avif" alt="Mesa redonda 180cm en banquete VIP" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-redondas-montaje-dorado-bodas.avif" alt="Mesas redondas en montaje dorado para bodas" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesa-redonda-overhead-chargers-boda.avif" alt="Vista aérea mesa redonda con chargers para boda VIP" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Redonda 180cm</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Mesa Redonda 180cm"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["El formato VIP para banquetes: 10 personas cómodas, máxima holgura y presencia visual."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿150 o 180cm?</h3>
                  <p class="faq-sidebar-card__text">Te ayudamos a elegir el formato ideal según tu venue y presupuesto. Sin compromiso.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, necesito ayuda para elegir entre mesas de 150 y 180cm`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Consultar por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Dinos el número de invitados y venue — respuesta en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes mesas redondas">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Redondas</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item"><a href="/servicios/mobiliario/mesas/" class="sidebar-nav__back">&uarr; Volver a Mesas</a></li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Mesas 180cm para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas redondas de 180cm`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Mesas Redondas 180cm"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y te enviamos cotización personalizada por WhatsApp. Sin compromiso.", "Dinos invitados y venue — calculamos mesas, layout y precio final."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
