---
/**
 * ─── Mesa Cocktail Alta Spandex — Página de Variante (Nivel 4) ───
 * Mesa cocktail alta con funda spandex elástica. Recepciones en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { label: "Alta Spandex" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesas-cocktail-corporativo-panoramica.avif", alt: "Mesas cocktail con funda spandex en evento corporativo panorámica" },
  { src: "/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif", alt: "Mesas cocktail alta spandex en evento corporativo CDMX" },
  { src: "/images/mobiliario/mesas-cocktail-recepcion-networking.avif", alt: "Mesas cocktail spandex en recepción de networking" },
  { src: "/images/mobiliario/mesas-cocktail-negras-networking-vista.avif", alt: "Mesas cocktail con funda negra en networking con vista ciudad" },
  { src: "/images/mobiliario/mesa-cocktail-01.avif", alt: "Mesa cocktail alta con funda spandex blanca para evento" },
  { src: "/images/mobiliario/mesa-cocktail-02.avif", alt: "Mesa cocktail spandex en recepción elegante" },
];

const faqs = [
  {
    question: "¿Qué es la funda spandex para mesa cocktail?",
    answer: "La <strong>funda spandex</strong> es una cubierta de tela elástica de lycra que se ajusta perfectamente sobre la mesa cocktail cubriendo hasta el piso. A diferencia de un mantel convencional, el spandex abraza la base de la mesa de forma ajustada, creando una presentación limpia y profesional sin arrugas ni exceso de tela. Disponible en más de 15 colores para combinar con cualquier paleta de evento."
  },
  {
    question: "¿En cuántos colores está disponible la funda spandex?",
    answer: "Ofrecemos fundas spandex en <strong>más de 15 colores</strong>: blanco, negro, champagne, dorado, plateado, rojo, azul marino, verde esmeralda, rosa blush, lila, naranja, terracota, gris antracita, coral y más. También tenemos disponibles fundas bicolor y con estampados para eventos temáticos. Al cotizar te enviamos el muestrario completo de colores disponibles."
  },
  {
    question: "¿La mesa cocktail alta con spandex sirve para exteriores?",
    answer: "Sí, con las precauciones adecuadas. La base metálica cromada de la mesa es resistente a la intemperie. Para exteriores te recomendamos <strong>anclar las mesas</strong> si hay viento (las periqueras son ligeras y pueden volcarse). La funda spandex de lycra resiste el exterior, aunque los colores pueden verse afectados por humedad excesiva. Para jardines ventosos, considérala solo bajo carpa."
  },
  {
    question: "¿Cuántas mesas cocktail spandex necesito para una recepción?",
    answer: "La regla estándar es <strong>1 mesa cocktail por cada 4-6 personas</strong> en la zona de cóctel. Para una recepción previa al banquete de 200 invitados, necesitarías aproximadamente 35-50 mesas cocktail, dependiendo de cuánto espacio de desplazamiento quieres dejar. En eventos estrictamente de networking (sin banquete), con 1 mesa por cada 3 personas es suficiente."
  },
  {
    question: "¿El precio incluye la funda spandex?",
    answer: "Sí. Cuando rentas la <strong>mesa cocktail alta spandex</strong>, el precio incluye la funda elástica en el color que elijas. Las fundas se incluyen sin costo adicional como parte del producto. Si quieres múltiples colores para el mismo evento (por ejemplo, funda blanca y funda negra alternadas), el cambio de funda no tiene cargo extra."
  },
];

const specs = [
  { label: "Tipo", value: "Mesa cocktail alta (periquera) con funda spandex" },
  { label: "Diámetro tablero", value: "60 cm" },
  { label: "Altura total", value: "110 cm" },
  { label: "Funda", value: "Lycra spandex elástica hasta el piso" },
  { label: "Colores disponibles", value: "15+ colores: blanco, negro, champagne, dorado, plateado y más" },
  { label: "Base", value: "Metálica cromada con contrapeso estabilizador" },
  { label: "Resistencia", value: "40 kg sobre el tablero" },
  { label: "Incluye", value: "Funda spandex en color elegido sin costo adicional" },
  { label: "Precio referencial", value: "Desde $200 por mesa / evento" },
];

const reviews = [
  { author: "Mariana Pérez", text: "Las mesas cocktail con funda blanca spandex quedaron impecables en nuestra recepción de boda. Se veían limpias, profesionales y el contraste con las flores era perfecto.", rating: 5, date: "2025-11-20" },
  { author: "Arturo Campos", text: "Para el evento corporativo pedimos las fundas en azul marino con logotipo de la empresa. El resultado fue muy profesional y los asistentes quedaron impresionados.", rating: 5, date: "2025-10-10" },
  { author: "Fernanda Silva", text: "Alternamos fundas blancas y champagne para los XV años. El efecto visual fue hermoso y muy diferente a otras fiestas. El servicio de EVENTECH puntual como siempre.", rating: 5, date: "2025-09-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Cocktail Alta Spandex CDMX",
    description: "Mesa cocktail alta con funda spandex elástica en 15+ colores. Para recepciones, cócteles y networking en CDMX. 110 cm altura, 60 cm diámetro. Desde $200.",
    url: "/servicios/mobiliario/mesas/cocktail/alta-spandex/",
    priceRange: { min: 200, max: 300 },
    reviews,
    ratingValue: 5,
    reviewCount: 35,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Mesas Cocktail", url: "/servicios/mobiliario/mesas/cocktail/" },
    { name: "Alta Spandex", url: "/servicios/mobiliario/mesas/cocktail/alta-spandex/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Alta Spandex", href: null, active: true },
  { name: "Alta Madera", href: "/servicios/mobiliario/mesas/cocktail/alta-madera/" },
];

const sidebarRelated = [
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Mesa Cocktail Alta Spandex CDMX"
  description="Renta mesa cocktail alta con funda spandex en CDMX. 15+ colores disponibles, 110cm altura, 60cm diámetro. Ideal para recepciones, cócteles y networking."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="15+ colores de funda spandex — el acabado más limpio del mercado"
    title='Mesa Cocktail <span class="highlight">Alta Spandex</span> — Renta CDMX'
    subtitle="La mesa cocktail con funda spandex elástica es el estándar para recepciones y networking de alto nivel. La lycra abraza la base perfectamente hasta el piso — sin arrugas, sin exceso de tela. 15+ colores para combinar con cualquier paleta. Desde $200."
    primaryCTA={{ label: "Cotizar mesas cocktail spandex", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail alta spandex para mi evento` }}
    cards={[
      {
        title: "El acabado más limpio para recepciones de alto nivel",
        content: "La <strong>funda spandex elástica</strong> es lo que diferencia una recepción amateur de una profesional. A diferencia de un mantel que se arruga o se mueve con el viento, el spandex se ajusta perfectamente a la base de la mesa creando una superficie lisa y elegante que <strong>luce igual a las 8pm que a medianoche</strong>. Disponible en más de 15 colores para coordinar exactamente con tu paleta de evento.",
      },
      {
        title: "Funda incluida sin costo adicional",
        content: "Cuando rentas la <strong>mesa cocktail alta spandex</strong>, la funda en el color que elijas está incluida en el precio. Sin extras, sin sorpresas. Si quieres combinar colores para el mismo evento, el cambio de funda tampoco tiene costo. Entrega, montaje y recolección incluidos en CDMX.",
      },
    ]}
  />

  <CTABanner
    headline="¿Qué color de spandex combina mejor con tu evento? Te ayudamos a elegir"
    subheadline="Te enviamos el muestrario completo de colores y asesoría de coordinación sin costo"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Cocktail</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa cocktail alta spandex para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail alta spandex`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Cocktail Alta Spandex en Eventos Reales</h2>
            <p class="section__subtitle">Recepciones, cócteles y networking en CDMX</p>
