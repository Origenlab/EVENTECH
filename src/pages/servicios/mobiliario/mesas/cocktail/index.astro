---
/**
 * ─── Mesas Cocktail — Página de Producto (Nivel 4) ───
 * Periqueras de 60 cm diámetro × 110 cm altura.
 * El complemento ideal para recepciones y cócteles.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas > Mesas Cocktail
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Mesas Cocktail" },
];

const faqs = [
  { question: "¿Cuántas mesas cocktail necesito?", answer: 'La regla general es <strong>1 mesa cocktail por cada 10-15 invitados</strong>. Para un evento de 200 personas, recomendamos entre 15 y 20 mesas cocktail distribuidas estratégicamente en zonas de socialización. Nuestro equipo te ayuda a planificar la distribución ideal según el layout de tu venue para maximizar el flujo de invitados y la comodidad.' },
  { question: "¿Las fundas están incluidas?", answer: 'Las fundas en <strong>blanco y negro están incluidas sin costo adicional</strong>. Fundas de color (dorado, plata, azul marino, burdeos, blush, etc.) tienen un pequeño costo adicional que se detalla en tu cotización. Para eventos corporativos, ofrecemos <strong>matching Pantone</strong> para que las fundas coincidan exactamente con tu identidad de marca.' },
  { question: "¿Se pueden usar sin funda?", answer: 'Sí. El <strong>tablero de madera natural</strong> queda excelente sin funda para eventos rústicos, bohemios e industriales. La base cromada visible aporta un look moderno y limpio. También puedes optar por el tablero en negro o blanco sin funda para un estilo minimalista contemporáneo.' },
  { question: "¿Son estables con bebidas?", answer: 'Absolutamente. Cada mesa cocktail cuenta con <strong>contrapeso estabilizador en la base</strong> que garantiza firmeza total incluso en superficies irregulares como jardines y terrazas. Con una capacidad de carga de <strong>40 kg</strong>, soportan bebidas, botanas, arreglos florales y centros de mesa sin problema alguno.' },
  { question: "¿Hay altura ajustable?", answer: 'La altura estándar es de <strong>110 cm</strong>, ideal para uso de pie en recepciones y cócteles. Algunos modelos cuentan con <strong>columna telescópica ajustable</strong> que permite bajar la altura a 75 cm para uso tipo bistró con bancos altos. Indícanos tu preferencia al cotizar y te asesoramos sobre la mejor opción para tu evento.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos reservar con <strong>2 a 3 semanas de anticipación</strong> para garantizar disponibilidad de cantidad y color de funda deseados. Para pedidos de <strong>30+ mesas cocktail</strong> o en temporada alta (noviembre a febrero), sugerimos apartar con 1 mes de anticipación. Un anticipo del 30% confirma tu reserva y asegura tu fecha.' },
];

const specs = [
  { label: "Diámetro tablero", value: "60 cm (circular)" },
  { label: "Altura", value: "110 cm (estándar cocktail)" },
  { label: "Tablero", value: "Negro, Blanco, Madera natural" },
  { label: "Base", value: "Cromada con contrapeso estabilizador" },
  { label: "Capacidad de carga", value: "40 kg" },
  { label: "Fundas", value: "Spandex elástico, 15+ colores" },
  { label: "Peso", value: "12 kg (con contrapeso)" },
  { label: "Columna", value: "Telescópica ajustable (algunos modelos)" },
  { label: "Plegable", value: "Sí, tablero desmontable" },
  { label: "Mantenimiento", value: "Limpieza incluida pre-evento" },
];

const sidebarNav = [
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "Mesas Cocktail", href: null, active: true },
  { name: "Tablones y Buffet", href: "/servicios/mobiliario/mesas/tablones/" },
];

const sidebarRelated = [
  { name: "Barras para Eventos", href: "/servicios/mobiliario/barras/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Equipo Audiovisual", href: "/servicios/audiovisual/" },
];

const reviews = [
  { author: "Sandra López", text: "Rentamos 20 mesas cocktail con funda dorada para un evento de networking corporativo en un hotel de Polanco. La atmósfera fue perfecta — los invitados circulaban cómodamente y las mesas eran súper estables. El montaje fue rápido y profesional.", rating: 5, date: "2025-11-12" },
  { author: "Pablo Hernández", text: "Para el cocktail hour de nuestra boda rústica en un jardín, elegimos 15 mesas cocktail con tablero de madera natural sin funda. Combinadas con fairy lights, el resultado fue mágico. Todos los invitados quedaron encantados con el ambiente.", rating: 5, date: "2025-10-20" },
  { author: "Mariana Ibáñez", text: "Necesitábamos 25 mesas cocktail con fundas azul marino para un lanzamiento de producto. Las fundas coincidieron perfectamente con nuestro branding corporativo. El equipo montó todo según el plano que enviamos. Muy profesionales.", rating: 5, date: "2025-09-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesas Cocktail para Eventos en CDMX",
    description: "Renta de mesas cocktail (periqueras) de 60 cm × 110 cm para recepciones y cócteles en CDMX. Fundas spandex en 15+ colores. Desde $70 por mesa.",
    url: "/servicios/mobiliario/mesas/cocktail/",
    priceRange: { min: 70, max: 200 },
    reviews,
    ratingValue: 5,
    reviewCount: 58,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Mesas Cocktail", url: "/servicios/mobiliario/mesas/cocktail/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mesas Cocktail para Eventos en CDMX"
  description="Renta de mesas cocktail (periqueras) de 60 cm × 110 cm para recepciones y cócteles en CDMX. Fundas spandex en 15+ colores. Desde $70 por mesa."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El complemento ideal para cócteles"
    title='Renta de <span class="highlight">Mesas Cocktail</span> para Eventos en CDMX'
    subtitle="Mesas cocktail (periqueras) de 60 cm de diámetro × 110 cm de altura con base cromada y contrapeso estabilizador. Tableros en negro, blanco y madera natural. Fundas elásticas spandex en 15+ colores. 40 kg de capacidad."
    primaryCTA={{ label: "Cotiza tus mesas cocktail", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mesas cocktail para mi evento` }}
    cards={[
      {
        title: "Tablero circular con base cromada y contrapeso estabilizador",
        content: "<strong>Renta de mesas cocktail para eventos</strong> con tablero circular de 60 cm de diámetro × 110 cm de altura, el estándar para recepciones y cocktail hours. Tablero disponible en negro, blanco y madera natural con base cromada y contrapeso estabilizador que garantiza firmeza total. Capacidad de carga de <strong>40 kg en superficie</strong> para bebidas, botanas y arreglos florales. Estabilidad profesional incluso en superficies irregulares como jardines y terrazas al aire libre.",
      },
      {
        title: "Fundas spandex en 15+ colores que transforman su apariencia",
        content: "<strong>Personalización total con fundas elásticas spandex</strong> disponibles en más de 15 colores: blanco, negro, dorado, plata, azul marino, burdeos, blush, esmeralda, lavanda y más. Las fundas transforman completamente la apariencia de la mesa cocktail para adaptarse a cualquier temática. También disponible sin funda con tablero de madera natural para eventos rústicos y bohemios. Entrega, montaje y recolección incluidos en el servicio.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas mesas cocktail para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te asesoramos con cantidad y distribución ideal"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Mesas para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas mesas cocktail para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 2h8l-2 8h-4L8 2z"/><path d="M12 10v10"/><path d="M8 22h8"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Mesas Cocktail</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Cocktail con Funda Blanca -->
          <section class="section section--alt" aria-labelledby="blanca-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegancia clásica</span>
                <h2 class="showcase__title" id="blanca-heading">Cocktail con Funda Blanca</h2>
                <p class="showcase__subtitle">La funda blanca spandex: el look más solicitado que combina con cualquier decoración de evento.</p>
                <p class="showcase__text">La <strong>mesa cocktail con funda blanca spandex</strong> es la opción más popular de nuestra colección, presente en el 70% de los eventos que atendemos en CDMX. La funda elástica envuelve completamente la mesa creando un <strong>look limpio, elegante y uniforme</strong> que combina perfectamente con cualquier paleta de colores y temática decorativa. Es la elección segura para bodas clásicas, eventos corporativos y galas donde la sofisticación es prioridad.</p>
                <p class="showcase__text">La funda blanca <strong>está incluida sin costo adicional</strong> en cada mesa cocktail que rentes. El material spandex de alta calidad se ajusta perfectamente al contorno de la mesa, eliminando arrugas y creando líneas fluidas. Combínalas con nuestras <a href="/servicios/mobiliario/sillas/">sillas elegantes</a> y <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un montaje integral que impresiona.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Funda Blanca</span>
                  <span class="showcase__tag">Elegante</span>
                  <span class="showcase__tag">Bodas</span>
                  <span class="showcase__tag">Corporativos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cocktail Funda Blanca
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif"
                  alt="Mesas cocktail con funda blanca spandex en evento corporativo elegante CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cocktail con Funda de Color -->
          <section class="section section--alt" aria-labelledby="color-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Personalización total</span>
                <h2 class="showcase__title" id="color-heading">Cocktail con Funda de Color</h2>
                <p class="showcase__subtitle">Más de 15 colores de fundas spandex para que cada mesa refleje la identidad de tu evento.</p>
                <p class="showcase__text">Las <strong>fundas spandex de color</strong> transforman completamente la apariencia de la mesa cocktail para adaptarse a cualquier temática y paleta cromática. Disponibles en más de 15 colores: <strong>dorado, plata, azul marino, burdeos, blush, esmeralda, lavanda, coral, mostaza</strong> y más. Los colores más populares para bodas son dorado y blush, mientras que azul marino y negro dominan en eventos corporativos.</p>
                <p class="showcase__text">Para eventos de marca y lanzamientos de producto, ofrecemos <strong>matching Pantone</strong> para que las fundas coincidan exactamente con tu identidad corporativa. El proceso requiere 5 días hábiles de anticipación. Combina fundas de diferentes colores en un mismo evento para crear zonas temáticas o acentos visuales. Cada funda se entrega <strong>perfectamente planchada y ajustada</strong> por nuestro equipo de montaje.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">15+ Colores</span>
                  <span class="showcase__tag">Personalizable</span>
                  <span class="showcase__tag">Branding</span>
                  <span class="showcase__tag">Temática</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cocktail Funda Color
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/mesas-cocktail-negras-periqueras-evento.avif"
                  alt="Mesas cocktail con funda de color negra en evento nocturno elegante CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Cocktail Madera Natural -->
          <section class="section section--alt" aria-labelledby="madera-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Look rústico-moderno</span>
                <h2 class="showcase__title" id="madera-heading">Cocktail Madera Natural</h2>
                <p class="showcase__subtitle">Tablero de madera natural sin funda: la tendencia rústico-industrial para eventos con carácter.</p>
                <p class="showcase__text">La <strong>mesa cocktail con tablero de madera natural</strong> sin funda es la opción preferida para eventos rústicos, industriales y bohemios donde la textura y la naturalidad son protagonistas. El acabado de veta natural del tablero aporta <strong>calidez y autenticidad</strong> que ninguna funda puede replicar. La base cromada visible crea un contraste moderno que equilibra lo rústico con lo contemporáneo.</p>
                <p class="showcase__text">Combina espectacularmente con <strong>sillas Crossback</strong>, arreglos florales silvestres y <a href="/servicios/iluminacion/decorativa/">guirnaldas de fairy lights</a> para crear ambientes tipo hacienda mexicana. Es la elección estrella para bodas en jardines, haciendas, viñedos y espacios al aire libre donde quieres que la naturaleza y los materiales nobles sean los protagonistas del diseño.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Madera Natural</span>
                  <span class="showcase__tag">Rústico</span>
                  <span class="showcase__tag">Boho</span>
                  <span class="showcase__tag">Haciendas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cocktail Madera Natural
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/mesas-cocktail-madera-natural-rustico.avif"
                  alt="Mesas cocktail con tablero de madera natural en evento tipo hacienda rústico CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Cocktail para Recepción y Networking -->
          <section class="section section--alt" aria-labelledby="recepcion-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Zona de socialización</span>
                <h2 class="showcase__title" id="recepcion-heading">Cocktail para Recepción y Networking</h2>
                <p class="showcase__subtitle">Distribución estratégica de mesas cocktail para crear la zona de socialización perfecta en tu evento.</p>
                <p class="showcase__text">Las <strong>mesas cocktail son el elemento clave</strong> para crear zonas de socialización efectivas en recepciones, cocktail hours pre-cena y eventos de networking. La regla de distribución es <strong>1 mesa por cada 10-15 invitados</strong>, colocadas estratégicamente para facilitar el flujo de personas y fomentar la interacción natural entre los asistentes. Nuestro equipo te asesora con el layout ideal según las dimensiones de tu venue.</p>
                <p class="showcase__text">Para eventos corporativos de networking, recomendamos combinar mesas cocktail con <a href="/servicios/mobiliario/salas-lounge/">salas lounge</a> para ofrecer dos niveles de comodidad: zonas de conversación rápida de pie y áreas de descanso con sillones. Las mesas cocktail también son perfectas como <strong>estaciones de bebidas, puntos de registro y bases para centros de mesa</strong> que funcionan como referencia visual en eventos grandes.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Recepción</span>
                  <span class="showcase__tag">Networking</span>
                  <span class="showcase__tag">Cóctel</span>
                  <span class="showcase__tag">Socialización</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cocktail Recepción
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/mesas-cocktail-recepcion-networking.avif"
                  alt="Mesas cocktail distribuidas en zona de recepción y networking corporativo CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 8. FAQ (6 preguntas) -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas Frecuentes sobre Mesas Cocktail"
              subtitle="Resolvemos tus dudas"
              description={[
                "Antes de rentar mesas cocktail para tu evento, es natural tener preguntas sobre cantidades, fundas, estabilidad y logística. Aquí encontrarás las respuestas más comunes.",
                "Si no encuentras lo que buscas, escríbenos por WhatsApp y un asesor especializado en mobiliario te responderá al instante."
              ]}
            />

            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
