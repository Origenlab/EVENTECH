---
/**
 * ─── Mesa Cocktail Alta Madera — Página de Variante (Nivel 4) ───
 * Mesa cocktail alta tablero de madera natural. Premium en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { label: "Alta Madera" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesas-cocktail-madera-natural-rustico.avif", alt: "Mesas cocktail alta madera natural en evento rústico" },
  { src: "/images/mobiliario/mesas-cocktail-corporativo-panoramica.avif", alt: "Mesas cocktail madera en evento corporativo panorámica" },
  { src: "/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif", alt: "Mesa cocktail alta madera en evento corporativo CDMX" },
  { src: "/images/mobiliario/mesas-cocktail-negras-periqueras-evento.avif", alt: "Mesas cocktail periqueras en evento de lujo" },
  { src: "/images/mobiliario/mesa-cocktail-03.avif", alt: "Mesa cocktail alta madera para recepción premium" },
  { src: "/images/mobiliario/mesa-cocktail-04.avif", alt: "Mesa cocktail madera en evento de networking" },
];

const faqs = [
  {
    question: "¿Qué diferencia hay entre la mesa cocktail de madera y la de spandex?",
    answer: "La <strong>mesa cocktail alta madera</strong> tiene el tablero superior en madera barnizada o melamínico de madera, sin cubierta adicional — el tablero se muestra directamente. Esto da un aspecto más natural, cálido y premium, ideal para eventos rústicos, boda en hacienda o brand activations de bebidas premium. La de spandex cubre toda la base con tela elástica. La madera es la opción cuando quieres mostrar el material, no ocultarlo."
  },
  {
    question: "¿La mesa cocktail madera se usa en interiores y exteriores?",
    answer: "El tablero de madera barnizada resiste bien el interior y exteriores cubiertos bajo carpa. Para exteriores sin cubierta, el barniz protege contra la humedad breve pero no recomendamos exposición prolongada a lluvia directa. La base metálica es resistente a la intemperie. Para jardines, recomendamos la mesa cocktail madera bajo carpa donde la madera natural aporta calidez visual en contraste con la estructura."
  },
  {
    question: "¿La mesa cocktail alta madera requiere algún accesorio adicional?",
    answer: "La mesa se entrega lista para usar con el tablero de madera expuesto. Puedes agregar un <strong>centro de mesa</strong> (florero, veladora, lanterna) para complementar visualmente. Para eventos formales, un camino de flores o runner sobre el tablero eleva enormemente la presentación. También puedes combinarla con barra de bebidas en la misma mesa para hospitality stations de alto nivel."
  },
  {
    question: "¿Qué tipo de eventos elige la mesa cocktail alta madera?",
    answer: "Los eventos que más la solicitan son: <strong>bodas rústicas en haciendas y jardines</strong> (la madera complementa la decoración floral y natural), <strong>brand activations</strong> de marcas premium de bebidas y alimentos (la madera proyecta artesanal y calidad), y <strong>eventos de networking</strong> de nivel alto donde se quiere un ambiente más cálido que la típica periquera cromada."
  },
];

const specs = [
  { label: "Tipo", value: "Mesa cocktail alta tablero madera" },
  { label: "Diámetro tablero", value: "60 cm — madera barnizada o melamínico madera" },
  { label: "Altura total", value: "110 cm" },
  { label: "Acabado tablero", value: "Madera barnizada natural o nogal" },
  { label: "Base", value: "Metálica negra mate o cromada con contrapeso" },
  { label: "Resistencia", value: "40 kg sobre el tablero" },
  { label: "Uso recomendado", value: "Bodas rústicas, activaciones premium, networking íntimo" },
  { label: "Precio referencial", value: "Desde $250 por mesa / evento" },
];

const reviews = [
  { author: "Claudia Ramírez", text: "Las mesas cocktail de madera para nuestra boda rústica en hacienda fueron perfectas. El tablero de madera con flores encima fue lo más fotografiado del evento.", rating: 5, date: "2025-11-15" },
  { author: "Eduardo Vega", text: "Para la activación de nuestra marca de mezcal elegimos las cocktail madera. El ambiente artesanal fue exactamente lo que buscábamos para el lanzamiento.", rating: 5, date: "2025-10-28" },
  { author: "Paola Herrera", text: "Evento de networking íntimo con 20 mesas cocktail madera. Mucho más elegante que las periqueras convencionales. Los asistentes comentaron la diferencia de nivel.", rating: 5, date: "2025-09-10" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Cocktail Alta Madera CDMX",
    description: "Mesa cocktail alta con tablero de madera natural para bodas rústicas, activaciones premium y networking en CDMX. 110 cm altura, 60 cm diámetro. Desde $250.",
    url: "/servicios/mobiliario/mesas/cocktail/alta-madera/",
    priceRange: { min: 250, max: 350 },
    reviews,
    ratingValue: 5,
    reviewCount: 19,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Mesas Cocktail", url: "/servicios/mobiliario/mesas/cocktail/" },
    { name: "Alta Madera", url: "/servicios/mobiliario/mesas/cocktail/alta-madera/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Alta Spandex", href: "/servicios/mobiliario/mesas/cocktail/alta-spandex/" },
  { name: "Alta Madera", href: null, active: true },
];

const sidebarRelated = [
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Tablones y Buffet", href: "/servicios/mobiliario/mesas/tablones/" },
  { name: "Sillas Crossback", href: "/servicios/mobiliario/sillas/crossback/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];
---

<PageLayout
  title="Renta Mesa Cocktail Alta Madera CDMX"
  description="Renta mesa cocktail alta madera en CDMX. Tablero madera natural, 110cm altura, 60cm diámetro."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="El acabado premium — madera natural para eventos de carácter"
    title='Mesa Cocktail <span class="highlight">Alta Madera</span> — Renta CDMX'
    subtitle="La mesa cocktail con tablero de madera es la elección de los eventos que buscan calidez, artesanía y diferenciación visual. Sin fundas, sin plástico — la madera habla por sí sola. Ideal para bodas rústicas, activaciones premium y networking íntimo. Desde $250."
    primaryCTA={{ label: "Cotizar mesas cocktail madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail alta madera para mi evento` }}
    cards={[
      {
        title: "La madera que proyecta calidad en cualquier contexto",
        content: "La <strong>mesa cocktail alta madera</strong> es la elección correcta cuando quieres que el mobiliario refuerce el mensaje de tu evento. En una boda rústica en hacienda, el tablero de madera barnizada dialoga con la arquitectura de piedra y las flores silvestres. En una activación de marca premium de bebidas, la madera artesanal proyecta autenticidad y calidad. No es solo una mesa — es una declaración de intenciones.",
      },
      {
        title: "Resistencia profesional con estética natural",
        content: "El tablero de <strong>60 cm de diámetro en madera barnizada</strong> resiste el uso intensivo de eventos sin perder su presentación. La base metálica con contrapeso estabilizador garantiza firmeza incluso en superficies irregulares. Capacidad de <strong>40 kg</strong> sobre el tablero. Montaje, entrega y recolección incluidos en CDMX.",
      },
    ]}
  />

  <CTABanner
    headline="La mesa cocktail madera que diferencia tu evento de todos los demás"
    subheadline="Calidez artesanal para bodas rústicas, activaciones y networking de alto nivel"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Cocktail</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesa cocktail madera para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail alta madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Cocktail Alta Madera en Eventos</h2>
            <p class="section__subtitle">Bodas rústicas, activaciones y networking en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa Cocktail Alta Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="La mesa cocktail que hace que tus invitados noten la diferencia"
    headingId="descripcion-heading"
    badge="Madera natural — el lujo sin esfuerzo"
    tags={["Madera barnizada", "Estilo rústico premium", "Activaciones", "Bodas hacienda"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay eventos donde la típica periquera cromada se ve genérica. La <strong>mesa cocktail alta madera</strong> es la alternativa que proyecta nivel sin necesidad de accesorios adicionales. El tablero de madera barnizada tiene una calidez visual que ninguna funda de tela puede replicar — la veta natural, el color cálido del barniz, la textura real de la madera.</p>
      <p class="showcase__text">En una boda en jardín, combínala con arreglos de flores silvestres y votivas. En una activación de marca artesanal, déjala sola con productos sobre el tablero. En un networking de lujo, añade un arreglo floral bajo y estiloso. La versatilidad de la madera es que <strong>funciona en cualquier contexto premium</strong> sin necesidad de personalización adicional.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/mesas-cocktail-madera-natural-rustico.avif" alt="Mesa cocktail alta madera en evento rústico premium" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesa-cocktail-03.avif" alt="Mesa cocktail madera para recepción premium" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesa-cocktail-04.avif" alt="Mesa cocktail madera en evento de networking" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section section--alt" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Mesa Cocktail Alta Madera</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Mesa Cocktail Alta Madera"
              subtitle="Lo que nos preguntan antes de reservar"
              description={["La opción premium para bodas rústicas, activaciones y eventos donde la autenticidad importa."]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer"><p set:html={faq.answer} /></div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Madera o spandex?</h3>
                  <p class="faq-sidebar-card__text">Te ayudamos a elegir el acabado ideal para el estilo de tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, necesito ayuda para elegir entre cocktail madera o spandex`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Consultar por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Respuesta en menos de 30 minutos con precio y disponibilidad.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes mesas cocktail">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Cocktail</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item"><a href="/servicios/mobiliario/mesas/" class="sidebar-nav__back">&uarr; Volver a Mesas</a></li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Mesa cocktail madera para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas cocktail alta madera`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Mesas Cocktail Alta Madera"
        subtitle="Cuéntanos sobre tu evento y te respondemos de inmediato"
        description={["Completa el formulario y te enviamos cotización personalizada por WhatsApp. Sin compromiso."]}
      />
      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate data-wa-number={SITE.contact.whatsapp} data-wa-title="Mesa Cocktail Alta Madera — Cotización">
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda Rústica">Boda Rústica / Hacienda</option>
