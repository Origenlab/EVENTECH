---
/**
 * ─── Mesa Rectangular 180cm — Página de Variante (Nivel 4) ───
 * Mesa rectangular 180cm, 8 personas, formato compacto en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { label: "180cm — 8 personas" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesas-rectangulares-honor-formato-t.avif", alt: "Mesa rectangular 180cm para mesa de honor en formato T" },
  { src: "/images/mobiliario/mesas-rectangulares-imperiales-gala-velas.avif", alt: "Mesas rectangulares 180cm en gala con velas" },
  { src: "/images/mobiliario/mesas-rectangulares-manteleria-premium.avif", alt: "Mesa rectangular 180cm con mantelería premium" },
  { src: "/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif", alt: "Mesa rectangular con espejo y candelabros para cena gala" },
  { src: "/images/mobiliario/mesas-rectangulares-distribucion-u-corporativa.avif", alt: "Mesas rectangulares 180cm en distribución U corporativa" },
  { src: "/images/mobiliario/mesa-imperial-salon-barroco-chargers.avif", alt: "Mesa rectangular en salón barroco con chargers dorados" },
];

const faqs = [
  {
    question: "¿Para qué eventos es ideal la mesa rectangular de 180cm?",
    answer: "La <strong>mesa rectangular de 180 cm</strong> es ideal para <strong>mesas de honor</strong> (donde se sientan los novios, padrinos y familiares directos), <strong>conferencias pequeñas</strong> con distribución en U, y bodas íntimas de 30-50 personas. Su tamaño más manejable que las de 240 cm la hace perfecta para salones medianos y para combinaciones donde la mesa de honor requiere un formato diferente al resto del salón."
  },
  {
    question: "¿Cuántas personas caben en una mesa rectangular de 180cm?",
    answer: "Una <strong>mesa rectangular de 180 × 90 cm</strong> tiene capacidad cómoda para <strong>8 personas</strong> — 3 por lado y 1 en cada cabecera. Sin cabeceras caben 6 personas con mayor holgura. Es el formato estándar para mesas de honor en bodas de hasta 200 personas, donde se busca una mesa principal diferenciada del resto del salón."
  },
  {
    question: "¿Cómo se configura una mesa de honor con mesas de 180cm?",
    answer: "La <strong>mesa de honor</strong> típica para 16-20 personas (novios + padrinos + familiares directos) requiere 2-3 mesas de 180 cm unidas en línea. Esta configuración crea una mesa principal de hasta 540 cm que destaca visualmente frente al salón. Se coloca generalmente en el extremo del salón o al centro de la pared principal, elevada sobre un podio para mayor visibilidad."
  },
  {
    question: "¿Cuál es la diferencia entre la mesa de 180cm y la de 240cm?",
    answer: "La de 180 cm es más <strong>manejable y versátil</strong>: cabe en espacios más compactos, es más fácil de configurar en ángulos y curvas, y es más económica. La de 240 cm es el estándar para banquetes imperiales de gran escala donde se requiere más capacidad por mesa. Para mesas de honor, la de 180 cm suele ser la elección correcta por su escala más íntima."
  },
  {
    question: "¿Puedo combinar mesas rectangulares de 180 y 240cm?",
    answer: "Sí y es una combinación frecuente. En bodas grandes, se usan las de 240 cm para el banquete principal y las de 180 cm para la <strong>mesa de honor</strong> y la <strong>mesa de novios</strong>. También se combinan para crear distribuciones en T donde el travesaño más corto usa las de 180 cm. Nuestros asesores te diseñan el layout combinado perfecto."
  },
];

const specs = [
  { label: "Largo", value: "180 cm" },
  { label: "Ancho", value: "90 cm" },
  { label: "Altura", value: "75 cm (estándar banquete)" },
  { label: "Capacidad", value: "8 personas (3 por lado + 1 en cada cabecera)" },
  { label: "Material tablero", value: "Triplay alta densidad con melamínico resistente" },
  { label: "Estructura", value: "Patas metálicas plegables reforzadas" },
  { label: "Resistencia", value: "120 kg distribuidos sobre la superficie" },
  { label: "Uso principal", value: "Mesa de honor, conferencias, bodas íntimas" },
  { label: "Precio referencial", value: "Desde $120 por mesa / evento" },
];

const reviews = [
  { author: "Isabela Moreno", text: "Usamos la mesa de 180cm para nuestra mesa de honor con 14 personas. Con 2 mesas unidas quedó perfecta — el aspecto visual desde el salón era espectacular.", rating: 5, date: "2025-11-30" },
  { author: "Ricardo Flores", text: "Para las conferencias pequeñas de nuestra empresa, las mesas de 180cm en U son perfectas. Caben 20 personas con espacio para laptop y documentos.", rating: 5, date: "2025-10-20" },
  { author: "Sandra López", text: "Boda íntima de 40 personas con 5 mesas de 180cm en línea. El salón quedó elegante y acogedor — los invitados pudieron conversar con todos.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Mesa Rectangular 180cm CDMX — 8 Personas",
    description: "Mesa rectangular 180cm para 8 personas. Ideal para mesas de honor, bodas íntimas y corporativos en CDMX. Resistencia 120 kg. Desde $120.",
    url: "/servicios/mobiliario/mesas/rectangulares/180cm/",
    priceRange: { min: 120, max: 200 },
    reviews,
    ratingValue: 5,
    reviewCount: 22,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Mesas Rectangulares", url: "/servicios/mobiliario/mesas/rectangulares/" },
    { name: "180cm — 8 Personas", url: "/servicios/mobiliario/mesas/rectangulares/180cm/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "240cm (10 personas)", href: "/servicios/mobiliario/mesas/rectangulares/240cm/" },
  { name: "180cm (8 personas)", href: null, active: true },
];

const sidebarRelated = [
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Mesa Rectangular 180cm CDMX — 8 Personas"
  description="Renta mesa rectangular 180cm en CDMX — 8 personas. Ideal para mesas de honor, bodas íntimas y distribuciones corporativas en U o T. Desde $120."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La mesa de honor perfecta — versátil y elegante"
    title='Mesa Rectangular <span class="highlight">180cm</span> — 8 Personas — Renta CDMX'
    subtitle="La mesa rectangular de 180 cm es la opción ideal para mesas de honor, bodas íntimas y distribuciones corporativas en U. Capacidad 8 personas, formato más manejable que las de 240 cm. Desde $120."
    primaryCTA={{ label: "Cotizar mesas rectangulares 180cm", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas rectangulares de 180cm para mi evento` }}
    cards={[
      {
        title: "El formato ideal para la mesa de honor y eventos íntimos",
        content: "La <strong>mesa rectangular de 180 cm</strong> es el tamaño correcto para <strong>mesas de honor en bodas</strong>, juntas directivas en formato U y banquetes íntimos de hasta 50 personas. Más compacta y versátil que las de 240 cm, se puede usar en salones donde las de mayor tamaño no caben, y permite configuraciones más flexibles en ángulos y distribuciones compuestas.",
      },
      {
        title: "Calidad profesional al mismo precio accesible",
        content: "Mismo tablero de <strong>triplay de alta densidad con melamínico resistente</strong> que el modelo de 240 cm, con patas metálicas plegables y <strong>capacidad de 120 kg</strong>. Los cantos lisos permiten unión sin escalonado entre mesas. Entrega, montaje y recolección incluidos en CDMX.",
      },
    ]}
  />

  <CTABanner
    headline="¿Mesa de honor o distribución corporativa en U? Te diseñamos el layout"
    subheadline="Asesoría especializada para mesas de honor, conferencias y eventos íntimos sin costo"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Rectangulares</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Mesas rectangulares 180cm para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mesas rectangulares de 180cm`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Mesa Rectangular 180cm en Eventos</h2>
            <p class="section__subtitle">Mesas de honor, bodas íntimas y corporativos en CDMX</p>
