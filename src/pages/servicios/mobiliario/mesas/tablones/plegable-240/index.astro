---
/**
 * ─── Tablón Plegable 240cm — Página de Variante (Nivel 5) ───
 * El tablón más grande: 240×75 cm. Buffets, barras y estaciones de registro.
 * Desde $100. La medida estándar para montar cualquier buffet completo.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas > Tablones > Plegable 240cm
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Tablones", href: "/servicios/mobiliario/mesas/tablones/" },
  { label: "Plegable 240cm" },
];

const galleryImages = [
  { src: "/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif", alt: "Tablón plegable 240cm montado en boda jardín elegante CDMX" },
  { src: "/images/mobiliario/mesas-tablones-crossback-boda-rustica.avif", alt: "Tablón 240cm con sillas crossback en boda rústica" },
  { src: "/images/mobiliario/tablon-madera-runner-velas-jardin-rustico.avif", alt: "Tablón plegable 240cm con runner y velas en jardín rústico" },
  { src: "/images/mobiliario/tablon-crossback-jardin-string-lights.avif", alt: "Tablón 240cm en jardín con string lights noche" },
  { src: "/images/mobiliario/tablones-candy-bar-mesa-regalos.avif", alt: "Tablones 240cm como candy bar y mesa de regalos en evento" },
  { src: "/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif", alt: "Estación de buffet con tablones plegables 240cm en salón" },
];

const faqs = [
  {
    question: "¿Para qué tipo de eventos es ideal el tablón plegable de 240cm?",
    answer: "El <strong>tablón plegable de 240 × 75 cm</strong> es la medida estándar de la industria para eventos en México. Es ideal para <strong>buffets, barras de bebidas, mesas de registro, candy bars, estaciones de postres</strong> y cualquier montaje donde se necesite una superficie amplia y de trabajo. Su tamaño ofrece 1.8 m² de superficie útil — suficiente para disponer de 6 a 8 platillos de buffet en una sola pieza o para montar una barra de cocteles completa."
  },
  {
    question: "¿Cuántos tablones de 240cm necesito para mi buffet?",
    answer: "Para un <strong>buffet sencillo de 3-5 platillos</strong>, con 2 tablones es suficiente. Para un <strong>buffet completo de 6-10 platillos más postres</strong>, necesitarás entre 4 y 6 tablones dispuestos en línea o en configuración U. Para <strong>bodas de 200+ invitados con múltiples estaciones</strong> (buffet principal, postres, barra de bebidas, mesa de regalos y área de registro), el cálculo habitual es de 10 a 15 tablones. Te ayudamos a diseñar el layout exacto según tu menú y venue."
  },
  {
    question: "¿Cuánto pesa el tablón de 240cm y qué soporta?",
    answer: "El tablón de 240cm pesa entre <strong>12 y 15 kg</strong> según el material: plástico reforzado (12 kg) o madera barnizada (15 kg). La capacidad de carga es de <strong>100 kg distribuidos</strong> en toda la superficie — soporta sin problema chafers, calentadores, bandejas de servicio, fuentes de chocolate y torres de cupcakes. Para equipos excepcionalmente pesados, recomendamos usar el tablón doble o mesas de cocina móvil de acero inoxidable."
  },
  {
    question: "¿Se pueden unir varios tablones de 240cm en secuencia?",
    answer: "Sí. Los tablones se unen perfectamente en secuencia para crear <strong>líneas de buffet de cualquier longitud</strong>: 3 tablones = 7.2 metros de barra continua, 5 tablones = 12 metros. También se pueden disponer en configuraciones L, U o cuadrado para optimizar el flujo de servicio según el layout del venue. El equipo de EVENTECH diseña la distribución óptima incluida en el servicio de renta."
  },
  {
    question: "¿La renta incluye mantelería para el tablón de 240cm?",
    answer: "La <strong>renta del tablón incluye entrega, montaje y recolección</strong>. La mantelería se cotiza por separado y disponemos de más de 30 colores en diferentes telas: satinado, lino, organza y spandex elástico (el más popular porque cae perfecto hasta el piso). Para una boda, el combo más pedido es tablón 240cm + mantel spandex blanco o champagne hasta el piso. Pregunta al cotizar, te hacemos el paquete completo."
  },
  {
    question: "¿Con cuánto tiempo de anticipación debo reservar el tablón de 240cm?",
    answer: "Para pedidos de <strong>1 a 10 tablones</strong>, recomendamos reservar con 1 a 2 semanas de anticipación. Para <strong>eventos grandes con 15+ tablones</strong> (bodas, galas corporativas), lo ideal es apartar con 3 a 4 semanas. En <strong>temporada alta (noviembre a febrero)</strong> la demanda sube considerablemente — se recomienda reservar con 6 a 8 semanas. El 30% de anticipo confirma tu fecha y disponibilidad."
  },
];

const specs = [
  { label: "Dimensiones", value: "240 × 75 cm (largo × ancho)" },
  { label: "Altura", value: "75 cm (estándar de servicio)" },
  { label: "Superficie útil", value: "1.8 m² — suficiente para 6-8 platillos de buffet" },
  { label: "Línea Madera", value: "Madera barnizada, veta natural visible, acabado elegante" },
  { label: "Línea Plástico", value: "Polipropileno reforzado, resistente a intemperie y UV" },
  { label: "Capacidad de carga", value: "100 kg distribuidos en toda la superficie" },
  { label: "Patas", value: "Plegables tipo tijera, abatibles en segundos" },
  { label: "Peso madera", value: "15 kg" },
  { label: "Peso plástico", value: "12 kg" },
  { label: "Configuraciones", value: "Línea recta, L, U, cuadrado — se unen en secuencia" },
  { label: "Precio base", value: "Desde $100 por tablón (incluye entrega y montaje CDMX)" },
  { label: "Mantenimiento", value: "Limpieza e inspección incluida antes de cada evento" },
];

const reviews = [
  { author: "Chef Ernesto Velázquez", text: "Rentamos 8 tablones de 240cm para el buffet de una boda de 300 personas en Hacienda de los Morales. Los tablones madera quedaron espectaculares con la decoración rústica. Soportaron todo el equipo de catering sin problema — chafers, bandejas, la estación de carnes. Servicio puntual y profesional.", rating: 5, date: "2025-11-12" },
  { author: "Claudia Mendoza", text: "Usamos 6 tablones de 240cm plástico para el área de registro y buffet de un evento corporativo al aire libre. Llovió durante la tarde y los tablones aguantaron perfecto. La limpieza fue rapidísima. Definitivamente los volveré a rentar.", rating: 5, date: "2025-10-08" },
  { author: "Luis Espinoza", text: "Para nuestra boda pedimos 10 tablones de 240cm y el equipo de EVENTECH diseñó el layout completo del buffet. La configuración en U quedó perfecta para el flujo de invitados. Todo llegó puntual y bien montado. El resultado fue impecable.", rating: 5, date: "2025-09-19" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta Tablón Plegable 240cm para Buffets",
    description: "Renta de tablón plegable de 240×75 cm para buffets, barras y mesas de registro en CDMX. Madera barnizada o plástico reforzado. 100 kg capacidad. Desde $100 por tablón.",
    url: "/servicios/mobiliario/mesas/tablones/plegable-240/",
    priceRange: { min: 100, max: 250 },
    reviews,
    ratingValue: 5,
    reviewCount: 48,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Tablones", url: "/servicios/mobiliario/mesas/tablones/" },
    { name: "Plegable 240cm", url: "/servicios/mobiliario/mesas/tablones/plegable-240/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Tablones", href: "/servicios/mobiliario/mesas/tablones/" },
  { name: "Tablón Plegable 240cm", href: null, active: true },
  { name: "Tablón Plegable 180cm", href: "/servicios/mobiliario/mesas/tablones/plegable-180/" },
];

const sidebarRelated = [
  { name: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Equipo de Catering", href: "/servicios/catering/" },
];
---

<PageLayout
  title="Renta Tablón Plegable 240cm para Buffets"
  description="Renta tablón plegable 240×75 cm para buffets, barras y registro en CDMX. Madera barnizada o plástico reforzado."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La medida estándar para cualquier buffet profesional"
    title='Tablón Plegable <span class="highlight">240cm</span> — Renta para Buffets y Eventos CDMX'
    subtitle="El tablón de 240 × 75 cm ofrece 1.8 m² de superficie para buffets completos, barras de bebidas, mesas de registro y candy bars. Madera barnizada o plástico reforzado. 100 kg de capacidad, patas plegables y montaje incluido. Desde $100 por tablón."
    primaryCTA={{ label: "Cotizar tablones 240cm", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar tablones plegables de 240cm para mi evento` }}
    cards={[
      {
        title: "1.8 m² de superficie — el espacio que todo buffet profesional necesita",
        content: "El <strong>tablón plegable de 240 × 75 cm</strong> es la medida que eligen los chefs y coordinadores de eventos para montar buffets serios: 6 a 8 platillos en un solo tablón, con espacio para chafers, bandejas y decoración. Disponible en dos materiales: <strong>madera barnizada</strong> con veta natural visible para ambientes rústicos y elegantes, y <strong>plástico reforzado resistente a intemperie</strong> para exteriores y uso intensivo.",
      },
      {
        title: "Plegable, modular y listo para montaje en minutos",
        content: "Las <strong>patas tipo tijera se abaten en segundos</strong> — listo para transporte y montaje ágil. Se unen en secuencia para líneas de buffet de cualquier longitud: 3 tablones = 7.2 metros corridos. Dispuestos en L, U o cuadrado para optimizar el flujo de servicio. <strong>Entrega, montaje según layout del venue y recolección incluidos en CDMX</strong>. El equipo diseña la distribución del buffet sin costo adicional.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Necesitas tablones de 240cm para tu buffet o evento? Cotiza sin compromiso"
    subheadline="Madera barnizada o plástico reforzado · Entrega y montaje en CDMX · Desde $100"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes de Tablón</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Tablones plegables 240cm para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar tablones plegables de 240cm para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA (primera sección del main) -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Tablón Plegable 240cm en Eventos Reales</h2>
            <p class="section__subtitle">Buffets, barras, mesas de registro y candy bars montados con tablones de 240cm en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="4" rx="1"/><path d="M4 11v8"/><path d="M20 11v8"/><path d="M8 11v8"/><path d="M16 11v8"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Tablón Plegable 240cm</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Por qué el 240cm es el estándar -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Por qué el tablón de 240cm es el estándar del sector"
    headingId="descripcion-heading"
    badge="La medida que los chefs piden por nombre"
    tags={["240 × 75 cm", "Buffets Completos", "Mesas de Registro", "Barras de Bebidas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Hay una razón por la que <strong>coordinadores de eventos, chefs de catering y wedding planners</strong> piden el tablón de 240cm por nombre sin siquiera preguntar el modelo: es la única medida que resuelve todo sin compromisos. La superficie de 240 × 75 cm permite disponer una línea completa de buffet — sopas, entradas, platos fuertes, guarniciones y salsas — en un solo tablón, con espacio para decoración y señalización.</p>
      <p class="showcase__text">Combinado en secuencia, tres tablones de 240cm crean <strong>7.2 metros de barra continua</strong> para eventos de 300+ personas. La altura estándar de 75 cm es ergonómica para servicio de pie — la misma altura que usan los banquetes más formales de la Ciudad de México. Las <strong>patas tipo tijera se instalan sin herramientas</strong> en menos de 30 segundos por tablón.</p>
      <p class="showcase__text">El tablón de madera barnizada deja la veta natural visible — perfecto para bodas y eventos donde la madera queda expuesta como elemento decorativo. El de plástico reforzado no absorbe humedad, no se mancha con salsas y aguanta la intemperie total. Ambos con la misma capacidad de 100 kg distribuidos.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif" alt="Tablón plegable 240cm en evento jardín elegante CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/tablon-madera-runner-velas-jardin-rustico.avif" alt="Tablón 240cm madera con runner y velas en jardín" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-tablones-crossback-boda-rustica.avif" alt="Tablones 240cm con sillas crossback en boda rústica" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- SHOWCASE: Usos del tablón 240cm -->
          <section class="section section--alt" aria-labelledby="usos-heading">
            <ServiceShowcase
    title="Los 4 usos más frecuentes del tablón 240cm"
    headingId="usos-heading"
    badge="Versátil para cualquier formato de evento"
    tags={["Buffet", "Barra de Bebidas", "Registro", "Candy Bar"]}
  >
    <Fragment slot="body">
      <p class="showcase__text"><strong>Buffet principal:</strong> La configuración más pedida — 4 a 6 tablones en línea o en U con chafers, bandejas y señalización. El 240cm permite que dos personas sirvan simultáneamente desde lados opuestos sin chocarse, lo que reduce los tiempos de espera en eventos de 200+ personas.</p>
      <p class="showcase__text"><strong>Barra de bebidas:</strong> Un solo tablón de 240cm es suficiente para una barra de cocteles o bar completo con botellas, vasos, hieleras y decoración. Dos tablones en L crean una barra de esquina con zona de atención y zona de preparación separadas.</p>
      <p class="showcase__text"><strong>Mesa de registro:</strong> El tamaño ideal para el área de bienvenida donde los invitados se registran y reciben sus lugares. Superficie amplia para laptop, impresora, lista de invitados, tarjetas de mesa y flores decorativas sin saturar el espacio.</p>
      <p class="showcase__text"><strong>Candy bar y mesa de postres:</strong> La madera barnizada con veta natural es la base más elegante para un candy bar elaborado — permite decorar con telas, flores y risers para crear niveles visuales que se convierten en el punto focal del evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/tablones-candy-bar-mesa-regalos.avif" alt="Tablones 240cm como candy bar en evento CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/tablon-crossback-jardin-string-lights.avif" alt="Tablón 240cm en jardín con string lights" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif" alt="Tablones 240cm cruzados en boda jardín" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Tablón Plegable 240cm</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre el Tablón Plegable 240cm"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "El tablón de 240cm es la medida más versátil para eventos en CDMX. Aquí respondemos las dudas más frecuentes sobre capacidad, materiales, configuraciones y logística.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
