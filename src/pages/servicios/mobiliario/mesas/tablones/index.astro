---
/**
 * ─── Tablones y Buffet — Página de Producto (Nivel 4) ───
 * Tablones plegables de 240×75 cm en madera y plástico.
 * Versátiles para buffets, candy bars y montajes modulares.
 *
 * Jerarquía: Servicios > Mobiliario > Mesas > Tablones y Buffet
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas", href: "/servicios/mobiliario/mesas/" },
  { label: "Tablones y Buffet" },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre tablón de madera y plástico?", answer: 'El <strong>tablón de madera barnizada</strong> tiene un acabado elegante con veta visible — ideal para candy bars, mesas de postres y eventos rústicos donde la madera queda expuesta. El <strong>tablón de plástico reforzado</strong> es resistente a la intemperie, rayos UV y no se mancha — ideal para buffets al exterior, áreas de registro y uso intensivo. Ambos comparten las mismas dimensiones de <strong>240 × 75 cm</strong> y capacidad de carga de <strong>100 kg distribuidos</strong>.' },
  { question: "¿Cuántos tablones necesito para un buffet?", answer: 'Depende de la cantidad de platillos y estaciones. Para un <strong>buffet sencillo</strong> (3-5 platillos), recomendamos <strong>2 a 3 tablones</strong>. Para un <strong>buffet elaborado</strong> (6-10 platillos + postres), necesitarás <strong>4 a 6 tablones</strong>. Para <strong>estaciones completas</strong> con barra de bebidas, postres y registro, calcula <strong>8 o más tablones</strong>. Nuestro equipo te ayuda a calcular la cantidad exacta según tu menú y layout.' },
  { question: "¿Se pueden usar sin mantelería?", answer: 'Sí, especialmente los de <strong>madera barnizada</strong> — su veta natural y acabado pulido lucen hermosos al descubierto, perfectos para estilos rústicos, bohemios y vintage. Los de <strong>plástico reforzado</strong> normalmente se cubren con mantelería. Ofrecemos <a href="/servicios/accesorios/manteleria-textiles/">manteles en más de 30 colores</a> que complementan cualquier tablón y temática.' },
  { question: "¿Soportan equipos de catering pesados?", answer: 'Sí. Cada tablón tiene una <strong>capacidad de carga de 100 kg distribuidos</strong>, lo cual soporta sin problema chafers, calentadores, bandejas de servicio, fuentes de chocolate y torres de cupcakes. Para equipos excepcionalmente pesados como planchas industriales o parrillas, recomendamos refuerzo adicional o uso de nuestras <a href="/servicios/catering/cocina-movil/">mesas de cocina móvil de acero inoxidable</a>.' },
  { question: "¿Son estables en exterior?", answer: 'Los tablones de <strong>plástico reforzado son ideales para exterior</strong> — resistentes a lluvia, sol y humedad. Los de <strong>madera barnizada funcionan perfecto bajo carpas</strong> o en terrazas techadas. Ambos modelos incluyen <strong>niveladores en las patas</strong> para estabilidad en pasto, tierra o superficies irregulares. Complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para protección total.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Para pedidos pequeños (1-10 tablones), recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong>. Para eventos grandes con 20+ tablones o estaciones de buffet completas, sugerimos <strong>2 a 4 semanas</strong>. En temporada alta (noviembre a febrero), la demanda se incrementa considerablemente. Un anticipo del 30% confirma tu reserva y asegura tu fecha.' },
];

const specs = [
  { label: "Dimensiones", value: "240 × 75 cm" },
  { label: "Altura", value: "75 cm (estándar)" },
  { label: "Línea Madera", value: "Madera barnizada, acabado elegante" },
  { label: "Línea Plástico", value: "Polipropileno reforzado, resistente intemperie" },
  { label: "Capacidad de carga", value: "100 kg distribuidos" },
  { label: "Patas", value: "Plegables tipo tijera, abatibles" },
  { label: "Peso Madera", value: "15 kg" },
  { label: "Peso Plástico", value: "12 kg" },
  { label: "Unibles", value: "Sí, en secuencia para buffets largos" },
  { label: "Mantenimiento", value: "Limpieza e inspección incluida pre-evento" },
];

const sidebarNav = [
  { name: "Mesas Redondas", href: "/servicios/mobiliario/mesas/redondas/" },
  { name: "Mesas Rectangulares", href: "/servicios/mobiliario/mesas/rectangulares/" },
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Tablones y Buffet", href: null, active: true },
];

const sidebarRelated = [
  { name: "Equipo de Catering", href: "/servicios/catering/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Barras para Eventos", href: "/servicios/mobiliario/barras/" },
];

const reviews = [
  { author: "Chef Eduardo Martínez", text: "Rentamos 8 tablones de madera para la estación de postres de una boda en jardín. La madera barnizada se veía espectacular con la decoración rústica — la veta natural le dio un toque muy elegante. Soportaron todo el equipo sin problema: chafers, bandejas, la torre de cupcakes. El montaje fue rápido y el equipo muy profesional.", rating: 5, date: "2025-11-05" },
  { author: "Daniela Ríos", text: "Necesitábamos 6 tablones de plástico para una feria al aire libre con área de registro y buffet. Llovió durante el evento y los tablones aguantaron perfecto — ni se mojaron ni se mancharon. La limpieza fue facilísima. Definitivamente los volvería a rentar para cualquier evento exterior.", rating: 5, date: "2025-10-15" },
  { author: "Verónica Guzmán", text: "Montamos un candy bar elaborado para los XV años de mi hija con 4 tablones de madera. Los decoramos con telas y flores, y la base fue súper resistente — soportó la torre de cupcakes, fuente de chocolate y todos los dulces sin problema. Se veía increíble en las fotos.", rating: 5, date: "2025-08-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Tablones y Mesas de Buffet para Eventos en CDMX",
    description: "Renta de tablones plegables de 240×75 cm en madera barnizada y plástico reforzado para buffets, candy bars y registro. 100 kg capacidad. Desde $50 por tablón.",
    url: "/servicios/mobiliario/mesas/tablones/",
    priceRange: { min: 50, max: 180 },
    reviews,
    ratingValue: 5,
    reviewCount: 72,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
    { name: "Tablones y Buffet", url: "/servicios/mobiliario/mesas/tablones/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Tablones y Mesas de Buffet para Eventos en CDMX"
  description="Renta de tablones plegables de 240×75 cm en madera barnizada y plástico reforzado para buffets, candy bars y registro. 100 kg capacidad. Desde $50 por tablón."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La base versátil para todo montaje"
    title='Renta de <span class="highlight">Tablones y Mesas de Buffet</span> para Eventos en CDMX'
    subtitle="Tablones plegables de 240×75 cm en madera barnizada y plástico reforzado. 100 kg de capacidad. Patas abatibles para transporte rápido. Ideales para buffets, candy bars, mesas de regalos, barras y áreas de registro."
    primaryCTA={{ label: "Cotiza tus tablones", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar tablones para mi evento` }}
    cards={[
      {
        title: "Dos materiales para cada necesidad: madera barnizada y plástico",
        content: "<strong>Renta de tablones para eventos</strong> en dos líneas de material: madera barnizada con acabado elegante y veta natural visible, ideal para candy bars, mesas de postres y eventos rústicos donde la madera queda expuesta; y plástico reforzado resistente a la intemperie y rayos UV, perfecto para buffets al exterior, áreas de registro y uso intensivo. Ambos modelos de <strong>240 × 75 cm con capacidad de 100 kg</strong> y patas plegables para transporte rápido y montaje ágil.",
      },
      {
        title: "Plegables, modulares y montaje en minutos para cualquier configuración",
        content: "<strong>Diseño plegable para montaje rápido</strong> — las patas tipo tijera se abaten en segundos para transporte y almacenamiento eficiente. Se unen en secuencia para crear líneas largas de buffet, se colocan en configuraciones L o U para estaciones de servicio, se cubren con mantelería para un look formal o se dejan con madera expuesta para ambientes rústicos. <strong>Entrega, montaje y recolección incluidos</strong> en todos nuestros servicios de tablones.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas tablones para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te asesoramos con la cantidad y material ideal"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Mesas para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas tablones para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar tablones para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="4" rx="1"/><path d="M4 11v8"/><path d="M20 11v8"/><path d="M8 11v8"/><path d="M16 11v8"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Tablones y Buffet</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Tablón Madera Barnizada -->
          <section class="section section--alt" aria-labelledby="madera-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Acabado elegante</span>
                <h2 class="showcase__title" id="madera-heading">Tablón Madera Barnizada</h2>
                <p class="showcase__subtitle">La calidez y elegancia de la madera natural con acabado barnizado a mano para eventos con personalidad.</p>
                <p class="showcase__text">El <strong>tablón de madera barnizada</strong> es nuestra línea premium con acabado pulido a mano que resalta la veta natural de la madera. Su apariencia cálida y sofisticada lo convierte en la elección favorita para <strong>candy bars, mesas de postres, mesas de regalos</strong> y eventos con estilo rústico o bohemio donde la madera queda expuesta como elemento decorativo. La veta natural aporta carácter único a cada pieza — ningún tablón es idéntico al otro.</p>
                <p class="showcase__text">Puede cubrirse con <a href="/servicios/accesorios/manteleria-textiles/">mantelería premium</a> para looks formales o dejarse al descubierto para ambientes rústicos y vintage. Con <strong>240 × 75 cm de superficie y 100 kg de capacidad</strong>, soporta sin problema torres de cupcakes, fuentes de chocolate, charolas de servicio y toda la decoración que necesites. Patas plegables tipo tijera para montaje rápido.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Madera Barnizada</span>
                  <span class="showcase__tag">Candy Bar</span>
                  <span class="showcase__tag">Postres</span>
                  <span class="showcase__tag">Rústico</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tablón Madera
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/tablon-madera-runner-velas-jardin-rustico.avif"
                  alt="Tablón de madera barnizada con runner y velas en jardín rústico para boda CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Tablón Plástico Reforzado -->
          <section class="section section--alt" aria-labelledby="plastico-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Resistente a intemperie</span>
                <h2 class="showcase__title" id="plastico-heading">Tablón Plástico Reforzado</h2>
                <p class="showcase__subtitle">Polipropileno de alta resistencia que no se deforma, no se mancha y soporta lluvia, sol y uso intensivo.</p>
                <p class="showcase__text">El <strong>tablón de plástico reforzado</strong> está fabricado en polipropileno de alta densidad con tratamiento anti-UV — no se deforma con el calor, no se mancha con líquidos y no absorbe humedad. Es la opción ideal para <strong>buffets al aire libre, áreas de registro, ferias, bazares</strong> y cualquier escenario donde se necesite resistencia total a la intemperie y uso intensivo.</p>
                <p class="showcase__text">Con el mismo formato de <strong>240 × 75 cm y 100 kg de capacidad</strong>, se limpia con un trapo húmedo en segundos. Ligero (12 kg vs 15 kg de madera) para logística eficiente. Complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para eventos completamente protegidos del clima. Patas plegables abatibles para transporte y almacenamiento optimizado.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Plástico Reforzado</span>
                  <span class="showcase__tag">Intemperie</span>
                  <span class="showcase__tag">Buffets</span>
                  <span class="showcase__tag">Registro</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tablón Plástico
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/mesas-tablones-crossback-boda-rustica.avif"
                  alt="Tablones para eventos con sillas Crossback en boda rústica al aire libre CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Estación de Buffet Completa -->
          <section class="section section--alt" aria-labelledby="buffet-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Montaje integral</span>
                <h2 class="showcase__title" id="buffet-heading">Estación de Buffet Completa</h2>
                <p class="showcase__subtitle">Múltiples tablones unidos en secuencia con equipo de catering para estaciones de servicio profesionales.</p>
                <p class="showcase__text">Combina múltiples tablones en secuencia para crear <strong>estaciones de buffet completas</strong> de cualquier longitud. Nuestros tablones se unen perfectamente uno tras otro para líneas rectas, o se disponen en configuraciones L y U para optimizar el flujo de servicio. El equipo diseña la distribución óptima del buffet según tu menú, número de invitados y layout del venue.</p>
                <p class="showcase__text">Complementa con <a href="/servicios/catering/">equipo de catering profesional</a>: chafers, calentadores, bandejas de servicio, fuentes y todo lo necesario para una <strong>experiencia gastronómica impecable</strong>. Incluimos mantelería coordinada, faldones y accesorios para un montaje integral que impresiona desde el primer vistazo hasta el último bocado.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Buffet Completo</span>
                  <span class="showcase__tag">Estaciones</span>
                  <span class="showcase__tag">Catering</span>
                  <span class="showcase__tag">Servicio</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Estación Buffet
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/tablones-crossback-boda-jardin-elegante.avif"
                  alt="Estación de buffet completa con tablones de madera en boda jardín elegante CDMX"
                  width="800" height="436"
                  loading="lazy" decoding="async"
                  class="showcase__img"
                />
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Candy Bar y Mesa de Regalos -->
          <section class="section section--alt" aria-labelledby="candybar-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El toque dulce del evento</span>
                <h2 class="showcase__title" id="candybar-heading">Candy Bar y Mesa de Regalos</h2>
                <p class="showcase__subtitle">Tablones como base para montajes elaborados de postres, dulces y regalos que son el centro de atención.</p>
                <p class="showcase__text">Los tablones son la <strong>base perfecta para candy bars elaborados, mesas de postres y mesas de regalos</strong> que se convierten en el centro de atención de cualquier celebración. Populares para bodas, XV años, baby showers y bautizos, los tablones de madera barnizada aportan la calidez ideal para exhibir dulces, cupcakes, macarons, cake pops y arreglos temáticos.</p>
                <p class="showcase__text">Se pueden elevar con risers y pedestales para crear niveles visuales, decorar con telas, flores y <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un <strong>efecto wow garantizado</strong>. La superficie de 240 × 75 cm ofrece espacio generoso para montajes creativos sin comprometer la estabilidad — los 100 kg de capacidad soportan torres de cupcakes, fuentes de chocolate y toda la decoración sin problema.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Candy Bar</span>
                  <span class="showcase__tag">Mesa Regalos</span>
                  <span class="showcase__tag">Postres</span>
                  <span class="showcase__tag">Decoración</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Candy Bar
                </a>
              </div>
              <div class="showcase__image">
                <img
                  src="/images/mobiliario/tablones-candy-bar-mesa-regalos.avif"
