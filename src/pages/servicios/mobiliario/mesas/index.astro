---
/**
 * ─── Mesas para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Mesas para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const MESAS = [
  {
    name: "Mesas Redondas",
    excerpt: "Diámetros de 150 y 180 cm para 8 a 10 personas. El estándar de oro para banquetes de bodas, XV años y galas corporativas.",
    cta: "Redondas",
    href: "#redondas-heading",
    icon: "users",
  },
  {
    name: "Mesas Rectangulares",
    excerpt: "Tableros de 240 × 120 cm para 8 comensales. Formato imperial perfecto para bodas lineales y cenas de gala.",
    cta: "Rectangulares",
    href: "#rectangulares-heading",
    icon: "layers",
  },
  {
    name: "Mesas Cocktail",
    excerpt: "Periqueras de 60 cm de diámetro y 110 cm de altura. El complemento ideal para recepciones, cócteles y áreas de socialización.",
    cta: "Cocktail",
    href: "#cocktail-heading",
    icon: "briefcase",
  },
  {
    name: "Tablones y Buffet",
    excerpt: "Tablones plegables de 240 × 75 cm en madera y plástico. Versátiles para buffets, registro, candy bars y montajes modulares.",
    cta: "Tablones",
    href: "#tablones-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Cuántas mesas redondas necesito para mi evento?", answer: "La regla estándar es 1 mesa redonda de 150 cm por cada 8 invitados, o 1 mesa de 180 cm por cada 10 invitados. Para un evento de 200 personas necesitarías aproximadamente 25 mesas de 150 cm o 20 mesas de 180 cm. Nuestro equipo te ayuda a calcular la cantidad exacta según el plano de tu venue, considerando espacio para circulación, pista de baile y áreas de servicio." },
  { question: "¿Qué diferencia hay entre mesa redonda y rectangular para un banquete?", answer: "La mesa redonda favorece la conversación entre todos los comensales y es la opción clásica para bodas y galas. La mesa rectangular (formato imperial) crea una distribución lineal más elegante, ideal para bodas íntimas y cenas de revista. La elección depende del estilo de tu evento: la redonda es más social y la rectangular es más fotogénica. Muchos clientes combinan ambos formatos." },
  { question: "¿Las mesas incluyen mantelería?", answer: "Las mesas se rentan con o sin mantelería según tu preferencia. Ofrecemos manteles redondos, rectangulares, caminos de mesa, cubre manteles y servilletas en más de 30 colores y texturas. La mantelería se cotiza por separado para darte flexibilidad total en tu presupuesto. Consulta nuestra sección de accesorios para ver todas las opciones disponibles." },
  { question: "¿Qué capacidad de peso soportan las mesas?", answer: "Nuestras mesas redondas soportan hasta 120 kg distribuidos sobre la superficie. Las mesas rectangulares soportan hasta 150 kg. Los tablones plegables tienen capacidad de 100 kg. Las mesas cocktail soportan hasta 40 kg, suficiente para bebidas y bocadillos. Todas nuestras mesas cuentan con bases estabilizadoras que evitan el balanceo en superficies irregulares." },
  { question: "¿Puedo combinar diferentes tipos de mesas en un mismo evento?", answer: "Es una de las estrategias más recomendadas. Por ejemplo: mesas redondas para el banquete principal, rectangulares para la mesa de honor, cocktail para la zona de recepción y tablones para el buffet y candy bar. Nuestros asesores diseñan el layout combinado óptimo según las dimensiones de tu venue y el flujo de invitados." },
  { question: "¿Con cuánta anticipación debo reservar las mesas?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación. En temporada alta (noviembre a febrero) y para eventos grandes de más de 200 personas, lo ideal es apartar con 1 a 2 meses. Los formatos más solicitados (redondas de 150 cm y cocktail) se agotan primero, así que te sugerimos confirmar tu cantidad lo antes posible para garantizar disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mesas para Eventos en CDMX",
    description: "Mesas redondas, rectangulares, cocktail y tablones para bodas, XV años y corporativos. Entrega y montaje incluido en CDMX.",
    url: "/servicios/mobiliario/mesas/",
    priceRange: { min: 50, max: 350 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas", url: "/servicios/mobiliario/mesas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mesas para Eventos en CDMX"
  description="Renta de mesas redondas, rectangulares, cocktail y tablones para eventos en CDMX. Desde $50 por mesa. Entrega y montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 3,000 mesas disponibles"
    title='Renta de <span class="highlight">Mesas para Eventos</span> en CDMX'
    subtitle="Mesas redondas, rectangulares, cocktail y tablones con configuraciones flexibles para cualquier número de invitados. Entrega, montaje y asesoría de layout incluidos."
    primaryCTA={{ label: "Cotiza tus mesas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mesas para mi evento` }}
    cards={[
      {
        title: "Todos los formatos para cualquier tipo de evento",
        content: "<strong>Renta de mesas para eventos</strong> con el inventario más completo de la Ciudad de México. Mesas redondas de 150 y 180 cm para banquetes clásicos de bodas y XV años. Mesas rectangulares de 240 cm para distribuciones imperiales y cenas de gala. Mesas cocktail (periqueras) de 110 cm de altura para recepciones y cócteles elegantes. Tablones plegables para buffets, candy bars y áreas de registro — cada mesa verificada en estabilidad, acabado y resistencia antes de cada evento.",
      },
      {
        title: "Asesoría de layout y montaje profesional incluidos",
        content: "<strong>Servicio integral de mesas</strong> que va más allá de la simple renta. Nuestro equipo calcula la cantidad exacta de mesas según tu número de invitados y las dimensiones de tu venue. Diseñamos el layout óptimo considerando espacio de circulación, pista de baile y zonas de servicio. Incluimos entrega puntual, montaje con niveladores en cada base y recolección al finalizar — todo sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas calcular cuántas mesas necesitas?"
    subheadline="Nuestros asesores diseñan el layout perfecto para tu venue sin costo. Cotiza sin compromiso."
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de mesa
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Mesas"
        subtitle="El formato ideal para cada distribución"
        description={[
          "Ofrecemos los 4 formatos de mesa más solicitados para eventos profesionales en la Ciudad de México. Más de 3,000 unidades en inventario permanente con bases estabilizadoras y acabados impecables.",
          "Cada formato está diseñado para un propósito específico: desde el banquete principal hasta las áreas de cóctel y buffet. Combínalos para crear la distribución perfecta en tu venue."
        ]}
      />

      <div class="grid grid--4">
        {MESAS.map((mesa) => (
          <Card
            name={mesa.name}
            excerpt={mesa.excerpt}
            cta={mesa.cta}
            href={mesa.href}
            icon={mesa.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS REDONDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="redondas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Las más solicitadas</span>
          <h2 class="showcase__title" id="redondas-heading">Mesas Redondas</h2>
          <p class="showcase__subtitle">El estándar de oro para banquetes: máxima conversación y distribución eficiente.</p>
          <p class="showcase__text">La <strong>mesa redonda</strong> es la opción más popular para banquetes de bodas, XV años, bautizos y galas corporativas. Disponible en dos diámetros profesionales: <strong>150 cm (capacidad 8 personas)</strong> y <strong>180 cm (capacidad 10 personas)</strong>. Fabricadas en tablero de triplay de alta densidad con acabado melamínico resistente a manchas y humedad, montadas sobre base metálica plegable con niveladores ajustables.</p>
          <p class="showcase__text">Cada mesa incluye <strong>base estabilizadora antivuelco</strong> que garantiza firmeza total incluso en superficies de jardín o pasto. Soportan hasta <strong>120 kg distribuidos</strong> sobre la superficie. Combínalas con nuestras <a href="/servicios/mobiliario/sillas/">sillas Tiffany o Chiavari</a> para un montaje de banquete completo y perfectamente coordinado.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">150 cm / 8 personas</span>
            <span class="showcase__tag">180 cm / 10 personas</span>
            <span class="showcase__tag">120 kg capacidad</span>
            <span class="showcase__tag">Plegables</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Redondas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v8"/>
              <path d="M8 12h8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS RECTANGULARES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="rectangulares-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Formato imperial</span>
          <h2 class="showcase__title" id="rectangulares-heading">Mesas Rectangulares</h2>
          <p class="showcase__subtitle">La distribución lineal que transforma tu banquete en una experiencia de revista.</p>
          <p class="showcase__text">La <strong>mesa rectangular</strong> (también llamada mesa imperial) es la favorita para bodas íntimas, cenas de gala y eventos corporativos de alto nivel. Dimensiones profesionales de <strong>240 × 120 cm con capacidad para 8 comensales</strong> (4 por lado) o hasta 10 personas incluyendo cabeceras. Fabricadas en tablero de alta densidad con acabado resistente y estructura metálica reforzada con <strong>capacidad de 150 kg</strong>.</p>
          <p class="showcase__text">El formato rectangular crea líneas visuales dramáticas que lucen espectaculares en fotografías. Es ideal para <strong>mesas de honor, banquetes imperiales continuos</strong> y distribuciones en forma de U o T. Se pueden unir en secuencia para crear mesas de cualquier longitud. Complementa con nuestra <a href="/servicios/accesorios/">mantelería premium</a> en caminos de mesa y cubre manteles para un acabado de alta gama.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">240 × 120 cm</span>
            <span class="showcase__tag">8-10 personas</span>
            <span class="showcase__tag">150 kg capacidad</span>
            <span class="showcase__tag">Unibles en secuencia</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Rectangulares
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="6" width="18" height="12" rx="2"/>
              <path d="M3 12h18"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS COCKTAIL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cocktail-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Elegancia vertical</span>
          <h2 class="showcase__title" id="cocktail-heading">Mesas Cocktail</h2>
          <p class="showcase__subtitle">El complemento indispensable para recepciones, cócteles y áreas de socialización.</p>
          <p class="showcase__text">Las <strong>mesas cocktail</strong> (periqueras) son el elemento clave para crear zonas de networking y socialización en tu evento. Disponibles en formato estándar de <strong>60 cm de diámetro × 110 cm de altura</strong> con tablero circular y base metálica cromada con <strong>contrapeso estabilizador</strong>. Capacidad de hasta <strong>40 kg</strong> sobre la superficie, ideal para bebidas, bocadillos y arreglos florales.</p>
          <p class="showcase__text">Ofrecemos acabados en <strong>tablero negro, blanco y madera natural</strong>, más la opción de <strong>fundas elásticas (spandex)</strong> en más de 15 colores que transforman completamente su apariencia. Ideales para la hora del cóctel previo al banquete, fiestas de empresa y ferias comerciales. Potencia su presencia con nuestra <a href="/servicios/iluminacion/">iluminación ambiental</a> para crear atmósferas sofisticadas.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">60 cm diámetro</span>
            <span class="showcase__tag">110 cm altura</span>
            <span class="showcase__tag">Fundas spandex</span>
            <span class="showcase__tag">15+ colores</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Cocktail
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 2h8l-2 8h-4L8 2z"/>
              <path d="M12 10v10"/>
              <path d="M8 22h8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TABLONES Y BUFFET — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tablones-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Versatilidad total</span>
          <h2 class="showcase__title" id="tablones-heading">Tablones y Buffet</h2>
          <p class="showcase__subtitle">La base versátil para buffets, candy bars, registro y montajes modulares.</p>
          <p class="showcase__text">Los <strong>tablones plegables</strong> son la solución más versátil de nuestro catálogo. Disponibles en formato profesional de <strong>240 × 75 cm</strong> en dos materiales: <strong>madera barnizada</strong> (acabado elegante para mesas de postres y exhibiciones) y <strong>plástico reforzado</strong> (resistente a intemperie para montajes exteriores). Estructura de patas plegables con <strong>capacidad de 100 kg</strong> distribuidos y altura estándar de 75 cm.</p>
          <p class="showcase__text">Son el recurso imprescindible para <strong>estaciones de buffet, candy bars, mesas de regalos, barras de bebidas improvisadas y áreas de registro</strong>. Se pueden cubrir con mantelería para lograr un acabado formal o dejar la madera expuesta para estilos rústicos. Instálalos bajo nuestras <a href="/servicios/carpas/">carpas profesionales</a> para eventos al aire libre y complementa con el <a href="/servicios/catering/">equipo de catering</a> para estaciones de servicio completas.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">240 × 75 cm</span>
            <span class="showcase__tag">Madera barnizada</span>
            <span class="showcase__tag">Plástico reforzado</span>
            <span class="showcase__tag">Plegables</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Tablones
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="4" rx="1"/>
              <path d="M4 11v8"/>
              <path d="M20 11v8"/>
              <path d="M8 11v8"/>
              <path d="M16 11v8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Mesas"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus mesas, es natural tener preguntas sobre formatos, capacidades, mantelería y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor especializado te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre mesas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de mesas para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Mesas"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de mesas. Sin compromiso, sin costos ocultos.",
          "Ya sea que necesites 10 mesas redondas o un montaje completo para 1,000 invitados con todas las configuraciones, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

