---
/**
 * ─── EVENTECH.MX — Renta de Mesas para Eventos (L4 hub, sistema hm-) ───
 * Redondas · Rectangulares · Cocktail · Tablones — CDMX y ZMVM
 * Homólogo del hub de sillas (mismo layout, complementos y dorado institucional).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "redondas",
    name: "Mesas Redondas",
    badge: "Las más solicitadas",
    excerpt: "El estándar de oro para banquetes: diámetros de 150 cm (8 personas) y 180 cm (10 personas), tablero de alta densidad sobre base plegable con niveladores y capacidad de 120 kg. La distribución que maximiza conversación en bodas, XV años y galas.",
    href: "/servicios/mobiliario/mesas/redondas/",
    image: "/images/mobiliario/mesas-redondas-montaje-dorado-bodas.avif",
    subcategories: [
      { name: "Redonda 150 cm (8 personas)", href: "/servicios/mobiliario/mesas/redondas/150cm/" },
      { name: "Redonda 180 cm (10 personas)", href: "/servicios/mobiliario/mesas/redondas/180cm/" },
    ],
  },
  {
    id: "rectangulares",
    name: "Mesas Rectangulares",
    badge: "Formato imperial",
    excerpt: "El formato imperial para bodas lineales y cenas de gala. Dimensiones de 240 × 120 cm para 8 a 10 comensales, estructura reforzada de 150 kg y posibilidad de unirse en secuencia para mesas de honor de cualquier longitud.",
    href: "/servicios/mobiliario/mesas/rectangulares/",
    image: "/images/mobiliario/mesas-rectangulares-imperiales-gala-velas.avif",
    subcategories: [
      { name: "Rectangular 240 cm (10 personas)", href: "/servicios/mobiliario/mesas/rectangulares/240cm/" },
      { name: "Rectangular 180 cm (8 personas)", href: "/servicios/mobiliario/mesas/rectangulares/180cm/" },
    ],
  },
  {
    id: "cocktail",
    name: "Mesas Cocktail",
    badge: "Elegancia vertical",
    excerpt: "Periqueras de 60 cm de diámetro y 110 cm de altura con base de contrapeso estabilizador. El complemento indispensable para la hora del cóctel, networking y ferias. Acabados en negro, blanco y madera, más fundas spandex en 15+ colores.",
    href: "/servicios/mobiliario/mesas/cocktail/",
    image: "/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif",
    subcategories: [
      { name: "Cocktail Alta Spandex", href: "/servicios/mobiliario/mesas/cocktail/alta-spandex/" },
      { name: "Cocktail Alta Madera", href: "/servicios/mobiliario/mesas/cocktail/alta-madera/" },
    ],
  },
  {
    id: "tablones",
    name: "Tablones y Buffet",
    badge: "Versatilidad total",
    excerpt: "La base más versátil del catálogo: tablones plegables de 240 × 75 cm en madera barnizada y plástico reforzado, con capacidad de 100 kg. El recurso imprescindible para buffets, candy bars, mesas de regalos y áreas de registro.",
    href: "/servicios/mobiliario/mesas/tablones/",
    image: "/images/mobiliario/mesas-tablones-crossback-boda-rustica.avif",
    subcategories: [
      { name: "Tablón Plegable 240 cm", href: "/servicios/mobiliario/mesas/tablones/plegable-240/" },
      { name: "Tablón Plegable 180 cm", href: "/servicios/mobiliario/mesas/tablones/plegable-180/" },
    ],
  },
];

const whyFeatures = [
  {
    title: "Inventario propio — sin subcontratistas",
    body: "Más de 3,000 mesas propias en bodega CDMX en los 4 formatos. No intermediamos con otros proveedores. Lo que cotizamos es lo que existe en nuestro almacén, verificado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    title: "Bases estabilizadoras antivuelco",
    body: "Cada mesa monta sobre base plegable con niveladores ajustables que garantizan firmeza total incluso en jardín, pasto o terreno irregular. Nada de mesas que cojean a mitad del banquete — el detalle que separa un montaje profesional de uno improvisado.",
  },
  {
    title: "Entrega puntual con montaje según layout",
    body: "Nuestro equipo logístico entrega y coloca cada mesa en la posición exacta de tu plano aprobado — no dejamos la mercancía en la puerta. Llegamos con tiempo suficiente antes del evento para que el venue quede listo sin contratiempos.",
  },
  {
    title: "Revisión pieza por pieza antes de salir de bodega",
    body: "Toda mesa pasa por protocolo de inspección: tablero, acabado, estructura, patas y niveladores. Las unidades con rayones, manchas o fallas mecánicas se separan y reemplazan antes de cargar el camión. Lo que llega a tu evento está impecable.",
  },
  {
    title: "Reposición en sitio garantizada",
    body: "Si durante el montaje detectamos una mesa dañada o un formato incorrecto, la reponemos sin costo dentro de CDMX. Siempre cargamos un porcentaje de reposición en cada servicio para que no te descubras con una pieza faltante minutos antes del evento.",
  },
  {
    title: "Asesoría de layout y cálculo de cantidad",
    body: "¿Cuántas mesas para tu número de invitados? ¿Qué formato deja más espacio para pista de baile? Calculamos la distribución óptima de tu venue considerando circulación, zonas de servicio y la mezcla de formatos que mejor funciona — con referencias visuales reales.",
  },
];

const steps = [
  { n: 1, t: "Cotización y aparto de inventario", p: "Nos indicas formato, cantidad, dimensiones y fecha. En menos de 24 horas te confirmamos disponibilidad y te enviamos propuesta. Con el 30% de anticipo apartamos tu inventario — sin pago total por adelantado." },
  { n: 2, t: "Coordinación con venue y otros proveedores", p: "Si trabajas con decoradora, wedding planner o el propio salón, coordinamos directamente con ellos. Compartimos layout de entrega, horario de acceso y requerimientos logísticos para que el montaje sea limpio y sin conflictos." },
  { n: 3, t: "Entrega, montaje y verificación en sitio", p: "Llegamos el día del evento o la tarde anterior según acuerdo. Cada mesa se coloca en su posición según el plano, se nivela correctamente y hacemos verificación visual del montaje completo antes de retirarnos. Tú o tu coordinador firman conformidad." },
  { n: 4, t: "Recolección al finalizar el evento", p: "Al cierre, nuestro equipo recoge, pliega y carga todas las mesas. Conteo final en conjunto para confirmar que no falta ninguna pieza. Sin presiones de tiempo si el evento se extiende — acordamos horario de recolección con anticipación." },
];

const faqs = [
  {
    question: "¿Cuántas personas caben en cada mesa?",
    answer: "Las mesas redondas de 150 cm de diámetro son cómodas para 8 personas y las de 180 cm para 10. Las rectangulares de 240 × 120 cm acomodan 8 comensales (4 por lado) o hasta 10 incluyendo cabeceras. Las cocktail (periqueras) no son para sentarse: son de pie, ideales para 3 a 4 personas socializando alrededor. Te ayudamos a calcular la cantidad exacta según tu número de invitados y el formato elegido.",
  },
  {
    question: "¿Cuál es la diferencia entre mesa redonda y rectangular?",
    answer: "La redonda favorece la conversación porque todos los comensales se ven entre sí, es el estándar clásico de banquete de boda y aprovecha mejor el espacio circular del salón. La rectangular (imperial) crea líneas visuales dramáticas que lucen espectaculares en fotografía, es ideal para mesas de honor y permite distribuciones en U o T. Muchos eventos combinan ambas: imperial para la mesa principal y redondas para invitados.",
  },
  {
    question: "¿Cuántas mesas necesito para mi evento?",
    answer: "Depende del número de invitados y el formato. Con redondas de 180 cm (10 personas), 200 invitados requieren 20 mesas más mesa de honor. Recuerda reservar espacio para pista de baile, zona de cóctel y estaciones de servicio. Calcula también mesas de apoyo: registro, regalos, candy bar y buffet. Te armamos el layout completo con la cantidad exacta sin que sobren ni falten mesas.",
  },
  {
    question: "¿Puedo combinar diferentes formatos en el mismo evento?",
    answer: "Sí, y es lo más recomendable. Combinaciones frecuentes: mesa imperial rectangular de honor + redondas para invitados; redondas en banquete + cocktail en la zona de recepción; tablones para buffet y candy bar + redondas en el comedor. Lo importante es coordinar mantelería y altura para una estética coherente. Te asesoramos con la mezcla que mejor aprovecha tu venue.",
  },
  {
    question: "¿El precio de renta incluye mantelería y montaje?",
    answer: "El precio cotizado de la mesa incluye entrega al venue, colocación según layout, nivelación y recolección al finalizar. Dentro de CDMX no hay cargo logístico adicional. La mantelería (manteles, cubre manteles, caminos de mesa) se cotiza por separado en más de 30 colores y telas — pregúntanos por el paquete mesa + mantelería para un acabado coordinado. Para Zona Metropolitana el transporte se especifica en la cotización.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Para eventos medianos (hasta 20 mesas), 2 a 3 semanas de anticipación es suficiente. Para eventos grandes (40+ mesas) o si requieres un formato y dimensión muy específicos, recomendamos 4 a 6 semanas. En temporada alta de bodas (noviembre a febrero) y en fines de semana con múltiples eventos simultáneos, 6 a 8 semanas es lo ideal para garantizar el inventario completo en el formato exacto.",
  },
  {
    question: "¿Las mesas son aptas para exteriores y jardín?",
    answer: "Sí. Todas montan sobre bases con niveladores antivuelco que estabilizan en pasto y terreno irregular. Los tablones de plástico reforzado son los más aptos para intemperie. Para banquetes completos al aire libre recomendamos combinarlas bajo nuestras carpas profesionales como respaldo ante lluvia. El tablero de alta densidad resiste humedad ambiental, pero la exposición directa prolongada a lluvia no es recomendable.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Mesas para Eventos en CDMX",
    description: "Renta de mesas redondas, rectangulares, cocktail y tablones para bodas, XV años, corporativos y eventos sociales en CDMX. Entrega, montaje y asesoría de layout incluidos.",
    url: "/servicios/mobiliario/mesas/",
    priceRange: { min: 80, max: 250 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Mesas para Eventos", url: "/servicios/mobiliario/mesas/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Mesas para Eventos" },
];
---

<PageLayout
  title="Renta de Mesas para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/mobiliario/mesas-redondas-montaje-dorado-bodas.avif"
  description="Renta de mesas redondas, rectangulares, cocktail y tablones en CDMX. +3,000 unidades en inventario. Montaje y asesoría de layout incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="mesas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Mesas para eventos · CDMX y ZMVM</p>
            <h1 id="mesas-hero-heading">
              Más de <em>3,000 mesas en inventario</em> — el formato exacto para cada distribución
            </h1>
            <p class="hm-hero__lead">
              Redondas, rectangulares, cocktail y tablones. Bases estabilizadoras,
              entrega puntual, montaje según tu layout y recolección al finalizar.
              Una sola empresa para todas las mesas que tu evento necesita.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mesas%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar mesas
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>mesas para eventos</strong> con uno de los inventarios
              propios más completos de la Ciudad de México — más de 3,000 unidades en
              4 formatos distintos, sin subcontratar ni intermediar. Redondas de 150 y 180 cm
              para banquetes clásicos, rectangulares imperiales de 240 cm para cenas de gala,
              cocktail de 110 cm para recepciones y tablones plegables para buffets y candy bars.
              Cada mesa se entrega verificada, nivelada y colocada en la posición exacta de tu layout.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que el formato
              de mesa define la circulación del salón, el espacio para pista de baile y la
              estética de cada fotografía: por eso incluimos asesoría de layout, cálculo exacto
              de cantidad y reposición garantizada en sitio. Para bodas que también requieren
              <a href="/servicios/mobiliario/sillas/">sillas Tiffany o Chiavari</a> te cotizamos
              el paquete completo desde una sola empresa, sin duplicar logística.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Formatos de mesa disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20mesas%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué formato de mesa necesita tu evento?</h2>
            <p class="hm__head-sub">4 formatos, múltiples dimensiones — la distribución perfecta para cada venue, estilo y presupuesto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La mesa es la pieza que organiza todo el evento: define cuántos invitados
              caben, cómo circula la gente, cuánto espacio queda para la pista de baile
              y qué tan cohesivas se ven las fotografías del salón. Elegir el formato
              correcto no es cuestión de presupuesto solamente — es decidir cómo quieres
              que tus invitados convivan y cómo quieres que luzca el montaje completo.
            </p>
            <p>
              Redondas para banquetes clásicos donde la conversación es protagonista.
              Rectangulares imperiales cuando buscas líneas dramáticas y mesas de honor.
              Cocktail para la hora de recepción y el networking de pie. Tablones cuando
              necesitas buffets, candy bars o áreas de registro funcionales y limpias.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada formato, a fondo</p>
            <h2 id="detalle-heading">Los 4 formatos de mesa — en detalle</h2>
            <p class="hm__head-sub">Dimensiones, capacidad, materiales y para qué tipo de evento funciona mejor cada formato.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada formato de mesa hay decisiones que afectan la experiencia
              del evento: el diámetro que determina cuántos invitados conversan cómodos,
              la altura que define si es para sentarse o socializar de pie, la estructura
              que marca la estabilidad en jardín, y el material del tablero que decide si
              resiste humedad y uso intensivo sin deteriorarse.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por
              precio. A continuación, lo que realmente importa de cada formato.
            </p>
          </div>
        </div>

        <!-- REDONDAS -->
        <article class="hm-feat" aria-labelledby="feat-redondas">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Mesas Redondas</p>
            <h3 class="hm-feat__title" id="feat-redondas">El estándar de oro del banquete — la distribución que maximiza conversación en bodas, XV años y galas</h3>
            <p class="hm-feat__lead">No existe salón de banquetes en CDMX que no monte mesas redondas. La razón es simple: ningún otro formato combina esa eficiencia de espacio con la dinámica social de que todos los comensales se vean entre sí.</p>
            <p>
              Disponibles en dos diámetros profesionales: <strong>150 cm para 8 personas</strong>
              y <strong>180 cm para 10 personas</strong>. Fabricadas en tablero de triplay de
              alta densidad con acabado melamínico resistente a manchas y humedad, montadas
              sobre <strong>base metálica plegable con niveladores ajustables</strong>. Soportan
              hasta <strong>120 kg distribuidos</strong> sobre la superficie con estabilidad
              total, incluso en jardín o pasto.
            </p>
            <p>
              Cada mesa incluye base estabilizadora antivuelco — nada de mesas que cojean a
              mitad del banquete. Combínalas con nuestras
              <a href="/servicios/mobiliario/sillas/">sillas Tiffany o Chiavari</a> y con
              <a href="/servicios/accesorios/">mantelería premium</a> para un montaje de
              banquete completo y perfectamente coordinado.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Redonda 150 cm", href: "/servicios/mobiliario/mesas/redondas/150cm/" },
                { name: "Redonda 180 cm", href: "/servicios/mobiliario/mesas/redondas/180cm/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/mobiliario/mesas/redondas/">
              Ver Mesas Redondas completas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/mobiliario/mesas-redondas-montaje-dorado-bodas.avif" alt="Mesas redondas con montaje dorado y flores blancas para boda en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/mobiliario/mesa-redonda-detalle-chargers-dorados-flores.avif" alt="Detalle de mesa redonda con chargers dorados y flores" loading="lazy" decoding="async" />
              <img src="/images/mobiliario/mesa-redonda-overhead-chargers-boda.avif" alt="Vista aérea de mesa redonda con chargers dorados para boda" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- RECTANGULARES -->
        <article class="hm-feat" aria-labelledby="feat-rectangulares">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Mesas Rectangulares</p>
            <h3 class="hm-feat__title" id="feat-rectangulares">Formato imperial — las líneas dramáticas que transforman tu banquete en una experiencia de revista</h3>
