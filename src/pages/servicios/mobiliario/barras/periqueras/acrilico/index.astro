---
/**
 * ─── Periquera Acrílico Transparente — Página de Variante ───
 * Periquera acrílico transparente para eventos modernos y bodas elegantes en CDMX.
 * Desde $200 por pieza.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { label: "Acrílico Transparente" },
];

const galleryImages = [
  { src: "/images/mobiliario/periqueras-madera-acolchada-evento.avif", alt: "Periquera acrílico transparente junto a barra LED en evento CDMX" },
  { src: "/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif", alt: "Periqueras acrílico en boda moderna con decoración minimalista" },
  { src: "/images/mobiliario/mesas-cocktail-negras-periqueras-evento.avif", alt: "Detalle estructura acrílico transparente periquera para eventos" },
  { src: "/images/mobiliario/periqueras-madera-acolchada-evento.avif", alt: "Periqueras de acrílico en salón iluminado con barra de cócteles" },
  { src: "/images/mobiliario/periqueras-kit-coctel-completo.avif", alt: "Periquera acrílico transparente en evento exterior de noche" },
  { src: "/images/mobiliario/periqueras-kit-coctel-completo.avif", alt: "Conjunto periqueras acrílico con barra acrílico iluminado LED" },
];

const faqs = [
  {
    question: "¿Cuál es la altura de la periquera de acrílico y para qué tipo de barra aplica?",
    answer: "La periquera de acrílico tiene <strong>altura de asiento de 75 cm</strong>, compatible con barras de 110 cm de altura — el estándar en eventos. La altura total es de 103 cm. El asiento circular de acrílico mide 38 cm de diámetro y el reposapiés es de acero inoxidable pulido. Combina perfectamente con nuestra <a href='/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/'>barra acrílico LED</a> y con barras de acero inoxidable para una estética completamente transparente y moderna."
  },
  {
    question: "¿El acrílico es resistente al peso y a uso continuo en eventos?",
    answer: "Sí. El cuerpo está fabricado en <strong>acrílico de 10 mm de espesor</strong> con refuerzos internos de acero — soporta hasta <strong>120 kg de carga</strong> sin deformarse. El acrílico es inmune a la humedad, alcohol y la mayoría de líquidos comunes en eventos. No amarilla con el tiempo porque usamos acrílico cristal de grado premium, no PVC. El acabado es perfectamente liso, fácil de limpiar entre usos."
  },
  {
    question: "¿Cuántas periqueras de acrílico necesito para mi barra?",
    answer: "La proporción estándar es <strong>1 periquera por cada 65 cm de barra</strong>. Barra de 2m: 3 piezas. Barra de 3m: 4-5 piezas. Para zonas de cócteles sin barra fija, las periqueras se agrupan en tríos alrededor de mesas altas de 110 cm. Si combinas periqueras de acrílico con <a href='/servicios/mobiliario/barras/periqueras/metal/'>periqueras de metal</a> en el mismo evento, te asesoramos sobre la distribución para que no choquen estéticamente."
  },
  {
    question: "¿Tiene asiento acolchado o es solo acrílico?",
    answer: "La versión estándar tiene el <strong>asiento de acrílico pulido sin cojín</strong> — esto mantiene la estética completamente transparente que hace especial a esta periquera. Si necesitas mayor comodidad para eventos de más de 4 horas, ofrecemos la opción con <strong>cojín circular de cuero sintético blanco o negro</strong> que se adhiere magnéticamente y puede retirarse para limpiar. El cojín tiene cargo adicional de $25 por pieza. Pregunta disponibilidad al cotizar."
  },
  {
    question: "¿Con cuánta anticipación debo reservar las periqueras de acrílico?",
    answer: "Las periqueras de acrílico son las más solicitadas para bodas y eventos corporativos en temporada alta (octubre-febrero). Recomendamos reservar con <strong>3-5 semanas de anticipación</strong>. Para temporada regular, con 2 semanas es suficiente. Un anticipo del 30% bloquea la fecha. Confirmamos disponibilidad por WhatsApp al instante en horario de atención."
  },
];

const specs = [
  { label: "Material principal", value: "Acrílico cristal premium 10 mm con refuerzos de acero inoxidable" },
  { label: "Altura de asiento", value: "75 cm (compatible con barras de 110 cm)" },
  { label: "Altura total", value: "103 cm" },
  { label: "Diámetro de asiento", value: "38 cm" },
  { label: "Capacidad de carga", value: "120 kg" },
  { label: "Reposapiés", value: "Acero inoxidable pulido — circular, a 25 cm del piso" },
  { label: "Acabado", value: "Transparente liso — sin burbuja, sin amarillamiento" },
  { label: "Opción de cojín", value: "Cuero sintético blanco o negro (cargo adicional $25/pieza)" },
  { label: "Limpieza", value: "Fácil con paño húmedo — resistente a alcohol y derrames" },
  { label: "Precio desde", value: "$200 por pieza por evento (incluye entrega y montaje)" },
];

const reviews = [
  { author: "Paola Sánchez", text: "Las periqueras de acrílico con la barra LED fueron el combo perfecto para nuestra boda moderna. Parecían flotar en el espacio. Varios invitados preguntaron de dónde las habíamos rentado. El servicio de EVENTECH fue impecable.", rating: 5, date: "2025-12-06" },
  { author: "Roberto Garza", text: "Las usamos en una gala corporativa junto a barras de acero inoxidable. El efecto era de hotel de lujo. Llegaron en perfectas condiciones, sin rayones ni marcas. Muy profesionales.", rating: 5, date: "2025-10-18" },
  { author: "Fernanda Ríos", text: "Para mi cumpleaños en salón moderno, las periqueras de acrílico le daban ese toque especial. Cómodas, elegantes y sin estorbar visualmente. Las recomiendo mucho.", rating: 5, date: "2025-09-27" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Periqueras Acrílico Transparente para Eventos CDMX",
    description: "Renta de periqueras de acrílico transparente para bodas y eventos en CDMX. Estructura cristal con reposapiés de acero inoxidable. Soporta 120 kg. Desde $200 por pieza.",
    url: "/servicios/mobiliario/barras/periqueras/acrilico/",
    priceRange: { min: 200, max: 400 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Periqueras", url: "/servicios/mobiliario/barras/periqueras/" },
    { name: "Acrílico Transparente", url: "/servicios/mobiliario/barras/periqueras/acrilico/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Madera Natural", href: "/servicios/mobiliario/barras/periqueras/madera/" },
  { name: "Metal Industrial", href: "/servicios/mobiliario/barras/periqueras/metal/" },
  { name: "Acrílico Transparente", href: null, active: true },
];

const sidebarRelated = [
  { name: "Barra Acrílico LED", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];
---

<PageLayout
  title="Renta Periqueras Acrílico Transparente CDMX"
  description="Renta periqueras de acrílico transparente para bodas y eventos en CDMX — estética moderna, cuerpo cristal con reposapiés inoxidable."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La periquera que hace desaparecer el mobiliario y solo deja el ambiente"
    title='Periqueras <span class="highlight">Acrílico Transparente</span> — Renta en CDMX'
    subtitle="Periquera en acrílico cristal de 10 mm con reposapiés de acero inoxidable. Estética completamente transparente que se adapta a cualquier decoración sin competir con ella. Ideal para bodas modernas, eventos corporativos y venues con iluminación LED."
    primaryCTA={{ label: "Cotizar periqueras acrílico", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar las periqueras de acrílico transparente para mi evento` }}
    cards={[
      {
        title: "Transparencia total que hace que tu decoración sea el centro de atención",
        content: "La <strong>periquera de acrílico transparente</strong> es el mobiliario que desaparece para que solo brille la decoración. Sin estructura metálica visible, sin madera que compita con las flores, sin color que choque con la paleta del evento. El cuerpo de <strong>acrílico cristal de 10 mm con refuerzos de acero</strong> garantiza resistencia total — hasta 120 kg — sin sacrificar un milímetro de elegancia. El reposapiés circular de acero inoxidable pulido es el único detalle metálico visible, y complementa perfectamente cualquier barra moderna.",
      },
      {
        title: "La pareja perfecta de la barra acrílico LED — crea zonas bar que parecen flotar",
        content: "Cuando combinas las periqueras de acrílico con nuestra <a href='/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/'><strong>barra acrílico LED</strong></a>, el resultado es una zona bar que parece levitar. La iluminación atraviesa la barra y se refleja en las periqueras creando un efecto de luz difusa que transforma el ambiente. Disponibles desde <strong>$200 por pieza</strong> con entrega y recogida incluidas. Cotiza en menos de 30 minutos por WhatsApp.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Periqueras de acrílico que desaparecen del escenario — solo queda la elegancia de tu evento"
    subheadline="Desde $200/pieza · Cuerpo cristal + acero inoxidable · Entrega y recogida incluidas · CDMX y EdoMex"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes de Periqueras</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Periqueras de acrílico para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar las periqueras de acrílico transparente para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Periqueras Acrílico en Eventos Reales</h2>
            <p class="section__subtitle">Bodas modernas, galas corporativas y eventos de cócteles en CDMX y Estado de México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Periquera Acrílico Transparente</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la periquera de acrílico es la favorita en eventos modernos y bodas minimalistas?"
    headingId="descripcion-heading"
    badge="Acrílico cristal de grado premium — no amarilla, no se raya fácil"
    tags={["Acrílico Transparente", "Bodas Modernas", "Eventos Corporativos", "Cócteles"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La razón es simple: <strong>el acrílico transparente no compite con nada</strong>. En una boda donde cada detalle decorativo fue cuidadosamente seleccionado — el color de las flores, la tela del mantel, la temperatura de la iluminación — lo último que quieres es un mueble que distraiga la vista. La periquera de acrílico se funde con el ambiente y deja que la decoración sea la protagonista.</p>
      <p class="showcase__text">El material de <strong>acrílico cristal de 10 mm</strong> tiene la resistencia del vidrio templado sin el peso ni el riesgo de rotura. Los refuerzos internos de acero garantizan que soporte hasta 120 kg sin ceder. El reposapiés de <strong>acero inoxidable pulido</strong> añade un toque metálico elegante que complementa cualquier barra de metal o acrílico.</p>
      <p class="showcase__text">Las combinamos frecuentemente con la <strong>barra acrílico LED</strong> para crear zonas bar de impacto visual total, con los <a href='/servicios/mobiliario/barras/accesorios-decorativos/portavelas/'>portavelas de cristal</a> sobre la barra y los <a href='/servicios/mobiliario/barras/accesorios-decorativos/marcos/'>marcos decorativos</a> como señalización del menú de cócteles.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/periqueras-kit-coctel-completo.avif" alt="Periqueras de acrílico transparente junto a barra LED en boda moderna CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-cocktail-periqueras-evento-corporativo.avif" alt="Detalle reposapiés acero inoxidable periquera acrílico" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesas-cocktail-negras-periqueras-evento.avif" alt="Periqueras acrílico en gala corporativa con iluminación" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Periqueras Acrílico Transparente</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre las Periqueras de Acrílico"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Resistencia, compatibilidad con barras y opciones de cojín. Aquí resolvemos las dudas más frecuentes antes de reservar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te respondemos al instante sobre disponibilidad y precios.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre las periqueras de acrílico transparente`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos cuántas piezas necesitas, la fecha y el venue — precio confirmado en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes de periqueras y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes de Periqueras</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa tu zona de bar:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
