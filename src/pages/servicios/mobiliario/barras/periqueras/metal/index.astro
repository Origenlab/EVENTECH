---
/**
 * ─── Periquera Metal Industrial — Página de Variante ───
 * Periquera de metal industrial estilo negro para eventos modernos y corporativos en CDMX.
 * Desde $180 por pieza.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { label: "Metal Industrial" },
];

const galleryImages = [
  { src: "/images/mobiliario/periquera-metal-industrial-evento-01.avif", alt: "Periquera metal industrial negro en evento corporativo CDMX" },
  { src: "/images/mobiliario/periquera-metal-industrial-barra-02.avif", alt: "Periqueras metal negro alrededor de barra industrial" },
  { src: "/images/mobiliario/periquera-metal-industrial-rooftop-03.avif", alt: "Periqueras industriales en rooftop evento de noche" },
  { src: "/images/mobiliario/periquera-metal-industrial-detalle-04.avif", alt: "Detalle periquera metal negro con asiento cuero negro" },
  { src: "/images/mobiliario/periquera-metal-industrial-loft-05.avif", alt: "Periqueras industriales en venue tipo loft CDMX" },
  { src: "/images/mobiliario/periquera-metal-industrial-boda-moderna-06.avif", alt: "Periqueras metal en boda de estilo contemporáneo" },
];

const faqs = [
  {
    question: "¿Cuál es el material y acabado exacto de la periquera industrial?",
    answer: "La periquera está fabricada en <strong>acero al carbón tubular con pintura epoxi negra mate</strong> — la misma técnica que se usa en mobiliario de restaurantes de diseño y bares de alto nivel. La pintura epoxi forma una película dura resistente a golpes y rayaduras. El asiento es en <strong>cuero sintético negro de alta durabilidad</strong> — fácil de limpiar con paño húmedo. La base tiene pies con protectores de goma para no rayar pisos de mármol, madera o porcelanato."
  },
  {
    question: "¿Con qué tipo de barra combina mejor la periquera de metal?",
    answer: "La periquera industrial combina perfectamente con la <a href='/servicios/mobiliario/barras/barras-bebidas/industrial/'>barra industrial metal+madera</a> — forman un conjunto totalmente coherente. También funciona muy bien con la <a href='/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/'>barra acrílico LED</a> en eventos donde se quiere un contraste entre negro sólido y luz. Para haciendas o bodas rústicas, las <a href='/servicios/mobiliario/barras/periqueras/madera/'>periqueras de madera</a> son la opción más adecuada."
  },
  {
    question: "¿La periquera de metal es estable en terrenos irregulares?",
    answer: "Sí. Los cuatro pies tienen <strong>niveladores ajustables</strong> que permiten compensar hasta 2 cm de desnivel sin que la periquera se tambalee. En jardines con pasto grueso, recomendamos colocar una base de madera o plástico bajo cada pie para mayor estabilidad. Si el evento es en terreno de tierra o grava, indícanoslo al cotizar y recomendamos la distribución más estable para tu venue."
  },
  {
    question: "¿Cuánto peso soporta la periquera de metal industrial?",
    answer: "La periquera soporta <strong>150 kg de carga estática</strong> — muy por encima del uso típico. La estructura tubular de acero con soldadura continua es más robusta que la mayoría de periqueras de diseño importadas. No tiene partes plásticas en la estructura — todo el cuerpo es metal. El asiento de cuero está cosido con hilo industrial y pegado con adhesivo estructural para que no se desprenda aunque alguien se siente con fuerza."
  },
  {
    question: "¿Cuánto cuesta rentar periqueras de metal para 20 personas?",
    answer: "Para 20 periqueras de metal industrial, el costo es <strong>$3,600</strong> (20 × $180). En lotes de 20 o más piezas, el precio se mantiene en $180/pieza sin descuento por volumen adicional, ya que el material y acabado tienen mayor costo base que las periqueras de madera. Si combinas con la renta de la barra industrial, pregúntanos por el <strong>precio de paquete integrado</strong> — barra + periqueras en un solo pedido con descuento."
  },
];

const specs = [
  { label: "Estructura", value: "Acero al carbón tubular — pintura epoxi negra mate" },
  { label: "Asiento", value: "Cuero sintético negro alta durabilidad" },
  { label: "Altura de asiento", value: "75 cm (para barras de 110 cm)" },
  { label: "Altura total", value: "100 cm (sin respaldo alto)" },
  { label: "Diámetro asiento", value: "38 cm" },
  { label: "Niveladores", value: "Sí — ajustables ±2cm" },
  { label: "Pies protectores", value: "Goma antideslizante — no raya pisos" },
  { label: "Capacidad de carga", value: "150 kg por pieza" },
  { label: "Cantidad mínima", value: "3 periqueras" },
  { label: "Precio desde", value: "$180 por pieza (incluye montaje y desmontaje)" },
];

const reviews = [
  { author: "Alejandro Flores", text: "Rentamos 15 periqueras de metal para la zona VIP de nuestro evento corporativo. Con la barra industrial hacían un conjunto perfecto. El acabado negro mate era exactamente lo que necesitábamos para el look de la marca.", rating: 5, date: "2025-12-05" },
  { author: "Carmen Vega", text: "Boda en rooftop con paleta negro+blanco. Las periqueras industriales alrededor de las mesas altas blancas crearon un contraste espectacular. Robustas, estables y llegaron perfectas.", rating: 5, date: "2025-11-18" },
  { author: "David Herrera", text: "Para el lanzamiento en venue tipo loft, las periqueras industriales completaban la estética perfectamente. El cuero negro limpiaba fácilmente con un paño — sin problema por los derrames de cóctel.", rating: 5, date: "2025-10-25" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Periqueras Metal Industrial para Eventos CDMX",
    description: "Periqueras de metal industrial negro para eventos corporativos y bodas modernas en CDMX. Acero epoxi + cuero negro. 150kg. Desde $180/pieza.",
    url: "/servicios/mobiliario/barras/periqueras/metal/",
    priceRange: { min: 180, max: 200 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Periqueras", url: "/servicios/mobiliario/barras/periqueras/" },
    { name: "Metal Industrial", url: "/servicios/mobiliario/barras/periqueras/metal/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Periquera Madera", href: "/servicios/mobiliario/barras/periqueras/madera/" },
  { name: "Periquera Metal Industrial", href: null, active: true },
  { name: "Periquera Acrílico", href: "/servicios/mobiliario/barras/periqueras/acrilico/" },
];

const sidebarRelated = [
  { name: "Barra Industrial Metal+Madera", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
  { name: "Barra Acrílico LED", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];
---

<PageLayout
  title="Renta Periqueras Metal Industrial"
  description="Renta periqueras de metal industrial negro en CDMX — acero epoxi + cuero negro, 150kg, para eventos corporativos y bodas contemporáneas. Desde $180/pieza."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="El asiento que define el estilo de los eventos corporativos de alto nivel"
    title='Periqueras <span class="highlight">Metal Industrial</span> — Renta en CDMX'
    subtitle="Estructura tubular de acero con pintura epoxi negra mate y asiento de cuero sintético negro. Resistencia de 150 kg, niveladores ajustables y pies con protectores para cualquier tipo de piso. La periquera que siempre combina en eventos donde el negro es el protagonista."
    primaryCTA={{ label: "Cotizar periqueras de metal", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de metal industrial para mi evento` }}
    cards={[
      {
        title: "Acero al carbón + cuero negro: la combinación que no envejece en diseño de eventos",
        content: "La <strong>periquera de metal industrial</strong> funciona porque usa los mismos materiales que llevan 30 años en los bares de diseño más reconocidos del mundo — y que siguen siendo referencia porque son honestos y funcionales. El acero con pintura epoxi negra mata no necesita mantenimiento especial, no se descascara, no se oxida. El cuero sintético negro es impermeable, resistente a la abrasión y se limpia con paño húmedo en segundos.",
      },
      {
        title: "150 kg de capacidad, niveladores incluidos, desde $180 con montaje",
        content: "El diseño estructural de la periquera industrial está sobre-dimensionado para uso en eventos: <strong>150 kg de carga estática</strong>, soldadura continua en todas las uniones, y pies con protectores de goma que no dejan marca en ningún tipo de piso. Los niveladores ajustables compensan hasta 2 cm de desnivel — suficiente para la mayoría de venues con pisos irregulares o terraza. <strong>Desde $180 por pieza</strong> con entrega, colocación y recogida al final del evento.",
      },
    ]}
  />

  <CTABanner
    headline="Periqueras de metal que hacen que tu evento corporativo se vea producido profesionalmente"
    subheadline="Desde $180/pieza · Acero epoxi + cuero negro · 150kg · Paquete con barra industrial disponible"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Periqueras</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Periqueras de metal para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de metal industrial para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Periqueras Metal Industrial en Eventos Reales</h2>
            <p class="section__subtitle">Eventos corporativos, rooftops y bodas contemporáneas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Periquera Metal Industrial</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la periquera industrial de metal es la más solicitada para eventos premium?"
    headingId="descripcion-heading"
    badge="El mismo material que usan los mejores bares de diseño del mundo"
    tags={["Metal Negro Mate", "Cuero Sintético", "Corporativo Premium", "Rooftops y Lofts"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La periquera industrial tiene una ventaja que ningún otro acabado puede replicar: <strong>el negro mate del metal no envejece</strong>. No tiene temporada ni tendencia — hace 10 años se veía igual de bien en un bar de diseño, y en 10 años seguirá siendo la referencia en mobiliario de eventos de alto nivel.</p>
      <p class="showcase__text">El cuero sintético negro del asiento no es solo una elección estética — es una <strong>decisión de mantenimiento</strong>. En un evento de varias horas con bebidas servidas, el cuero se limpia en segundos con un paño húmedo. No absorbe líquidos, no deja manchas permanentes, no requiere secado especial.</p>
      <p class="showcase__text">Combinamos estas periqueras con la <strong>barra industrial metal+madera</strong> y las mesas altas negras para crear configuraciones de bar corporativo que los directivos de empresa fotografían y comparten internamente como referencia para futuros eventos.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/periquera-metal-showcase-main.avif" alt="Periqueras metal industrial negro en evento corporativo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/periquera-metal-showcase-02.avif" alt="Detalle asiento cuero negro periquera industrial" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/periquera-metal-showcase-03.avif" alt="Periqueras de metal con barra industrial en evento de lujo" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Periqueras Metal Industrial</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Periqueras Metal Industrial"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Materiales, compatibilidad con barras, resistencia y precios. Todo lo que necesitas saber antes de confirmar las periqueras para tu evento.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te asesoramos sobre combinación de barras y periqueras para tu evento.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre las periqueras de metal industrial`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Paquete bar industrial</h3>
                  <p class="faq-sidebar-card__text">Barra industrial + periqueras de metal en un solo pedido — descuento de paquete disponible.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Solicitar en formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes periqueras y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Periqueras</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Periqueras de metal para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de metal industrial para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
