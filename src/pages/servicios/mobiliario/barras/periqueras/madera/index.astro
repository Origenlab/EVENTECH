---
/**
 * ─── Periquera de Madera — Página de Variante ───
 * Periquera de madera natural para eventos, bodas y celebraciones en CDMX.
 * Desde $150 por pieza.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { label: "Madera" },
];

const galleryImages = [
  { src: "/images/mobiliario/periquera-madera-boda-hacienda-01.avif", alt: "Periquera de madera en boda hacienda CDMX" },
  { src: "/images/mobiliario/periquera-madera-barra-exterior-02.avif", alt: "Periqueras de madera alrededor de barra rústica" },
  { src: "/images/mobiliario/periquera-madera-detalle-03.avif", alt: "Detalle periquera madera natural con asiento tapizado" },
  { src: "/images/mobiliario/periquera-madera-evento-campestre-04.avif", alt: "Periqueras de madera en evento campestre jardín" },
  { src: "/images/mobiliario/periquera-madera-bar-montaje-05.avif", alt: "Montaje periqueras madera alrededor de barra de bebidas" },
  { src: "/images/mobiliario/periquera-madera-comedor-alto-06.avif", alt: "Periqueras de madera en comedor de alto nivel evento" },
];

const faqs = [
  {
    question: "¿Cuáles son las dimensiones de la periquera de madera y para qué altura de barra aplica?",
    answer: "La periquera tiene una <strong>altura de asiento de 75 cm</strong>, diseñada para barras y mesas altas de 110 cm — la altura estándar de barras de eventos. La altura total con respaldo es 105 cm. El asiento circular tiene 35 cm de diámetro, y el reposapiés metálico queda a 25 cm del piso. Es la periquera que combina directamente con nuestra <a href='/servicios/mobiliario/barras/barras-bebidas/madera-rustica/'>barra de madera rústica</a> por estética y proporción."
  },
  {
    question: "¿La periquera de madera tiene asiento acolchado?",
    answer: "Sí. El asiento incluye un <strong>cojín circular de espuma de alta densidad</strong> recubierto en tela de lino natural — resistente a derrames leves y fácil de limpiar. La tela de lino es el acabado que mejor combina con la estética rústica de la madera. Para eventos donde se necesite un acabado más elegante, también ofrecemos la versión con <strong>asiento en cuero sintético negro o beige</strong> con cargo adicional de $20 por pieza."
  },
  {
    question: "¿Cuántas periqueras necesito para mi barra?",
    answer: "La regla general es <strong>1 periquera por cada 60-70 cm de barra</strong>. Para una barra de 2 metros: 3 periqueras. Para una barra de 3 metros: 4-5 periqueras. Esto asegura que los invitados puedan sentarse cómodamente sin estar muy juntos. Si las periqueras son para una zona de cócteles independiente sin barra fija, puedes ponerlas en grupos de 3-4 alrededor de mesas altas. Te asesoramos sobre la distribución ideal según tu venue."
  },
  {
    question: "¿Se puede combinar la periquera de madera con la barra acrílico LED o la industrial?",
    answer: "Tecnicamente sí, pero en términos de diseño, la periquera de madera <strong>combina mejor con la barra rústica</strong> o cualquier setup con decoración natural. Para la barra acrílico LED, las <a href='/servicios/mobiliario/barras/periqueras/acrilico/'>periqueras de acrílico</a> crean un conjunto visualmente coherente. Para la barra industrial, las <a href='/servicios/mobiliario/barras/periqueras/metal/'>periqueras de metal</a> son la opción más consistente. Podemos mostrarte ejemplos de cada combinación por WhatsApp."
  },
  {
    question: "¿Cuánto cuesta rentar 10 periqueras de madera?",
    answer: "10 periqueras de madera tienen un costo de <strong>$1,500</strong> (10 × $150). En lotes de 20 o más piezas, el precio baja a $130 por pieza. El precio incluye entrega, montaje y desmontaje en CDMX. Si las combinas con la renta de la barra rústica, el paquete completo (barra 2m + 3 periqueras) tiene un precio especial — indícalo al cotizar y te hacemos un paquete integrado."
  },
];

const specs = [
  { label: "Material estructura", value: "Madera de fresno tratada — veta natural visible" },
  { label: "Asiento", value: "Cojín espuma alta densidad en tela lino natural" },
  { label: "Asiento alternativo", value: "Cuero sintético negro o beige (+$20/pieza)" },
  { label: "Altura de asiento", value: "75 cm (para barras de 110 cm)" },
  { label: "Altura total", value: "105 cm (con respaldo)" },
  { label: "Diámetro asiento", value: "35 cm" },
  { label: "Reposapiés", value: "Aro metálico a 25 cm del piso" },
  { label: "Capacidad de carga", value: "120 kg por pieza" },
  { label: "Cantidad mínima", value: "3 periqueras" },
  { label: "Precio desde", value: "$150 por pieza (incluye montaje y desmontaje)" },
];

const reviews = [
  { author: "Gabriela Montero", text: "Rentamos 8 periqueras de madera para la zona de bar de nuestra boda en hacienda. Combinaban perfecto con la barra rústica y con toda la decoración. El asiento de lino era muy cómodo para estar parado toda la noche.", rating: 5, date: "2025-11-10" },
  { author: "Roberto Sánchez", text: "Para el cóctel de bienvenida de nuestra convención, las periqueras de madera alrededor de las mesas altas crearon un ambiente muy agradable. Robustas, bien acabadas y llegaron exactamente a tiempo.", rating: 5, date: "2025-10-05" },
  { author: "Jimena Ríos", text: "El precio es muy justo para la calidad. La madera se veía impecable, sin rayones ni manchas. El reposapiés metálico le da un toque más moderno que las periqueras totalmente de madera que he visto en otros lados.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Periqueras de Madera para Eventos CDMX",
    description: "Periqueras de madera natural para bodas rústicas y eventos en CDMX. Asiento lino natural o cuero. Altura 75cm. Desde $150 por pieza.",
    url: "/servicios/mobiliario/barras/periqueras/madera/",
    priceRange: { min: 150, max: 170 },
    reviews,
    ratingValue: 5,
    reviewCount: 41,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Periqueras", url: "/servicios/mobiliario/barras/periqueras/" },
    { name: "Madera", url: "/servicios/mobiliario/barras/periqueras/madera/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Periqueras", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Periquera Madera", href: null, active: true },
  { name: "Periquera Metal Industrial", href: "/servicios/mobiliario/barras/periqueras/metal/" },
  { name: "Periquera Acrílico", href: "/servicios/mobiliario/barras/periqueras/acrilico/" },
];

const sidebarRelated = [
  { name: "Barra Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
];
---

<PageLayout
  title="Renta Periqueras de Madera para Bodas"
  description="Renta periqueras de madera en CDMX — asiento lino natural o cuero, altura 75cm para barras estándar. Perfectas para bodas rústicas y eventos campestres."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La periquera que completa tu zona de bar rústico en CDMX"
    title='Periqueras de <span class="highlight">Madera</span> — Renta en CDMX'
    subtitle="Periquera en madera de fresno con asiento de lino natural y reposapiés metálico. Altura de 75 cm para barras estándar de 110 cm. La complemento perfecto para barras rústicas, zonas de cóctel en hacienda y eventos campestres con estilo."
    primaryCTA={{ label: "Cotizar periqueras de madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de madera para mi evento` }}
    cards={[
      {
        title: "Madera de fresno + lino natural: la combinación que funciona en cualquier boda rústica",
        content: "La <strong>periquera de madera</strong> con asiento de lino es el mobiliario que los planners de bodas rústicas siempre piden porque <em>combina sin esfuerzo</em>: con flores silvestres, con manteles en lino, con centros de mesa naturales. La madera de fresno tiene una veta fina y elegante — más sofisticada que el pino y con un color natural más cálido. El aro metálico del reposapiés añade el contraste contemporáneo que evita que la pieza se vea anticuada.",
      },
      {
        title: "3 periqueras desde $450 — el pack mínimo para barra de 2 metros",
        content: "La renta de periqueras de madera comienza desde <strong>$150 por pieza</strong>, con un mínimo de 3 piezas. Para una barra de 2 metros, recomendamos 3 periqueras — total $450. Para barra de 3 metros, 4-5 periqueras — $600-$750. En lotes de 20+, el precio baja a $130/pieza. Todos los precios incluyen entrega, montaje y desmontaje. <strong>Combina la renta de barra + periqueras</strong> en un solo pedido para facilitar la coordinación logística.",
      },
    ]}
  />

  <CTABanner
    headline="Periqueras de madera que complementan tu boda rústica sin esfuerzo — cotiza sin compromiso"
    subheadline="Desde $150/pieza · Asiento lino natural · 3 piezas mínimo · Montaje incluido"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Periqueras</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Periqueras de madera para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Periqueras de Madera en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en haciendas, eventos al aire libre y cócteles en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Periquera de Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué las periqueras de madera son el mobiliario más versátil para zonas de bar?"
    headingId="descripcion-heading"
    badge="Lino natural + fresno: el dúo que define las bodas rústicas de CDMX"
    tags={["Madera Fresno", "Lino Natural", "Bodas Rústicas", "Eventos Campestres"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La periquera de madera tiene una ventaja sobre cualquier otro material: <strong>no necesita que todo lo demás sea perfecto para verse bien</strong>. En una hacienda con paredes irregulares, en un jardín con pasto, en un salón con iluminación cálida — la madera natural siempre se ve correcta. Es un material que suma sin competir.</p>
      <p class="showcase__text">El asiento de <strong>lino natural</strong> es la elección inteligente para eventos donde se va a estar parado por horas: absorbe menos calor que los sintéticos, tiene una textura que no se percibe como fría al tacto, y el color beige natural coordina con prácticamente cualquier paleta de boda.</p>
      <p class="showcase__text">Cuando combinamos las periqueras de madera con la barra rústica y los portavelas de nuestro catálogo de <strong>accesorios decorativos</strong>, el resultado es una zona de bar completa y coherente que parece diseñada por un wedding planner de alto nivel — sin serlo.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/periquera-madera-showcase-main.avif" alt="Periqueras de madera alrededor de barra rústica en boda hacienda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/periquera-madera-showcase-02.avif" alt="Detalle asiento lino natural periquera de madera" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/periquera-madera-showcase-03.avif" alt="Periqueras de madera en zona cóctel evento campestre" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Periqueras de Madera</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre Periqueras de Madera"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Dimensiones exactas, cantidad recomendada, opciones de asiento y precios por volumen. Todo lo que necesitas saber antes de confirmar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te asesoramos sobre la cantidad y distribución ideal para tu venue.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre las periqueras de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Paquete barra + periqueras</h3>
                  <p class="faq-sidebar-card__text">Renta la barra rústica y las periqueras juntas en un solo pedido — precio especial de paquete disponible.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Solicitar en formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes periqueras y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Periqueras</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Periqueras de madera para tu evento en CDMX</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras de madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
