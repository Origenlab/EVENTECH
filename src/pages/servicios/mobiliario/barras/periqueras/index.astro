---
/**
 * ─── Periqueras y Bancos Altos — Pagina de Producto (Nivel 4) ───
 * Bancos altos de 75 cm en madera acolchada, metal cromado y
 * acrilico Ghost para zonas de coctel y barras en eventos.
 *
 * Jerarquia: Servicios > Mobiliario > Barras > Periqueras y Bancos
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Periqueras y Bancos" },
];

const faqs = [
  { question: "¿Cuántas periqueras necesito por mesa cocktail?", answer: 'La proporción estándar es <strong>3 a 4 bancos por mesa cocktail</strong>. Para una zona de cóctel de 50 personas, sugerimos 8-10 mesas cocktail con 30-40 periqueras. Sin embargo, en eventos de networking donde los invitados se mueven frecuentemente, puedes reducir a 2-3 por mesa.' },
  { question: "¿Los bancos de madera tienen asiento acolchado?", answer: 'Sí. Todos nuestros bancos de madera incluyen <strong>asiento tapizado acolchado</strong> en tela o cuerina. Los colores de tapizado disponibles son: blanco, negro, gris, beige, azul marino y burdeos. Para colores especiales, consulta con 2 semanas de anticipación.' },
  { question: "¿La periquera de metal es giratoria?", answer: 'Sí. El banco de metal cromado cuenta con <strong>base giratoria 360°</strong> con sistema de bloqueo opcional. El mecanismo giratorio facilita las conversaciones y el movimiento en zonas de networking. Incluye reposapiés cromado a altura ergonómica.' },
  { question: "¿Las periqueras Ghost se rayan?", answer: 'El policarbonato de nuestras periqueras Ghost es de <strong>alta resistencia al rayado</strong>. Sin embargo, recomendamos no arrastrarlas sobre superficies abrasivas. Cada pieza se pule e inspecciona antes de cada entrega. Son las mismas periqueras que complementan nuestras <a href="/servicios/mobiliario/sillas/ghost/">sillas Ghost</a>.' },
  { question: "¿Puedo combinar estilos de periquera en un mismo evento?", answer: 'Sí. Muchos clientes usan <strong>madera en la zona de cóctel principal, metal en el área VIP/corporativa y Ghost en espacios modernos</strong>. Lo importante es mantener coherencia en cada zona. Nuestros asesores te ayudan con la distribución.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos <strong>2 semanas de anticipación</strong>. Para eventos grandes (50+ periqueras) o kits de zona cóctel completos, reserva con <strong>3 a 4 semanas</strong>. Las periqueras Ghost son las más solicitadas y se agotan primero en temporada alta.' },
];

const specs = [
  { label: "Materiales", value: "Madera acolchada, Metal cromado, Acrílico Ghost" },
  { label: "Altura", value: "75 cm (compatible con mesas cocktail 110 cm)" },
  { label: "Madera", value: "Pino barnizado con asiento tapizado en tela o cuerina" },
  { label: "Metal", value: "Acero cromado con base giratoria 360°" },
  { label: "Acrílico", value: "Policarbonato transparente estilo Ghost" },
  { label: "Reposapiés", value: "Cromado incluido en todos los modelos" },
  { label: "Base", value: "Antideslizante con protector de piso" },
  { label: "Resistencia Madera", value: "120 kg" },
  { label: "Resistencia Metal/Acrílico", value: "130 kg / 110 kg" },
  { label: "Proporción", value: "3-4 bancos por mesa cocktail" },
];

const sidebarNav = [
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Mesas de Postres", href: "/servicios/mobiliario/barras/postres/" },
  { name: "Periqueras y Bancos", href: null, active: true },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
];

const sidebarRelated = [
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Sillas de Diseño", href: "/servicios/mobiliario/sillas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Ricardo Fuentes", text: "Rentamos 40 periqueras de metal cromado para nuestra feria comercial. El diseño giratorio fue perfecto para los stands — los visitantes podían girar para ver las presentaciones sin levantarse. Montaje profesional y puntual.", rating: 5, date: "2025-11-18" },
  { author: "Paola Medina", text: "Las periqueras de madera acolchada quedaron hermosas en nuestra boda. El acabado natural combinó perfecto con las barras y mesas de madera. Los invitados las amaron porque eran super cómodas. Excelente servicio.", rating: 5, date: "2025-10-05" },
  { author: "Andrés Quiroz", text: "Kit de zona cóctel con periqueras Ghost para el lanzamiento de nuestra marca. El resultado fue espectacular — la transparencia amplió el espacio y las fotos quedaron increíbles. Logística impecable.", rating: 5, date: "2025-08-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Periqueras y Bancos Altos para Eventos en CDMX",
    description: "Renta de periqueras y bancos altos de 75 cm en madera, metal cromado y acrílico Ghost para zonas de cóctel y barras en CDMX. Desde $45 por unidad. Montaje incluido.",
    url: "/servicios/mobiliario/barras/periqueras/",
    priceRange: { min: 45, max: 350 },
    reviews,
    ratingValue: 5,
    reviewCount: 189,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Periqueras y Bancos", url: "/servicios/mobiliario/barras/periqueras/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Periqueras y Bancos Altos para Eventos en CDMX"
  description="Renta de periqueras y bancos altos de 75 cm en madera, metal cromado y acrílico Ghost para zonas de cóctel y barras en CDMX. Desde $45 por unidad. Montaje incluido."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El complemento perfecto para zonas de cóctel"
    title='Renta de <span class="highlight">Periqueras y Bancos Altos</span> para Eventos en CDMX'
    subtitle="Bancos altos de 75 cm en 3 materiales: madera acolchada, metal cromado giratorio y acrílico transparente Ghost. Diseñados para mesas cocktail y barras de bebidas. Reposapiés cromado y base antideslizante. Montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tus periqueras", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar periqueras para mi evento` }}
    cards={[
      {
        title: "Tres materiales premium: madera, metal cromado y acrílico Ghost",
        content: "<strong>Renta de periqueras y bancos altos</strong> con la mejor selección para zonas de cóctel en CDMX. Bancos de <strong>madera de pino acolchada</strong> con asiento tapizado para bodas rústicas. <strong>Metal cromado</strong> con base giratoria 360° para corporativos y ferias. <strong>Acrílico transparente</strong> estilo Ghost para eventos contemporáneos y minimalistas — todos de 75 cm de altura, diseñados para combinar con mesas cocktail de 110 cm.",
      },
      {
        title: "Reposapiés cromado, base antideslizante y entrega profesional",
        content: "<strong>Servicio integral de periqueras</strong> con reposapiés cromado de confort y base antideslizante para máxima estabilidad. Resistencia de 110 a 130 kg según modelo. Proporción recomendada: 3-4 bancos por mesa cocktail. Entrega puntual con distribución según layout aprobado y recolección incluida dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas periqueras para tu zona de cóctel?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con opciones de periqueras para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Barras y Complementos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas periqueras para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar periqueras para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Periqueras y Bancos Altos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Periquera Madera Acolchada -->
          <section class="section section--alt" aria-labelledby="madera-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas y eventos rústicos</span>
                <h2 class="showcase__title" id="madera-heading">Periquera Madera Acolchada</h2>
                <p class="showcase__subtitle">Banco alto de pino barnizado con asiento tapizado en tela o cuerina para máximo confort en zonas de cóctel.</p>
                <p class="showcase__text">La <strong>periquera de madera acolchada</strong> es la elección favorita para bodas rústicas, haciendas y eventos al aire libre en la Ciudad de México. Fabricada en <strong>pino barnizado</strong> con acabados disponibles en natural, nogal oscuro y blanco, cada banco combina la calidez de la madera con un asiento tapizado acolchado que garantiza confort durante largas horas de cóctel y conversación.</p>
                <p class="showcase__text">El <strong>asiento acolchado</strong> está disponible en tela o cuerina con colores blanco, negro, gris, beige, azul marino y burdeos. Combina perfectamente con nuestras <a href="/servicios/mobiliario/barras/barras-bebidas/">barras de madera artesanal</a> y mesas cocktail de madera para crear una zona de cóctel coherente y visualmente atractiva. Resistencia de <strong>120 kg</strong> con reposapiés cromado incluido.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Madera</span>
                  <span class="showcase__tag">Acolchada</span>
                  <span class="showcase__tag">Bodas</span>
                  <span class="showcase__tag">Rústico</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Periquera Madera
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
                    <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
                    <path d="M5 21v-2"/><path d="M19 21v-2"/>
                  </svg>
                  <span>Periquera Madera Acolchada</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Periquera Metal Cromado -->
          <section class="section section--alt" aria-labelledby="metal-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Corporativos y ferias</span>
                <h2 class="showcase__title" id="metal-heading">Periquera Metal Cromado</h2>
                <p class="showcase__subtitle">Base de acero cromado con asiento giratorio 360° tapizado en cuerina negra o blanca para zonas VIP y stands.</p>
                <p class="showcase__text">La <strong>periquera de metal cromado</strong> es la solución profesional para eventos corporativos, ferias comerciales y zonas de networking en CDMX. Su <strong>base de acero cromado con asiento giratorio 360°</strong> tapizado en cuerina negra o blanca combina funcionalidad con un diseño elegante que proyecta imagen profesional en stands de exposición, áreas VIP corporativas y zonas de cóctel ejecutivas.</p>
                <p class="showcase__text">La <strong>base giratoria</strong> facilita la conversación y el movimiento — los invitados pueden girar para ver presentaciones, interactuar con stands vecinos o simplemente moverse con comodidad sin levantarse. Incluye sistema de bloqueo opcional para fijar la posición. Resistencia de <strong>130 kg</strong> con reposapiés cromado a altura ergonómica. Diseño apilable para optimizar transporte y almacenamiento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Metal Cromado</span>
                  <span class="showcase__tag">Giratoria</span>
                  <span class="showcase__tag">Corporativos</span>
                  <span class="showcase__tag">Ferias</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Periquera Metal
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
                    <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
                    <path d="M5 21v-2"/><path d="M19 21v-2"/>
                  </svg>
                  <span>Periquera Metal Cromado</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Periquera Acrílico Ghost -->
          <section class="section section--alt" aria-labelledby="ghost-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Eventos contemporáneos</span>
                <h2 class="showcase__title" id="ghost-heading">Periquera Acrílico Ghost</h2>
                <p class="showcase__subtitle">Banco alto de policarbonato transparente estilo Ghost: amplitud visual sin obstruir la decoración.</p>
                <p class="showcase__text">La <strong>periquera acrílico Ghost</strong> es el complemento perfecto para eventos contemporáneos y minimalistas en CDMX. Fabricada en <strong>policarbonato transparente</strong> de alta resistencia, ofrece amplitud visual sin obstruir la decoración del espacio — cada pieza se integra elegantemente con cualquier estilo de montaje sin competir visualmente con los elementos decorativos del venue.</p>
                <p class="showcase__text">El complemento perfecto para <strong>barras de acrílico LED</strong> y mesas cocktail con fundas spandex. Resistente a UV para uso en exteriores bajo techo. Cada pieza se pule e inspecciona antes de cada entrega para garantizar transparencia impecable. Son las mismas periqueras que complementan nuestras <a href="/servicios/mobiliario/sillas/ghost/">sillas Ghost</a>. Resistencia de <strong>110 kg</strong> con reposapiés cromado incluido y base antideslizante.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Acrílico Ghost</span>
                  <span class="showcase__tag">Transparente</span>
                  <span class="showcase__tag">Minimalista</span>
                  <span class="showcase__tag">Moderno</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Periquera Ghost
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
                    <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
                    <path d="M5 21v-2"/><path d="M19 21v-2"/>
                  </svg>
                  <span>Periquera Acrílico Ghost</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Zona Cóctel -->
          <section class="section section--alt" aria-labelledby="kit-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Paquete completo</span>
                <h2 class="showcase__title" id="kit-heading">Kit Zona Cóctel</h2>
                <p class="showcase__subtitle">Configuración completa: 4 mesas cocktail + 12-16 periqueras + 1 barra de bebidas, todo coordinado en el mismo estilo.</p>
                <p class="showcase__text">Nuestro <strong>kit de zona cóctel</strong> es la solución más práctica para crear un área de cóctel profesional lista para servir. Incluye <strong>4 mesas cocktail + 12 a 16 periqueras + 1 barra de bebidas</strong>, todo coordinado en el mismo estilo: madera para bodas rústicas, metal para corporativos o acrílico para eventos contemporáneos. La configuración completa elimina la complejidad de rentar piezas por separado.</p>
                <p class="showcase__text">Incluye <strong>distribución según venue</strong> — nuestro equipo de logística evalúa el plano del espacio y propone la disposición óptima de mesas, periqueras y barra para maximizar flujo de circulación y confort de los invitados. El kit se entrega montado y listo para usar, con recolección incluida al finalizar el evento. Combinación ideal con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para ambientar la zona de cóctel.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Kit Completo</span>
                  <span class="showcase__tag">Zona Cóctel</span>
                  <span class="showcase__tag">4 Mesas</span>
