---
/**
 * ─── Donas y Cupcakes — Página de Producto (Nivel 5) ───
 * La tendencia que conquista Instagram: muros de donas y torres de cupcakes.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Postres", href: "/servicios/mobiliario/barras/postres/" },
  { label: "Donas y Cupcakes" },
];

const faqs = [
  { question: "¿Qué incluye el muro de donas?", answer: 'El <strong>muro de donas</strong> incluye: estructura de madera o acrílico con ganchos para colgar 30-60 donas (según tamaño), donas gourmet glaseadas en sabores variados (chocolate, vainilla, fresa, maple, Nutella, red velvet), y decoración personalizable con flores, follaje o lettering. El muro se convierte en la pieza focal más fotografiada del evento.' },
  { question: "¿Puedo personalizar los colores de las donas y cupcakes?", answer: 'Sí, los <strong>colores son 100% personalizables</strong>. Las donas se glasean en los colores exactos de tu paleta (blush, dorado, terracota, azul marino, cualquier color). Los cupcakes llevan betún teñido y toppings coordinados. Necesitamos confirmar colores con 2 semanas de anticipación para garantizar el tono exacto.' },
  { question: "¿Cuántas donas/cupcakes necesito para mi evento?", answer: 'Calculamos <strong>1-1.5 piezas por invitado</strong> como postre complementario. Para 100 personas: 100-150 donas o cupcakes. Nuestro muro estándar acomoda 48 donas y es ideal para 80-120 personas. Para eventos más grandes, ofrecemos muros dobles o combinación muro de donas + torre de cupcakes.' },
  { question: "¿Las donas son de una marca específica o artesanales?", answer: 'Trabajamos con <strong>reposteros artesanales especializados</strong> en donas gourmet — no son de cadenas comerciales. Cada dona se hace el día anterior al evento con ingredientes premium. Sabores disponibles: chocolate belga, vainilla bourbon, maple bacon (sí, con tocino), Nutella, fresa natural, red velvet, matcha, y especiales de temporada.' },
  { question: "¿La torre de cupcakes incluye los cupcakes?", answer: 'Sí, el paquete incluye <strong>estructura torre + cupcakes decorados</strong>. Las torres acomodan 30-80 cupcakes según el tamaño (3-5 niveles). Cada cupcake lleva betún de alta calidad, decoración temática (flores de azúcar, sprinkles, fondant) y papel corrugado coordinado con tu paleta. También rentamos solo la estructura si prefieres usar tu repostero.' },
  { question: "¿Combinan bien para fotos de Instagram?", answer: 'Absolutamente — son el <strong>elemento más instagrameable</strong> de cualquier evento moderno. El muro de donas funciona como backdrop para selfies. La torre de cupcakes crea un punto focal vertical impresionante. Ofrecemos iluminación adicional (ring lights, Edison) para mejorar las fotos. También podemos agregar <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas</a> como "#BODA" o "LOVE" detrás del muro.' },
];

const specs = [
  { label: "Muro de donas", value: "Madera/acrílico, 30-60 donas" },
  { label: "Torre cupcakes", value: "3-5 niveles, 30-80 cupcakes" },
  { label: "Sabores donas", value: "8+ sabores gourmet" },
  { label: "Sabores cupcakes", value: "6+ sabores, betún premium" },
  { label: "Capacidad", value: "50-200 personas (según paquete)" },
  { label: "Personalización", value: "Colores, sabores, decoración" },
  { label: "Preparación", value: "Día anterior al evento" },
  { label: "Iluminación", value: "Ring light opcional" },
  { label: "Montaje", value: "2-3 horas antes" },
  { label: "Dimensiones muro", value: "1.5 x 1.2 metros aprox." },
];

const sidebarNav = [
  { name: "Mesa de Dulces (Candy Bar)", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
  { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
  { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
  { name: "Quesos y Embutidos", href: "/servicios/mobiliario/barras/postres/quesos-embutidos/" },
  { name: "Mesa de Snacks", href: "/servicios/mobiliario/barras/postres/mesa-snacks/" },
  { name: "Mesa de Botanas", href: "/servicios/mobiliario/barras/postres/mesa-botanas/" },
  { name: "Dulces Tradicionales", href: "/servicios/mobiliario/barras/postres/dulces-tradicionales/" },
  { name: "Donas y Cupcakes", href: null, active: true },
];

const sidebarRelated = [
  { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
  { name: "Letras Luminosas", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Guirnaldas Edison", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
];

const reviews = [
  { author: "Fernanda Ochoa", text: "El muro de donas fue el hit de nuestra boda. Las donas en tonos blush y dorado combinaban perfecto con la decoración. Todos los invitados se tomaron fotos frente al muro — fue increíble ver todas las historias de Instagram esa noche. Las donas estaban deliciosas, sobre todo las de Nutella.", rating: 5, date: "2025-11-30" },
  { author: "Daniela Pérez", text: "Para los XV de mi hija queríamos algo moderno y diferente. La torre de cupcakes con el muro de donas fue espectacular. Los cupcakes de red velvet y los de chocolate belga fueron los favoritos. El letrero luminoso 'XV' que agregamos completó el look perfectamente.", rating: 5, date: "2025-10-20" },
  { author: "Mariana González", text: "Contratamos el combo muro de donas + torre de cupcakes para un evento corporativo de lanzamiento de producto. La presentación era impecable, las fotos quedaron increíbles para nuestras redes, y los postres estaban riquísimos. Muy profesional todo el servicio.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Muro de Donas y Torre de Cupcakes en CDMX",
    description: "Muro de donas gourmet y torres de cupcakes decorados. La tendencia más instagrameable para bodas, XV años y eventos. Colores personalizables. Montaje incluido en CDMX.",
    url: "/servicios/mobiliario/barras/postres/donas-cupcakes/",
    priceRange: { min: 3500, max: 15000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Postres", url: "/servicios/mobiliario/barras/postres/" },
    { name: "Donas y Cupcakes", url: "/servicios/mobiliario/barras/postres/donas-cupcakes/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout title="Donas y Cupcakes — Renta para Eventos CDMX" description="Muro de donas gourmet y torres de cupcakes decorados. La tendencia más instagrameable. Colores personalizables. Montaje incluido en CDMX. Cotiza hoy." jsonLd={jsonLd}>
  <div class="container"><Breadcrumbs items={breadcrumbItems} /></div>

  <HeroPage badge="Tendencia Instagram" title='Renta de <span class="highlight">Muro de Donas y Torre de Cupcakes</span>' subtitle="El elemento más fotografiado de cualquier evento moderno. Donas gourmet glaseadas en colores personalizados colgando de un muro elegante. Torres de cupcakes decorados que roban todas las miradas. Puro eye-candy que conquista Instagram." primaryCTA={{ label: "Cotiza Donas y Cupcakes", href: "#reserva-heading" }} secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar muro de donas y cupcakes` }} cards={[{ title: "Muro de donas gourmet instagrameable", content: "<strong>Muro de donas</strong> en estructura de madera o acrílico con ganchos para 30-60 donas gourmet. Donas artesanales glaseadas en 8+ sabores (chocolate belga, vainilla bourbon, maple bacon, Nutella, fresa, red velvet, matcha). Colores 100% personalizables para coordinar con tu paleta — blush, dorado, terracota, cualquier tono. El muro funciona como backdrop perfecto para selfies y fotos de Instagram." },{ title: "Torres de cupcakes con decoración premium", content: "<strong>Torres de cupcakes</strong> de 3-5 niveles con 30-80 cupcakes decorados. Betún premium en sabores (vainilla, chocolate, cream cheese, dulce de leche), decoración temática con flores de azúcar, sprinkles coordinados, toppers personalizados. Papel corrugado en tu paleta de colores. Combinamos con <a href='/servicios/iluminacion/decorativa/letras-luminosas/'>letras luminosas</a> y <a href='/servicios/iluminacion/decorativa/fairy-lights/'>guirnaldas Edison</a> para máximo impacto visual." }]} />

  <CTABanner headline="¿Quieres el postre más instagrameable para tu evento?" subheadline="Muro de donas + torre de cupcakes — el combo que conquista redes sociales" primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }} secondaryCTA={{ label: "Llamar", href: `tel:${SITE.contact.phoneRaw}` }} />

  <section class="l4-mobile-nav" aria-label="Navegación"><div class="container"><div class="l4-sidebar--mobile"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}</ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Donas y cupcakes`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a><a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a></div></div></div></section>

  <div class="l4-content-section"><div class="container"><div class="l4-layout">
    <div class="l4-main">
      <section aria-labelledby="specs-heading"><div class="specs-table"><div class="specs-table__header"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg><h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Donas y Cupcakes</h2></div><div class="specs-table__body">{specs.map((spec) => (<div class="specs-table__row"><div class="specs-table__label">{spec.label}</div><div class="specs-table__value">{spec.value}</div></div>))}</div></div></section>

      <section class="section section--alt" aria-labelledby="muro-heading"><div class="showcase"><div class="showcase__content"><span class="showcase__badge">Backdrop perfecto</span><h2 class="showcase__title" id="muro-heading">Muro de Donas Gourmet</h2><p class="showcase__subtitle">30-60 donas artesanales colgando de un muro elegante — el backdrop más fotografiado.</p><p class="showcase__text">El <strong>muro de donas</strong> es la estrella de cualquier evento moderno. Estructura de madera con acabado natural o acrílico transparente, con ganchos de madera donde cuelgan las donas creando un patrón visual irresistible. Las <strong>donas gourmet</strong> se preparan el día anterior con ingredientes premium: chocolate belga, vainilla bourbon, maple con tocino crujiente, Nutella, fresa natural, red velvet, matcha japonés.</p><p class="showcase__text">Los <strong>glaseados son 100% personalizables</strong> — podemos crear cualquier color para combinar con tu paleta de decoración. Agregamos toppings coordinados: sprinkles, virutas de chocolate, frutas secas, flores comestibles. El muro funciona como <strong>backdrop perfecto para fotos</strong>: los invitados se paran frente a él, toman su dona y se fotografían. Las historias de Instagram se disparan.</p><div class="showcase__tags"><span class="showcase__tag">30-60 donas</span><span class="showcase__tag">8+ sabores</span><span class="showcase__tag">Colores custom</span><span class="showcase__tag">Backdrop fotos</span></div><a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Muro de Donas</a></div><div class="showcase__image"><img src="/images/mobiliario/muro-donas-gourmet-boda.avif" alt="Muro de donas gourmet glaseadas para boda" width="1200" height="686" loading="lazy" /></div></div></section>

      <section class="section section--alt" aria-labelledby="torre-heading"><div class="showcase"><div class="showcase__content"><span class="showcase__badge">Impacto vertical</span><h2 class="showcase__title" id="torre-heading">Torre de Cupcakes Decorados</h2><p class="showcase__subtitle">3-5 niveles de cupcakes con betún premium y decoración temática.</p><p class="showcase__text">La <strong>torre de cupcakes</strong> crea un punto focal vertical impresionante. Estructura de acrílico o metal con 3-5 niveles que acomodan 30-80 cupcakes según el tamaño. Cada cupcake lleva <strong>betún premium</strong> en sabores (vainilla, chocolate belga, cream cheese, dulce de leche) aplicado con manga profesional para un acabado de roseta perfecta.</p><p class="showcase__text">La <strong>decoración temática</strong> incluye: flores de azúcar comestibles, sprinkles y perlas coordinados, toppers personalizados (iniciales, números, figuras), papel corrugado en tu paleta de colores. Para XV años agregamos coronas y tiaras. Para bodas, flores naturales. Para corporativos, logo de la marca en fondant. Cada cupcake es una pequeña obra de arte.</p><div class="showcase__tags"><span class="showcase__tag">3-5 niveles</span><span class="showcase__tag">30-80 cupcakes</span><span class="showcase__tag">Betún premium</span><span class="showcase__tag">Decoración custom</span></div><a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Torre de Cupcakes</a></div><div class="showcase__image"><img src="/images/mobiliario/torre-cupcakes-decorados-xv.avif" alt="Torre de cupcakes decorados para XV años" width="1200" height="686" loading="lazy" /></div></div></section>

      <section class="section section--alt" aria-labelledby="combo-heading"><div class="showcase"><div class="showcase__content"><span class="showcase__badge">Máximo impacto</span><h2 class="showcase__title" id="combo-heading">Combo Muro + Torre + Iluminación</h2><p class="showcase__subtitle">La combinación ganadora para eventos que quieren dominar Instagram.</p><p class="showcase__text">El <strong>combo completo</strong> incluye: muro de donas como backdrop principal, torre de cupcakes como pieza focal, y elementos de iluminación que elevan todo el montaje. Agregamos <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas</a> personalizadas (LOVE, nombres, XV, hashtag del evento) que se iluminan detrás del muro.</p><p class="showcase__text"><a href="/servicios/iluminacion/decorativa/fairy-lights/">Guirnaldas Edison</a> enmarcando el área crean un efecto de warmth irresistible para fotos. Ring light profesional (incluido en paquete premium) garantiza que cada selfie salga perfectamente iluminada. El resultado: una <strong>estación de postres + photo booth</strong> que genera contenido viral para tu evento.</p><div class="showcase__tags"><span class="showcase__tag">Muro + Torre</span><span class="showcase__tag">Letras luminosas</span><span class="showcase__tag">Guirnaldas</span><span class="showcase__tag">Ring light</span></div><a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Combo Completo</a></div><div class="showcase__image"><img src="/images/mobiliario/combo-donas-cupcakes-iluminacion.avif" alt="Combo muro de donas, torre de cupcakes e iluminación" width="1200" height="686" loading="lazy" /></div></div></section>

      <section class="section" aria-labelledby="galeria-heading"><div class="container"><h2 class="section-header__title" id="galeria-heading">Galería — Donas y Cupcakes</h2><p class="section-header__description">Bodas, XV años y eventos corporativos en CDMX.</p><div class="galeria-grid"><img src="/images/mobiliario/muro-donas-boda-blush.avif" alt="Muro donas boda blush" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/torre-cupcakes-xv-rosa.avif" alt="Torre cupcakes XV años rosa" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/combo-donas-cupcakes-corporativo.avif" alt="Combo donas cupcakes corporativo" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/muro-donas-letras-luminosas.avif" alt="Muro donas con letras luminosas" width="600" height="343" loading="lazy" /></div></div></section>

      <section class="section" aria-labelledby="faq-heading"><SectionHeader id="faq-heading" title="Preguntas Frecuentes — Donas y Cupcakes" subtitle="Resolvemos tus dudas" description={["Todo sobre muros de donas y torres de cupcakes.", "Escríbenos por WhatsApp."]} /><div class="faq-layout"><div class="faq-list">{faqs.map((faq) => (<details class="faq-item"><summary class="faq-item__question"><span>{faq.question}</span><svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></summary><div class="faq-item__answer"><p set:html={faq.answer} /></div></details>))}</div><aside class="faq-sidebar"><div class="faq-sidebar-card faq-sidebar-card--accent"><h3 class="faq-sidebar-card__title">¿Dudas?</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Dudas donas y cupcakes`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">WhatsApp</a></div><div class="faq-sidebar-card"><h3 class="faq-sidebar-card__title">Llámanos</h3><a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a></div></aside></div></section>
    </div>

    <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Navegación"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}<li><div class="sidebar-nav__divider"></div></li><li class="sidebar-nav__item"><a href="/servicios/mobiliario/barras/postres/" class="sidebar-nav__back">&uarr; Postres</a></li></ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Donas y cupcakes`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0