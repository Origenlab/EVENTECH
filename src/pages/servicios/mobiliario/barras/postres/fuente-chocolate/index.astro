---
/**
 * ─── Fuente de Chocolate — Página de Producto (Nivel 4) ───
 * Fuentes de chocolate profesionales de 3 a 7 niveles para eventos.
 * Servicio completo con chocolate belga premium y estación de dipping.
 * Color accent: Amber #e17055 (nivel 4/5).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Postres", href: "/servicios/mobiliario/barras/postres/" },
  { label: "Fuente de Chocolate" },
];

const faqs = [
  { question: "¿Qué tamaños de fuente de chocolate ofrecen?", answer: 'Ofrecemos <strong>tres tamaños profesionales</strong>: <strong>Fuente de 3 niveles</strong> (27" de altura, ideal para 50-80 invitados), <strong>Fuente de 5 niveles</strong> (34" de altura, perfecta para 80-200 invitados), y <strong>Fuente de 7 niveles</strong> (44" de altura, para eventos de 200-500 invitados). Todas son fuentes comerciales de grado profesional con sistema de calentamiento integrado y flujo continuo de chocolate.' },
  { question: "¿Qué tipos de chocolate incluyen?", answer: 'Trabajamos exclusivamente con <strong>chocolate belga premium</strong> de Callebaut y Valrhona. Ofrecemos: <strong>Chocolate oscuro 70%</strong> (intenso, para paladares adultos), <strong>Chocolate con leche 40%</strong> (el favorito universal, cremoso y dulce), <strong>Chocolate blanco</strong> (suave, combina con frutos rojos), y <strong>Chocolate Ruby</strong> (el chocolate rosa, sin colorantes, sabor frutal). Puedes elegir uno o combinar varios — ofrecemos paquetes con hasta 3 tipos de chocolate simultáneo.' },
  { question: "¿Qué frutas y elementos para mojar incluyen?", answer: 'Nuestros paquetes incluyen una <strong>estación de dipping completa</strong> con: frutas frescas de temporada (fresas, plátano, uvas, piña, manzana, kiwi), malvaviscos jumbo, churros recién hechos (opción premium), pretzels de sal y dulces, brownies en cubos, galletas de mantequilla, y cake pops. Todo presentado en exhibidores elegantes con palillos de bambú y servilletas personalizables. Adaptamos la selección según la temporada y tu presupuesto.' },
  { question: "¿El servicio incluye personal atendiendo la fuente?", answer: 'Sí, <strong>todos nuestros paquetes incluyen un operador profesional</strong> durante la duración del servicio (típicamente 3-4 horas). El operador se encarga de: mantener el chocolate a temperatura óptima (45-48°C), reponer frutas y elementos de dipping, asegurar higiene y limpieza del área, asistir a invitados con necesidades especiales, y coordinar con el venue. Para eventos grandes (+200 invitados) asignamos 2 operadores.' },
  { question: "¿Cuánto tiempo antes llegan a montar?", answer: 'Llegamos <strong>2-3 horas antes</strong> del inicio del evento para: armar la estructura de la fuente, calentar el chocolate a temperatura óptima (requiere 45-60 min), preparar la estación de dipping con las frutas frescas cortadas, coordinar ubicación con el venue (necesitamos toma eléctrica cercana), y realizar pruebas de flujo del chocolate. El montaje es completamente discreto y estamos listos antes de que lleguen los primeros invitados.' },
  { question: "¿Qué pasa si hay invitados con alergias o restricciones?", answer: 'Tomamos las <strong>alergias muy en serio</strong>. El chocolate contiene leche y puede contener trazas de frutos secos (dependiendo de la marca). Para invitados con alergias severas, podemos: usar chocolate vegano certificado (sin lácteos), ofrecer una selección de frutas libre de alérgenos comunes, identificar claramente cada elemento con etiquetas. Necesitamos conocer las restricciones con 1 semana de anticipación para coordinar alternativas seguras.' },
  { question: "¿La fuente funciona en eventos al aire libre?", answer: '<strong>Sí, con consideraciones especiales</strong>. Las fuentes funcionan perfectamente en jardines y terrazas siempre que: haya acceso a electricidad (120V estándar), la temperatura ambiente no sea extrema (funcionamos bien entre 15-30°C), el área esté protegida de viento directo y lluvia. Para eventos en exterior extremadamente caluroso (+32°C), ajustamos la mezcla del chocolate para mantener consistencia óptima. Incluimos carpa/toldo sobre la fuente si es necesario.' },
  { question: "¿Cuánto chocolate necesito para mi evento?", answer: 'La regla general es <strong>100-150g de chocolate por persona</strong> para un servicio de 2-3 horas. Nuestros paquetes incluyen: <strong>Paquete Esencial (50-80 pers)</strong>: 8kg de chocolate, <strong>Paquete Estándar (80-150 pers)</strong>: 12kg de chocolate, <strong>Paquete Premium (150-250 pers)</strong>: 18kg de chocolate, <strong>Paquete Grand Gala (250-400 pers)</strong>: 25kg+ de chocolate. Siempre llevamos 20% extra como reserva sin costo adicional.' },
];

const specs = [
  { label: "Fuentes disponibles", value: "3, 5 y 7 niveles (27-44 pulgadas)" },
  { label: "Chocolate", value: "Belga premium Callebaut/Valrhona" },
  { label: "Variedades", value: "Oscuro 70%, leche 40%, blanco, ruby" },
  { label: "Capacidad", value: "50-400+ invitados (según paquete)" },
  { label: "Flujo continuo", value: "Sí, sistema comercial profesional" },
  { label: "Temperatura", value: "45-48°C controlada automáticamente" },
  { label: "Dipping incluido", value: "Frutas, malvaviscos, pretzels, brownies" },
  { label: "Operador", value: "Incluido (1-2 personas según evento)" },
  { label: "Duración servicio", value: "3-4 horas estándar" },
  { label: "Montaje", value: "2-3 horas antes del evento" },
  { label: "Electricidad", value: "120V estándar (500-800W según tamaño)" },
  { label: "Eventos exterior", value: "Sí, con protección de viento/lluvia" },
];

const sidebarNav = [
  { name: "Fuente de Chocolate", href: null, active: true },
  { name: "Mesa de Dulces (Candy Bar)", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
  { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
  { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
  { name: "Quesos y Embutidos", href: "/servicios/mobiliario/barras/postres/quesos-embutidos/" },
  { name: "Mesa de Snacks", href: "/servicios/mobiliario/barras/postres/mesa-snacks/" },
  { name: "Dulces Tradicionales", href: "/servicios/mobiliario/barras/postres/dulces-tradicionales/" },
  { name: "Donas y Cupcakes", href: "/servicios/mobiliario/barras/postres/donas-cupcakes/" },
];

const sidebarRelated = [
  { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Fairy Lights", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
];

const reviews = [
  { author: "Patricia Mendoza", text: "La fuente de chocolate fue el hit de nuestra boda. Los invitados no paraban de regresar por más fresas con chocolate. El operador fue muy profesional, mantuvo todo impecable durante 4 horas. El chocolate oscuro 70% estaba delicioso — varios invitados preguntaron qué marca era. 100% recomendados.", rating: 5, date: "2025-12-08" },
  { author: "Roberto Sánchez", text: "Contratamos la fuente de 5 niveles para los XV años de mi hija (180 invitados). Eligieron el combo de chocolate con leche y blanco — los dos sabores fueron un éxito. La estación de churros recién hechos fue el toque perfecto. El equipo llegó temprano y montó todo discretamente.", rating: 5, date: "2025-11-15" },
  { author: "Carolina Vega", text: "Para nuestro evento corporativo de fin de año (250 personas) queríamos algo especial. La fuente de 7 niveles con chocolate oscuro fue espectacular — impresionó a todos nuestros clientes VIP. Los brownies con chocolate fueron increíbles. Muy profesionales y puntuales.", rating: 5, date: "2025-10-22" },
  { author: "Diana López", text: "Fuente de chocolate ruby para el baby shower de mi hermana. ¡El color rosa natural del chocolate era perfecto para la temática! Las fresas con chocolate ruby son una combinación divina. El servicio fue excelente — reponían frutas constantemente.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Fuente de Chocolate Profesional para Eventos en CDMX",
    description: "Fuente de chocolate profesional de 3-7 niveles con chocolate belga premium. Estación de dipping con frutas frescas y churros. Operador incluido. Servicio para 50-400+ invitados en CDMX.",
    url: "/servicios/mobiliario/barras/postres/fuente-chocolate/",
    priceRange: { min: 4500, max: 28000 },
    reviews,
    ratingValue: 5,
    reviewCount: 4,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Postres", url: "/servicios/mobiliario/barras/postres/" },
    { name: "Fuente de Chocolate", url: "/servicios/mobiliario/barras/postres/fuente-chocolate/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Fuente de Chocolate Profesional — Renta para Eventos CDMX"
  description="Fuente de chocolate profesional de 3-7 niveles con chocolate belga premium. Frutas frescas, churros y malvaviscos. Operador incluido. Cotiza para tu evento en CDMX."
  jsonLd={jsonLd}
>
  <div class="container"><Breadcrumbs items={breadcrumbItems} /></div>

  <HeroPage
    badge="Chocolate belga premium"
    title='Renta de <span class="highlight">Fuente de Chocolate</span> Profesional para Eventos'
    subtitle="Fuentes comerciales de 3 a 7 niveles con flujo continuo de chocolate belga. Estación de dipping completa con fresas, churros, malvaviscos y más. Operador profesional incluido durante todo el evento."
    primaryCTA={{ label: "Cotiza tu Fuente de Chocolate", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una fuente de chocolate profesional` }}
    cards={[
      {
        title: "Fuentes profesionales con chocolate belga Callebaut y Valrhona",
        content: "<strong>Fuentes de chocolate comerciales</strong> de 3, 5 y 7 niveles con flujo continuo y sistema de calentamiento integrado. Chocolate belga premium: <strong>oscuro 70%</strong> (intenso), <strong>leche 40%</strong> (cremoso), <strong>blanco</strong> (suave), y <strong>ruby</strong> (rosa natural, sabor frutal). Capacidad desde 50 hasta 400+ invitados. Temperatura controlada automáticamente (45-48°C) para consistencia perfecta durante todo el evento. Puedes elegir un tipo de chocolate o combinar hasta 3 variedades.",
      },
      {
        title: "Estación de dipping completa con frutas frescas y churros",
        content: "<strong>Estación de dipping premium</strong> incluida: fresas frescas de temporada, plátano, uvas, piña, kiwi, manzana. Malvaviscos jumbo, pretzels de sal y dulces, brownies en cubos, galletas de mantequilla. <strong>Opción premium</strong>: churros recién hechos con azúcar y canela. Todo presentado en exhibidores elegantes con palillos de bambú profesionales. <strong>Operador incluido</strong> que mantiene la estación impecable, repone frutas y asiste a los invitados durante 3-4 horas de servicio.",
      },
    ]}
  />

  <CTABanner headline="¿Buscas el elemento WOW para tu evento?" subheadline="Fuente de chocolate con chocolate belga y frutas frescas — cotiza sin compromiso" primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }} secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }} />

  <!-- Mobile Navigation -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Tipos de Mesas</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Combina con</h3>
          <ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">Fuente de chocolate belga</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una fuente de chocolate`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content with Sidebar -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- Specifications Table -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Fuente de Chocolate</h2>
              </div>
              <div class="specs-table__body">{specs.map((spec) => (<div class="specs-table__row"><div class="specs-table__label">{spec.label}</div><div class="specs-table__value">{spec.value}</div></div>))}</div>
            </div>
          </section>

          <!-- Showcase 1: Tipos de Chocolate -->
          <section class="section section--alt" aria-labelledby="chocolate-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Chocolate belga premium</span>
                <h2 class="showcase__title" id="chocolate-heading">4 Variedades de Chocolate Profesional</h2>
                <p class="showcase__subtitle">Callebaut y Valrhona — las marcas de chocolate más prestigiosas del mundo.</p>
                <p class="showcase__text">Trabajamos exclusivamente con <strong>chocolate belga de grado profesional</strong> que garantiza flujo perfecto, consistencia cremosa y sabor excepcional. <strong>Chocolate Oscuro 70%</strong>: intenso con notas de cacao puro, perfecto para paladares adultos y eventos elegantes. <strong>Chocolate con Leche 40%</strong>: el favorito universal, cremoso y dulce, ideal para bodas y eventos familiares. <strong>Chocolate Blanco</strong>: suave y mantecoso, combina perfectamente con frutos rojos como fresas y frambuesas.</p>
                <p class="showcase__text"><strong>Chocolate Ruby</strong>: la innovación del mundo chocolatero — un chocolate naturalmente rosa (sin colorantes) con sabor frutal y acidez ligera. Perfecto para baby showers, XV años y eventos con temática rosa. Puedes elegir <strong>un tipo de chocolate o combinar hasta 3 variedades</strong> en fuentes separadas para crear una estación de degustación premium.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Oscuro 70%</span>
                  <span class="showcase__tag">Leche 40%</span>
                  <span class="showcase__tag">Blanco</span>
                  <span class="showcase__tag">Ruby (rosa)</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Fuente</a>
              </div>
              <div class="showcase__image"><img src="/images/mobiliario/fuente-chocolate-variedades-belga.avif" alt="Variedades de chocolate belga para fuente: oscuro, leche, blanco y ruby" width="1200" height="686" loading="lazy" /></div>
            </div>
          </section>

          <!-- Showcase 2: Tamaños de Fuente -->
          <section class="section section--alt" aria-labelledby="tamanos-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">3 tamaños profesionales</span>
                <h2 class="showcase__title" id="tamanos-heading">Fuentes de 3, 5 y 7 Niveles</h2>
                <p class="showcase__subtitle">Desde eventos íntimos de 50 personas hasta galas de 400+ invitados.</p>
                <p class="showcase__text"><strong>Fuente de 3 Niveles (27")</strong>: compacta pero impactante, ideal para bodas íntimas, baby showers y reuniones de 50-80 personas. Requiere 6-8kg de chocolate. <strong>Fuente de 5 Niveles (34")</strong>: nuestro tamaño más popular, perfecto para bodas medianas, XV años y eventos corporativos de 80-200 personas. Capacidad para 10-14kg de chocolate con flujo continuo espectacular.</p>
                <p class="showcase__text"><strong>Fuente de 7 Niveles (44")</strong>: la pieza central definitiva para eventos de gran escala — bodas de lujo, galas corporativas y festivales con 200-500 invitados. Cascada de chocolate de casi un metro de altura que se convierte en el centro de todas las fotos. Capacidad para 18-25kg de chocolate. Todas nuestras fuentes son <strong>comerciales de grado profesional</strong> con sistema de calentamiento integrado, motor silencioso y control de temperatura automático (45-48°C).</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">3 niveles (50-80 pers)</span>
                  <span class="showcase__tag">5 niveles (80-200 pers)</span>
                  <span class="showcase__tag">7 niveles (200-500 pers)</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">Ver Paquetes</a>
              </div>
              <div class="showcase__image"><img src="/images/mobiliario/fuente-chocolate-tamanos-niveles.avif" alt="Fuentes de chocolate de 3, 5 y 7 niveles" width="1200" height="686" loading="lazy" /></div>
            </div>
          </section>

          <!-- Showcase 3: Estación de Dipping -->
          <section class="section section--alt" aria-labelledby="dipping-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Estación premium</span>
                <h2 class="showcase__title" id="dipping-heading">Estación de Dipping con Frutas y Churros</h2>
                <p class="showcase__subtitle">Todo para mojar en chocolate: frutas frescas, malvaviscos, pretzels y más.</p>
                <p class="showcase__text">Nuestra <strong>estación de dipping</strong> incluye una selección curada de elementos para sumergir en chocolate: <strong>Frutas frescas de temporada</strong> — fresas grandes, plátano en rodajas, uvas sin semilla, piña en cubos, kiwi, manzana verde. <strong>Malvaviscos jumbo</strong> (el clásico que nunca falla). <strong>Pretzels</strong> de sal y dulces. <strong>Brownies</strong> en cubos del tamaño perfecto. <strong>Galletas de mantequilla</strong> tipo shortbread.</p>
                <p class="showcase__text">Como <strong>opción premium</strong> ofrecemos <strong>churros recién hechos</strong> — servidos tibios con azúcar y canela, la combinación perfecta con chocolate. Todo presentado en <strong>exhibidores elegantes</strong> de acrílico o madera según tu estilo, con palillos de bambú profesionales, servilletas de calidad (personalizables con tu diseño), y platos pequeños para invitados. Nuestro operador repone continuamente durante el servicio.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Frutas frescas</span>
                  <span class="showcase__tag">Malvaviscos</span>
                  <span class="showcase__tag">Churros (premium)</span>
                  <span class="showcase__tag">Pretzels</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Estación Completa</a>
              </div>
              <div class="showcase__image"><img src="/images/mobiliario/fuente-chocolate-estacion-dipping.avif" alt="Estación de dipping con frutas, malvaviscos y churros" width="1200" height="686" loading="lazy" /></div>
            </div>
          </section>

          <!-- Showcase 4: Servicio Profesional -->
          <section class="section section--alt" aria-labelledby="servicio-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Operador incluido</span>
                <h2 class="showcase__title" id="servicio-heading">Servicio Profesional de 3-4 Horas</h2>
                <p class="showcase__subtitle">Personal capacitado que mantiene tu estación impecable durante todo el evento.</p>
                <p class="showcase__text"><strong>Todos nuestros paquetes incluyen operador profesional</strong> que se encarga de cada detalle: mantener el chocolate a temperatura óptima, verificar el flujo continuo sin interrupciones, reponer frutas y elementos de dipping conforme se consumen, mantener el área limpia y ordenada, asistir a invitados que necesiten ayuda, y coordinar con el personal del venue.</p>
                <p class="showcase__text">Para <strong>eventos de más de 200 invitados</strong> asignamos 2 operadores para garantizar servicio fluido sin tiempos de espera. Nuestro equipo llega <strong>2-3 horas antes</strong> para montar todo discretamente: armado de la fuente, calentamiento del chocolate (45-60 min para temperatura óptima), preparación de la estación de dipping con frutas recién cortadas, y coordinación de ubicación con el venue. Necesitamos una toma eléctrica estándar (120V) a máximo 3 metros de distancia.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Operador incluido</span>
