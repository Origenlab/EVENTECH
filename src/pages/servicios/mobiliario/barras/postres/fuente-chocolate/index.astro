  <!-- WhatsApp Form Handler -->
  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();
      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const invitados = document.getElementById('invitados').value;
      const chocolate = document.getElementById('chocolate').value;
      const extras = document.getElementById('extras').value;
      const mensaje = document.getElementById('mensaje').value.trim();
      if (!nombre || !telefono || !mensaje) { if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error'); if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error'); if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error'); return; }
      let fechaTexto = 'No especificada'; if (fecha) { const d = new Date(fecha + 'T12:00:00'); fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }); }
      let texto = `*Fuente de Chocolate Profesional*\n\n*Nombre:* ${nombre}\n*Teléfono:* ${telefono}\n`; if (tipoEvento) texto += `*Evento:* ${tipoEvento}\n`; texto += `*Fecha:* ${fechaTexto}\n`; if (invitados) texto += `*Invitados:* ${invitados}\n`; if (chocolate) texto += `*Chocolate:* ${chocolate}\n`; if (extras) texto += `*Extras:* ${extras}\n`; texto += `\n*Mensaje:*\n${mensaje}`;
      window.open(`https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`, '_blank');
    });
    document.querySelectorAll('.form-field__input').forEach(input => input.addEventListener('input', function() { this.classList.remove('form-field__input--error'); }));
  </script>

