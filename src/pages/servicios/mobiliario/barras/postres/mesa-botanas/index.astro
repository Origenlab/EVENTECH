---
/**
 * ─── Mesa de Botanas — Página de Producto (Nivel 5) ───
 * El contrapunto perfecto para lo dulce: dips, crudités, tostadas y bocadillos salados.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Postres", href: "/servicios/mobiliario/barras/postres/" },
  { label: "Mesa de Botanas" },
];

const faqs = [
  { question: "¿Qué incluye la mesa de botanas?", answer: 'Nuestra mesa incluye <strong>dips gourmet</strong> (hummus, guacamole, tzatziki, queso crema con hierbas), <strong>crudités</strong> (bastones de zanahoria, apio, pepino, jícama, pimiento), <strong>tostadas y chips</strong> (tortilla, pita, pan árabe), y <strong>botanas saladas</strong> (aceitunas, pepinillos, almendras, nueces). Todo fresco y repuesto durante el evento.' },
  { question: "¿Para cuántas personas es el paquete estándar?", answer: 'El <strong>paquete estándar</strong> cubre <strong>80-150 personas</strong> como estación de botanas durante coctel o recepción. Calculamos 80-100g de botanas por persona para eventos de 2-3 horas. Para cenas completas o eventos más largos, ajustamos cantidades. Todos los dips y vegetales se preparan frescos el día del evento.' },
  { question: "¿Los dips son caseros?", answer: 'Sí, todos los <strong>dips son preparados artesanalmente</strong> el día del evento: hummus de garbanzo con aceite de oliva y páprika, guacamole con cilantro y limón, tzatziki griego con pepino y eneldo, y queso crema batido con hierbas finas. Utilizamos ingredientes frescos y recetas probadas. Sin conservadores artificiales.' },
  { question: "¿Puedo personalizar los dips y vegetales?", answer: 'Por supuesto. Puedes elegir qué dips incluir y agregar opciones especiales: <strong>baba ganoush</strong>, <strong>salsa de alcachofa</strong>, <strong>queso brie al horno</strong>, o <strong>fondue de queso</strong>. También ofrecemos vegetales adicionales (espárragos, champiñones, tomates cherry) y opciones para dietas especiales (vegano, sin gluten).' },
  { question: "¿Cómo se conservan los dips y vegetales?", answer: 'Los dips se sirven en <strong>recipientes de cerámica sobre bases con hielo</strong> que mantienen temperatura fresca sin congelar. Los vegetales se presentan en camas de hielo picado que los mantienen crujientes. Nuestro personal repone y rota productos cada 45-60 minutos para garantizar frescura durante todo el evento.' },
  { question: "¿Combinan bien con mesas de dulces?", answer: 'Absolutamente. La mesa de botanas es el <strong>contrapunto perfecto</strong> para mesas de dulces — el balance entre salado y dulce mejora la experiencia de los invitados. Ofrecemos paquetes combinados con descuento: botanas + <a href="/servicios/mobiliario/barras/postres/mesa-dulces/">candy bar</a> o botanas + <a href="/servicios/mobiliario/barras/postres/quesos-embutidos/">quesos y embutidos</a>.' },
];

const specs = [
  { label: "Estructura", value: "Madera rústica / Cerámica artesanal" },
  { label: "Dips gourmet", value: "4-6 variedades artesanales" },
  { label: "Crudités", value: "6-8 tipos de vegetales frescos" },
  { label: "Chips y tostadas", value: "Tortilla, pita, pan árabe" },
  { label: "Capacidad", value: "50-200 personas (según paquete)" },
  { label: "Conservación", value: "Bases con hielo, rotación cada 45 min" },
  { label: "Preparación", value: "Dips caseros el día del evento" },
  { label: "Opciones especiales", value: "Vegano, sin gluten disponibles" },
  { label: "Montaje", value: "2-3 horas antes" },
  { label: "Dimensiones", value: "2 x 1.2 metros aprox." },
];

const sidebarNav = [
  { name: "Mesa de Dulces (Candy Bar)", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
  { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
  { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
  { name: "Quesos y Embutidos", href: "/servicios/mobiliario/barras/postres/quesos-embutidos/" },
  { name: "Mesa de Snacks", href: "/servicios/mobiliario/barras/postres/mesa-snacks/" },
  { name: "Mesa de Botanas", href: null, active: true },
  { name: "Dulces Tradicionales", href: "/servicios/mobiliario/barras/postres/dulces-tradicionales/" },
  { name: "Donas y Cupcakes", href: "/servicios/mobiliario/barras/postres/donas-cupcakes/" },
];

const sidebarRelated = [
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Quesos y Embutidos", href: "/servicios/mobiliario/barras/postres/quesos-embutidos/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Laura Mendoza", text: "La mesa de botanas fue perfecta para el coctel de nuestra boda. El hummus y el guacamole estaban increíbles — todos preguntaban si eran caseros. Los vegetales súper frescos y crujientes. El balance con el candy bar fue ideal.", rating: 5, date: "2025-11-25" },
  { author: "Carlos Jiménez", text: "Para nuestra recepción corporativa de 120 personas, la mesa de botanas fue un éxito. Elegante, fresca, y el personal mantuvo todo impecable durante las 3 horas. Los dips artesanales fueron el punto fuerte.", rating: 5, date: "2025-10-30" },
  { author: "Sofía Torres", text: "Contratamos botanas + quesos para los XV de mi hija. La combinación fue perfecta — los invitados tenían opciones variadas entre lo dulce del candy bar y lo salado de las botanas. Muy profesional el servicio.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa de Botanas para Eventos en CDMX",
    description: "Mesa de botanas con dips artesanales, crudités frescos y chips gourmet. Hummus, guacamole, tzatziki caseros. Montaje incluido en CDMX.",
    url: "/servicios/mobiliario/barras/postres/mesa-botanas/",
    priceRange: { min: 2500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Postres", url: "/servicios/mobiliario/barras/postres/" },
    { name: "Mesa de Botanas", url: "/servicios/mobiliario/barras/postres/mesa-botanas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout title="Mesa de Botanas — Renta para Eventos CDMX" description="Mesa de botanas con dips artesanales (hummus, guacamole, tzatziki), crudités frescos y chips gourmet. Montaje incluido en CDMX. Cotiza hoy." jsonLd={jsonLd}>
  <div class="container"><Breadcrumbs items={breadcrumbItems} /></div>

  <HeroPage badge="Contrapunto perfecto" title='Renta de <span class="highlight">Mesa de Botanas</span> para Eventos' subtitle="Dips artesanales (hummus, guacamole, tzatziki), crudités frescos (zanahoria, apio, jícama), tostadas y chips gourmet. El balance salado perfecto para equilibrar mesas de dulces. Todo fresco, casero y elegantemente presentado." primaryCTA={{ label: "Cotiza tu Mesa de Botanas", href: "#reserva-heading" }} secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una mesa de botanas` }} cards={[{ title: "Dips artesanales preparados el día del evento", content: "<strong>4-6 dips gourmet caseros</strong>: hummus de garbanzo con aceite de oliva y páprika ahumada, guacamole fresco con cilantro y limón, tzatziki griego con pepino y eneldo, queso crema batido con hierbas finas. Opciones adicionales: baba ganoush, salsa de alcachofa, queso brie al horno. Todos preparados artesanalmente sin conservadores. Servidos en recipientes de cerámica sobre bases con hielo." },{ title: "Crudités frescos y chips variados", content: "<strong>Vegetales crujientes</strong>: bastones de zanahoria, apio, pepino, jícama, pimiento rojo y amarillo. Presentados en camas de hielo que mantienen frescura. <strong>Chips y tostadas</strong>: tortilla de maíz, pita, pan árabe, crostini. El personal repone cada 45 minutos para garantizar que todo esté siempre fresco y crujiente. Balance perfecto con <a href='/servicios/mobiliario/barras/postres/mesa-dulces/'>mesas de dulces</a>." }]} />

  <CTABanner headline="¿Necesitas balance salado para tu evento?" subheadline="Dips artesanales y crudités frescos — el complemento perfecto para cualquier coctel" primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }} secondaryCTA={{ label: "Llamar", href: `tel:${SITE.contact.phoneRaw}` }} />

  <section class="l4-mobile-nav" aria-label="Navegación"><div class="container"><div class="l4-sidebar--mobile"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}</ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Cotizar botanas`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a><a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a></div></div></div></section>

  <div class="l4-content-section"><div class="container"><div class="l4-layout">
    <div class="l4-main">
      <section aria-labelledby="specs-heading"><div class="specs-table"><div class="specs-table__header"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg><h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa de Botanas</h2></div><div class="specs-table__body">{specs.map((spec) => (<div class="specs-table__row"><div class="specs-table__label">{spec.label}</div><div class="specs-table__value">{spec.value}</div></div>))}</div></div></section>

      <section class="section section--alt" aria-labelledby="dips-heading"><div class="showcase"><div class="showcase__content"><span class="showcase__badge">Preparación artesanal</span><h2 class="showcase__title" id="dips-heading">Dips Gourmet Caseros</h2><p class="showcase__subtitle">Hummus, guacamole, tzatziki y más — todos preparados frescos el día del evento.</p><p class="showcase__text">Nuestros <strong>dips artesanales</strong> se preparan el mismo día del evento con ingredientes frescos: <strong>Hummus</strong> de garbanzo con aceite de oliva extra virgen y páprika ahumada. <strong>Guacamole</strong> con aguacate Hass, cilantro fresco, cebolla y limón. <strong>Tzatziki</strong> estilo griego con yogurt, pepino, ajo y eneldo. <strong>Queso crema</strong> batido con hierbas finas de Provenza.</p><p class="showcase__text">Servimos en <strong>recipientes de cerámica artesanal</strong> sobre bases con hielo discreto que mantiene temperatura fresca sin congelar. Opciones adicionales disponibles: baba ganoush, salsa de alcachofa y espinaca, queso brie al horno con nueces, o fondue de queso para eventos más formales.</p><div class="showcase__tags"><span class="showcase__tag">Hummus</span><span class="showcase__tag">Guacamole</span><span class="showcase__tag">Tzatziki</span><span class="showcase__tag">Caseros</span></div><a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Dips</a></div><div class="showcase__image"><img src="/images/mobiliario/mesa-botanas-dips-artesanales.avif" alt="Dips artesanales: hummus, guacamole, tzatziki caseros" width="1200" height="686" loading="lazy" /></div></div></section>

      <section class="section section--alt" aria-labelledby="crudites-heading"><div class="showcase"><div class="showcase__content"><span class="showcase__badge">Frescura garantizada</span><h2 class="showcase__title" id="crudites-heading">Crudités y Chips Gourmet</h2><p class="showcase__subtitle">Vegetales crujientes en hielo y chips artesanales para complementar cada dip.</p><p class="showcase__text">Los <strong>crudités frescos</strong> son el vehículo perfecto para los dips: bastones de zanahoria, apio, pepino, jícama mexicana, y pimientos de colores. Todo cortado uniformemente y presentado sobre <strong>camas de hielo picado</strong> que mantienen los vegetales crujientes durante todo el evento.</p><p class="showcase__text"><strong>Chips y tostadas variadas</strong>: totopos de tortilla de maíz (naturales y con chile), triángulos de pita tostada, pan árabe, crostini de baguette, y crackers de agua. Perfectos para scooping sin romperse. Nuestro personal repone cada 45 minutos para que siempre haya opciones frescas disponibles.</p><div class="showcase__tags"><span class="showcase__tag">Zanahoria</span><span class="showcase__tag">Jícama</span><span class="showcase__tag">Totopos</span><span class="showcase__tag">Pita</span></div><a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Mesa Completa</a></div><div class="showcase__image"><img src="/images/mobiliario/mesa-botanas-crudites-chips.avif" alt="Crudités frescos y chips gourmet para botanas" width="1200" height="686" loading="lazy" /></div></div></section>

      <section class="section" aria-labelledby="galeria-heading"><div class="container"><h2 class="section-header__title" id="galeria-heading">Galería — Mesas de Botanas</h2><p class="section-header__description">Cocteles, bodas y recepciones en CDMX.</p><div class="galeria-grid"><img src="/images/mobiliario/mesa-botanas-coctel-boda.avif" alt="Mesa botanas coctel boda" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-botanas-corporativo.avif" alt="Mesa botanas corporativo" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-botanas-xv-anos.avif" alt="Mesa botanas XV años" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-botanas-detalle-dips.avif" alt="Detalle dips artesanales" width="600" height="343" loading="lazy" /></div></div></section>

      <section class="section" aria-labelledby="faq-heading"><SectionHeader id="faq-heading" title="Preguntas Frecuentes — Botanas" subtitle="Resolvemos tus dudas" description={["Todo sobre dips y crudités.", "Escríbenos por WhatsApp."]} /><div class="faq-layout"><div class="faq-list">{faqs.map((faq) => (<details class="faq-item"><summary class="faq-item__question"><span>{faq.question}</span><svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></summary><div class="faq-item__answer"><p set:html={faq.answer} /></div></details>))}</div><aside class="faq-sidebar"><div class="faq-sidebar-card faq-sidebar-card--accent"><h3 class="faq-sidebar-card__title">¿Dudas?</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Dudas botanas`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">WhatsApp</a></div><div class="faq-sidebar-card"><h3 class="faq-sidebar-card__title">Llámanos</h3><a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a></div></aside></div></section>
    </div>

    <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Navegación"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}<li><div class="sidebar-nav__divider"></div></li><li class="sidebar-nav__item"><a href="/servicios/mobiliario/barras/postres/" class="sidebar-nav__back">&uarr; Postres</a></li></ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Cotizar botanas`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a><a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a></div></aside>
  </div></div></div>

  <section class="section section--alt" aria-labelledby="reserva-heading"><div class="container"><SectionHeader id="reserva-heading" title="Cotiza tu Mesa de Botanas" subtitle="Balance perfecto" description={["Dips caseros y crudités frescos.", "Montaje incluido."]} /><div class="reserva-layout"><form class="reserva-form" id="reservaForm" novalidate><div class="reserva-form__grid"><div class="form-field"><label class="form-field__label" for="nombre">Nombre <span class="form-field__required">*</span></label><input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required /></div><div class="form-field"><label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label><input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required /></div><div class="form-field"><label class="form-field__label" for="tipoEvento">Evento</label><select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select"><option value="">Selecciona</option><option value="Boda">Boda</option><option value="Coctel">Coctel</option><option value="Corporativo">Corporativo</option><option value="XV Años">XV Años</option><option value="Otro">Otro</option></select></div><div class="form-field"><label class="form-field__label" for="fecha">Fecha</label><input type="date" id="fecha" name="fecha" class="form-field__input" /></div><div class="form-field form-field--full"><label class="form-field__label" for="paquete">Paquete</label><select id="paquete" name="paquete" class="form-field__input form-field__select"><option value="Botanas Básico (50-80)">Básico (50-80)</option><option value="Botanas Estándar (80-150)" selected>Estándar (80-150)</option><option value="Botanas Premium (150-200)">Premium (150-200)</option><option value="Botanas + Candy Bar">+ Candy Bar</option></select></div><div class="form-field form-field--full"><label class="form-field__label" for="mensaje">Mensaje <span class="form-field__required">*</span></label><textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Cuéntanos: número de invitados, dips preferidos, restricciones alimentarias..." rows="4" required></textarea></div></div><button type="submit" class="reserva-form__submit"><svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>Enviar por WhatsApp</button></form><aside class="reserva-sidebar"><div class="reserva-card"><h3 class="reserva-card__title">Respuesta rápida</h3><p class="reserva-card__text">30 min WhatsApp.</p></div><div class="reserva-card"><h3 class="reserva-card__title">Dips caseros</h3><p class="reserva-card__text">Preparados el día del evento.</p></div><div class="reserva-card reserva-card--highlight"><h3 class="reserva-card__title">Horario</h3><p cl