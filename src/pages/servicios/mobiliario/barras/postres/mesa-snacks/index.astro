---
/**
 * ─── Mesa de Snacks — Página de Producto (Nivel 5) ───
 * Para fiestas que duran hasta tarde: palomitas, nachos, pretzels y botanas saladas.
 * Color accent: Amber #e17055.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Postres", href: "/servicios/mobiliario/barras/postres/" },
  { label: "Mesa de Snacks" },
];

const faqs = [
  { question: "¿Qué snacks incluye la mesa?", answer: 'Nuestra mesa incluye <strong>snacks salados</strong> perfectos para fiestas nocturnas: palomitas (mantequilla, caramelo, cheddar), nachos con queso y jalapeños, pretzels suaves con mostaza, papas fritas gourmet, nueces mixtas sazonadas, cacahuates japoneses, y mini hot dogs. Todo se mantiene caliente y crujiente durante el evento.' },
  { question: "¿Incluyen máquina de palomitas?", answer: 'Sí, ofrecemos <strong>máquina de palomitas estilo vintage</strong> que prepara palomitas frescas frente a los invitados. Disponible en rojo clásico o personalizada con los colores de tu evento. Incluye operador durante 3-4 horas, aceite, maíz y bolsas de papel. Es un hit en fiestas nocturnas y XV años.' },
  { question: "¿Para cuántas personas alcanza?", answer: 'El <strong>paquete estándar</strong> está diseñado para <strong>80-150 personas</strong> con variedad de 6-8 tipos de snacks. Calculamos que cada invitado consume 100-150g de snacks durante una fiesta de 4-5 horas. Para eventos más largos o con más invitados, ajustamos cantidades y agregamos personal de reposición.' },
  { question: "¿Los snacks se mantienen calientes?", answer: 'Sí, utilizamos <strong>equipos profesionales de conservación</strong>: warmers para nachos y pretzels, lámparas de calor para papas, y la máquina de palomitas mantiene las palomitas frescas y calientes. Para eventos largos, nuestro personal repone constantemente para que todo esté siempre en condiciones óptimas.' },
  { question: "¿Puedo personalizar los snacks?", answer: 'Por supuesto. Puedes elegir qué snacks incluir según tus preferencias y temática. Ofrecemos opciones adicionales: <strong>nachos con carne y guacamole</strong>, <strong>mini tacos</strong>, <strong>alitas de pollo</strong>, <strong>dedos de queso</strong>, y <strong>snacks saludables</strong> (hummus con vegetales, edamames). Armamos el menú perfecto para tu evento.' },
  { question: "¿Combinan bien con barra de bebidas?", answer: 'Absolutamente. La mesa de snacks es el <strong>complemento perfecto para barras de bebidas</strong> y fiestas nocturnas. Los snacks salados estimulan la sed y son ideales para acompañar cocteles y cerveza. Ofrecemos paquetes combinados con descuento — mesa de snacks + <a href="/servicios/mobiliario/barras/barras-bebidas/">barra de bebidas</a>.' },
];

const specs = [
  { label: "Estructura", value: "Carrito vintage / Mesa industrial" },
  { label: "Máquina palomitas", value: "Incluida (vintage roja o custom)" },
  { label: "Snacks variados", value: "6-10 tipos (según paquete)" },
  { label: "Capacidad", value: "50-200 personas (según paquete)" },
  { label: "Conservación", value: "Warmers, lámparas calor" },
  { label: "Dispensadores", value: "Nachos, pretzels, papas" },
  { label: "Personal", value: "Operador de máquina incluido" },
  { label: "Bolsas/recipientes", value: "Incluidos (papel craft o personalizados)" },
  { label: "Montaje", value: "2-3 horas antes" },
  { label: "Dimensiones", value: "3 x 1.5 metros aprox." },
];

const sidebarNav = [
  { name: "Mesa de Dulces (Candy Bar)", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
  { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
  { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
  { name: "Quesos y Embutidos", href: "/servicios/mobiliario/barras/postres/quesos-embutidos/" },
  { name: "Mesa de Snacks", href: null, active: true },
  { name: "Mesa de Botanas", href: "/servicios/mobiliario/barras/postres/mesa-botanas/" },
  { name: "Dulces Tradicionales", href: "/servicios/mobiliario/barras/postres/dulces-tradicionales/" },
  { name: "Donas y Cupcakes", href: "/servicios/mobiliario/barras/postres/donas-cupcakes/" },
];

const sidebarRelated = [
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Periqueras y Bancos", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Iluminación LED", href: "/servicios/iluminacion/escenario/par-led/" },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
  { name: "Pistas de Baile LED", href: "/servicios/pistas-baile/pistas-led/" },
];

const reviews = [
  { author: "Diana Castillo", text: "La mesa de snacks fue el complemento perfecto para nuestra fiesta de fin de año. La máquina de palomitas fue un hit — todos los invitados hacían fila para servirse. Los nachos con queso y los pretzels estaban increíbles. Muy profesional el servicio.", rating: 5, date: "2025-12-28" },
  { author: "Jorge Ramírez", text: "Para los XV años de mi hija queríamos algo diferente después de la cena. La mesa de snacks mantuvo a todos contentos hasta las 4am. Las palomitas recién hechas y los mini hot dogs fueron los favoritos. Excelente inversión.", rating: 5, date: "2025-11-08" },
  { author: "Mariana López", text: "Contratamos la mesa de snacks junto con la barra de bebidas para nuestra boda. El combo fue perfecto — los snacks salados complementaban los cocteles increíblemente bien. El carrito vintage quedaba hermoso con nuestra decoración.", rating: 5, date: "2025-10-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mesa de Snacks para Fiestas en CDMX",
    description: "Mesa de snacks con máquina de palomitas, nachos, pretzels y botanas para fiestas nocturnas. Equipos calientes y personal incluido. Montaje en CDMX.",
    url: "/servicios/mobiliario/barras/postres/mesa-snacks/",
    priceRange: { min: 3500, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Postres", url: "/servicios/mobiliario/barras/postres/" },
    { name: "Mesa de Snacks", url: "/servicios/mobiliario/barras/postres/mesa-snacks/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Mesa de Snacks — Renta para Fiestas CDMX"
  description="Mesa de snacks con máquina de palomitas vintage, nachos, pretzels y botanas calientes. Perfecta para fiestas nocturnas. Montaje incluido en CDMX. Cotiza hoy."
  jsonLd={jsonLd}
>
  <div class="container"><Breadcrumbs items={breadcrumbItems} /></div>

  <HeroPage
    badge="Para fiestas que no paran"
    title='Renta de <span class="highlight">Mesa de Snacks</span> para Fiestas'
    subtitle="Máquina de palomitas vintage, nachos con queso, pretzels calientes, papas gourmet y más. El combustible perfecto para fiestas que duran hasta tarde. Todo caliente, fresco y listo para servir."
    primaryCTA={{ label: "Cotiza tu Mesa de Snacks", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una mesa de snacks para mi fiesta` }}
    cards={[
      {
        title: "Máquina de palomitas vintage y snacks calientes",
        content: "<strong>Mesa de snacks profesional</strong> con máquina de palomitas estilo vintage (roja clásica o colores custom) que prepara palomitas frescas frente a los invitados. Incluye nachos con queso derretido y jalapeños, pretzels suaves con mostaza, papas fritas gourmet con salsas, nueces sazonadas, cacahuates japoneses y mini hot dogs. Todo se mantiene caliente con warmers y lámparas de calor profesionales.",
      },
      {
        title: "Servicio completo con operador y reposición",
        content: "<strong>Servicio profesional</strong> que incluye operador de máquina de palomitas durante 3-4 horas del evento, personal de reposición que mantiene todos los snacks en condiciones óptimas, bolsas de papel craft o personalizadas para palomitas, recipientes individuales para nachos y pretzels. Combinación perfecta con <a href='/servicios/mobiliario/barras/barras-bebidas/'>barras de bebidas</a> — los snacks salados son el complemento ideal para cocteles y cerveza.",
      },
    ]}
  />

  <CTABanner headline="¿Fiesta nocturna que necesita combustible?" subheadline="Mesa de snacks con palomitas, nachos y botanas calientes — tu fiesta no para hasta que tú digas" primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }} secondaryCTA={{ label: "Llamar", href: `tel:${SITE.contact.phoneRaw}` }} />

  <section class="l4-mobile-nav" aria-label="Navegación"><div class="container"><div class="l4-sidebar--mobile"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}</ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Cotizar mesa de snacks`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>WhatsApp</a><a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a></div></div></div></section>

  <div class="l4-content-section"><div class="container"><div class="l4-layout">
    <div class="l4-main">
      <section aria-labelledby="specs-heading"><div class="specs-table"><div class="specs-table__header"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg><h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Mesa de Snacks</h2></div><div class="specs-table__body">{specs.map((spec) => (<div class="specs-table__row"><div class="specs-table__label">{spec.label}</div><div class="specs-table__value">{spec.value}</div></div>))}</div></div></section>

      <section class="section section--alt" aria-labelledby="palomitas-heading">
        <div class="showcase">
          <div class="showcase__content">
            <span class="showcase__badge">Favorito de fiestas</span>
            <h2 class="showcase__title" id="palomitas-heading">Máquina de Palomitas Vintage</h2>
            <p class="showcase__subtitle">Palomitas recién hechas frente a tus invitados en carrito estilo retro.</p>
            <p class="showcase__text">La <strong>máquina de palomitas estilo vintage</strong> es el corazón de la mesa de snacks. Disponible en rojo clásico cinematográfico o personalizada con los colores de tu evento. Prepara palomitas frescas y calientes frente a los invitados — el aroma y el espectáculo son irresistibles. Incluye operador profesional durante 3-4 horas.</p>
            <p class="showcase__text">Ofrecemos <strong>3 sabores de palomitas</strong>: mantequilla clásica, caramelo dulce, y cheddar sazonado. Las bolsas de papel craft o personalizadas con tu logo/nombre están incluidas. La máquina tiene capacidad para servir hasta 200 invitados continuamente. Es un <strong>hit en XV años, bodas nocturnas y fiestas corporativas</strong>.</p>
            <div class="showcase__tags"><span class="showcase__tag">Vintage retro</span><span class="showcase__tag">3 sabores</span><span class="showcase__tag">Operador incluido</span><span class="showcase__tag">Bolsas craft</span></div>
            <a href="#reserva-heading" class="btn btn--primary btn--lg">Cotizar Máquina de Palomitas</a>
          </div>
          <div class="showcase__image"><img src="/images/mobiliario/mesa-snacks-maquina-palomitas-vintage.avif" alt="Máquina de palomitas vintage estilo retro para fiestas" width="1200" height="686" loading="lazy" /></div>
        </div>
      </section>

      <section class="section section--alt" aria-labelledby="variedad-heading">
        <div class="showcase">
          <div class="showcase__content">
            <span class="showcase__badge">Todo caliente</span>
            <h2 class="showcase__title" id="variedad-heading">Nachos, Pretzels y Más</h2>
            <p class="showcase__subtitle">Snacks salados mantenidos en temperatura óptima toda la noche.</p>
            <p class="showcase__text">Más allá de las palomitas, nuestra mesa incluye <strong>snacks calientes</strong> que mantienen la energía de la fiesta: <strong>Nachos</strong> con queso cheddar derretido, jalapeños y salsa. <strong>Pretzels suaves</strong> estilo alemán con mostaza y queso. <strong>Papas fritas gourmet</strong> con salsas (ketchup, mayonesa chipotle, guacamole). <strong>Mini hot dogs</strong> con toppings variados.</p>
            <p class="showcase__text">Todo se sirve en <strong>dispensadores calientes profesionales</strong> que mantienen temperatura óptima sin resecar. Nuestro personal repone constantemente para que siempre haya snacks frescos disponibles. Perfectos para acompañar la <a href="/servicios/mobiliario/barras/barras-bebidas/">barra de bebidas</a> — los snacks salados complementan cocteles y cerveza de maravilla.</p>
            <div class="showcase__tags"><span class="showcase__tag">Nachos</span><span class="showcase__tag">Pretzels</span><span class="showcase__tag">Hot dogs</span><span class="showcase__tag">Warmers</span></div>
            <a href="#reserva-heading" class="btn btn--primary btn--lg">Ver Menú Completo</a>
          </div>
          <div class="showcase__image"><img src="/images/mobiliario/mesa-snacks-nachos-pretzels-calientes.avif" alt="Nachos con queso, pretzels y snacks calientes para fiestas" width="1200" height="686" loading="lazy" /></div>
        </div>
      </section>

      <section class="section" aria-labelledby="galeria-heading"><div class="container"><h2 class="section-header__title" id="galeria-heading">Galería — Mesas de Snacks</h2><p class="section-header__description">XV años, bodas nocturnas y fiestas corporativas en CDMX.</p><div class="galeria-grid"><img src="/images/mobiliario/mesa-snacks-fiesta-noche.avif" alt="Mesa snacks fiesta nocturna" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-snacks-xv-anos.avif" alt="Mesa snacks XV años" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-snacks-boda-after.avif" alt="Mesa snacks boda after party" width="600" height="343" loading="lazy" /><img src="/images/mobiliario/mesa-snacks-corporativo.avif" alt="Mesa snacks corporativo" width="600" height="343" loading="lazy" /></div></div></section>

      <section class="section" aria-labelledby="faq-heading"><SectionHeader id="faq-heading" title="Preguntas Frecuentes — Snacks" subtitle="Resolvemos tus dudas" description={["Todo sobre la mesa de snacks.", "Escríbenos por WhatsApp."]} /><div class="faq-layout"><div class="faq-list">{faqs.map((faq) => (<details class="faq-item"><summary class="faq-item__question"><span>{faq.question}</span><svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></summary><div class="faq-item__answer"><p set:html={faq.answer} /></div></details>))}</div><aside class="faq-sidebar"><div class="faq-sidebar-card faq-sidebar-card--accent"><h3 class="faq-sidebar-card__title">¿Dudas?</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Dudas mesa snacks`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">WhatsApp</a></div><div class="faq-sidebar-card"><h3 class="faq-sidebar-card__title">Llámanos</h3><a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a></div></aside></div></section>
    </div>

    <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Navegación"><div class="sidebar-card"><h3 class="sidebar-card__title">Tipos de Mesas</h3><ul class="sidebar-nav">{sidebarNav.map((item) => (<li class="sidebar-nav__item">{item.active ? (<span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>) : (<a href={item.href} class="sidebar-nav__link">{item.name}</a>)}</li>))}<li><div class="sidebar-nav__divider"></div></li><li class="sidebar-nav__item"><a href="/servicios/mobiliario/barras/postres/" class="sidebar-nav__back">&uarr; Postres</a></li></ul></div><div class="sidebar-card"><h3 class="sidebar-card__title">Relacionados</h3><ul class="sidebar-related">{sidebarRelated.map((item) => (<li><a href={item.href} class="sidebar-related__link"><span class="sidebar-related__arrow">&rarr;</span>{item.name}</a></li>))}</ul></div><div class="sidebar-card sidebar-card--cta"><h3 class="sidebar-card__title">Cotiza</h3><a href={`https://wa.me/${SITE.contact.whatsapp}?text=Cotizar snacks`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0