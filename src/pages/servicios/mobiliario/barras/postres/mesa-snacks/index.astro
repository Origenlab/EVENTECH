  </div></div></div>

  <section class="section section--alt" aria-labelledby="reserva-heading"><div class="container"><SectionHeader id="reserva-heading" title="Cotiza tu Mesa de Snacks" subtitle="Fiesta que no para" description={["Palomitas, nachos y snacks calientes.", "Montaje y operador incluidos."]} /><div class="reserva-layout"><form class="reserva-form" id="reservaForm" novalidate><div class="reserva-form__grid"><div class="form-field"><label class="form-field__label" for="nombre">Nombre <span class="form-field__required">*</span></label><input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required /></div><div class="form-field"><label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label><input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required /></div><div class="form-field"><label class="form-field__label" for="tipoEvento">Evento</label><select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select"><option value="">Selecciona</option><option value="XV Años">XV Años</option><option value="Boda">Boda</option><option value="Fiesta Privada">Fiesta Privada</option><option value="Corporativo">Corporativo</option><option value="Otro">Otro</option></select></div><div class="form-field"><label class="form-field__label" for="fecha">Fecha</label><input type="date" id="fecha" name="fecha" class="form-field__input" /></div><div class="form-field form-field--full"><label class="form-field__label" for="paquete">Paquete</label><select id="paquete" name="paquete" class="form-field__input form-field__select"><option value="Snacks Básico (50-80)" >Básico (50-80 pers)</option><option value="Snacks Estándar (80-150)" selected>Estándar (80-150 pers)</option><option value="Snacks Premium (150-200)">Premium (150-200 pers)</option><option value="Snacks + Barra Bebidas">+ Barra de Bebidas</option></select></div><div class="form-field form-field--full"><label class="form-field__label" for="mensaje">Mensaje <span class="form-field__required">*</span></label><textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Cuéntanos: número de invitados, duración de la fiesta, snacks preferidos..." rows="4" required></textarea></div></div><button type="submit" class="reserva-form__submit"><svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>Enviar por WhatsApp</button></form><aside class="reserva-sidebar"><div class="reserva-card"><h3 class="reserva-card__title">Respuesta rápida</h3><p class="reserva-card__text">30 min por WhatsApp.</p></div><div class="reserva-card"><h3 class="reserva-card__title">Operador incluido</h3><p class="reserva-card__text">Personal para máquina y reposición.</p></div><div class="reserva-card reserva-card--highlight"><h3 class="reserva-card__title">Horario</h3><p class="reserva-card__text">Lun-Vie: 9-19h</p></div></aside></div></div></section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) { e.preventDefault(); const nombre = document.getElementById('nombre').value.trim(); const telefono = document.getElementById('telefono').value.trim(); const tipoEvento = document.getElementById('tipoEvento').value; const fecha = document.getElementById('fecha').value; const paquete = document.getElementById('paquete').value; const mensaje = document.getElementById('mensaje').value.trim(); if (!nombre || !telefono || !mensaje) { if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error'); if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error'); if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error'); return; } let fechaTexto = 'No especificada'; if (fecha) { const d = new Date(fecha + 'T12:00:00'); fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }); } let texto = `*Mesa de Snacks para Fiesta*\n\n*Nombre:* ${nombre}\n*Teléfono:* ${telefono}\n`; if (tipoEvento) texto += `*Evento:* ${tipoEvento}\n`; texto += `*Fecha:* ${fechaTexto}\n`; if (paquete) texto += `*Paquete:* ${paquete}\n`; texto += `\n*Mensaje:*\n${mensaje}`; window.open(`https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`, '_blank'); });
    document.querySelectorAll('.form-field__input').forEach(input => input.addEventListener('input', function() { this.classList.remove('form-field__input--error'); }));
  </script>

