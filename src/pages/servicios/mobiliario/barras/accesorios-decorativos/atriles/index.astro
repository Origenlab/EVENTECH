---
/**
 * ─── Atriles Decorativos — Página de Variante ───
 * Atriles decorativos para menús, señalización y bienvenida en eventos CDMX.
 * Desde $80 por pieza.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { label: "Atriles Decorativos" },
];

const galleryImages = [
  { src: "/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif", alt: "Atril de madera rústica con menú en boda hacienda CDMX" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Atril dorado de metal con cartel de bienvenida en evento" },
  { src: "/images/mobiliario/accesorios-atriles-senalizacion.avif", alt: "Atril de acrílico transparente con menú de cócteles" },
  { src: "/images/mobiliario/accesorios-atriles-senalizacion.avif", alt: "Atril de madera como número de mesa en boda rústica" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Atril de metal negro en gala corporativa con señalización" },
  { src: "/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif", alt: "Atril de madera natural en entrada de boda con detalle floral" },
];

const faqs = [
  {
    question: "¿Para qué se usa un atril en un evento y dónde se coloca?",
    answer: "Los atriles tienen tres usos principales en eventos: <strong>señalización de bienvenida</strong> (en la entrada con nombre de los novios y fecha), <strong>menús de mesa</strong> (uno por mesa con el menú del banquete) y <strong>señalización de secciones</strong> (zona de bar, zona de baile, mesas numeradas). También los usamos como soporte para cuadros de fotos, pizarras de bienvenida y carteles con programa del evento. El atril más versátil para señalización es el de <strong>madera natural</strong> por su escala y el de <strong>metal dorado</strong> para piezas más elegantes."
  },
  {
    question: "¿Los atriles incluyen el cartel o la señalización?",
    answer: "Los atriles se rentan como <strong>soporte vacío</strong> — sin cartel, impresión ni señalización incluida. Sin embargo, ofrecemos el servicio de impresión e instalación de carteles con cargo adicional. También aceptamos que el cliente traiga su propia impresión — solo indícanos las dimensiones del atril al cotizar para que tu diseñador prepare el arte con el tamaño correcto. Los <strong>atriles de madera soportan piezas hasta A2 (42×59 cm)</strong>; los de metal hasta A1 (59×84 cm)."
  },
  {
    question: "¿Qué tipos de atriles tienen disponibles?",
    answer: "Manejamos tres líneas: <strong>Madera rústica natural</strong> (con soporte de madera tratada, ideal para bodas campestres y haciendas), <strong>Metal dorado</strong> (patas trípode de metal galvanizado en dorado brillante, para bodas clásicas y galas) y <strong>Acrílico transparente</strong> (soporte invisible que hace que el cartel flote, ideal para bodas modernas y minimalistas). Los tres están disponibles en altura regulable de 100 a 140 cm, adaptable a carteles de piso y a mesas de distintas alturas."
  },
  {
    question: "¿Cuántos atriles necesito para mi evento?",
    answer: "Para la configuración básica de una boda recomendamos: <strong>1 atril grande en la entrada</strong> (bienvenida), <strong>1 atril en la zona de bar</strong> (menú de cócteles) y <strong>1 atril en la mesa de pastel o dulces</strong>. Si tu evento tiene 10+ mesas, puedes agregar <strong>1 atril por mesa</strong> para menús individuales. Para eventos corporativos con múltiples áreas, 1 atril por zona de señalización. Cotizamos precio especial para 5+ piezas."
  },
  {
    question: "¿Con cuánta anticipación debo reservar los atriles?",
    answer: "Para piezas individuales o paquetes pequeños (hasta 10 piezas), <strong>1-2 semanas de anticipación</strong> es suficiente. Si necesitas atriles para menús de mesa en bodas grandes (20+ piezas) o quieres el servicio de impresión incluido, reserva con <strong>3-4 semanas</strong> para que haya tiempo de producir los carteles. En temporada alta (noviembre-diciembre), reserva antes. Un anticipo del 30% garantiza la disponibilidad."
  },
];

const specs = [
  { label: "Tipos disponibles", value: "Madera rústica natural, Metal dorado trípode, Acrílico transparente" },
  { label: "Altura regulable", value: "100–140 cm (ajustable en campo)" },
  { label: "Capacidad de soporte", value: "Hasta A1 (59×84 cm) en modelos de metal; hasta A2 (42×59 cm) en madera" },
  { label: "Usos frecuentes", value: "Bienvenida, menú de banquete, señalización, número de mesa, menú de bar" },
  { label: "Señalización incluida", value: "No — soporte vacío. Servicio de impresión con cargo adicional" },
  { label: "Acabados metal", value: "Dorado brillante, Plateado, Negro mate" },
  { label: "Acabado madera", value: "Madera natural barnizada — veta visible" },
  { label: "Acabado acrílico", value: "Transparente cristal — soporte invisible" },
  { label: "Descuentos por volumen", value: "Sí — desde 5 piezas cotizamos precio especial" },
  { label: "Precio desde", value: "$80 por pieza por evento (incluye entrega)" },
];

const reviews = [
  { author: "Andrea Castillo", text: "Usamos 3 atriles de madera: uno en la entrada con el nombre de los novios, uno en la barra con el menú de cócteles y uno en la mesa de dulces. El acabado de madera combinaba perfecto con el estilo rústico de la hacienda. Llegaron en perfectas condiciones.", rating: 5, date: "2025-11-22" },
  { author: "Héctor Ruiz", text: "Para nuestra gala corporativa necesitábamos señalización elegante en 6 zonas. Los atriles de metal dorado con impresión incluida fueron exactamente lo que buscábamos. Profesional y puntual en todo.", rating: 5, date: "2025-10-08" },
  { author: "Isabel Flores", text: "Los atriles de acrílico transparente con los menús flotando eran el detalle más comentado de la boda. Quedaban perfectamente con la barra LED y las periqueras de acrílico. Coherencia total en la decoración.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Atriles Decorativos para Eventos y Bodas CDMX",
    description: "Renta de atriles decorativos para bodas y eventos en CDMX. Madera rústica, metal dorado y acrílico transparente. Altura regulable 100-140 cm. Señalización e impresión opcional. Desde $80 por pieza.",
    url: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/",
    priceRange: { min: 80, max: 600 },
    reviews,
    ratingValue: 5,
    reviewCount: 86,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Accesorios Decorativos", url: "/servicios/mobiliario/barras/accesorios-decorativos/" },
    { name: "Atriles Decorativos", url: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Accesorios", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Portavelas", href: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/" },
  { name: "Atriles Decorativos", href: null, active: true },
];

const sidebarRelated = [
  { name: "Portavelas Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Atriles Decorativos para Bodas"
  description="Renta atriles decorativos para bodas y eventos en CDMX — madera rústica, metal dorado y acrílico transparente."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El primer detalle que ven tus invitados al llegar — hazlo memorable"
    title='<span class="highlight">Atriles Decorativos</span> — Renta para Eventos en CDMX'
    subtitle="Atriles en madera rústica, metal dorado y acrílico transparente para bodas y eventos en CDMX. Señalización de bienvenida, menús de banquete y carteles de zona. Altura regulable de 100 a 140 cm. Desde $80 por pieza."
    primaryCTA={{ label: "Cotizar atriles", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar atriles decorativos para mi evento` }}
    cards={[
      {
        title: "Tres materiales para tres estilos — uno de ellos encaja perfectamente en tu evento",
        content: "El <strong>atril de madera rústica</strong> es el favorito para bodas en haciendas y eventos al aire libre — la veta natural de la madera lo hace cálido y orgánico. El <strong>atril de metal dorado en trípode</strong> añade elegancia y estructura a bodas clásicas, galas y eventos corporativos formales. El <strong>atril de acrílico transparente</strong> es la opción más moderna — el soporte desaparece y el cartel parece flotar en el espacio. Los tres son regulables en altura de 100 a 140 cm.",
      },
      {
        title: "Señalización que ordena el espacio y reduce la confusión de tus invitados",
        content: "Un evento bien señalizado es un evento que fluye. Los atriles en la entrada indican a los invitados que están en el lugar correcto. El atril en la barra comunica el menú de cócteles sin que el bartender tenga que repetirlo 200 veces. Los atriles de mesa con menú del banquete eliminan las preguntas al mesero. <strong>Desde $80 por pieza</strong> con entrega incluida — la inversión más barata para mejorar la experiencia de tus invitados.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Atriles que dan identidad al espacio y orden al evento — sin que nadie se pierda"
    subheadline="Madera · Metal dorado · Acrílico · Regulables 100-140 cm · Entrega incluida · Desde $80/pieza"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Accesorios Decorativos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Atriles para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar atriles decorativos para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Atriles Decorativos en Eventos Reales</h2>
            <p class="section__subtitle">Bodas, galas y eventos corporativos en CDMX y Estado de México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Atriles Decorativos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué los atriles son el accesorio más funcional y elegante en bodas y eventos?"
    headingId="descripcion-heading"
    badge="El primer detalle que ven tus invitados — y el que marca el tono de todo el evento"
    tags={["Atriles Madera", "Señalización Bodas", "Metal Dorado", "Menú de Bar"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">Un atril bien ubicado hace dos cosas simultáneamente: <strong>comunica información de forma elegante</strong> y <strong>añade un elemento decorativo tridimensional</strong> al espacio. Sin él, la señalización se convierte en carteles pegados con cinta en las paredes — lo que le resta categoría a cualquier evento, sin importar cuánto costó el resto de la decoración.</p>
      <p class="showcase__text">El <strong>atril de madera rústica</strong> es el que más fotografías genera en redes porque su textura natural lo hace fotogénico desde cualquier ángulo. Los de <strong>metal dorado en trípode</strong> son los más estables para carteles grandes y para exteriores con algo de brisa. El de <strong>acrílico transparente</strong> es el que mejor se adapta a eventos modernos y minimalistas donde el exceso de material visual satura.</p>
      <p class="showcase__text">Los complementamos con frecuencia con los <a href='/servicios/mobiliario/barras/accesorios-decorativos/'>marcos y espejos decorativos</a> para señalización de tabla de bodas y los <a href='/servicios/mobiliario/barras/accesorios-decorativos/portavelas/'>portavelas</a> para crear rincones fotogénicos completos junto al atril.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif" alt="Atril de madera rústica con cartel de bienvenida en entrada de boda hacienda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif" alt="Atril metal dorado con menú de cócteles en barra de bebidas" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/accesorios-atriles-senalizacion.avif" alt="Atril acrílico transparente con menú flotante en boda moderna" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Atriles Decorativos</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre los Atriles Decorativos"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Usos, materiales, señalización incluida y cuántos necesitas. Aquí resolvemos las dudas más frecuentes antes de reservar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te respondemos al instante sobre disponibilidad y precios.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre los atriles decorativos para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos cuántos atriles necesitas, el estilo de tu evento y la fecha — cotización en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Accesorios decorativos y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Accesorios Decorativos</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa la señalización de tu evento:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
