---
/**
 * ─── Portavelas Decorativos — Página de Variante ───
 * Set de portavelas para bodas y eventos en CDMX.
 * Desde $50 por set.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { label: "Portavelas" },
];

const galleryImages = [
  { src: "/images/mobiliario/mesa-postres-boda-tarta-candelabros-salon.avif", alt: "Set portavelas de cristal en mesa de boda CDMX" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Portavelas dorados como centro de mesa evento elegante" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Candelabro de tres brazos portavelas en boda romántica" },
  { src: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif", alt: "Portavelas votivas de cristal sobre barra de bebidas" },
  { src: "/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif", alt: "Portavelas cilíndricas en jardín de evento al aire libre" },
  { src: "/images/mobiliario/mesa-imperial-gala-candelabros-boda.avif", alt: "Portavelas cobre envejecido en boda hacienda rústica" },
];

const faqs = [
  {
    question: "¿Cuántos portavelas necesito por mesa?",
    answer: "La configuración más común es <strong>3-4 portavelas por mesa redonda</strong> de 150 cm y <strong>4-6 por mesa rectangular</strong> de 240 cm. Para mesas altas tipo barra o cóctel, con 2-3 votivas o 1 candelabro de 3 brazos es suficiente. El set básico desde <strong>$50 incluye 3 portavelas votivas de cristal</strong> — ideal para una mesa. Para paquetes de 10 o más mesas, cotizamos precio especial por volumen."
  },
  {
    question: "¿Las velas están incluidas en el set de portavelas?",
    answer: "Los portavelas se rentan como <strong>contenedores sin velas incluidas</strong>. Sin embargo, ofrecemos dos opciones: velas LED recargables (más seguras, reutilizables y permitidas en todos los venues) o te recomendamos proveedores de velas de cera natural. Las <strong>velas LED tienen cargo adicional de $10 por pieza</strong> y son la opción más solicitada porque duran toda la noche sin necesidad de reemplazarlas. Muchos venues en CDMX ya no permiten llama real — pregunta a tu coordinador de evento."
  },
  {
    question: "¿Qué acabados están disponibles en los portavelas?",
    answer: "Manejamos cuatro líneas de acabado: <strong>Cristal transparente</strong> (votivas y cilindros, la más versátil), <strong>Dorado brillante</strong> (bodas elegantes y galas), <strong>Cobre envejecido</strong> (bodas rústicas y haciendas) y <strong>Negro mate</strong> (eventos modernos e industriales). Los candelabros de 3 y 5 brazos están disponibles en dorado y negro. Para colores personalizados o acabados especiales, se requieren 2 semanas de anticipación y cargo adicional."
  },
  {
    question: "¿Se pueden mezclar portavelas de cristal con los candelabros dorados?",
    answer: "Sí, y de hecho es la combinación más popular en bodas clásicas: <strong>1 candelabro dorado de 3 brazos como pieza central + 3 votivas de cristal alrededor</strong>. La mezcla de texturas — el brillo del dorado con la transparencia del cristal — crea profundidad visual sin sobrecargarlo. También mezclamos portavelas de diferente altura en la misma mesa para crear volumen sin costo extra. Tu asesor de EVENTECH puede armar una propuesta visual para tu paleta de colores."
  },
  {
    question: "¿Con cuánta anticipación debo reservar los portavelas?",
    answer: "Para cantidades de hasta 50 piezas, <strong>1-2 semanas de anticipación</strong> es suficiente. Para bodas con 20+ mesas o paquetes de más de 100 portavelas, recomendamos <strong>3-4 semanas</strong>. En temporada alta (noviembre-diciembre y mayo-junio), la demanda sube mucho — reserva con mayor anticipación. Un anticipo del 30% bloquea la fecha y la cantidad específica."
  },
];

const specs = [
  { label: "Tipos disponibles", value: "Votivas cristal, cilindros, candelabros de 3 y 5 brazos" },
  { label: "Acabados", value: "Cristal transparente, Dorado, Cobre envejecido, Negro mate" },
  { label: "Set básico", value: "3 portavelas votivas de cristal (por mesa de 150 cm)" },
  { label: "Alturas disponibles", value: "8 cm (votiva), 15 cm (cilindro), 35 cm (candelabro 3 brazos), 55 cm (candelabro 5 brazos)" },
  { label: "Velas incluidas", value: "No — opcional velas LED a $10/pieza adicional" },
  { label: "Limpieza entre usos", value: "Sí — todos los portavelas llegan limpios y pulidos" },
  { label: "Personalización", value: "Colores especiales y grabados con 2 semanas de anticipación" },
  { label: "Set mínimo", value: "1 set (3 votivas) — sin mínimo de mesas" },
  { label: "Descuentos por volumen", value: "Sí — desde 10 sets cotizamos precio especial" },
  { label: "Precio desde", value: "$50 por set de 3 votivas por evento (incluye entrega)" },
];

const reviews = [
  { author: "Daniela Moreno", text: "Rentamos los portavelas de cristal y los candelabros dorados para 20 mesas. La combinación era exactamente lo que buscábamos para nuestra boda clásica. Llegaron perfectamente limpios y los de EVENTECH los acomodaron en cada mesa. Precioso.", rating: 5, date: "2025-12-14" },
  { author: "Lorena Vásquez", text: "Los portavelas de cobre envejecido para nuestra boda en hacienda fueron el toque mágico. La llama (LED) bailando en el cobre creaba un ambiente que parecía de película. Todo llegó en perfectas condiciones.", rating: 5, date: "2025-10-30" },
  { author: "Marco Gutiérrez", text: "Para nuestra gala corporativa usamos los candelabros de 5 brazos en dorado. El efecto era de hotel cinco estrellas. Servicio puntual y profesional de principio a fin.", rating: 5, date: "2025-09-19" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Set Portavelas Decorativos para Eventos CDMX",
    description: "Renta de portavelas para bodas y eventos en CDMX. Votivas de cristal, candelabros de 3 y 5 brazos en dorado, cobre y negro. Incluye entrega. Desde $50 por set.",
    url: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/",
    priceRange: { min: 50, max: 800 },
    reviews,
    ratingValue: 5,
    reviewCount: 142,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Accesorios Decorativos", url: "/servicios/mobiliario/barras/accesorios-decorativos/" },
    { name: "Portavelas", url: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todos los Accesorios", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Portavelas", href: null, active: true },
  { name: "Atriles Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/" },
];

const sidebarRelated = [
  { name: "Atriles Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/" },
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
];
---

<PageLayout
  title="Renta Set Portavelas Decorativos CDMX"
  description="Renta portavelas para bodas y eventos en CDMX — votivas de cristal, candelabros de 3 y 5 brazos en dorado, cobre envejecido y negro."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El detalle que separa una boda memorable de una boda bonita"
    title='Set <span class="highlight">Portavelas Decorativos</span> — Renta en CDMX'
    subtitle="Portavelas en cristal, dorado, cobre envejecido y negro mate para bodas y eventos en CDMX. Votivas, cilindros y candelabros de 3 y 5 brazos. El accesorio que transforma cada mesa en un rincón íntimo y cálido."
    primaryCTA={{ label: "Cotizar portavelas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar portavelas decorativos para mi evento` }}
    cards={[
      {
        title: "Cuatro acabados que se adaptan a cualquier estilo de boda o evento",
        content: "Los portavelas de <strong>cristal transparente</strong> son los más versátiles — funcionan igual en bodas románticas que en galas corporativas. Los de <strong>dorado brillante</strong> son el estándar para bodas clásicas y elegantes. El <strong>cobre envejecido</strong> es el favorito de bodas en haciendas y eventos rústicos. El <strong>negro mate</strong> cierra cualquier evento moderno o industrial. Disponibles en votivas (8 cm), cilindros (15 cm), y candelabros de 3 brazos (35 cm) y 5 brazos (55 cm) — el portfolio completo para crear cualquier atmósfera.",
      },
      {
        title: "Set desde $50 con entrega incluida — el accesorio con mejor relación costo-impacto visual",
        content: "Ningún otro elemento decorativo mejora el ambiente de un evento con un presupuesto tan bajo. Un <strong>set de 3 votivas de cristal a $50</strong> transforma completamente una mesa de 10 personas. Para bodas de 20 mesas, la inversión total en portavelas es de $1,000 — y el resultado visual es de revista. Cotizamos precio especial para paquetes de 10+ mesas. Con <strong>velas LED opcionales a $10/pieza</strong>, la duración es toda la noche sin atención.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Portavelas que convierten cada mesa en un rincón íntimo — desde $50 por set con entrega incluida"
    subheadline="Cristal · Dorado · Cobre envejecido · Negro mate · Velas LED opcionales · CDMX y EdoMex"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Accesorios Decorativos</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Portavelas para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar portavelas decorativos para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Portavelas en Eventos Reales</h2>
            <p class="section__subtitle">Bodas, galas y eventos en CDMX y Estado de México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Set Portavelas Decorativos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué los portavelas son el accesorio que nunca falla en bodas y eventos?"
    headingId="descripcion-heading"
    badge="El detalle decorativo con mejor relación costo-impacto"
    tags={["Portavelas Cristal", "Candelabros Dorados", "Bodas CDMX", "Centros de Mesa"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La respuesta tiene que ver con la luz. <strong>La llama — real o LED — crea movimiento y calidez</strong> que ningún otro elemento decorativo puede replicar. Un salón bien iluminado con portavelas se siente acogedor, íntimo y lujoso de una manera que las luces fijas nunca logran. Por eso los portavelas están en todas las bodas de revista y en los eventos corporativos más elegantes.</p>
      <p class="showcase__text">Los portavelas de <strong>cristal transparente</strong> son el comodín — funcionan en cualquier paleta de colores porque reflejan y amplifican la luz sin añadir color propio. Los de <strong>dorado brillante</strong> añaden calidez y glamour. El <strong>cobre envejecido</strong> añade textura y caracter — perfecto para bodas rústicas donde todo el mobiliario tiene veta y historia. El <strong>negro mate</strong> da sobriedad y modernidad en eventos contemporáneos.</p>
      <p class="showcase__text">Los combinamos con frecuencia con los <a href='/servicios/mobiliario/barras/accesorios-decorativos/atriles/'>atriles decorativos</a> para menús de mesa y los <a href='/servicios/mobiliario/barras/accesorios-decorativos/'>marcos y espejos</a> como señalización del evento. El trío completo — portavelas + atril + marco — es el paquete de accesorios más solicitado para bodas con decoración detallada.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/mesa-postres-boda-tarta-candelabros-salon.avif" alt="Set de portavelas de cristal y candelabros dorados en boda elegante CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/cena-gala-mesa-mirror-candelabros.avif" alt="Candelabro de tres brazos dorado con flores en mesa de boda" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/mesa-imperial-gala-candelabros-boda.avif" alt="Votivas de cristal con velas LED sobre barra de bebidas" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Portavelas Decorativos</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre los Portavelas Decorativos"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Cuántas piezas necesito, velas incluidas o no, acabados y combinaciones. Aquí resolvemos las dudas más frecuentes antes de reservar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te respondemos al instante sobre disponibilidad y precios.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre los portavelas decorativos para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos cuántas mesas tienes, el estilo de tu evento y la fecha — cotización en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Accesorios decorativos y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Accesorios Decorativos</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa la decoración de tu evento:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
