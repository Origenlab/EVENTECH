---
/**
 * ─── Accesorios Decorativos — Pagina de Producto (Nivel 4) ───
 * Bases para centros de mesa, portavelas, atriles, marcos y
 * senalizacion en acabados dorado, plateado, cobre y cristal.
 *
 * Jerarquia: Servicios > Mobiliario > Barras > Accesorios Decorativos
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Accesorios Decorativos" },
];

const faqs = [
  { question: "¿Cuántas piezas necesito por mesa?", answer: 'La configuración estándar es <strong>1 base para centro de mesa + 2 a 4 portavelas por mesa</strong>. Para mesas redondas de 150 cm sugerimos 3 portavelas; para mesas rectangulares de 240 cm, 4 a 6 portavelas distribuidas a lo largo. Nuestros asesores te ayudan con la cantidad exacta según tu layout.' },
  { question: "¿Los paquetes temáticos incluyen suficientes piezas?", answer: 'Sí. Cada paquete temático incluye piezas para <strong>10 a 30 mesas</strong> según el tamaño seleccionado. Incluye bases de centro de mesa, portavelas, elementos decorativos y señalización básica. Puedes agregar piezas individuales adicionales con descuento sobre precio unitario.' },
  { question: "¿Se pueden personalizar los accesorios?", answer: 'Sí. Ofrecemos <strong>personalización con viniles decorativos, grabado en cristal y acabados en colores especiales</strong>. Los números de mesa se pueden hacer en acrílico con tipografía personalizada. Toda personalización requiere <strong>2 semanas de anticipación</strong>. Consulta opciones y precios con tu asesor.' },
  { question: "¿Las velas están incluidas con los portavelas?", answer: 'Los portavelas y votivas se rentan como <strong>contenedores sin velas</strong>. Sin embargo, ofrecemos paquetes con velas LED incluidas (más seguras y reutilizables) o podemos recomendarte proveedores de velas naturales. Las velas LED son la opción preferida en venues que no permiten fuego real.' },
  { question: "¿Puedo mezclar piezas de diferentes paquetes temáticos?", answer: 'Absolutamente. Los paquetes son sugerencias curadas, pero puedes <strong>combinar piezas de cualquier línea</strong>. La mezcla más popular es bases Elegantes (dorado) con portavelas Románticos (cristal) para bodas clásicas. Nuestros asesores te guían para crear combinaciones armoniosas.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Para piezas individuales, <strong>1 a 2 semanas</strong> es suficiente. Para paquetes temáticos completos o eventos de 20+ mesas, recomendamos <strong>3 semanas</strong>. Piezas personalizadas requieren <strong>4 semanas</strong>. En temporada de bodas (mayo-junio, noviembre-diciembre), reserva con mayor anticipación.' },
];

const specs = [
  { label: "Bases centros de mesa", value: "Cilíndricas, cuadradas, candelabro (40-80 cm)" },
  { label: "Portavelas", value: "Votivas cristal, cilindros, candelabros de 3 y 5 brazos" },
  { label: "Atriles", value: "Madera rústica, metal dorado, acrílico transparente" },
  { label: "Marcos", value: "Vintage dorado, moderno negro, rústico madera" },
  { label: "Acabados disponibles", value: "Dorado, Plateado, Cobre envejecido, Cristal" },
  { label: "Señalización", value: "Letras luminosas, números de mesa, pizarras" },
  { label: "Paquetes temáticos", value: "Romántico, Rústico, Moderno, Elegante" },
  { label: "Pedestales", value: "Exhibición de pastel, arreglos florales (60-100 cm)" },
  { label: "Biombos", value: "Separadores de ambiente en madera, metal o tela" },
  { label: "Personalización", value: "Viniles, grabado, colores especiales (2 semanas)" },
];

const sidebarNav = [
  { name: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Mesas de Postres", href: "/servicios/mobiliario/barras/postres/" },
  { name: "Periqueras y Bancos", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Accesorios Decorativos", href: null, active: true },
];

const sidebarRelated = [
  { name: "Mantelería y Textiles", href: "/servicios/accesorios/manteleria-textiles/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas de Diseño", href: "/servicios/mobiliario/sillas/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];

const reviews = [
  { author: "Carolina Estrada", text: "Los centros de mesa dorados y las votivas de cristal fueron el toque perfecto para nuestra boda. El paquete Romántico incluyó todo lo necesario para 25 mesas. El resultado fue digno de revista. Servicio impecable de principio a fin.", rating: 5, date: "2025-11-30" },
  { author: "Elena Rivas", text: "Rentamos el paquete Rústico para nuestra boda en hacienda. Las bases de cobre envejecido con los faroles de cristal crearon un ambiente mágico. Los atriles de madera para los menús fueron un detalle hermoso. Todo llegó impecable.", rating: 5, date: "2025-10-12" },
  { author: "Adrián Navarro", text: "Para nuestra gala corporativa usamos bases espejadas y candelabros de 5 brazos. El efecto fue de hotel cinco estrellas. Los números de mesa en acrílico con nuestra tipografía fueron un plus genial. Profesionalismo total.", rating: 5, date: "2025-09-01" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Accesorios Decorativos para Eventos en CDMX",
    description: "Renta de accesorios decorativos para eventos: bases para centros de mesa, portavelas, atriles, marcos y señalización en CDMX. Acabados dorado, plateado y cobre. Desde $30 por pieza.",
    url: "/servicios/mobiliario/barras/accesorios-decorativos/",
    priceRange: { min: 30, max: 3000 },
    reviews,
    ratingValue: 5,
    reviewCount: 210,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Accesorios Decorativos", url: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Accesorios Decorativos para Eventos en CDMX"
  description="Renta de accesorios decorativos para eventos: bases para centros de mesa, portavelas, atriles, marcos y señalización en CDMX. Acabados dorado, plateado y cobre. Desde $30 por pieza."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Los detalles que hacen la diferencia"
    title='Renta de <span class="highlight">Accesorios Decorativos</span> para Eventos en CDMX'
    subtitle="Bases para centros de mesa, portavelas y votivas, atriles y caballetes, marcos decorativos y señalización. Acabados en dorado, plateado, cobre y cristal. Piezas individuales o paquetes temáticos. Entrega y montaje profesional incluidos."
    primaryCTA={{ label: "Cotiza tus accesorios", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar accesorios decorativos para mi evento` }}
    cards={[
      {
        title: "Catálogo completo de accesorios en dorado, plateado, cobre y cristal",
        content: "<strong>Renta de accesorios decorativos</strong> con el catálogo más completo para eventos en CDMX. <strong>Bases para centros de mesa</strong> cilíndricas, cuadradas y tipo candelabro de 40 a 80 cm en dorado, plateado, cobre y cristal. <strong>Portavelas y votivas</strong> en cristal transparente, dorado y espejo para crear ambientes íntimos. <strong>Atriles y caballetes</strong> de madera y metal para señalización, menús y distribución — cada pieza seleccionada para elevar cualquier estilo decorativo.",
      },
      {
        title: "Piezas individuales o paquetes temáticos con asesoría decorativa",
        content: "<strong>Servicio integral de accesorios</strong> con renta individual o paquetes temáticos prediseñados: Romántico, Rústico, Moderno y Elegante. Cada paquete incluye selección curada de bases, portavelas, marcos y elementos complementarios. Nuestros asesores te guían para elegir las piezas que mejor complementan tu mobiliario, mantelería y estilo de evento. Entrega y montaje profesional incluidos en CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas accesorios decorativos para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con opciones de accesorios para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Barras y Complementos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas accesorios decorativos?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar accesorios decorativos para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Accesorios Decorativos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Bases y Centros de Mesa -->
          <section class="section section--alt" aria-labelledby="bases-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El corazón de cada mesa</span>
                <h2 class="showcase__title" id="bases-heading">Bases y Centros de Mesa</h2>
                <p class="showcase__subtitle">Bases cilíndricas, cuadradas y tipo candelabro en alturas de 40 a 80 cm con acabados premium en dorado, plateado, cobre y cristal.</p>
                <p class="showcase__text">Las <strong>bases para centros de mesa</strong> son el elemento que define la personalidad visual de cada mesa en tu evento. Nuestra colección incluye bases <strong>cilíndricas</strong> elegantes, <strong>cuadradas</strong> contemporáneas y tipo <strong>candelabro</strong> clásicas en alturas de 40 a 80 cm. Acabados en dorado champagne, plateado espejo, cobre envejecido y cristal transparente — cada pieza diseñada para sostener arreglos florales, velas y composiciones decorativas con estabilidad y estilo.</p>
                <p class="showcase__text">La <strong>base correcta transforma una mesa ordinaria en una pieza de diseño</strong>. Para bodas elegantes, las bases doradas de 60 cm con arreglos florales son las más solicitadas. Para eventos corporativos, las bases cuadradas plateadas proyectan modernidad. Combina con nuestros <a href="/servicios/accesorios/manteleria-textiles/">manteles y textiles</a> para un resultado profesional y cohesivo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Bases</span>
                  <span class="showcase__tag">Centros de Mesa</span>
                  <span class="showcase__tag">Dorado</span>
                  <span class="showcase__tag">Plateado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Bases y Centros
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
                  <span>Bases y Centros de Mesa</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Portavelas y Votivas -->
          <section class="section section--alt" aria-labelledby="portavelas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ambientes íntimos y cálidos</span>
                <h2 class="showcase__title" id="portavelas-heading">Portavelas y Votivas</h2>
                <p class="showcase__subtitle">Votivas de cristal, cilindros para velas flotantes, candelabros de 3 y 5 brazos y faroles con marco metálico.</p>
                <p class="showcase__text">Nuestra colección de <strong>portavelas y votivas</strong> crea puntos de luz cálidos que transforman la atmósfera de cualquier mesa. <strong>Votivas de cristal transparente</strong> en 3 tamaños, <strong>cilindros de cristal</strong> para velas flotantes, <strong>candelabros de 3 y 5 brazos</strong> en dorado y plateado, y <strong>faroles de cristal</strong> con marco metálico — cada pieza diseñada para generar ambientes íntimos y acogedores que invitan a la conversación.</p>
                <p class="showcase__text">Los portavelas son el complemento perfecto para las bases de centro de mesa. La combinación más popular para bodas es <strong>base dorada + 3 votivas de cristal por mesa</strong>, creando un efecto de luz envolvente al atardecer. Ofrecemos paquetes con <strong>velas LED incluidas</strong> para venues que no permiten fuego real — misma estética cálida con total seguridad. Combina con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente mágico.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Portavelas</span>
                  <span class="showcase__tag">Votivas</span>
                  <span class="showcase__tag">Candelabros</span>
                  <span class="showcase__tag">Cristal</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Portavelas
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
                  <span>Portavelas y Votivas</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Atriles y Señalización -->
          <section class="section section--alt" aria-labelledby="atriles-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Orientación con estilo</span>
                <h2 class="showcase__title" id="atriles-heading">Atriles y Señalización</h2>
                <p class="showcase__subtitle">Atriles de madera rústica, caballetes de metal dorado, números de mesa en acrílico y pizarras con marco para menús.</p>
                <p class="showcase__text"><strong>Atriles de madera rústica</strong> para bodas campestres, <strong>caballetes de metal dorado</strong> para eventos elegantes y <strong>bases de acrílico transparente</strong> para celebraciones contemporáneas — nuestra línea de señalización combina funcionalidad con diseño. <strong>Números de mesa</strong> en acrílico, madera o espejo con tipografía personalizable. <strong>Pizarras con marco</strong> para menús y bienvenida que añaden un toque artesanal y personal a cada rincón del evento.</p>
                <p class="showcase__text">Complementa con <strong>letras luminosas decorativas</strong> para la mesa de regalos o la zona de fotos. Todo diseñado para orientar a los invitados con elegancia, desde la entrada del venue hasta la distribución de mesas. Los números de mesa en acrílico con tipografía personalizada son el detalle favorito de wedding planners — se producen en <strong>2 semanas</strong> con el diseño que elijas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Atriles</span>
                  <span class="showcase__tag">Señalización</span>
                  <span class="showcase__tag">Números Mesa</span>
                  <span class="showcase__tag">Pizarras</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Señalización
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
                  <span>Atriles y Señalización</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Paquete Temático Completo -->
          <section class="section section--alt" aria-labelledby="paquete-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Selección curada por expertos</span>
                <h2 class="showcase__title" id="paquete-heading">Paquete Temático Completo</h2>
                <p class="showcase__subtitle">4 paquetes prediseñados con bases, portavelas, señalización y elementos complementarios para 10 a 30 mesas.</p>
