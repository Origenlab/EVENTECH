---
/**
 * ─── Barra de Bebidas Industrial Metal+Madera — Página de Variante ───
 * Barra industrial combinación metal negro y tablero madera para eventos modernos en CDMX.
 * Desde $3,000 por evento.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { label: "Industrial" },
];

const galleryImages = [
  { src: "/images/mobiliario/barra-industrial-metal-madera-evento-01.avif", alt: "Barra industrial metal negro y madera en evento CDMX" },
  { src: "/images/mobiliario/barra-industrial-metal-madera-corporativo-02.avif", alt: "Barra industrial para evento corporativo sala de conferencias" },
  { src: "/images/mobiliario/barra-industrial-metal-madera-detalle-03.avif", alt: "Detalle estructura metal negro con tablero madera barra industrial" },
  { src: "/images/mobiliario/barra-industrial-metal-madera-gala-04.avif", alt: "Barra industrial en gala nocturna CDMX" },
  { src: "/images/mobiliario/barra-industrial-metal-madera-loft-05.avif", alt: "Barra metal madera en venue tipo loft industrial" },
  { src: "/images/mobiliario/barra-industrial-metal-madera-boda-06.avif", alt: "Barra estilo industrial en boda contemporánea" },
];

const faqs = [
  {
    question: "¿Qué combinación de materiales tiene la barra industrial?",
    answer: "La barra combina <strong>estructura tubular de acero al carbón pintado en negro mate</strong> con tablero superior en <strong>madera de roble barnizada</strong>. La estructura metálica incluye travesaños decorativos visibles y estantes intermedios de madera — el look industrial donde el metal y la madera se complementan. El negro mate del metal no refleja la luz, lo que da un efecto visual más sobrio y sofisticado que el acero inoxidable brillante."
  },
  {
    question: "¿La barra industrial funciona en venues de arquitectura moderna o solo en lofts?",
    answer: "Funciona perfectamente en <strong>venues contemporáneos, rooftops, lofts industriales y salones de eventos modernos</strong>. También la usamos con éxito en bodas de estilo minimalista o bodas con paleta blanco+negro donde se quiere un elemento de contraste. No recomendamos la barra industrial para haciendas de estilo colonial o eventos muy tradicionales — para esos casos la <a href='/servicios/mobiliario/barras/barras-bebidas/madera-rustica/'>barra rústica</a> es más coherente con el estilo del venue."
  },
  {
    question: "¿Cuánto pesa y qué tan difícil es el montaje en pisos superiores?",
    answer: "La barra pesa aproximadamente <strong>45 kg</strong> — manejable por dos personas sin equipo especial. Se desmonta en tres módulos para transporte, lo que facilita subir en elevadores o escaleras. El montaje toma 45-60 minutos. Nuestro equipo de instalación tiene experiencia en venues con acceso complicado — si el venue tiene alguna restricción de acceso, indícanoslo al momento de cotizar y lo planificamos con anticipación."
  },
  {
    question: "¿La barra industrial se puede personalizar con el logo de una marca?",
    answer: "Sí. Para eventos corporativos, ofrecemos la opción de <strong>agregar una pieza metálica con el logo recortado en láser</strong> en el panel frontal de la barra. El costo adicional depende del diseño y se cotiza por separado. Necesitamos el archivo del logo en vectores (AI, SVG o EPS) con al menos <strong>10 días de anticipación</strong> para fabricar la pieza. Es muy solicitado para lanzamientos de marca y eventos de patrocinadores."
  },
  {
    question: "¿Cuál es el precio de la barra industrial y qué incluye?",
    answer: "La barra industrial tiene un precio <strong>desde $3,000 por evento</strong>. Incluye barra completa (estructura metálica + tablero madera + estantes internos), entrega en CDMX, montaje en sitio, nivelación y desmontaje al final del evento. No incluye bartenders, bebidas ni personalización de logo. Si necesitas periqueras que combinen con el estilo industrial, te recomendamos las <a href='/servicios/mobiliario/barras/periqueras/metal/'>periqueras de metal industrial</a> para una zona de bar coherente."
  },
];

const specs = [
  { label: "Estructura", value: "Acero al carbón tubular pintado negro mate" },
  { label: "Tablero superior", value: "Madera de roble barnizada — 60mm de espesor" },
  { label: "Dimensiones", value: "2m largo × 60cm profundidad × 110cm altura" },
  { label: "Peso total", value: "45 kg (3 módulos desmontables)" },
  { label: "Estantes internos", value: "2 niveles en madera — visibles en estructura frontal" },
  { label: "Personalización", value: "Logo en metal recortado en láser (cargo adicional)" },
  { label: "Acabado metal", value: "Negro mate anti-reflejo" },
  { label: "Acabado madera", value: "Roble natural barnizado — veta visible" },
  { label: "Armado", value: "45-60 minutos" },
  { label: "Precio desde", value: "$3,000 por evento (incluye montaje y desmontaje)" },
];

const reviews = [
  { author: "Hernán Villalba", text: "Para la convención anual de nuestra empresa, la barra industrial fue la elección perfecta. Pegó perfectamente con el venue tipo loft que teníamos. El logo en metal recortado fue un detalle que sorprendió a todos.", rating: 5, date: "2025-11-25" },
  { author: "Isabella García", text: "Boda con estética industrial en un almacén rehabilitado. La barra de metal y madera era exactamente la pieza que necesitábamos para que todo fuera coherente. Llegó puntual y quedó perfecta.", rating: 5, date: "2025-10-18" },
  { author: "Marco Orozco", text: "La usamos en un rooftop para un evento de lanzamiento. El acabado negro mate se veía muy elegante de noche con la iluminación ambiental. Resistente, estable y sin una sola queja.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Barra de Bebidas Industrial Metal y Madera para Eventos CDMX",
    description: "Barra industrial metal negro+madera para bodas modernas y eventos corporativos en CDMX. Personalización con logo disponible. Desde $3,000.",
    url: "/servicios/mobiliario/barras/barras-bebidas/industrial/",
    priceRange: { min: 3000, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 22,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Barras de Bebidas", url: "/servicios/mobiliario/barras/barras-bebidas/" },
    { name: "Industrial", url: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
  { name: "Acrílico Iluminado LED", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
  { name: "Industrial Metal+Madera", href: null, active: true },
];

const sidebarRelated = [
  { name: "Periqueras Metal Industrial", href: "/servicios/mobiliario/barras/periqueras/metal/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];
---

<PageLayout
  title="Renta Barra de Bebidas Industrial Metal"
  description="Renta barra industrial metal negro+madera en CDMX — para bodas modernas, eventos corporativos y lofts. Personalización con logo disponible. Desde $3,000."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La barra que define el estilo de los eventos contemporáneos en CDMX"
    title='Barra de Bebidas <span class="highlight">Industrial Metal+Madera</span> — Renta en CDMX'
    subtitle="Estructura tubular de acero negro mate con tablero de roble barnizado. Para bodas de estilo contemporáneo, eventos corporativos en venues modernos y lanzamientos de marca donde el detalle industrial dice más que cualquier decoración."
    primaryCTA={{ label: "Cotizar barra industrial", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas industrial metal+madera para mi evento` }}
    cards={[
      {
        title: "Metal negro mate + roble barnizado: la combinación que define el diseño de eventos moderno",
        content: "La <strong>barra industrial</strong> nació de una tendencia que ya es estándar en diseño de interiores de alto nivel: la combinación de metal industrial con madera cálida. El acero al carbón negro mate tiene una presencia visual que el acero inoxidable brillante no puede igualar — más sobrio, más sofisticado, más fotogénico. El tablero de <strong>roble de 60mm</strong> con veta natural visible es el contrapunto cálido que equilibra la frialdad del metal. Dos estantes intermedios de madera visibles en la estructura frontal completan la estética.",
      },
      {
        title: "Logo en metal, montaje en 60 min y desde $3,000 con todo incluido",
        content: "Para eventos corporativos, la barra industrial se puede personalizar con <strong>logo recortado en láser</strong> en el panel frontal — el tipo de detalle que hace que el evento se vea producido profesionalmente y no como una renta genérica. Sin personalización, el precio es <strong>desde $3,000</strong> con entrega, montaje, nivelación y desmontaje incluidos. La barra desmonta en 3 módulos para facilitar el acceso a venues con escaleras o pasillos angostos.",
      },
    ]}
  />

  <CTABanner
    headline="La barra industrial que hace que tu evento corporativo parezca una producción de agencia — cotiza sin compromiso"
    subheadline="Metal negro mate + roble · Logo personalizado disponible · Desde $3,000 con montaje"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Barra industrial para tu evento en CDMX</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas industrial metal+madera para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Barra Industrial en Eventos Reales</h2>
            <p class="section__subtitle">Eventos corporativos, bodas contemporáneas y lanzamientos de marca en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Barra Industrial Metal+Madera</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="Metal y madera: por qué este dúo domina el diseño de eventos corporativos"
    headingId="descripcion-heading"
    badge="El contraste que define el diseño moderno de eventos"
    tags={["Metal Negro Mate", "Roble Natural", "Eventos Corporativos", "Bodas Contemporáneas"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La combinación de metal industrial y madera cálida es la fórmula de diseño de interiores que más ha crecido en la última década — y se trasladó naturalmente al diseño de eventos. El metal negro mate <strong>aporta estructura y seriedad</strong>, la madera aporta calidez y humanidad. Juntos comunican: sofisticado pero accesible, serio pero no frío.</p>
      <p class="showcase__text">Para eventos corporativos, la barra industrial es especialmente potente porque <strong>refuerza la identidad de marca sin gritar</strong>. La opción de logo recortado en láser en el panel frontal hace que la barra sea literalmente un activo de comunicación del evento — cada foto que se tome frente a la barra tiene la marca visible.</p>
      <p class="showcase__text">En bodas contemporáneas, la barra industrial funciona como ancla de estilo para toda la decoración. La combinamos frecuentemente con las <strong>periqueras de metal</strong> y las mesas con patas negras para crear una zona bar con coherencia visual total. El resultado es el tipo de setup que aparece en Pinterest y que los guests fotografían antes de la primera bebida.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-industrial-showcase-main.avif" alt="Barra industrial metal negro y roble en evento corporativo CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-industrial-showcase-02.avif" alt="Detalle logo corporativo recortado en láser barra industrial" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-industrial-showcase-03.avif" alt="Barra industrial con periqueras metal en venue tipo loft" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Barra Industrial Metal+Madera</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Barra Industrial Metal+Madera"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Metal negro, roble natural, opción de logo personalizado y montaje profesional. Resolvemos las dudas más frecuentes sobre la barra más versátil para eventos modernos.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te enviamos fotos del logo personalizado en barra y ejemplos de eventos pasados.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la barra de bebidas industrial metal y madera`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Logo personalizado</h3>
                  <p class="faq-sidebar-card__text">Envíanos tu logo en vectores — cotizamos la pieza en metal recortado en láser para el panel frontal.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Solicitar en formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes barras y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa tu zona de bar industrial:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
