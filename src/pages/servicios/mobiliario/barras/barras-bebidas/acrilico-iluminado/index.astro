---
/**
 * ─── Barra de Bebidas Acrílico Iluminado LED — Página de Variante ───
 * Barra acrílico con iluminación LED RGB para eventos modernos y galas en CDMX.
 * Desde $3,500 por evento.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { label: "Acrílico Iluminado" },
];

const galleryImages = [
  { src: "/images/mobiliario/barra-bebidas-04.avif", alt: "Barra acrílico LED iluminada en gala nocturna CDMX" },
  { src: "/images/mobiliario/candy-bar-acrilico-led-noche.avif", alt: "Barra acrílico con luz blanca en evento corporativo" },
  { src: "/images/mobiliario/barra-bebidas-02.avif", alt: "Barra acrílico LED RGB colores personalizados" },
  { src: "/images/mobiliario/barra-bebidas-01.avif", alt: "Barra LED acrílico en boda contemporánea CDMX" },
  { src: "/images/mobiliario/barra-bebidas-03.avif", alt: "Detalle iluminación LED debajo de barra acrílico" },
  { src: "/images/mobiliario/barra-bebidas-05.avif", alt: "Barra acrílico iluminada en salón de lujo" },
];

const faqs = [
  {
    question: "¿Cuántos colores de iluminación LED tiene la barra acrílica?",
    answer: "La barra incluye un <strong>sistema LED RGB con 16 colores preconfigurados</strong> y modo multicolor dinámico. Los más solicitados son: blanco puro (para bodas modernas), azul cobalto (galas corporativas), morado (fiestas temáticas) y el modo multicolor que cambia automáticamente. El control remoto viene incluido y se entrega al organizador del evento para que ajuste el color durante la noche según el momento. No requiere intervención técnica — cualquier persona lo puede operar."
  },
  {
    question: "¿La barra de acrílico necesita instalación eléctrica especial?",
    answer: "No. La barra funciona con <strong>cable de 110V estándar</strong> — la misma toma de corriente de cualquier salón o hacienda. El cable de alimentación tiene 3 metros de longitud, suficiente para llegar a la toma más cercana sin extensiones visibles. Si el venue no tiene toma accesible, también ofrecemos una versión con <strong>batería recargable de 8 horas de autonomía</strong> con cargo adicional de $500. Indicanoslo al cotizar."
  },
  {
    question: "¿El acrílico se raya o se ve opaco con el tiempo?",
    answer: "El material es <strong>acrílico de celda colada de 10mm de espesor</strong> — el mismo grado que se usa en exhibits de museo y vitrinas de joyería. Es significativamente más resistente al rayado que el acrílico extruido común. Cada barra se revisa y pule antes de cada evento. Si hay algún micro-rayado, el área de calidad lo corrige antes de la entrega. La transparencia del material es lo que permite que la luz LED se distribuya de forma uniforme y espectacular."
  },
  {
    question: "¿Cuánto mide la barra acrílica y para cuántos invitados aplica?",
    answer: "La barra estándar mide <strong>2 metros de largo × 60 cm de profundidad × 110 cm de altura</strong>. Es el tamaño óptimo para eventos de 100-200 invitados con un bartender profesional. Para eventos más grandes, se pueden configurar <strong>dos barras en paralelo o en L</strong> con conector de esquina incluido. La superficie translúcida del tablero superior es también de acrílico iluminado — todo el mueble brilla de manera uniforme."
  },
  {
    question: "¿La barra LED se ve bien en el exterior o solo en interiores?",
    answer: "La iluminación es más impactante en <strong>interiores y exteriores nocturnos</strong> con poca luz ambiental — ahí la barra se convierte en el foco visual del espacio. Para exteriores diurnos, la luz LED no es tan visible pero el acrílico transparente sigue siendo un elemento visual de alto impacto. Si tu evento es de día al aire libre y buscas máximo impacto visual, la <a href='/servicios/mobiliario/barras/barras-bebidas/madera-rustica/'>barra rústica</a> o la <a href='/servicios/mobiliario/barras/barras-bebidas/industrial/'>barra industrial</a> pueden ser más adecuadas."
  },
];

const specs = [
  { label: "Material", value: "Acrílico celda colada 10mm + estructura acero inoxidable" },
  { label: "Dimensiones", value: "2m largo × 60cm profundidad × 110cm altura" },
  { label: "Sistema LED", value: "RGB 16 colores + multicolor dinámico con control remoto" },
  { label: "Consumo eléctrico", value: "45W — toma 110V estándar" },
  { label: "Cable de alimentación", value: "3 metros incluido" },
  { label: "Batería opcional", value: "Sí, 8 horas de autonomía (+$500)" },
  { label: "Tablero superior", value: "Acrílico iluminado — translúcido" },
  { label: "Estantes internos", value: "2 niveles en estructura inferior para botellas" },
  { label: "Armado", value: "45-60 minutos incluyendo conexión eléctrica" },
  { label: "Precio desde", value: "$3,500 por evento (incluye montaje, conexión y desmontaje)" },
];

const reviews = [
  { author: "Carlos Mendoza", text: "La barra LED fue el elemento que definió la estética de toda nuestra gala. La pusimos en azul y fue una locura — todos querían tomarse fotos ahí. El control remoto es súper fácil de usar.", rating: 5, date: "2025-12-01" },
  { author: "Andrea Leyva", text: "Para el lanzamiento de producto de nuestra empresa, la barra acrílica iluminada en blanco era exactamente lo que necesitábamos. Proyectábamos el logo en la pared de atrás y la barra encuadraba perfectamente.", rating: 5, date: "2025-11-15" },
  { author: "Paola Serrano", text: "Boda de noche en salón, pusimos la barra en morado que era el color de nuestra boda. El acrílico era transparente y brillante, sin un solo rayón. Quedó espectacular en fotos y video.", rating: 5, date: "2025-10-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Barra de Bebidas Acrílico Iluminado LED para Eventos CDMX",
    description: "Barra de bebidas acrílico con iluminación LED RGB para galas y bodas modernas en CDMX. 16 colores, control remoto incluido. Desde $3,500.",
    url: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/",
    priceRange: { min: 3500, max: 5500 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Barras de Bebidas", url: "/servicios/mobiliario/barras/barras-bebidas/" },
    { name: "Acrílico Iluminado", url: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
  { name: "Acrílico Iluminado LED", href: null, active: true },
  { name: "Industrial Metal+Madera", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
];

const sidebarRelated = [
  { name: "Periqueras para Barra", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];
---

<PageLayout
  title="Renta Barra de Bebidas Acrílico Iluminado LED"
  description="Renta barra de bebidas acrílico LED RGB en CDMX — 16 colores, control remoto incluido. Para bodas modernas, galas y eventos corporativos. Desde $3,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <HeroPage
    badge="La barra que se convierte en el foco visual de tu evento nocturno"
    title='Barra de Bebidas <span class="highlight">Acrílico Iluminado LED</span> — Renta en CDMX'
    subtitle="Barra translúcida en acrílico de celda colada 10mm con sistema LED RGB de 16 colores y control remoto. Para bodas contemporáneas, galas corporativas y fiestas temáticas donde el impacto visual es prioridad."
    primaryCTA={{ label: "Cotizar barra LED", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas acrílico iluminado LED para mi evento` }}
    cards={[
      {
        title: "16 colores, control remoto y acrílico que brilla de manera uniforme",
        content: "La <strong>barra acrílico iluminada</strong> está fabricada en acrílico de celda colada de 10mm — el mismo grado que joyerías y museos usan para sus vitrinas. La diferencia con el acrílico barato es inmediata: sin burbujas, sin deformaciones, con una claridad cristalina que hace que la luz LED se distribuya de forma perfectamente uniforme. El tablero superior también es acrílico iluminado — <strong>todo el mueble brilla</strong>, no solo la parte frontal. 16 colores preconfigurados con control remoto para que tú decidas el ambiente de cada momento.",
      },
      {
        title: "110V estándar, 3m de cable, sin instalación eléctrica especial",
        content: "No necesitas un electricista ni una instalación especial. La barra se conecta a cualquier <strong>toma de 110V estándar</strong> con el cable de 3 metros incluido. El control remoto viene en la entrega para que el organizador del evento maneje el color y modo durante la noche. Si el venue no tiene toma accesible o quieres la barra en medio de un jardín sin cableado visible, ofrecemos la versión con <strong>batería de 8 horas por $500 adicionales</strong>. <strong>Desde $3,500</strong> con montaje, conexión, desmontaje y control remoto.",
      },
    ]}
  />

  <CTABanner
    headline="La barra LED que transforma tu gala en un espectáculo visual — cotiza sin compromiso"
    subheadline="16 colores RGB · Control remoto incluido · 110V estándar · Opción batería disponible"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Barra LED acrílico para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas acrílico iluminado LED para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Barra Acrílico LED en Eventos Reales</h2>
            <p class="section__subtitle">Galas corporativas, bodas contemporáneas y fiestas temáticas en CDMX</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Barra Acrílico Iluminado LED</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la barra LED es el elemento favorito de las galas modernas?"
    headingId="descripcion-heading"
    badge="RGB que se ajusta al mood de tu evento en segundos"
    tags={["Acrílico LED RGB", "Galas Corporativas", "Bodas Modernas", "Eventos Nocturnos"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">En un evento nocturno, la iluminación lo decide todo — y la barra acrílica LED es el elemento que <strong>trabaja en dos niveles simultáneamente</strong>: como mueble funcional donde se sirven las bebidas y como instalación lumínica que define la paleta de color del espacio. Cuando la pones en azul cobalto en una sala oscura, todo el ambiente se vuelve sofisticado sin necesidad de otros elementos.</p>
      <p class="showcase__text">El acrílico de <strong>celda colada de 10mm</strong> no es el material translúcido genérico que se vende en ferreterías. Es el mismo grado que las joyerías usan para sus vitrinas iluminadas — sin micro-burbujas, sin variaciones de densidad, con una distribución de luz perfectamente uniforme. La diferencia se nota inmediatamente en la calidad de las fotos y el video del evento.</p>
      <p class="showcase__text">Combinamos la barra LED con las <strong>periqueras de acrílico</strong> para crear una zona completa de bar donde todo el mobiliario es traslúcido e iluminado — el efecto en fotografía de evento es espectacular y muy solicitado por planners de bodas de lujo.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-01.avif" alt="Barra acrílico LED iluminada en azul en gala nocturna CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-06.avif" alt="Control remoto y colores disponibles barra LED" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/candy-bar-acrilico-led-noche.avif" alt="Barra acrílico con periqueras iluminadas en evento" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Barra Acrílico Iluminado LED</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Barra Acrílico Iluminado LED"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "16 colores RGB, conexión estándar 110V y acrílico de calidad premium. Aquí resolvemos las dudas más frecuentes antes de confirmar la barra para tu evento.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te enviamos video de la barra en funcionamiento con los distintos colores.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la barra de bebidas acrílico iluminado LED`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos tipo de evento, fecha y venue — precio confirmado en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes barras y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa tu zona de bar LED:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Barra LED acrílico para tu gala o boda en CDMX</p>
