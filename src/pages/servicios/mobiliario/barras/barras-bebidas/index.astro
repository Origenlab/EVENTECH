---
/**
 * ─── Barras de Bebidas — Página de Producto (Nivel 4) ───
 * Barras profesionales en madera artesanal, acrílico LED e industrial
 * para eventos en CDMX. Tamaños de 2m y 3m.
 *
 * Jerarquía: Servicios > Mobiliario > Barras > Barras de Bebidas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Barras de Bebidas" },
];

const faqs = [
  { question: "¿Qué tamaño de barra necesito para mi evento?", answer: 'La regla general es: <strong>barra de 2 metros para eventos de hasta 150 personas</strong> y <strong>barra de 3 metros para 150 a 500+ personas</strong>. Para eventos superiores a 300 invitados, recomendamos 2 barras distribuidas estratégicamente para evitar filas largas. Nuestros asesores te ayudan a elegir según tu venue y formato de servicio.' },
  { question: "¿La barra incluye cristalería y accesorios de bar?", answer: 'Las barras se rentan como estructura completa con superficie, repisa y área de preparación. La cristalería (copas, vasos, hieleras, cocteleras) se cotiza por separado o como paquete con descuento. Consulta nuestro <a href="/servicios/catering/vajilla-cristaleria/">servicio de vajilla y cristalería</a> para opciones completas.' },
  { question: "¿La barra LED se puede personalizar con los colores de mi marca?", answer: 'Sí. La barra de <strong>Acrílico LED tiene 16 colores programables</strong> con control remoto incluido. Puedes fijar un color institucional, alternar entre colores o programar secuencias automáticas. Para personalización avanzada (logos en vinilo, wraps completos), solicítalo con 2 semanas de anticipación.' },
  { question: "¿Las barras funcionan en exteriores?", answer: 'Sí. Las barras de Madera e Industrial son resistentes a uso exterior bajo condiciones normales. La barra de Acrílico LED funciona en exteriores siempre que la instalación eléctrica esté protegida. Para todos los modelos, recomendamos ubicación bajo techo (carpa o terraza) para proteger de lluvia directa.' },
  { question: "¿Puedo agregar una barra de servicio trasera?", answer: 'Sí. Ofrecemos <strong>módulos de servicio trasero</strong> que se acoplan a cualquier barra: mesa auxiliar para preparación, contenedor de hielo industrial, organizador de botellas y dispensador de agua/refrescos. Estos módulos se cotizan por separado y se montan junto con la barra.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos <strong>2 a 3 semanas de anticipación</strong>. Las barras de Acrílico LED son las más solicitadas y se agotan primero en temporada alta (noviembre-febrero). Para eventos grandes que requieren doble barra o configuraciones especiales, reserva con <strong>1 mes de anticipación</strong>.' },
];

const specs = [
  { label: "Estilos", value: "Madera Artesanal, Acrílico LED, Industrial" },
  { label: "Tamaño estándar", value: "2 metros (hasta 150 personas)" },
  { label: "Tamaño grande", value: "3 metros (150-500+ personas)" },
  { label: "Altura", value: "110 cm (altura profesional de barra)" },
  { label: "Profundidad", value: "60 cm (superficie + área de preparación)" },
  { label: "Superficie", value: "Anti-derrames con acabado resistente" },
  { label: "Incluye", value: "Repisa trasera + área de preparación + posa-vasos" },
  { label: "LED (modelo Acrílico)", value: "16 colores programables con control remoto" },
  { label: "Resistencia superficie", value: "80 kg distribuidos" },
  { label: "Mantenimiento", value: "Limpieza y sanitización incluida pre-evento" },
];

const sidebarNav = [
  { name: "Barras de Bebidas", href: null, active: true },
  { name: "Mesas de Postres", href: "/servicios/mobiliario/barras/postres/" },
  { name: "Periqueras y Bancos", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
];

const sidebarRelated = [
  { name: "Mesas Cocktail", href: "/servicios/mobiliario/mesas/cocktail/" },
  { name: "Vajilla y Cristalería", href: "/servicios/catering/vajilla-cristaleria/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Refrigeración", href: "/servicios/catering/refrigeracion/" },
];

const reviews = [
  { author: "Martín Delgado", text: "La barra de acrílico LED fue el hit de nuestra boda. Programamos los colores de nuestra paleta (dorado y blush) y el efecto fue mágico. Los invitados no paraban de sacar fotos. El montaje fue rápido y el equipo súper profesional.", rating: 5, date: "2025-11-28" },
  { author: "Laura Espinoza", text: "Rentamos una barra de madera de 3 metros para nuestra boda en hacienda. El acabado es hermoso, se veía como mueble artesanal, no como renta. La repisa trasera para las botellas fue súper práctica. Todo impecable.", rating: 5, date: "2025-10-15" },
  { author: "Jorge Villaseñor", text: "Para nuestro festival de cerveza artesanal necesitábamos 2 barras industriales y el resultado fue espectacular. Las tuberías de cobre le dieron el toque perfecto. Logística puntual y montaje profesional. Repetiremos sin duda.", rating: 5, date: "2025-08-22" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Barras de Bebidas para Eventos en CDMX",
    description: "Renta de barras de bebidas profesionales en madera artesanal, acrílico iluminado LED e industrial para eventos en CDMX. Tamaños de 2m y 3m. Desde $1,500. Montaje incluido.",
    url: "/servicios/mobiliario/barras/barras-bebidas/",
    priceRange: { min: 1500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 156,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Barras de Bebidas", url: "/servicios/mobiliario/barras/barras-bebidas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Barras de Bebidas para Eventos en CDMX"
  description="Renta de barras de bebidas profesionales en madera artesanal, acrílico iluminado LED e industrial para eventos en CDMX. Tamaños de 2m y 3m. Desde $1,500. Montaje incluido."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La pieza central de toda celebración"
    title='Renta de <span class="highlight">Barras de Bebidas</span> para Eventos en CDMX'
    subtitle="Barras de bebidas profesionales en 3 estilos: madera artesanal, acrílico con retroiluminación LED y estilo industrial con tuberías de cobre. Tamaños de 2 y 3 metros con superficie anti-derrames, repisa trasera y área de preparación. Montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tu barra", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar barras de bebidas para mi evento` }}
    cards={[
      {
        title: "Tres estilos profesionales en madera, acrílico LED e industrial",
        content: "<strong>Renta de barras de bebidas</strong> con la colección más completa para eventos en CDMX. Barra de <strong>Madera Artesanal</strong> con acabado barnizado natural para bodas rústicas y haciendas. Barra de <strong>Acrílico Iluminado</strong> con retroiluminación LED programable en 16 colores para fiestas y eventos nocturnos. Barra <strong>Industrial</strong> con tuberías de cobre y tablero de madera reciclada para eventos contemporáneos — cada modelo diseñado por profesionales para servicio de alta demanda.",
      },
      {
        title: "Superficie anti-derrames, repisa trasera y montaje profesional",
        content: "<strong>Servicio integral de barras</strong> con superficie de servicio con protección anti-derrames, repisa trasera para exhibición de botellas y área de preparación oculta. Disponibles en <strong>2 metros</strong> (eventos hasta 150 personas) y <strong>3 metros</strong> (eventos de 150 a 500+). Entrega puntual, montaje profesional con nivelación y ajuste, y recolección incluida dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la barra perfecta para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con opciones de barras para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Barras y Complementos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas barras para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar barras de bebidas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Barras de Bebidas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Barra Madera Artesanal -->
          <section class="section section--alt" aria-labelledby="madera-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas y haciendas</span>
                <h2 class="showcase__title" id="madera-heading">Barra Madera Artesanal</h2>
                <p class="showcase__subtitle">Pino barnizado con acabado natural o nogal oscuro. Superficie amplia con bordes redondeados y repisa trasera en 3 niveles.</p>
                <p class="showcase__text">La <strong>barra de madera artesanal</strong> es el modelo favorito para bodas rústicas en haciendas, jardines y salones con decoración natural. Fabricada en pino de primera calidad con acabado barnizado en tono natural o nogal oscuro según tu preferencia. La superficie de servicio es amplia con <strong>bordes redondeados</strong> que combinan seguridad y estética, y la repisa trasera de <strong>3 niveles</strong> permite exhibir botellas premium de forma elegante y organizada.</p>
                <p class="showcase__text">Las patas torneadas incluyen <strong>niveladores ajustables</strong> que garantizan estabilidad perfecta en cualquier tipo de piso: terraza, jardín, pasto o salón. Combina espectacularmente con nuestras <a href="/servicios/mobiliario/mesas/">mesas de madera</a> y <a href="/servicios/mobiliario/sillas/">sillas Crossback</a> para crear un concepto integral rústico-elegante que tus invitados recordarán.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Madera Artesanal</span>
                  <span class="showcase__tag">Bodas Rústicas</span>
                  <span class="showcase__tag">Haciendas</span>
                  <span class="showcase__tag">Pino Barnizado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Barra Madera
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Barra de bebidas bartender madera para evento" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-madera-dorada-bartender.avif" alt="Barra madera dorada con bartender profesional" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-premium-evento-celebracion.avif" alt="Barra premium para celebración y evento CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Barra Acrílico Iluminado -->
          <section class="section section--alt" aria-labelledby="acrilico-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Fiestas y eventos nocturnos</span>
                <h2 class="showcase__title" id="acrilico-heading">Barra Acrílico Iluminado</h2>
                <p class="showcase__subtitle">Paneles de acrílico transparente con retroiluminación LED programable en 16 colores. Cambio por control remoto o secuencias automáticas.</p>
                <p class="showcase__text">La <strong>barra de acrílico iluminado</strong> transforma el servicio de bebidas en un espectáculo visual. Los paneles de acrílico transparente de alta resistencia incorporan <strong>retroiluminación LED programable en 16 colores</strong> que se controlan con un control remoto incluido. Puedes fijar un color que combine con tu paleta de evento, alternar entre tonos o activar secuencias automáticas de cambio de color para la pista de baile.</p>
                <p class="showcase__text">El efecto es especialmente espectacular en <strong>ambientes nocturnos</strong> donde la barra se convierte en un elemento decorativo central que atrae la atención de todos los invitados. Ideal para bodas modernas, fiestas corporativas, lanzamientos de producto y eventos de marca donde la imagen lo es todo. Combínala con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente coordinado y envolvente.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Acrílico LED</span>
                  <span class="showcase__tag">16 Colores</span>
                  <span class="showcase__tag">Eventos Nocturnos</span>
                  <span class="showcase__tag">Corporativos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Barra Acrílico LED
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Barra de coctelería lujo en madera para evento" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-hexagonal-bartender-botanical.avif" alt="Barra hexagonal bartender botanical garden" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-bartender-madera-evento.avif" alt="Barra bebidas con bartender en evento CDMX" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Barra Industrial -->
          <section class="section section--alt" aria-labelledby="industrial-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Estilo contemporáneo</span>
                <h2 class="showcase__title" id="industrial-heading">Barra Industrial</h2>
                <p class="showcase__subtitle">Tuberías de cobre vista con tablero de madera reciclada y acabado envejecido. Estética steampunk/loft con carácter y personalidad.</p>
                <p class="showcase__text">La <strong>barra industrial</strong> aporta carácter y personalidad a cualquier evento con su combinación de <strong>tuberías de cobre vista</strong> y tablero de <strong>madera reciclada</strong> con acabado envejecido. La estética steampunk/loft es tendencia en eventos contemporáneos y genera un impacto visual inmediato que distingue tu celebración de las convencionales.</p>
                <p class="showcase__text">Perfecta para <strong>eventos temáticos, festivales gastronómicos, lanzamientos de cerveza artesanal</strong> y bodas con estilo urbano que buscan romper con lo tradicional. La estructura robusta incluye repisa para botellas integrada en las tuberías de cobre y área de preparación funcional. Combina con nuestras <a href="/servicios/mobiliario/barras/periqueras/">periqueras y bancos altos</a> de estilo industrial para crear una zona de bar con personalidad propia.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Industrial</span>
                  <span class="showcase__tag">Cobre</span>
                  <span class="showcase__tag">Madera Reciclada</span>
                  <span class="showcase__tag">Contemporáneo</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Barra Industrial
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barras-bebidas-industrial-hexagonal.avif" alt="Barra bebidas industrial hexagonal para evento" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif" alt="Barra coctelería lujo en madera evento CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-madera-dorada-bartender.avif" alt="Barra madera dorada bartender en evento" loading="lazy" decoding="async" />
                  </div>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Doble Barra -->
          <section class="section section--alt" aria-labelledby="doble-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Eventos grandes 300+</span>
                <h2 class="showcase__title" id="doble-heading">Kit Doble Barra</h2>
                <p class="showcase__subtitle">Configuración con 2 barras enfrentadas o en L para eventos de gran formato. Servicio simultáneo que reduce tiempos de espera.</p>
                <p class="showcase__text">El <strong>kit doble barra</strong> es la solución para eventos de gran formato donde el flujo de invitados exige servicio rápido y eficiente. La configuración con <strong>2 barras enfrentadas o en forma de L</strong> permite atender simultáneamente desde ambos lados, reduciendo drásticamente los tiempos de espera y manteniendo a todos los invitados servidos durante los momentos de mayor demanda como el brindis o la hora del cocktail.</p>
