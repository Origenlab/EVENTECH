---
/**
 * ─── Barra de Bebidas Madera Rústica — Página de Variante ───
 * Barra madera rústica 2-3m ideal para bodas rústicas y eventos campestres en CDMX.
 * Desde $2,500 por evento.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras", href: "/servicios/mobiliario/barras/" },
  { label: "Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { label: "Madera Rústica" },
];

const galleryImages = [
  { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Barra de madera rústica en boda hacienda CDMX" },
  { src: "/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif", alt: "Barra rústica de madera para evento al aire libre" },
  { src: "/images/mobiliario/barra-hexagonal-bartender-botanical.avif", alt: "Detalle barra madera rústica 2 metros con copas" },
  { src: "/images/mobiliario/barra-madera-dorada-bartender.avif", alt: "Barra rústica montada como open bar en boda campestre" },
  { src: "/images/mobiliario/barra-bebidas-01.avif", alt: "Barra de madera en jardín con decoración rústica" },
  { src: "/images/mobiliario/barra-bebidas-02.avif", alt: "Barra rústica iluminada de noche en evento CDMX" },
];

const faqs = [
  {
    question: "¿Cuánto mide la barra de madera rústica y cuántas personas pueden atender?",
    answer: "La <strong>barra de madera rústica</strong> está disponible en dos medidas: <strong>2 metros</strong> (ideal para 80-120 invitados con un bartender) y <strong>3 metros</strong> (para 150-250 invitados con dos bartenders). La superficie de madera tratada tiene profundidad de 60 cm, suficiente para trabajar con comodidad. Si tu evento supera los 250 invitados, recomendamos dos barras de 2m o una configuración en L con módulo extra."
  },
  {
    question: "¿La madera rústica es resistente al exterior y a derrames?",
    answer: "Sí. La barra está fabricada en <strong>madera de pino tratada con barniz náutico</strong> — el mismo acabado que se usa en muebles de exterior de alta gama. Resiste derrames de alcohol, agua y jugos sin mancharse. Las patas tienen niveladores de goma para terrenos irregulares en jardines o haciendas. No se recomienda exposición prolongada a lluvia intensa, pero para eventos bajo techo o en ambientes semi-abiertos funciona perfectamente."
  },
  {
    question: "¿Qué está incluido en la renta de la barra de madera rústica?",
    answer: "La renta incluye: barra completa (tablero superior + estructura inferior + estantes para botellas), <strong>entrega y montaje en CDMX</strong>, anclaje y nivelación, y desmontaje al final del evento. No incluye bartenders, bebidas, ni cristalería — aunque podemos cotizarte esos servicios adicionales si los necesitas. El precio desde <strong>$2,500</strong> es por la renta del mobiliario solamente."
  },
  {
    question: "¿La barra rústica funciona para bodas en haciendas o solo para eventos modernos?",
    answer: "La barra rústica es <strong>especialmente popular en haciendas</strong> como San Gabriel de Las Palmas, La Querencia o cualquier venue con arquitectura colonial o estilo campo. El acabado en madera sin tratar contrasta perfectamente con la piedra y el adobe. También la usamos mucho en bodas tipo bohemio, festivales privados y eventos al aire libre con decoración natural. Para venues modernos o industriales, tenemos las barras <a href='/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/'>acrílico LED</a> o <a href='/servicios/mobiliario/barras/barras-bebidas/industrial/'>industrial metal+madera</a>."
  },
  {
    question: "¿Con cuánta anticipación debo reservar la barra de madera para mi evento?",
    answer: "Para eventos en temporada alta (octubre-febrero), recomendamos reservar con <strong>4-6 semanas de anticipación</strong>. En temporada regular, con 2-3 semanas es suficiente. La barra de madera rústica es uno de los elementos más solicitados por su versatilidad — se agenda rápido. Un anticipo del 30% bloquea la fecha. Escríbenos por WhatsApp y confirmamos disponibilidad al instante."
  },
];

const specs = [
  { label: "Material", value: "Madera de pino tratada con barniz náutico resistente a derrames" },
  { label: "Medidas disponibles", value: "2 metros (estándar) y 3 metros (grande)" },
  { label: "Profundidad de trabajo", value: "60 cm" },
  { label: "Altura de barra", value: "110 cm (altura ergonómica de bartender)" },
  { label: "Capacidad de carga", value: "150 kg distribuidos en superficie" },
  { label: "Estantes para botellas", value: "Incluidos — 2 niveles en estructura inferior" },
  { label: "Acabado", value: "Madera rústica barnizada — sin pintura, veta natural visible" },
  { label: "Niveladores", value: "Sí — ajustables para terrenos irregulares" },
  { label: "Armado", value: "30-45 minutos por barra" },
  { label: "Precio desde", value: "$2,500 por evento (incluye montaje y desmontaje)" },
];

const reviews = [
  { author: "Sofía Ramírez", text: "Rentamos la barra de madera de 3m para nuestra boda en hacienda. Era exactamente lo que buscábamos — el acabado rústico combinó perfecto con las flores silvestres y las velas. El montaje fue rápido y quedó muy estable.", rating: 5, date: "2025-11-08" },
  { author: "Diego Fuentes", text: "La usamos para un festival privado en jardín con 200 personas. La madera aguantó perfectamente toda la noche, incluyendo derrames de cerveza y mezcal. Sin manchas, sin problemas. La recomiendo.", rating: 5, date: "2025-10-22" },
  { author: "Valentina Cruz", text: "Para mi cumpleaños en el campo, la barra de madera rústica fue el centro de atención. Todos mis amigos preguntaron dónde la consiguieron. El precio está muy bien para lo que es.", rating: 5, date: "2025-09-14" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Barra de Bebidas Madera Rústica para Eventos CDMX",
    description: "Barra de bebidas en madera rústica 2-3m para bodas y eventos en CDMX. Barniz náutico resistente. Estantes incluidos. Entrega y montaje. Desde $2,500.",
    url: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/",
    priceRange: { min: 2500, max: 4500 },
    reviews,
    ratingValue: 5,
    reviewCount: 34,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras", url: "/servicios/mobiliario/barras/" },
    { name: "Barras de Bebidas", url: "/servicios/mobiliario/barras/barras-bebidas/" },
    { name: "Madera Rústica", url: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
  ]),
  faqJsonLd(faqs),
];

const sidebarNav = [
  { name: "Todas las Barras de Bebidas", href: "/servicios/mobiliario/barras/barras-bebidas/" },
  { name: "Madera Rústica", href: null, active: true },
  { name: "Acrílico Iluminado LED", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
  { name: "Industrial Metal+Madera", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
];

const sidebarRelated = [
  { name: "Periqueras para Barra", href: "/servicios/mobiliario/barras/periqueras/" },
  { name: "Accesorios Decorativos", href: "/servicios/mobiliario/barras/accesorios-decorativos/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
  { name: "Sillas para Eventos", href: "/servicios/mobiliario/sillas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];
---

<PageLayout
  title="Renta Barra de Bebidas Madera Rústica CDMX"
  description="Renta barra de bebidas madera rústica 2-3m en CDMX — perfecta para bodas en haciendas y eventos campestres."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="La barra más solicitada para bodas rústicas y eventos campestres"
    title='Barra de Bebidas <span class="highlight">Madera Rústica</span> — Renta en CDMX'
    subtitle="Barra en madera de pino tratada con barniz náutico, disponible en 2 y 3 metros. Resistente a derrames, con estantes para botellas incluidos. El punto focal perfecto para bodas en haciendas, eventos al aire libre y celebraciones con estilo campestre."
    primaryCTA={{ label: "Cotizar barra de madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar por WhatsApp", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas madera rústica para mi evento` }}
    cards={[
      {
        title: "Madera rústica que transforma cualquier espacio en open bar de hacienda",
        content: "La <strong>barra de madera rústica</strong> es el elemento que convierte un evento ordinario en una experiencia que los invitados recuerdan. La madera de pino con barniz náutico tiene veta natural visible — cada barra es única, con las marcas y tonos propios de la madera real. Dos estantes internos para botellas, superficie amplia de 60 cm de profundidad, y altura de 110 cm para que el bartender trabaje con ergonomía. Disponible en <strong>2 metros para 80-150 invitados</strong> y <strong>3 metros para eventos de 250+</strong>.",
      },
      {
        title: "Montaje en 30 minutos y sin sorpresas el día de tu evento",
        content: "El equipo de EVENTECH llega con la barra desmontada, la arma en sitio en <strong>30-45 minutos</strong> y la nivela aunque el jardín tenga pendiente. Los niveladores ajustables en las patas garantizan que la barra quede perfectamente horizontal en terrenos de hacienda, pasto o piso irregular. <strong>Desmontaje incluido</strong> al final del evento sin cargo extra. Desde <strong>$2,500 por evento</strong> para la barra de 2m — con entrega, montaje, nivelación y desmontaje.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="Barra de madera rústica que convierte tu boda en hacienda en algo memorable — cotiza sin compromiso"
    subheadline="2m desde $2,500 · 3m desde $3,500 · Montaje incluido · CDMX y Estado de México"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">Barra de madera rústica para tu evento</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar la barra de bebidas madera rústica para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <h2 id="galeria-heading" class="section__title">Galería — Barra de Madera Rústica en Eventos Reales</h2>
            <p class="section__subtitle">Bodas en haciendas, jardines y venues campestres en CDMX y Estado de México</p>
            <Gallery4x4 images={galleryImages} />
          </section>

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Barra Madera Rústica</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE -->
          <section class="section section--alt" aria-labelledby="descripcion-heading">
            <ServiceShowcase
    title="¿Por qué la barra rústica es el open bar favorito de bodas en hacienda?"
    headingId="descripcion-heading"
    badge="Madera real — no laminado, no imitación"
    tags={["Madera Rústica", "Bodas en Hacienda", "Open Bar", "Eventos Campestres"]}
  >
    <Fragment slot="body">
      <p class="showcase__text">La respuesta es simple: <strong>la madera real no miente</strong>. Los invitados que se acercan a la barra tocan la superficie y saben inmediatamente que es madera genuina, con sus marcas naturales y su temperatura cálida al tacto. Ese detalle sensorial eleva la percepción de todo el evento.</p>
      <p class="showcase__text">El acabado en <strong>barniz náutico</strong> protege contra derrames sin crear una capa plástica visible — la veta de la madera sigue siendo el protagonista. Las dos barras de estantes internos están diseñadas para organizar botellas de destilados, vinos y refrescos sin necesidad de mesas auxiliares. Todo en un solo mueble funcional y hermoso.</p>
      <p class="showcase__text">La combinamos con frecuencia con las <strong>periqueras de madera</strong> para crear una zona bar completa y coherente, y con portavelas y atriles decorativos para personalizar la experiencia. El equipo de EVENTECH puede asesorarte sobre la configuración ideal para tu número de invitados y tipo de venue.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src="/images/mobiliario/barra-bebidas-05.avif" alt="Barra de madera rústica como open bar en boda hacienda CDMX" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-03.avif" alt="Detalle estantes barra rústica con botellas organizadas" loading="lazy" decoding="async" />
                  </div>
                  <div class="showcase__gallery3-thumb">
                    <img src="/images/mobiliario/barra-bebidas-04.avif" alt="Barra de madera con periqueras en evento campestre" loading="lazy" decoding="async" />
                  </div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- TESTIMONIALES -->
          <section class="section" aria-labelledby="testimonios-heading">
            <h2 id="testimonios-heading" class="section__title">Opiniones — Barra Madera Rústica</h2>
            <div class="grid grid--3" style="margin-top: var(--space-xl);">
              {reviews.map((review) => (
                <div class="sidebar-card">
                  <div style="display: flex; gap: 4px; margin-bottom: var(--space-sm);">
                    {[1,2,3,4,5].map(() => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="#f59e0b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <p style="font-size: var(--text-sm); line-height: 1.7; color: var(--color-text); font-style: italic; margin-bottom: var(--space-sm);">"{review.text}"</p>
                  <p style="font-size: var(--text-xs); font-weight: 700; color: var(--color-heading);">— {review.author}</p>
                </div>
              ))}
            </div>
          </section>

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <SectionHeader
              id="faq-heading"
              title="Preguntas sobre la Barra de Madera Rústica"
              subtitle="Lo que nos preguntan antes de reservar"
              description={[
                "Madera real resistente, medidas para cada tamaño de evento, montaje profesional en 30 minutos. Aquí resolvemos las dudas más frecuentes antes de reservar.",
              ]}
            />
            <div class="faq-layout">
              <div class="faq-list">
                {faqs.map((faq) => (
                  <details class="faq-item">
                    <summary class="faq-item__question">
                      <span>{faq.question}</span>
                      <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                    </summary>
                    <div class="faq-item__answer">
                      <p set:html={faq.answer} />
                    </div>
                  </details>
                ))}
              </div>
              <aside class="faq-sidebar">
                <div class="faq-sidebar-card faq-sidebar-card--accent">
                  <h3 class="faq-sidebar-card__title">¿Tienes más dudas?</h3>
                  <p class="faq-sidebar-card__text">Escríbenos por WhatsApp — te respondemos al instante sobre disponibilidad y precios.</p>
                  <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo dudas sobre la barra de bebidas madera rústica`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">Escribir por WhatsApp</a>
                </div>
                <div class="faq-sidebar-card">
                  <h3 class="faq-sidebar-card__title">Cotización express</h3>
                  <p class="faq-sidebar-card__text">Cuéntanos el tamaño de tu evento, fecha y venue — precio confirmado en menos de 30 minutos.</p>
                  <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario &darr;</a>
                </div>
              </aside>
            </div>
          </section>

        </div>

        <!-- DESKTOP SIDEBAR -->
        <aside class="l4-sidebar l4-sidebar--desktop" aria-label="Variantes barras de bebidas y servicios relacionados">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Variantes Barras de Bebidas</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
              <li><div class="sidebar-nav__divider"></div></li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/barras/" class="sidebar-nav__back">&uarr; Volver a Barras</a>
              </li>
              <li class="sidebar-nav__item">
                <a href="/servicios/mobiliario/" class="sidebar-nav__back">&uarr; Volver a Mobiliario</a>
              </li>
            </ul>
          </div>
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Complementa tu zona de bar:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">Barra de madera rústica para tu evento en CDMX</p>
