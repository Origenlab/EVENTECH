---
/**
 * ─── EVENTECH.MX — Renta de Barras y Complementos para Eventos (L4 hub, sistema hm-) ───
 * Barras de Bebidas · Periqueras · Mesas de Postres · Accesorios — CDMX y ZMVM
 * Homólogo del hub de sillas (mismo layout, complementos y dorado institucional).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "barras-bebidas",
    name: "Barras de Bebidas",
    badge: "El punto focal",
    excerpt: "Barras profesionales en madera rústica, acrílico iluminado e industrial, con repisa para botellas y área de preparación oculta. El punto de socialización donde tus invitados brindan. Formatos de 2 y 3 metros. Desde $2,500.",
    href: "/servicios/mobiliario/barras/barras-bebidas/",
    image: "/images/mobiliario/barra-hexagonal-bartender-botanical.avif",
    subcategories: [
      { name: "Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
      { name: "Acrílico Iluminado", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
      { name: "Industrial", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
    ],
  },
  {
    id: "periqueras",
    name: "Periqueras",
    badge: "Zona de cóctel",
    excerpt: "Bancos altos en madera, metal y acrílico — el complemento perfecto para barras y zonas de cóctel. Asiento cómodo a la altura de la barra que invita a la conversación de pie. Desde $150 por banco.",
    href: "/servicios/mobiliario/barras/periqueras/",
    image: "/images/mobiliario/periqueras-kit-coctel-completo.avif",
    subcategories: [
      { name: "Periquera Madera", href: "/servicios/mobiliario/barras/periqueras/madera/" },
      { name: "Periquera Metal", href: "/servicios/mobiliario/barras/periqueras/metal/" },
      { name: "Periquera Acrílico", href: "/servicios/mobiliario/barras/periqueras/acrilico/" },
    ],
  },
  {
    id: "postres",
    name: "Mesas de Postres",
    badge: "Candy bar",
    excerpt: "Estructuras escalonadas y candy bars en estilos madera, acrílico y vintage. Exhibiciones gastronómicas de 3 a 7 niveles que convierten tus postres en el rincón más fotografiado del evento. Desde $800.",
    href: "/servicios/mobiliario/barras/postres/",
    image: "/images/mobiliario/barra-postres-tarta-macarons-rosas.avif",
    subcategories: [
      { name: "Mesa de Dulces", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
      { name: "Mesa de Frutas", href: "/servicios/mobiliario/barras/postres/mesa-frutas/" },
      { name: "Postres Gourmet", href: "/servicios/mobiliario/barras/postres/postres-gourmet/" },
      { name: "Fuente de Chocolate", href: "/servicios/mobiliario/barras/postres/fuente-chocolate/" },
    ],
  },
  {
    id: "accesorios-decorativos",
    name: "Accesorios Decorativos",
    badge: "El detalle final",
    excerpt: "Portavelas, atriles, marcos y señalización. Los detalles que completan el montaje y transforman un evento correcto en una experiencia visual cuidada de principio a fin. Desde $50 por pieza.",
    href: "/servicios/mobiliario/barras/accesorios-decorativos/",
    image: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif",
    subcategories: [
      { name: "Portavelas", href: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/" },
      { name: "Atriles y Señalización", href: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/" },
    ],
  },
];

const whyFeatures = [
  {
    title: "Inventario propio — sin subcontratistas",
    body: "Barras, periqueras, estructuras de postres y accesorios propios en bodega CDMX. No intermediamos con otros proveedores. Lo que cotizamos es lo que existe en nuestro almacén, verificado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    title: "Superficies tratadas para alimentos",
    body: "Las barras y mesas de postres tienen superficies de servicio tratadas para contacto con alimentos, con protección anti-derrames y áreas de preparación. No improvisamos con tableros sin sellar — el detalle que distingue un montaje profesional de uno casero.",
  },
  {
    title: "Entrega y montaje del set completo",
    body: "Nuestro equipo entrega y arma la barra, las periqueras, la estructura de postres y los accesorios en la posición exacta de tu layout. No dejamos la mercancía en la puerta. Llegamos con tiempo antes del evento para que la zona quede lista sin contratiempos.",
  },
  {
    title: "Revisión pieza por pieza antes de salir de bodega",
    body: "Toda pieza pasa por protocolo de inspección: estructura, acabado, iluminación LED y superficies. Las unidades con rayones, manchas o fallas se separan y reemplazan antes de cargar el camión. Lo que llega a tu evento está impecable.",
  },
  {
    title: "Reposición en sitio garantizada",
    body: "Si durante el montaje detectamos una pieza dañada o un acabado incorrecto, la reponemos sin costo dentro de CDMX. Siempre cargamos piezas de respaldo en cada servicio para que tu barra o candy bar quede completa sin importar imprevistos de último minuto.",
  },
  {
    title: "Asesoría de montaje y estilo",
    body: "¿Barra de madera o acrílico iluminado para tu paleta? ¿Cuántas periqueras para la zona de cóctel? ¿Qué estructura de postres luce mejor con tu pastel? Te asesoramos con referencias visuales reales para que cada complemento dialogue con el resto del evento.",
  },
];

const steps = [
  { n: 1, t: "Cotización y aparto de inventario", p: "Nos indicas qué complementos necesitas (barra, periqueras, postres, accesorios), estilo, fecha y venue. En menos de 24 horas te confirmamos disponibilidad y te enviamos propuesta. Con el 30% de anticipo apartamos tu inventario — sin pago total por adelantado." },
  { n: 2, t: "Coordinación con venue y otros proveedores", p: "Coordinamos directamente con tu decoradora, wedding planner, banquetero o el salón. Compartimos layout de montaje, horario de acceso y requerimientos logísticos (tomas de corriente para barras iluminadas, espacio de servicio) para que todo encaje sin conflictos." },
  { n: 3, t: "Entrega, montaje y verificación en sitio", p: "Llegamos el día del evento o la tarde anterior según acuerdo. Armamos barras, periqueras y estructuras en su posición, conectamos la iluminación LED y hacemos verificación visual del montaje antes de retirarnos. Tú o tu coordinador firman conformidad." },
  { n: 4, t: "Recolección al finalizar el evento", p: "Al cierre, nuestro equipo desarma y carga todas las piezas. Revisión en conjunto del estado del mobiliario al momento de la recolección, no de forma unilateral. Sin presiones de tiempo si el evento se extiende — acordamos horario con anticipación." },
];

const faqs = [
  {
    question: "¿Las barras incluyen bartender y bebidas?",
    answer: "No. Rentamos el mobiliario de barra (estructura, superficie de servicio, repisa de botellas e iluminación), no el servicio de bartender ni las bebidas. Esto te da libertad de contratar al bartender y la coctelería que prefieras, o trabajar con el banquetero de tu venue. Si lo necesitas, podemos recomendarte proveedores de bar service de confianza con los que hemos trabajado.",
  },
  {
    question: "¿Qué tamaño de barra necesito para mi evento?",
    answer: "La barra de 2 metros es suficiente para eventos de hasta 150 personas con un bartender. Para eventos de 150 a 500 personas recomendamos la barra de 3 metros o dos barras de 2 metros en distintos puntos para evitar filas. Considera también el espacio: una barra necesita área de circulación detrás para el servicio. Te ayudamos a definir el tamaño y la cantidad según tu evento.",
  },
  {
    question: "¿Las mesas de postres incluyen los postres?",
    answer: "No. Rentamos la estructura escalonada, las bandejas, vitrinas y pedestales de exhibición — el mobiliario del candy bar, no los dulces ni postres. Tú los provees con tu repostero o banquetero. Las superficies están tratadas para contacto con alimentos. Si requieres, coordinamos con tu proveedor de postres para que la exhibición luzca perfecta.",
  },
  {
    question: "¿Puedo combinar diferentes estilos de barra y complementos?",
    answer: "Sí, y es lo más común. Combinaciones frecuentes: barra de madera rústica + periqueras de madera para bodas en hacienda; barra de acrílico iluminado + periqueras de metal para eventos corporativos nocturnos; mesa de postres vintage + accesorios en portavelas para un candy bar romántico. Lo importante es la coherencia de paleta. Te asesoramos con la mezcla ideal.",
  },
  {
    question: "¿El precio incluye montaje y recolección?",
    answer: "Sí. El precio cotizado incluye entrega al venue, armado completo según layout, conexión de iluminación LED donde aplique, verificación de montaje y recolección al finalizar. Dentro de CDMX no hay cargo logístico adicional. Para Zona Metropolitana (Naucalpan, Tlalnepantla, Ecatepec, Neza, etc.) el costo de transporte se especifica en la cotización.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar?",
    answer: "Para barras y complementos puntuales, 2 a 3 semanas de anticipación suele ser suficiente. Para eventos grandes con varias barras o estructuras de postres específicas, recomendamos 4 a 6 semanas. En temporada alta de bodas (noviembre a febrero) y fines de semana con eventos simultáneos, 6 a 8 semanas garantiza el estilo exacto que buscas.",
  },
  {
    question: "¿Las barras se pueden usar en exteriores?",
    answer: "Sí. Las barras de madera y las estructuras montan sobre superficie firme en jardines y terrazas. Las barras de acrílico iluminado requieren toma de corriente cercana para la iluminación LED. Para eventos completamente al aire libre recomendamos ubicar las barras bajo carpa o techo como respaldo ante lluvia, especialmente las piezas con componentes eléctricos.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Barras y Complementos para Eventos en CDMX",
    description: "Renta de barras de bebidas, periqueras, mesas de postres y accesorios decorativos para bodas, XV años, corporativos y eventos sociales en CDMX. Montaje y asesoría incluidos.",
    url: "/servicios/mobiliario/barras/",
    priceRange: { min: 50, max: 6000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras y Complementos", url: "/servicios/mobiliario/barras/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras y Complementos" },
];
---

<PageLayout
  title="Renta de Barras y Complementos para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/mobiliario/barra-hexagonal-bartender-botanical.avif"
  description="Renta de barras de bebidas, periqueras, mesas de postres y accesorios en CDMX. Madera, acrílico iluminado e industrial. Montaje y asesoría incluidos."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="barras-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Barras y complementos · CDMX y ZMVM</p>
            <h1 id="barras-hero-heading">
              Los <em>complementos que completan tu montaje</em> — barras, periqueras y candy bars
            </h1>
            <p class="hm-hero__lead">
              Barras de bebidas, periqueras, mesas de postres y accesorios decorativos.
              Superficies tratadas para alimentos, entrega puntual, montaje profesional y
              recolección al finalizar. Una sola empresa para cerrar tu evento con acabado de detalle.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20barras%20y%20complementos%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar barras
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>barras y complementos para eventos</strong> con inventario
              propio en la Ciudad de México — barras de bebidas, periqueras, mesas de postres y
              accesorios, sin subcontratar ni intermediar. Barras en madera rústica, acrílico
              iluminado e industrial; periqueras en madera, metal y acrílico; estructuras de
              candy bar de 3 a 7 niveles. Cada pieza se entrega verificada, con superficies
              tratadas para alimentos y armada en la posición exacta de tu layout.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que los
              complementos son lo que separa un evento correcto de uno memorable: la barra donde
              la gente se reúne, el candy bar que todos fotografían, los detalles que cierran la
              estética. Por eso incluimos asesoría de montaje y reposición garantizada en sitio.
              Para eventos que también requieren <a href="/servicios/mobiliario/mesas/">mesas</a>
              y <a href="/servicios/mobiliario/sillas/">sillas</a> te cotizamos el paquete
              completo desde una sola empresa, sin duplicar logística.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Barras y complementos disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20barras%20y%20complementos%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada detalle cuenta</p>
            <h2 id="catalogo-heading">¿Qué complementos necesita tu evento?</h2>
            <p class="hm__head-sub">4 líneas de complementos — los detalles que completan tu montaje con acabado profesional.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Las sillas y las mesas resuelven la estructura del evento, pero los complementos
              son los que crean los momentos: la barra donde se forma la fila para brindar, las
              periqueras de la hora del cóctel, el candy bar que aparece en cada historia de
              Instagram, los detalles decorativos que cierran la estética. Son piezas pequeñas
              con un impacto visual desproporcionado.
            </p>
            <p>
              Barras de bebidas como punto focal de socialización. Periqueras para zonas de
              cóctel y networking. Mesas de postres para exhibiciones gastronómicas memorables.
              Accesorios decorativos para el acabado final de cada rincón del evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada complemento, a fondo</p>
            <h2 id="detalle-heading">Las 4 líneas de complementos — en detalle</h2>
            <p class="hm__head-sub">Materiales, formatos, capacidad y para qué tipo de evento funciona mejor cada complemento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada complemento hay decisiones que afectan la experiencia del evento:
              el material de la barra que define la estética de la zona de bebidas, el tamaño
              que determina si se forman filas, la estructura de postres que decide cuántas
              porciones exhibes, y los acabados que deben dialogar con el resto del montaje.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada línea.
            </p>
          </div>
        </div>

        <!-- BARRAS DE BEBIDAS -->
        <article class="hm-feat" aria-labelledby="feat-barras">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Barras de Bebidas</p>
            <h3 class="hm-feat__title" id="feat-barras">El punto focal de socialización — donde tus invitados se reúnen, brindan y celebran</h3>
            <p class="hm-feat__lead">La barra es el imán social del evento: el lugar donde se forma la conversación espontánea y donde la gente regresa una y otra vez. Por eso no es un mueble cualquiera, es una pieza de diseño que define la zona.</p>
            <p>
              Disponibles en 3 estilos y 2 tamaños. La <strong>barra de Madera Rústica</strong>
              con acabado barnizado natural es perfecta para bodas en haciendas. La
              <strong>barra de Acrílico Iluminado</strong> con LED programable en 16 colores es
              la favorita para eventos corporativos y nocturnos. La <strong>barra Industrial</strong>
              con tubería de cobre y madera reciclada aporta carácter a eventos contemporáneos.
            </p>
            <p>
              Todas incluyen <strong>superficie con protección anti-derrames, repisa trasera para
              botellas y área de preparación oculta</strong>. En formatos de <strong>2 metros
              (hasta 150 personas)</strong> y <strong>3 metros (150 a 500 personas)</strong>.
              Combínalas con nuestras <a href="/servicios/mobiliario/mesas/cocktail/">mesas
              cocktail</a> para crear una zona de cóctel completa.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
                { name: "Acrílico Iluminado", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
                { name: "Industrial", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/mobiliario/barras/barras-bebidas/">
              Ver Barras de Bebidas completas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/mobiliario/barra-hexagonal-bartender-botanical.avif" alt="Barra de bebidas hexagonal con bartender y decoración botánica en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/mobiliario/barra-madera-dorada-bartender.avif" alt="Barra de madera con detalles dorados y bartender en evento" loading="lazy" decoding="async" />
              <img src="/images/mobiliario/candy-bar-acrilico-led-noche.avif" alt="Barra de acrílico iluminado con LED en evento nocturno" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- PERIQUERAS -->
