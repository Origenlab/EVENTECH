---
/**
 * ─── Barras y Complementos para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Barras y Complementos para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import CategoryCard from "@components/CategoryCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import Gallery4x4 from "@components/Gallery4x4.astro";
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Mobiliario", href: "/servicios/mobiliario/" },
  { label: "Barras" },
];

const BARRAS = [
  {
    name: "Barras de Bebidas",
    excerpt: "Barras profesionales de 2 y 3 metros en madera, acrílico iluminado e industrial. Con respaldo para botellas y área de preparación.",
    cta: "Barras",
    href: "/servicios/mobiliario/barras/barras-bebidas/",
    icon: "utensils",
    image: "/images/mobiliario/barra-hexagonal-bartender-botanical.avif",
  },
  {
    name: "Mesas de Postres",
    excerpt: "Estructuras escalonadas y candy bars en madera, acrílico y vintage. Exhibiciones gastronómicas que enamoran a tus invitados.",
    cta: "Postres",
    href: "/servicios/mobiliario/barras/postres/",
    icon: "cake",
    image: "/images/mobiliario/barra-postres-tarta-macarons-rosas.avif",
  },
  {
    name: "Periqueras y Bancos",
    excerpt: "Bancos altos de 75 cm en madera, metal y acrílico. El complemento perfecto para zonas de cóctel y barras de bebidas.",
    cta: "Periqueras",
    href: "/servicios/mobiliario/barras/periqueras/",
    icon: "chair",
    image: "/images/mobiliario/mesas-cocktail-negras-networking-vista.avif",
  },
  {
    name: "Accesorios Decorativos",
    excerpt: "Bases para centros de mesa, portavelas, atriles, marcos y señalización. Detalles que completan tu montaje con acabado profesional.",
    cta: "Accesorios",
    href: "/servicios/mobiliario/barras/accesorios-decorativos/",
    icon: "heart",
    image: "/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif",
  },
];

const faqs = [
  { question: "¿Qué tamaños de barra de bebidas ofrecen?", answer: "Ofrecemos barras de 2 metros (ideales para eventos de hasta 150 personas) y de 3 metros (para eventos de 150 a 500 personas). Para eventos más grandes, se pueden colocar múltiples barras distribuidas estratégicamente en el venue. Todas incluyen área de preparación trasera, repisa para botellas y superficie de servicio con protección anti-derrames." },
  { question: "¿Las barras incluyen la cristalería y accesorios de bar?", answer: "Las barras se rentan como estructura con superficie de servicio y respaldo. La cristalería (copas, vasos, hieleras, cocteleras) se cotiza por separado o como complemento del servicio de catering. Ofrecemos paquetes combinados barra + cristalería con descuento especial. Consulta nuestra sección de catering para ver las opciones completas." },
  { question: "¿Qué opciones hay para mesas de postres y candy bar?", answer: "Ofrecemos 3 líneas: la línea Madera con niveles escalonados y acabado rústico, la línea Acrílico con superficies transparentes y retroiluminación LED opcional, y la línea Vintage con piezas de diferentes alturas y estilos decorativos. Cada configuración incluye entre 3 y 7 niveles según el tamaño seleccionado." },
  { question: "¿Los bancos altos combinan con las mesas cocktail?", answer: "Sí, nuestros bancos altos de 75 cm están diseñados específicamente para complementar las mesas cocktail de 110 cm. Ofrecemos bancos en los mismos acabados (madera, metal cromado y acrílico) para garantizar coherencia visual. La proporción estándar es 3 a 4 bancos por mesa cocktail." },
  { question: "¿Puedo rentar accesorios decorativos por separado?", answer: "Por supuesto. Los accesorios decorativos se rentan como piezas individuales: bases para centros de mesa desde $50, portavelas desde $30, atriles desde $150 y marcos decorativos desde $200. También ofrecemos paquetes temáticos prediseñados (Romántico, Rústico, Moderno, Elegante) con descuento sobre el precio individual." },
  { question: "¿Con cuánta anticipación debo reservar barras y complementos?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación. Las barras de acrílico iluminado y las mesas de postres vintage son las piezas más solicitadas y se agotan primero en temporada alta (noviembre a febrero). Para eventos grandes o con piezas específicas, lo ideal es apartar con 1 a 2 meses de anticipación." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Barras y Complementos CDMX",
    description: "Barras de bebidas, mesas de postres, periqueras y accesorios decorativos para bodas, XV años y corporativos. Entrega y montaje incluido en CDMX.",
    url: "/servicios/mobiliario/barras/",
    priceRange: { min: 30, max: 8000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Mobiliario", url: "/servicios/mobiliario/" },
    { name: "Barras y Complementos", url: "/servicios/mobiliario/barras/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Barras y Complementos CDMX"
  description="Renta de barras de bebidas, mesas de postres, periqueras y accesorios decorativos para eventos en CDMX. Entrega y montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Complementos que hacen la diferencia"
    title='Renta de <span class="highlight">Barras y Complementos</span> para Eventos en CDMX'
    subtitle="Barras de bebidas, mesas de postres, periqueras y accesorios decorativos. Todo lo que necesitas para completar tu montaje con acabado profesional. Entrega, montaje y asesoría incluidos."
    primaryCTA={{ label: "Cotiza tus complementos", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar barras y complementos para mi evento` }}
    cards={[
      {
        title: "El complemento perfecto para cada montaje",
        content: "<strong>Renta de barras y complementos para eventos</strong> con el catálogo más completo de CDMX. Barras de bebidas profesionales en madera artesanal, acrílico con retroiluminación LED y estilo industrial con tuberías de cobre. Mesas de postres escalonadas para candy bars espectaculares. Periqueras y bancos altos que transforman cualquier zona de cóctel. Accesorios decorativos que aportan el toque final — cada pieza seleccionada por su calidad y versatilidad para elevar cualquier estilo de evento.",
      },
      {
        title: "Piezas que completan la experiencia de tu evento",
        content: "<strong>Servicio integral de complementos</strong> que cuida cada detalle del montaje. Nuestro equipo te asesora para seleccionar las barras y accesorios que mejor combinan con tu mobiliario principal, estilo decorativo y distribución del venue. Incluimos entrega puntual, montaje profesional con nivelación y ajuste de cada pieza, y recolección al finalizar — todo sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas completar tu montaje de evento?"
    subheadline="Nuestros asesores te ayudan a seleccionar las barras y complementos ideales para tu celebración. Cotiza sin compromiso."
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO PRODUCT CARDS — 4 tipos de complementos
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Barras y Complementos"
        subtitle="Cada detalle cuenta en un evento profesional"
        description={[
          "Ofrecemos 4 líneas de complementos diseñados para elevar cualquier montaje de evento. Desde barras de bebidas profesionales hasta accesorios decorativos de acabado impecable.",
          "Cada pieza está pensada para complementar nuestro mobiliario principal y crear experiencias visuales y funcionales que tus invitados recordarán."
        ]}
      />

      <div class="grid grid--4">
        <CategoryCard
          title="Barras de Bebidas"
          subtitle="Barras profesionales en madera rústica, acrílico iluminado e industrial. Con respaldo para botellas y área de preparación. Desde $2,500."
          href="/servicios/mobiliario/barras/barras-bebidas/"
          image="/images/mobiliario/barra-hexagonal-bartender-botanical.avif"
          subcategories={[
            { name: "Madera Rústica", href: "/servicios/mobiliario/barras/barras-bebidas/madera-rustica/" },
            { name: "Acrílico Iluminado", href: "/servicios/mobiliario/barras/barras-bebidas/acrilico-iluminado/" },
            { name: "Industrial", href: "/servicios/mobiliario/barras/barras-bebidas/industrial/" },
          ]}
        />
        <CategoryCard
          title="Periqueras"
          subtitle="Bancos altos en madera, metal y acrílico. El complemento perfecto para zonas de cóctel y barras de bebidas. Desde $150."
          href="/servicios/mobiliario/barras/periqueras/"
          image="/images/mobiliario/mesas-cocktail-negras-networking-vista.avif"
          subcategories={[
            { name: "Madera", href: "/servicios/mobiliario/barras/periqueras/madera/" },
            { name: "Metal", href: "/servicios/mobiliario/barras/periqueras/metal/" },
            { name: "Acrílico", href: "/servicios/mobiliario/barras/periqueras/acrilico/" },
          ]}
        />
        <CategoryCard
          title="Mesas de Postres"
          subtitle="Estructuras escalonadas y candy bars en diferentes estilos. Exhibiciones gastronómicas que enamoran a tus invitados. Desde $800."
          href="/servicios/mobiliario/barras/postres/"
          image="/images/mobiliario/barra-postres-tarta-macarons-rosas.avif"
          subcategories={[
            { name: "Escalonada", href: "/servicios/mobiliario/barras/postres/escalonada/" },
            { name: "Redonda", href: "/servicios/mobiliario/barras/postres/redonda/" },
            { name: "Mesa Dulces", href: "/servicios/mobiliario/barras/postres/mesa-dulces/" },
          ]}
        />
        <CategoryCard
          title="Accesorios Decorativos"
          subtitle="Portavelas, atriles, marcos y señalización. Detalles que completan tu montaje con acabado profesional. Desde $50."
          href="/servicios/mobiliario/barras/accesorios-decorativos/"
          image="/images/mobiliario/accesorios-decorativos-candelabros-mesa.avif"
          subcategories={[
            { name: "Portavelas", href: "/servicios/mobiliario/barras/accesorios-decorativos/portavelas/" },
            { name: "Atriles", href: "/servicios/mobiliario/barras/accesorios-decorativos/atriles/" },
            { name: "Marcos", href: "/servicios/mobiliario/barras/accesorios-decorativos/marcos/" },
          ]}
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BARRAS DE BEBIDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="barras-bebidas-heading">
    <div class="container">
      <ServiceShowcase
    title="Barras de Bebidas"
    headingId="barras-bebidas-heading"
    badge="Pieza central del evento"
    subtitle="El punto focal de socialización donde tus invitados se reúnen, brindan y celebran."
    tags={["Madera Artesanal", "Acrílico LED", "Industrial", "2m y 3m"]}
    ctaHref="/servicios/mobiliario/barras/barras-bebidas/"
    ctaLabel="Ver Barras de Bebidas"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>barras de bebidas profesionales</strong> están disponibles en 3 estilos y 2 tamaños. La <strong>barra de Madera Artesanal</strong> con acabado barnizado natural es perfecta para bodas rústicas y eventos en haciendas. La <strong>barra de Acrílico Iluminado</strong> con retroiluminación LED programable en 16 colores es la favorita para fiestas corporativas y eventos nocturnos. La <strong>barra Industrial</strong> con tuberías de cobre y tablero de madera reciclada aporta personalidad a eventos contemporáneos.</p>
      <p class="showcase__text">Todas las barras incluyen <strong>superficie de servicio con protección anti-derrames, repisa trasera para botellas y área de preparación oculta</strong>. Disponibles en formatos de <strong>2 metros (eventos hasta 150 personas)</strong> y <strong>3 metros (eventos de 150 a 500 personas)</strong>. Se integran perfectamente con nuestras <a href="/servicios/mobiliario/mesas/">mesas cocktail</a> para crear zonas de cóctel completas.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/mobiliario/barra-bebidas-madera-cocteleria-lujo.avif"
            alt="Barra de bebidas de madera artesanal con bartender para eventos de lujo"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/barra-hexagonal-bartender-botanical.avif" alt="Barra hexagonal iluminada con bartender y pared botanical" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/barra-premium-evento-celebracion.avif" alt="Barra premium con bartender y clientes en evento de celebración" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MESAS DE POSTRES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="postres-heading">
    <div class="container">
      <ServiceShowcase
    title="Mesas de Postres y Candy Bar"
    headingId="postres-heading"
    badge="Exhibición gastronómica"
    subtitle="Estructuras escalonadas que transforman tus postres en una exhibición visual espectacular."
    tags={["Madera Escalonada", "Acrílico LED", "Vintage", "3-7 niveles"]}
    ctaHref="/servicios/mobiliario/barras/postres/"
    ctaLabel="Ver Mesas de Postres"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>mesas de postres</strong> están diseñadas para exhibir dulces, pasteles y bocadillos de forma profesional. La <strong>línea Madera</strong> con niveles escalonados de pino barnizado es ideal para bodas rústicas y baby showers. La <strong>línea Acrílico</strong> con superficies transparentes y retroiluminación LED opcional crea un efecto de flotación que impresiona en eventos nocturnos. La <strong>línea Vintage</strong> combina piezas de diferentes alturas, bandejas con pedestal y vitrinas decorativas.</p>
      <p class="showcase__text">Cada configuración incluye entre <strong>3 y 7 niveles</strong> según el tamaño seleccionado, con capacidad para exhibir desde 50 hasta 300 porciones. Las superficies están tratadas para contacto con alimentos. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> con luces cálidas y guirnaldas para crear el escenario perfecto de candy bar.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/mobiliario/barra-postres-candy-bar-boda-elegante.avif"
            alt="Barra de postres candy bar con pastel y macarons para boda elegante"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/barra-postres-tarta-wedding-salon-lujo.avif" alt="Barra de postres con tarta nupcial en salón de lujo chandelier" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
            <img src="/images/mobiliario/mesa-postres-boda-tarta-candelabros-salon.avif" alt="Mesa de postres con tarta y candelabros en boda de salón" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TIPOS DE MESAS — 8 cards de estaciones y montajes
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="tipos-mesas-heading">
    <div class="container">
      <SectionHeader
        id="tipos-mesas-heading"
        title="Tipos de Mesas y Estaciones"
        subtitle="Montajes especializados para cada tipo de exhibición gastronómica"
        description={[
          "Cada estación tiene su propia personalidad y función. Desde el clásico candy bar que conquista a todos los invitados, hasta mesas de quesos y embutidos que aportan sofisticación europea.",
          "Nuestras mesas y estaciones están diseñadas para exhibir, conservar y servir cada tipo de alimento de forma óptima. Todas incluyen entrega, montaje y asesoría de presentación."
        ]}
      />

      <div class="grid grid--4">
        <Card
          name="Mesa de Dulces (Candy Bar)"
          excerpt="El clásico candy bar que nunca falla. Gomitas, chocolates, malvaviscos y dulces variados en dispensadores y frascos de cristal."
          cta="Ver Candy Bar"
          href="/servicios/mobiliario/barras/postres/mesa-dulces/"
          icon="cake"
          image="/images/mobiliario/candy-bar-dulces-frascos.avif"
        />
        <Card
          name="Mesa de Frutas"
          excerpt="Frescura y color en cada bocado. Frutas de temporada cortadas artísticamente con dips, miel y chocolates para fondue."
          cta="Ver Frutas"
          href="/servicios/mobiliario/barras/postres/mesa-frutas/"
          icon="heart"
          image="/images/mobiliario/mesa-frutas-cascada-colores.avif"
        />
        <Card
          name="Mesa de Postres Gourmet"
          excerpt="Macarons, éclairs, pays y creaciones de alta repostería. La opción sofisticada para bodas y eventos de lujo."
          cta="Ver Gourmet"
          href="/servicios/mobiliario/barras/postres/postres-gourmet/"
          icon="crown"
          image="/images/mobiliario/mesa-postres-gourmet-macarons.avif"
        />
        <Card
          name="Quesos y Embutidos"
          excerpt="Sofisticación europea en tu evento. Selección de quesos artesanales, embutidos ibéricos y acompañamientos gourmet."
          cta="Ver Quesos"
          href="/servicios/mobiliario/barras/postres/quesos-embutidos/"
          icon="utensils"
          image="/images/mobiliario/mesa-quesos-embutidos-rustica.avif"
        />
        <Card
          name="Mesa de Snacks"
          excerpt="Para esas fiestas que duran hasta tarde. Palomitas, nachos, pretzels y botanas saladas que mantienen la energía."
          cta="Ver Snacks"
          href="/servicios/mobiliario/barras/postres/mesa-snacks/"
          icon="package"
          image="/images/mobiliario/mesa-snacks-palomitas-nocturno.avif"
        />
        <Card
          name="Mesa de Botanas"
          excerpt="El contrapunto perfecto para lo dulce. Dips, crudités, tostadas y bocadillos salados para equilibrar el menú."
          cta="Ver Botanas"
          href="/servicios/mobiliario/barras/postres/mesa-botanas/"
          icon="layers"
          image="/images/mobiliario/mesa-botanas-dips-crudites.avif"
        />
        <Card
          name="Dulces Tradicionales"
          excerpt="Un viaje a la infancia mexicana. Mazapanes, tamarindos, obleas, cocadas y dulces de leche que evocan nostalgia."
          cta="Ver Tradicionales"
          href="/servicios/mobiliario/barras/postres/dulces-tradicionales/"
          icon="heart"
          image="/images/mobiliario/mesa-dulces-tradicionales-mexicanos.avif"
        />
        <Card
          name="Donas y Cupcakes"
          excerpt="La tendencia que conquista Instagram. Muros de donas glaseadas y torres de cupcakes decorados que son puro eye-candy."
          cta="Ver Tendencia"
          href="/servicios/mobiliario/barras/postres/donas-cupcakes/"
          icon="cake"
          image="/images/mobiliario/muro-donas-cupcakes-instagram.avif"
          badge="Tendencia"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PERIQUERAS Y BANCOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="periqueras-heading">
    <div class="container">
      <ServiceShowcase
    title="Periqueras y Bancos Altos"
    headingId="periqueras-heading"
    badge="Zona de cóctel"
    subtitle="El asiento ideal para zonas de cóctel, barras y áreas de networking casual."
    tags={["Madera Acolchada", "Metal Cromado", "Acrílico Ghost", "75 cm altura"]}
    ctaHref="/servicios/mobiliario/barras/periqueras/"
    ctaLabel="Ver Periqueras y Bancos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>bancos altos de 75 cm</strong> están diseñados específicamente para complementar mesas cocktail y barras de bebidas. Disponibles en 3 materiales: <strong>madera de pino barnizada</strong> con asiento acolchado para eventos rústicos y bodas. <strong>Metal cromado</strong> con base giratoria para corporativos y ferias. <strong>Acrílico transparente</strong> estilo Ghost para eventos contemporáneos y minimalistas.</p>
      <p class="showcase__text">La proporción recomendada es <strong>3 a 4 bancos por mesa cocktail</strong>. Todos los modelos incluyen <strong>reposapiés cromado y base antideslizante</strong> para máxima estabilidad. Los bancos de madera soportan <strong>120 kg</strong>, los de metal <strong>130 kg</strong> y los de acrílico <strong>110 kg</strong>. Combínalos con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para crear zonas de cóctel al aire libre con presencia impecable.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/mobiliario/mesas-cocktail-negras-periqueras-evento.avif"
            alt="Periqueras negras y bancos altos en evento corporativo de noche"
            width="800" height="436"
            loading="lazy" decoding="async"
            class="showcase__img"
          />

          <div class="showcase__gallery">
            <img src="/images/mobiliario/mesas-cocktail-corporativo-panoramica.avif" alt="Mesas cocktail negras en evento corporativo con vista panorámica" class="showcase__gallery-img" width="640" height="384" loading="lazy" decoding="async" />
