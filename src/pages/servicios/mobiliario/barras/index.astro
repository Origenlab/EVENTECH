       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Barras y Complementos"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Ya sea que necesites una barra de bebidas o un montaje completo con mesas de postres, periqueras y accesorios decorativos, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoComplemento">
                Complemento de interés
              </label>
              <select id="tipoComplemento" name="tipoComplemento" class="form-field__input form-field__select">
                <option value="">Selecciona el complemento</option>
                <option value="Barra Madera 2m">Barra de Madera 2 metros</option>
                <option value="Barra Madera 3m">Barra de Madera 3 metros</option>
                <option value="Barra Acrílico LED 2m">Barra Acrílico LED 2 metros</option>
                <option value="Barra Acrílico LED 3m">Barra Acrílico LED 3 metros</option>
                <option value="Barra Industrial">Barra Industrial</option>
                <option value="Mesa Postres Madera">Mesa de Postres Madera</option>
                <option value="Mesa Postres Acrílico">Mesa de Postres Acrílico</option>
                <option value="Mesa Postres Vintage">Mesa de Postres Vintage</option>
                <option value="Periqueras / Bancos">Periqueras / Bancos Altos</option>
                <option value="Accesorios Decorativos">Accesorios Decorativos</option>
                <option value="Paquete Completo">Paquete Completo</option>
                <option value="Varios">Varios / No estoy seguro</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: qué complementos necesitas, estilo de tu evento, número de invitados..."
