    ],
    cta: "Ver equipo de cómputo",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    alt: "Renta de computadoras para eventos CDMX: presentación con equipo de cómputo en congreso corporativo",
    img2: "/images/eventos/corporativos-hero.avif",
