---
/**
 * ─── Services Landing Page ───
 * Página hub de todos los servicios de EVENTECH.
 * Catálogo completo de renta de equipo para eventos en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE, SERVICE_CATEGORIES } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd } from "@utils/seo";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios" },
];

const jsonLd = [
  serviceJsonLd({
    name: "Servicios de Renta de Equipo para Eventos en CDMX",
    description: "Catálogo completo de renta de mobiliario, audio, iluminación, carpas, pistas de baile y accesorios para eventos en CDMX.",
    url: "/servicios/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
  ]),
];
---

<PageLayout
  title="Servicios de Renta de Equipo para Eventos en CDMX"
  description="Catálogo completo: mobiliario, audio, iluminación, carpas, pistas de baile y accesorios para bodas, XV años y corporativos en CDMX."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Catálogo completo de equipo para eventos"
    title='Servicios de <span class="highlight">Renta de Equipo</span> para Eventos'
    subtitle="Mobiliario, audio, iluminación, carpas y todo lo que necesitas para tu evento en un solo lugar. Entrega, montaje y asesoría incluidos en cada renta."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
    cards={[
      {
        title: "Todo el equipo para tu evento en un solo lugar",
        content: "<strong>Renta de equipo para eventos</strong> sin complicaciones. En EVENTECH centralizamos mobiliario premium, sistemas audiovisuales de última generación, carpas profesionales, iluminación arquitectónica y accesorios decorativos bajo un solo contacto y una sola cotización. Olvídate de coordinar con múltiples proveedores — nuestro catálogo integral cubre cada necesidad de tu celebración, desde bodas íntimas en Polanco hasta congresos corporativos de gran escala en Santa Fe.",
      },
      {
        title: "Servicio integral con logística garantizada",
        content: "<strong>Entrega puntual, montaje profesional y recolección</strong> incluidos en cada renta. Nuestro equipo de logística coordinado por especialistas en producción de eventos se encarga de cada detalle técnico y operativo para que tú solo disfrutes tu celebración. Con cobertura en toda la CDMX y zona metropolitana, operamos con protocolos de calidad que garantizan cero contratiempos, sin costos ocultos y sin sorpresas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Ya sabes qué necesitas para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada en menos de 24 horas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO COMPLETO — Todos los servicios
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo Completo"
        subtitle="Todo el equipamiento para tu evento en un solo lugar"
        description={[
          "En EVENTECH contamos con el inventario más completo de renta de equipo para eventos en la Ciudad de México. Cada categoría incluye múltiples modelos, estilos y configuraciones para adaptarse a cualquier tipo de celebración y presupuesto.",
          "Desde sillas Tiffany para una boda elegante hasta sistemas de sonido profesional para un congreso corporativo — tenemos la solución perfecta para ti."
        ]}
      />

      <div class="grid grid--4">
        {SERVICE_CATEGORIES.map((service) => (
          <Card
            name={service.name}
            excerpt={service.excerpt}
            cta={service.cta}
            href={service.href}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILIARIO — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="mobiliario-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Categoría destacada</span>
          <h2 class="showcase__title" id="mobiliario-heading">Mobiliario para Eventos</h2>
          <p class="showcase__subtitle">Sillas Tiffany, Chiavari, salas lounge, mesas y barras personalizadas. Calidad premium que impresiona a tus invitados.</p>
          <p class="showcase__text">Nuestro catálogo de mobiliario es el más completo de la Ciudad de México. Desde la elegancia atemporal de las <strong>sillas Tiffany y Chiavari</strong> para bodas y galas, hasta configuraciones modernas de <strong>salas lounge</strong> que transforman cualquier espacio en un área VIP sofisticada.</p>
          <p class="showcase__text">Contamos con <strong>mesas redondas, rectangulares y tipo coctel</strong> en múltiples acabados, además de <strong>barras personalizadas</strong> que se adaptan a la temática de tu evento. Cada pieza se entrega impecable, con montaje profesional incluido.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Sillas Tiffany</span>
            <span class="showcase__tag">Sillas Chiavari</span>
            <span class="showcase__tag">Salas Lounge</span>
            <span class="showcase__tag">Mesas</span>
            <span class="showcase__tag">Barras</span>
          </div>
          <a href="/servicios/mobiliario/" class="btn btn--primary btn--lg">
            Ver catálogo de mobiliario
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="12" width="4" height="8" rx="1"/>
              <rect x="10" y="8" width="4" height="12" rx="1"/>
              <rect x="18" y="12" width="4" height="8" rx="1"/>
              <path d="M4 12V9a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       AUDIOVISUAL — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="audiovisual-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Tecnología profesional</span>
          <h2 class="showcase__title" id="audiovisual-heading">Equipo Audiovisual</h2>
          <p class="showcase__subtitle">Pantallas LED, sonido profesional, proyectores y micrófonos. Todo para presentaciones impactantes.</p>
          <p class="showcase__text">Llevamos la tecnología de nivel profesional directamente a tu evento. Nuestro inventario incluye <strong>pantallas LED de alta resolución</strong> en múltiples tamaños, <strong>sistemas de sonido</strong> desde ambientación sutil hasta conciertos al aire libre, y <strong>proyectores Full HD</strong> para presentaciones corporativas impecables.</p>
          <p class="showcase__text">Cada equipo viene con <strong>técnico de operación incluido</strong>, pruebas de sonido previas al evento y cableado oculto para una instalación limpia. Ya sea una conferencia para 50 personas o un festival para 5,000 — tenemos la solución audiovisual perfecta.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Pantallas LED</span>
            <span class="showcase__tag">Sonido Profesional</span>
            <span class="showcase__tag">Proyectores</span>
            <span class="showcase__tag">Micrófonos</span>
            <span class="showcase__tag">DJ Equipment</span>
          </div>
          <a href="/servicios/audiovisual/" class="btn btn--primary btn--lg">
            Ver equipo audiovisual
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CARPAS — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="carpas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Espacios protegidos</span>
          <h2 class="showcase__title" id="carpas-heading">Carpas para Eventos</h2>
          <p class="showcase__subtitle">Carpas profesionales en múltiples tamaños con montaje, iluminación interior y opciones de piso incluidas.</p>
          <p class="showcase__text">Transforma cualquier espacio abierto en un venue elegante y protegido. Nuestras <strong>carpas tipo carpa árabe, tipo hangar y estructurales</strong> se adaptan a jardines, terrazas y estacionamientos, creando ambientes espectaculares sin importar el clima.</p>
          <p class="showcase__text">Cada instalación incluye <strong>estructura certificada, anclaje profesional y opciones de piso</strong> (duela, alfombra o plataforma). Complementa con <strong>iluminación interior, cortinas y clima artificial</strong> para crear el ambiente perfecto. Capacidad desde 20 hasta más de 1,000 invitados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Carpas Árabes</span>
            <span class="showcase__tag">Carpas Estructurales</span>
            <span class="showcase__tag">Tipo Hangar</span>
            <span class="showcase__tag">Pisos</span>
            <span class="showcase__tag">Clima Artificial</span>
          </div>
          <a href="/servicios/carpas/" class="btn btn--primary btn--lg">
            Cotizar carpas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 20l9-16 9 16"/>
              <path d="M7.5 20l4.5-8 4.5 8"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ILUMINACIÓN — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="iluminacion-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Ambientación profesional</span>
          <h2 class="showcase__title" id="iluminacion-heading">Iluminación para Eventos</h2>
          <p class="showcase__subtitle">Luces LED arquitectónicas, robóticas, efectos especiales y cortinas de luz. Creamos el ambiente perfecto.</p>
          <p class="showcase__text">La iluminación define la atmósfera de tu evento. Contamos con <strong>luces LED arquitectónicas</strong> para resaltar la estructura del venue, <strong>cabezas robóticas</strong> para shows dinámicos, y <strong>cortinas de luz</strong> que transforman cualquier espacio en algo mágico.</p>
          <p class="showcase__text">Nuestro equipo de iluminación diseña un <strong>plano de luces personalizado</strong> para cada evento. Incluimos <strong>efectos especiales</strong> como máquinas de humo, papelitos de mariposas y luces UV. Desde iluminación ambiental cálida para una cena íntima hasta shows de luz sincronizados para fiestas de XV años.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">LED Arquitectónico</span>
            <span class="showcase__tag">Robóticas</span>
            <span class="showcase__tag">Cortinas de Luz</span>
            <span class="showcase__tag">Efectos Especiales</span>
            <span class="showcase__tag">Mariposas</span>
          </div>
          <a href="/servicios/iluminacion/" class="btn btn--primary btn--lg">
            Diseñar iluminación
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18h6"/>
              <path d="M10 22h4"/>
              <path d="M12 2v1"/>
              <path d="M12 7a4 4 0 0 1 4 4c0 2-1.5 3-2 4h-4c-.5-1-2-2-2-4a4 4 0 0 1 4-4z"/>
              <path d="M4.22 7.22l.7.7"/>
              <path d="M19.07 7.93l-.7.7"/>
              <path d="M2 12h1"/>
              <path d="M21 12h1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTAS DE BAILE — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pistas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Centro de la fiesta</span>
          <h2 class="showcase__title" id="pistas-heading">Pistas de Baile</h2>
          <p class="showcase__subtitle">Pistas LED programables, de madera y modulares. El centro de atención de cualquier celebración.</p>
          <p class="showcase__text">La pista de baile es donde sucede la magia de tu evento. Ofrecemos <strong>pistas LED programables</strong> con patrones de color personalizados, <strong>pistas de madera clásica</strong> con acabado espejo, y <strong>pistas modulares</strong> que se adaptan a cualquier espacio y forma.</p>
          <p class="showcase__text">Cada pista incluye <strong>instalación nivelada profesional</strong>, bordes de seguridad y diseño de iluminación perimetral. Personalizamos el <strong>monograma o logo de tu evento</strong> directamente en las pistas LED. Disponibles desde 3x3 metros hasta pistas de gran formato para más de 500 personas.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Pistas LED</span>
            <span class="showcase__tag">Madera Clásica</span>
            <span class="showcase__tag">Modulares</span>
            <span class="showcase__tag">Monograma</span>
            <span class="showcase__tag">Gran Formato</span>
          </div>
          <a href="/servicios/pistas-baile/" class="btn btn--primary btn--lg">
            Ver pistas de baile
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       INFLABLES — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="inflables-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Diversión garantizada</span>
          <h2 class="showcase__title" id="inflables-heading">Inflables para Fiestas</h2>
          <p class="showcase__subtitle">Brincolines, toboganes, castillos y juegos inflables para fiestas infantiles. Diversión segura garantizada.</p>
          <p class="showcase__text">Haz que la fiesta de los más pequeños sea inolvidable. Nuestro catálogo incluye <strong>brincolines temáticos</strong>, <strong>toboganes gigantes</strong> con doble carril, <strong>castillos inflables</strong> y juegos interactivos que mantienen a los niños entretenidos por horas.</p>
          <p class="showcase__text">La seguridad es nuestra prioridad: cada inflable cuenta con <strong>certificación de seguridad</strong>, anclaje profesional, red de protección y <strong>monitor de seguridad</strong> durante todo el evento. Incluimos inflado, instalación y supervisión. Ideales para fiestas infantiles, kermesses, eventos escolares y días familiares corporativos.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Brincolines</span>
            <span class="showcase__tag">Toboganes</span>
            <span class="showcase__tag">Castillos</span>
            <span class="showcase__tag">Juegos Interactivos</span>
            <span class="showcase__tag">Pistas de Obstáculos</span>
          </div>
          <a href="/servicios/inflables/" class="btn btn--primary btn--lg">
            Ver inflables
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
              <line x1="9" y1="9" x2="9.01" y2="9"/>
              <line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATERING — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="catering-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Experiencia gourmet</span>
          <h2 class="showcase__title" id="catering-heading">Catering para Eventos</h2>
          <p class="showcase__subtitle">Canapés gourmet, mesas de dulces, barra de quesos y snacks. Deliciosos complementos para consentir a tus invitados.</p>
          <p class="showcase__text">Consiente a tus invitados con una experiencia gastronómica memorable. Ofrecemos <strong>canapés gourmet</strong> con presentación de alta cocina, <strong>mesas de dulces personalizadas</strong> que se adaptan a la temática de tu evento, y <strong>barras de quesos artesanales</strong> con selección premium.</p>
          <p class="showcase__text">Cada servicio de catering incluye <strong>montaje de estaciones</strong>, vajilla elegante, personal de servicio y <strong>menú personalizado</strong> según tus preferencias y restricciones alimentarias. Complementa con estaciones de <strong>snacks gourmet, fruta de temporada y fuentes de chocolate</strong>.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Canapés Gourmet</span>
            <span class="showcase__tag">Mesas de Dulces</span>
            <span class="showcase__tag">Barra de Quesos</span>
            <span class="showcase__tag">Snacks Premium</span>
            <span class="showcase__tag">Fuentes de Chocolate</span>
          </div>
          <a href="/servicios/catering/" class="btn btn--primary btn--lg">
            Ver menú catering
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8h1a4 4 0 0 1 0 8h-1"/>
              <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/>
              <line x1="6" y1="1" x2="6" y2="4"/>
              <line x1="10" y1="1" x2="10" y2="4"/>
              <line x1="14" y1="1" x2="14" y2="4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ACCESORIOS — Sección destacada
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="accesorios-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Complementos esenciales</span>
          <h2 class="showcase__title" id="accesorios-heading">Accesorios para Eventos</h2>
          <p class="showcase__subtitle">Barras, calentadores, generadores, manteles y fundas. Todo lo necesario para complementar tu evento.</p>
          <p class="showcase__text">Los detalles hacen la diferencia. Nuestro catálogo de accesorios incluye <strong>manteles y fundas</strong> en más de 30 colores, <strong>calentadores de exterior</strong> para eventos en temporada de frío, y <strong>generadores de energía</strong> silenciosos para venues sin conexión eléctrica.</p>
          <p class="showcase__text">Complementa tu evento con <strong>centros de mesa, bases para arreglos florales, mamparas divisorias</strong> y señalización personalizada. Cada accesorio se entrega limpio, planchado y listo para usar. Incluimos <strong>asesoría de decoración</strong> para ayudarte a elegir la combinación perfecta.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Manteles y Fundas</span>
            <span class="showcase__tag">Calentadores</span>
            <span class="showcase__tag">Generadores</span>
            <span class="showcase__tag">Centros de Mesa</span>
            <span class="showcase__tag">Señalización</span>
          </div>
          <a href="/servicios/accesorios/" class="btn btn--primary btn--lg">
            Ver accesorios
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v2"/>
              <path d="M12 21v2"/>
              <path d="M4.22 4.22l1.42 1.42"/>
