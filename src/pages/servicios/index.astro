---
/**
 * ─── EVENTECH.MX — Servicios (L2 hub, rediseño 2026) ───
 * Catálogo completo de renta de equipo para eventos en CDMX.
 * Homologado al Home (L1): importa home-2026.css, usa clases `hm-`.
 * CSS exclusivo de esta página: namespace `sv-` (stats band) al final.
 *
 * Keyword primaria: "renta de equipo para eventos CDMX"
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, SERVICE_CATEGORIES, FEATURES, ALLIANCES } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const features = FEATURES.slice(0, 6);

const alliances = [
  ...ALLIANCES.filter((r) => r.company === "REDEIL"),
  ...ALLIANCES.filter((r) => r.company !== "REDEIL"),
].slice(0, 8);

const steps = [
  { n: 1, t: "Cotiza", p: "Cuéntanos tu evento, fecha y venue. Respondemos con cotización en menos de 24 horas." },
  { n: 2, t: "Confirma", p: "Ajustamos el paquete a tu presupuesto y apartamos la fecha con un anticipo." },
  { n: 3, t: "Entregamos", p: "Llevamos y montamos todo el día del evento antes de que llegue el primer invitado." },
  { n: 4, t: "Disfruta", p: "Tú celebras; al terminar nuestro equipo desmonta y recoge sin que muevas un dedo." },
];

const serviciosFaqs = [
  {
    question: "¿Qué categorías de equipo renta EVENTECH para eventos?",
    answer: "Rentamos 9 categorías: mobiliario (sillas, mesas, salas lounge, barras), audiovisual (pantallas LED, sonido, proyectores, micrófonos), carpas y estructuras, iluminación (arquitectónica, decorativa, escenario, efectos), pistas de baile, inflables, equipo de catering, cómputo (laptops, iPads, PCs e impresoras) y accesorios. Todo bajo un solo contrato con entrega y montaje incluidos.",
  },
  {
    question: "¿La entrega y el montaje están incluidos en el precio?",
    answer: "Sí. Todos nuestros servicios incluyen entrega en el venue, montaje profesional por nuestro equipo y recolección al finalizar. El costo de envío puede variar según la zona, pero siempre lo detallamos en tu cotización antes de confirmar.",
  },
  {
    question: "¿Puedo rentar varias categorías de equipo en un solo pedido?",
    answer: "Absolutamente. Una de nuestras principales ventajas es que puedes armar el paquete completo — mobiliario, audio, iluminación, carpas y accesorios — en un solo pedido, con un solo contrato y una sola logística de entrega. Esto simplifica la coordinación y reduce costos.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar el equipo?",
    answer: "Recomendamos reservar con al menos 2 semanas de anticipación para garantizar disponibilidad, especialmente en temporada alta (noviembre–febrero). Para bodas o congresos, lo ideal es apartar con 1–2 meses. También atendemos solicitudes de último momento sujetas a disponibilidad.",
  },
  {
    question: "¿Cuáles son las zonas de cobertura para entrega de equipo?",
    answer: "Cubrimos toda la Ciudad de México y Zona Metropolitana: Polanco, Santa Fe, Coyoacán, Roma-Condesa, Del Valle, Naucalpan, Huixquilucan y Tlalnepantla. También atendemos Toluca, Metepec, Cuernavaca y ciudades cercanas con costos de envío claros desde la cotización.",
  },
  {
    question: "¿Cómo obtengo una cotización para el equipo de mi evento?",
    answer: "La forma más rápida es por WhatsApp: cuéntanos el tipo de evento, fecha, venue y equipo que necesitas, y te respondemos en menos de 24 horas con una propuesta detallada. También puedes usar el formulario en esta página. Sin compromiso y sin costos ocultos.",
  },
];

// Módulos destacados — copy editorial único por categoría
const featuredModules = [
  {
    idx: 0,
    eyebrow: "Mobiliario",
    title: "La primera impresión la crea el mobiliario, antes de que suene una sola nota",
    lead: "Los invitados se forman un juicio del evento en los primeros veinte segundos. Todo lo que ven antes de sentarse es mobiliario.",
    body: [
      "Manejamos <strong>sillas Tiffany, Chiavari, Crossback y Ghost, mesas redondas e imperiales, salas lounge modulares y barras de diseño</strong> en acabados que van del blanco nupcial al madera natural y al negro mate. El inventario es propio: revisado, retapizado y en condiciones impecables para cada montaje.",
      "No entregamos piezas sueltas; diseñamos la distribución completa. Calculamos aforos, flujos de circulación y alturas de mesa para que el salón respire. Esa diferencia —entre «mobiliario rentado» y «espacio diseñado»— es exactamente la que aparece en cada fotografía del evento.",
    ],
    cta: "Explorar mobiliario",
    image: "/images/moviliario-para-eventos/boda-salon-mesas-redondas-flores-dorado-34.avif",
    alt: "Renta de mobiliario para eventos en CDMX: salón con mesas redondas y sillas chiavari doradas",
    img2: "/images/mobiliario/sillas-chiavari-doradas-boda-lujo.avif",
    alt2: "Sillas Chiavari doradas en salón de lujo para bodas CDMX",
