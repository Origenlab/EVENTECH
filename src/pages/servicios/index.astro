// Menu de categorías para navegación interna
const catMenu = SERVICE_CATEGORIES.map((s) => ({ label: s.name, href: `#cat-${s.id}` }));

const jsonLd = [
  serviceJsonLd({
    name: "Servicios de Renta de Equipo para Eventos CDMX",
    description:
      "Catálogo completo de renta de mobiliario, audio, iluminación, carpas, pistas de baile, catering y accesorios para eventos en CDMX y Estado de México.",
    url: "/servicios/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios de renta de equipo", url: "/servicios/" },
  ]),
  faqJsonLd(serviciosFaqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios" },
];
---

<PageLayout
  title="Renta de equipo para eventos CDMX | Catálogo completo"
  rawTitle={true}
  description="Catálogo de renta de equipo para eventos en CDMX: mobiliario, audio, carpas, iluminación, pistas de baile, inflables, catering y accesorios. Entrega, montaje y cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- ══════════════════════════════════════════════════════════════
         HERO
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm-hero" aria-labelledby="sv-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <!-- Breadcrumbs inline en el hero -->

        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">
              Catálogo de renta · CDMX y Estado de México
            </p>
            <h1 id="sv-hero-heading">
              Renta de equipo para eventos, todo en un solo <em>catálogo</em>
            </h1>
            <p class="hm-hero__lead">
              9 categorías de equipamiento profesional. Mobiliario, audio, carpas,
              iluminación, cómputo y más — entrega, montaje y asesoría incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20equipo%20para%20mi%20evento`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z" />
                </svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5v14M5 12l7 7 7-7" />
                </svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 30 años de experiencia</strong>, EVENTECH es una
              de las empresas con mayor trayectoria en la renta de equipo para eventos
              en México. Tres décadas equipando bodas, XV años, corporativos y
              celebraciones privadas en CDMX y Estado de México nos respaldan
              como proveedor de confianza para planners, empresas y familias.
            </p>
            <p>
              Nuestro catálogo abarca <strong>9 categorías completas</strong>
              —mobiliario, audiovisual, carpas, iluminación, pistas de baile,
              inflables, catering, cómputo y accesorios— con inventario propio y verificado,
              entrega puntual garantizada y un equipo especializado que monta y
              desmonta el día del evento para que tú no cargues con la logística.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         NAV DE CATEGORÍAS (acceso rápido)
         ══════════════════════════════════════════════════════════════ -->
    <nav class="hm-menu" aria-label="Categorías de servicios">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(4, 1fr);">
        {catMenu.map((m) => (
          <li>
            <a class="hm-menu__item" href={m.href}>{m.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- ══════════════════════════════════════════════════════════════
         CATÁLOGO — Todas las categorías
         ══════════════════════════════════════════════════════════════ -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Todo en un solo lugar</p>
            <h2 id="catalogo-heading">Catálogo de servicios</h2>
            <p class="hm__head-sub">9 categorías de equipo para cualquier tipo de celebración.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Rentamos cada categoría de equipo que un evento necesita bajo un mismo
              proveedor. Eso elimina la coordinación entre múltiples empresas: un solo
