---
/**
 * ─── Services Landing Page ───
 * Página hub de todos los servicios de EVENTECH.
 * Catálogo completo de renta de equipo para eventos en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE, SERVICE_CATEGORIES, FEATURES } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd } from "@utils/seo";

const jsonLd = [
  serviceJsonLd({
    name: "Servicios de Renta de Equipo para Eventos en CDMX",
    description: "Catálogo completo de renta de mobiliario, audio, iluminación, carpas, pistas de baile y accesorios para eventos en CDMX.",
    url: "/servicios/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
  ]),
];
---

<PageLayout
  title="Servicios de Renta de Equipo para Eventos"
  description="Catálogo completo: mobiliario, audio, iluminación, carpas, pistas de baile y accesorios para bodas, XV años y corporativos en CDMX."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Catálogo completo de equipo para eventos"
    title='Servicios de <span class="highlight">Renta de Equipo</span> para Eventos'
    subtitle="Mobiliario, audio, iluminación, carpas y todo lo que necesitas para tu evento en un solo lugar. Entrega, montaje y asesoría incluidos en cada renta."
    primaryCTA={{ label: "Cotiza tu evento", href: "/contacto/" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
    cards={[
      {
        content: "Olvídate de coordinar con múltiples empresas. En EVENTECH encuentras <strong>mobiliario, audio, iluminación, carpas y accesorios</strong> con un solo contacto, una sola cotización y un solo equipo de montaje. Todo el equipamiento que necesitas para tu evento en un solo lugar.",
      },
      {
        content: "Cada renta incluye <strong>entrega puntual, montaje profesional y recolección</strong>. Nuestro equipo de logística se encarga de cada detalle para que tú solo disfrutes tu evento. Sin costos ocultos, sin sorpresas, sin complicaciones.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Ya sabes qué necesitas para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada en menos de 24 horas"
    primaryCTA={{ label: "Cotizar ahora", href: "/contacto/" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO COMPLETO — Todos los servicios
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo Completo"
        subtitle="Todo el equipamiento para tu evento en un solo lugar"
        description={[
          "En EVENTECH contamos con el inventario más completo de renta de equipo para eventos en la Ciudad de México. Cada categoría incluye múltiples modelos, estilos y configuraciones para adaptarse a cualquier tipo de celebración y presupuesto.",
          "Desde sillas Tiffany para una boda elegante hasta sistemas de sonido profesional para un congreso corporativo — tenemos la solución perfecta para ti."
        ]}
      />

      <div class="grid grid--4">
        {SERVICE_CATEGORIES.map((service) => (
          <Card
            name={service.name}
            excerpt={service.excerpt}
            cta={service.cta}
            href={service.href}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       QUÉ INCLUYE CADA RENTA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="incluye-heading">
    <div class="container">
      <SectionHeader
        id="incluye-heading"
        title="¿Qué Incluye Cada Renta?"
        subtitle="Servicio integral, sin sorpresas"
        description={[
          "En EVENTECH, el precio que cotizas es el precio que pagas. Cada renta incluye todo lo necesario para que tu evento sea un éxito: desde la asesoría inicial hasta la recolección del equipo.",
          "No importa si rentas una silla o un evento completo — nuestro compromiso de servicio es el mismo."
        ]}
      />

      <div class="includes-grid">
        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3 class="includes-card__title">Asesoría Personalizada</h3>
          <p class="includes-card__text">Te ayudamos a elegir el equipo ideal según tu tipo de evento, número de invitados, venue y presupuesto. Sin presiones, sin compromiso.</p>
        </div>

        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          </div>
          <h3 class="includes-card__title">Entrega en Tu Venue</h3>
          <p class="includes-card__text">Llevamos el equipo directamente a tu salón, jardín o venue en toda la CDMX y Zona Metropolitana. Puntualidad garantizada.</p>
        </div>

        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3 class="includes-card__title">Montaje Profesional</h3>
          <p class="includes-card__text">Nuestro equipo de instaladores se encarga del armado completo. Cada pieza queda en su lugar exacto según el layout de tu evento.</p>
        </div>

        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="includes-card__title">Equipo Garantizado</h3>
          <p class="includes-card__text">Cada pieza sale limpia, sanitizada y en perfectas condiciones. Incluimos seguro básico por uso normal durante tu evento.</p>
        </div>

        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="includes-card__title">Recolección Incluida</h3>
          <p class="includes-card__text">Al terminar tu evento, regresamos por todo el equipo. Desmontaje y recolección sin costo adicional dentro de CDMX.</p>
        </div>

        <div class="includes-card">
          <div class="includes-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
          </div>
          <h3 class="includes-card__title">Precios Transparentes</h3>
          <p class="includes-card__text">Sin costos ocultos ni cargos de última hora. El precio que cotizas incluye todo: entrega, montaje, desmontaje y recolección.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       POR QUÉ ELEGIRNOS
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="porque-heading">
    <div class="container">
      <SectionHeader
        id="porque-heading"
        title="¿Por Qué Elegir EVENTECH?"
        subtitle="La diferencia está en los detalles"
        description={[
          "Sabemos que organizar un evento puede ser estresante. Por eso, en EVENTECH nos enfocamos en hacer tu vida más fácil: cotizaciones rápidas, precios transparentes, entrega puntual y equipo siempre en perfectas condiciones.",
          "No somos solo proveedores, somos socios de tu evento. Nuestro equipo te acompaña desde la primera llamada hasta el desmontaje."
        ]}
      />

      <div class="grid grid--4">
        {FEATURES.map((feature) => (
          <Card
            name={feature.name}
            excerpt={feature.excerpt}
            cta={feature.cta}
            href={feature.href}
            icon={feature.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Haz realidad el evento que siempre soñaste"
    subheadline="Más de 500 eventos exitosos en CDMX nos respaldan. Cotiza hoy y recibe asesoría personalizada sin compromiso."
    primaryCTA={{ label: "Cotizar mi evento", href: "/contacto/" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
    variant="accent"
  />
</PageLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════════════
     INCLUDES GRID
     ═══════════════════════════════════════════════════════════════════════ */
  .includes-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .includes-card {
    background: var(--color-bg);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-sm);
  }

  .includes-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    margin-block-end: var(--space-lg);
  }

  .includes-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-heading);
    margin-block-end: var(--space-sm);
  }

  .includes-card__text {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .includes-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .includes-grid {
      grid-template-columns: 1fr;
    }

    .includes-card {
      padding: var(--space-lg);
    }
  }
</style>
