    img2: "/images/pistas-baile/pista-madera-natural-boda.avif",
    alt2: "Pista de baile de madera natural para boda clásica CDMX",
    img3: "/images/pistas-baile/pista-acrilica-transparente-boda.avif",
    alt3: "Pista acrílica transparente iluminada para boda moderna",
