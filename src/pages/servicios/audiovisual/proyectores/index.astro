---
/**
 * ─── EVENTECH.MX — Renta de Proyectores y Video para Eventos (Hub L4, molde hm- 2026) ───
 * Full HD/4K · Streaming · Video Mapping · Pantallas de Proyección — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: reusadas de /images/audiovisual (faltan fotos reales por tipo — reemplazar).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "fullhd-4k",
    name: "Proyectores Full HD y 4K",
    badge: "El más solicitado",
    excerpt: "5,000 a 10,000 lúmenes en Full HD y 4K nativo. Imagen nítida en salones con luz ambiental y auditorios de hasta 500 personas. Pantalla de proyección incluida.",
    href: "/servicios/audiovisual/proyectores/fullhd-4k/",
    image: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif",
    specs: ["5,000–10,000 lm", "Full HD", "4K nativo", "HDMI / SDI / HDBaseT"],
  },
  {
    id: "streaming",
    name: "Streaming en Vivo",
    badge: "Eventos híbridos",
    excerpt: "Multi-cámara HD, switcher Blackmagic ATEM y encoder profesional. Transmisión simultánea a YouTube, Zoom o Teams con grabación HD del evento incluida.",
    href: "/servicios/audiovisual/proyectores/streaming/",
    image: "/images/audiovisual/equipo-audiovisual-completo-boda.avif",
    specs: ["Multi-cámara", "ATEM", "1080p 60fps", "YouTube / Zoom / Teams"],
  },
  {
    id: "mapping",
    name: "Video Mapping",
    badge: "Efecto WOW",
    excerpt: "Proyección artística con Resolume Arena sobre fachadas, escenarios y pasteles de boda. El efecto visual más impactante para bodas y lanzamientos de producto.",
    href: "/servicios/audiovisual/proyectores/mapping/",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    specs: ["Resolume Arena", "Fachadas 3D", "Cake mapping", "Contenido a medida"],
  },
  {
    id: "pantallas-proyeccion",
    name: "Pantallas de Proyección",
    badge: "La superficie ideal",
    excerpt: "Front y rear projection de 100 a 300 pulgadas. Trípode, eléctrica, frame y fast-fold para presentaciones en salón o escenarios de congreso.",
    href: "/servicios/audiovisual/proyectores/pantallas-proyeccion/",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    specs: ['100"–300"', "Front / Rear", "Fast-fold", "Trípode", "Frame"],
  },
];

const whyFeatures = [
  {
    title: "Operador de video dedicado en cada evento",
    body: "No entregamos el proyector y nos vamos. Un operador de video se queda todo el evento gestionando fuentes, transiciones y monitoreando la señal — sea una presentación con varios ponentes, un streaming en vivo o un show de mapping. La proyección falla frente a todos: por eso siempre hay alguien operándola.",
  },
  {
    title: "Inventario propio calibrado — sin subcontratar",
    body: "Proyectores propios DLP y LCD en bodega CDMX. Cada equipo se calibra en brillo, color y foco antes de salir, y se verifica la vida útil de la lámpara/láser. Lo que cotizamos es lo que existe, revisado antes de cada entrega. Sin sorpresas de una imagen apagada o desenfocada el día del evento.",
  },
  {
    title: "Lúmenes correctos según la luz de tu venue",
    body: "Un proyector que se ve espectacular en salón oscuro desaparece con luz ambiental. Hacemos visita técnica sin costo para medir la luz, las distancias y el tamaño de imagen, y recomendarte los lúmenes exactos — para que la imagen se vea nítida desde cualquier punto y no pagues por más equipo del necesario.",
  },
  {
    title: "Contenido a medida y pruebas previas",
    body: "Streaming y mapping no se improvisan: diseñamos el contenido, hacemos levantamiento técnico del venue, calibramos y ensayamos antes del evento. En proyección estándar probamos resolución y fuentes con tu laptop antes de abrir puertas. Nada de descubrir un problema de señal cuando ya llegó la audiencia.",
  },
  {
    title: "Respaldo de equipo y laptop en sitio",
    body: "Cargamos proyector, cables y laptop de respaldo en cada servicio. Si un equipo o una conexión falla durante el montaje o el evento, se reemplaza sin costo en sitio. El operador tiene con qué responder ante cualquier imprevisto — no te quedas con una pantalla en negro a media presentación.",
  },
  {
    title: "Producción audiovisual integral",
    body: "Proyección, streaming y mapping se coordinan mejor cuando el sonido y la iluminación vienen del mismo proveedor. Integramos todo desde una sola empresa, con un solo equipo técnico y una sola logística — para que la imagen, el audio y la luz estén sincronizados y nadie se eche la culpa entre proveedores.",
  },
];

const steps = [
  { n: 1, t: "Cotización y visita técnica", p: "Nos indicas tipo de evento, venue, número de asistentes y contenido a proyectar. Hacemos visita técnica sin costo para medir luz, distancias y tamaño de imagen. En menos de 24 horas te confirmamos el equipo ideal y te enviamos propuesta." },
  { n: 2, t: "Propuesta técnica y aparto de equipo", p: "Definimos lúmenes, resolución, tipo de pantalla y — si es streaming o mapping — diseño de contenido y flujo técnico. Con el 30% de anticipo apartamos el equipo y la fecha. Coordinamos con tu productor, wedding planner o el venue si aplica." },
  { n: 3, t: "Instalación, calibración y pruebas", p: "Llegamos con tiempo el día del evento o la tarde anterior. Montaje con cableado oculto, calibración de brillo y foco según la luz del venue, y prueba completa de imagen, señal y contenido antes de abrir puertas. Tú o tu coordinador dan el visto bueno." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "El operador de video gestiona la proyección durante todo el evento, controla fuentes y monitorea la señal. Al cierre, desmontamos, recogemos y hacemos conteo de equipo. El desmontaje y recolección están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuántos lúmenes necesita el proyector para mi evento?", answer: "Depende del ambiente de tu venue. Para salones oscuros o con control de iluminación, de 3,000 a 5,000 lúmenes es suficiente. Si hay luz ambiental moderada (ventanales, iluminación parcial), recomendamos de 5,000 a 7,000 lúmenes. Para grandes recintos, auditorios o eventos al aire libre necesitas de 7,000 a 10,000 lúmenes. Nuestro equipo técnico evalúa tu espacio en una visita sin costo y te recomienda la potencia exacta para garantizar una imagen nítida y visible desde cualquier punto." },
  { question: "¿Pueden hacer transmisión en vivo (streaming) de mi evento?", answer: "Sí, ofrecemos servicio completo de streaming profesional. Configuramos setups multi-cámara con cámaras HD, switcher Blackmagic ATEM, encoder profesional y conexión a internet dedicada. Transmitimos a YouTube, Zoom, Microsoft Teams o cualquier plataforma que necesites. El servicio incluye grabación del evento en alta definición como respaldo. Nuestro operador de video gestiona las transiciones, gráficos en pantalla y monitoreo de la señal en tiempo real." },
  { question: "¿Qué es video mapping y para qué tipo de eventos se usa?", answer: "El video mapping es una técnica de proyección sobre superficies tridimensionales como fachadas, edificios, escenarios, pasteles de boda y objetos decorativos. Mediante software especializado (Resolume Arena), se adapta el contenido visual a la geometría de la superficie para crear efectos inmersivos y espectaculares. Es perfecto para bodas (cake mapping, proyección en mesa de novios), lanzamientos de producto, shows artísticos y eventos corporativos de alto impacto. Requiere planeación de 1 a 2 meses de anticipación para diseño de contenido y calibración." },
  { question: "¿Qué tipo de pantalla de proyección debo elegir?", answer: "Depende del espacio y uso. Pantalla trípode para reuniones pequeñas y presentaciones rápidas (fácil de montar). Pantalla eléctrica para salas de juntas y espacios corporativos permanentes. Pantalla frame para instalaciones fijas con imagen tensada. Pantalla fast-fold para eventos con montaje rápido y profesional, disponible desde 100 hasta 300 pulgadas. Si el proyector está detrás de la pantalla (en escenarios), necesitas rear projection. Para configuraciones normales, front projection es la opción estándar. Te asesoramos según tu venue." },
  { question: "¿Puedo proyectar en exteriores o con luz de día?", answer: "Sí, pero requiere proyectores de alto lumen y control de la superficie de proyección. Con luz de día directa, ningún proyector compite con el sol — para esos casos recomendamos pantallas LED de exterior en lugar de proyección. En exteriores al atardecer o de noche, o bajo carpa con sombra controlada, un proyector de 7,000 a 10,000 lúmenes sobre pantalla de alta ganancia entrega excelente resultado. En la visita técnica evaluamos la luz de tu locación y te decimos con franqueza si conviene proyector o pantalla LED." },
  { question: "¿El proyector incluye computadora o fuente de señal?", answer: "Cada proyector incluye cable HDMI, adaptador USB-C y conectividad básica para que conectes tu laptop o dispositivo. Si no cuentas con computadora, ofrecemos renta de laptop como complemento adicional. También disponemos de reproductores multimedia para loops de video y presentaciones automáticas. Nuestro técnico te asiste con la conexión, configuración de resolución y pruebas previas al evento para garantizar que todo funcione perfectamente." },
  { question: "¿Con cuánta anticipación debo reservar proyectores?", answer: "Para renta estándar de proyectores y pantallas de proyección, recomendamos reservar con 2 a 3 semanas de anticipación. Para servicios de video mapping o streaming profesional, lo ideal es apartar con 1 a 2 meses de anticipación, ya que requieren planeación técnica, diseño de contenido y pruebas previas. En temporada alta (noviembre a febrero) la demanda aumenta considerablemente, por lo que te sugerimos reservar lo antes posible. También atendemos solicitudes urgentes sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Proyectores y Video para Eventos en CDMX",
    description: "Renta de proyectores Full HD y 4K, streaming en vivo, video mapping y pantallas de proyección para bodas, congresos y eventos corporativos en CDMX. Operador de video incluido.",
    url: "/servicios/audiovisual/proyectores/",
    priceRange: { min: 1000, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Proyectores", url: "/servicios/audiovisual/proyectores/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Proyectores" },
];
---

<PageLayout
  title="Renta de Proyectores y Video para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif"
  description="Renta de proyectores Full HD y 4K, streaming en vivo, video mapping y pantallas de proyección en CDMX. Operador de video incluido. +500 eventos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="proyectores-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Proyectores y video · CDMX y ZMVM</p>
            <h1 id="proyectores-hero-heading">
              Proyección y video para eventos — <em>de la conferencia al mapping de fachada</em>
            </h1>
            <p class="hm-hero__lead">
              Proyectores de 5,000 a 10,000 lúmenes Full HD y 4K, streaming multi-cámara,
              video mapping artístico y pantallas de proyección de hasta 300 pulgadas.
              Operador de video incluido en cada renta.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20proyectores%20y%20video%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar proyección
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>proyectores y video para eventos</strong> en CDMX con
              inventario propio calibrado — proyectores DLP y LCD de <strong>5,000 a 10,000
              lúmenes</strong> en Full HD y 4K nativo, streaming en vivo multi-cámara con
              switcher Blackmagic ATEM, video mapping con Resolume Arena sobre superficies 3D,
              y pantallas de proyección front y rear de 100 a 300 pulgadas. Cada equipo se
              calibra en brillo, color y foco antes de cada entrega.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que una imagen
              apagada o una señal caída se ven frente a toda la audiencia: por eso cada renta
              incluye visita técnica, calibración según la luz del venue y un operador de video
              dedicado durante todo el evento. Para producciones completas integramos la
              proyección con <a href="/servicios/audiovisual/sonido/">sonido profesional</a> e
              <a href="/servicios/iluminacion/">iluminación de escenario</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de proyección y video disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20proyectores%20y%20video%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué solución de video necesita tu evento?</h2>
            <p class="hm__head-sub">4 soluciones — de la proyección de una presentación al mapping que transforma una fachada.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La imagen enfoca la atención de toda la audiencia al mismo tiempo: la presentación
              del ponente, el video de los novios, la transmisión para los que no pudieron ir o
              el show que abre el evento. Si se ve opaca, se corta la señal o el contenido no
              luce, lo nota cada persona. Elegir bien no es solo lúmenes — es la superficie, la
              fuente y quién lo opera.
            </p>
            <p>
              Proyectores Full HD/4K para presentaciones y video. Streaming cuando parte de la
              audiencia está a distancia. Mapping cuando el evento necesita un momento
              espectacular. Pantallas de proyección para cada tipo de venue. Una sola empresa
              para todo el video de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de proyección y video — en detalle</h2>
            <p class="hm__head-sub">Lúmenes, resolución, flujo técnico y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada solución de video hay decisiones técnicas que afectan el resultado:
              los lúmenes que deciden si la imagen se ve con la luz del venue, la superficie que
              determina el tamaño y la nitidez, y el flujo de producción que define si un
              streaming o un mapping salen impecables o improvisados.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- FULL HD / 4K -->
        <article class="hm-feat" aria-labelledby="feat-fullhd-4k">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Proyectores Full HD y 4K</p>
            <h3 class="hm-feat__title" id="feat-fullhd-4k">Imagen nítida y brillante — la base de cualquier presentación o video en evento</h3>
            <p class="hm-feat__lead">El caballo de batalla del audiovisual. Un buen proyector con los lúmenes correctos resuelve el 80% de las necesidades de video de un evento sin complicaciones.</p>
            <p>
              Disponibles en <strong>5,000, 7,000 y 10,000 lúmenes</strong> con resolución
              Full HD (1080p) y <strong>4K nativo</strong>, tecnología DLP y LCD con contraste
              superior a 10,000:1 para colores vibrantes y negros profundos. Equipos short throw
              para espacios reducidos: imágenes de hasta 150 pulgadas a solo 1.5 metros de la
              pantalla.
            </p>
            <p>
              Incluyen <strong>lente de zoom motorizado, corrección keystone y conexiones HDMI,
              SDI y HDBaseT</strong> para fuentes profesionales. Ideales para <strong>presentaciones
              corporativas, conferencias, videos de boda y ceremonias</strong>. Cada proyector
              se entrega calibrado en brillo y color según la luz de tu venue. Para eventos en
              exteriores sin instalación fija, combínalo con nuestras
              <a href="/servicios/carpas/">carpas</a> para controlar la luz sobre la pantalla.
            </p>
            <ul class="hm-feat__stats">
              {["5,000–10,000 lm", "Full HD", "4K nativo", "Short throw", "HDMI / SDI / HDBaseT"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/audiovisual/proyectores/fullhd-4k/">
              Ver Proyectores Full HD/4K
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif" alt="Proyector 4K con pantalla gigante para evento en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/audiovisual/monitor-pantalla-presentacion-congreso.avif" alt="Proyección de presentación en congreso corporativo" loading="lazy" decoding="async" />
              <img src="/images/audiovisual/equipo-audiovisual-completo-boda.avif" alt="Proyector dentro de montaje audiovisual completo para boda" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- STREAMING -->
        <article class="hm-feat" aria-labelledby="feat-streaming">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Streaming en Vivo</p>
            <h3 class="hm-feat__title" id="feat-streaming">Multi-cámara profesional — para llevar tu evento a la audiencia que no pudo asistir</h3>
            <p class="hm-feat__lead">Un evento híbrido bien transmitido llega a diez veces más gente. Pero un streaming improvisado con una laptop se ve exactamente como lo que es. La diferencia es la producción.</p>
            <p>
              Setup completo con <strong>2 a 4 cámaras HD</strong>, switcher
              <strong>Blackmagic ATEM</strong> para transiciones en vivo, encoder de hardware
              dedicado y conexión a internet redundante. Transmisión simultánea a
              <strong>YouTube Live, Zoom, Microsoft Teams, Facebook Live</strong> y cualquier
