        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoProyector">
                Tipo de proyector / servicio
              </label>
              <select id="tipoProyector" name="tipoProyector" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de equipo</option>
                <option value="Proyector Full HD 5,000 lm">Proyector Full HD 5,000 lm</option>
                <option value="Proyector Full HD 7,000 lm">Proyector Full HD 7,000 lm</option>
                <option value="Proyector 4K 10,000 lm">Proyector 4K 10,000 lm</option>
                <option value="Streaming Multi-cámara">Streaming Multi-cámara</option>
                <option value="Video Mapping">Video Mapping</option>
                <option value="Pantalla Trípode">Pantalla Trípode</option>
                <option value="Pantalla Fast-Fold">Pantalla Fast-Fold</option>
                <option value="Pantalla Eléctrica">Pantalla Eléctrica</option>
                <option value="Paquete Completo">Paquete Completo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de asistentes, tipo de venue (salón/jardín/auditorio), contenido a proyectar, necesidad de streaming o mapping..."
