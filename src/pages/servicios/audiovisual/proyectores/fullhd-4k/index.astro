---
/**
 * ─── Proyectores Full HD y 4K — Página de Producto (Nivel 4) ───
 * Proyectores de 5,000 a 10,000 lúmenes con resolución Full HD y 4K
 * para presentaciones, conferencias y eventos de gran formato.
 *
 * Jerarquía: Servicios > Audiovisual > Proyectores > Full HD y 4K
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { label: "Full HD y 4K" },
];

const faqs = [
  { question: "¿Cuántos lúmenes necesito para mi evento?", answer: "Depende del ambiente de tu venue. Para salones oscuros con control total de iluminación, de 3,000 a 5,000 lúmenes es suficiente. Si hay luz ambiental moderada como ventanales o iluminación parcial, recomendamos de 5,000 a 7,000 lúmenes. Para grandes recintos, auditorios con más de 300 personas o eventos al aire libre, necesitas de 7,000 a 10,000 lúmenes. Nuestro técnico evalúa tu espacio y te recomienda la potencia exacta para garantizar una imagen nítida y visible desde cualquier punto del venue." },
  { question: "¿Cuál es la diferencia entre Full HD y 4K en proyectores para eventos?", answer: "Full HD (1920x1080) ofrece una imagen nítida perfecta para presentaciones de PowerPoint, videos corporativos y proyecciones hasta 200 pulgadas de diagonal. Es la opción más versátil y económica para la mayoría de eventos. 4K UHD (3840x2160) cuadruplica la resolución y es ideal para proyecciones de gran formato (más de 200 pulgadas), contenido fotográfico o cinematográfico de alta calidad, y eventos donde el detalle visual es prioritario como lanzamientos de producto y galas de alto perfil." },
  { question: "¿El proyector incluye pantalla de proyección?", answer: 'Los paquetes estándar incluyen proyector, cableado y técnico de operación. La pantalla de proyección se cotiza por separado según el tamaño y tipo que necesites (trípode, fast-fold, eléctrica o frame). También ofrecemos kits completos de proyector + pantalla con descuento especial. Si tu venue ya cuenta con pantalla fija, nuestro técnico verifica la compatibilidad y calibra el equipo para obtener la mejor imagen posible. Consulta nuestras <a href="/servicios/audiovisual/proyectores/pantallas-proyeccion/">pantallas de proyección</a> disponibles.' },
  { question: "¿Puedo conectar mi laptop al proyector sin problemas?", answer: "Sí, todos nuestros proyectores incluyen cables HDMI estándar y adaptadores USB-C para laptops modernas. También disponemos de adaptadores Mini DisplayPort, VGA y conectividad inalámbrica para presentaciones sin cables. Nuestro técnico realiza pruebas de conexión y configuración de resolución antes del evento para garantizar compatibilidad perfecta con tu equipo. Si no cuentas con laptop, ofrecemos renta de equipo de cómputo como complemento." },
  { question: "¿Los proyectores funcionan en exteriores o con luz natural?", answer: "Para eventos con luz ambiental o en exteriores, necesitas proyectores de alta luminosidad (7,000 a 10,000 lúmenes). Sin embargo, la proyección en exteriores con luz solar directa no es recomendable — funciona mejor en horarios nocturnos o al atardecer. Para eventos de día en exteriores, recomendamos nuestras <a href=\"/servicios/audiovisual/pantallas-led/\">pantallas LED</a> que tienen brillo propio y son perfectamente visibles bajo el sol. Para exteriores nocturnos, un proyector de 7,000+ lúmenes con pantalla de alta ganancia ofrece resultados excelentes." },
  { question: "¿Con cuánta anticipación debo reservar un proyector?", answer: "Para renta estándar de proyectores Full HD y 4K, recomendamos reservar con 2 a 3 semanas de anticipación para garantizar disponibilidad del modelo y potencia que necesitas. En temporada alta de eventos (noviembre a febrero), la demanda se incrementa considerablemente, por lo que sugerimos apartar tu equipo con 1 mes de anticipación. Para kits especiales con pantalla de gran formato o múltiples proyectores, lo ideal es reservar con 3 a 4 semanas. También atendemos solicitudes urgentes sujetas a disponibilidad." },
];

const specs = [
  { label: "Resolución", value: "Full HD 1080p / 4K UHD (3840×2160)" },
  { label: "Lúmenes", value: "5,000 a 10,000 lm (según modelo)" },
  { label: "Tecnología", value: "DLP / Láser (vida útil 20,000+ hrs)" },
  { label: "Contraste", value: "10,000:1 a 50,000:1" },
  { label: "Conexiones", value: "HDMI / HDBaseT / USB-C / SDI" },
  { label: "Lente", value: "Zoom óptico motorizado + lens shift" },
  { label: "Peso", value: "8 – 25 kg (según potencia)" },
  { label: "Silencio", value: "35 dB en modo eco" },
  { label: "Técnico", value: "Incluido: setup + calibración + operación" },
  { label: "Pantalla", value: "Incluida según paquete (consultar)" },
];

const sidebarNav = [
  { name: "Proyectores Full HD y 4K", href: null, active: true },
  { name: "Streaming en Vivo", href: "/servicios/audiovisual/proyectores/streaming/" },
  { name: "Video Mapping", href: "/servicios/audiovisual/proyectores/mapping/" },
  { name: "Pantallas de Proyección", href: "/servicios/audiovisual/proyectores/pantallas-proyeccion/" },
];

const sidebarRelated = [
  { name: "Pantallas de Proyección", href: "/servicios/audiovisual/proyectores/pantallas-proyeccion/" },
  { name: "Streaming en Vivo", href: "/servicios/audiovisual/proyectores/streaming/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
];

const reviews = [
  { author: "Roberto Hernández", text: "Rentamos un proyector de 7,000 lúmenes para nuestra convención anual en un hotel de Polanco. La imagen se veía perfecta en una pantalla de 200 pulgadas, incluso con algo de luz ambiental. El técnico llegó 3 horas antes para calibrar todo y durante el evento estuvo pendiente de cualquier ajuste. Servicio impecable.", rating: 5, date: "2025-11-18" },
  { author: "Patricia Villanueva", text: "Usamos un proyector 4K para el video de nuestra boda en un jardín de Coyoacán. La calidad de imagen fue espectacular — los invitados quedaron impresionados con la nitidez del video. El equipo incluyó pantalla fast-fold y todo el cableado necesario. Excelente servicio y puntualidad.", rating: 5, date: "2025-10-05" },
  { author: "Ing. Miguel Sandoval", text: "Para un congreso médico necesitábamos dos proyectores de 10,000 lúmenes en un auditorio para 500 personas. La imagen fue brillante y nítida desde cualquier asiento. El técnico configuró las presentaciones de todos los ponentes sin contratiempos. Ya es nuestro proveedor fijo para eventos corporativos.", rating: 5, date: "2025-09-12" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Proyectores Full HD y 4K para Eventos en CDMX",
    description: "Proyectores de 5,000 a 10,000 lúmenes en Full HD y 4K para presentaciones y eventos en CDMX. Técnico y pantalla incluidos. Desde $2,500.",
    url: "/servicios/audiovisual/proyectores/fullhd-4k/",
    priceRange: { min: 2500, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 189,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Proyectores", url: "/servicios/audiovisual/proyectores/" },
    { name: "Full HD y 4K", url: "/servicios/audiovisual/proyectores/fullhd-4k/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Proyectores Full HD y 4K para Eventos en CDMX"
  description="Renta de proyectores de 5,000 a 10,000 lúmenes en Full HD y 4K para presentaciones y eventos en CDMX. Técnico y pantalla incluidos. Desde $2,500."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Imagen profesional para cualquier espacio"
    title='Renta de <span class="highlight">Proyectores Full HD y 4K</span> para Eventos en CDMX'
    subtitle="Proyectores DLP y láser de 5,000 a 10,000 lúmenes con resolución Full HD y 4K para presentaciones corporativas, conferencias, bodas y eventos de gran formato. Técnico de operación y calibración incluidos."
    primaryCTA={{ label: "Cotiza tu proyector", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar proyectores Full HD o 4K para mi evento` }}
    cards={[
      {
        title: "Proyectores de grado profesional para cada espacio",
        content: "<strong>Renta de proyectores Full HD y 4K</strong> con equipos DLP y láser de las marcas líderes del mercado profesional. Proyectores de 5,000 lúmenes para salones y salas de juntas, 7,000 lúmenes para auditorios y recintos medianos, y 10,000 lúmenes para grandes espacios, convenciones y eventos al aire libre. Contraste superior a 10,000:1, lente de zoom óptico motorizado con lens shift, y conexiones HDMI, HDBaseT, USB-C y SDI para fuentes de video profesionales — cada equipo calibrado antes de la entrega.",
      },
      {
        title: "Técnico certificado y soporte durante todo el evento",
        content: "<strong>Servicio integral</strong> que incluye técnico de operación dedicado para setup, calibración de brillo y color según las condiciones lumínicas de tu venue, conexión de fuentes de video, pruebas previas y operación durante todo el evento. Adaptadores para cualquier tipo de laptop incluidos. Equipos short throw disponibles para espacios reducidos donde la distancia de proyección es limitada, logrando imágenes de hasta 150 pulgadas a solo 1.5 metros de la pantalla.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un proyector potente y nítido para tu evento?"
    subheadline="Cotiza sin compromiso — te recomendamos el equipo ideal según tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Proyectores y Video</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un proyector para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un proyector Full HD o 4K para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Proyectores Full HD y 4K</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Proyector 5,000 lm -->
          <section class="section section--alt" aria-labelledby="proy-5k-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Salones y juntas</span>
                <h2 class="showcase__title" id="proy-5k-heading">Proyector 5,000 Lúmenes</h2>
                <p class="showcase__subtitle">Imagen nítida y brillante para salones de eventos, salas de juntas y presentaciones corporativas de hasta 200 personas.</p>
                <p class="showcase__text">Nuestro <strong>proyector de 5,000 lúmenes Full HD</strong> es la opción más versátil para eventos corporativos, conferencias de mediana escala y presentaciones en salones con control de iluminación. Tecnología DLP de un chip con resolución nativa 1920x1080 que garantiza textos legibles, gráficas nítidas y videos con colores vibrantes. Contraste de 10,000:1 que asegura negros profundos y blancos brillantes incluso en salones con algo de luz ambiental residual.</p>
                <p class="showcase__text">Incluye <strong>lente de zoom óptico 1.5x con corrección keystone automática</strong> para adaptarse a cualquier distancia de proyección. Conexiones HDMI, USB-C y VGA para compatibilidad con laptops Windows, Mac y dispositivos móviles. Ideal para <strong>juntas de consejo, capacitaciones, presentaciones de ventas, ceremonias religiosas y proyección de video en bodas</strong> de hasta 200 invitados. Cada equipo se entrega con cableado completo y nuestro técnico calibra brillo y color según las condiciones de tu venue.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">5,000 lúmenes</span>
                  <span class="showcase__tag">Full HD 1080p</span>
                  <span class="showcase__tag">Zoom óptico</span>
                  <span class="showcase__tag">Hasta 200 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector 5,000 lm
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                  <span>Proyector 5,000 lm</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Proyector 7,000 lm -->
          <section class="section section--alt" aria-labelledby="proy-7k-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Auditorios</span>
                <h2 class="showcase__title" id="proy-7k-heading">Proyector 7,000 Lúmenes</h2>
                <p class="showcase__subtitle">Potencia lumínica para auditorios, convenciones y eventos donde la audiencia supera las 200 personas.</p>
                <p class="showcase__text">El <strong>proyector de 7,000 lúmenes</strong> ofrece la potencia necesaria para auditorios medianos, salones de convenciones y eventos con luz ambiental moderada. Disponible en Full HD y 4K con tecnología láser que garantiza <strong>20,000+ horas de vida útil sin cambio de lámpara</strong>, contraste superior a 20,000:1 y encendido instantáneo sin tiempo de calentamiento. La fuente láser asegura brillo constante durante todo el evento sin degradación.</p>
                <p class="showcase__text">Equipado con <strong>lente intercambiable y lens shift horizontal/vertical</strong> para una instalación flexible sin distorsión. Conectividad profesional HDMI 2.0, HDBaseT (hasta 100m de cable) y SDI para integración con sistemas de producción profesional. La opción ideal para <strong>congresos médicos, convenciones empresariales, auditorios universitarios y galas corporativas</strong> donde cada detalle visual importa. Nuestro técnico gestiona la señal de todos los presentadores para transiciones fluidas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">7,000 lúmenes</span>
                  <span class="showcase__tag">Tecnología láser</span>
                  <span class="showcase__tag">HDBaseT 100m</span>
                  <span class="showcase__tag">Lente intercambiable</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector 7,000 lm
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                  <span>Proyector 7,000 lm</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Proyector 10,000 lm -->
          <section class="section section--alt" aria-labelledby="proy-10k-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Grandes recintos</span>
                <h2 class="showcase__title" id="proy-10k-heading">Proyector 10,000 Lúmenes</h2>
                <p class="showcase__subtitle">Máxima potencia para grandes auditorios, centros de convenciones y eventos al aire libre con audiencias masivas.</p>
                <p class="showcase__text">Nuestro <strong>proyector de 10,000 lúmenes 4K láser</strong> es el equipo de mayor potencia de nuestro catálogo, diseñado para los eventos más exigentes. Resolución nativa 4K UHD (3840x2160) con contraste de 50,000:1 que reproduce cada detalle con precisión cinematográfica. Tecnología láser de estado sólido con <strong>encendido instantáneo, brillo constante y cero mantenimiento</strong>. Capaz de proyectar imágenes de hasta 500 pulgadas de diagonal en pantallas de gran formato.</p>
                <p class="showcase__text">Incluye <strong>lente motorizada de ultra largo alcance, corrección geométrica avanzada y fusión de imagen</strong> para configuraciones multi-proyector en superficies curvas o irregulares. Conectividad completa: HDMI 2.0, HDBaseT, SDI 12G y red Ethernet para control remoto. La elección profesional para <strong>centros de convenciones como Citibanamex, auditorios nacionales, eventos al aire libre y producciones donde la calidad visual no admite concesiones</strong>. Complementa con nuestras <a href="/servicios/accesorios/plantas-energia/">plantas de energía</a> para venues sin instalación eléctrica fija.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">10,000 lúmenes</span>
                  <span class="showcase__tag">4K nativo</span>
                  <span class="showcase__tag">50,000:1 contraste</span>
                  <span class="showcase__tag">Hasta 500"</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector 10,000 lm
                </a>
              </div>
              <div class="showcase__image">
