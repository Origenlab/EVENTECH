---
/**
 * ─── Streaming en Vivo — Página de Producto (Nivel 4) ───
 * Servicio de streaming profesional con cámaras HD, switcher
 * Blackmagic y encoder para transmisión a YouTube, Zoom y Teams.
 *
 * Jerarquía: Servicios > Audiovisual > Proyectores > Streaming en Vivo
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { label: "Streaming en Vivo" },
];

const faqs = [
  { question: "¿Qué velocidad de internet necesito para hacer streaming?", answer: "Para una transmisión en HD (1080p) estable, necesitas un mínimo de 10 Mbps de subida dedicados al streaming. Sin embargo, recomendamos 20-50 Mbps de subida para garantizar calidad y evitar cortes. Nuestro equipo incluye medición de velocidad en el venue y, si la conexión del salón no es suficiente, llevamos un enlace dedicado por internet móvil 5G/4G como respaldo. También configuramos codificación adaptativa para ajustar la calidad automáticamente según el ancho de banda disponible." },
  { question: "¿Pueden transmitir a varias plataformas al mismo tiempo?", answer: "Sí, nuestro servicio de streaming multi-plataforma permite transmitir simultáneamente a YouTube Live, Facebook Live, Zoom, Microsoft Teams, Vimeo y cualquier plataforma que soporte RTMP/RTMPS. Utilizamos un encoder de hardware dedicado con capacidad de restream a múltiples destinos sin pérdida de calidad. Cada plataforma recibe la señal optimizada según sus especificaciones técnicas. Puedes tener tu evento en vivo en todas las plataformas que necesites sin equipo adicional." },
  { question: "¿El streaming incluye grabación del evento?", answer: "Sí, todos nuestros paquetes de streaming incluyen grabación completa del evento en alta definición (1080p o 4K según el equipo) como respaldo. La grabación se realiza de forma independiente al streaming, directamente en disco SSD, para garantizar una copia perfecta sin depender de la calidad de internet. Al finalizar el evento, te entregamos el archivo en formato MP4 listo para edición o distribución. Opcionalmente ofrecemos edición básica del video posterior al evento." },
  { question: "¿Cuántas cámaras necesito para mi evento?", answer: "Depende del tipo de evento. Para conferencias y presentaciones, 1 cámara fija es suficiente. Para paneles de discusión, ceremonias de graduación y eventos corporativos recomendamos 2 cámaras (una general y una de detalle). Para bodas, galas, conciertos y producciones de alto perfil, el setup ideal es de 3 a 4 cámaras con operador dedicado en cada una para capturar diferentes ángulos y momentos. Nuestro director técnico gestiona las transiciones entre cámaras en tiempo real." },
  { question: "¿Se pueden agregar gráficos y logos durante la transmisión?", answer: "Sí, nuestro switcher Blackmagic ATEM permite insertar gráficos en tiempo real durante la transmisión: logo de tu empresa o evento en esquina permanente, lower thirds con nombres de ponentes, contadores de tiempo, transiciones con identidad de marca, imágenes de espera para pausas y pantallas de inicio/cierre personalizadas. Necesitamos recibir tu material gráfico (logos en PNG transparente) con al menos 3 días de anticipación para preparar las plantillas." },
  { question: "¿Con cuánta anticipación debo reservar streaming?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación para garantizar disponibilidad de equipo y permitir la planeación técnica: visita al venue para evaluar conectividad, pruebas de internet, configuración de plataformas y preparación de gráficos. Para eventos de gran escala con multi-cámara y producción integral, lo ideal es apartar con 1 a 2 meses. En temporada alta de congresos (septiembre a noviembre), la demanda aumenta significativamente." },
];

const specs = [
  { label: "Cámaras", value: "HD/4K PTZ y fijas (1 a 4 según paquete)" },
  { label: "Switcher", value: "Blackmagic ATEM Mini / ATEM Pro" },
  { label: "Encoder", value: "Hardware dedicado (no depende de PC)" },
  { label: "Plataformas", value: "YouTube / Zoom / Teams / Facebook / RTMP" },
  { label: "Internet", value: "Conexión dedicada 50 Mbps+ (respaldo 5G)" },
  { label: "Gráficos", value: "Títulos, logos y lower thirds en tiempo real" },
  { label: "Grabación", value: "Respaldo HD/4K en SSD incluido" },
  { label: "Audio", value: "Integración con sistema de sonido PA del venue" },
  { label: "Operador", value: "Director técnico de video incluido" },
  { label: "Monitoreo", value: "Preview + Program en monitores dedicados" },
];

const sidebarNav = [
  { name: "Proyectores Full HD y 4K", href: "/servicios/audiovisual/proyectores/fullhd-4k/" },
  { name: "Streaming en Vivo", href: null, active: true },
  { name: "Video Mapping", href: "/servicios/audiovisual/proyectores/mapping/" },
  { name: "Pantallas de Proyección", href: "/servicios/audiovisual/proyectores/pantallas-proyeccion/" },
];

const sidebarRelated = [
  { name: "Proyectores Full HD y 4K", href: "/servicios/audiovisual/proyectores/fullhd-4k/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Micrófonos y DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Monitores", href: "/servicios/audiovisual/pantallas-led/monitores/" },
];

const reviews = [
  { author: "Lic. Andrea Guzmán", text: "Contratamos streaming para nuestro congreso médico con 3 cámaras y transmisión simultánea a YouTube y Zoom. La calidad de video fue impecable y tuvimos más de 800 personas conectadas sin un solo corte. El operador gestionó las transiciones entre cámaras y los gráficos con nombres de ponentes de manera profesional. Excelente servicio.", rating: 5, date: "2025-11-10" },
  { author: "Carlos Mendoza", text: "Hicimos streaming de nuestra boda para familiares en el extranjero. La transmisión fue perfecta — mis abuelos en España pudieron ver toda la ceremonia en HD. El equipo llevó internet de respaldo porque el salón tenía mala señal y no hubo ningún problema. Muy recomendable.", rating: 5, date: "2025-10-22" },
  { author: "Mtra. Fernanda Ruiz", text: "Necesitábamos transmitir una graduación universitaria a múltiples plataformas. El servicio incluyó 2 cámaras, gráficos con los nombres de cada graduado y transmisión simultánea a YouTube y Facebook. Todo funcionó perfecto y la grabación HD que nos entregaron la usamos para el video institucional. Profesionales de verdad.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Equipo de Streaming en Vivo para Eventos en CDMX",
    description: "Servicio de streaming profesional con cámaras HD, switcher Blackmagic y encoder para transmisión a YouTube, Zoom y Teams. Desde $5,000.",
    url: "/servicios/audiovisual/proyectores/streaming/",
    priceRange: { min: 5000, max: 25000 },
    reviews,
    ratingValue: 5,
    reviewCount: 67,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Proyectores", url: "/servicios/audiovisual/proyectores/" },
    { name: "Streaming en Vivo", url: "/servicios/audiovisual/proyectores/streaming/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Equipo de Streaming en Vivo para Eventos en CDMX"
  description="Servicio de streaming profesional con cámaras HD, switcher Blackmagic y encoder para transmisión a YouTube, Zoom y Teams. Desde $5,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Transmite tu evento al mundo"
    title='Renta de Equipo de <span class="highlight">Streaming en Vivo</span> para Eventos en CDMX'
    subtitle="Servicio completo de streaming profesional con cámaras HD/4K, switcher Blackmagic ATEM, encoder de hardware y transmisión simultánea a YouTube, Zoom, Teams y cualquier plataforma. Director técnico de video incluido."
    primaryCTA={{ label: "Cotiza tu streaming", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar streaming en vivo para mi evento` }}
    cards={[
      {
        title: "Producción de video en vivo con equipo profesional",
        content: "<strong>Servicio de streaming profesional</strong> con cámaras HD y 4K PTZ y fijas, switcher Blackmagic ATEM Mini y Pro para transiciones en vivo, encoder de hardware dedicado y conexión a internet redundante. Transmisión simultánea a YouTube Live, Zoom, Microsoft Teams, Facebook Live y cualquier plataforma RTMP. Calidad de transmisión hasta 1080p a 60fps con audio embebido profesional y monitoreo constante de la señal — grabación completa en SSD como respaldo incluida.",
      },
      {
        title: "Director técnico y gráficos en tiempo real",
        content: "<strong>Producción integral</strong> con director técnico de video dedicado que gestiona transiciones entre cámaras, inserción de gráficos en tiempo real (logos, lower thirds, nombres de ponentes, contadores), gestión de Q&A remoto y monitoreo de la señal durante toda la transmisión. Internet de respaldo por enlace 5G incluido. Configuración de plataformas, pruebas previas y soporte técnico continuo para que tu evento híbrido sea impecable.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres transmitir tu evento a audiencias remotas?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con opciones de streaming para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Proyectores y Video</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas streaming para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar streaming en vivo para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Streaming en Vivo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Streaming Básico -->
          <section class="section section--alt" aria-labelledby="basico-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Conferencias y charlas</span>
                <h2 class="showcase__title" id="basico-heading">Streaming Básico</h2>
                <p class="showcase__subtitle">Setup con 1 cámara HD fija y encoder para transmisión estable a una plataforma — ideal para conferencias y presentaciones.</p>
                <p class="showcase__text">Nuestro <strong>paquete de streaming básico</strong> incluye 1 cámara HD fija en trípode con encuadre general del escenario, encoder de hardware dedicado para codificación estable sin depender de una computadora, y transmisión a la plataforma de tu elección (YouTube, Zoom, Teams o Facebook). La señal de audio se toma directamente del sistema de sonido del venue para calidad profesional. Incluye <strong>monitoreo de la transmisión en pantalla dedicada</strong> y grabación HD de respaldo.</p>
                <p class="showcase__text">El operador configura la transmisión 2 horas antes del evento, realiza pruebas de conexión y calidad de imagen, y permanece monitoreando durante toda la transmisión. Si el internet del venue presenta problemas, activa el <strong>enlace de respaldo por red móvil 5G</strong>. Perfecto para <strong>conferencias corporativas, capacitaciones, clases magistrales, ceremonias religiosas y juntas de consejo</strong> donde necesitas una señal limpia y confiable sin producción multi-cámara. Complementa con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> si el venue no cuenta con sistema de audio.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">1 cámara HD</span>
                  <span class="showcase__tag">Encoder dedicado</span>
                  <span class="showcase__tag">Grabación HD</span>
                  <span class="showcase__tag">Respaldo 5G</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Streaming Básico
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                  <span>Streaming Básico</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Streaming Pro -->
          <section class="section section--alt" aria-labelledby="pro-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Multi-cámara</span>
                <h2 class="showcase__title" id="pro-heading">Streaming Pro</h2>
                <p class="showcase__subtitle">Producción multi-cámara con switcher Blackmagic ATEM para transiciones profesionales y gráficos en tiempo real.</p>
                <p class="showcase__text">El <strong>paquete Streaming Pro</strong> es nuestra solución más popular para eventos que requieren producción de video de nivel broadcast. Incluye <strong>2 a 3 cámaras HD/4K</strong> (general, medio plano y detalle), switcher <strong>Blackmagic ATEM Mini Pro</strong> para transiciones fluidas entre cámaras, inserción de gráficos en tiempo real (lower thirds con nombres de ponentes, logo permanente, contadores) y encoder de hardware con codificación H.264/H.265 para máxima calidad de transmisión.</p>
                <p class="showcase__text">Nuestro <strong>director técnico de video</strong> opera el switcher durante todo el evento, seleccionando los mejores ángulos y gestionando transiciones suaves entre cámaras. Incluye monitoreo en pantallas de preview y program, grabación independiente en cada cámara y una grabación master del programa final. La producción incluye <strong>pantalla de espera personalizada, intro/outro con identidad del evento y gestión de Q&A remoto</strong>. Ideal para <strong>congresos, paneles de discusión, ceremonias de premiación, graduaciones y galas corporativas</strong>. Integración perfecta con nuestros <a href="/servicios/audiovisual/microfonos-dj/">micrófonos profesionales</a>.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">2-3 cámaras</span>
                  <span class="showcase__tag">Blackmagic ATEM</span>
                  <span class="showcase__tag">Gráficos en vivo</span>
                  <span class="showcase__tag">Director técnico</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Streaming Pro
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                  <span>Streaming Pro</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Streaming Multi-Plataforma -->
          <section class="section section--alt" aria-labelledby="multi-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Máximo alcance</span>
                <h2 class="showcase__title" id="multi-heading">Streaming Multi-Plataforma</h2>
                <p class="showcase__subtitle">Transmisión simultánea a YouTube, Facebook, Zoom, Teams y más — llega a todas las audiencias al mismo tiempo.</p>
                <p class="showcase__text">Nuestro <strong>servicio de streaming multi-plataforma</strong> permite transmitir tu evento en vivo a múltiples destinos simultáneamente sin pérdida de calidad. Utilizamos un encoder profesional con capacidad de <strong>restream a 5+ plataformas</strong> al mismo tiempo: YouTube Live, Facebook Live, Zoom Webinar, Microsoft Teams Live Events, Vimeo, Twitch y cualquier servidor RTMP personalizado. Cada plataforma recibe la señal optimizada según sus especificaciones técnicas de bitrate y resolución.</p>
                <p class="showcase__text">Incluye todo lo del paquete Streaming Pro más <strong>configuración y prueba de cada plataforma, gestión de claves de transmisión, monitoreo de audiencia en tiempo real</strong> y un dashboard donde puedes ver las estadísticas de viewers de todas las plataformas. Nuestro equipo gestiona la comunicación con audiencias remotas: chat en vivo, preguntas de Zoom y comentarios de YouTube se pueden mostrar en pantalla para el presentador. La solución definitiva para <strong>eventos corporativos con audiencia global, lanzamientos de producto, transmisiones gubernamentales y eventos religiosos</strong> con feligresía distribuida.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">5+ plataformas</span>
                  <span class="showcase__tag">Restream simultáneo</span>
                  <span class="showcase__tag">Dashboard analytics</span>
                  <span class="showcase__tag">Chat integrado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Multi-Plataforma
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                  <span>Streaming Multi-Plataforma</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Híbrido -->
