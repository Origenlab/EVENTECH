---
/**
 * ─── Pantallas LED para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Pantallas LED para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Pantallas LED" },
];

const PANTALLAS = [
  {
    name: "Pantallas en Pedestal",
    excerpt: "LED de 55, 65, 75 y 85 pulgadas en pedestal profesional con ruedas. Ideales para bodas, recepciones, conferencias y presentaciones corporativas.",
    cta: "En Pedestal",
    href: "#pedestal-heading",
    icon: "speaker",
  },
  {
    name: "Videowall Modular",
    excerpt: "Paneles LED modulares P2.5 y P3.9 que se ensamblan en cualquier dimensión. Desde 2x1 hasta 6x3 metros para escenarios de gran impacto.",
    cta: "Videowall",
    href: "#videowall-heading",
    icon: "layers",
  },
  {
    name: "Pantallas Gigantes Exterior",
    excerpt: "LED de alto brillo (5,000+ nits) resistentes a luz solar directa. Perfectas para festivales, conciertos, ferias y eventos masivos al aire libre.",
    cta: "Exterior",
    href: "#exterior-heading",
    icon: "award",
  },
  {
    name: "Monitores y Displays",
    excerpt: "Monitores de retorno para presentadores, pantallas de señalización digital y displays informativos para congresos, expos y eventos corporativos.",
    cta: "Monitores",
    href: "#monitores-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué tamaño de pantalla LED necesito para mi evento?", answer: "Depende del número de asistentes y la distancia de visualización. Para eventos íntimos (hasta 80 personas) recomendamos pantallas de 65 a 75 pulgadas. Para medianos (80-200 personas) una de 85 pulgadas o videowall de 2x1 m. Para grandes (200+ personas) videowall modular de 3x2 m o más. Nuestro equipo técnico evalúa tu venue y te recomienda la dimensión exacta para que cada asistente vea con claridad." },
  { question: "¿Cuál es la diferencia entre pantalla en pedestal y videowall modular?", answer: "La pantalla en pedestal es una unidad LED independiente (55 a 85 pulgadas) montada sobre un soporte con ruedas, ideal para espacios medianos y fácil de reposicionar. El videowall modular está compuesto por paneles LED individuales que se ensamblan como piezas, permitiendo crear pantallas de cualquier dimensión (hasta 6x3 metros o más). El videowall ofrece mayor impacto visual y brillo, mientras que el pedestal es más práctico y económico." },
  { question: "¿Las pantallas LED funcionan bien en exteriores con sol?", answer: "Sí, pero requieres pantallas de alto brillo. Nuestras pantallas de interior tienen 1,000-2,000 nits, suficientes para salones. Para exteriores con luz solar directa, usamos paneles de 5,000+ nits que garantizan imagen nítida incluso a pleno sol. Siempre recomendamos pantallas outdoor certificadas IP65 para eventos al aire libre, con protección contra polvo y lluvia ligera." },
  { question: "¿Qué contenido puedo proyectar en las pantallas LED?", answer: "Prácticamente cualquier contenido digital: videos de boda (same day edit, retrospectivas), presentaciones corporativas, logos animados, transmisiones en vivo, videoconferencias, contadores regresivos, redes sociales en tiempo real, menús digitales y mapping artístico. Aceptamos formatos HDMI, USB, SDI y señal inalámbrica. Nuestro técnico te asiste con la conexión y reproducción." },
  { question: "¿El precio incluye instalación y técnico?", answer: "Sí. Todos nuestros paquetes de pantallas LED incluyen transporte, instalación profesional, cableado oculto, procesador de video, pruebas previas al evento y un técnico de operación dedicado durante todo el evento. El técnico monitorea la señal en tiempo real y resuelve cualquier ajuste necesario. El desmontaje y recolección también están incluidos sin costo adicional dentro de CDMX." },
  { question: "¿Con cuánta anticipación debo reservar pantallas LED?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero). Para eventos corporativos grandes con videowall modular o configuraciones especiales, lo ideal es apartar con 1 a 2 meses. Las pantallas de 75 y 85 pulgadas son las más solicitadas y se agotan primero. También atendemos solicitudes de último momento sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pantallas LED para Eventos en CDMX",
    description: "Pantallas LED en pedestal, videowall modular y pantallas gigantes para bodas, congresos y festivales. Técnico incluido.",
    url: "/servicios/audiovisual/pantallas-led/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Pantallas LED", url: "/servicios/audiovisual/pantallas-led/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pantallas LED para Eventos en CDMX"
  description="Renta de pantallas LED de 55 a 85 pulgadas, videowall modular y pantallas gigantes para eventos en CDMX. Técnico incluido. Desde $500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Tecnología LED de última generación"
    title='Renta de <span class="highlight">Pantallas LED</span> para Eventos en CDMX'
    subtitle="Pantallas LED de alta resolución desde 55 pulgadas hasta videowall modulares de 6x3 metros. Brillo superior, imagen nítida y técnico de operación incluido en cada renta."
    primaryCTA={{ label: "Cotiza tu pantalla", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar pantallas LED para mi evento` }}
    cards={[
      {
        title: "Pantallas LED de grado profesional para cada evento",
        content: "<strong>Renta de pantallas LED para eventos</strong> con la tecnología más avanzada disponible en CDMX. Pantallas en pedestal de 55 a 85 pulgadas con resolución Full HD y 4K para bodas, conferencias y presentaciones. Videowall modular con paneles P2.5 y P3.9 que se ensamblan en cualquier dimensión hasta 6x3 metros para escenarios de gran formato. Pantallas gigantes de exterior con brillo superior a 5,000 nits para festivales y eventos masivos — cada pantalla calibrada y verificada antes de cada entrega.",
      },
      {
        title: "Instalación profesional con técnico dedicado",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de pantallas LED. Nuestro ingeniero de video se encarga del transporte, instalación con cableado oculto, conexión de fuentes HDMI/SDI, calibración de brillo y color según las condiciones de iluminación de tu venue, y monitoreo en tiempo real durante todo el evento. Procesador de video profesional incluido para gestionar múltiples fuentes y transiciones suaves entre contenidos.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas impacto visual en tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con la pantalla ideal para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de pantalla
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pantallas LED"
        subtitle="La solución visual perfecta para cada tipo de evento"
        description={[
          "Desde pantallas individuales para presentaciones corporativas hasta videowall gigantes para conciertos y festivales. Contamos con el inventario de pantallas LED más completo de la Ciudad de México.",
          "Cada pantalla incluye procesador de video, cableado profesional y técnico de operación dedicado. Brillo, resolución y tamaño certificados para garantizar una experiencia visual impecable."
        ]}
      />

      <div class="grid grid--4">
        {PANTALLAS.map((pantalla) => (
          <Card
            name={pantalla.name}
            excerpt={pantalla.excerpt}
            cta={pantalla.cta}
            href={pantalla.href}
            icon={pantalla.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLAS EN PEDESTAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pedestal-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Las más solicitadas</span>
          <h2 class="showcase__title" id="pedestal-heading">Pantallas en Pedestal</h2>
          <p class="showcase__subtitle">La solución práctica y elegante para eventos en salón con hasta 200 personas.</p>
          <p class="showcase__text">Nuestras <strong>pantallas LED en pedestal</strong> están disponibles en 4 tamaños profesionales: <strong>55, 65, 75 y 85 pulgadas</strong> con resolución Full HD y 4K. Montadas sobre pedestales de acero con ruedas bloqueables y ajuste de altura, son perfectas para <strong>bodas, recepciones, conferencias y presentaciones corporativas</strong>. Cada pantalla ofrece un brillo de 1,000 a 2,000 nits con ángulo de visión de 178° para que todos los asistentes vean con claridad.</p>
          <p class="showcase__text">Incluyen <strong>procesador de video con entrada HDMI, USB y señal inalámbrica</strong> para conectar laptops, celulares y cámaras en vivo. En bodas, las pantallas de 75 y 85 pulgadas son perfectas para proyectar <strong>videos retrospectivos, same day edits y transmisiones en vivo de la ceremonia</strong>. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para presentaciones ejecutivas impecables.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">LED 55"</span>
            <span class="showcase__tag">LED 65"</span>
            <span class="showcase__tag">LED 75"</span>
            <span class="showcase__tag">LED 85"</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pantallas en Pedestal
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       VIDEOWALL MODULAR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="videowall-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Máximo impacto visual</span>
          <h2 class="showcase__title" id="videowall-heading">Videowall Modular</h2>
          <p class="showcase__subtitle">Paneles LED ensamblables que crean pantallas de cualquier dimensión para escenarios espectaculares.</p>
          <p class="showcase__text">Nuestro <strong>videowall modular</strong> utiliza paneles LED de última generación en pixel pitch <strong>P2.5 (interior) y P3.9 (interior/exterior)</strong> que se ensamblan como piezas de rompecabezas. Configuraciones desde <strong>2×1 metros hasta 6×3 metros o más</strong>, adaptándose al escenario de tu evento. Resolución efectiva superior a Full HD con tasa de refresco de 3,840 Hz para una imagen sin parpadeos incluso en grabaciones de video.</p>
          <p class="showcase__text">Incluye <strong>estructura de soporte ground stack o fly system</strong> (rigging aéreo) según tu venue, procesador de video Novastar con gestión de hasta 4 fuentes simultáneas, y cableado SDI/HDMI profesional. Ideal para <strong>congresos, conciertos, lanzamientos de producto y escenarios de gran formato</strong>. El montaje requiere entre 3 y 6 horas según dimensión. Combínalo con nuestra <a href="/servicios/iluminacion/">iluminación de escenario</a> para producciones de nivel profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">P2.5 Interior</span>
            <span class="showcase__tag">P3.9 Versátil</span>
            <span class="showcase__tag">Hasta 6×3 m</span>
            <span class="showcase__tag">Novastar</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Videowall
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="9" height="7" rx="1"/>
              <rect x="13" y="3" width="9" height="7" rx="1"/>
              <rect x="2" y="12" width="9" height="7" rx="1"/>
              <rect x="13" y="12" width="9" height="7" rx="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLAS GIGANTES EXTERIOR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="exterior-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Alto brillo outdoor</span>
          <h2 class="showcase__title" id="exterior-heading">Pantallas Gigantes Exterior</h2>
          <p class="showcase__subtitle">LED de alto brillo resistente a luz solar para festivales, conciertos y eventos masivos al aire libre.</p>
          <p class="showcase__text">Nuestras <strong>pantallas LED de exterior</strong> están diseñadas para condiciones de intemperie con certificación <strong>IP65 contra polvo y lluvia</strong>. Brillo superior a <strong>5,000 nits</strong> que garantiza imagen nítida incluso bajo luz solar directa. Disponibles en pixel pitch <strong>P4.8 y P6.2</strong> con dimensiones desde 3×2 metros hasta configuraciones de 10×5 metros para audiencias masivas de 5,000+ personas.</p>
          <p class="showcase__text">Incluyen <strong>estructura de soporte ground stack certificada para viento</strong>, generador de respaldo (opcional), procesador de video profesional y equipo técnico de montaje especializado. Ideales para <strong>festivales de música, conciertos, ferias comerciales, eventos deportivos y celebraciones públicas</strong>. El montaje outdoor requiere de 4 a 8 horas. Complementa con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para proteger el área técnica y crear zonas VIP.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">5,000+ nits</span>
            <span class="showcase__tag">IP65 certificado</span>
            <span class="showcase__tag">P4.8 / P6.2</span>
            <span class="showcase__tag">Hasta 10×5 m</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pantalla Exterior
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MONITORES Y DISPLAYS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="monitores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Complemento profesional</span>
          <h2 class="showcase__title" id="monitores-heading">Monitores y Displays</h2>
          <p class="showcase__subtitle">Pantallas de retorno, señalización digital e información para congresos y eventos corporativos.</p>
          <p class="showcase__text">Los <strong>monitores y displays profesionales</strong> son el complemento esencial para eventos corporativos de alto nivel. <strong>Monitores de retorno de 24 a 32 pulgadas</strong> para que presentadores y conferencistas vean sus notas y el timer sin voltear a la pantalla principal. <strong>Displays de señalización digital de 43 a 55 pulgadas</strong> para agendas, directorios de expo, menús y contenido informativo en pasillos y lobbies.</p>
          <p class="showcase__text">Incluyen <strong>soportes profesionales (pedestal, truss clamp o pared)</strong>, reproductor multimedia integrado y gestión remota de contenido para actualizar información en tiempo real. Ideales para <strong>congresos, expos comerciales, ferias de empleo, convenciones y eventos híbridos</strong>. Cada monitor incluye cableado HDMI y señal inalámbrica. Combínalos con nuestros <a href="/servicios/accesorios/">accesorios de señalización</a> como podiums y backdrops para un montaje corporativo profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Retorno 24"-32"</span>
            <span class="showcase__tag">Digital Signage</span>
            <span class="showcase__tag">Señalización 43"-55"</span>
            <span class="showcase__tag">Gestión remota</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Monitores
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Pantallas LED"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu pantalla LED, es natural tener preguntas sobre tamaños, resoluciones, brillo y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre pantallas LED al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de pantallas LED para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Pantalla LED"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores técnicos te responderá por WhatsApp con una cotización personalizada de pantallas LED. Sin compromiso, sin costos ocultos.",
          "Ya sea una pantalla de 55 pulgadas para tu conferencia o un videowall de 6x3 metros para tu festival, estamos aquí para ayudarte."
