              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoPantalla">
                Tipo de pantalla
              </label>
              <select id="tipoPantalla" name="tipoPantalla" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de pantalla</option>
                <option value="LED 55 pulgadas">LED 55 pulgadas en pedestal</option>
                <option value="LED 65 pulgadas">LED 65 pulgadas en pedestal</option>
                <option value="LED 75 pulgadas">LED 75 pulgadas en pedestal</option>
                <option value="LED 85 pulgadas">LED 85 pulgadas en pedestal</option>
                <option value="Videowall Modular Interior">Videowall Modular Interior</option>
                <option value="Videowall Modular Exterior">Videowall Modular Exterior</option>
                <option value="Pantalla Gigante Outdoor">Pantalla Gigante Outdoor</option>
                <option value="Monitores de Retorno">Monitores de Retorno</option>
                <option value="Señalización Digital">Señalización Digital / Displays</option>
                <option value="Paquete Completo">Paquete Completo / Varios</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de asistentes, tipo de venue (salón/jardín/auditorio), contenido a proyectar, dimensiones del escenario..."
