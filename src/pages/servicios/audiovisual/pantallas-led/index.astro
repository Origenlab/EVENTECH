---
/**
 * ─── EVENTECH.MX — Renta de Pantallas LED para Eventos (Hub L4, molde hm- 2026) ───
 * Pedestal · Videowall · Exterior · Monitores — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: reusadas de /images/audiovisual (faltan fotos reales por tipo — reemplazar).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "pedestal",
    name: "Pantallas en Pedestal",
    badge: "Las más solicitadas",
    excerpt: "LED de 55, 65, 75 y 85 pulgadas sobre pedestal de acero con ruedas bloqueables. La de 85\" cubre salones de hasta 200 personas sin perder detalle — la solución práctica para bodas, conferencias y presentaciones corporativas.",
    href: "/servicios/audiovisual/pantallas-led/pedestal/",
    image: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif",
    specs: ['55"', '65"', '75"', '85"', "Full HD / 4K"],
  },
  {
    id: "videowall",
    name: "Videowall Modular",
    badge: "Máximo impacto",
    excerpt: "Paneles P2.5 y P3.9 ensamblables desde 2×1 hasta 6×3 metros con procesador Novastar incluido. El estándar para congresos en el WTC, lanzamientos y escenarios de gran formato.",
    href: "/servicios/audiovisual/pantallas-led/videowall/",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    specs: ["P2.5", "P3.9", "Hasta 6×3 m", "Novastar", "Rigging"],
  },
  {
    id: "exterior",
    name: "Pantallas Gigantes Exterior",
    badge: "Alto brillo outdoor",
    excerpt: "LED de 5,000+ nits con certificación IP65 contra polvo y lluvia. Imagen nítida bajo sol directo para festivales, conciertos y ferias masivas al aire libre en CDMX.",
    href: "/servicios/audiovisual/pantallas-led/exterior/",
    image: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif",
    specs: ["5,000+ nits", "IP65", "P4.8", "P6.2", "Outdoor"],
  },
  {
    id: "monitores",
    name: "Monitores y Displays",
    badge: "Complemento pro",
    excerpt: "Retorno de 24–32\" para presentadores y señalización digital de 43–55\" para lobbies y pasillos de congreso. Gestión remota de contenido en tiempo real.",
    href: "/servicios/audiovisual/pantallas-led/monitores/",
    image: "/images/audiovisual/equipo-audiovisual-completo-boda.avif",
    specs: ['Retorno 24"–32"', 'Señalización 43"–55"', "Digital Signage", "Gestión remota"],
  },
];

const whyFeatures = [
  {
    title: "Técnico de video dedicado en cada evento",
    body: "No solo entregamos la pantalla y nos vamos. Un ingeniero de video se queda durante todo el evento monitoreando la señal, gestionando fuentes y resolviendo cualquier ajuste en tiempo real. La proyección es un punto de falla visible frente a todos tus invitados — por eso siempre hay alguien operándola.",
  },
  {
    title: "Inventario propio calibrado — sin subcontratar",
    body: "Pantallas propias en bodega CDMX. Cada panel se calibra en brillo y color antes de salir y se verifica pixel por pixel: descartamos módulos con puntos muertos o desuniformidad. Lo que cotizamos es lo que existe, revisado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    title: "Procesador de video profesional incluido",
    body: "Cada renta incluye procesador (Novastar en videowall) para gestionar múltiples fuentes HDMI/SDI/inalámbricas con transiciones suaves. Conectamos laptop, cámara en vivo, celular y reproductor sin cortes ni parpadeos, incluso en grabaciones de video con tasa de refresco alta.",
  },
  {
    title: "Instalación con cableado oculto y pruebas previas",
    body: "Montaje profesional con cableado escondido, estructura ground stack o rigging aéreo según el venue, y prueba completa de contenido antes de que llegue el primer invitado. Nada de improvisar con el proyector cinco minutos antes: llegamos con tiempo y dejamos todo probado.",
  },
  {
    title: "Respaldo y soporte en sitio",
    body: "Cargamos módulos y cables de respaldo en cada servicio. Si un panel o una conexión falla durante el montaje, se reemplaza sin costo en sitio. El técnico tiene con qué responder ante cualquier imprevisto — no te quedas con una pantalla apagada a media presentación.",
  },
  {
    title: "Asesoría de dimensión y brillo según tu venue",
    body: "El tamaño y el brillo correctos dependen de la distancia de visualización y la luz del espacio. Hacemos visita técnica sin costo para medir tu salón, jardín o auditorio y recomendarte la configuración exacta — para que cada asistente vea con claridad y no pagues por más pantalla de la que necesitas.",
  },
];

const steps = [
  { n: 1, t: "Cotización y visita técnica", p: "Nos indicas tipo de evento, venue, número de asistentes y contenido a proyectar. Hacemos visita técnica sin costo para medir distancias y condiciones de luz. En menos de 24 horas te confirmamos la configuración ideal y te enviamos propuesta." },
  { n: 2, t: "Propuesta técnica y aparto de equipo", p: "Definimos dimensión exacta, pixel pitch, ubicación de pantalla y fuentes de contenido. Con el 30% de anticipo apartamos el equipo y la fecha — sin pago total por adelantado. Coordinamos con tu productor, wedding planner o el venue si aplica." },
  { n: 3, t: "Instalación, calibración y pruebas", p: "Llegamos con tiempo el día del evento o la tarde anterior. Montaje con cableado oculto, conexión del procesador, calibración de brillo y color según la luz del venue, y prueba completa del contenido antes de abrir puertas. Tú o tu coordinador dan el visto bueno." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "El técnico opera la pantalla durante todo el evento, gestiona fuentes y monitorea la señal. Al cierre, desmontamos, recogemos y hacemos conteo de equipo. El desmontaje y recolección están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tamaño de pantalla LED necesito para mi evento?", answer: "Depende del número de asistentes y la distancia de visualización. Para eventos íntimos (hasta 80 personas) recomendamos pantallas de 65 a 75 pulgadas. Para medianos (80-200 personas) una de 85 pulgadas o videowall de 2x1 m. Para grandes (200+ personas) videowall modular de 3x2 m o más. Nuestro equipo técnico evalúa tu venue en una visita sin costo y te recomienda la dimensión exacta para que cada asistente vea con claridad." },
  { question: "¿Cuál es la diferencia entre pantalla en pedestal y videowall modular?", answer: "La pantalla en pedestal es una unidad LED independiente (55 a 85 pulgadas) montada sobre un soporte con ruedas, ideal para espacios medianos y fácil de reposicionar. El videowall modular está compuesto por paneles LED individuales que se ensamblan como piezas, permitiendo crear pantallas de cualquier dimensión (hasta 6x3 metros o más). El videowall ofrece mayor impacto visual y brillo, mientras que el pedestal es más práctico y económico para salones." },
  { question: "¿Las pantallas LED funcionan bien en exteriores con sol?", answer: "Sí, pero requieres pantallas de alto brillo. Nuestras pantallas de interior tienen 1,000-2,000 nits, suficientes para salones. Para exteriores con luz solar directa, usamos paneles de 5,000+ nits que garantizan imagen nítida incluso a pleno sol. Siempre recomendamos pantallas outdoor certificadas IP65 para eventos al aire libre, con protección contra polvo y lluvia ligera." },
  { question: "¿Qué contenido puedo proyectar en las pantallas LED?", answer: "Prácticamente cualquier contenido digital: videos de boda (same day edit, retrospectivas), presentaciones corporativas, logos animados, transmisiones en vivo, videoconferencias, contadores regresivos, redes sociales en tiempo real, menús digitales y mapping artístico. Aceptamos formatos HDMI, USB, SDI y señal inalámbrica. Nuestro técnico te asiste con la conexión y reproducción." },
  { question: "¿Ofrecen transmisión en vivo o videoconferencia en las pantallas?", answer: "Sí. Integramos cámaras para transmitir en vivo a la pantalla (ceremonia, escenario, mesa principal) y conectamos plataformas de videoconferencia como Zoom, Meet o Teams para eventos híbridos donde parte de la audiencia participa a distancia. El procesador de video gestiona la señal de cámara y la fuente remota simultáneamente, con audio sincronizado si se combina con nuestro equipo de sonido." },
  { question: "¿El precio incluye instalación y técnico?", answer: "Sí. Todos nuestros paquetes de pantallas LED incluyen transporte, instalación profesional, cableado oculto, procesador de video, pruebas previas al evento y un técnico de operación dedicado durante todo el evento. El técnico monitorea la señal en tiempo real y resuelve cualquier ajuste necesario. El desmontaje y recolección también están incluidos sin costo adicional dentro de CDMX." },
  { question: "¿Con cuánta anticipación debo reservar pantallas LED?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero). Para eventos corporativos grandes con videowall modular o configuraciones especiales, lo ideal es apartar con 1 a 2 meses. Las pantallas de 75 y 85 pulgadas son las más solicitadas y se agotan primero. También atendemos solicitudes de último momento sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pantallas LED para Eventos en CDMX",
    description: "Renta de pantallas LED en pedestal, videowall modular, pantallas gigantes de exterior y monitores para bodas, congresos y festivales en CDMX. Procesador, instalación y técnico incluidos.",
    url: "/servicios/audiovisual/pantallas-led/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Pantallas LED", url: "/servicios/audiovisual/pantallas-led/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Pantallas LED" },
];
---

<PageLayout
  title="Renta de Pantallas LED para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif"
  description="Renta de pantallas LED de 55 a 85″, videowall modular y pantallas gigantes en CDMX. Procesador y técnico incluidos. +500 eventos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="pantallas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Pantallas LED · CDMX y ZMVM</p>
            <h1 id="pantallas-hero-heading">
              Pantallas LED de alta resolución — <em>del pedestal al videowall de 6×3 m</em>
            </h1>
            <p class="hm-hero__lead">
              Pedestal de 55 a 85 pulgadas, videowall modular P2.5/P3.9, pantallas gigantes
              de exterior y monitores de señalización. Procesador de video, instalación
              profesional y técnico de operación incluidos en cada renta.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20pantallas%20LED%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar pantallas
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>pantallas LED para eventos</strong> en CDMX con
              inventario propio calibrado — pedestal de 55 a 85 pulgadas en Full HD y 4K,
              videowall modular P2.5 y P3.9 ensamblable hasta 6×3 metros, pantallas gigantes
              de exterior con 5,000+ nits y certificación IP65, y monitores de señalización
              digital. Cada panel se verifica pixel por pixel y se calibra en brillo y color
              antes de cada entrega.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que la
              proyección es el punto de falla más visible de un evento: por eso cada renta
              incluye procesador de video, instalación con cableado oculto, pruebas previas
              y un técnico de operación dedicado que se queda todo el evento. Para producciones
              completas combinamos las pantallas con
              <a href="/servicios/audiovisual/sonido/">sistemas de sonido</a> e
              <a href="/servicios/iluminacion/">iluminación de escenario</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de pantalla disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20pantallas%20LED%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué pantalla necesita tu evento?</h2>
            <p class="hm__head-sub">4 soluciones LED — del salón íntimo al festival masivo, con la resolución y el brillo correctos para cada espacio.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La pantalla es lo que enfoca la atención de toda la audiencia al mismo tiempo:
              la ceremonia proyectada, el video retrospectivo, la presentación del CEO o el
              contenido del festival. Si se ve opaca, pixeleada o falla la señal, lo nota
              cada persona en la sala. Elegir bien no es solo tamaño — es pixel pitch,
              brillo y procesamiento acordes al venue.
            </p>
            <p>
              Pedestal para salones y presentaciones. Videowall cuando importa el impacto
              y el gran formato. Exterior de alto brillo cuando el evento es a pleno sol.
              Monitores para retorno de presentadores y señalización de congreso. Una sola
              empresa para toda la proyección de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de pantalla — en detalle</h2>
            <p class="hm__head-sub">Resolución, pixel pitch, brillo y para qué tipo de evento funciona mejor cada formato.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada formato de pantalla hay decisiones técnicas que afectan la
              experiencia del evento: el pixel pitch que determina la nitidez a corta
              distancia, el brillo en nits que decide si se ve bajo luz directa, y el
              tipo de estructura que define dónde y cómo se puede instalar con seguridad.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por
              tamaño. A continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- PEDESTAL -->
        <article class="hm-feat" aria-labelledby="feat-pedestal">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pantallas en Pedestal</p>
            <h3 class="hm-feat__title" id="feat-pedestal">La solución práctica para salón — de la conferencia íntima a la boda de 200 invitados</h3>
            <p class="hm-feat__lead">Una unidad LED independiente sobre pedestal rodante: se coloca, se conecta y se reposiciona en minutos. El formato correcto cuando el evento es en salón y no necesitas gran formato.</p>
            <p>
              Disponibles en <strong>55, 65, 75 y 85 pulgadas</strong> con resolución
              <strong>Full HD y 4K</strong>, montadas sobre pedestal de acero con ruedas
              bloqueables y ajuste de altura. Brillo de 1,000 a 2,000 nits y ángulo de
              visión de 178° para que todos los asistentes vean con claridad. En bodas,
              las de 75 y 85 pulgadas son perfectas para <strong>same day edits,
              retrospectivas y transmisión en vivo de la ceremonia</strong>.
            </p>
            <p>
              Incluyen <strong>procesador con entrada HDMI, USB y señal inalámbrica</strong>
              para conectar laptop, celular o cámara en vivo. Ideales para conferencias,
              presentaciones corporativas y recepciones. Combínalas con nuestro
              <a href="/servicios/audiovisual/sonido/">sistema de sonido</a> para una
              presentación con audio y video sincronizados.
            </p>
            <ul class="hm-feat__stats">
              {['55"', '65"', '75"', '85"', "Full HD / 4K", "1,000–2,000 nits"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/audiovisual/pantallas-led/pedestal/">
              Ver Pantallas en Pedestal
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/audiovisual/monitor-pantalla-presentacion-congreso.avif" alt="Pantalla LED en pedestal para presentación de congreso en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/audiovisual/equipo-audiovisual-completo-boda.avif" alt="Pantalla en pedestal dentro de montaje audiovisual completo para boda" loading="lazy" decoding="async" />
              <img src="/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif" alt="Pantalla LED de alta resolución en evento corporativo" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- VIDEOWALL -->
        <article class="hm-feat" aria-labelledby="feat-videowall">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Videowall Modular</p>
            <h3 class="hm-feat__title" id="feat-videowall">Paneles ensamblables que crean cualquier dimensión — el máximo impacto visual para gran formato</h3>
            <p class="hm-feat__lead">Cuando la pantalla tiene que ser el escenario. El videowall se arma como un rompecabezas de paneles LED, adaptándose a la dimensión exacta que tu escenario necesita.</p>
            <p>
              Paneles en pixel pitch <strong>P2.5 (interior) y P3.9 (interior/exterior)</strong>
              que se ensamblan en configuraciones <strong>desde 2×1 hasta 6×3 metros o más</strong>.
              Resolución efectiva superior a Full HD con tasa de refresco de 3,840 Hz para
              imagen sin parpadeos incluso en grabación de video. Procesador
              <strong>Novastar</strong> con gestión de hasta 4 fuentes simultáneas incluido.
            </p>
            <p>
              Incluye <strong>estructura ground stack o rigging aéreo</strong> según el venue
              y cableado SDI/HDMI profesional. El estándar para <strong>congresos, conciertos,
              lanzamientos de producto y galas</strong>. El montaje requiere de 3 a 6 horas
              según dimensión. Combínalo con nuestra
              <a href="/servicios/iluminacion/">iluminación de escenario</a> para una
              producción de nivel profesional.
            </p>
            <ul class="hm-feat__stats">
