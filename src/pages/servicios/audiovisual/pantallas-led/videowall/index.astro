---
/**
 * ─── Videowall Modular LED — Pagina de Producto (Nivel 4) ───
 * Paneles LED modulares P2.5 y P3.9 ensamblables en cualquier
 * dimension para escenarios de gran impacto.
 *
 * Jerarquia: Servicios > Audiovisual > Pantallas LED > Videowall
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { label: "Videowall Modular" },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre pixel pitch P2.5 y P3.9?", answer: 'El <strong>pixel pitch</strong> indica la distancia en milímetros entre cada LED. P2.5 tiene una densidad mayor de pixeles (mayor resolución) ideal para <strong>interiores con distancias de visualización cortas</strong> (2 a 10 metros) — perfecto para salones de hotel, centros de convenciones y salas de conferencias. P3.9 tiene menor densidad pero mayor brillo, ideal para <strong>escenarios con distancias medianas a largas</strong> (5 a 30 metros) y eventos con iluminación intensa o uso semi-exterior. Para conciertos y festivales, P3.9 ofrece el mejor balance entre resolución, brillo y costo.' },
  { question: "¿Puedo solicitar dimensiones personalizadas para el videowall?", answer: "Sí, es una de las mayores ventajas del videowall modular. Nuestros paneles se ensamblan como piezas para crear pantallas de <strong>cualquier dimensión</strong>: desde 2x1 metros para presentaciones hasta 6x3 metros o más para conciertos masivos. También creamos <strong>configuraciones no rectangulares</strong> como formas en L, U, curvas e incluso columnas envolventes. El único límite es el espacio disponible en tu venue. Nuestro ingeniero de video diseña la configuración óptima según tus necesidades y el espacio disponible." },
  { question: "¿Necesito crear contenido especial para el videowall?", answer: "No necesariamente. Nuestro procesador Novastar <strong>escala automáticamente</strong> cualquier contenido (presentaciones, videos, transmisiones) a la resolución del videowall. Sin embargo, para un resultado visualmente impactante, recomendamos crear contenido en la <strong>resolución nativa del videowall</strong> (que calculamos según la configuración elegida). Si necesitas contenido personalizado, podemos referirte con diseñadores especializados en contenido para LED. Para corporativos, tus presentaciones de PowerPoint funcionan perfectamente sin modificaciones." },
  { question: "¿Cuánta energía necesita un videowall modular?", answer: "Depende de la dimensión. Configuraciones pequeñas de <strong>2x1m a 3x2m</strong> funcionan con alimentación <strong>110V/220V estándar</strong> (1-2 circuitos dedicados). Configuraciones medianas de <strong>3x2m a 4x2.5m</strong> requieren 220V con tablero dedicado. Para configuraciones grandes de <strong>5x3m o más</strong>, recomendamos alimentación trifásica 220V o una <a href='/servicios/accesorios/plantas-energia/'>planta de energía dedicada</a>. Nuestro equipo técnico evalúa la infraestructura eléctrica de tu venue y coordina todo lo necesario para garantizar una alimentación estable y segura." },
  { question: "¿Cuánto tiempo tarda el montaje de un videowall?", answer: "El tiempo de montaje varía según la dimensión y configuración. Un <strong>videowall de 2x1m</strong> se instala en aproximadamente <strong>2 a 3 horas</strong>. Configuraciones de <strong>3x2m</strong> requieren 3 a 4 horas. Para <strong>4x2.5m o más</strong>, el montaje puede tomar de 4 a 8 horas dependiendo de si es ground stack (piso) o fly system (rigging aéreo). Siempre programamos el montaje con margen suficiente e incluimos pruebas de imagen, calibración de color y verificación de señal antes de que inicie tu evento." },
  { question: "¿El videowall modular funciona en exteriores?", answer: 'Nuestros paneles P3.9 pueden utilizarse en <strong>exteriores cubiertos</strong> (bajo carpa o toldo) con excelentes resultados. Para eventos completamente al aire libre con exposición al sol y riesgo de lluvia, recomendamos nuestras <a href="/servicios/audiovisual/pantallas-led/exterior/">pantallas LED de exterior</a> con certificación IP65 y brillo de 5,000+ nits. Si tu evento es al atardecer o de noche al aire libre, los paneles P3.9 ofrecen suficiente brillo (3,000-5,000 nits) para una imagen nítida.' },
];

const specs = [
  { label: "Pixel pitch", value: "P2.5 (interior) / P3.9 (versátil)" },
  { label: "Dimensiones", value: "2×1 m hasta 6×3 m+ (modular)" },
  { label: "Brillo", value: "1,500 – 5,000 nits (según modelo)" },
  { label: "Procesador", value: "Novastar incluido (hasta 4 fuentes)" },
  { label: "Refresh rate", value: "3,840 Hz (sin parpadeo en cámara)" },
  { label: "Peso por panel", value: "~8 kg/m²" },
  { label: "Montaje", value: "Ground stack / Fly system (rigging)" },
  { label: "Contenido", value: "Video, gráficos, streaming, multi-fuente" },
  { label: "Energía", value: "220V trifásica para configuraciones >3×2 m" },
  { label: "Técnico", value: "Instalación + operación incluidos" },
];

const sidebarNav = [
  { name: "Pantallas en Pedestal", href: "/servicios/audiovisual/pantallas-led/pedestal/" },
  { name: "Videowall Modular", href: null, active: true },
  { name: "Pantallas Gigantes Exterior", href: "/servicios/audiovisual/pantallas-led/exterior/" },
  { name: "Monitores y Displays", href: "/servicios/audiovisual/pantallas-led/monitores/" },
];

const sidebarRelated = [
  { name: "Sonido Line Array", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
  { name: "Streaming en Vivo", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Miguel Ángel Reyes", text: "Montamos un videowall de 3x2 metros P2.5 para un concierto privado en un salón de Polanco. La calidad de imagen fue impresionante — los videos musicales se veían con una nitidez increíble. El equipo de EVENTECH instaló todo en 4 horas y el técnico operó las transiciones entre contenidos como un profesional. El punto focal del evento.", rating: 5, date: "2025-11-28" },
  { author: "Laura Mendoza", text: "Contratamos un videowall de 4x2.5 metros para nuestra convención anual corporativa con 400 asistentes. El procesador Novastar permitió alternar entre la presentación del CEO, cámaras en vivo y videos institucionales sin ningún corte. La inversión valió completamente la pena — el impacto visual fue de otro nivel.", rating: 5, date: "2025-10-12" },
  { author: "Carlos Vega", text: "Usamos el videowall P3.9 de 3x2m para un festival de música al aire libre en el atardecer. Tenía dudas sobre el brillo pero se veía perfecto. El montaje fue rápido, el rigging profesional y el equipo técnico resolvió todo impecablemente. Ya estamos planeando el siguiente festival con una pantalla aún más grande.", rating: 5, date: "2025-09-05" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Videowall Modular LED para Eventos en CDMX",
    description: "Videowall modular LED P2.5 y P3.9 en cualquier dimensión para escenarios en CDMX. Desde 2x1 hasta 6x3 metros. Técnico e instalación incluidos. Desde $8,000.",
    url: "/servicios/audiovisual/pantallas-led/videowall/",
    priceRange: { min: 8000, max: 45000 },
    reviews,
    ratingValue: 5,
    reviewCount: 87,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Pantallas LED", url: "/servicios/audiovisual/pantallas-led/" },
    { name: "Videowall Modular", url: "/servicios/audiovisual/pantallas-led/videowall/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Videowall Modular LED para Eventos en CDMX"
  description="Renta de videowall modular LED P2.5 y P3.9 en cualquier dimensión para escenarios en CDMX. Desde 2x1 hasta 6x3 metros. Técnico e instalación incluidos. Desde $8,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Impacto visual sin límites de tamaño"
    title='Renta de <span class="highlight">Videowall Modular LED</span> para Eventos en CDMX'
    subtitle="Paneles LED modulares P2.5 y P3.9 que se ensamblan en cualquier dimensión. Desde 2x1 hasta 6x3 metros para escenarios de gran impacto. Procesador Novastar, técnico e instalación profesional incluidos."
    primaryCTA={{ label: "Cotiza tu videowall", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar un videowall modular para mi evento` }}
    cards={[
      {
        title: "Paneles LED modulares en cualquier dimensión",
        content: "<strong>Renta de videowall modular LED</strong> con paneles de última generación en pixel pitch P2.5 (alta resolución interior) y P3.9 (versátil interior/exterior). Ensamblaje en cualquier dimensión desde 2x1 hasta 6x3 metros o configuraciones creativas en formas L, U y curvas. Refresh rate de 3,840 Hz para imagen sin parpadeos incluso en grabaciones de video. Procesador Novastar incluido con gestión de hasta 4 fuentes simultáneas para transiciones fluidas entre contenidos.",
      },
      {
        title: "Instalación profesional con ingeniería de video",
        content: "<strong>Servicio completo de instalación</strong> con ingeniero de video certificado. Estructura de soporte ground stack o fly system (rigging aéreo) según tu venue. Cableado SDI/HDMI profesional, calibración de brillo y color panel por panel, y operación técnica durante todo el evento. Montaje de 3 a 8 horas según dimensión con pruebas previas completas. Ideal para congresos, conciertos, lanzamientos de producto y escenarios de gran formato.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un escenario visual de gran impacto?"
    subheadline="Cotiza sin compromiso — diseñamos la configuración de videowall perfecta para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pantallas LED para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un videowall para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un videowall modular para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Videowall Modular LED</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Videowall 2x1m -->
          <section class="section section--alt" aria-labelledby="vw-2x1-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para salones</span>
                <h2 class="showcase__title" id="vw-2x1-heading">Videowall 2x1 Metros</h2>
                <p class="showcase__subtitle">La configuración de entrada para presentaciones corporativas y eventos en salón con impacto superior a una pantalla convencional.</p>
                <p class="showcase__text">El <strong>videowall de 2x1 metros</strong> es la configuración más compacta de nuestro catálogo modular y ofrece un impacto visual significativamente superior a cualquier pantalla individual. Con paneles <strong>P2.5 de alta resolución</strong>, entrega una imagen nítida y vibrante visible desde distancias de 2 a 15 metros. Resolución efectiva de 800x400 píxeles (P2.5) con tasa de refresco de 3,840 Hz — perfecta para grabaciones de video sin parpadeos.</p>
                <p class="showcase__text">Ideal para <strong>presentaciones corporativas, lanzamientos de producto, conferencias de prensa y showrooms</strong> donde necesitas un fondo visual de alto impacto sin ocupar demasiado espacio. El montaje ground stack se completa en <strong>2 a 3 horas</strong> e incluye procesador Novastar, cableado HDMI/SDI y técnico de operación. Funciona con alimentación <strong>110V/220V estándar</strong> sin necesidad de tablero especial. Combínalo con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para una producción completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">2×1 metros</span>
                  <span class="showcase__tag">P2.5 interior</span>
                  <span class="showcase__tag">3,840 Hz</span>
                  <span class="showcase__tag">2-3 hrs montaje</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Videowall 2×1m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Videowall 2×1m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Videowall 3x2m -->
          <section class="section section--alt" aria-labelledby="vw-3x2-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más solicitado</span>
                <h2 class="showcase__title" id="vw-3x2-heading">Videowall 3x2 Metros</h2>
                <p class="showcase__subtitle">El tamaño más popular para escenarios: congresos, galas corporativas y eventos con 200 a 500 asistentes.</p>
                <p class="showcase__text">El <strong>videowall de 3x2 metros</strong> es nuestra configuración más solicitada y el estándar para <strong>escenarios profesionales</strong> en la Ciudad de México. Con 6 metros cuadrados de superficie visual, ofrece un impacto dramático que transforma cualquier salón en un espacio de primer nivel. Disponible en <strong>P2.5 para máxima resolución</strong> o P3.9 para mayor versatilidad y brillo, con resolución efectiva superior a Full HD.</p>
                <p class="showcase__text">El montaje se realiza en <strong>3 a 4 horas</strong> con estructura ground stack o fly system según la altura del venue. El procesador Novastar gestiona hasta 4 fuentes simultáneas — alterna entre presentaciones, cámaras en vivo, videos pregrabados y gráficos animados con transiciones suaves. Perfecto para <strong>congresos, galas de premiación, conciertos privados y lanzamientos de marca</strong>. Requiere alimentación 220V con circuito dedicado. Complementa con nuestra <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para una producción integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">3×2 metros</span>
                  <span class="showcase__tag">P2.5 / P3.9</span>
                  <span class="showcase__tag">4 fuentes</span>
                  <span class="showcase__tag">3-4 hrs montaje</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Videowall 3×2m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Videowall 3×2m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Videowall 4x2.5m -->
          <section class="section section--alt" aria-labelledby="vw-4x25-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Gran formato</span>
                <h2 class="showcase__title" id="vw-4x25-heading">Videowall 4x2.5 Metros</h2>
                <p class="showcase__subtitle">El videowall de gran formato para conciertos, festivales y eventos con más de 500 asistentes.</p>
                <p class="showcase__text">El <strong>videowall de 4x2.5 metros</strong> (10 m² de superficie) es la elección para <strong>eventos de gran escala</strong> donde el impacto visual debe ser proporcional al tamaño de la audiencia. Con paneles <strong>P3.9 de alto brillo</strong> (hasta 5,000 nits), la imagen se mantiene nítida y vibrante incluso bajo iluminación intensa de escenario. Visible con claridad desde distancias de hasta 30 metros — perfecto para festivales, conciertos y eventos masivos.</p>
                <p class="showcase__text">El montaje requiere <strong>4 a 6 horas</strong> con estructura fly system (rigging aéreo certificado) o ground stack reforzado. Incluye procesador Novastar profesional, cableado SDI redundante y <strong>dos técnicos dedicados</strong> (ingeniero de video + operador de contenido). Alimentación trifásica 220V con tablero protegido. Ideal para <strong>conciertos, festivales de música, convenciones masivas y shows de entretenimiento</strong>. Combínalo con nuestras <a href="/servicios/pistas-baile/tarimas-escenarios/">tarimas y escenarios</a> para una producción de nivel profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4×2.5 metros</span>
                  <span class="showcase__tag">P3.9 alto brillo</span>
                  <span class="showcase__tag">10 m² superficie</span>
                  <span class="showcase__tag">Fly system</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Videowall 4×2.5m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
