---
/**
 * ─── Monitores y Displays Profesionales — Pagina de Producto (Nivel 4) ───
 * Monitores de retorno, displays de señalizacion digital y pantallas
 * informativas para congresos y expos.
 *
 * Jerarquia: Servicios > Audiovisual > Pantallas LED > Monitores
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { label: "Monitores y Displays" },
];

const faqs = [
  { question: "¿Ofrecen pantallas táctiles para registro de eventos?", answer: "Sí. Contamos con <strong>pantallas táctiles de 32 y 43 pulgadas</strong> con tecnología multi-touch capacitiva, ideales para sistemas de check-in/registro de asistentes, directorios interactivos de expo y kioscos de información. Incluyen soporte de pedestal o mesa, software de señalización digital preinstalado y conectividad WiFi/Ethernet para actualizaciones en tiempo real. Nuestro técnico configura tu contenido interactivo y permanece disponible durante el evento para resolver cualquier ajuste." },
  { question: "¿Puedo gestionar el contenido de varios monitores desde un solo punto?", answer: "Sí. Nuestro sistema de <strong>gestión centralizada de contenido</strong> permite controlar el contenido de múltiples monitores desde un solo laptop o tablet. Puedes programar <strong>contenido diferente para cada monitor</strong> (agenda en uno, mapa de expo en otro, bienvenida en un tercero) o sincronizar el mismo contenido en todos. El sistema permite actualizaciones en tiempo real vía WiFi — cambios de horario, anuncios de última hora o mensajes personalizados se reflejan al instante en todos los monitores conectados." },
  { question: "¿Qué es un monitor de retorno y para qué sirve?", answer: 'Un <strong>monitor de retorno</strong> (también llamado confidence monitor) es una pantalla que se coloca frente al presentador o panelista, fuera de la vista del público, para que pueda ver sus notas, diapositivas y el timer de su presentación sin voltear hacia la pantalla principal. Es esencial en <strong>conferencias, paneles de discusión y keynotes</strong> para que los presentadores mantengan contacto visual con la audiencia. Nuestros monitores de retorno de 15 a 24 pulgadas incluyen soporte ajustable, conexión HDMI independiente y opción de mostrar contenido diferente al de la pantalla principal.' },
  { question: "¿Los monitores se pueden conectar por WiFi?", answer: "Sí. Nuestros displays de señalización digital incluyen <strong>conectividad WiFi y Ethernet</strong> para recibir contenido de forma inalámbrica. Esto permite actualizaciones remotas sin necesidad de cables adicionales — perfecto para monitores distribuidos en diferentes zonas de un congreso o expo. Para monitores de retorno y displays con contenido de video en tiempo real, recomendamos conexión por <strong>HDMI cableado</strong> para garantizar latencia cero y máxima estabilidad de señal." },
  { question: "¿Pueden personalizar los monitores con la imagen de mi empresa?", answer: "Sí. Ofrecemos <strong>personalización completa de contenido</strong> para todos los monitores: pantallas de bienvenida con logo y colores corporativos, marcos de contenido con branding, plantillas de agenda con identidad visual de tu evento y animaciones de transición personalizadas. Si proporcionas tu manual de marca (logo, colores, tipografías), nuestro equipo crea las plantillas sin costo adicional. También podemos integrar tu contenido con <strong>feeds de redes sociales en tiempo real</strong> y hashtags del evento." },
  { question: "¿Cuántos monitores necesito para mi congreso o expo?", answer: "Depende del tamaño y distribución del evento. Como referencia: para un <strong>congreso de 1-2 salas</strong>, recomendamos 2-4 monitores de retorno + 2-3 displays de señalización. Para <strong>expos con 10-20 stands</strong>, 6-10 displays de señalización + 2 de registro. Para <strong>convenciones grandes</strong>, 10-20 monitores distribuidos entre salas, pasillos y área de registro. Nuestro equipo evalúa el plano de tu venue y te propone la distribución óptima con cotización detallada por monitor." },
];

const specs = [
  { label: "Monitores retorno", value: '15" – 24" con soporte ajustable' },
  { label: "Displays señalización", value: '32" – 55" (horizontal / vertical)' },
  { label: "Resolución", value: "Full HD 1080p" },
  { label: "Touch", value: "Pantallas táctiles opcionales (32-43\")" },
  { label: "Soporte", value: "Mesa / Pared / Pedestal bajo" },
  { label: "Conectividad", value: "HDMI / USB / WiFi / Ethernet" },
  { label: "Software", value: "Señalización digital incluido" },
  { label: "Formato", value: "Horizontal / Vertical (rotación libre)" },
  { label: "Brillo", value: "500 – 1,500 nits (interior)" },
  { label: "Técnico", value: "Configuración e instalación incluida" },
];

const sidebarNav = [
  { name: "Pantallas en Pedestal", href: "/servicios/audiovisual/pantallas-led/pedestal/" },
  { name: "Videowall Modular", href: "/servicios/audiovisual/pantallas-led/videowall/" },
  { name: "Pantallas Gigantes Exterior", href: "/servicios/audiovisual/pantallas-led/exterior/" },
  { name: "Monitores y Displays", href: null, active: true },
];

const sidebarRelated = [
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Streaming en Vivo", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Mesas para Eventos", href: "/servicios/mobiliario/mesas/" },
];

const reviews = [
  { author: "Dra. Elena Ramírez", text: "Contratamos 8 monitores de retorno y 6 displays de señalización para un congreso médico de 3 días en el Centro de Convenciones. Cada sala tenía su monitor de retorno para los ponentes y los displays en los pasillos mostraban la agenda actualizada en tiempo real. El equipo técnico configuró todo impecablemente y resolvió cada ajuste al instante. Servicio profesional de primer nivel.", rating: 5, date: "2025-11-25" },
  { author: "Fernando Castillo", text: "Usamos 12 displays de señalización y 2 pantallas táctiles de registro para nuestra expo comercial anual con 30 stands. Los displays mostraban el directorio de expositores, mapa de la expo y horarios de conferencias. Las pantallas táctiles de check-in agilizaron enormemente el registro de los 800 visitantes. EVENTECH coordinó toda la logística sin un solo problema.", rating: 5, date: "2025-10-03" },
  { author: "Ana María López", text: "Para nuestra conferencia de tecnología necesitábamos monitores de retorno para 4 presentadores simultáneos y displays con la agenda del evento. EVENTECH proporcionó todo el equipo con gestión centralizada — pudimos actualizar horarios y mensajes en todos los monitores al mismo tiempo desde un solo laptop. El técnico fue muy profesional y atento a cada detalle.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Monitores y Displays para Eventos en CDMX",
    description: "Monitores de retorno, displays de señalización digital y pantallas informativas para congresos y expos en CDMX. Desde $800 por monitor.",
    url: "/servicios/audiovisual/pantallas-led/monitores/",
    priceRange: { min: 800, max: 4000 },
    reviews,
    ratingValue: 5,
    reviewCount: 167,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Pantallas LED", url: "/servicios/audiovisual/pantallas-led/" },
    { name: "Monitores y Displays", url: "/servicios/audiovisual/pantallas-led/monitores/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Monitores y Displays para Eventos en CDMX"
  description="Renta de monitores de retorno, displays de señalización digital y pantallas informativas para congresos y expos en CDMX. Desde $800 por monitor."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Señalización digital profesional"
    title='Renta de <span class="highlight">Monitores y Displays</span> para Eventos en CDMX'
    subtitle="Monitores de retorno para presentadores, displays de señalización digital y pantallas informativas para congresos, expos y eventos corporativos. Software de gestión y técnico de configuración incluidos."
    primaryCTA={{ label: "Cotiza tus monitores", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar monitores y displays para mi evento` }}
    cards={[
      {
        title: "Monitores de retorno y displays de señalización profesional",
        content: "<strong>Renta de monitores y displays</strong> especializados para eventos corporativos y congresos en CDMX. Monitores de retorno de 15 a 24 pulgadas para presentadores y panelistas con soporte ajustable y conexión independiente. Displays de señalización digital de 32 a 55 pulgadas para agendas, directorios de expo, bienvenida y contenido informativo. Pantallas táctiles opcionales para sistemas de check-in y kioscos interactivos. Formato horizontal o vertical según tus necesidades.",
      },
      {
        title: "Gestión centralizada de contenido con técnico incluido",
        content: "<strong>Software de señalización digital</strong> incluido en cada renta para gestionar el contenido de todos los monitores desde un solo punto. Actualiza agendas, mensajes y contenido en tiempo real vía WiFi. Nuestro técnico se encarga de la configuración inicial, personalización con tu branding corporativo, instalación en cada ubicación y soporte durante todo el evento. Conectividad HDMI, USB, WiFi y Ethernet para máxima flexibilidad. Desmontaje incluido.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Congreso, expo o conferencia en puerta?"
    subheadline="Cotiza sin compromiso — diseñamos la distribución de monitores perfecta para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pantallas LED para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas monitores para tu congreso o expo?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar monitores y displays para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Monitores y Displays</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Monitor de Retorno -->
          <section class="section section--alt" aria-labelledby="retorno-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Esencial para presentadores</span>
                <h2 class="showcase__title" id="retorno-heading">Monitor de Retorno</h2>
                <p class="showcase__subtitle">El confidence monitor que todo presentador necesita: notas, diapositivas y timer sin voltear a la pantalla principal.</p>
                <p class="showcase__text">El <strong>monitor de retorno</strong> (confidence monitor) es un equipo esencial para conferencias y presentaciones profesionales. Se coloca frente al presentador, fuera de la vista del público, mostrando las <strong>diapositivas actuales y siguientes, notas del presentador y timer</strong> de la presentación. Disponible en <strong>15 y 24 pulgadas</strong> con soporte ajustable en altura y ángulo, se adapta a podiums, mesas de conferencia y escenarios con atril.</p>
                <p class="showcase__text">Cada monitor de retorno incluye <strong>conexión HDMI independiente</strong> de la pantalla principal — puede mostrar la vista de presentador de PowerPoint mientras el público ve las diapositivas en la pantalla grande. También funciona como <strong>prompter de guión, monitor de cámara en vivo o pantalla de countdown</strong>. El técnico configura la distribución de señal y la vista de presentador antes de tu evento. Combínalo con nuestros <a href="/servicios/audiovisual/microfonos-dj/">micrófonos profesionales</a> para una presentación impecable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">15" y 24"</span>
                  <span class="showcase__tag">Soporte ajustable</span>
                  <span class="showcase__tag">Vista presentador</span>
                  <span class="showcase__tag">HDMI independiente</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Monitor de Retorno
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Monitor de Retorno</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Display de Registro -->
          <section class="section section--alt" aria-labelledby="registro-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Primera impresión perfecta</span>
                <h2 class="showcase__title" id="registro-heading">Display de Registro y Bienvenida</h2>
                <p class="showcase__subtitle">Pantallas de bienvenida y check-in digital que agilizan el registro y elevan la imagen de tu evento.</p>
                <p class="showcase__text">Los <strong>displays de registro y bienvenida</strong> transforman la entrada de tu evento en una experiencia profesional de primer nivel. Pantallas de <strong>32 a 43 pulgadas</strong> en formato vertical con mensaje de bienvenida personalizado, logo del evento, agenda del día y sistema de <strong>check-in digital</strong>. Disponibles con <strong>pantalla táctil opcional</strong> para que los asistentes se registren directamente, escaneen su QR de entrada o consulten el programa del evento de manera interactiva.</p>
                <p class="showcase__text">El contenido de bienvenida se personaliza con tu <strong>branding corporativo</strong>: colores, logo, tipografías y mensajes de patrocinadores. El sistema se integra con plataformas de registro como Eventbrite, Cvent y sistemas personalizados vía navegador web. Incluye <strong>pedestal elegante o soporte de mesa</strong>, conectividad WiFi para actualizaciones remotas y técnico de configuración. Ideal para <strong>congresos, convenciones, seminarios, galas de premiación y eventos de networking</strong>. Combínalo con nuestros <a href="/servicios/accesorios/senalizacion-alfombras/">accesorios de señalización</a> para un montaje de recepción impecable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">32-43" vertical</span>
                  <span class="showcase__tag">Touch opcional</span>
                  <span class="showcase__tag">Check-in digital</span>
                  <span class="showcase__tag">Branding custom</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Display de Registro
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Display de Registro</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Señalización Digital -->
          <section class="section section--alt" aria-labelledby="senalizacion-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Información en tiempo real</span>
                <h2 class="showcase__title" id="senalizacion-heading">Señalización Digital</h2>
                <p class="showcase__subtitle">Displays informativos para directorios, mapas de expo, agendas dinámicas y contenido de patrocinadores.</p>
                <p class="showcase__text">La <strong>señalización digital profesional</strong> es el complemento esencial para expos, congresos y eventos corporativos donde los asistentes necesitan acceso constante a información actualizada. Displays de <strong>43 a 55 pulgadas</strong> en formato horizontal o vertical, distribuidos estratégicamente en pasillos, lobbies, áreas de descanso y entradas de salas para mostrar <strong>directorios de expositores, mapas de la expo, agendas por sala, horarios de conferencias y contenido de patrocinadores</strong>.</p>
                <p class="showcase__text">El software de señalización digital incluido permite <strong>gestión centralizada de contenido</strong> — actualiza horarios, mensajes de emergencia o anuncios de última hora en todos los displays simultáneamente desde un solo laptop. Programación por zonas para mostrar contenido diferente según la ubicación del display. Compatibilidad con <strong>feeds de redes sociales, hashtags del evento y contenido multimedia</strong>. Cada display incluye reproductor multimedia integrado y conectividad WiFi/Ethernet. Complementa con nuestras <a href="/servicios/audiovisual/pantallas-led/pedestal/">pantallas LED en pedestal</a> para las salas principales.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">43-55" displays</span>
                  <span class="showcase__tag">Gestión centralizada</span>
                  <span class="showcase__tag">Actualización en vivo</span>
                  <span class="showcase__tag">Multi-zona</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Señalización Digital
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Señalización Digital</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Congreso -->
          <section class="section section--alt" aria-labelledby="kit-congreso-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Solución integral</span>
                <h2 class="showcase__title" id="kit-congreso-heading">Kit Congreso Multi-Monitor</h2>
                <p class="showcase__subtitle">Paquete completo de monitores para congresos: retorno, registro, señalización y gestión centralizada.</p>
