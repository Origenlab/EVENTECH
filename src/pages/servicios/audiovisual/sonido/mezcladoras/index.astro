---
/**
 * ─── Mezcladoras y Monitoreo — Pagina de Producto (Nivel 4) ───
 * Consolas digitales Yamaha y Allen & Heath de 16 a 32 canales
 * para eventos en CDMX. Monitores de escenario incluidos.
 *
 * Jerarquia: Servicios > Audiovisual > Sonido > Mezcladoras
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Sonido", href: "/servicios/audiovisual/sonido/" },
  { label: "Mezcladoras y Monitoreo" },
];

const faqs = [
  { question: "¿Qué consola necesito según el tamaño de mi evento?", answer: 'Para <strong>bodas y eventos sociales</strong> con banda, DJ y 2-4 micrófonos, una consola de <strong>16 canales Yamaha TF1</strong> es suficiente. Para <strong>conciertos y festivales</strong> con banda completa, múltiples micrófonos y fuentes de audio, recomendamos una consola de <strong>32 canales Yamaha CL3/CL5 o Allen & Heath dLive</strong>. La diferencia principal es el número de canales simultáneos: 16 canales para eventos sencillos, 32+ canales para producciones complejas con muchas fuentes de audio. Nuestro ingeniero evalúa tu rider técnico y recomienda la opción ideal.' },
  { question: "¿La consola incluye monitores de escenario?", answer: "Nuestros paquetes de consola incluyen <strong>monitores de escenario (wedges) bajo solicitud</strong>. El <strong>Kit Monitoreo</strong> incluye monitores activos de 12 y 15 pulgadas con mezclas independientes para cada posición de escenario. También ofrecemos <strong>sidefills (monitores laterales)</strong> para cubrir el escenario completo. Para artistas profesionales que lo requieran, contamos con <strong>sistemas IEM (In-Ear Monitors)</strong> con receptores inalámbricos de alta fidelidad. Cada monitor tiene su propia mezcla personalizada gestionada por el ingeniero de monitoreo." },
  { question: "¿Puedo grabar el audio de mi evento con la consola?", answer: "Sí, todas nuestras consolas digitales incluyen <strong>grabación multitrack vía USB</strong> integrada. La Yamaha TF graba hasta 34 tracks simultáneos y la CL graba hasta 64 tracks. Esto permite capturar cada canal por separado (voz, instrumentos, música ambiente) para una <strong>post-producción profesional</strong>. El archivo se guarda directamente en una memoria USB o disco duro externo. Ideal para <strong>grabar conferencias, conciertos y ceremonias</strong> que necesiten edición posterior o distribución." },
  { question: "¿Qué es un split y para qué sirve?", answer: "Un <strong>split (o splitter de audio)</strong> es un dispositivo que duplica la señal de cada micrófono e instrumento para enviarla a dos consolas independientes: una para el <strong>FOH (Front of House)</strong> que maneja el sonido que escucha la audiencia, y otra para <strong>monitoreo</strong> que gestiona lo que escuchan los artistas en escenario. Esto permite que el ingeniero de FOH y el de monitoreo trabajen de forma independiente sin afectarse mutuamente. Es esencial en <strong>conciertos y producciones con banda en vivo</strong> donde los artistas necesitan mezclas de monitor personalizadas." },
  { question: "¿Las consolas funcionan con stage box digital?", answer: 'Sí, todas nuestras consolas digitales trabajan con <strong>stage boxes (cajas de escenario) digitales</strong> conectadas por cable Cat6 o fibra óptica. La stage box se coloca en el escenario y convierte las señales de los micrófonos de analógico a digital, enviando todo por un solo cable hasta la consola. Esto <strong>elimina la necesidad de tirar docenas de cables analógicos XLR</strong> entre el escenario y la posición de mezcla, simplificando el montaje, reduciendo el peso del cableado y mejorando la calidad de la señal al minimizar la longitud de cable analógico.' },
  { question: "¿Incluye sistema de intercom para el equipo técnico?", answer: "Sí, nuestros paquetes de producción incluyen <strong>sistema de intercom profesional con comunicación bidireccional</strong> entre el ingeniero de audio (FOH), el ingeniero de monitoreo, el director de escena y el coordinador de producción. Cada posición cuenta con un <strong>beltpack con auricular y micrófono</strong> para comunicación clara incluso en ambientes ruidosos. Es esencial para <strong>coordinar entradas de artistas, cambios de escena, cues de iluminación y cualquier ajuste técnico</strong> durante el evento en tiempo real." },
];

const specs = [
  { label: "Consolas", value: "Yamaha TF/CL, Allen & Heath dLive/SQ" },
  { label: "Canales", value: "16 a 32 canales" },
  { label: "Formato", value: "Digital con recall de escenas" },
  { label: "Monitores", value: "Escenario 12\" y 15\" activos" },
  { label: "Procesadores", value: "Gates / Compresores / EQ por canal" },
  { label: "IEM", value: "In-ear monitors opcionales" },
  { label: "Intercom", value: "Sistema de comunicación técnica" },
  { label: "Grabación", value: "Multitrack USB incluida" },
  { label: "Splits", value: "Para FOH + monitoreo independiente" },
  { label: "Ingeniero", value: "De audio dedicado incluido" },
];

const sidebarNav = [
  { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
  { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
  { name: "Subwoofers y Graves", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras y Monitoreo", href: null, active: true },
];

const sidebarRelated = [
  { name: "Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
  { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
  { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Streaming en Vivo", href: "/servicios/audiovisual/proyectores/" },
  { name: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
];

const reviews = [
  { author: "Ing. Alejandro Fuentes", text: "Contratamos una consola Yamaha CL5 de 32 canales con stage box y split para un concierto de 2,000 personas. El ingeniero de audio fue excepcional, la mezcla de FOH sonó impecable y los artistas estuvieron encantados con sus mezclas de monitor. La grabación multitrack nos permitió hacer la mezcla del disco en vivo. Servicio de primer nivel.", rating: 5, date: "2025-11-25" },
  { author: "Sofía Contreras", text: "Rentamos una Yamaha TF1 de 16 canales para nuestra boda con trío y DJ. El ingeniero coordinó las transiciones entre la ceremonia, los discursos y la fiesta sin un solo problema. La calidad de audio fue cristalina y el micrófono inalámbrico funcionó perfecto para los brindis. Muy profesionales.", rating: 5, date: "2025-10-18" },
  { author: "Lic. Roberto Méndez", text: "Usamos una Allen & Heath con 4 monitores de escenario para un congreso de 3 días con 12 ponentes. El sistema de intercom fue crucial para coordinar las entradas y la grabación multitrack nos permitió distribuir el audio de cada conferencia. Logística impecable y equipo técnico de primera.", rating: 5, date: "2025-09-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Mezcladoras y Monitoreo para Eventos en CDMX",
    description: "Renta de consolas digitales Yamaha y Allen & Heath de 16 a 32 canales para eventos en CDMX. Monitores de escenario y procesadores incluidos. Desde $3,000.",
    url: "/servicios/audiovisual/sonido/mezcladoras/",
    priceRange: { min: 3000, max: 15000 },
    reviews,
    ratingValue: 5,
    reviewCount: 89,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
    { name: "Mezcladoras y Monitoreo", url: "/servicios/audiovisual/sonido/mezcladoras/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Mezcladoras y Monitoreo para Eventos en CDMX"
  description="Renta de consolas digitales Yamaha y Allen & Heath de 16 a 32 canales para eventos en CDMX. Monitores de escenario y procesadores incluidos. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Control total del audio en tu evento"
    title='Renta de <span class="highlight">Mezcladoras y Monitoreo</span> para Eventos en CDMX'
    subtitle="Consolas digitales Yamaha TF/CL y Allen & Heath dLive/SQ de 16 a 32 canales. Monitores de escenario, procesadores, grabación multitrack e ingeniero de audio incluidos."
    primaryCTA={{ label: "Cotiza tu consola", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar mezcladoras y monitoreo para mi evento` }}
    cards={[
      {
        title: "Consolas digitales de última generación con procesamiento completo",
        content: "<strong>Renta de consolas digitales profesionales</strong> con las marcas líderes del audio para eventos en CDMX. Yamaha TF y CL Series con interfaz táctil intuitiva y Allen & Heath dLive y SQ con procesamiento de 96 kHz. Configuraciones de 16 a 32 canales con procesamiento interno completo: ecualización paramétrica, compresión dinámica, gates, efectos y gestión de grupos por canal. Recall de escenas para transiciones instantáneas entre momentos del evento. Stage box digital con conexión Cat6 o fibra óptica.",
      },
      {
        title: "Monitoreo profesional e ingeniero de audio dedicado",
        content: "<strong>Sistema de monitoreo completo incluido</strong> en cada renta de consola. Monitores de escenario activos de 12 y 15 pulgadas con mezclas independientes para cada posición. Sistema de intercom profesional para coordinación del equipo técnico. Grabación multitrack USB para post-producción. Splits para FOH y monitoreo independiente. Ingeniero de audio dedicado que gestiona la mezcla, los monitores y la comunicación técnica durante todo tu evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas control profesional del audio en tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la consola y monitoreo ideal para tu producción"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Sonido Profesional</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas mezcladoras para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar mezcladoras y monitoreo para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Mezcladoras y Monitoreo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Consola 16ch -->
          <section class="section section--alt" aria-labelledby="consola16-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para bodas y eventos sociales</span>
                <h2 class="showcase__title" id="consola16-heading">Consola 16 Canales</h2>
                <p class="showcase__subtitle">La consola digital perfecta para bodas, corporativos y eventos sociales con banda, DJ y micrófonos.</p>
                <p class="showcase__text">Nuestra <strong>consola digital de 16 canales Yamaha TF1</strong> es la opción ideal para <strong>bodas y eventos sociales</strong> que requieren gestión profesional del audio. Con <strong>interfaz táctil de 15 pulgadas</strong>, ofrece control intuitivo de cada canal con ecualización paramétrica, compresión dinámica y efectos integrados. Los 16 canales son suficientes para manejar simultáneamente: micrófono del maestro de ceremonias, micrófonos para brindis, entrada del DJ, salida de la laptop para presentaciones y música ambiente.</p>
                <p class="showcase__text">Incluye <strong>recall de escenas</strong> que permite programar configuraciones preestablecidas para cada momento del evento: ceremonia (micrófonos + música suave), cena (música ambiente), brindis (micrófono inalámbrico con reverb) y fiesta (DJ a volumen completo). El ingeniero de audio cambia de escena con un solo toque, garantizando transiciones suaves y profesionales. Stage box de 16 inputs con conexión Cat6 para un montaje limpio y rápido. Ideal para <strong>bodas, cenas de gala, bautizos, graduaciones y presentaciones corporativas</strong>. Complementa con nuestro <a href="/servicios/audiovisual/sonido/bocinas/">equipo de bocinas</a> para un sistema completo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Yamaha TF1</span>
                  <span class="showcase__tag">16 canales</span>
                  <span class="showcase__tag">Pantalla táctil</span>
                  <span class="showcase__tag">Recall de escenas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Consola 16ch
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Consola 16 Canales</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Consola 32ch -->
          <section class="section section--alt" aria-labelledby="consola32-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Para conciertos y festivales</span>
                <h2 class="showcase__title" id="consola32-heading">Consola 32 Canales</h2>
                <p class="showcase__subtitle">La consola profesional para conciertos, festivales y producciones con banda completa y múltiples fuentes de audio.</p>
                <p class="showcase__text">La <strong>consola digital de 32 canales Yamaha CL3/CL5 o Allen & Heath dLive</strong> es la herramienta definitiva para producciones de audio complejas. Con <strong>32+ canales de entrada, 16+ buses auxiliares y procesamiento de 96 kHz</strong>, maneja simultáneamente cada micrófono e instrumento de una banda completa: batería (8-10 mics), bajo, guitarras, teclados, voces principales y coros, más fuentes adicionales como pistas de respaldo y efectos. Procesamiento interno de estudio incluyendo EQ, compresión, gates y efectos premium por canal.</p>
                <p class="showcase__text">Incluye <strong>stage box digital de 32 inputs con conversión A/D de alta calidad</strong>, conectada por Cat6 o fibra óptica hasta la posición de mezcla. Sistema de <strong>recall completo</strong> que guarda toda la configuración de la consola (niveles, EQ, efectos) permitiendo reproducir exactamente la misma mezcla en eventos recurrentes o ensayos. Ideal para <strong>conciertos, festivales de música, producciones teatrales, conferencias multi-sala y eventos híbridos con streaming</strong>. Complementa con nuestro <a href="/servicios/audiovisual/sonido/line-array/">sistema line array</a> para una producción de nivel profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Yamaha CL / Allen & Heath</span>
                  <span class="showcase__tag">32 canales</span>
                  <span class="showcase__tag">96 kHz</span>
                  <span class="showcase__tag">Stage box digital</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Consola 32ch
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Consola 32 Canales</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Kit Monitoreo -->
          <section class="section section--alt" aria-labelledby="monitoreo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Audio perfecto en escenario</span>
                <h2 class="showcase__title" id="monitoreo-heading">Kit Monitoreo Completo</h2>
                <p class="showcase__subtitle">Monitores de escenario (wedges) + sidefills para que los artistas escuchen perfectamente en el escenario.</p>
                <p class="showcase__text">El <strong>Kit Monitoreo</strong> proporciona audio de alta fidelidad directamente en el escenario para <strong>músicos, cantantes, ponentes y presentadores</strong>. Incluye <strong>monitores de escenario (wedges) activos de 12 y 15 pulgadas</strong> posicionados en cada posición del escenario, con mezclas independientes para cada monitor. Cada artista escucha exactamente lo que necesita: el cantante escucha su voz y la guía, el baterista escucha el click y el bajo, el guitarrista escucha su amplificador y la voz.</p>
                <p class="showcase__text">También incluye <strong>sidefills (monitores laterales de mayor potencia)</strong> que cubren las áreas del escenario donde los wedges individuales no alcanzan, ideal para bandas con mucho movimiento en escena. Para artistas que lo prefieran, ofrecemos <strong>IEM (In-Ear Monitors)</strong> con receptores inalámbricos de alta fidelidad que eliminan el ruido del escenario y proporcionan una mezcla personal cristalina. El ingeniero de monitoreo dedicado gestiona todas las mezclas desde una consola independiente. Ideal para <strong>conciertos, festivales, producciones teatrales y conferencias con múltiples ponentes</strong>. Complementa con nuestras <a href="/servicios/pistas-baile/tarimas-escenarios/">tarimas modulares</a> para un escenario profesional completo.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Wedges 12" y 15"</span>
                  <span class="showcase__tag">Sidefills</span>
                  <span class="showcase__tag">IEM disponible</span>
                  <span class="showcase__tag">Mezclas independientes</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Kit Monitoreo
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
