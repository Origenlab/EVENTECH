  <!-- ── Nav de 8 subservicios: 4 columnas × 2 filas + CTA full-width ──
       Nota: se usa <style is:global> con media queries en lugar del atributo
       inline `style=` porque un inline gana siempre a las media queries de
       home-2026.css y rompía el responsive del hm-menu en móvil. -->
  <style is:global>
    .hm-menu__grid--sonido {
      grid-template-columns: repeat(4, 1fr);
    }
    .hm-menu__grid--sonido li:nth-child(4n + 1) {
      border-left: 0;
    }
    .hm-menu__grid--sonido .hm-menu__cta-row {
      grid-column: 1 / -1;
      border-left: 0 !important;
      border-top: 1px solid var(--color-hairline);
    }
    @media (max-width: 900px) {
      .hm-menu__grid--sonido {
        grid-template-columns: repeat(3, 1fr);
      }
      .hm-menu__grid--sonido li:nth-child(4n + 1) {
        border-left: 1px solid var(--color-hairline);
      }
      .hm-menu__grid--sonido li:nth-child(3n + 1) {
        border-left: 0;
      }
    }
    @media (max-width: 560px) {
      .hm-menu__grid--sonido {
        grid-template-columns: repeat(2, 1fr);
      }
      .hm-menu__grid--sonido li:nth-child(3n + 1) {
        border-left: 1px solid var(--color-hairline);
      }
      .hm-menu__grid--sonido li:nth-child(2n + 1) {
        border-left: 0;
      }
    }
  </style>

  <script>
    const sonidoForm = document.getElementById("sonidoForm");
    if (sonidoForm) {
      sonidoForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const f = e.currentTarget as HTMLFormElement;
        const wa = f.dataset.wa;
        const data = new FormData(f);
        const get = (k: string) => (data.get(k) || "").toString().trim();
        let t = "Hola, quiero cotizar sonido profesional para mi evento.";
        if (get("nombre"))  t += `\nNombre: ${get("nombre")}`;
        if (get("tipo"))    t += `\nTipo de evento: ${get("tipo")}`;
        if (get("fecha"))   t += `\nFecha: ${get("fecha")}`;
        if (get("modelo"))  t += `\nTipo de sonido: ${get("modelo")}`;
        if (get("mensaje")) t += `\nDetalles: ${get("mensaje")}`;
        window.open(`https://wa.me/${wa}?text=${encodeURIComponent(t)}`, "_blank", "noopener");
      });
    }
  </script>

