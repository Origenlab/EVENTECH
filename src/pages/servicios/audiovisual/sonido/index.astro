---
/**
 * ─── EVENTECH.MX — Renta de Sonido Profesional para Eventos (Hub L4, molde hm- 2026) ───
 * Line Array · Bocinas · Subwoofers · Mezcladoras · Amplificadores · Monitores ·
 * Paquetes · Accesorios — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * Proveedor aliado white-label: SOEVE (sonidoparaeventos.com.mx) vía ProveedorSonido.astro.
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: reusadas de /images/audiovisual (faltan fotos reales por tipo — reemplazar).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorSonido from "@components/ProveedorSonido.astro";

const SUB_SERVICES = [
  {
    id: "line-array",
    name: "Sistemas Line Array",
    short: "Line Array",
    badge: "El estándar profesional",
    excerpt: "JBL VTX y d&b audiotechnik para 200 a 5,000+ personas. Cobertura uniforme en el WTC, Citibanamex y festivales al aire libre. Ingeniero de audio incluido.",
    href: "/servicios/audiovisual/sonido/line-array/",
    image: "/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif",
    specs: ["JBL VTX", "d&b Y-Series", "200–5,000+ pax", "Flown / Ground-stack"],
  },
  {
    id: "bocinas",
    name: "Bocinas Amplificadas",
    short: "Bocinas",
    badge: "Solución compacta",
    excerpt: "Bocinas activas JBL de 12\" y 15\" para eventos en salón de hasta 200 personas. Instalación en 30 minutos — ideal para bodas y salones del sur de CDMX.",
    href: "/servicios/audiovisual/sonido/bocinas/",
    image: "/images/audiovisual/audio-evento-02.avif",
    specs: ['Activas 12"', 'Activas 15"', "80–200 pax", "Trípode"],
  },
  {
    id: "subwoofers",
    name: "Subwoofers y Graves",
    short: "Subwoofers",
    badge: "Potencia que se siente",
    excerpt: "Subs de 18\" y 21\" con respuesta desde 28 Hz y configuración cardioide. Regla: 1 sub por cada 100 personas en salón. Imprescindibles para DJ y música en vivo.",
    href: "/servicios/audiovisual/sonido/subwoofers/",
    image: "/images/audiovisual/audio-evento-03.avif",
    specs: ['18"', '21"', "Cardioide", "Desde 28 Hz"],
  },
  {
    id: "mezcladoras",
    name: "Mezcladoras y Monitoreo",
    short: "Mezcladoras",
    badge: "Control total",
    excerpt: "Consolas digitales Yamaha CL/TF y Allen & Heath de 16 a 32 canales. Monitores de escenario, stage box e intercom para eventos con artistas y panelistas.",
    href: "/servicios/audiovisual/sonido/mezcladoras/",
    image: "/images/audiovisual/audio-evento-04.avif",
    specs: ["Yamaha CL/TF", "Allen & Heath", "16–32 canales", "Intercom"],
  },
  {
    id: "amplificadores",
    name: "Amplificadores de Potencia",
    short: "Amplificadores",
    badge: "El motor del sistema",
    excerpt: "Amplificación clase D con DSP, crossover y limitadores. Crown, QSC, Lab.gruppen y Powersoft en racks preconfigurados para sistemas pasivos y line array.",
    href: "/servicios/audiovisual/sonido/amplificadores/",
    image: "/images/audiovisual/audio-evento-04.avif",
    specs: ["Clase D", "DSP integrado", "2 / 4 / 8 Ω", "Racks armados"],
  },
  {
    id: "monitores-escenario",
    name: "Monitores de Escenario",
    short: "Monitores",
    badge: "Para música en vivo",
    excerpt: "Wedges de piso, sistemas in-ear, sidefills y drumfills con mezclas independientes. Si hay banda en vivo, el monitoreo no es opcional.",
    href: "/servicios/audiovisual/sonido/monitores-escenario/",
    image: "/images/audiovisual/audio-evento-05.avif",
    specs: ["Wedges 12\" / 15\"", "In-ear (IEM)", "Sidefill", "Mezclas aux"],
  },
  {
    id: "paquetes",
    name: "Paquetes de Sonido",
    short: "Paquetes",
    badge: "Precio cerrado",
    excerpt: "Cuatro kits probados por tipo de evento: boda, XV años, corporativo y concierto. Equipo, montaje, sound check e ingeniero de audio incluidos.",
    href: "/servicios/audiovisual/sonido/paquetes/",
    image: "/images/audiovisual/equipo-audiovisual-completo-boda.avif",
    specs: ["Boda", "XV y Fiesta", "Corporativo", "Concierto"],
  },
  {
    id: "accesorios-audio",
    name: "Accesorios y Cableado",
    short: "Accesorios",
    badge: "El montaje invisible",
    excerpt: "Stage box digital, snake Cat6, cajas DI, pedestales, rigging certificado y plantas de luz. El 90% de las fallas de audio son fallas de cable o de corriente.",
    href: "/servicios/audiovisual/sonido/accesorios-audio/",
    image: "/images/audiovisual/audio-evento-01.avif",
    specs: ["Stage box Cat6", "Cajas DI", "Rigging", "Planta de luz"],
  },
];

const whyFeatures = [
  {
    title: "Ingeniero de audio dedicado y sound check",
    body: "No entregamos el equipo y nos vamos. Cada renta incluye prueba de sonido previa e ingeniero de audio que se queda todo el evento monitoreando niveles y ajustando la mezcla según el programa: discurso, música en vivo o DJ. El audio es lo que todos escuchan al mismo tiempo — siempre hay alguien operándolo.",
  },
  {
    title: "Inventario propio de marcas líderes — sin subcontratar",
    body: "Equipo propio JBL, d&b audiotechnik, Yamaha y Allen & Heath en bodega CDMX. Cada sistema se revisa y calibra antes de salir: conos, amplificadores, cableado y DSP. Lo que cotizamos es lo que existe, verificado antes de cada entrega. Sin sorpresas de disponibilidad el día del evento.",
  },
  {
    title: "Ecualización según la acústica de tu venue",
    body: "Un salón con eco no suena igual que un jardín abierto. El ingeniero ecualiza el sistema en sitio según la acústica real del espacio — reverberación, materiales, techos — para que la voz se entienda y la música tenga cuerpo sin retumbar. No es un equipo genérico encendido: es sonido afinado a tu venue.",
  },
  {
    title: "Cableado profesional y stage box digital",
    body: "Cableado limpio y oculto, con stage box digital vía Cat6 que elimina los tendidos largos de cable analógico. Menos ruido, menos puntos de falla y un montaje ordenado que no estorba al resto de la producción ni se ve en las fotos del evento.",
  },
  {
    title: "Respaldo de equipo en sitio",
    body: "Cargamos bocinas, amplificación y cables de respaldo en cada servicio. Si un componente falla durante el montaje o el evento, se reemplaza sin costo en sitio. El ingeniero tiene con qué responder ante cualquier imprevisto — no te quedas sin sonido a media pista.",
  },
  {
    title: "Asesoría de sistema según pax, espacio y programa",
    body: "El sistema correcto depende de cuántas personas, qué tan grande es el espacio y qué se va a reproducir. Hacemos visita técnica sin costo para medir tu venue y recomendarte la configuración exacta — para que cada asistente escuche con claridad y no pagues por más potencia de la que necesitas.",
  },
];

const steps = [
  { n: 1, t: "Cotización y visita técnica", p: "Nos indicas tipo de evento, venue, número de asistentes y programa (discursos, música en vivo, DJ). Hacemos visita técnica sin costo para evaluar la acústica. En menos de 24 horas te confirmamos el sistema ideal y te enviamos propuesta." },
  { n: 2, t: "Propuesta técnica y aparto de equipo", p: "Definimos configuración: cajas, subwoofers, canales de consola y monitoreo. Con el 30% de anticipo apartamos el equipo y la fecha — sin pago total por adelantado. Coordinamos con tu DJ, banda o productor si aplica." },
  { n: 3, t: "Montaje, sound check y ecualización", p: "Llegamos con tiempo el día del evento o la tarde anterior. Montaje con cableado oculto, rigging certificado si es line array, y sound check completo con ecualización según la acústica del venue antes de abrir puertas. Tú o tu coordinador dan el visto bueno." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "El ingeniero opera el sistema durante todo el evento, gestiona la mezcla y monitorea niveles. Al cierre, desmontamos, recogemos y hacemos conteo de equipo. El desmontaje y recolección están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué sistema de sonido necesito según el tamaño de mi evento?", answer: "La elección del sistema depende directamente del número de asistentes y el tipo de espacio. Para eventos íntimos de hasta 80 personas recomendamos bocinas amplificadas de 12 pulgadas. Para eventos medianos de 80 a 200 personas, bocinas de 15 pulgadas con subwoofer complementario. Para eventos de 200 a 500 personas, un sistema line array compacto con procesador digital. Para eventos de más de 500 personas, un sistema line array completo con múltiples cajas y subwoofers. Nuestro ingeniero de audio evalúa tu venue en una visita sin costo y te recomienda la configuración exacta." },
  { question: "¿Qué diferencia hay entre line array y bocinas amplificadas?", answer: "El line array es un sistema de cajas acústicas apiladas verticalmente que distribuye el sonido de manera uniforme a grandes distancias, ideal para eventos al aire libre y recintos de gran tamaño con audiencias de 200 a 5,000+ personas. Las bocinas amplificadas son sistemas punto-fuente compactos con amplificador integrado, perfectos para salones y espacios cerrados de hasta 200 personas. El line array ofrece mayor alcance y cobertura pareja, mientras que las bocinas son más prácticas, económicas y rápidas de instalar." },
  { question: "¿El sistema de sonido incluye ingeniero de audio?", answer: "Sí. Todos nuestros paquetes de sonido profesional incluyen prueba de sonido (sound check) previa al evento, ecualización del sistema según la acústica del venue, y un ingeniero de audio dedicado durante todo el evento. El ingeniero monitorea los niveles en tiempo real, ajusta la mezcla según las necesidades del programa (discursos, música en vivo, DJ) y resuelve cualquier situación técnica al instante. El servicio técnico completo está incluido en el precio de la renta." },
  { question: "¿El sonido incluye micrófonos para discursos o música?", answer: "El sistema de sonido incluye la mezcladora y el monitoreo, pero los micrófonos se cotizan según tu necesidad: inalámbricos de mano para brindis y presentaciones, solapa o diadema para conferencistas, e instrumentos para bandas en vivo. Los coordinamos en el mismo paquete desde nuestra sección de micrófonos y DJ para que todo el audio llegue de un solo proveedor, ya ecualizado en conjunto. Cuéntanos el programa del evento y armamos el set completo." },
  { question: "¿Pueden instalar sonido bajo una carpa?", answer: "Sí, tenemos amplia experiencia instalando sistemas de sonido bajo carpas de todo tipo. Utilizamos rigging certificado que se ancla directamente en los puntos estructurales de la carpa. Recomendamos las carpas estructurales de aluminio ya que ofrecen los mejores puntos de anclaje para colgar line array y distribuir bocinas de manera óptima. El ingeniero de audio evalúa la acústica particular del espacio techado para ecualizar correctamente y evitar reverberaciones indeseadas." },
  { question: "¿Cuántos subwoofers necesito para mi evento?", answer: "La regla general es 1 subwoofer por cada 100 personas en espacios cerrados y 1 por cada 50 personas en espacios al aire libre. Para eventos con DJ o música electrónica, recomendamos aumentar la proporción ya que estos géneros requieren mayor presencia de graves. Por ejemplo, una boda en salón con 150 invitados necesita 2 subwoofers de 18 pulgadas. Un festival outdoor con 300 personas requiere 6 subwoofers mínimo. Nuestro ingeniero de audio calcula la configuración exacta según tu evento." },
  { question: "¿Con cuánta anticipación debo reservar el equipo de sonido?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para eventos estándar. Para eventos grandes con sistemas line array o configuraciones especiales, lo ideal es apartar con 1 a 2 meses, especialmente en temporada alta (noviembre a febrero y mayo a junio). Los sistemas line array JBL y los paquetes completos son los más solicitados y se agotan primero. También atendemos solicitudes de último momento sujetas a disponibilidad de equipo." },
  { question: "¿Puedo rentar amplificadores, monitores o accesorios por separado?", answer: "Sí. Aunque la mayoría de nuestros clientes contrata un sistema completo o un paquete cerrado, rentamos por separado amplificadores de potencia, monitores de escenario (wedges e in-ear) y accesorios técnicos como stage box, cajas DI, pedestales y rigging. Es común en productores y bandas que ya tienen parte del equipo y solo necesitan completar. Ten en cuenta que cuando rentas un sistema o un paquete de EVENTECH, la amplificación, el cableado y los accesorios ya vienen incluidos: no se cobran aparte." },
  { question: "¿Conviene armar el sonido por piezas o contratar un paquete?", answer: "Si no eres técnico de audio, un paquete cerrado casi siempre sale mejor. Elegir pieza por pieza es donde se cometen los errores más caros: se renta la bocina correcta pero falta el subwoofer, o sobra potencia y falta un micrófono. Nuestros paquetes de sonido parten de las variables que sí conoces —cuántas personas y qué tipo de evento— y de ahí derivan la configuración completa, ya probada en eventos reales. Si tu evento tiene requerimientos específicos, armamos una configuración a la medida sobre esa misma base." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Sonido Profesional para Eventos en CDMX",
    description: "Renta de line array JBL y d&b, bocinas, subwoofers, mezcladoras, amplificadores, monitores de escenario, paquetes y accesorios de audio para eventos en CDMX. Sound check e ingeniero de audio incluidos.",
    url: "/servicios/audiovisual/sonido/",
    priceRange: { min: 300, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Sonido" },
];
---

<PageLayout
  title="Renta de Sonido Profesional para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif"
  description="Renta de equipo de sonido para eventos en CDMX: line array, bocinas, subwoofers, mezcladoras, amplificadores, monitores y paquetes. Ingeniero de audio incluido."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="sonido-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Sonido profesional · CDMX y ZMVM</p>
            <h1 id="sonido-hero-heading">
              Sonido profesional para eventos — <em>del salón íntimo al festival de 5,000 personas</em>
            </h1>
            <p class="hm-hero__lead">
              Line array JBL y d&b audiotechnik, bocinas amplificadas, subwoofers de alto
              rendimiento y mezcladoras digitales de 16 a 32 canales. Sound check e ingeniero
              de audio incluidos en cada renta.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20sonido%20profesional%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar sonido
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>sonido profesional para eventos</strong> en CDMX con
              inventario propio de las marcas líderes de la industria — line array
              <strong>JBL VTX y d&b audiotechnik</strong> para audiencias de 200 a 5,000+
              personas, bocinas amplificadas activas de 12 y 15 pulgadas, subwoofers de 18 y
              21 pulgadas con configuración cardioide, y consolas digitales Yamaha y Allen &
              Heath de hasta 32 canales. Cada sistema se calibra y verifica antes de cada entrega.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que el audio
              es lo que separa un evento que se disfruta de uno donde nadie entiende los
              discursos: por eso cada renta incluye sound check, ecualización según la
              acústica del venue y un ingeniero de audio dedicado durante todo el evento.
              Para producciones completas sumamos
              <a href="/servicios/audiovisual/microfonos-dj/">micrófonos y cabina de DJ</a> e
              <a href="/servicios/iluminacion/">iluminación de escenario</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de sistema de sonido disponibles">
      <ul class="hm-menu__grid hm-menu__grid--sonido">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.short}</a></li>
        ))}
        <li class="hm-menu__cta-row">
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20sonido%20profesional%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué sistema de sonido necesita tu evento?</h2>
            <p class="hm__head-sub">8 soluciones de audio — del salón íntimo al festival masivo, con la potencia y la cobertura correctas para cada espacio.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El sonido es lo único que absolutamente todos perciben al mismo tiempo, todo
              el tiempo. Si el discurso no se entiende, si la música retumba o si una bocina
              satura, lo nota cada persona en el lugar — y arruina momentos que no se repiten.
              Elegir bien no es solo potencia: es cobertura pareja, graves controlados y una
              mezcla afinada al espacio.
            </p>
            <p>
              Line array cuando el evento es grande o al aire libre. Bocinas para salón y
              presentaciones. Subwoofers cuando los graves son protagonistas. Mezcladoras,
              amplificación y monitores de escenario cuando hay artistas o panelistas en
              escena. Accesorios y cableado que sostienen todo el montaje. Y si prefieres no
              elegir pieza por pieza, un <a href="/servicios/audiovisual/sonido/paquetes/">paquete
              cerrado por tipo de evento</a>. Una sola empresa para todo el audio.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada sistema, a fondo</p>
            <h2 id="detalle-heading">Los 4 sistemas base de sonido — en detalle</h2>
            <p class="hm__head-sub">Marca, cobertura, potencia y para qué tipo de evento funciona mejor cada sistema.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada sistema de audio hay decisiones técnicas que afectan la
              experiencia del evento: el tipo de caja que determina el alcance y la cobertura,
              la cantidad de subwoofers que define la presencia de graves, y la consola que
              decide cuántas fuentes se pueden mezclar con precisión en vivo.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por
              potencia. A continuación, lo que realmente importa de los cuatro sistemas base;
