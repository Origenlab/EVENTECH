---
/**
 * ─── Sonido Profesional para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Sonido Profesional para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const SONIDO = [
  {
    name: "Sistemas Line Array",
    excerpt: "Audio profesional JBL y d&b audiotechnik con cobertura uniforme para audiencias de 200 a 5,000+ personas. El estándar de la industria para eventos de gran formato.",
    cta: "Line Array",
    href: "#linearray-heading",
    icon: "speaker",
  },
  {
    name: "Bocinas Amplificadas",
    excerpt: "Bocinas activas de 12 y 15 pulgadas con subwoofer integrado. Solución compacta y potente para eventos en salón de hasta 200 personas.",
    cta: "Bocinas",
    href: "#bocinas-heading",
    icon: "music",
  },
  {
    name: "Subwoofers y Graves",
    excerpt: "Subwoofers de 18 y 21 pulgadas que aportan profundidad y potencia al audio. Esenciales para fiestas, conciertos y eventos con DJ.",
    cta: "Subwoofers",
    href: "#subwoofers-heading",
    icon: "layers",
  },
  {
    name: "Mezcladoras y Monitoreo",
    excerpt: "Consolas digitales Yamaha y Allen & Heath de 16 a 32 canales. Monitores de escenario, procesadores y sistema de intercom profesional.",
    cta: "Mezcladoras",
    href: "#mezcladoras-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué sistema de sonido necesito según el tamaño de mi evento?", answer: "La elección del sistema depende directamente del número de asistentes y el tipo de espacio. Para eventos íntimos de hasta 80 personas recomendamos bocinas amplificadas de 12 pulgadas. Para eventos medianos de 80 a 200 personas, bocinas de 15 pulgadas con subwoofer complementario. Para eventos de 200 a 500 personas, un sistema line array compacto con procesador digital. Para eventos de más de 500 personas, un sistema line array completo con múltiples cajas y subwoofers. Nuestro ingeniero de audio evalúa tu venue y te recomienda la configuración exacta." },
  { question: "¿Qué diferencia hay entre line array y bocinas amplificadas?", answer: "El line array es un sistema de cajas acústicas apiladas verticalmente que distribuye el sonido de manera uniforme a grandes distancias, ideal para eventos al aire libre y recintos de gran tamaño con audiencias de 200 a 5,000+ personas. Las bocinas amplificadas son sistemas punto-fuente compactos con amplificador integrado, perfectos para salones y espacios cerrados de hasta 200 personas. El line array ofrece mayor alcance y cobertura pareja, mientras que las bocinas son más prácticas, económicas y rápidas de instalar." },
  { question: "¿El sistema de sonido incluye ingeniero de audio?", answer: "Sí. Todos nuestros paquetes de sonido profesional incluyen prueba de sonido (sound check) previa al evento, ecualización del sistema según la acústica del venue, y un ingeniero de audio dedicado durante todo el evento. El ingeniero monitorea los niveles en tiempo real, ajusta la mezcla según las necesidades del programa (discursos, música en vivo, DJ) y resuelve cualquier situación técnica al instante. El servicio técnico completo está incluido en el precio de la renta." },
  { question: "¿Pueden instalar sonido bajo una carpa?", answer: "Sí, tenemos amplia experiencia instalando sistemas de sonido bajo carpas de todo tipo. Utilizamos rigging certificado que se ancla directamente en los puntos estructurales de la carpa. Recomendamos las carpas estructurales de aluminio ya que ofrecen los mejores puntos de anclaje para colgar line array y distribuir bocinas de manera óptima. El ingeniero de audio evalúa la acústica particular del espacio techado para ecualizar correctamente y evitar reverberaciones indeseadas." },
  { question: "¿Cuántos subwoofers necesito para mi evento?", answer: "La regla general es 1 subwoofer por cada 100 personas en espacios cerrados y 1 por cada 50 personas en espacios al aire libre. Para eventos con DJ o música electrónica, recomendamos aumentar la proporción ya que estos géneros requieren mayor presencia de graves. Por ejemplo, una boda en salón con 150 invitados necesita 2 subwoofers de 18 pulgadas. Un festival outdoor con 300 personas requiere 6 subwoofers mínimo. Nuestro ingeniero de audio calcula la configuración exacta según tu evento." },
  { question: "¿Con cuánta anticipación debo reservar el equipo de sonido?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para eventos estándar. Para eventos grandes con sistemas line array o configuraciones especiales, lo ideal es apartar con 1 a 2 meses, especialmente en temporada alta (noviembre a febrero y mayo a junio). Los sistemas line array JBL y los paquetes completos son los más solicitados y se agotan primero. También atendemos solicitudes de último momento sujetas a disponibilidad de equipo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Sonido Profesional para Eventos en CDMX",
    description: "Renta de line array, bocinas amplificadas, subwoofers y mezcladoras digitales para eventos en CDMX. Ingeniero de audio incluido.",
    url: "/servicios/audiovisual/sonido/",
    priceRange: { min: 800, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Sonido Profesional para Eventos en CDMX"
  description="Renta de line array JBL, bocinas amplificadas, subwoofers y mezcladoras digitales para eventos en CDMX. Ingeniero de audio incluido. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Audio de grado profesional"
    title='Renta de <span class="highlight">Sonido Profesional</span> para Eventos en CDMX'
    subtitle="Sistemas line array JBL y d&b audiotechnik, bocinas amplificadas, subwoofers de alto rendimiento y mezcladoras digitales de 16 a 32 canales. Ingeniero de audio incluido en cada renta."
    primaryCTA={{ label: "Cotiza tu sonido", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sonido profesional para mi evento` }}
    cards={[
      {
        title: "Equipos de audio de grado profesional para cada evento",
        content: "<strong>Renta de sonido profesional para eventos</strong> con las marcas líderes de la industria en CDMX. Sistemas line array JBL VTX y d&b audiotechnik Y-Series con cobertura uniforme para audiencias de 200 a 5,000+ personas. Bocinas amplificadas activas de 12 y 15 pulgadas para salones y espacios cerrados. Subwoofers de 18 y 21 pulgadas con configuración cardioide para graves controlados y potentes — cada sistema calibrado y verificado antes de cada entrega para garantizar calidad de audio impecable.",
      },
      {
        title: "Servicio técnico integral con ingeniero de audio dedicado",
        content: "<strong>Ingeniero de audio profesional incluido</strong> en cada renta de equipo de sonido. Nuestro equipo técnico se encarga del transporte, instalación, cableado profesional, sound check completo con ecualización del sistema según la acústica de tu venue, y monitoreo en tiempo real durante todo el evento. Consolas digitales Yamaha TF/CL y Allen & Heath con gestión de múltiples fuentes, monitores de escenario y sistema de intercom para coordinación del staff técnico.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas sonido perfecto para tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con el sistema de audio ideal para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de sonido
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Sonido Profesional"
        subtitle="La solución de audio perfecta para cada tipo de evento"
        description={[
          "Desde bocinas compactas para presentaciones corporativas hasta sistemas line array para conciertos y festivales. Contamos con el inventario de equipo de sonido profesional más completo de la Ciudad de México.",
          "Cada sistema incluye cableado profesional, procesador digital, prueba de sonido e ingeniero de audio dedicado. Potencia, claridad y cobertura certificadas para garantizar una experiencia sonora impecable."
        ]}
      />

      <div class="grid grid--4">
        {SONIDO.map((item) => (
          <Card
            name={item.name}
            excerpt={item.excerpt}
            cta={item.cta}
            href={item.href}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SISTEMAS LINE ARRAY — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="linearray-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">El estándar profesional</span>
          <h2 class="showcase__title" id="linearray-heading">Sistemas Line Array</h2>
          <p class="showcase__subtitle">Audio de alta fidelidad con cobertura uniforme para audiencias de 200 a 5,000+ personas.</p>
          <p class="showcase__text">Nuestros <strong>sistemas line array</strong> representan lo más avanzado en audio profesional para eventos de gran formato. Trabajamos con las marcas líderes de la industria: <strong>JBL VTX Series y d&b audiotechnik Y-Series</strong>, ofreciendo cobertura sonora uniforme desde la primera fila hasta el último rincón del venue. Configuraciones desde <strong>4 cajas por lado para 200 personas hasta 12+ cajas por lado para audiencias de 5,000+ personas</strong>, con subwoofers dedicados que complementan el rango de graves.</p>
          <p class="showcase__text">Incluye <strong>procesador de señal digital, amplificación dedicada y rigging certificado</strong> para montaje volado (flown) o apilado en piso (ground-stacked) según las características de tu venue. Ideal para <strong>conciertos, festivales, convenciones, ceremonias y eventos masivos al aire libre</strong>. El montaje requiere entre 3 y 6 horas según la dimensión del sistema. Complementa con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para crear escenarios techados con anclaje perfecto para rigging de audio.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">JBL VTX</span>
            <span class="showcase__tag">d&b Y-Series</span>
            <span class="showcase__tag">200-5,000+ personas</span>
            <span class="showcase__tag">Flown / Ground-stack</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Line Array
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="2" width="16" height="4" rx="1"/>
              <rect x="4" y="7" width="16" height="4" rx="1"/>
              <rect x="4" y="12" width="16" height="4" rx="1"/>
              <line x1="12" y1="16" x2="12" y2="20"/>
              <line x1="8" y1="20" x2="16" y2="20"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BOCINAS AMPLIFICADAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="bocinas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Solución compacta</span>
          <h2 class="showcase__title" id="bocinas-heading">Bocinas Amplificadas</h2>
          <p class="showcase__subtitle">Audio potente y claro en un formato compacto para eventos en salón de hasta 200 personas.</p>
          <p class="showcase__text">Nuestras <strong>bocinas amplificadas activas</strong> son la solución ideal para eventos en espacios cerrados que requieren audio de calidad profesional sin la complejidad de un sistema line array. Disponibles en <strong>12 pulgadas (para hasta 80 personas) y 15 pulgadas (para hasta 200 personas)</strong> con amplificación clase D integrada de alta eficiencia. Cada bocina ofrece respuesta en frecuencia extendida, dispersión controlada y SPL suficiente para llenar salones completos con claridad cristalina.</p>
          <p class="showcase__text">Incluyen <strong>procesador DSP interno, ecualización paramétrica y protección contra sobrecarga</strong>. Montaje en trípode profesional con ajuste de altura e inclinación para apuntar directamente a la audiencia. Perfectas para <strong>bodas en salón, cenas de gala, conferencias, presentaciones corporativas y fiestas privadas</strong>. Se complementan con subwoofer compañero para mayor profundidad de graves. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario ejecutivo</a> para eventos corporativos de alto nivel.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Activas 12"</span>
            <span class="showcase__tag">Activas 15"</span>
            <span class="showcase__tag">80-200 personas</span>
            <span class="showcase__tag">Trípode profesional</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Bocinas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="2" width="12" height="18" rx="2"/>
              <circle cx="12" cy="14" r="3"/>
              <circle cx="12" cy="7" r="1.5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SUBWOOFERS Y GRAVES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="subwoofers-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Potencia que se siente</span>
          <h2 class="showcase__title" id="subwoofers-heading">Subwoofers y Graves</h2>
          <p class="showcase__subtitle">Profundidad y potencia en frecuencias bajas que transforman la experiencia de audio en tu evento.</p>
          <p class="showcase__text">Nuestros <strong>subwoofers profesionales</strong> están disponibles en dos formatos de alto rendimiento: <strong>18 pulgadas para eventos en salón y 21 pulgadas para exteriores y grandes producciones</strong>. Con respuesta en frecuencia desde 28 Hz, entregan graves profundos, definidos y controlados que se sienten en todo el cuerpo. Disponibles en <strong>configuración cardioide</strong> que concentra la energía hacia la audiencia y reduce el sonido detrás del escenario, ideal para venues con restricciones de ruido.</p>
          <p class="showcase__text">Los subwoofers son el complemento <strong>esencial para eventos con DJ, música electrónica, fiestas, conciertos y cualquier producción donde los graves sean protagonistas</strong>. Se integran perfectamente con nuestros sistemas line array y bocinas amplificadas mediante procesador de crossover digital. Cada subwoofer incluye amplificación de alta potencia y protección térmica. Combínalos con nuestras <a href="/servicios/pistas-baile/">pistas de baile</a> para crear la experiencia completa de fiesta.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Sub 18"</span>
            <span class="showcase__tag">Sub 21"</span>
            <span class="showcase__tag">Cardioide</span>
            <span class="showcase__tag">Desde 28 Hz</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Subwoofers
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="4" y="4" width="16" height="16" rx="2"/>
              <circle cx="12" cy="12" r="5"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MEZCLADORAS Y MONITOREO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="mezcladoras-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Control total</span>
          <h2 class="showcase__title" id="mezcladoras-heading">Mezcladoras y Monitoreo</h2>
          <p class="showcase__subtitle">Consolas digitales de última generación con monitoreo de escenario y comunicación profesional.</p>
          <p class="showcase__text">Nuestras <strong>consolas digitales profesionales</strong> ofrecen control total sobre cada fuente de audio de tu evento. Trabajamos con <strong>Yamaha TF y CL Series</strong> y <strong>Allen & Heath dLive y SQ</strong>, disponibles en configuraciones de <strong>16 a 32 canales</strong> con procesamiento interno de efectos, ecualización paramétrica por canal, compresión dinámica y gestión de grupos. Interfaz táctil intuitiva que permite ajustes rápidos y precisos durante el evento en tiempo real.</p>
          <p class="showcase__text">Incluyen <strong>monitores de escenario activos de 12 y 15 pulgadas</strong> para artistas, presentadores y ponentes, con mezclas independientes para cada monitor. <strong>Sistema de intercom profesional</strong> con comunicación bidireccional entre ingeniero de audio, director de escena y coordinador de producción. Stage box digital con cableado Cat6 que elimina runs de cables analógicos largos. Ideal para <strong>conciertos, conferencias con panelistas, eventos híbridos y producciones con múltiples fuentes de audio</strong>. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación de escenario</a> para producciones de nivel profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Yamaha TF/CL</span>
            <span class="showcase__tag">Allen & Heath</span>
            <span class="showcase__tag">16-32 canales</span>
            <span class="showcase__tag">Intercom profesional</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Mezcladoras
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="6" width="20" height="14" rx="2"/>
              <line x1="6" y1="10" x2="6" y2="16"/>
              <line x1="10" y1="9" x2="10" y2="16"/>
              <line x1="14" y1="11" x2="14" y2="16"/>
              <line x1="18" y1="8" x2="18" y2="16"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Sonido Profesional"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu equipo de sonido, es natural tener preguntas sobre sistemas, potencia, configuración y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre sonido profesional al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de sonido profesional para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Sonido Profesional"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores técnicos te responderá por WhatsApp con una cotización personalizada de sonido profesional. Sin compromiso, sin costos ocultos.",
