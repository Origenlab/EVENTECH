---
/**
 * ─── Amplificadores de Potencia — Página de Producto (L5) ───
 * Etapa de amplificación para sistemas de sonido profesional:
 * Clase D, amplificadores con DSP, racks para line array y
 * amplificación para sistemas pasivos.
 *
 * Jerarquía: Servicios > Audiovisual > Sonido > Amplificadores de Potencia
 * Template: sillas/tiffany (l3-shared + l4-shared, dorado institucional).
 * IMG: reusadas de /images/audiovisual — no hay fotos de amplificadores;
 * alt honesto (equipo de audio / racks / bocinas), nunca afirma mostrar un amplificador.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProveedorSonido from "@components/ProveedorSonido.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Sonido", href: "/servicios/audiovisual/sonido/" },
  { label: "Amplificadores de Potencia" },
];

const faqs = [
  { question: "¿Qué potencia de amplificador necesito para mis bocinas?", answer: 'La regla de la industria es dar al amplificador <strong>entre 1.5 y 2 veces la potencia continua (RMS) de la bocina</strong>, calculado a la impedancia real de la carga. Ese margen —el <strong>headroom</strong>— permite reproducir los picos de la música sin recortar la señal. Contra lo que parece intuitivo, <strong>lo que quema las bocinas no es el exceso de potencia limpia, sino un amplificador chico llevado al clip</strong>: la señal recortada satura y funde el driver de agudos. En la visita técnica calculamos potencia e impedancia a partir de tus <a href="/servicios/audiovisual/sonido/bocinas/">bocinas amplificadas</a> y del tamaño real del venue.' },
  { question: "¿Clase D o Clase AB, cuál conviene para un evento?", answer: 'Para eventos, <strong>Clase D es hoy el estándar</strong>. Su eficiencia supera el <strong>90%</strong> frente al 50–60% de un Clase AB típico, lo que significa menos calor disipado, menos peso y más potencia por unidad de rack — decisivo en montajes móviles y cuando el audio comparte una sola planta de luz con el resto de la producción. El Clase AB todavía se aprecia en algunas instalaciones fijas por su comportamiento térmico predecible, pero para gira y eventos —incluido cualquier <a href="/servicios/audiovisual/sonido/line-array/">line array</a> moderno— la Clase D conmutada es lo que se usa.' },
  { question: "¿Un amplificador puede quemar mis bocinas?", answer: 'Sí, por dos caminos opuestos: un amplificador <strong>subdimensionado</strong> que se lleva al clip genera una señal recortada que fríe los agudos, y uno <strong>sobredimensionado sin limitador</strong> puede exceder el recorrido mecánico del cono. La protección real es el <strong>limitador del DSP</strong>, que topa la señal en el umbral seguro de cada driver. En cada rack cargamos limitadores por caja acústica y coordinamos las ganancias con la <a href="/servicios/audiovisual/sonido/mezcladoras/">mezcladora</a> y los <a href="/servicios/audiovisual/sonido/subwoofers/">subwoofers</a>, de modo que el sistema trabaje fuerte sin acercarse a su límite.' },
  { question: "¿Cuál es la diferencia entre un sistema activo y uno pasivo?", answer: 'Una bocina <strong>activa</strong> lleva el amplificador integrado: llega corriente y señal, y suena. Una bocina <strong>pasiva</strong> necesita un amplificador externo y cable de potencia. La activa es más cómoda para montajes rápidos, pero la pasiva sigue ganando en <strong>instalaciones fijas, tiradas de cable largas y control centralizado</strong>, donde conviene tener toda la amplificación en un rack y no un amplificador dentro de cada caja. Si no sabes qué sistema tienes, en la visita técnica lo identificamos y cotizamos solo la amplificación que te falta, o el equipo completo desde <a href="/servicios/audiovisual/sonido/bocinas/">bocinas</a>.' },
  { question: "¿Necesito un rack de amplificación especial para line array?", answer: 'Sí. Un <a href="/servicios/audiovisual/sonido/line-array/">line array</a> no funciona con cualquier amplificador: cada caja tiene un <strong>preset de fábrica</strong> —crossover, EQ y limitadores calculados por el fabricante— que debe cargarse en el canal correspondiente, con la impedancia y la potencia exactas. Por eso entregamos <strong>racks preconfigurados</strong> con esos presets ya cargados, cableado <strong>Speakon NL4</strong> etiquetado y distribución eléctrica dimensionada. Llegas, conectas y el arreglo suena parejo desde el primer sound check, sin emparejar canales a mano.' },
  { question: "¿Qué incluye la renta del amplificador?", answer: 'Incluye el <strong>rack de amplificación, los presets cargados por caja, el cableado Speakon, la distribución eléctrica y un ingeniero que verifica el emparejamiento amplificador-bocina y las ganancias en sitio</strong>. No entregamos etapas sueltas para que las conectes tú. Puedes sumar <a href="/servicios/audiovisual/sonido/accesorios-audio/">cableado y accesorios</a> adicionales, o resolver todo el audio en un <a href="/servicios/audiovisual/sonido/paquetes/">paquete de sonido</a> que ya trae bocinas, consola, microfonía y amplificación bajo un solo montaje e ingeniero.' },
];

const specs = [
  { label: "Topología", value: "Clase D conmutada y Clase AB" },
  { label: "Eficiencia Clase D", value: ">90% · menos calor y peso" },
  { label: "Potencia", value: "RMS continua y pico por canal" },
  { label: "Impedancia", value: "2Ω · 4Ω · 8Ω y modo puente" },
  { label: "Procesamiento", value: "DSP: crossover, EQ y limitadores" },
  { label: "Factor de amortiguamiento", value: "Alto · control de graves" },
  { label: "Conectores", value: "Speakon NL4 / NL8 · entrada XLR" },
  { label: "Formato", value: "Racks preconfigurados 2U–6U" },
  { label: "Marcas", value: "Crown · QSC · Lab.gruppen · Powersoft" },
  { label: "Cobertura", value: "CDMX y zona metropolitana" },
];

const sidebarNav = [
  { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
  { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
  { name: "Subwoofers y Graves", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras y Monitoreo", href: "/servicios/audiovisual/sonido/mezcladoras/" },
  { name: "Amplificadores de Potencia", href: null, active: true },
  { name: "Monitores de Escenario", href: "/servicios/audiovisual/sonido/monitores-escenario/" },
  { name: "Paquetes de Sonido", href: "/servicios/audiovisual/sonido/paquetes/" },
  { name: "Accesorios y Cableado", href: "/servicios/audiovisual/sonido/accesorios-audio/" },
];

const sidebarRelated = [
  { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
  { name: "Subwoofers y Graves", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras y Monitoreo", href: "/servicios/audiovisual/sonido/mezcladoras/" },
  { name: "Accesorios y Cableado", href: "/servicios/audiovisual/sonido/accesorios-audio/" },
  { name: "Iluminación de Escenario", href: "/servicios/iluminacion/escenario/" },
];

const reviews = [
  { author: "Alejandro Villaseñor", text: "Soy productor de espectáculos y rento equipo por temporada. Pedí dos racks de amplificación para un line array en un foro de Coyoacán y llegaron preconfigurados con los presets de fábrica de cada caja. Conectamos Speakon y arrancamos: sin adivinar potencias ni cruzar canales. El sistema aguantó tres horas a nivel alto y el limitador no entró una sola vez.", rating: 5, date: "2026-02-21" },
  { author: "Gabriela Montes de Oca", text: "Coordino eventos corporativos y monté un congreso de dos días en un hotel de Santa Fe. Nos armaron la amplificación con DSP y dejaron cargados los limitadores por zona; aunque los ponentes forzaban el micrófono, nunca saturó ni se dañó una bocina. Entregaron el rack etiquetado y con diagrama de conexión, se nota el trabajo de ingeniería.", rating: 5, date: "2025-10-18" },
  { author: "Rodrigo Cázares", text: "Tenemos una instalación fija de bocinas pasivas en un salón de Polanco y necesitábamos un amplificador con el factor de amortiguamiento correcto para no perder graves en las tiradas largas de cable. Nos asesoraron con el matching exacto amplificador-caja y trajeron el calibre de cable adecuado. El bajo quedó firme y controlado toda la noche.", rating: 5, date: "2026-05-03" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Amplificadores de Potencia CDMX",
    description: "Renta de amplificadores de potencia para eventos en CDMX: Clase D, racks con DSP y presets para line array, con matching amplificador-caja verificado. Marcas Crown, QSC, Lab.gruppen y Powersoft con montaje, configuración e ingeniero de audio.",
    url: "/servicios/audiovisual/sonido/amplificadores/",
    priceRange: { min: 1200, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 96,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
    { name: "Amplificadores de Potencia", url: "/servicios/audiovisual/sonido/amplificadores/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Amplificadores de Potencia en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/audio-evento-04.avif"
  description="Renta de amplificadores de potencia en CDMX: Clase D, racks con DSP y presets para line array. Marcas Crown, QSC, Lab.gruppen y Powersoft. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Amplificación de potencia para audio profesional"
    title='<span class="highlight">Amplificadores de Potencia</span> para Eventos en CDMX'
    subtitle="Clase D, racks con DSP y presets para line array. La etapa que convierte la señal de tu consola en la potencia real que mueve las bocinas — dimensionada, limitada y protegida para tu evento."
    primaryCTA={{ label: "Cotiza tu amplificación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar amplificadores de potencia para mi evento` }}
    cards={[
      {
        title: "El amplificador es el músculo del sistema, no un accesorio",
        content: "<strong>El amplificador de potencia es la etapa que convierte la señal de línea de tu consola en la energía real que mueve los conos de las bocinas.</strong> Junto con las cajas acústicas, es lo que define cuánto sonido tienes disponible y con cuánto control. La mayoría de los problemas de audio en eventos —sonido débil, graves flojos o bocinas quemadas— no vienen de la bocina ni del micrófono, sino de un amplificador subdimensionado, mal emparejado o sin limitador. Elegir la potencia, la impedancia y el headroom correctos es lo que separa un sistema que suena fuerte de uno que suena fuerte y limpio toda la noche.",
      },
      {
        title: "Renta con configuración, matching y protección incluidos",
        content: "<strong>Entregamos racks de amplificación preconfigurados, no etapas sueltas.</strong> Cada rack llega con los presets cargados por caja acústica, crossover y limitadores ajustados, cableado Speakon, distribución eléctrica y un ingeniero que verifica el emparejamiento amplificador-bocina en sitio. Trabajamos con marcas estándar de la industria —Crown, QSC, Lab.gruppen y Powersoft— y dimensionamos la potencia según tus bocinas y el tamaño del venue. Montaje, configuración y desmontaje incluidos dentro de CDMX; si prefieres resolver todo en un solo servicio, lo integramos en un paquete de sonido completo con un solo ingeniero responsable.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿No sabes qué amplificador necesita tu sistema de sonido?"
    subheadline="Dinos qué bocinas vas a mover y el tamaño del evento — te confirmamos potencia, impedancia y configuración exacta"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sonido Profesional</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Qué amplificación necesita tu sistema?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar amplificadores de potencia para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Ficha Técnica — Amplificadores de Potencia</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Amplificadores Clase D -->
          <section class="section" aria-labelledby="amp-claseD-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">La norma actual · eficiencia superior al 90%</span>
                <h2 class="showcase__title" id="amp-claseD-heading">Amplificadores Clase D</h2>
                <p class="showcase__subtitle">Más potencia en menos peso y menos calor: por qué la Clase D desplazó a la Clase AB en el audio de eventos.</p>
                <p class="showcase__text">Un amplificador <strong>Clase D</strong> no es de menor calidad que un Clase AB — la letra solo indica la topología. En vez de disipar como calor cerca de la mitad de la energía que consume, la etapa conmutada trabaja con una <strong>eficiencia superior al 90%</strong>. Eso cambia todo lo práctico: un equipo que antes pesaba veinte kilos y necesitaba disipadores enormes y ventilación forzada hoy entrega la misma potencia —o más— en un chasis ligero de dos unidades de rack. Series como <strong>Crown DCi, QSC CXD y Powersoft Ottocanali</strong> son ejemplos de este estándar.</p>
                <p class="showcase__text">Para un evento eso se traduce en <strong>montajes más rápidos, racks que una sola persona puede maniobrar y mucho menos calor</strong> en backstage o en cuartos de equipo cerrados. Consume menos corriente, lo que importa cuando el sistema comparte una planta de luz con iluminación y video. La Clase D es la base de casi todo nuestro inventario móvil y de los <a href="/servicios/audiovisual/sonido/paquetes/">paquetes de sonido</a>; alimenta desde <a href="/servicios/audiovisual/sonido/bocinas/">bocinas amplificadas</a> puntuales hasta arreglos completos de gran formato.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Eficiencia &gt;90%</span>
                  <span class="showcase__tag">Ligeros y compactos</span>
                  <span class="showcase__tag">Menos calor</span>
                  <span class="showcase__tag">Montaje rápido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar amplificación Clase D
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/audio-evento-04.avif" alt="Rack de audio profesional durante el montaje de un evento en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-02.avif" alt="Equipo de audio conectado y cableado antes de un evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-05.avif" alt="Sistema de sonido profesional montado para un evento" loading="lazy" decoding="async" /></div>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Amplificadores con DSP Integrado -->
          <section class="section" aria-labelledby="amp-dsp-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Procesamiento a bordo · protección del driver</span>
                <h2 class="showcase__title" id="amp-dsp-heading">Amplificadores con DSP Integrado</h2>
                <p class="showcase__subtitle">Crossover, ecualización y limitadores en el mismo equipo — el limitador es, literalmente, lo que evita que quemes tus bocinas.</p>
                <p class="showcase__text">Los amplificadores modernos integran un <strong>procesador digital (DSP)</strong> antes de la etapa de potencia. En un solo equipo resuelven el <strong>crossover activo</strong> —repartir cada rango de frecuencia a la bocina que le corresponde, graves al subwoofer y medios-agudos a la caja principal—, la ecualización, los retardos (delay) para alinear el sistema y los <strong>presets guardados por modelo de caja acústica</strong>. En vez de una maraña de procesadores externos, toda la cadena de proceso queda dentro del amplificador y se recupera con un preset.</p>
                <p class="showcase__text">La función crítica es el <strong>limitador</strong>. Cada driver tiene un límite mecánico y térmico; el limitador topa la señal justo antes de ese punto, de forma que el sistema puede trabajar al máximo aprovechable sin llegar a dañarse. <strong>Un limitador bien ajustado es la diferencia entre exigirle todo a una bocina y quemarla.</strong> Nosotros cargamos los presets y limitadores por caja, y coordinamos el corte con la <a href="/servicios/audiovisual/sonido/mezcladoras/">mezcladora</a> y los <a href="/servicios/audiovisual/sonido/subwoofers/">subwoofers</a> para que graves y agudos trabajen en fase y sin saturar.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Crossover activo</span>
                  <span class="showcase__tag">Limitadores</span>
                  <span class="showcase__tag">Presets por caja</span>
                  <span class="showcase__tag">Protección del driver</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar amplificación con DSP
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/audio-evento-03.avif" alt="Equipo de procesamiento y audio profesional en un evento en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif" alt="Bocina profesional conectada al sistema de audio del evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-06.avif" alt="Cableado de audio profesional durante el montaje de un evento" loading="lazy" decoding="async" /></div>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Racks de Amplificación para Line Array -->
          <section class="section" aria-labelledby="amp-linearray-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Preconfigurado · matching amplificador-caja</span>
                <h2 class="showcase__title" id="amp-linearray-heading">Racks de Amplificación para Line Array</h2>
                <p class="showcase__subtitle">Racks que llegan listos: presets de fábrica por caja, cableado Speakon y distribución eléctrica dimensionada.</p>
                <p class="showcase__text">Un <a href="/servicios/audiovisual/sonido/line-array/">line array</a> es un sistema afinado como conjunto, y su amplificación no admite improvisación. Cada modelo de caja tiene un <strong>preset de fábrica</strong> —crossover, EQ, limitadores y protección— calculado por el fabricante para una <strong>impedancia y una potencia exactas</strong>. Marcas como <strong>Lab.gruppen y Powersoft</strong> publican esos presets precisamente para que el amplificador y la caja trabajen como una sola unidad. Cargar el preset equivocado, o forzar una impedancia distinta, degrada el sonido y arriesga el equipo.</p>
                <p class="showcase__text">Por eso no rentamos amplificadores sueltos para arreglos: entregamos <strong>racks preconfigurados</strong> con los presets cargados, el <strong>matching amplificador-caja verificado</strong>, cableado <strong>Speakon NL4</strong> etiquetado y la distribución eléctrica dimensionada para el consumo real del sistema. El técnico llega, conecta y el arreglo suena parejo de la primera a la última fila desde el sound check. Súmalo con <a href="/servicios/audiovisual/sonido/subwoofers/">subwoofers</a> cardioides y el <a href="/servicios/audiovisual/sonido/accesorios-audio/">cableado y los accesorios</a> que el montaje requiera.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Racks preconfigurados</span>
                  <span class="showcase__tag">Speakon NL4</span>
                  <span class="showcase__tag">Distribución eléctrica</span>
                  <span class="showcase__tag">Matching por caja</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar rack para line array
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/audio-evento-01.avif" alt="Sistema de sonido de gran formato montado para un evento en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-04.avif" alt="Rack de equipo de audio conectado durante el montaje" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/equipo-audiovisual-completo-boda.avif" alt="Equipo audiovisual completo montado antes de un evento" loading="lazy" decoding="async" /></div>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Amplificación para Sistemas Pasivos -->
          <section class="section" aria-labelledby="amp-pasivos-heading">
            <ServiceShowcase
              title="Amplificación para Sistemas Pasivos"
              headingId="amp-pasivos-heading"
              badge="Cuándo el pasivo sigue ganando"
              subtitle="Las bocinas activas son cómodas, pero el sistema pasivo con amplificación externa sigue siendo superior en instalaciones fijas, tiradas largas y control centralizado."
              tags={["Instalación fija", "Tiradas largas", "Control centralizado", "Factor de amortiguamiento"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar amplificación pasiva"
            >
              <Fragment slot="body">
                <p class="showcase__text">La bocina <strong>activa</strong> —con amplificador integrado— ganó terreno por comodidad: una toma de corriente por caja y listo. Pero para muchos montajes el <strong>sistema pasivo con amplificación externa sigue siendo la mejor decisión</strong>. En una <strong>instalación fija</strong> conviene tener toda la potencia concentrada en un rack accesible: si algo falla, se atiende un solo equipo sin bajar las cajas colgadas. Y con <strong>tiradas de cable largas</strong> es más eficiente llevar señal de línea o red hasta un amplificador cercano a las bocinas y dejar solo tramos cortos de cable de potencia.</p>
                <p class="showcase__text">El pasivo también manda cuando se busca <strong>control centralizado</strong> —un solo rack alimentando varias zonas de un salón— o cuando el <strong>factor de amortiguamiento</strong> importa: un amplificador con alto factor de amortiguamiento controla mejor el movimiento del cono y da graves más firmes, siempre que el calibre del cable sea el adecuado para la distancia. Te ayudamos a decidir entre activo y pasivo según tu caso, y cotizamos solo la amplificación que necesitas o el sistema completo desde <a href="/servicios/audiovisual/sonido/bocinas/">bocinas</a> y <a href="/servicios/audiovisual/sonido/paquetes/">paquetes de sonido</a>.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif" alt="Bocina profesional en un evento corporativo en CDMX" loading="lazy" decoding="async" /></div>
