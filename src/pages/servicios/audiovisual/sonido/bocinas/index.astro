---
/**
 * ─── Bocinas Amplificadas — Pagina de Producto (Nivel 4) ───
 * Bocinas activas de 12 y 15 pulgadas con subwoofer para eventos
 * de hasta 200 personas en CDMX.
 *
 * Jerarquia: Servicios > Audiovisual > Sonido > Bocinas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Sonido", href: "/servicios/audiovisual/sonido/" },
  { label: "Bocinas Amplificadas" },
];

const faqs = [
  { question: "¿Qué tamaño de bocina necesito para mi evento?", answer: 'El tamaño ideal depende del número de asistentes y el tipo de espacio. Para <strong>fiestas íntimas y reuniones de 20-50 personas</strong>, un par de bocinas de 12 pulgadas es suficiente. Para <strong>bodas en salón y corporativos de 50-120 personas</strong>, recomendamos bocinas de 15 pulgadas. Para <strong>eventos de 120-200 personas</strong>, un par de bocinas de 15 pulgadas con subwoofer complementario ofrece la potencia necesaria. Si tu evento supera 200 asistentes, te sugerimos un <a href="/servicios/audiovisual/sonido/line-array/">sistema line array</a>.' },
  { question: "¿Las bocinas incluyen subwoofer?", answer: "Nuestras bocinas amplificadas se rentan individualmente o en paquetes que incluyen subwoofer complementario. El <strong>Kit Boda</strong> incluye 2 bocinas de 15 pulgadas + 1 subwoofer de 18 pulgadas + micrófono inalámbrico. El <strong>Kit Corporativo</strong> incluye 4 bocinas distribuidas + mixer. También puedes agregar subwoofers de 15 o 18 pulgadas como complemento individual a cualquier configuración. Nuestro asesor te recomienda la combinación ideal según el tamaño y tipo de tu evento." },
  { question: "¿Puedo conectar mi celular o laptop a las bocinas?", answer: "Sí, nuestras bocinas amplificadas aceptan múltiples fuentes de audio. Cada bocina cuenta con entradas <strong>XLR profesional, TRS de 1/4 pulgada y conectividad Bluetooth</strong> para streaming directo desde celulares y tablets. Para laptops recomendamos la conexión por cable XLR o TRS para mayor estabilidad. El técnico incluido configura todas las conexiones y verifica la calidad de audio antes del evento. También puedes conectar un mixer externo para gestionar múltiples fuentes simultáneamente." },
  { question: "¿Las bocinas sirven para música en vivo?", answer: "Sí, nuestras bocinas amplificadas son ideales para <strong>música en vivo acústica, tríos, solistas, cuartetos y DJ en espacios de hasta 200 personas</strong>. La respuesta en frecuencia extendida y la amplificación clase D de alta eficiencia entregan un sonido limpio y potente. Para bandas con batería o eventos donde se requiera más presencia de graves, recomendamos agregar un subwoofer complementario. Para agrupaciones grandes o eventos al aire libre, te sugerimos considerar nuestro <a href=\"/servicios/audiovisual/sonido/line-array/\">sistema line array compacto</a>." },
  { question: "¿Incluye técnico de audio durante el evento?", answer: "Sí, <strong>cada renta de bocinas incluye un operador de audio</strong> que permanece durante todo el evento. El operador se encarga del transporte, instalación en trípode profesional, conexión de fuentes de audio, ecualización según la acústica del salón y monitoreo de niveles durante el programa. Si necesitas cambiar de fuente de audio, ajustar el volumen o conectar un micrófono, el operador lo resuelve al instante. Desmontaje y recolección incluidos sin costo adicional." },
  { question: "¿Con cuánta anticipación debo reservar las bocinas?", answer: "Recomendamos reservar con <strong>1 a 2 semanas de anticipación</strong> para garantizar disponibilidad. Los <strong>Kit Boda y Kit Corporativo</strong> son los más solicitados y se agotan primero, especialmente en temporada alta (noviembre a febrero y mayo a junio). Para fines de semana en temporada alta, lo ideal es apartar con 3 semanas de anticipación. También atendemos solicitudes de último momento sujetas a disponibilidad de equipo." },
];

const specs = [
  { label: "Tipos disponibles", value: "12\" y 15\" activas" },
  { label: "Potencia", value: "1,000W – 2,000W RMS" },
  { label: "Cobertura", value: "Hasta 200 personas" },
  { label: "Subwoofer", value: "Complementario 15\" o 18\"" },
  { label: "Amplificación", value: "Integrada clase D" },
  { label: "Conexiones", value: "XLR / TRS / Bluetooth" },
  { label: "Pedestal", value: "Trípode profesional incluido" },
  { label: "Procesador", value: "DSP integrado con EQ" },
  { label: "Peso", value: "15 – 22 kg por bocina" },
  { label: "Ingeniero", value: "Operador incluido" },
];

const sidebarNav = [
  { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
  { name: "Bocinas Amplificadas", href: null, active: true },
  { name: "Subwoofers y Graves", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras y Monitoreo", href: "/servicios/audiovisual/sonido/mezcladoras/" },
];

const sidebarRelated = [
  { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Subwoofers", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras", href: "/servicios/audiovisual/sonido/mezcladoras/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Salas Lounge", href: "/servicios/mobiliario/salas-lounge/" },
];

const reviews = [
  { author: "Ana Cristina Vega", text: "Rentamos el Kit Boda con 2 bocinas de 15 pulgadas y subwoofer para nuestra boda en un salón de Polanco con 150 invitados. El sonido fue increíble, se escuchaba perfecto en cada rincón del salón. El operador coordinó todo con nuestro DJ y no tuvimos que preocuparnos por nada. Excelente servicio.", rating: 5, date: "2025-11-08" },
  { author: "Jorge Mendoza", text: "Contratamos 4 bocinas de 12 pulgadas para una presentación corporativa en un hotel de Santa Fe. La calidad de audio fue profesional, los ponentes se escucharon con claridad y la música ambiental sonó perfecta. El técnico fue muy atento y resolvió todo al momento. Totalmente recomendados.", rating: 5, date: "2025-10-15" },
  { author: "Laura Domínguez", text: "Usamos un par de bocinas de 15 pulgadas con subwoofer para la fiesta de cumpleaños de mi hija en el jardín de la casa. El Bluetooth funcionó perfecto con mi playlist de Spotify y cuando llegó el DJ la transición fue inmediata. Sonido potente y limpio. Muy contenta con el servicio.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Bocinas Amplificadas para Eventos en CDMX",
    description: "Renta de bocinas activas de 12 y 15 pulgadas con subwoofer para eventos de hasta 200 personas en CDMX. Desde $2,000. Técnico incluido.",
    url: "/servicios/audiovisual/sonido/bocinas/",
    priceRange: { min: 2000, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 234,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
    { name: "Bocinas Amplificadas", url: "/servicios/audiovisual/sonido/bocinas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Bocinas Amplificadas para Eventos en CDMX"
  description="Renta de bocinas activas de 12 y 15 pulgadas con subwoofer para eventos de hasta 200 personas en CDMX. Desde $2,000. Técnico incluido."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Solución compacta para eventos en salón"
    title='Renta de <span class="highlight">Bocinas Amplificadas</span> para Eventos en CDMX'
    subtitle="Bocinas activas de 12 y 15 pulgadas con amplificación clase D, conexión Bluetooth y pedestal profesional. Operador de audio incluido en cada renta."
    primaryCTA={{ label: "Cotiza tus bocinas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar bocinas amplificadas para mi evento` }}
    cards={[
      {
        title: "Bocinas activas de 12 y 15 pulgadas para cada evento",
        content: "<strong>Renta de bocinas amplificadas</strong> con la tecnología más práctica y eficiente para eventos en salón en CDMX. Bocinas activas de 12 pulgadas para reuniones de hasta 80 personas y 15 pulgadas para eventos de hasta 200 personas. Amplificación clase D integrada de alta eficiencia con procesador DSP, ecualización paramétrica y protección contra sobrecarga. Conexiones XLR profesional, TRS y Bluetooth para conectar cualquier fuente de audio al instante. Incluye pedestal trípode profesional con ajuste de altura.",
      },
      {
        title: "Operador de audio y montaje completo incluido",
        content: "<strong>Servicio técnico completo incluido</strong> en cada renta de bocinas amplificadas. Nuestro operador de audio se encarga del transporte, instalación en trípode profesional, conexión de fuentes de audio, ecualización según la acústica del salón y monitoreo de niveles durante todo el evento. Kits completos para bodas (bocinas + subwoofer + micrófono inalámbrico) y corporativos (bocinas distribuidas + mixer). Desmontaje y recolección sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas audio compacto y potente para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la bocina ideal para tu espacio y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Sonido Profesional</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas bocinas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar bocinas amplificadas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Bocinas Amplificadas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Bocinas 12" -->
          <section class="section section--alt" aria-labelledby="bocinas12-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Fiestas de 50-80 personas</span>
                <h2 class="showcase__title" id="bocinas12-heading">Bocinas de 12 Pulgadas</h2>
                <p class="showcase__subtitle">La opción más compacta y práctica para fiestas privadas, reuniones y eventos íntimos de hasta 80 personas.</p>
                <p class="showcase__text">Nuestras <strong>bocinas amplificadas de 12 pulgadas</strong> son la solución perfecta para eventos pequeños que requieren audio de calidad profesional. Con <strong>1,000W de potencia RMS y amplificación clase D</strong>, cada bocina llena salones de hasta 80 personas con un sonido limpio, potente y sin distorsión. El woofer de 12 pulgadas reproduce frecuencias medias con claridad, mientras que el tweeter de compresión de 1.4 pulgadas proyecta los agudos con definición.</p>
                <p class="showcase__text">Incluyen <strong>procesador DSP integrado con ecualización preset para voz y música</strong>, conexión Bluetooth para streaming directo desde tu celular, y entradas XLR/TRS para fuentes profesionales. Montadas en trípode profesional con ajuste de altura para apuntar directamente a la audiencia. Ideales para <strong>fiestas de cumpleaños, cenas privadas, cocktails y presentaciones en sala de juntas</strong>. Se complementan con nuestros <a href="/servicios/audiovisual/microfonos-dj/">micrófonos inalámbricos</a> para brindis y discursos.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">12 pulgadas</span>
                  <span class="showcase__tag">1,000W RMS</span>
                  <span class="showcase__tag">Bluetooth</span>
                  <span class="showcase__tag">Hasta 80 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Bocinas 12"
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Bocinas 12"</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Bocinas 15" -->
          <section class="section section--alt" aria-labelledby="bocinas15-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas y corporativos 80-200 personas</span>
                <h2 class="showcase__title" id="bocinas15-heading">Bocinas de 15 Pulgadas</h2>
                <p class="showcase__subtitle">Potencia y claridad profesional para bodas en salón, corporativos y eventos sociales de 80 a 200 personas.</p>
                <p class="showcase__text">Las <strong>bocinas amplificadas de 15 pulgadas</strong> son nuestras más solicitadas para <strong>bodas y eventos corporativos</strong> en la Ciudad de México. Con <strong>2,000W de potencia RMS y dispersión de 90x60 grados</strong>, cada bocina proyecta el sonido con alcance y uniformidad suficiente para cubrir salones de hasta 200 personas. El woofer de 15 pulgadas reproduce graves más profundos que el modelo de 12, ofreciendo un sonido más completo incluso sin subwoofer adicional.</p>
                <p class="showcase__text">Incluyen <strong>procesador DSP avanzado con modos preconfigurados para voz, música en vivo y DJ</strong>, además de las mismas conexiones XLR, TRS y Bluetooth. La mayor potencia y respuesta en frecuencia las hacen ideales para <strong>bodas con pista de baile, recepciones, galas corporativas, conferencias y fiestas de hasta 200 invitados</strong>. Se recomienda agregar subwoofer complementario para eventos con DJ o cuando se requiera mayor presencia de graves. Combina con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para un montaje impecable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">15 pulgadas</span>
                  <span class="showcase__tag">2,000W RMS</span>
                  <span class="showcase__tag">90x60° dispersión</span>
                  <span class="showcase__tag">80-200 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Bocinas 15"
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Bocinas 15"</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Kit Boda -->
          <section class="section section--alt" aria-labelledby="kitboda-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más solicitado para bodas</span>
                <h2 class="showcase__title" id="kitboda-heading">Kit Boda Completo</h2>
                <p class="showcase__subtitle">2 bocinas de 15 pulgadas + subwoofer + micrófono inalámbrico: todo lo que necesitas para tu boda.</p>
                <p class="showcase__text">Nuestro <strong>Kit Boda</strong> es el paquete más popular para <strong>bodas y recepciones</strong> en CDMX. Incluye <strong>2 bocinas amplificadas de 15 pulgadas en trípode, 1 subwoofer de 18 pulgadas y 1 micrófono inalámbrico</strong> de mano para brindis, discursos y la conducción del evento. Este kit cubre con holgura salones de hasta 200 personas con un sonido potente, claro y con graves profundos que hacen vibrar la pista de baile.</p>
                <p class="showcase__text">El operador de audio incluido coordina el sonido con tu DJ durante toda la recepción: <strong>volumen bajo y música ambiental durante la cena, transición suave para los discursos con micrófono inalámbrico, y potencia completa para la pista de baile</strong>. El subwoofer agrega la profundidad de graves necesaria para que la música se sienta en todo el cuerpo. Ideal para <strong>bodas en salones de hotel, haciendas, jardines techados y restaurantes</strong>. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para crear la atmósfera perfecta.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">2 bocinas 15"</span>
                  <span class="showcase__tag">Subwoofer 18"</span>
                  <span class="showcase__tag">Mic inalámbrico</span>
                  <span class="showcase__tag">Hasta 200 personas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Kit Boda
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/>
                  </svg>
                  <span>Kit Boda Completo</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Corporativo -->
          <section class="section section--alt" aria-labelledby="kitcorp-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Audio distribuido profesional</span>
                <h2 class="showcase__title" id="kitcorp-heading">Kit Corporativo</h2>
                <p class="showcase__subtitle">4 bocinas distribuidas + mixer para conferencias, capacitaciones y eventos empresariales.</p>
