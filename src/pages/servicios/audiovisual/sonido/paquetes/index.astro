---
/**
 * ─── Paquetes de Sonido por Tipo de Evento — Página de Producto (L5) ───
 * Kits cerrados de audio por número de asistentes y tipo de evento:
 * boda, XV años, corporativo/conferencia y concierto/festival.
 *
 * Jerarquía: Servicios > Audiovisual > Sonido > Paquetes de Sonido
 * Template: sillas/tiffany (l3-shared + l4-shared, dorado institucional).
 * IMG: reusadas de /images/audiovisual — no hay fotos por paquete; alt honesto.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProveedorSonido from "@components/ProveedorSonido.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Sonido", href: "/servicios/audiovisual/sonido/" },
  { label: "Paquetes de Sonido" },
];

const faqs = [
  { question: "¿Qué incluye exactamente un paquete de sonido?", answer: 'Todos nuestros paquetes incluyen <strong>el equipo de audio, el cableado profesional, el transporte, el montaje, el sound check previo, el ingeniero de audio durante todo el evento y el desmontaje</strong>. Lo que cambia entre paquetes es la escala del sistema: número de cajas acústicas, subwoofers, canales de consola y micrófonos. No cobramos por separado la instalación ni la operación técnica — el precio que cotizamos es el precio final del servicio completo dentro de CDMX.' },
  { question: "¿Cómo sé qué paquete necesito para mi evento?", answer: 'La regla práctica es partir del <strong>número de asistentes y del programa del evento</strong>. Hasta 200 personas en salón, el <strong>Paquete Boda</strong> o el <strong>Paquete Corporativo</strong> resuelven con <a href="/servicios/audiovisual/sonido/bocinas/">bocinas amplificadas</a>. De 200 a 800 personas, el <strong>Paquete XV y Fiesta</strong> agrega subwoofers y potencia para pista de baile. Arriba de 800 personas o al aire libre, el <strong>Paquete Concierto</strong> con <a href="/servicios/audiovisual/sonido/line-array/">line array</a> es la única configuración que da cobertura pareja. Hacemos visita técnica sin costo para confirmarlo.' },
  { question: "¿Puedo modificar un paquete o agregar equipo?", answer: 'Sí. Los paquetes son un punto de partida, no una camisa de fuerza. Puedes agregar <a href="/servicios/audiovisual/sonido/subwoofers/">subwoofers</a> adicionales si tu evento tiene DJ o música electrónica, sumar <a href="/servicios/audiovisual/microfonos-dj/">micrófonos inalámbricos</a> para más panelistas, escalar la <a href="/servicios/audiovisual/sonido/mezcladoras/">consola</a> a más canales, o incorporar <a href="/servicios/audiovisual/sonido/monitores-escenario/">monitores de escenario</a> si habrá música en vivo. Cada adición se cotiza por separado y se integra al mismo montaje, con un solo ingeniero responsable.' },
  { question: "¿Los paquetes incluyen micrófonos?", answer: 'El <strong>Paquete Boda</strong> incluye un micrófono inalámbrico de mano para brindis y conducción. El <strong>Paquete Corporativo</strong> incluye dos micrófonos (uno de mano y uno de solapa o diadema para el ponente principal). Los paquetes <strong>XV y Fiesta</strong> y <strong>Concierto</strong> incluyen microfonía según el programa: mano para el maestro de ceremonias, y set de instrumentos si hay banda en vivo. Micrófonos adicionales se agregan desde nuestra sección de <a href="/servicios/audiovisual/microfonos-dj/">micrófonos y DJ</a> en la misma cotización.' },
  { question: "¿Qué pasa si mi evento es al aire libre o no tiene corriente eléctrica?", answer: 'Los eventos al aire libre requieren más potencia porque no hay paredes que refuercen el sonido: como referencia, un jardín necesita aproximadamente <strong>el doble de subwoofers</strong> que un salón para el mismo número de asistentes. Si el venue no tiene acometida eléctrica suficiente o no tiene corriente, coordinamos <strong>planta de luz con capacidad para el sistema completo</strong> como servicio adicional. Lo detectamos en la visita técnica: medimos la acometida disponible antes de confirmar la configuración.' },
  { question: "¿Con cuánta anticipación debo apartar un paquete de sonido?", answer: 'Para los paquetes <strong>Boda y Corporativo</strong> recomendamos <strong>2 a 4 semanas</strong> de anticipación. Para los paquetes <strong>XV y Fiesta</strong> y sobre todo <strong>Concierto</strong>, que comprometen line array y consolas grandes, lo ideal es <strong>1 a 2 meses</strong>, especialmente en temporada alta (noviembre a febrero y mayo a junio). Con el <strong>30% de anticipo</strong> apartamos equipo y fecha. También atendemos solicitudes de último momento sujetas a disponibilidad real de inventario.' },
];

const specs = [
  { label: "Paquete Boda", value: "Hasta 200 pax · salón" },
  { label: "Paquete XV y Fiesta", value: "200 – 800 pax · pista de baile" },
  { label: "Paquete Corporativo", value: "Hasta 300 pax · claridad de voz" },
  { label: "Paquete Concierto", value: "800 – 5,000+ pax · line array" },
  { label: "Incluido en todos", value: "Montaje, sound check y desmontaje" },
  { label: "Ingeniero de audio", value: "Presente todo el evento" },
  { label: "Cableado", value: "Profesional y oculto" },
  { label: "Respaldo", value: "Equipo de reemplazo en sitio" },
  { label: "Anticipo", value: "30% para apartar fecha" },
  { label: "Cobertura", value: "CDMX y zona metropolitana" },
];

const sidebarNav = [
  { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
  { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
  { name: "Subwoofers y Graves", href: "/servicios/audiovisual/sonido/subwoofers/" },
  { name: "Mezcladoras y Monitoreo", href: "/servicios/audiovisual/sonido/mezcladoras/" },
  { name: "Amplificadores de Potencia", href: "/servicios/audiovisual/sonido/amplificadores/" },
  { name: "Monitores de Escenario", href: "/servicios/audiovisual/sonido/monitores-escenario/" },
  { name: "Paquetes de Sonido", href: null, active: true },
  { name: "Accesorios y Cableado", href: "/servicios/audiovisual/sonido/accesorios-audio/" },
];

const sidebarRelated = [
  { name: "Micrófonos y Cabina DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Iluminación de Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Mariana Escobedo", text: "Contratamos el Paquete Boda para 180 invitados en una hacienda de Xochimilco. Lo que más valoramos fue no tener que armar el rompecabezas nosotros: llegaron con todo, hicieron sound check dos horas antes y el ingeniero se quedó coordinando con el DJ hasta el último baile. Los discursos se escucharon perfecto en todas las mesas.", rating: 5, date: "2026-04-18" },
  { author: "Ricardo Palacios", text: "Usamos el Paquete Corporativo para una junta general con 260 colaboradores en un hotel de Santa Fe. El audio distribuido eliminó los puntos muertos del salón y los micrófonos de solapa nunca fallaron. La coordinación con el equipo de video fue impecable porque todo salió del mismo proveedor.", rating: 5, date: "2026-02-27" },
  { author: "Daniela Fuentes", text: "Paquete XV y Fiesta para los quince de mi hija, 400 invitados en un jardín de Cuajimalpa. Al aire libre me preocupaba que el sonido se perdiera y fue todo lo contrario: los subwoofers se sentían en la pista y en la zona de mesas se podía platicar. Nos ajustaron la configuración después de la visita técnica.", rating: 5, date: "2025-12-06" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Paquetes de Sonido para Eventos CDMX",
    description: "Paquetes de renta de sonido por tipo de evento en CDMX: boda, XV años, corporativo y concierto. Equipo, montaje, sound check e ingeniero de audio incluidos.",
    url: "/servicios/audiovisual/sonido/paquetes/",
    priceRange: { min: 3500, max: 45000 },
    reviews,
    ratingValue: 5,
    reviewCount: 187,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Sonido", url: "/servicios/audiovisual/sonido/" },
    { name: "Paquetes de Sonido", url: "/servicios/audiovisual/sonido/paquetes/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Paquetes de Renta de Sonido para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/equipo-audiovisual-completo-boda.avif"
  description="Paquetes de sonido por tipo de evento en CDMX: boda, XV años, corporativo y concierto. Montaje, sound check e ingeniero de audio incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Kits cerrados por tipo de evento"
    title='<span class="highlight">Paquetes de Sonido</span> para Eventos en CDMX'
    subtitle="Cuatro configuraciones probadas en más de 500 eventos: boda, XV años, corporativo y concierto. Equipo, montaje, sound check e ingeniero de audio incluidos en cada paquete."
    primaryCTA={{ label: "Cotiza tu paquete", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar un paquete de sonido para mi evento` }}
    cards={[
      {
        title: "Un paquete es una decisión menos que tomar",
        content: "<strong>Elegir sonido por piezas sueltas es donde se equivocan la mayoría de los eventos</strong>: se renta la bocina correcta pero falta el subwoofer, o sobra potencia y falta un micrófono. Nuestros <strong>paquetes de sonido</strong> parten de la variable que sí conoces — cuántas personas y qué tipo de evento — y de ahí derivan la configuración completa: cajas acústicas, subwoofers, canales de consola, microfonía y cableado. Cada paquete se calibró en eventos reales en CDMX antes de ofrecerse como estándar.",
      },
      {
        title: "Precio cerrado: equipo, montaje, operación y desmontaje",
        content: "<strong>El precio del paquete es el precio del servicio completo.</strong> Incluye transporte, montaje con cableado oculto, sound check y ecualización según la acústica real de tu venue, ingeniero de audio presente durante todo el evento, equipo de respaldo en sitio y desmontaje al cierre — sin cargos adicionales dentro de CDMX. Visita técnica sin costo previa para confirmar la configuración, y ajustes al paquete si tu evento requiere más subwoofers, más micrófonos o monitores de escenario.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿No sabes qué paquete de sonido necesita tu evento?"
    subheadline="Dinos cuántas personas y qué tipo de evento — te confirmamos la configuración exacta en menos de 24 horas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Sonido Profesional</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Qué paquete necesita tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un paquete de sonido para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Comparativa Rápida — Paquetes de Sonido</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Paquete Boda -->
          <section class="section" aria-labelledby="paq-boda-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más solicitado · hasta 200 personas</span>
                <h2 class="showcase__title" id="paq-boda-heading">Paquete Boda</h2>
                <p class="showcase__subtitle">Ceremonia, cena y pista de baile resueltas con un solo sistema y un solo ingeniero.</p>
                <p class="showcase__text">Una boda no es un evento de audio, son <strong>tres eventos de audio en la misma noche</strong>: una ceremonia donde la voz debe entenderse sin que el sistema se note, una cena donde la música tiene que dejar conversar, y una pista de baile donde los graves deben sentirse. El <strong>Paquete Boda</strong> se armó exactamente sobre esa curva. Incluye <strong>2 bocinas amplificadas de 15 pulgadas en trípode, 1 subwoofer de 18 pulgadas, 1 micrófono inalámbrico de mano y consola de 8 canales</strong>, dimensionado para salones y jardines techados de hasta 200 invitados.</p>
                <p class="showcase__text">El ingeniero de audio trabaja el evento por bloques: <strong>refuerzo discreto durante la ceremonia, nivel de fondo durante la cena, y sistema completo con subwoofer al abrir la pista</strong>. Coordina con tu DJ o grupo desde el sound check y se queda hasta el último baile. Si tu boda es en jardín abierto o supera 200 invitados, en la visita técnica escalamos a un segundo subwoofer o al <a href="/servicios/audiovisual/sonido/line-array/">line array compacto</a>. Combina con <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> y <a href="/servicios/pistas-baile/">pista de baile</a> desde la misma producción.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">2 bocinas 15"</span>
                  <span class="showcase__tag">Subwoofer 18"</span>
                  <span class="showcase__tag">Mic inalámbrico</span>
                  <span class="showcase__tag">Hasta 200 pax</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Paquete Boda
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/equipo-audiovisual-completo-boda.avif" alt="Montaje de audio EVENTECH para boda en salón en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-06.avif" alt="Bocina amplificada en trípode durante montaje de boda" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-02.avif" alt="Equipo de audio profesional montado antes de un evento social" loading="lazy" decoding="async" /></div>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Paquete XV y Fiesta -->
          <section class="section" aria-labelledby="paq-xv-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Pista de baile · 200 a 800 personas</span>
                <h2 class="showcase__title" id="paq-xv-heading">Paquete XV Años y Fiesta</h2>
                <p class="showcase__subtitle">Presencia de graves y potencia sostenida para eventos donde la pista no para en toda la noche.</p>
                <p class="showcase__text">Los XV años, las fiestas privadas y los eventos con DJ tienen una exigencia distinta a la de una boda: <strong>el sistema opera a niveles altos durante horas seguidas</strong>. Aquí lo que falla no es la potencia máxima sino la potencia sostenida — un sistema subdimensionado se comprime, distorsiona y a las dos horas suena cansado. El <strong>Paquete XV y Fiesta</strong> monta <strong>4 cajas acústicas, 2 a 4 subwoofers de 18 pulgadas y consola digital de 16 canales</strong>, con margen térmico para trabajar toda la noche sin llegar al límite.</p>
                <p class="showcase__text">La regla que aplicamos es <strong>1 subwoofer por cada 100 personas en salón, y 1 por cada 50 al aire libre</strong>, porque en un jardín no hay paredes que refuercen los graves. El paquete incluye micrófono inalámbrico para el maestro de ceremonias y las transiciones del protocolo — vals, brindis, entrada de la festejada — coordinadas por el ingeniero junto al DJ. Escala directamente con <a href="/servicios/audiovisual/sonido/subwoofers/">subwoofers adicionales</a> y se integra con <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> y <a href="/servicios/audiovisual/microfonos-dj/">cabina de DJ</a>.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4 cajas acústicas</span>
                  <span class="showcase__tag">2–4 subwoofers 18"</span>
                  <span class="showcase__tag">Consola 16 canales</span>
                  <span class="showcase__tag">200–800 pax</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Paquete XV y Fiesta
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/audiovisual/audio-evento-03.avif" alt="Sistema de audio con subwoofers montado para fiesta en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif" alt="Cabina de DJ conectada al sistema de sonido del evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/audiovisual/audio-evento-05.avif" alt="Cajas acústicas profesionales durante un evento social" loading="lazy" decoding="async" /></div>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Paquete Corporativo -->
          <section class="section" aria-labelledby="paq-corp-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Claridad de voz · hasta 300 personas</span>
                <h2 class="showcase__title" id="paq-corp-heading">Paquete Corporativo y Conferencia</h2>
                <p class="showcase__subtitle">Audio distribuido y microfonía redundante: en un corporativo, lo único que no se perdona es que no se entienda al ponente.</p>
                <p class="showcase__text">En un evento corporativo el audio no compite con nada — <strong>es el evento</strong>. Si el ponente no se entiende desde la última fila, el resto de la producción es irrelevante. El <strong>Paquete Corporativo</strong> resuelve el problema real de los salones de hotel: los puntos muertos. En vez de dos bocinas frontales a volumen alto, montamos <strong>4 bocinas distribuidas y ecualizadas individualmente</strong> para compensar las reflexiones de cada zona, más <strong>consola digital y 2 micrófonos (mano y solapa o diadema)</strong>.</p>
                <p class="showcase__text">Incluye <strong>micrófono de respaldo con batería fresca listo para entregar sin cortar la sesión</strong>, y gestión de múltiples fuentes en la consola: micrófonos de panelistas, audio de presentaciones, videoconferencia y música de entrada y salida. El ingeniero opera las transiciones entre ponentes y contenido multimedia. Se integra con <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a>, <a href="/servicios/audiovisual/proyectores/">proyectores</a> y <a href="/servicios/audiovisual/microfonos-dj/inalambricos/">microfonía inalámbrica</a> adicional para paneles de más de dos personas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4 bocinas distribuidas</span>
                  <span class="showcase__tag">Consola digital</span>
                  <span class="showcase__tag">Mic mano + solapa</span>
                  <span class="showcase__tag">Hasta 300 pax</span>
