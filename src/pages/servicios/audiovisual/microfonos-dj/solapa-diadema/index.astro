---
/**
 * ─── Micrófonos de Solapa y Diadema — Pagina de Producto (Nivel 4) ───
 * Micrófonos de solapa Sennheiser ME2 y diademas Shure MX
 * para presentadores y panelistas. Body pack ultraligero.
 *
 * Jerarquia: Servicios > Audiovisual > Micrófonos y DJ > Solapa y Diadema
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Micrófonos y DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { label: "Solapa y Diadema" },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre micrófono de solapa y diadema?", answer: 'El <strong>micrófono de solapa (lavalier)</strong> se sujeta en la solapa del saco, corbata o blusa con un clip discreto. Es omnidireccional, captura el audio de forma natural y es prácticamente invisible en cámara — ideal para <strong>conferencias, paneles y entrevistas</strong>. La <strong>diadema (headset)</strong> se coloca en la oreja con el micrófono posicionado junto a la boca. Es cardioide, rechaza más ruido ambiente y mantiene distancia constante — perfecta para <strong>MC, animadores y presentadores</strong> que se mueven por el escenario.' },
  { question: "¿Cuál micrófono es mejor para streaming y video?", answer: 'Para <strong>streaming y producción de video</strong>, recomendamos el micrófono de solapa Shure MX150 con cápsula subminiatura. Su tamaño reducido lo hace prácticamente invisible en cámara, captura audio nítido y el body pack permite conectar directamente a cámaras y sistemas de streaming. Para presentadores en movimiento que aparecen en cámara, la <strong>diadema en tono piel</strong> es la mejor opción ya que se camufla completamente.' },
  { question: "¿Se nota el micrófono de solapa en cámara?", answer: 'Los micrófonos de solapa profesionales están diseñados para ser <strong>mínimamente visibles</strong>. El Sennheiser ME2-II tiene un diámetro de apenas 10mm y el Shure MX150 es aún más pequeño (subminiatura). Con un <strong>clip discreto</strong> posicionado en la solapa, corbata o borde del escote, pasa desapercibido en la mayoría de las tomas. Para máxima discreción, las diademas en <strong>tono piel</strong> son prácticamente invisibles incluso en primeros planos.' },
  { question: "¿Cuántos micrófonos de solapa pueden funcionar simultáneamente?", answer: 'Nuestros sistemas permiten operar <strong>hasta 8 micrófonos de solapa simultáneos</strong> sin interferencias. Cada micrófono opera en su propia frecuencia UHF coordinada y nuestro ingeniero de audio configura todos los canales para evitar cruces. Para <strong>paneles de 2-4 personas</strong> usamos receptores multi-canal en rack. Para <strong>conferencias de 5-8 panelistas</strong>, combinamos receptores y distribuimos frecuencias estratégicamente.' },
  { question: "¿Se pueden combinar solapas con micrófonos inalámbricos de mano?", answer: 'Sí, es una configuración muy común. Por ejemplo, en un <strong>panel corporativo</strong> los panelistas usan solapa para discusión continua, mientras que el moderador tiene <a href="/servicios/audiovisual/microfonos-dj/inalambricos/">micrófono de mano</a> para intervenciones y preguntas del público. En <strong>bodas</strong>, el MC usa diadema para animar toda la noche mientras los micrófonos de mano se usan para brindis puntuales. Nuestro ingeniero coordina todas las frecuencias para operación simultánea sin conflictos.' },
  { question: "¿Con cuánta anticipación debo reservar?", answer: 'Recomendamos reservar con <strong>2 a 3 semanas de anticipación</strong> para garantizar disponibilidad de los modelos que necesitas. Los kits de conferencia con 3-4 solapas son los más solicitados en <strong>temporada de congresos (septiembre a noviembre)</strong>. Para eventos corporativos con configuraciones especiales o múltiples canales, lo ideal es apartar con <strong>1 mes de anticipación</strong>. También atendemos solicitudes de último momento sujetas a disponibilidad.' },
];

const specs = [
  { label: "Tipo Solapa", value: "Lavalier omnidireccional" },
  { label: "Tipo Diadema", value: "Headset cardioide" },
  { label: "Marcas", value: "Sennheiser ME2-II / Shure MX150" },
  { label: "Transmisor", value: "Body pack ultraligero" },
  { label: "Frecuencia", value: "UHF coordinada, cero interferencias" },
  { label: "Batería", value: "AA, 8+ horas" },
  { label: "Color Diadema", value: "Tono piel / negro" },
  { label: "Clip", value: "Ajustable para solapa, corbata o blusa" },
  { label: "Conectividad", value: "Mini-XLR / 3.5mm al body pack" },
  { label: "Ingeniero", value: "Incluido, configura frecuencias" },
];

const sidebarNav = [
  { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/inalambricos/" },
  { name: "Solapa y Diadema", href: null, active: true },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
  { name: "Cabina DJ", href: "/servicios/audiovisual/microfonos-dj/cabina-dj/" },
];

const sidebarRelated = [
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Mobiliario Ejecutivo", href: "/servicios/mobiliario/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
];

const reviews = [
  { author: "Lic. Mónica Herrera", text: "Rentamos 3 micrófonos de solapa Sennheiser para un panel de expertos en nuestro congreso de marketing. La calidad de audio fue impecable, los panelistas se movían con total libertad y el ingeniero coordinó todo con el sistema de streaming. Los asistentes virtuales escucharon perfecto.", rating: 5, date: "2025-11-10" },
  { author: "Carlos Mendoza", text: "Contratamos una diadema profesional para el MC de nuestra boda. Se veía elegante, el sonido era cristalino y nuestro animador pudo moverse por todo el salón sin restricciones. El body pack era tan ligero que ni se notaba. Excelente inversión.", rating: 5, date: "2025-10-25" },
  { author: "Dra. Sofía Ramírez", text: "Para nuestro congreso médico con streaming necesitábamos 4 solapas que fueran discretas en cámara. El equipo de EVENTECH configuró todo perfecto, los micrófonos eran prácticamente invisibles y el audio en la transmisión fue de calidad broadcast. Muy profesionales.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Micrófonos de Solapa y Diadema para Eventos en CDMX",
    description: "Renta de micrófonos de solapa Sennheiser ME2 y diademas Shure MX para presentadores y panelistas en CDMX. Body pack ultraligero. Ingeniero incluido. Desde $350.",
    url: "/servicios/audiovisual/microfonos-dj/solapa-diadema/",
    priceRange: { min: 350, max: 3500 },
    reviews,
    ratingValue: 5,
    reviewCount: 189,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Micrófonos y DJ", url: "/servicios/audiovisual/microfonos-dj/" },
    { name: "Solapa y Diadema", url: "/servicios/audiovisual/microfonos-dj/solapa-diadema/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Micrófonos de Solapa y Diadema para Eventos en CDMX"
  description="Renta de micrófonos de solapa Sennheiser ME2 y diademas Shure MX para presentadores y panelistas en CDMX. Body pack ultraligero. Ingeniero incluido. Desde $350."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Audio profesional manos libres"
    title='Renta de <span class="highlight">Micrófonos de Solapa y Diadema</span> para Eventos en CDMX'
    subtitle="Micrófonos de solapa Sennheiser ME2-II y Shure MX150, más diademas profesionales para MC y presentadores. Body pack ultraligero e ingeniero de audio dedicado en cada evento."
    primaryCTA={{ label: "Cotiza tu micrófono", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar micrófonos de solapa o diadema para mi evento` }}
    cards={[
      {
        title: "Lavalier Sennheiser y Shure con body pack ultraligero",
        content: "<strong>Renta de micrófonos de solapa profesionales</strong> con las marcas líderes en audio discreto. Lavalier Sennheiser ME2-II con cápsula omnidireccional que captura la voz con naturalidad excepcional, y Shure MX150 con cápsula subminiatura prácticamente invisible en cámara. Ambos sistemas con body pack transmisor ultraligero que se oculta en cinturón o bolsillo. Ideales para conferencias, paneles de discusión, entrevistas y eventos híbridos con transmisión en vivo.",
      },
      {
        title: "Diademas profesionales y frecuencias coordinadas",
        content: "<strong>Diademas cardioide para MC y presentadores</strong> que necesitan las manos completamente libres mientras se mueven por el escenario. Clip ajustable con tono piel para máxima discreción en cámara, cápsula posicionada junto a la boca para rechazo óptimo de ruido ambiente. Frecuencias UHF coordinadas por nuestro ingeniero de audio para cero interferencias, incluso con múltiples micrófonos simultáneos. Configuración completa, monitoreo en tiempo real y soporte técnico durante todo el evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas audio discreto y manos libres para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el micrófono ideal para tus presentadores y panelistas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Micrófonos y DJ para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas micrófonos de solapa o diadema para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar micrófonos de solapa o diadema para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Solapa y Diadema</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Solapa Sennheiser ME2-II -->
          <section class="section section--alt" aria-labelledby="solapa-sennheiser-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para conferencias y paneles</span>
                <h2 class="showcase__title" id="solapa-sennheiser-heading">Solapa Sennheiser ME2-II</h2>
                <p class="showcase__subtitle">El lavalier omnidireccional de referencia para conferencias, paneles y producción profesional.</p>
                <p class="showcase__text">El <strong>Sennheiser ME2-II</strong> es el micrófono de solapa más utilizado en producciones profesionales a nivel mundial. Su cápsula omnidireccional captura la voz con una <strong>naturalidad excepcional</strong>, sin importar si el orador gira la cabeza o se mueve. Con un diámetro de apenas 10mm, es discreto y elegante para cualquier tipo de vestimenta. El clip de sujeción se ajusta a solapas, corbatas, blusas y cuellos con seguridad total — <strong>perfecto para conferencias, paneles de discusión y entrevistas corporativas</strong>.</p>
                <p class="showcase__text">El body pack transmisor <strong>pesa menos de 100 gramos</strong> y se sujeta al cinturón o bolsillo sin que el orador lo note. Frecuencia UHF con escaneo automático y batería AA con duración de 8+ horas para eventos de larga duración. El cable del micrófono se oculta discretamente por dentro de la ropa. Nuestro ingeniero posiciona el micrófono a la distancia óptima de la boca y ecualiza para cada voz. Combínalo con nuestros <a href="/servicios/audiovisual/proyectores/">proyectores</a> para presentaciones corporativas completas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Omnidireccional</span>
                  <span class="showcase__tag">10mm diámetro</span>
                  <span class="showcase__tag">Body pack ligero</span>
                  <span class="showcase__tag">Conferencias</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Solapa Sennheiser ME2-II
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Solapa Sennheiser ME2-II</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Solapa Shure MX150 -->
          <section class="section section--alt" aria-labelledby="solapa-shure-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Perfecto para eventos híbridos</span>
                <h2 class="showcase__title" id="solapa-shure-heading">Solapa Shure MX150</h2>
                <p class="showcase__subtitle">El micrófono subminiatura de Shure optimizado para streaming y producción de video.</p>
                <p class="showcase__text">El <strong>Shure MX150</strong> es nuestro micrófono de solapa subminiatura diseñado específicamente para <strong>eventos híbridos con transmisión en vivo</strong> y producción de video. Su cápsula de apenas 5mm de diámetro es prácticamente invisible incluso en primeros planos de cámara. Patrón omnidireccional con respuesta en frecuencia optimizada para voz que garantiza audio broadcast en streaming de Zoom, Teams, YouTube Live y plataformas de webinar.</p>
                <p class="showcase__text">Incluye <strong>tres clips de sujeción diferentes</strong> (solapa, corbata y magnético) para adaptarse a cualquier vestimenta sin dañar la tela. El cable ultra-delgado se oculta sin esfuerzo. Compatible con body pack Shure para transmisión inalámbrica UHF o conexión directa a cámaras y grabadoras vía adaptador 3.5mm. Ideal para <strong>conferencias con streaming, podcasts en vivo, entrevistas on-camera y producciones de contenido corporativo</strong>. Combínalo con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para un setup de streaming profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Subminiatura 5mm</span>
                  <span class="showcase__tag">Streaming</span>
                  <span class="showcase__tag">3 clips incluidos</span>
                  <span class="showcase__tag">Eventos híbridos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Solapa Shure MX150
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Solapa Shure MX150</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Diadema Profesional -->
          <section class="section section--alt" aria-labelledby="diadema-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Manos libres para el escenario</span>
                <h2 class="showcase__title" id="diadema-heading">Diadema Profesional</h2>
                <p class="showcase__subtitle">La solución definitiva para MC, animadores y presentadores que necesitan libertad total de movimiento.</p>
                <p class="showcase__text">Nuestras <strong>diademas profesionales (headset)</strong> son el estándar para maestros de ceremonias, animadores y presentadores que necesitan <strong>las manos completamente libres</strong> mientras se mueven por el escenario. La cápsula cardioide se posiciona junto a la boca para capturar la voz con máxima claridad y rechazar el ruido ambiente de música y crowd. La sujeción ergonómica se adapta a cualquier tamaño de cabeza y permanece firme incluso con movimientos energéticos.</p>
                <p class="showcase__text">Disponibles en <strong>tono piel y negro</strong> para adaptarse al look del presentador y la producción. El tono piel se camufla completamente en cámara, perfecto para <strong>producciones televisivas, galas corporativas y eventos con cobertura de video</strong>. El body pack ultraligero se oculta en el cinturón o bolsillo trasero. Incluye paravientos para eventos en exteriores. Combínala con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para una producción integral de audio.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cardioide</span>
                  <span class="showcase__tag">Tono piel / negro</span>
                  <span class="showcase__tag">Manos libres</span>
                  <span class="showcase__tag">MC y animadores</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Diadema Profesional
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
