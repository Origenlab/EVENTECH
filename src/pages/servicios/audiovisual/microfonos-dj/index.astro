    primaryCTA={{ label: "Cotizar micrófonos y DJ", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar micrófonos y equipo DJ para mi evento` }}
    variant="accent"
  />

</PageLayout>

