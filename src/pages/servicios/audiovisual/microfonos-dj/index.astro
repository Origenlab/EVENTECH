---
/**
 * ─── EVENTECH.MX — Renta de Micrófonos y Equipo DJ para Eventos (Hub L4, molde hm- 2026) ───
 * Inalámbricos · Solapa/Diadema · Equipo DJ · Cabina DJ — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: reusadas de /images/audiovisual (faltan fotos reales por tipo — reemplazar).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "inalambricos",
    name: "Micrófonos Inalámbricos",
    badge: "El más solicitado",
    excerpt: "Shure SLX-D y Sennheiser EW de mano con receptor UHF. Alcance 100 m, audio sin interferencias para ceremonias, brindis y discursos en bodas y XV años.",
    href: "/servicios/audiovisual/microfonos-dj/inalambricos/",
    image: "/images/audiovisual/microfono-inalambrico-shure-conferencia-evento.avif",
    specs: ["Shure SLX-D", "Sennheiser EW", "UHF 100 m", "Respaldo incluido"],
  },
  {
    id: "solapa-diadema",
    name: "Micrófono de Solapa y Diadema",
    badge: "Manos libres",
    excerpt: "Lavalier y headset profesionales para maestros de ceremonias y conferencistas. Audio discreto y manos libres durante toda la presentación.",
    href: "/servicios/audiovisual/microfonos-dj/solapa-diadema/",
    image: "/images/audiovisual/microfono-solapa-diadema-conferencista.avif",
    specs: ["Lavalier", "Headset", "Body pack", "Tono piel"],
  },
  {
    id: "equipo-dj",
    name: "Equipo DJ Completo",
    badge: "Setup profesional",
    excerpt: "Pioneer CDJ-3000 + DJM-900NXS2 + monitores de referencia. El setup que usan los mejores DJs de bodas en CDMX. Llegan y conectan.",
    href: "/servicios/audiovisual/microfonos-dj/equipo-dj/",
    image: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif",
    specs: ["Pioneer CDJ-3000", "DJM-900NXS2", "DDJ-1000", "KRK / JBL"],
  },
  {
    id: "cabina-dj",
    name: "Cabina DJ Iluminada",
    badge: "El centro de la fiesta",
    excerpt: "Estructura de truss con LEDs RGB integrados y facia personalizable con tu logo o tema. Transforma el rincón del DJ en el centro visual de la fiesta.",
    href: "/servicios/audiovisual/microfonos-dj/cabina-dj/",
    image: "/images/audiovisual/equipo-audiovisual-completo-boda.avif",
    specs: ["Truss aluminio", "LED RGB", "Branding custom", "Logo projection"],
  },
];

const whyFeatures = [
  {
    title: "Ingeniero de audio y prueba de sonido",
    body: "El micrófono que falla en el momento del sí, acepto o del brindis no tiene segunda oportunidad. Cada renta incluye prueba de sonido previa e ingeniero que coordina frecuencias, niveles y ecualización de cada micrófono. No entregamos el equipo y nos vamos: hay alguien atento al audio durante los momentos que importan.",
  },
  {
    title: "Inventario propio de marcas líderes — sin subcontratar",
    body: "Micrófonos Shure y Sennheiser y equipo DJ Pioneer propios, en bodega CDMX. Cada unidad se revisa y prueba antes de salir: cápsulas, receptores, baterías, jog wheels y faders. Lo que cotizamos es lo que existe, verificado antes de cada entrega. Sin sorpresas de un micrófono con estática el día del evento.",
  },
  {
    title: "Frecuencias coordinadas — cero interferencias",
    body: "En un venue con varios equipos inalámbricos, las frecuencias chocan y aparecen zumbidos y cortes. Nuestro ingeniero coordina cada micrófono en frecuencias limpias antes del evento, evitando interferencias con el DJ, el sonido del salón y otros proveedores. Audio estable de principio a fin.",
  },
  {
    title: "Unidades de respaldo en sitio",
    body: "Cargamos micrófonos, baterías y receptores de respaldo listos para activarse al instante. Si una unidad falla durante la ceremonia o los discursos, se reemplaza sin que nadie lo note. El ingeniero tiene con qué responder ante cualquier imprevisto — no te quedas sin voz a media ceremonia.",
  },
  {
    title: "Instalación y cableado pro — tu DJ solo conecta",
    body: "Montamos, cableamos y probamos todo el equipo DJ y la cabina antes del evento: tornamesas, mixer, monitores, energía regulada y iluminación. Trabajamos con tu DJ o te conectamos con uno de confianza. El DJ llega a un setup listo y verificado — sin perder tiempo armando ni improvisando conexiones.",
  },
  {
    title: "Integración con sonido e iluminación",
    body: "Los micrófonos suenan mejor cuando se integran al sistema de sonido, y la cabina luce mejor sincronizada con la iluminación del evento — todo coordinado cuando viene del mismo proveedor. Integramos audio, música y luz desde una sola empresa, con un solo equipo técnico y una sola logística.",
  },
];

const steps = [
  { n: 1, t: "Cotización y necesidades del evento", p: "Nos cuentas el programa: ceremonia, discursos, panel, fiesta. Definimos cuántos micrófonos y de qué tipo, si necesitas equipo DJ o cabina, y si trabajas con DJ propio. En menos de 24 horas te confirmamos disponibilidad y te enviamos propuesta." },
  { n: 2, t: "Propuesta técnica y aparto de equipo", p: "Definimos micrófonos, setup DJ, cabina y branding si aplica. Con el 30% de anticipo apartamos el equipo y la fecha — sin pago total por adelantado. Coordinamos con tu DJ, wedding planner o el venue para el acceso y el montaje." },
  { n: 3, t: "Instalación, frecuencias y prueba de sonido", p: "Llegamos con tiempo el día del evento. Montaje y cableado del equipo DJ y la cabina, coordinación de frecuencias de los micrófonos y prueba de sonido completa antes de abrir puertas. Tu DJ encuentra el setup listo y verificado." },
  { n: 4, t: "Soporte en vivo y desmontaje", p: "El ingeniero de audio da soporte durante los momentos clave (ceremonia, discursos) y queda pendiente del equipo toda la noche. Al cierre, desmontamos, recogemos y hacemos conteo. El desmontaje y recolección están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuántos micrófonos inalámbricos necesito?", answer: "Para ceremonias religiosas o civiles recomendamos 1 a 2 micrófonos (oficiante y pareja). En eventos corporativos con panel de discusión, de 2 a 4 micrófonos según el número de panelistas. Para brindis y discursos sociales, 1 micrófono es suficiente. Siempre incluimos unidades de respaldo en cada renta para garantizar audio sin interrupciones durante todo tu evento." },
  { question: "¿Qué diferencia hay entre micrófono de mano, solapa y diadema?", answer: "El micrófono de mano es ideal para discursos, brindis y momentos puntuales donde el orador lo sostiene. El micrófono de solapa (lavalier) se sujeta en la solapa del saco o blusa, perfecto para conferencias, paneles y entrevistas donde necesitas audio continuo sin sostener nada. La diadema (headset) se coloca en la oreja y queda frente a la boca, ideal para maestros de ceremonias, presentadores y animadores que necesitan las manos completamente libres. Cada tipo tiene su caso de uso óptimo y nuestro ingeniero de audio te recomienda el adecuado." },
  { question: "¿El equipo de DJ incluye DJ?", answer: "No, la renta es únicamente del equipo profesional: tornamesas, controladores, mixer, monitores y cableado. Proporcionamos el setup completo listo para operar. Si necesitas recomendación de DJ, te conectamos con nuestros DJs asociados de confianza con experiencia comprobada en bodas, fiestas y eventos corporativos. También trabajamos sin problema con tu propio DJ — solo necesita llegar y conectarse." },
  { question: "¿Cuánto tarda el montaje del equipo DJ y la cabina?", answer: "El montaje de un setup DJ estándar con cabina iluminada toma entre 1.5 y 2.5 horas, incluyendo estructura de truss, cableado, energía regulada, iluminación LED y prueba de equipo. Siempre llegamos con tiempo suficiente antes del inicio del evento — normalmente coordinamos el acceso al venue con 2 a 3 horas de anticipación. Para cabinas con branding personalizado o configuraciones especiales, contemplamos tiempo adicional de montaje que no afecta el horario de tu evento." },
  { question: "¿La cabina DJ incluye iluminación?", answer: "Sí, nuestras cabinas DJ incluyen tiras LED RGB integradas en la estructura, opción de proyección de logo en la facia frontal, e integración con el diseño de iluminación general de tu evento. Disponibles en acabado blanco, negro y con branding personalizado (viniles o impresión en tela). La iluminación LED se controla de forma independiente o sincronizada con la música." },
  { question: "¿Se pueden combinar micrófonos con el sistema de sonido?", answer: "Sí, todos nuestros micrófonos son 100% compatibles con nuestros sistemas de sonido profesional. La integración es completamente transparente a través de nuestro ingeniero de audio, quien configura las frecuencias, ecualización y niveles para cada micrófono en el sistema. Si ya cuentas con equipo de sonido propio o de otro proveedor, nuestros micrófonos también se conectan sin problema vía XLR o receptor UHF estándar." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación para micrófonos y equipo estándar. El equipo Pioneer CDJ-3000 y las cabinas DJ premium tienen alta demanda, por lo que en temporada alta (noviembre a febrero) sugerimos apartar con al menos 1 mes de anticipación. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Micrófonos y Equipo DJ para Eventos en CDMX",
    description: "Renta de micrófonos inalámbricos Shure y Sennheiser, solapa y diadema, equipo DJ Pioneer CDJ-3000 y cabinas DJ iluminadas para eventos en CDMX. Ingeniero de audio incluido.",
    url: "/servicios/audiovisual/microfonos-dj/",
    priceRange: { min: 300, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Micrófonos y DJ", url: "/servicios/audiovisual/microfonos-dj/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Micrófonos y DJ" },
];
---

<PageLayout
  title="Renta de Micrófonos y Equipo DJ para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif"
  description="Renta de micrófonos inalámbricos Shure y Sennheiser, equipo DJ Pioneer y cabinas iluminadas en CDMX. Ingeniero de audio incluido. +500 eventos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="microfonos-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Micrófonos y DJ · CDMX y ZMVM</p>
            <h1 id="microfonos-hero-heading">
              Micrófonos y equipo DJ para eventos — <em>del brindis a la pista de baile</em>
            </h1>
            <p class="hm-hero__lead">
              Micrófonos inalámbricos Shure y Sennheiser, solapa y diadema, equipo DJ Pioneer
              de última generación y cabinas iluminadas con branding. Ingeniero de audio y
              prueba de sonido incluidos en cada renta.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20micr%C3%B3fonos%20y%20equipo%20DJ%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar equipo
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>micrófonos y equipo DJ para eventos</strong> en CDMX con
              inventario propio de las marcas líderes — micrófonos inalámbricos
              <strong>Shure y Sennheiser</strong> de mano, solapa y diadema con alcance de 100 m,
              y equipo DJ <strong>Pioneer CDJ-3000, DJM-900NXS2 y controladores DDJ-1000</strong>
              con monitores de referencia. Cabinas de truss con iluminación LED y branding
              personalizable. Cada equipo se prueba y verifica antes de cada entrega.
            </p>
            <p>
              Con <strong>más de 500 eventos montados</strong> en CDMX, sabemos que un micrófono
              con estática arruina el momento más importante de una boda y que una pista sin
              buen DJ vacía el salón: por eso cada renta incluye prueba de sonido, coordinación
              de frecuencias e ingeniero de audio dedicado. Para producciones completas
              integramos <a href="/servicios/audiovisual/sonido/">sonido profesional</a> y
              <a href="/servicios/pistas-baile/">pistas de baile</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de micrófono y equipo DJ disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20micr%C3%B3fonos%20y%20equipo%20DJ%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El catálogo más completo de CDMX</p>
            <h2 id="catalogo-heading">¿Qué equipo necesita tu evento?</h2>
            <p class="hm__head-sub">4 soluciones — del micrófono que hace escuchar cada palabra al setup DJ que llena la pista.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Hay dos momentos donde el audio no puede fallar: cuando alguien toma la palabra
              y cuando empieza la fiesta. Un micrófono con estática arruina el brindis; un
              equipo DJ mal montado vacía la pista. No son detalles menores — son los momentos
              que la gente recuerda del evento.
            </p>
            <p>
              Inalámbricos para ceremonias y discursos. Solapa y diadema para presentadores y
              paneles. Equipo DJ Pioneer para la mejor fiesta. Cabina iluminada para que el DJ
              sea también el centro visual. Una sola empresa para la voz y la música de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada equipo, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de micrófono y DJ — en detalle</h2>
            <p class="hm__head-sub">Marca, tipo, alcance y para qué momento del evento funciona mejor cada equipo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada equipo hay decisiones que afectan el resultado: el tipo de
              micrófono que decide si el orador tiene las manos libres, la coordinación de
              frecuencias que evita interferencias, y el setup DJ que determina qué tan fácil
              es para el DJ dar su mejor set.
            </p>
            <p>
              Conocer estas diferencias te permite elegir con criterio y no solo por precio.
              A continuación, lo que realmente importa de cada equipo.
            </p>
          </div>
        </div>

        <!-- INALÁMBRICOS -->
        <article class="hm-feat" aria-labelledby="feat-inalambricos">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Micrófonos Inalámbricos</p>
            <h3 class="hm-feat__title" id="feat-inalambricos">Claridad de voz sin cables — para ceremonias, brindis y discursos que no pueden fallar</h3>
            <p class="hm-feat__lead">El momento del sí, acepto o del brindis del padrino no tiene repetición. Un micrófono confiable, con frecuencias limpias y respaldo, es lo que garantiza que cada palabra se escuche.</p>
            <p>
              Sistemas <strong>Shure SLX-D y QLXD</strong> con cápsulas SM58 y Beta 58A, y
              <strong>Sennheiser EW 100/300 G4</strong> con receptores UHF de banda ancha.
              Alcance efectivo de <strong>100 metros sin interferencias</strong>, frecuencias
              coordinadas automáticamente y baterías con duración de 8+ horas. Perfectos para
              <strong>ceremonias religiosas y civiles, brindis y discursos corporativos</strong>.
            </p>
            <p>
              Cada sistema incluye <strong>receptor de rack, antenas direccionales y unidad de
              respaldo</strong> lista para activarse al instante. Nuestro ingeniero configura
              las frecuencias para evitar interferencias con otros equipos del venue. Combínalos
              con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para
              cobertura de audio completa.
            </p>
            <ul class="hm-feat__stats">
              {["Shure SLX-D / QLXD", "Sennheiser EW G4", "UHF 100 m", "8+ h batería", "Respaldo incluido"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/audiovisual/microfonos-dj/inalambricos/">
              Ver Micrófonos Inalámbricos
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/audiovisual/microfono-inalambrico-shure-conferencia-evento.avif" alt="Micrófono inalámbrico Shure para ceremonia y discursos en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/audiovisual/microfono-solapa-diadema-conferencista.avif" alt="Micrófono inalámbrico y de solapa para evento" loading="lazy" decoding="async" />
              <img src="/images/audiovisual/equipo-audiovisual-completo-boda.avif" alt="Micrófonos inalámbricos en montaje audiovisual para boda" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- SOLAPA Y DIADEMA -->
        <article class="hm-feat" aria-labelledby="feat-solapa-diadema">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Micrófono de Solapa y Diadema</p>
            <h3 class="hm-feat__title" id="feat-solapa-diadema">Audio discreto y manos libres — el estándar para presentadores y paneles</h3>
            <p class="hm-feat__lead">Cuando el orador necesita moverse, gesticular o no quiere un micrófono en cámara, la solapa y la diadema son la respuesta. Audio continuo sin sostener nada.</p>
            <p>
              Los <strong>micrófonos de solapa (lavalier)</strong> —<strong>Sennheiser ME2-II</strong>
              y <strong>Shure MX150</strong>— se sujetan discretamente con body pack ultraligero
              oculto en cinturón o bolsillo. Audio nítido sin que el micrófono sea visible en
              cámara, perfecto para <strong>conferencias, paneles y eventos híbridos con
              transmisión en vivo</strong>.
            </p>
            <p>
              Las <strong>diademas (headset)</strong> se colocan junto a la boca con cápsula
