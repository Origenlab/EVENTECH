---
/**
 * ─── Micrófonos y DJ para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Micrófonos y Equipo DJ para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProductCard from "@components/ProductCard.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import Gallery4x4 from "@components/Gallery4x4.astro";
import PricingCards from "@components/PricingCards.astro";
import FaqSection from "@components/FaqSection.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Micrófonos y DJ" },
];

const MICROFONOS = [
  {
    name: "Micrófonos Inalámbricos",
    price: "Desde $300",
    excerpt: "Shure SLX-D y Sennheiser EW de mano con receptor UHF. Alcance 100 m, audio sin interferencias para ceremonias, brindis y discursos en bodas y XV años.",
    href: "/servicios/audiovisual/microfonos-dj/inalambricos/",
    image: "/images/audiovisual/microfono-inalambrico-shure-conferencia-evento.avif",
    tags: ["Shure SLX-D", "Sennheiser EW", "UHF", "100 m", "Bodas"],
    badge: "Más popular",
  },
  {
    name: "Micrófono de Solapa y Diadema",
    price: "Desde $400",
    excerpt: "Lavalier y headset profesionales para maestros de ceremonias y conferencistas. Audio discreto y manos libres durante toda la presentación.",
    href: "/servicios/audiovisual/microfonos-dj/solapa-diadema/",
    image: "/images/audiovisual/microfono-solapa-diadema-conferencista.avif",
    tags: ["Lavalier", "Headset", "Manos libres", "Congresos", "MC"],
  },
  {
    name: "Equipo DJ Completo",
    price: "Desde $3,500",
    excerpt: "Pioneer CDJ-3000 + DJM-900 Nexus + monitores de referencia. El setup que usan los mejores DJs de bodas en CDMX. Llegan y conectan.",
    href: "/servicios/audiovisual/microfonos-dj/equipo-dj/",
    image: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif",
    tags: ["Pioneer CDJ-3000", "DJM-900", "Monitores", "Bodas", "Fiestas"],
  },
  {
    name: "Cabina DJ Iluminada",
    price: "Desde $2,500",
    excerpt: "Estructura de truss con LEDs RGB integrados y facia personalizable con tu logo o tema. Transforma el rincón del DJ en el centro visual de la fiesta.",
    href: "/servicios/audiovisual/microfonos-dj/cabina-dj/",
    image: "/images/audiovisual/equipo-audiovisual-completo-boda.avif",
    tags: ["LED RGB", "Truss", "Branding", "Personalizable"],
  },
];

const faqs = [
  { question: "¿Cuántos micrófonos inalámbricos necesito?", answer: "Para ceremonias religiosas o civiles recomendamos 1 a 2 micrófonos (oficiante y pareja). En eventos corporativos con panel de discusión, de 2 a 4 micrófonos según el número de panelistas. Para brindis y discursos sociales, 1 micrófono es suficiente. Siempre incluimos unidades de respaldo en cada renta para garantizar audio sin interrupciones durante todo tu evento." },
  { question: "¿Qué diferencia hay entre micrófono de mano, solapa y diadema?", answer: "El micrófono de mano es ideal para discursos, brindis y momentos puntuales donde el orador lo sostiene. El micrófono de solapa (lavalier) se sujeta en la solapa del saco o blusa, perfecto para conferencias, paneles y entrevistas donde necesitas audio continuo sin sostener nada. La diadema (headset) se coloca en la oreja y queda frente a la boca, ideal para maestros de ceremonias, presentadores y animadores que necesitan las manos completamente libres. Cada tipo tiene su caso de uso óptimo y nuestro ingeniero de audio te recomienda el adecuado." },
  { question: "¿El equipo de DJ incluye DJ?", answer: "No, la renta es únicamente del equipo profesional: tornamesas, controladores, mixer, monitores y cableado. Proporcionamos el setup completo listo para operar. Si necesitas recomendación de DJ, te conectamos con nuestros DJs asociados de confianza con experiencia comprobada en bodas, fiestas y eventos corporativos. También trabajamos sin problema con tu propio DJ — solo necesita llegar y conectarse." },
  { question: "¿La cabina DJ incluye iluminación?", answer: "Sí, nuestras cabinas DJ incluyen tiras LED RGB integradas en la estructura, opción de proyección de logo en la facia frontal, e integración con el diseño de iluminación general de tu evento. Disponibles en acabado blanco, negro y con branding personalizado (viniles o impresión en tela). La iluminación LED se controla de forma independiente o sincronizada con la música." },
  { question: "¿Se pueden combinar micrófonos con el sistema de sonido?", answer: "Sí, todos nuestros micrófonos son 100% compatibles con nuestros sistemas de sonido profesional. La integración es completamente transparente a través de nuestro ingeniero de audio, quien configura las frecuencias, ecualización y niveles para cada micrófono en el sistema. Si ya cuentas con equipo de sonido propio o de otro proveedor, nuestros micrófonos también se conectan sin problema vía XLR o receptor UHF estándar." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación para micrófonos y equipo estándar. El equipo Pioneer CDJ-3000 y las cabinas DJ premium tienen alta demanda, por lo que en temporada alta (noviembre a febrero) sugerimos apartar con al menos 1 mes de anticipación. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Micrófonos y Equipo DJ CDMX",
    description: "Micrófonos inalámbricos Shure y Sennheiser, equipo DJ Pioneer CDJ-3000, cabinas DJ iluminadas. Ingeniero de audio incluido.",
    url: "/servicios/audiovisual/microfonos-dj/",
    priceRange: { min: 300, max: 12000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Micrófonos y DJ", url: "/servicios/audiovisual/microfonos-dj/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Micrófonos y Equipo DJ CDMX"
  description="Renta de micrófonos inalámbricos Shure y Sennheiser, equipo DJ Pioneer CDJ-3000 y cabinas DJ iluminadas para eventos en CDMX. Ingeniero de audio incluido."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Audio claro y fiesta garantizada"
    title='Renta de <span class="highlight">Micrófonos y DJ</span> para Eventos en CDMX'
    subtitle="Micrófonos inalámbricos profesionales Shure y Sennheiser para ceremonias y discursos, más equipo DJ Pioneer de última generación para la mejor fiesta. Ingeniero de audio dedicado en cada evento."
    primaryCTA={{ label: "Cotiza tu equipo", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar micrófonos y equipo DJ para mi evento` }}
    cards={[
      {
        title: "Micrófonos profesionales para cada momento de tu evento",
        content: "<strong>Renta de micrófonos inalámbricos para eventos</strong> con las marcas líderes de la industria del audio profesional. Sistemas Shure BLX y QLXD con receptores UHF de alta fidelidad y alcance de 100 metros para ceremonias religiosas, brindis y discursos corporativos. Micrófonos de solapa Sennheiser ME2 y diademas Shure MX para presentadores, panelistas y maestros de ceremonias que necesitan audio discreto y manos libres — cada sistema con baterías de respaldo y frecuencias coordinadas para cero interferencias.",
      },
      {
        title: "Equipo DJ Pioneer para producciones de primer nivel",
        content: "<strong>Setup DJ profesional</strong> con el equipo más solicitado por los mejores DJs del mundo. Tornamesas Pioneer CDJ-3000 con pantalla táctil de 9 pulgadas, controladores DDJ-1000 para sets versátiles, mixer DJM-900NXS2 con efectos integrados y monitores de referencia KRK y JBL para mezcla precisa. Cabinas DJ con estructura de truss, iluminación LED integrada y facias personalizables — todo instalado, cableado y listo para que tu DJ solo llegue y conecte.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas audio profesional y música para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con el equipo ideal para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de equipo
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Micrófonos y DJ"
        subtitle="Audio profesional y entretenimiento para cada tipo de evento"
        description={[
          "Desde micrófonos inalámbricos para ceremonias íntimas hasta setups DJ completos para fiestas de 1,000 personas. Contamos con el inventario de equipo de audio y DJ más completo de la Ciudad de México.",
          "Cada equipo incluye cableado profesional, configuración técnica e ingeniero de audio dedicado. Marcas certificadas Shure, Sennheiser y Pioneer para garantizar la mejor calidad de sonido."
        ]}
      />

      <div class="grid grid--4">
        {MICROFONOS.map((mic) => (
          <ProductCard
            name={mic.name}
            price={mic.price}
            excerpt={mic.excerpt}
            href={mic.href}
            image={mic.image}
            tags={mic.tags}
            badge={mic.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MICRÓFONOS INALÁMBRICOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="inalambricos-heading">
    <div class="container">
      <ServiceShowcase
    title="Micrófonos Inalámbricos"
    headingId="inalambricos-heading"
    badge="Claridad de voz"
    subtitle="Audio cristalino de grado profesional para ceremonias, brindis y discursos en eventos de cualquier tamaño."
    tags={["Shure BLX/QLXD", "Sennheiser EW G4", "UHF 100m", "Respaldo incluido"]}
    ctaHref="/servicios/audiovisual/microfonos-dj/inalambricos/"
    ctaLabel="Ver Micrófonos Inalámbricos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>micrófonos inalámbricos profesionales</strong> incluyen los sistemas más confiables de la industria: <strong>Shure BLX288 y QLXD24</strong> con cápsulas SM58 y Beta 58A, y <strong>Sennheiser EW 100/300 G4</strong> con receptores UHF de banda ancha. Alcance efectivo de <strong>100 metros sin interferencias</strong>, frecuencias coordinadas automáticamente y baterías AA con duración de 8+ horas. Perfectos para <strong>ceremonias religiosas, bodas civiles, brindis y discursos corporativos</strong> donde la claridad de voz es esencial.</p>
      <p class="showcase__text">Cada sistema incluye <strong>receptor de rack, antenas direccionales y unidad de respaldo</strong> lista para activarse al instante. Nuestro ingeniero de audio configura las frecuencias para evitar interferencias con otros equipos inalámbricos del venue. Combínalos con nuestro <a href="/servicios/audiovisual/">sonido profesional</a> para una cobertura de audio completa en tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SOLAPA Y DIADEMA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="solapa-heading">
    <div class="container">
      <ServiceShowcase
    title="Micrófonos de Solapa y Diadema"
    headingId="solapa-heading"
    badge="Audio discreto"
    subtitle="La solución manos libres para presentadores, maestros de ceremonias y panelistas profesionales."
    tags={["Sennheiser ME2", "Shure MX150", "Body Pack", "Manos libres"]}
    ctaHref="/servicios/audiovisual/microfonos-dj/solapa-diadema/"
    ctaLabel="Ver Solapa y Diadema"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>micrófonos de solapa (lavalier)</strong> son el estándar profesional para conferencias, paneles de discusión y entrevistas. Nuestro inventario incluye <strong>Sennheiser ME2-II</strong> con cápsula omnidireccional y <strong>Shure MX150</strong> con cápsula subminiatura, ambos con body pack transmisor ultraligero que se oculta en el cinturón o bolsillo. Audio nítido sin que el micrófono sea visible en cámara — perfecto para <strong>eventos híbridos con transmisión en vivo</strong>.</p>
      <p class="showcase__text">Las <strong>diademas profesionales (headset)</strong> son ideales para maestros de ceremonias, animadores y presentadores que necesitan <strong>las manos completamente libres</strong> mientras se mueven por el escenario. Cápsula cardioide posicionada junto a la boca para rechazo máximo de ruido ambiente. Incluyen body pack, clip de sujeción ajustable y color de diadema en tono piel para discreción total. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario ejecutivo</a> para conferencias y paneles de primer nivel.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
              <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EQUIPO DJ — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="dj-heading">
    <div class="container">
      <ServiceShowcase
    title="Equipo DJ Completo"
    headingId="dj-heading"
    badge="Setup profesional"
    subtitle="El setup Pioneer de grado profesional que los mejores DJs exigen para fiestas y eventos memorables."
    tags={["Pioneer CDJ-3000", "DDJ-1000", "DJM-900NXS2", "KRK / JBL"]}
    ctaHref="/servicios/audiovisual/microfonos-dj/equipo-dj/"
    ctaLabel="Ver Equipo DJ"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestro <strong>equipo DJ profesional</strong> incluye el hardware más solicitado en la industria: <strong>Pioneer CDJ-3000</strong> con pantalla táctil HD de 9 pulgadas, análisis de tracks en tiempo real y conectividad USB/SD/WiFi. <strong>Controladores DDJ-1000</strong> con jog wheels de tamaño completo para DJs que prefieren setup compacto. Mixer <strong>DJM-900NXS2</strong> con 4 canales, efectos Beat FX integrados y doble puerto USB para transiciones entre DJs sin interrupciones.</p>
      <p class="showcase__text">Complementamos con <strong>monitores de referencia KRK Rokit 8 y JBL 308P</strong> posicionados en la cabina para que el DJ escuche su mezcla con precisión. Todo el cableado es profesional <strong>XLR y RCA blindado</strong>, con regletas de energía reguladas y protección contra picos. Nuestro técnico instala, configura y verifica todo antes del evento. Combínalo con nuestras <a href="/servicios/pistas-baile/">pistas de baile</a> para crear la zona de fiesta perfecta.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="5.5" cy="17.5" r="2.5"/>
              <circle cx="17.5" cy="15.5" r="2.5"/>
              <path d="M8 17V5l12-2v10"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CABINA DJ — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cabina-heading">
    <div class="container">
      <ServiceShowcase
    title="Cabina DJ Iluminada"
    headingId="cabina-heading"
    badge="El centro de la fiesta"
    subtitle="Estructura profesional con iluminación LED y branding personalizable que eleva la experiencia visual de tu evento."
    tags={["Truss aluminio", "LED RGB", "Branding custom", "Logo projection"]}
    ctaHref="/servicios/audiovisual/microfonos-dj/cabina-dj/"
    ctaLabel="Ver Cabina DJ"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>cabinas DJ profesionales</strong> están construidas con <strong>estructura de truss de aluminio</strong> reforzado, facias frontales y laterales intercambiables, y espacio amplio para todo el equipo técnico: tornamesas, mixer, monitores, laptop y controladores de iluminación. Disponibles en <strong>acabado blanco, negro y con branding personalizado</strong> mediante viniles impresos o tela tensada con el logo de tu evento, marca o temática de la fiesta.</p>
      <p class="showcase__text">La iluminación LED viene <strong>integrada en la estructura</strong> con tiras RGB programables en la base, bordes y facia frontal. Opción de <strong>proyección de logo o monograma</strong> en la superficie frontal y sincronización con la música para efectos reactivos al beat. La cabina se convierte en el <strong>punto focal visual de la pista de baile</strong>. Combínala con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para un diseño de luz integral en todo tu evento.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
              <path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/>
              <line x1="12" y1="12" x2="12" y2="16"/>
              <line x1="10" y1="14" x2="14" y2="14"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo luce nuestro equipo de micrófonos y DJ?</h2>
      <Gallery4x4 images={[
        { src: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif", alt: "Cabina DJ profesional para boda en CDMX" },
        { src: "/images/audiovisual/equipo-audiovisual-completo-boda.avif", alt: "Equipo audiovisual completo para boda" },
        { src: "/images/audiovisual/microfono-inalambrico-shure-conferencia-evento.avif", alt: "Micrófono inalámbrico Shure para conferencia" },
        { src: "/images/audiovisual/microfono-solapa-diadema-conferencista.avif", alt: "Micrófono de solapa y diadema para conferencista" },
        { src: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif", alt: "Monitor pantalla presentación congreso" },
        { src: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif", alt: "Pantalla LED videowall evento corporativo" },
        { src: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif", alt: "Proyector 4K pantalla gigante evento" },
        { src: "/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif", alt: "Sistema audio JBL evento corporativo" },
      ]} />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="paquetes-heading">
    <div class="container">
      <h2 id="paquetes-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 0.5rem;">¿Cuánto cuesta rentar micrófonos y equipo DJ?</h2>
      <p style="color: var(--color-text-light); margin-bottom: 2rem; max-width: 60ch;">Precios referenciales por evento (+IVA). Incluye entrega y montaje en CDMX.</p>
      <PricingCards packages={[
        {
          name: "Básico",
          price: "$800",
          priceNote: "por evento",
          description: "1-2 micrófonos para ceremonias y brindis.",
          features: [
            { text: "2 micrófonos inalámbricos", included: true },
            { text: "Receptor y baterías", included: true },
            { text: "Equipo DJ", included: false },
            { text: "Cabina DJ", included: false },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Estándar",
          badge: "Más popular",
          highlight: true,
          price: "$1,500",
          priceNote: "por evento",
          description: "Micrófonos + equipo DJ básico.",
          features: [
            { text: "3 micrófonos (mano + solapa)", included: true },
            { text: "Controlador DDJ-1000", included: true },
            { text: "Monitores de referencia", included: true },
            { text: "Ingeniero de audio", included: true },
          ],
          ctaHref: "/cotizar/",
        },
        {
          name: "Premium",
          price: "$2,800",
