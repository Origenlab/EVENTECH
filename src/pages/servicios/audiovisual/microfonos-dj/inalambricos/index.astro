---
/**
 * ─── Micrófonos Inalámbricos — Pagina de Producto (Nivel 4) ───
 * Micrófonos inalámbricos Shure BLX, QLXD y Sennheiser EW G4
 * con receptor UHF y alcance 100m para bodas y corporativos.
 *
 * Jerarquia: Servicios > Audiovisual > Micrófonos y DJ > Micrófonos Inalámbricos
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Micrófonos y DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { label: "Micrófonos Inalámbricos" },
];

const faqs = [
  { question: "¿Qué diferencia hay entre los micrófonos Shure y Sennheiser?", answer: 'Ambas marcas son referencia mundial en audio profesional. Los <strong>Shure BLX288 y QLXD24</strong> destacan por su robustez, frecuencias estables y cápsulas SM58/Beta 58A con presencia vocal excepcional — son los preferidos para bodas y ceremonias. Los <strong>Sennheiser EW 100/300 G4</strong> ofrecen un sonido más natural y cálido, con receptores de escaneo automático ideales para conferencias y eventos corporativos. Nuestro ingeniero de audio te recomienda la marca ideal según tu tipo de evento y venue.' },
  { question: "¿Cuántos micrófonos inalámbricos necesito para mi evento?", answer: 'Depende del tipo de evento. Para <strong>bodas y ceremonias</strong> recomendamos 2 micrófonos (oficiante y pareja). Para <strong>brindis y discursos sociales</strong>, 1 micrófono es suficiente. En <strong>paneles y mesas redondas</strong> corporativas, de 3 a 6 micrófonos según el número de participantes. Siempre incluimos una <strong>unidad de respaldo</strong> en cada renta para garantizar audio continuo sin interrupciones.' },
  { question: "¿Puede haber interferencias con otros equipos inalámbricos?", answer: 'No con nuestros sistemas. Tanto Shure como Sennheiser utilizan <strong>frecuencias UHF de banda ancha</strong> con tecnología de escaneo automático que detecta y evita frecuencias congestionadas. Nuestro ingeniero de audio realiza un <strong>barrido de frecuencias</strong> antes del evento para coordinar todos los canales inalámbricos del venue, incluyendo equipos de otros proveedores. El resultado es audio limpio y sin cortes durante todo tu evento.' },
  { question: "¿Los micrófonos inalámbricos funcionan en exteriores?", answer: 'Sí, nuestros micrófonos inalámbricos funcionan perfectamente en <strong>jardines, terrazas y venues al aire libre</strong>. El alcance de 100 metros se mantiene en espacios abiertos. Para eventos exteriores recomendamos los modelos con <strong>antenas direccionales</strong> que mejoran la recepción y estabilidad de la señal. Si tu evento es en jardín, hacienda o terraza, nuestro ingeniero posiciona el receptor estratégicamente para máxima cobertura.' },
  { question: "¿Se pueden combinar con un sistema de sonido profesional?", answer: 'Sí, todos nuestros micrófonos son <strong>100% compatibles</strong> con cualquier sistema de sonido profesional. La conexión es directa vía <strong>XLR balanceado</strong> desde el receptor al mixer o sistema de amplificación. Nuestro ingeniero configura niveles, ecualización y compresión para cada micrófono. Si rentas nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a>, la integración es transparente y el ingeniero gestiona todo el audio desde una sola consola.' },
  { question: "¿Con cuánta anticipación debo reservar mis micrófonos?", answer: 'Recomendamos reservar con <strong>2 a 3 semanas de anticipación</strong> para garantizar disponibilidad. Los sistemas Shure QLXD24 y los kits multi-micrófono son los más solicitados, especialmente en <strong>temporada alta (noviembre a febrero)</strong>. Para eventos corporativos con múltiples micrófonos o configuraciones especiales, lo ideal es apartar con <strong>1 mes de anticipación</strong>. También atendemos solicitudes de último momento sujetas a disponibilidad.' },
];

const specs = [
  { label: "Marcas", value: "Shure BLX, QLXD / Sennheiser EW G4" },
  { label: "Tipo", value: "De mano, cardioide" },
  { label: "Frecuencia", value: "UHF banda ancha" },
  { label: "Alcance", value: "100 metros sin interferencias" },
  { label: "Batería", value: "AA, 8+ horas de duración" },
  { label: "Cápsulas", value: "SM58, Beta 58A, e835" },
  { label: "Receptor", value: "Rack montable, auto-scan" },
  { label: "Respaldo", value: "Unidad de respaldo incluida" },
  { label: "Conectividad", value: "XLR / salida de audio balanceada" },
  { label: "Ingeniero", value: "Incluido durante todo el evento" },
];

const sidebarNav = [
  { name: "Micrófonos Inalámbricos", href: null, active: true },
  { name: "Solapa y Diadema", href: "/servicios/audiovisual/microfonos-dj/solapa-diadema/" },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
  { name: "Cabina DJ", href: "/servicios/audiovisual/microfonos-dj/cabina-dj/" },
];

const sidebarRelated = [
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Proyectores", href: "/servicios/audiovisual/proyectores/" },
  { name: "Carpas", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Fernanda Martínez", text: "Rentamos 2 micrófonos Shure BLX para la ceremonia de nuestra boda en un jardín de Coyoacán. El audio fue cristalino, se escuchó perfecto en todo el jardín. El ingeniero coordinó todo con el DJ y no hubo un solo problema. Los invitados nos felicitaron por la calidad del sonido.", rating: 5, date: "2025-11-20" },
  { author: "Dr. Ricardo Valdés", text: "Para nuestro congreso médico en un hotel de Polanco necesitábamos 4 micrófonos inalámbricos simultáneos para los panelistas. El equipo Sennheiser G4 funcionó impecable durante 3 días de conferencias. Cero interferencias, audio profesional y el ingeniero siempre atento. Excelente servicio.", rating: 5, date: "2025-10-12" },
  { author: "Alejandra Ruiz", text: "Contratamos un micrófono inalámbrico Shure para los brindis de nuestra gala corporativa. La calidad fue excepcional, el ingeniero lo entregó configurado y listo para usar. Además llevaron unidad de respaldo que nos dio total tranquilidad. Muy profesionales.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Micrófonos Inalámbricos para Eventos en CDMX",
    description: "Renta de micrófonos inalámbricos Shure BLX, QLXD y Sennheiser EW G4 con receptor UHF y alcance 100m para bodas y corporativos en CDMX. Ingeniero incluido. Desde $300.",
    url: "/servicios/audiovisual/microfonos-dj/inalambricos/",
    priceRange: { min: 300, max: 3000 },
    reviews,
    ratingValue: 5,
    reviewCount: 245,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Micrófonos y DJ", url: "/servicios/audiovisual/microfonos-dj/" },
    { name: "Micrófonos Inalámbricos", url: "/servicios/audiovisual/microfonos-dj/inalambricos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Micrófonos Inalámbricos para Eventos en CDMX"
  description="Renta de micrófonos inalámbricos Shure BLX, QLXD y Sennheiser EW G4 con receptor UHF y alcance 100m para bodas y corporativos en CDMX. Ingeniero incluido. Desde $300."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Audio cristalino para ceremonias y discursos"
    title='Renta de <span class="highlight">Micrófonos Inalámbricos</span> para Eventos en CDMX'
    subtitle="Micrófonos inalámbricos profesionales Shure BLX, QLXD y Sennheiser EW G4 con receptor UHF, alcance de 100 metros y baterías de 8+ horas. Ingeniero de audio dedicado en cada evento."
    primaryCTA={{ label: "Cotiza tu micrófono", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar micrófonos inalámbricos para mi evento` }}
    cards={[
      {
        title: "Shure y Sennheiser con receptor UHF y alcance 100 metros",
        content: "<strong>Renta de micrófonos inalámbricos profesionales</strong> con las marcas líderes de la industria del audio. Sistemas Shure BLX288 y QLXD24 con cápsulas SM58 y Beta 58A de presencia vocal excepcional, y Sennheiser EW 100/300 G4 con sonido natural y cálido. Frecuencia UHF de banda ancha con alcance efectivo de 100 metros sin interferencias y baterías AA con duración de 8+ horas. Ideales para ceremonias religiosas, bodas civiles, brindis, discursos corporativos y paneles de discusión.",
      },
      {
        title: "Receptor de rack, respaldo e ingeniero de audio incluido",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de micrófonos inalámbricos. Receptor de rack montable con escaneo automático de frecuencias, antenas direccionales para máxima cobertura y unidad de respaldo lista para activarse al instante. Nuestro ingeniero de audio se encarga de la configuración de frecuencias, ecualización, monitoreo en tiempo real y coordinación con el sistema de sonido del venue. Audio profesional sin complicaciones de inicio a fin.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas audio cristalino para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el micrófono ideal para tu ceremonia o conferencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Micrófonos y DJ para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas micrófonos inalámbricos para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar micrófonos inalámbricos para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Micrófonos Inalámbricos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Shure BLX288 Dual -->
          <section class="section section--alt" aria-labelledby="shure-blx288-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para ceremonias y brindis</span>
                <h2 class="showcase__title" id="shure-blx288-heading">Shure BLX288 Dual</h2>
                <p class="showcase__subtitle">Dos micrófonos de mano con receptor dual para ceremonias, brindis y discursos simultáneos.</p>
                <p class="showcase__text">El <strong>Shure BLX288</strong> es nuestro sistema dual más solicitado para <strong>bodas y eventos sociales</strong> en la Ciudad de México. Incluye dos micrófonos de mano con cápsulas SM58 de presencia vocal excepcional y un receptor dual que gestiona ambos canales simultáneamente. Frecuencia UHF con alcance de 100 metros, escaneo automático de frecuencias y baterías AA con duración de 8+ horas por micrófono. Perfecto para <strong>ceremonias religiosas donde el oficiante y la pareja necesitan micrófono</strong>, o para brindis donde el padre de la novia y el padrino hablan en secuencia.</p>
                <p class="showcase__text">Cada sistema incluye <strong>receptor de rack, antenas direccionales y cables XLR</strong> para conexión directa al sistema de sonido del venue. Nuestro ingeniero configura las frecuencias para evitar interferencias y ecualiza cada micrófono para la voz del orador. Incluimos siempre una <strong>unidad de respaldo</strong> lista para activarse al instante. Combínalo con nuestro <a href="/servicios/audiovisual/sonido/">sonido profesional</a> para una cobertura de audio completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">2 micrófonos</span>
                  <span class="showcase__tag">Cápsula SM58</span>
                  <span class="showcase__tag">Receptor dual</span>
                  <span class="showcase__tag">Bodas y ceremonias</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Shure BLX288 Dual
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Shure BLX288 Dual</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Shure QLXD24 Premium -->
          <section class="section section--alt" aria-labelledby="shure-qlxd24-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Gama alta para producciones exigentes</span>
                <h2 class="showcase__title" id="shure-qlxd24-heading">Shure QLXD24 Premium</h2>
                <p class="showcase__subtitle">El sistema inalámbrico de gama alta con cápsula Beta 58A para la máxima calidad vocal.</p>
                <p class="showcase__text">El <strong>Shure QLXD24</strong> es nuestro sistema premium para <strong>producciones de primer nivel</strong> y eventos donde la calidad de audio es prioridad absoluta. Equipado con cápsula <strong>Beta 58A supercardioide</strong> que ofrece un rango dinámico superior, mayor rechazo de ruido ambiente y una respuesta en frecuencia extendida que captura cada matiz de la voz. Receptor digital con procesamiento de 24 bits y latencia imperceptible — el estándar profesional para <strong>galas corporativas, congresos médicos y producciones televisivas</strong>.</p>
                <p class="showcase__text">El receptor QLXD4 incluye <strong>pantalla LCD a color</strong> con indicadores de nivel, estado de batería y calidad de señal en tiempo real. Escaneo de espectro para encontrar frecuencias limpias automáticamente y encriptación AES-256 para seguridad de audio. Con <strong>alcance de 100 metros</strong> y batería recargable de 10+ horas, es ideal para eventos de larga duración. Combínalo con nuestros <a href="/servicios/audiovisual/proyectores/">proyectores</a> para presentaciones corporativas completas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Beta 58A</span>
                  <span class="showcase__tag">Digital 24-bit</span>
                  <span class="showcase__tag">AES-256</span>
                  <span class="showcase__tag">Gama alta</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Shure QLXD24 Premium
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Shure QLXD24 Premium</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Sennheiser EW 100 G4 -->
          <section class="section section--alt" aria-labelledby="sennheiser-ew100-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Versatilidad europea para conferencias</span>
                <h2 class="showcase__title" id="sennheiser-ew100-heading">Sennheiser EW 100 G4</h2>
                <p class="showcase__subtitle">El sistema inalámbrico europeo con sonido natural y cálido para conferencias y eventos corporativos.</p>
                <p class="showcase__text">El <strong>Sennheiser EW 100 G4</strong> es la referencia europea en microfonía inalámbrica para <strong>conferencias, congresos y eventos corporativos</strong>. Su cápsula e835 cardioide ofrece un sonido natural y cálido que reproduce la voz con fidelidad excepcional, sin coloración artificial. Receptor con <strong>escaneo automático de frecuencias</strong> que encuentra canales limpios al instante, sincronización infrarroja con el transmisor y display OLED con información detallada de señal y batería.</p>
                <p class="showcase__text">Con un rango de conmutación de hasta <strong>42 MHz</strong>, el EW 100 G4 permite operar múltiples sistemas simultáneos sin interferencias — ideal para <strong>paneles de discusión, mesas redondas y conferencias con múltiples ponentes</strong>. La construcción en metal garantiza durabilidad profesional y el body pack opcional permite convertirlo en sistema de solapa. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario ejecutivo</a> para conferencias de primer nivel.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Sennheiser e835</span>
                  <span class="showcase__tag">42 MHz rango</span>
                  <span class="showcase__tag">OLED display</span>
                  <span class="showcase__tag">Conferencias</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Sennheiser EW 100 G4
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
