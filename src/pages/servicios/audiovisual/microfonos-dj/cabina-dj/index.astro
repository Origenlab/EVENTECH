---
/**
 * ─── Cabina DJ Iluminada — Pagina de Producto (Nivel 4) ───
 * Cabina DJ profesional con estructura de truss, LED RGB
 * integrado y branding personalizable para fiestas y eventos.
 *
 * Jerarquia: Servicios > Audiovisual > Micrófonos y DJ > Cabina DJ
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual", href: "/servicios/audiovisual/" },
  { label: "Micrófonos y DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { label: "Cabina DJ" },
];

const faqs = [
  { question: "¿La cabina incluye equipo DJ o es solo la estructura?", answer: 'La renta de cabina incluye <strong>únicamente la estructura, iluminación LED y facia</strong>. El equipo DJ (tornamesas, mixer, monitores) se renta por separado. Ofrecemos <strong>paquetes combinados Cabina + Equipo DJ</strong> con descuento especial que incluyen todo listo para usar. También puedes rentar solo la cabina si tu DJ trae su propio equipo — nuestro técnico verifica que todo quepa y funcione correctamente dentro de la estructura.' },
  { question: "¿Se puede personalizar la cabina con mi logo o diseño?", answer: 'Sí, la personalización es una de las ventajas principales de nuestras cabinas. Ofrecemos <strong>viniles impresos de alta resolución</strong> que se adhieren a la facia frontal y laterales, y <strong>tela tensada con impresión directa</strong> para un acabado premium. Puedes colocar el logo de tu empresa, monograma de la pareja (bodas), XV años o cualquier diseño gráfico. Necesitamos el archivo en alta resolución <strong>5 días hábiles antes del evento</strong> para producción. También ofrecemos proyección de logo en la facia para cambios dinámicos.' },
  { question: "¿Cuánto tiempo tarda el montaje de la cabina?", answer: 'El montaje completo toma aproximadamente <strong>2 horas</strong>. Nuestro equipo llega con tiempo suficiente para ensamblar la estructura de truss, instalar las facias, conectar la iluminación LED, hacer pruebas de color y sincronización, y posicionar el equipo DJ dentro de la cabina. Recomendamos <strong>acceso al venue 3 horas antes del evento</strong> para montaje completo sin prisas. El desmontaje toma aproximadamente 1 hora y está incluido en el servicio.' },
  { question: "¿La cabina cabe en cualquier espacio?", answer: 'Nuestras cabinas tienen dimensiones aproximadas de <strong>180 x 120 x 100 cm</strong> y son modulares para adaptarse a diferentes espacios. Necesitan un área plana de al menos <strong>2.5 x 2 metros</strong> considerando el espacio de circulación del DJ. Funcionan en salones, jardines (con piso nivelado), terrazas y cualquier superficie estable. Para venues con accesos reducidos, la cabina se ensambla en sitio — las piezas individuales pasan por puertas estándar.' },
  { question: "¿Se puede usar la cabina sin DJ?", answer: 'Sí, la cabina funciona como <strong>elemento decorativo y estación de música independiente</strong>. La iluminación LED opera de forma autónoma con patrones preprogramados o reactivos al audio del venue. Puedes usarla como punto focal decorativo, como <strong>estación de playlist</strong> conectando un dispositivo con música pregrabada, o como soporte visual para DJs virtuales o sets pregrabados. La facia con branding es un excelente recurso para eventos corporativos incluso sin DJ en vivo.' },
  { question: "¿La iluminación se puede sincronizar con la música?", answer: 'Sí, nuestras cabinas incluyen <strong>controlador DMX</strong> que permite sincronizar la iluminación LED con la música en tiempo real. El modo reactivo al beat detecta los graves y adapta los patrones de color automáticamente. También ofrecemos <strong>control independiente</strong> donde nuestro técnico programa secuencias de color específicas para momentos clave del evento: entrada del festejado, primer baile, hora loca, etc. Todo se gestiona desde un controlador dedicado sin depender del equipo DJ.' },
];

const specs = [
  { label: "Estructura", value: "Truss de aluminio reforzado" },
  { label: "Dimensiones", value: "180 x 120 x 100 cm aprox." },
  { label: "Facias", value: "Intercambiables: blanco, negro, branding custom" },
  { label: "Iluminación", value: "Tiras LED RGB en base, bordes y facia" },
  { label: "Proyección", value: "Logo o monograma en facia frontal" },
  { label: "Sincronización", value: "Reactiva al beat / control independiente" },
  { label: "Capacidad", value: "2 CDJ + mixer + laptop + controladores" },
  { label: "Personalización", value: "Viniles impresos / tela tensada con logo" },
  { label: "Montaje", value: "Incluido, 2 horas antes del evento" },
  { label: "Técnico", value: "Instalación y operación LED incluida" },
];

const sidebarNav = [
  { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/inalambricos/" },
  { name: "Solapa y Diadema", href: "/servicios/audiovisual/microfonos-dj/solapa-diadema/" },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
  { name: "Cabina DJ", href: null, active: true },
];

const sidebarRelated = [
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Ana y Luis", text: "Rentamos la cabina blanca con el monograma de nuestros nombres para la boda. Se veía espectacular, la iluminación LED cambiaba de colores con la música y todos los invitados se acercaban a tomarse fotos. El montaje fue rápido y discreto. Un toque premium que hizo la diferencia.", rating: 5, date: "2025-11-28" },
  { author: "Sofía Hernández", text: "Para los XV años de mi hija elegimos la cabina negra con LED. El DJ quedó encantado con el espacio y la iluminación reactiva al beat fue el hit de la noche. Los colores cambiaban con cada canción y creaba un ambiente increíble en la pista. Totalmente recomendable.", rating: 5, date: "2025-10-15" },
  { author: "Mkt. Director ACME Corp", text: "Contratamos la cabina con branding corporativo para nuestro evento de fin de año. La facia con nuestro logo en alta resolución se veía profesional y elegante. La proyección del logo alternaba con efectos de color. El técnico fue muy profesional y el montaje impecable.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Cabina DJ Iluminada para Eventos en CDMX",
    description: "Renta de cabina DJ profesional con estructura de truss, LED RGB integrado y branding personalizable para fiestas y eventos en CDMX. Desde $2,500.",
    url: "/servicios/audiovisual/microfonos-dj/cabina-dj/",
    priceRange: { min: 2500, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 178,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
    { name: "Micrófonos y DJ", url: "/servicios/audiovisual/microfonos-dj/" },
    { name: "Cabina DJ", url: "/servicios/audiovisual/microfonos-dj/cabina-dj/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Cabina DJ Iluminada para Eventos en CDMX"
  description="Renta de cabina DJ profesional con estructura de truss, LED RGB integrado y branding personalizable para fiestas y eventos en CDMX. Desde $2,500."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El punto focal de la pista de baile"
    title='Renta de <span class="highlight">Cabina DJ Iluminada</span> para Eventos en CDMX'
    subtitle="Cabina DJ profesional con estructura de truss de aluminio, iluminación LED RGB programable, facias intercambiables y branding personalizable. Montaje incluido 2 horas antes del evento."
    primaryCTA={{ label: "Cotiza tu cabina DJ", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una cabina DJ iluminada para mi evento` }}
    cards={[
      {
        title: "Truss de aluminio con facias intercambiables y espacio amplio",
        content: "<strong>Renta de cabina DJ profesional</strong> construida con estructura de truss de aluminio reforzado para máxima estabilidad y presencia visual. Facias frontales y laterales intercambiables en acabado blanco, negro o con branding personalizado mediante viniles impresos o tela tensada. Espacio interior amplio diseñado para alojar 2 tornamesas CDJ, mixer, laptop y controladores adicionales cómodamente. La cabina se convierte en el centro visual de la pista de baile.",
      },
      {
        title: "LED RGB programable con proyección de logo y sincronización musical",
        content: "<strong>Iluminación LED RGB integrada</strong> en la base, bordes y facia de la cabina con programación de colores y efectos visuales. Modo reactivo al beat que sincroniza los patrones de iluminación con la música en tiempo real. Opción de proyección de logo o monograma en la facia frontal para bodas, XV años y eventos corporativos. Controlador DMX independiente operado por nuestro técnico para secuencias personalizadas en momentos clave del evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres una cabina DJ que sea el centro de atención de tu fiesta?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el diseño ideal para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Micrófonos y DJ para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una cabina DJ iluminada para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una cabina DJ iluminada para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 7V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v3"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="10" y1="14" x2="14" y2="14"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Cabina DJ Iluminada</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Cabina Blanca -->
          <section class="section section--alt" aria-labelledby="cabina-blanca-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegante para bodas y galas</span>
                <h2 class="showcase__title" id="cabina-blanca-heading">Cabina Blanca</h2>
                <p class="showcase__subtitle">Acabado blanco elegante con LED RGB que transforma la pista de baile en bodas y galas premium.</p>
                <p class="showcase__text">Nuestra <strong>Cabina DJ Blanca</strong> es la elección favorita para <strong>bodas, galas corporativas y eventos elegantes</strong> donde la estética es tan importante como el sonido. La facia frontal en acabado blanco mate se integra armoniosamente con la decoración de cualquier venue, desde salones clásicos hasta jardines contemporáneos. La iluminación LED RGB en la base y bordes permite <strong>personalizar los colores</strong> para que coincidan con la paleta cromática de tu evento.</p>
                <p class="showcase__text">Ideal para complementar con <strong>proyección de monograma de la pareja</strong> en la facia frontal — un toque personal que impresiona a los invitados. Los colores LED cambian suavemente durante la cena y se vuelven más intensos y reactivos al beat durante la fiesta. Nuestro técnico programa secuencias específicas para <strong>momentos clave</strong>: entrada de los novios, primer baile, ramo, hora loca. Combínala con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un diseño de luz integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Blanco mate</span>
                  <span class="showcase__tag">LED personalizable</span>
                  <span class="showcase__tag">Monograma</span>
                  <span class="showcase__tag">Bodas premium</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cabina Blanca
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Cabina Blanca</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cabina Negra -->
          <section class="section section--alt" aria-labelledby="cabina-negra-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Discreta para eventos nocturnos</span>
                <h2 class="showcase__title" id="cabina-negra-heading">Cabina Negra</h2>
                <p class="showcase__subtitle">Acabado negro profesional que desaparece en la oscuridad y deja que la iluminación LED sea protagonista.</p>
                <p class="showcase__text">La <strong>Cabina DJ Negra</strong> es la opción preferida para <strong>fiestas, XV años, eventos nocturnos y clubs temporales</strong>. El acabado negro mate hace que la estructura <strong>desaparezca visualmente</strong> en ambientes oscuros, permitiendo que las tiras LED RGB sean el único elemento visible — creando un efecto flotante espectacular. Los colores brillan con mayor intensidad contra el fondo oscuro, generando contrastes visuales impactantes.</p>
                <p class="showcase__text">El modo reactivo al beat es particularmente efectivo en la cabina negra: los <strong>pulsos de color explotan desde la oscuridad</strong> sincronizados con cada golpe de bass, creando una experiencia inmersiva para la pista de baile. Programa secuencias de strobe, chase, fade y rainbow que transforman la cabina en el centro visual del evento. Ideal para combinar con nuestra <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> y <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> para una producción visual completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Negro mate</span>
                  <span class="showcase__tag">Efecto flotante</span>
                  <span class="showcase__tag">Reactivo al beat</span>
                  <span class="showcase__tag">Fiestas nocturnas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cabina Negra
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Cabina Negra</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Cabina Branding -->
          <section class="section section--alt" aria-labelledby="cabina-branding-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tu marca como protagonista</span>
                <h2 class="showcase__title" id="cabina-branding-heading">Cabina con Branding</h2>
                <p class="showcase__subtitle">Cabina personalizada con el logo y diseño de tu empresa o evento para máximo impacto de marca.</p>
                <p class="showcase__text">La <strong>Cabina con Branding</strong> convierte la estación del DJ en una <strong>pieza de comunicación visual</strong> para tu marca o evento. La facia frontal y paneles laterales se personalizan con impresión de alta resolución mediante viniles adhesivos o tela tensada. Reproduce fielmente los colores corporativos, logos, hashtags del evento y cualquier diseño gráfico que necesites. Ideal para <strong>lanzamientos de producto, eventos corporativos, activaciones de marca y festivales patrocinados</strong>.</p>
                <p class="showcase__text">La iluminación LED se programa para <strong>complementar los colores de tu marca</strong>, creando una experiencia visual coherente. Combinamos iluminación estática durante networking y cena, con efectos dinámicos durante la fiesta. Incluye opción de <strong>proyección de logo rotativo</strong> en la facia para máxima visibilidad. Necesitamos los archivos de diseño en alta resolución (AI, PSD o PDF a 300 DPI) <strong>5 días hábiles antes</strong> para producción. Combínala con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para cobertura de marca completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Logo impreso</span>
                  <span class="showcase__tag">Viniles HD</span>
                  <span class="showcase__tag">Colores corporativos</span>
                  <span class="showcase__tag">Eventos corporativos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cabina con Branding
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="23"/>
                    <line x1="8" y1="23" x2="16" y2="23"/>
                  </svg>
                  <span>Cabina con Branding</span>
                </div>
              </div>
            </div>
