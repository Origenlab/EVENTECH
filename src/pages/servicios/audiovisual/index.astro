---
/**
 * ─── Audiovisual Category Page ───
 * Página de categoría: Renta de Equipo Audiovisual para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const SUB_SERVICES = [
  {
    name: "Pantallas LED",
    excerpt: "Pantallas LED de alta resolución en múltiples tamaños. Ideales para bodas, congresos, presentaciones y conciertos.",
    cta: "Pantallas LED",
    href: "#pantallas-heading",
    icon: "speaker",
  },
  {
    name: "Sonido Profesional",
    excerpt: "Sistemas de audio line array, bocinas, subwoofers y mezcladoras. Potencia y claridad para cualquier espacio y audiencia.",
    cta: "Sonido Profesional",
    href: "#sonido-heading",
    icon: "music",
  },
  {
    name: "Proyectores y Video",
    excerpt: "Proyectores Full HD y 4K, cámaras de video, switchers y sistemas de streaming en vivo para eventos híbridos.",
    cta: "Proyectores",
    href: "#proyectores-heading",
    icon: "layers",
  },
  {
    name: "Micrófonos y DJ",
    excerpt: "Micrófonos inalámbricos, de solapa y diadema. Equipo completo de DJ con tornamesas, controladores y monitores.",
    cta: "Micrófonos y DJ",
    href: "#microfonos-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Qué tamaños de pantallas LED tienen disponibles?", answer: "Contamos con pantallas LED desde 55 pulgadas hasta videowall modular de hasta 6x3 metros. Para bodas y eventos sociales las pantallas de 75 a 85 pulgadas son las más populares. Para congresos y festivales ofrecemos pantallas gigantes modulares que se adaptan a cualquier dimensión." },
  { question: "¿El equipo incluye técnico de operación?", answer: "Sí. Todos nuestros paquetes de audio y video incluyen un técnico especializado que se encarga de la instalación, pruebas de sonido, operación durante el evento y desmontaje. Para eventos grandes asignamos un equipo técnico completo." },
  { question: "¿Qué sistema de sonido necesito según el tamaño de mi evento?", answer: "Para reuniones íntimas (hasta 50 personas) recomendamos bocinas amplificadas de 12 pulgadas. Para eventos medianos (50-200 personas) un sistema line array compacto. Para grandes eventos (200+ personas) o al aire libre, sistemas line array profesionales con subwoofers. Nuestro equipo te asesora según tu venue y número de asistentes." },
  { question: "¿Pueden hacer transmisión en vivo (streaming)?", answer: "Sí. Ofrecemos paquetes de streaming con cámaras HD, switcher de video, encoder profesional y conexión dedicada. Transmitimos a plataformas como YouTube, Zoom, Teams o cualquier otra. Ideal para eventos corporativos híbridos, conferencias y ceremonias religiosas." },
  { question: "¿Con cuánta anticipación debo reservar el equipo audiovisual?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta. Para eventos corporativos grandes o congresos con requerimientos técnicos específicos, lo ideal es apartar con 1 a 2 meses. También atendemos solicitudes de último momento sujetas a disponibilidad." },
  { question: "¿Realizan visita técnica previa al evento?", answer: "Sí, para eventos medianos y grandes realizamos una visita técnica al venue sin costo adicional. Evaluamos acústica del espacio, puntos de corriente, distancias de proyección y condiciones de iluminación para garantizar el mejor resultado técnico en tu evento." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo Audiovisual para Eventos en CDMX",
    description: "Pantallas LED, sonido profesional, proyectores y micrófonos para bodas, corporativos y congresos. Técnico incluido.",
    url: "/servicios/audiovisual/",
    priceRange: { min: 500, max: 50000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Equipo Audiovisual para Eventos en CDMX"
  description="Renta de pantallas LED, sonido profesional, proyectores y micrófonos para eventos en CDMX. Técnico de operación incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Tecnología de nivel profesional"
    title='Renta de <span class="highlight">Equipo Audiovisual</span> para Eventos'
    subtitle="Pantallas LED, sonido profesional, proyectores y micrófonos. Llevamos la tecnología de primer nivel directamente a tu evento con técnico de operación incluido."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo audiovisual para mi evento` }}
    cards={[
      {
        title: "Tecnología audiovisual de grado profesional",
        content: "<strong>Equipo audiovisual para eventos</strong> con estándares de producción profesional. Pantallas LED de alta resolución desde 55 pulgadas hasta videowall modulares de 6x3 metros, sistemas de sonido line array con cobertura uniforme para audiencias de 50 a 5,000+ personas, proyectores Full HD y 4K con hasta 10,000 lúmenes, y micrófonos inalámbricos Shure y Sennheiser. Cada equipo es calibrado y probado antes de cada evento para garantizar rendimiento impecable.",
      },
      {
        title: "Técnico especializado y soporte completo",
        content: "<strong>Servicio técnico profesional</strong> incluido en cada renta audiovisual. Un ingeniero de audio y video dedicado se encarga de la instalación, pruebas de sonido, ecualización según la acústica de tu venue y operación durante todo el evento. Cableado oculto, distribución limpia y monitoreo en tiempo real para que tu conferencia, boda o festival suene y se vea perfecto desde el primer minuto hasta el último.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para un evento con sonido e imagen impecables?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica personalizada para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo Audiovisual"
        subtitle="Tecnología profesional para cada tipo de evento"
        description={[
          "Desde conferencias corporativas hasta bodas espectaculares, contamos con el equipo audiovisual más completo de la Ciudad de México. Cada pieza es mantenida y calibrada por nuestro equipo técnico.",
          "Ya sea que necesites una pantalla LED para tu recepción o un sistema de sonido line array para 5,000 personas — tenemos la solución perfecta."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <Card
            name={sub.name}
            excerpt={sub.excerpt}
            cta={sub.cta}
            href={sub.href}
            icon={sub.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLAS LED — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pantallas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Lo más solicitado</span>
          <h2 class="showcase__title" id="pantallas-heading">Pantallas LED</h2>
          <p class="showcase__subtitle">Impacto visual garantizado. Pantallas de alta resolución que capturan la atención de cada asistente.</p>
          <p class="showcase__text">Nuestras <strong>pantallas LED de alta resolución</strong> están disponibles desde 55 pulgadas hasta videowall modulares de 6x3 metros. Para bodas y eventos sociales, las pantallas de <strong>75 y 85 pulgadas en pedestal</strong> son perfectas para proyectar fotos, videos y transmisiones en vivo de la ceremonia.</p>
          <p class="showcase__text">Para <strong>congresos y eventos corporativos</strong>, ofrecemos videowall modulares que se adaptan a cualquier dimensión del escenario. Cada pantalla incluye <strong>procesador de video, cableado HDMI/SDI</strong> y soporte técnico durante todo el evento. Brillo superior a 1,000 nits para perfecta visibilidad incluso en exteriores. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario ejecutivo</a> para presentaciones impecables.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">LED 55"</span>
            <span class="showcase__tag">LED 75"</span>
            <span class="showcase__tag">LED 85"</span>
            <span class="showcase__tag">Videowall Modular</span>
            <span class="showcase__tag">Pantalla Gigante</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pantallas LED
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SONIDO PROFESIONAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="sonido-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Audio de primer nivel</span>
          <h2 class="showcase__title" id="sonido-heading">Sonido Profesional</h2>
          <p class="showcase__subtitle">Claridad y potencia para cualquier espacio. Desde reuniones íntimas hasta festivales al aire libre.</p>
          <p class="showcase__text">Nuestros <strong>sistemas line array profesionales</strong> ofrecen cobertura uniforme para audiencias de 50 a 5,000+ personas. Para eventos en salón, las <strong>bocinas amplificadas de 12 y 15 pulgadas</strong> con subwoofer garantizan un sonido envolvente. Complementamos con <strong>mezcladoras digitales de 16 y 32 canales</strong> para control total del audio.</p>
          <p class="showcase__text">Cada sistema incluye <strong>prueba de sonido previa al evento</strong>, ecualización profesional según la acústica del venue y un <strong>ingeniero de audio dedicado</strong> durante toda la operación. Cableado oculto y distribución limpia para una <strong>instalación invisible y profesional</strong>. Para eventos bajo <a href="/servicios/carpas/">carpas</a>, usamos rigging certificado en puntos de anclaje estructural.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Line Array</span>
            <span class="showcase__tag">Bocinas 12"</span>
            <span class="showcase__tag">Subwoofers</span>
            <span class="showcase__tag">Mezcladoras</span>
            <span class="showcase__tag">Monitoreo</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Sonido Profesional
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M19.07 4.93a10 10 0 010 14.14"/>
              <path d="M15.54 8.46a5 5 0 010 7.07"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PROYECTORES Y VIDEO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="proyectores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Alta definición</span>
          <h2 class="showcase__title" id="proyectores-heading">Proyectores y Video</h2>
          <p class="showcase__subtitle">Presentaciones nítidas y streaming en vivo. Tecnología de proyección para eventos presenciales e híbridos.</p>
          <p class="showcase__text">Nuestros <strong>proyectores Full HD y 4K</strong> con hasta 10,000 lúmenes garantizan imagen nítida incluso en ambientes con luz natural. Ideales para <strong>presentaciones corporativas, congresos, mapping arquitectónico</strong> y proyecciones artísticas en bodas y eventos sociales.</p>
          <p class="showcase__text">Para <strong>eventos híbridos</strong>, ofrecemos paquetes de streaming con <strong>cámaras HD, switcher de video y encoder profesional</strong>. Transmitimos a YouTube, Zoom, Teams o cualquier plataforma. Complementamos con <strong>pantallas de retorno, telepromter</strong> y grabación profesional del evento completo. Necesitas <a href="/servicios/accesorios/">plantas de energía</a> para exteriores? Lo resolvemos.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Proyector Full HD</span>
            <span class="showcase__tag">Proyector 4K</span>
            <span class="showcase__tag">Streaming</span>
            <span class="showcase__tag">Cámaras HD</span>
            <span class="showcase__tag">Mapping</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Proyectores
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MICRÓFONOS Y DJ — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="microfonos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Complemento esencial</span>
          <h2 class="showcase__title" id="microfonos-heading">Micrófonos y DJ</h2>
          <p class="showcase__subtitle">Micrófonos profesionales para ceremonias y discursos. Equipo completo de DJ para la mejor fiesta.</p>
          <p class="showcase__text">Contamos con <strong>micrófonos inalámbricos Shure y Sennheiser</strong> de mano, solapa y diadema con alcance de hasta 100 metros. Ideales para <strong>ceremonias religiosas, brindis, discursos corporativos</strong> y presentaciones donde la claridad de voz es fundamental.</p>
          <p class="showcase__text">Para la fiesta, ofrecemos <strong>equipo completo de DJ</strong> con tornamesas Pioneer, controladores, monitores de referencia y <strong>cabina de DJ iluminada</strong>. Complementamos con efectos de iluminación sincronizados al audio: máquinas de humo, cañones CO2 y <a href="/servicios/iluminacion/">luces robóticas profesionales</a> para crear una experiencia memorable.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Inalámbricos</span>
            <span class="showcase__tag">Solapa</span>
            <span class="showcase__tag">Diadema</span>
            <span class="showcase__tag">Tornamesas</span>
            <span class="showcase__tag">Cabina DJ</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Micrófonos y DJ
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
              <path d="M19 10v2a7 7 0 01-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Audiovisual"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu equipo audiovisual, es natural tener preguntas sobre especificaciones técnicas, capacidades, montaje y logística. Aquí encontrarás las respuestas a las consultas más comunes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre equipo audiovisual al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de equipo audiovisual`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Equipo Audiovisual"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores técnicos te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Ya sea una pantalla para tu boda o un sistema de sonido para un congreso de 5,000 personas, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Graduación">Graduación</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="equipo">
                Equipo de interés
              </label>
              <select id="equipo" name="equipo" class="form-field__input form-field__select">
                <option value="">Selecciona el equipo que necesitas</option>
                <option value="Pantallas LED">Pantallas LED</option>
                <option value="Videowall Modular">Videowall Modular</option>
                <option value="Sonido Line Array">Sonido Line Array</option>
