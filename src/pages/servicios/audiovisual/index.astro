---
/**
 * ─── Audiovisual Category Page ───
 * Página de categoría: Renta de Equipo Audiovisual para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import CtaBar from "@components/CtaBar.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import FaqSection from "@components/FaqSection.astro";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual" },
];

const SUB_SERVICES = [
  {
    name: "Pantallas LED",
    excerpt: "Pantallas en pedestal de 55 a 85 pulgadas desde $500 y videowall modular hasta 6×3 m para congresos en el WTC y Citibanamex. Técnico incluido.",
    href: "/servicios/audiovisual/pantallas-led/",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    subcategories: [
      { name: "Pantallas en Pedestal", href: "/servicios/audiovisual/pantallas-led/pedestal/" },
      { name: "Videowall Modular", href: "/servicios/audiovisual/pantallas-led/videowall/" },
      { name: "Pantallas Exterior", href: "/servicios/audiovisual/pantallas-led/exterior/" },
      { name: "Monitores y Displays", href: "/servicios/audiovisual/pantallas-led/monitores/" },
    ],
  },
  {
    name: "Sonido Profesional",
    excerpt: "Line array JBL desde $800 para eventos de 50 a 5,000 personas. Bocinas, subwoofers de 18\" y mezcladoras Yamaha de 32 canales con ingeniero incluido.",
    href: "/servicios/audiovisual/sonido/",
    image: "/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif",
    subcategories: [
      { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
      { name: "Bocinas Amplificadas", href: "/servicios/audiovisual/sonido/bocinas/" },
      { name: "Subwoofers", href: "/servicios/audiovisual/sonido/subwoofers/" },
      { name: "Mezcladoras", href: "/servicios/audiovisual/sonido/mezcladoras/" },
    ],
  },
  {
    name: "Proyectores y Video",
    excerpt: "Proyectores Full HD y 4K de hasta 10,000 lúmenes desde $1,000. Streaming profesional a YouTube o Zoom y video mapping para bodas y lanzamientos.",
    href: "/servicios/audiovisual/proyectores/",
    image: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif",
    subcategories: [
      { name: "Proyectores Full HD y 4K", href: "/servicios/audiovisual/proyectores/fullhd-4k/" },
      { name: "Streaming en Vivo", href: "/servicios/audiovisual/proyectores/streaming/" },
      { name: "Video Mapping", href: "/servicios/audiovisual/proyectores/mapping/" },
      { name: "Pantallas de Proyección", href: "/servicios/audiovisual/proyectores/pantallas-proyeccion/" },
    ],
  },
  {
    name: "Micrófonos y DJ",
    excerpt: "Micrófonos Shure y Sennheiser desde $300 para ceremonias y brindis. Tornamesas Pioneer CDJ-3000 y cabinas DJ iluminadas para la fiesta perfecta.",
    href: "/servicios/audiovisual/microfonos-dj/",
    image: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif",
    subcategories: [
      { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/inalambricos/" },
      { name: "Solapa y Diadema", href: "/servicios/audiovisual/microfonos-dj/solapa-diadema/" },
      { name: "Equipo DJ Completo", href: "/servicios/audiovisual/microfonos-dj/equipo-dj/" },
      { name: "Cabina DJ Iluminada", href: "/servicios/audiovisual/microfonos-dj/cabina-dj/" },
    ],
  },
];

const faqs = [
  { question: "¿Qué tamaños de pantallas LED tienen disponibles?", answer: "Contamos con pantallas LED desde 55 pulgadas hasta videowall modular de hasta 6x3 metros. Para bodas y eventos sociales las pantallas de 75 a 85 pulgadas son las más populares. Para congresos y festivales ofrecemos pantallas gigantes modulares que se adaptan a cualquier dimensión." },
  { question: "¿El equipo incluye técnico de operación?", answer: "Sí. Todos nuestros paquetes de audio y video incluyen un técnico especializado que se encarga de la instalación, pruebas de sonido, operación durante el evento y desmontaje. Para eventos grandes asignamos un equipo técnico completo." },
  { question: "¿Qué sistema de sonido necesito según el tamaño de mi evento?", answer: "Para reuniones íntimas (hasta 50 personas) recomendamos bocinas amplificadas de 12 pulgadas. Para eventos medianos (50-200 personas) un sistema line array compacto. Para grandes eventos (200+ personas) o al aire libre, sistemas line array profesionales con subwoofers. Nuestro equipo te asesora según tu venue y número de asistentes." },
  { question: "¿Pueden hacer transmisión en vivo (streaming)?", answer: "Sí. Ofrecemos paquetes de streaming con cámaras HD, switcher de video, encoder profesional y conexión dedicada. Transmitimos a plataformas como YouTube, Zoom, Teams o cualquier otra. Ideal para eventos corporativos híbridos, conferencias y ceremonias religiosas." },
  { question: "¿Con cuánta anticipación debo reservar el equipo audiovisual?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta. Para eventos corporativos grandes o congresos con requerimientos técnicos específicos, lo ideal es apartar con 1 a 2 meses. También atendemos solicitudes de último momento sujetas a disponibilidad." },
  { question: "¿Realizan visita técnica previa al evento?", answer: "Sí, para eventos medianos y grandes realizamos una visita técnica al venue sin costo adicional. Evaluamos acústica del espacio, puntos de corriente, distancias de proyección y condiciones de iluminación para garantizar el mejor resultado técnico en tu evento." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo Audiovisual CDMX",
    description: "Pantallas LED, sonido profesional, proyectores y micrófonos para bodas, corporativos y congresos. Técnico incluido.",
    url: "/servicios/audiovisual/",
    priceRange: { min: 500, max: 50000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Equipo Audiovisual"
  description="Renta de equipo audiovisual para eventos: pantallas LED, sonido profesional, proyectores y micrófonos en CDMX. Técnico de operación incluido. Cotiza en 24h."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Más de 500 eventos realizados en CDMX"
    title='Renta de <span class="highlight">Equipo Audiovisual</span> para Eventos en CDMX'
    subtitle="Pantallas LED desde $500, sonido line array JBL, proyectores 4K y micrófonos Shure. Técnico de operación incluido en cada renta. Cotización el mismo día."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo audiovisual para mi evento` }}
    cards={[
      {
        title: "Pantallas LED desde $500, sonido desde $800 y proyectores 4K — todo con técnico incluido",
        content: "<strong>Renta de equipo audiovisual para eventos en CDMX</strong> con inventario propio: pantallas LED en pedestal de 55 a 85 pulgadas, videowall modular P2.5 hasta 6×3 metros, sistemas line array JBL y d&b audiotechnik para 50 a 5,000+ personas, proyectores Full HD y 4K de 10,000 lúmenes, y micrófonos inalámbricos Shure SLX-D y Sennheiser EW. Hemos montado en el WTC CDMX, Citibanamex, Salón Jardín Pedregal y Hacienda Tlalpan.",
      },
      {
        title: "Técnico o ingeniero de audio dedicado desde la instalación hasta el desmontaje",
        content: "<strong>Cada renta audiovisual incluye</strong> técnico especializado que llega 3 horas antes del evento, hace la prueba de sonido, calibra el sistema según la acústica de tu venue y opera el equipo durante todo el evento. Cableado oculto, distribución limpia y monitoreo en tiempo real — sin que tú tengas que preocuparte por nada técnico. Cubrimos las 16 alcaldías de la Ciudad de México sin costo adicional.",
      },
    ]}
  />

  <CtaBar headline="¿Qué equipo audiovisual necesitas?" items={[
    { label: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/", icon: "audiovisual" },
    { label: "Sonido", href: "/servicios/audiovisual/sonido/", icon: "audiovisual" },
    { label: "Proyectores", href: "/servicios/audiovisual/proyectores/", icon: "audiovisual" },
    { label: "Micrófonos y DJ", href: "/servicios/audiovisual/microfonos-dj/", icon: "audiovisual" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para un evento con sonido e imagen impecables?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica personalizada para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="¿Qué equipo audiovisual para eventos puedes rentar en CDMX?"
        subtitle="Pantallas LED, sonido, proyectores y micrófonos — todo en un solo proveedor"
        description={[
          "Tenemos inventario propio para bodas de 50 personas hasta congresos de 5,000 asistentes. Pantallas LED en pedestal desde $500, line array JBL desde $800, proyectores de 10,000 lúmenes y tornamesas Pioneer CDJ-3000. Hemos montado en el WTC CDMX, Citibanamex, Salón Jardín Pedregal y más de 500 venues en la ciudad.",
          "Cada renta incluye técnico o ingeniero de audio dedicado — instalación, prueba de sonido y operación durante el evento. Sin costos ocultos dentro de las 16 alcaldías."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <CategoryCard
            title={sub.name}
            subtitle={sub.excerpt}
            href={sub.href}
            image={sub.image}
            subcategories={sub.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PANTALLAS LED — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pantallas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Lo más solicitado</span>
          <h2 class="showcase__title" id="pantallas-heading">Pantallas LED</h2>
          <p class="showcase__subtitle">Impacto visual garantizado. Pantallas de alta resolución que capturan la atención de cada asistente.</p>
          <p class="showcase__text">Nuestras <strong>pantallas LED de alta resolución</strong> están disponibles desde 55 pulgadas hasta videowall modulares de 6x3 metros. Para bodas y eventos sociales, las pantallas de <strong>75 y 85 pulgadas en pedestal</strong> son perfectas para proyectar fotos, videos y transmisiones en vivo de la ceremonia.</p>
          <p class="showcase__text">Para <strong>congresos y eventos corporativos</strong>, ofrecemos videowall modulares que se adaptan a cualquier dimensión del escenario. Cada pantalla incluye <strong>procesador de video, cableado HDMI/SDI</strong> y soporte técnico durante todo el evento. Brillo superior a 1,000 nits para perfecta visibilidad incluso en exteriores. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario ejecutivo</a> para presentaciones impecables.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">LED 55"</span>
            <span class="showcase__tag">LED 75"</span>
            <span class="showcase__tag">LED 85"</span>
            <span class="showcase__tag">Videowall Modular</span>
            <span class="showcase__tag">Pantalla Gigante</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pantallas LED
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SONIDO PROFESIONAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="sonido-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Audio de primer nivel</span>
          <h2 class="showcase__title" id="sonido-heading">Sonido Profesional</h2>
          <p class="showcase__subtitle">Claridad y potencia para cualquier espacio. Desde reuniones íntimas hasta festivales al aire libre.</p>
          <p class="showcase__text">Nuestros <strong>sistemas line array profesionales</strong> ofrecen cobertura uniforme para audiencias de 50 a 5,000+ personas. Para eventos en salón, las <strong>bocinas amplificadas de 12 y 15 pulgadas</strong> con subwoofer garantizan un sonido envolvente. Complementamos con <strong>mezcladoras digitales de 16 y 32 canales</strong> para control total del audio.</p>
          <p class="showcase__text">Cada sistema incluye <strong>prueba de sonido previa al evento</strong>, ecualización profesional según la acústica del venue y un <strong>ingeniero de audio dedicado</strong> durante toda la operación. Cableado oculto y distribución limpia para una <strong>instalación invisible y profesional</strong>. Para eventos bajo <a href="/servicios/carpas/">carpas</a>, usamos rigging certificado en puntos de anclaje estructural.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Line Array</span>
            <span class="showcase__tag">Bocinas 12"</span>
            <span class="showcase__tag">Subwoofers</span>
            <span class="showcase__tag">Mezcladoras</span>
            <span class="showcase__tag">Monitoreo</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Sonido Profesional
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
              <path d="M19.07 4.93a10 10 0 010 14.14"/>
              <path d="M15.54 8.46a5 5 0 010 7.07"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PROYECTORES Y VIDEO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="proyectores-heading">
    <div class="container">
      <ServiceShowcase
    title="Proyectores y Video"
    headingId="proyectores-heading"
    badge="Alta definición"
    subtitle="Presentaciones nítidas y streaming en vivo. Tecnología de proyección para eventos presenciales e híbridos."
    tags={["Proyector Full HD", "Proyector 4K", "Streaming", "Cámaras HD", "Mapping"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Proyectores"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>proyectores Full HD y 4K</strong> con hasta 10,000 lúmenes garantizan imagen nítida incluso en ambientes con luz natural. Ideales para <strong>presentaciones corporativas, congresos, mapping arquitectónico</strong> y proyecciones artísticas en bodas y eventos sociales.</p>
      <p class="showcase__text">Para <strong>eventos híbridos</strong>, ofrecemos paquetes de streaming con <strong>cámaras HD, switcher de video y encoder profesional</strong>. Transmitimos a YouTube, Zoom, Teams o cualquier plataforma. Complementamos con <strong>pantallas de retorno, telepromter</strong> y grabación profesional del evento completo. Necesitas <a href="/servicios/accesorios/">plantas de energía</a> para exteriores? Lo resolvemos.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MICRÓFONOS Y DJ — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="microfonos-heading">
    <div class="container">
      <ServiceShowcase
    title="Micrófonos y DJ"
    headingId="microfonos-heading"
    badge="Complemento esencial"
    subtitle="Micrófonos profesionales para ceremonias y discursos. Equipo completo de DJ para la mejor fiesta."
    tags={["Inalámbricos", "Solapa", "Diadema", "Tornamesas", "Cabina DJ"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Micrófonos y DJ"
  >
    <Fragment slot="body">
      <p class="showcase__text">Contamos con <strong>micrófonos inalámbricos Shure y Sennheiser</strong> de mano, solapa y diadema con alcance de hasta 100 metros. Ideales para <strong>ceremonias religiosas, brindis, discursos corporativos</strong> y presentaciones donde la claridad de voz es fundamental.</p>
      <p class="showcase__text">Para la fiesta, ofrecemos <strong>equipo completo de DJ</strong> con tornamesas Pioneer, controladores, monitores de referencia y <strong>cabina de DJ iluminada</strong>. Complementamos con efectos de iluminación sincronizados al audio: máquinas de humo, cañones CO2 y <a href="/servicios/iluminacion/">luces robóticas profesionales</a> para crear una experiencia memorable.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 1a3 3 0 00-3 3v8a3 3 0 006 0V4a3 3 0 00-3-3z"/>
              <path d="M19 10v2a7 7 0 01-14 0v-2"/>
              <line x1="12" y1="19" x2="12" y2="23"/>
              <line x1="8" y1="23" x2="16" y2="23"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo luce nuestro equipo audiovisual en eventos?</h2>
      <Gallery4x4 images={[
        { src: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif", alt: "Cabina DJ profesional para boda en CDMX" },
        { src: "/images/audiovisual/equipo-audiovisual-completo-boda.avif", alt: "Equipo audiovisual completo para boda" },
        { src: "/images/audiovisual/microfono-inalambrico-shure-conferencia-evento.avif", alt: "Micrófono inalámbrico Shure para conferencia" },
        { src: "/images/audiovisual/microfono-solapa-diadema-conferencista.avif", alt: "Micrófono de solapa y diadema para conferencista" },
        { src: "/images/audiovisual/monitor-pantalla-presentacion-congreso.avif", alt: "Monitor pantalla presentación congreso" },
        { src: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif", alt: "Pantalla LED videowall evento corporativo" },
        { src: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif", alt: "Proyector 4K pantalla gigante evento" },
        { src: "/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif", alt: "Sistema audio JBL evento corporativo" },
      ]} />
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <h2 id="faq-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">Preguntas frecuentes sobre equipo audiovisual</h2>
    </div>
    <FaqSection items={faqs} serviceName="equipo audiovisual" />
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tu Equipo Audiovisual"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores técnicos te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Ya sea una pantalla para tu boda o un sistema de sonido para un congreso de 5,000 personas, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Graduación">Graduación</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="equipo">
                Equipo de interés
              </label>
              <select id="equipo" name="equipo" class="form-field__input form-field__select">
                <option value="">Selecciona el equipo que necesitas</option>
                <option value="Pantallas LED">Pantallas LED</option>
                <option value="Videowall Modular">Videowall Modular</option>
                <option value="Sonido Line Array">Sonido Line Array</option>
                <option value="Bocinas Amplificadas">Bocinas Amplificadas</option>
                <option value="Proyectores">Proyectores Full HD / 4K</option>
                <option value="Streaming en Vivo">Streaming en Vivo</option>
                <option value="Micrófonos Inalámbricos">Micrófonos Inalámbricos</option>
                <option value="Equipo DJ">Equipo DJ Completo</option>
                <option value="Paquete Audiovisual Completo">Paquete Audiovisual Completo</option>
                <option value="Otro">Otro / No estoy seguro</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de asistentes, tipo de venue (salón/jardín/auditorio), equipo que necesitas..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Reserva tu fecha</h3>
            <p class="reserva-card__text">Aparta tu equipo audiovisual con anticipación y asegura disponibilidad para tu evento.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría técnica personalizada para tu presupuesto.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const equipo = document.getElementById('equipo').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — Audiovisual*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (equipo) texto += `*Equipo de interés:* ${equipo}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

