---
/**
 * ─── EVENTECH.MX — Audiovisual para Eventos (L3, rediseño 2026) ───
 * Renta de equipo audiovisual: sonido, pantallas LED, proyectores y micrófonos.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "sonido",
    name: "Sonido Profesional",
    badge: "La columna vertebral del evento",
    excerpt: "Sistemas de audio line array, bafles activos JBL y RCF, subwoofers y consolas digitales para eventos de 50 a 5,000 personas. El sonido que llega parejo a cada rincón del venue — sin zonas muertas ni distorsión.",
    href: "/servicios/audiovisual/sonido/",
    image: "/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif",
    subcategories: [
      { name: "Sistemas Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
      { name: "Bafles y Monitores", href: "/servicios/audiovisual/sonido/bafles/" },
      { name: "Consolas Digitales", href: "/servicios/audiovisual/sonido/consolas/" },
      { name: "Subwoofers", href: "/servicios/audiovisual/sonido/subwoofers/" },
    ],
  },
  {
    id: "pantallas-led",
    name: "Pantallas LED",
    badge: "El impacto visual que no se olvida",
    excerpt: "Videowalls LED de alta resolución en cualquier formato: escenario principal, backdrops, totems y pantallas perimetrales. Desde un panel de 3×2 m hasta un videowall de 12×6 m — modulares, sin biseles, con brillo que funciona en exteriores.",
    href: "/servicios/audiovisual/pantallas-led/",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    subcategories: [
      { name: "Videowalls de Escenario", href: "/servicios/audiovisual/pantallas-led/videowall/" },
      { name: "Totems LED", href: "/servicios/audiovisual/pantallas-led/totems/" },
      { name: "Backdrops LED", href: "/servicios/audiovisual/pantallas-led/backdrops/" },
      { name: "Pantallas Perimetrales", href: "/servicios/audiovisual/pantallas-led/perimetrales/" },
    ],
  },
  {
    id: "proyectores",
    name: "Proyectores y Pantallas",
    badge: "Presentaciones de alto impacto",
    excerpt: "Proyectores de 5,000 a 30,000 lúmenes con pantallas de proyección manual, eléctrica o front projection para salas de conferencia, auditorios y eventos corporativos. Imagen nítida incluso en espacios con iluminación ambiente.",
    href: "/servicios/audiovisual/proyectores/",
    image: "/images/audiovisual/proyector-4k-pantalla-gigante-evento.avif",
    subcategories: [
      { name: "Proyectores de Alta Luminosidad", href: "/servicios/audiovisual/proyectores/alta-luminosidad/" },
      { name: "Pantallas de Proyección", href: "/servicios/audiovisual/proyectores/pantallas/" },
      { name: "Monitores de Presentación", href: "/servicios/audiovisual/proyectores/monitores/" },
      { name: "Sistemas de Videoconferencia", href: "/servicios/audiovisual/proyectores/videoconferencia/" },
    ],
  },
  {
    id: "microfonos-dj",
    name: "Micrófonos y DJ",
    badge: "Voz y música sin complicaciones",
    excerpt: "Sistemas de micrófono inalámbrico Shure y Sennheiser, diademas, solapa y de mano para conferencias, ceremonias y shows. Cabinas de DJ con mixers, CDJs y controladores para fiestas y eventos con ambientación musical en vivo.",
    href: "/servicios/audiovisual/microfonos-dj/",
    image: "/images/audiovisual/cabina-dj-profesional-boda-cdmx.avif",
    subcategories: [
      { name: "Micrófonos Inalámbricos", href: "/servicios/audiovisual/microfonos-dj/inalambricos/" },
      { name: "Micrófonos de Solapa", href: "/servicios/audiovisual/microfonos-dj/solapa/" },
      { name: "Cabinas DJ", href: "/servicios/audiovisual/microfonos-dj/dj/" },
      { name: "Sistemas de Conferencia", href: "/servicios/audiovisual/microfonos-dj/conferencia/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🎛️",
    title: "Equipo de marcas premium, no de segunda mano",
    body: "JBL, RCF, Sennheiser, Shure, Barco, Christie. Nuestro inventario son las marcas que usan los productores de eventos más exigentes de CDMX — no versiones de entrada ni marcas de nombre desconocido. El rider técnico de cualquier artista o conferencista de nivel lo cubrimos.",
  },
  {
    icon: "🔊",
    title: "Técnico de sonido incluido en los paquetes de audio",
    body: "Los sistemas de audio line array no se enchufan y listo — requieren afinación de la sala, configuración de EQ por frecuencias del venue y monitoreo durante el evento. Todos nuestros paquetes de audio incluyen técnico certificado que llega al venue antes que los primeros invitados.",
  },
  {
    icon: "📐",
    title: "Diseño técnico previo al evento",
    body: "Antes de cualquier evento con pantalla LED o sistema de sonido de media o alta complejidad, preparamos un plano técnico de distribución de equipo según el plano del venue. El día del evento no hay sorpresas de cobertura ni posiciones que no funcionan.",
  },
  {
    icon: "🔌",
    title: "Evaluación eléctrica sin costo adicional",
    body: "Los sistemas de audio y video de alto rendimiento tienen requerimientos eléctricos específicos. Evaluamos el panel eléctrico del venue previamente y llevamos distribución eléctrica de respaldo si el venue no tiene la capacidad suficiente — sin cargos adicionales.",
  },
  {
    icon: "📡",
    title: "Sistemas de frecuencia coordinada para múltiples micrófonos",
    body: "En conferencias con varios conferencistas simultáneos o eventos con múltiples micrófonos inalámbricos, coordinamos las frecuencias de radio para eliminar interferencias. Un aspecto técnico crítico que muchos proveedores ignoran hasta que hay problemas en el evento.",
  },
  {
    icon: "🛠️",
    title: "Equipo de respaldo en sitio",
    body: "Para eventos de un día completo o más, mantenemos equipo de respaldo en sitio — un micrófono extra, un amplificador de respaldo, cables adicionales. El audiovisual no falla cuando el evento no se puede parar.",
  },
];

const steps = [
  { n: 1, t: "Revisión técnica del venue", p: "Evaluamos el plano del espacio, capacidad eléctrica, acústica del recinto y requerimientos específicos del programa del evento para dimensionar correctamente el sistema." },
  { n: 2, t: "Diseño técnico y cotización", p: "Presentamos plano de distribución de equipo, especificaciones técnicas de cada componente y cotización detallada. Coordina directamente con tu productor de eventos o lo hacemos nosotros." },
  { n: 3, t: "Montaje y pruebas de sonido", p: "Instalamos el día anterior o la mañana del evento — nunca una hora antes. Realizamos prueba de sonido completa, verificación de señal de video y ajuste de frecuencias de micrófonos antes de que lleguen los primeros invitados." },
  { n: 4, t: "Operación y retiro", p: "Técnico en sitio durante todo el evento para ajustes en tiempo real. Retiro discreto al finalizar sin interrumpir el cierre del evento." },
];

const faqs = [
  {
    question: "¿El técnico de sonido está incluido o es un costo adicional?",
    answer: "En todos los paquetes de audio que incluyen sistema line array o setups de más de 4 bafles, el técnico de sonido está incluido. Para sistemas pequeños de 1–2 bafles activos con consola básica, ofrecemos la opción con o sin técnico — lo especificamos en la cotización. En eventos donde hay presentaciones en vivo, conferencias magistrales o shows, recomendamos siempre incluir técnico; la diferencia en el resultado es sustancial.",
  },
  {
    question: "¿Pueden cubrir eventos simultáneos en múltiples salones?",
    answer: "Sí. Para congresos y eventos corporativos multi-sala coordinamos sistemas de audio independientes en cada sala, con técnico por sala si el programa lo requiere. La coordinación de frecuencias de los micrófonos inalámbricos entre salas es parte del diseño técnico previo — eliminamos interferencias entre sistemas antes de que el evento empiece.",
  },
  {
    question: "¿Qué tamaño de pantalla LED necesito para mi evento?",
    answer: "La regla de base es: la distancia máxima de los espectadores al fondo de la sala dividida entre 6 te da el alto mínimo de pantalla en metros. Para una sala de 24 metros de profundidad, mínimo 4 metros de alto de pantalla. En exteriores con luz solar directa se requiere mínimo 4,000–5,000 nits de brillo — le preguntamos al proveedor del venue el horario de exposición solar antes de recomendar. Calculamos la configuración exacta según plano del venue.",
  },
  {
    question: "¿El equipo funciona en exteriores con calor o lluvia?",
    answer: "Las pantallas LED de exterior tienen rating IP65 — resistentes a lluvia y operables hasta 45°C. Los sistemas de audio de exterior tienen protección contra humedad y los amplificadores van en racks cerrados bajo techo o en fly cases con ventilación. Para eventos en jardín o terraza bajo lluvia montamos domos de protección sobre el rack de amplificadores. Lo que no cubrimos es granizo o lluvia torrencial sostenida — en esos casos el protocolo es cubrir los sistemas y esperar.",
  },
  {
    question: "¿Pueden entregar el video del evento grabado desde las cámaras?",
    answer: "Sí, ofrecemos servicios de video en vivo y grabación multi-cámara bajo paquetes separados. Si solo necesitas la señal de video transmitida a las pantallas del venue, eso está incluido en el servicio de pantallas LED. Si necesitas grabación, streaming en vivo o producción de video con switcher y mezcla, cotizamos como servicio adicional.",
  },
  {
    question: "¿Con cuánta anticipación necesito reservar el equipo audiovisual?",
    answer: "Para eventos medianos (hasta 300 personas, sistema de sonido estándar y 1–2 pantallas), con 2–3 semanas es suficiente. Para eventos grandes o con requerimientos técnicos específicos — videowall de más de 20m², sistema line array de más de 8 puntos, múltiples salas simultáneas — recomendamos 4–6 semanas para garantizar disponibilidad del equipo y tiempo para el diseño técnico. En temporada alta (septiembre–diciembre) lo ideal es 6–8 semanas.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Equipo Audiovisual para Eventos en CDMX",
    description: "Renta de equipo audiovisual para eventos en CDMX: sistemas de sonido line array, pantallas LED, proyectores y micrófonos inalámbricos. Técnico incluido. Cotización en 24h.",
    url: "/servicios/audiovisual/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Audiovisual", url: "/servicios/audiovisual/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Audiovisual" },
];
---

<PageLayout
  title="Renta de Equipo Audiovisual para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/audiovisual/equipo-audiovisual-completo-boda.avif"
  description="Equipo audiovisual para eventos en CDMX: sonido line array, pantallas LED, proyectores 4K y micrófonos Shure. Técnico incluido. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="av-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Audiovisual profesional · CDMX y ZMVM</p>
            <h1 id="av-hero-heading">
              Sonido, imagen y micrófonos de nivel profesional para <em>cualquier evento en CDMX</em>
            </h1>
            <p class="hm-hero__lead">
              Sistemas de audio line array JBL y RCF, videowalls LED modulares, proyectores
              de hasta 30,000 lúmenes y micrófonos Shure y Sennheiser coordinados en frecuencia.
              Equipo de marcas premium, técnico incluido y diseño técnico previo al evento —
              sin sorpresas el día de la función.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20equipo%20audiovisual%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver el equipo disponible
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>equipo audiovisual profesional</strong> para eventos en
              Ciudad de México y zona metropolitana. Nuestro inventario incluye sistemas de
              sonido line array, videowalls LED modulares, proyectores de alta luminosidad
              y sistemas de micrófono inalámbrico de marcas líderes — todo con soporte
              técnico incluido y diseño de instalación previo al evento.
            </p>
            <p>
              Con <strong>más de 600 eventos audiovisuales</strong> cubiertos en CDMX —
              desde bodas íntimas hasta congresos internacionales — conocemos los
              requerimientos técnicos de los venues y productores más exigentes de la ciudad.
              El evento no arranca hasta que el audio y el video estén perfectos.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Equipo audiovisual disponible">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20equipo%20audiovisual%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Sonido, imagen y comunicación</p>
            <h2 id="catalogo-heading">¿Qué sistema audiovisual necesita tu evento?</h2>
            <p class="hm__head-sub">Audio profesional, pantallas LED, proyectores o micrófonos — o el sistema completo.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El audiovisual es la diferencia entre un evento que se vive como experiencia
              y uno que se siente improvisado. El discurso del director que nadie escucha
              porque el sistema de sonido no cubre el fondo del salón. La presentación
              de slides que se ve lavada porque el proyector no tiene lúmenes suficientes
              para el nivel de iluminación ambiente del venue. El micrófono que retroalimenta
              justo cuando el novio dice los votos.
            </p>
            <p>
              El equipo correcto, instalado y operado correctamente, hace que el audiovisual
              desaparezca — los invitados escuchan y ven sin pensar en el equipo.
              Eso es lo que garantizamos.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada sistema, a fondo</p>
            <h2 id="detalle-heading">Equipo audiovisual en detalle</h2>
            <p class="hm__head-sub">Especificaciones, aplicaciones y por qué cada sistema marca la diferencia en el resultado final del evento.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El audiovisual de eventos tiene niveles de complejidad técnica que no siempre
              son visibles para el cliente — y esa invisibilidad es precisamente el objetivo.
              Cuando el sistema está bien dimensionado y operado por técnicos capacitados,
              el invitado solo percibe que se escucha bien, se ve bien y el micrófono funciona.
              Lo que hay detrás — la ingeniería de sonido, la coordinación de frecuencias,
              el diseño de videowall — permanece invisible. Así debe ser.
            </p>
          </div>
        </div>

        <!-- Sonido -->
        <article class="hm-feat" aria-labelledby="feat-sonido">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Sonido Profesional</p>
            <h3 class="hm-feat__title" id="feat-sonido">Sistemas line array y bafles de marcas líderes — el audio que cubre cada rincón del venue sin comprometer la claridad</h3>
            <p class="hm-feat__lead">Un sistema de sonido mal dimensionado se escucha en el primer minuto del evento — y se recuerda durante todo el evento. El audio correcto, en cambio, es completamente invisible.</p>
            <p>
              Nuestros <strong>sistemas de sonido line array</strong> JBL VTX y RCF HDL
              se configuran en clusters suspendidos sobre el escenario para cobertura
              uniforme desde primera fila hasta el fondo del venue — sin la distorsión
              ni el volumen excesivo de los sistemas de bafles en el suelo. Para eventos
              de 50 a 300 personas ofrecemos <strong>sistemas de bafles activos</strong>
              JBL SRX y EON en configuración estéreo o distribuida con subwoofers de
              18 pulgadas para respaldo de bajos. Todos los sistemas incluyen
              <strong>consola digital</strong> Yamaha CL o Allen &amp; Heath dLive
              para control preciso de EQ por zona, compresión y efectos en tiempo real.
            </p>
            <p>
              El técnico de sonido llega al venue para realizar la
              <strong>afinación de sala</strong> — un proceso de medición acústica del
              recinto y ajuste de la respuesta del sistema a la frecuencia específica de
              ese espacio. Cada salón tiene su propia acústica: reverberaciones,
              frecuencias que se acumulan en esquinas, materiales absorbentes o
              reflectantes. Sin afinación, el sistema suena genérico. Con ella,
              suena como fue diseñado. Coordina el audiovisual con nuestro servicio de <a href="/servicios/iluminacion/">iluminación de escenario</a> para una producción técnica integrada. Para venues con capacidad eléctrica insuficiente, gestionamos el <a href="/servicios/accesorios/plantas-energia/">generador eléctrico de respaldo</a> necesario para el sistema de audio y video.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Line Array", href: "/servicios/audiovisual/sonido/line-array/" },
                { name: "Bafles", href: "/servicios/audiovisual/sonido/bafles/" },
                { name: "Consolas", href: "/servicios/audiovisual/sonido/consolas/" },
                { name: "Subwoofers", href: "/servicios/audiovisual/sonido/subwoofers/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/audiovisual/sonido/">
              Ver sonido profesional
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/audiovisual/sistema-audio-bafle-jbl-evento-corporativo.avif" alt="Sistema de audio JBL bafles activos montados en evento corporativo CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/audiovisual/audio-evento-01.avif" alt="Consola digital de mezcla en cabina de sonido para evento" loading="lazy" decoding="async" />
