---
/**
 * ─── Escenarios con Techo — Pagina de Producto (Nivel 4) ───
 * Escenarios completos con estructura de techo tipo truss,
 * rigging para iluminación y sonido, protección contra lluvia.
 *
 * Jerarquia: Servicios > Pistas de Baile > Tarimas y Escenarios > Escenarios con Techo
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
  { label: "Escenarios con Techo" },
];

const faqs = [
  { question: "¿El escenario con techo incluye iluminación y sonido?", answer: 'La estructura del escenario con techo incluye <strong>puntos de rigging certificados</strong> para colgar iluminación y sonido, pero el equipo audiovisual se renta por separado. Ofrecemos paquetes integrales que combinan el escenario con nuestros servicios de <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> y <a href="/servicios/audiovisual/sonido/">sonido profesional</a> a precios especiales. Nuestro equipo coordina toda la producción para que no tengas que contratar múltiples proveedores.' },
  { question: "¿El techo protege contra lluvia durante el evento?", answer: 'Absolutamente. La cubierta de nuestros escenarios con techo está fabricada en <strong>lona PVC impermeable de alta resistencia</strong> con tratamiento UV. El diseño incluye pendiente calculada para desagüe eficiente y canaletas laterales que dirigen el agua lejos del escenario y la audiencia. Protege tanto el equipo técnico (iluminación, sonido, pantallas) como a los artistas y presentadores. Hemos operado exitosamente bajo lluvias moderadas a fuertes sin interrumpir eventos.' },
  { question: "¿Cuánto peso soporta el rigging del techo?", answer: 'Nuestra estructura de truss de aluminio cuenta con <strong>puntos de rigging certificados de 200 kg cada uno</strong>, distribuidos estratégicamente en el techo. La capacidad total de carga del sistema de rigging depende de la dimensión del escenario: un escenario de 6x4 m soporta hasta 800 kg en rigging, mientras que uno de 8x6 m soporta hasta 1,200 kg. Esto permite montar <a href="/servicios/iluminacion/escenario/moving-heads/">moving heads</a>, barras LED, line arrays de sonido y pantallas LED sin problema.' },
  { question: "¿Se puede instalar en cualquier tipo de terreno?", answer: 'Sí, nuestros escenarios con techo se instalan en terrenos variados: <strong>concreto, asfalto, césped, tierra compacta y superficies mixtas</strong>. Para terrenos blandos como jardines, utilizamos lastres de concreto de 500 kg por pata y bases de distribución de peso que protegen el césped. En terrenos con pendiente, combinamos con nuestras <a href="/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/">plataformas niveladas</a> para garantizar una tarima perfectamente horizontal bajo el techo.' },
  { question: "¿El escenario incluye backdrop o cerramiento?", answer: 'Sí, todos nuestros escenarios con techo incluyen <strong>backdrop posterior en tela negra</strong> como estándar. También ofrecemos opciones de backdrop personalizable con impresión de logotipos, branding corporativo o diseños temáticos. Los cerramientos laterales en lona PVC traslúcida o negra están disponibles como complemento, ideales para eventos privados o cuando se requiere control de iluminación ambiental para producciones con efectos de luz.' },
  { question: "¿Con cuánta anticipación debo reservar un escenario con techo?", answer: 'Recomendamos reservar con <strong>4 a 6 semanas de anticipación</strong> debido a la logística de transporte, montaje y coordinación técnica que requieren los escenarios con techo. En temporada alta (noviembre a febrero y mayo-junio), lo ideal es apartar con <strong>2 meses de anticipación</strong>. El montaje completo requiere de 6 a 12 horas dependiendo de la dimensión, por lo que generalmente se realiza el día anterior al evento. También atendemos solicitudes urgentes sujetas a disponibilidad.' },
];

const specs = [
  { label: "Tarima", value: "Aluminio con superficie antideslizante" },
  { label: "Techo", value: "Truss aluminio con lona PVC" },
  { label: "Rigging", value: "Puntos certificados 200 kg cada uno" },
  { label: "Medidas tarima", value: "4x3 a 8x6 metros" },
  { label: "Altura tarima", value: "80 a 150 cm" },
  { label: "Altura techo", value: "4 a 6 metros sobre tarima" },
  { label: "Protección", value: "Lluvia y sol con lona PVC" },
  { label: "Backdrop", value: "Tela negra o personalizable" },
  { label: "Acceso", value: "Escalones laterales con barandal" },
  { label: "Montaje", value: "Equipo profesional, 6-12 horas" },
];

const sidebarNav = [
  { name: "Tarimas Modulares", href: "/servicios/pistas-baile/tarimas-escenarios/modulares/" },
  { name: "Escenarios con Techo", href: null, active: true },
  { name: "Pasarelas y Runways", href: "/servicios/pistas-baile/tarimas-escenarios/pasarelas/" },
  { name: "Plataformas Niveladas", href: "/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/" },
];

const sidebarRelated = [
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Diego Martínez", text: "Rentamos un escenario con techo de 8x6 metros para un concierto al aire libre en un jardín de Xochimilco. Llovió durante parte del evento y ni los músicos ni el equipo se mojaron. El rigging soportó sin problema las luces y bocinas. Producción de nivel profesional.", rating: 5, date: "2025-11-08" },
  { author: "Laura Sánchez", text: "Contratamos un escenario con techo de 6x4 para un evento corporativo outdoor en Santa Fe. Empezó a llover a mitad de la presentación y el techo protegió perfectamente al ponente, las pantallas y todo el equipo. La audiencia quedó impresionada con la producción. Excelente inversión.", rating: 5, date: "2025-10-15" },
  { author: "Fernando Gutiérrez", text: "Organizamos un festival de música de dos días y rentamos el escenario grande con techo y rigging completo. El montaje fue impecable, el equipo de EVENTECH coordinó la instalación de luces, sonido y pantallas en los puntos de rigging. Todo funcionó perfecto durante los dos días. Muy profesionales.", rating: 5, date: "2025-09-30" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Escenarios con Techo para Eventos en CDMX",
    description: "Renta de escenarios completos con estructura de techo tipo truss, rigging para iluminación y sonido, protección contra lluvia para eventos en CDMX. Desde $15,000.",
    url: "/servicios/pistas-baile/tarimas-escenarios/con-techo/",
    priceRange: { min: 15000, max: 80000 },
    reviews,
    ratingValue: 5,
    reviewCount: 189,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Tarimas y Escenarios", url: "/servicios/pistas-baile/tarimas-escenarios/" },
    { name: "Escenarios con Techo", url: "/servicios/pistas-baile/tarimas-escenarios/con-techo/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Escenarios con Techo para Eventos en CDMX"
  description="Renta de escenarios completos con estructura de techo tipo truss, rigging para iluminación y sonido, protección contra lluvia para eventos en CDMX. Desde $15,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Producción profesional con techo integrado"
    title='Renta de <span class="highlight">Escenarios con Techo</span> para Eventos en CDMX'
    subtitle="Escenarios completos con estructura de techo tipo truss de aluminio, puntos de rigging certificados para iluminación y sonido, lona de protección contra lluvia y backdrop personalizable."
    primaryCTA={{ label: "Cotiza tu escenario", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar un escenario con techo para mi evento` }}
    cards={[
      {
        title: "Escenario completo con techo de truss y rigging profesional",
        content: "<strong>Renta de escenarios con techo</strong> con la estructura más robusta para producciones en CDMX. Escenario completo con estructura de techo tipo truss de aluminio de alta resistencia y puntos de rigging certificados de 200 kg cada uno para montar iluminación, sonido y pantallas LED. Tarima de aluminio con superficie antideslizante, altura ajustable de 80 a 150 cm y capacidad de carga de 750 kg/m². Medidas desde 4x3 hasta 8x6 metros.",
      },
      {
        title: "Protección total con lona impermeable y backdrop personalizable",
        content: "<strong>Producción a prueba de clima</strong> con lona de protección PVC impermeable con tratamiento UV que protege contra lluvia y sol. Diseño con pendiente calculada y canaletas de desagüe para drenaje eficiente. Backdrop posterior personalizable con impresión de logotipos o diseños temáticos. Escalones de acceso con barandal de seguridad en ambos lados. Montaje profesional de 6 a 12 horas con equipo técnico especializado. Desmontaje y recolección incluidos sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un escenario con producción profesional?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta técnica con la dimensión y rigging ideales para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Tarimas y Escenarios para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas un escenario con techo para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un escenario con techo para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="12" width="20" height="8" rx="1"/><path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/><path d="M12 6V2"/><path d="M8 6V4"/><path d="M16 6V4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Escenarios con Techo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Escenario Pequeño -->
          <section class="section section--alt" aria-labelledby="pequeno-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bandas y ceremonias</span>
                <h2 class="showcase__title" id="pequeno-heading">Escenario Pequeño 4x3</h2>
                <p class="showcase__subtitle">Escenario compacto con techo para bandas de 3-5 músicos y ceremonias al aire libre.</p>
                <p class="showcase__text">Nuestro <strong>escenario pequeño de 4x3 metros</strong> con techo es la solución ideal para eventos que requieren una producción profesional en un formato compacto. El techo de truss de aluminio con lona PVC impermeable protege a los artistas y el equipo del sol y la lluvia, mientras que los <strong>puntos de rigging de 200 kg</strong> permiten colgar iluminación básica y monitores de sonido. Altura de tarima ajustable de 80 a 120 cm con escalones laterales y barandal.</p>
                <p class="showcase__text">Perfecto para <strong>bodas con trío o cuarteto musical, ceremonias religiosas al aire libre, presentaciones acústicas y shows intimistas</strong>. El backdrop negro incluido crea un fondo profesional para los artistas y oculta el cableado. Combínalo con nuestra <a href="/servicios/iluminacion/escenario/par-led/">iluminación Par LED</a> para crear un ambiente escénico con colores programables. Montaje profesional en 6-8 horas, generalmente realizado el día anterior al evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4x3 metros</span>
                  <span class="showcase__tag">3-5 músicos</span>
                  <span class="showcase__tag">Techo impermeable</span>
                  <span class="showcase__tag">Rigging incluido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Escenario 4x3
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Escenario Pequeño 4x3</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Escenario Mediano -->
          <section class="section section--alt" aria-labelledby="mediano-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Corporativos y shows</span>
                <h2 class="showcase__title" id="mediano-heading">Escenario Mediano 6x4</h2>
                <p class="showcase__subtitle">Escenario versátil con techo para corporativos, bandas completas y shows de producción media.</p>
                <p class="showcase__text">El <strong>escenario mediano de 6x4 metros</strong> es nuestro modelo más versátil y el favorito para eventos corporativos y producciones musicales de formato medio. El techo de truss con <strong>4 a 6 puntos de rigging de 200 kg</strong> permite montar un sistema completo de iluminación con moving heads, barras LED y par LED, además de monitores de sonido colgados. La lona PVC con tratamiento UV protege contra lluvia y sol directo durante todo el evento.</p>
                <p class="showcase__text">Ideal para <strong>lanzamientos de producto, premiaciones corporativas, bandas de 5-8 músicos, shows de comedia y presentaciones keynote al aire libre</strong>. Incluye backdrop personalizable con opción de impresión de logotipos, escalones de acceso en ambos lados y espacio bajo la tarima para cableado oculto. La altura de 4 metros sobre la tarima proporciona espacio para <a href="/servicios/iluminacion/escenario/moving-heads/">moving heads</a> y efectos de iluminación aéreos. Montaje profesional en 8-10 horas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">6x4 metros</span>
                  <span class="showcase__tag">5-8 músicos</span>
                  <span class="showcase__tag">Rigging completo</span>
                  <span class="showcase__tag">Backdrop custom</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Escenario 6x4
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Escenario Mediano 6x4</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Escenario Grande -->
          <section class="section section--alt" aria-labelledby="grande-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Conciertos y festivales</span>
                <h2 class="showcase__title" id="grande-heading">Escenario Grande 8x6</h2>
                <p class="showcase__subtitle">Escenario de gran formato con techo reforzado para conciertos, festivales y producciones de alto nivel.</p>
                <p class="showcase__text">El <strong>escenario grande de 8x6 metros</strong> es nuestra estructura de mayor formato, diseñada para conciertos, festivales y producciones que requieren máximo impacto visual y sonoro. El techo de truss reforzado cuenta con <strong>8 a 12 puntos de rigging de 200 kg</strong> que soportan sistemas completos de line array, moving heads, follow spots, barras LED y pantallas de video. Altura de techo de 6 metros sobre tarima para efectos de iluminación aéreos espectaculares.</p>
                <p class="showcase__text">La tarima de 150 cm de altura garantiza <strong>visibilidad máxima</strong> para audiencias de 500 a 2,000 personas. Incluye cerramientos laterales opcionales, backdrop de 8 metros de ancho y sistema de desagüe profesional con canaletas perimetrales. Ideal para <strong>conciertos al aire libre, festivales de música, bodas masivas, fiestas patrias y eventos institucionales de gran formato</strong>. Montaje de 10-12 horas con equipo de 8-12 técnicos. Complementa con nuestras <a href="/servicios/audiovisual/pantallas-led/videowall/">pantallas videowall</a> para una producción de nivel profesional.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">8x6 metros</span>
                  <span class="showcase__tag">500-2,000 personas</span>
                  <span class="showcase__tag">12 puntos rigging</span>
                  <span class="showcase__tag">150 cm altura</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Escenario 8x6
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Escenario Grande 8x6</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Producción -->
          <section class="section section--alt" aria-labelledby="kit-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Producción integral</span>
