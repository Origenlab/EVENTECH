---
/**
 * ─── Tarimas y Escenarios para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Tarimas y Escenarios para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Tarimas y Escenarios" },
];

const TARIMAS = [
  {
    name: "Tarimas Modulares",
    excerpt: "Plataformas de aluminio ensamblables con altura ajustable de 40 a 120 cm. Carga máxima de 750 kg/m². Ideales para conferencias, ceremonias y presentaciones.",
    cta: "Modulares",
    href: "#modulares-heading",
    icon: "layers",
  },
  {
    name: "Escenarios con Techo",
    excerpt: "Escenario completo con estructura de techo tipo truss, puntos de rigging para iluminación y sonido, y protección contra lluvia. Producción profesional garantizada.",
    cta: "Con Techo",
    href: "#techo-heading",
    icon: "package",
  },
  {
    name: "Pasarelas y Runways",
    excerpt: "Pasarelas elevadas con alfombra antideslizante e iluminación LED perimetral. Configuraciones en T, L o recta para desfiles de moda y premiaciones.",
    cta: "Pasarelas",
    href: "#pasarelas-heading",
    icon: "award",
  },
  {
    name: "Plataformas Niveladas",
    excerpt: "Patas de altura ajustable para instalación en jardines, pendientes y terrenos irregulares. Superficie perfectamente nivelada garantizada en cualquier terreno.",
    cta: "Niveladas",
    href: "#niveladas-heading",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Cuánto peso soportan las tarimas y escenarios?", answer: "Nuestras tarimas modulares de aluminio soportan hasta 750 kg/m², lo que permite montar con seguridad equipos de sonido, iluminación, mobiliario pesado y grupos de personas. Cada módulo está certificado estructuralmente y cuenta con patas reforzadas con bases antideslizantes. Para escenarios con techo, la estructura de truss soporta hasta 500 kg en puntos de rigging distribuidos. Siempre realizamos una evaluación de carga según el montaje específico de tu evento." },
  { question: "¿Qué opciones de altura tienen las tarimas?", answer: "Ofrecemos alturas ajustables desde 40 cm hasta 120 cm en incrementos de 20 cm. Las tarimas de 40 cm son ideales para ceremonias y presentaciones en salón donde se busca una ligera elevación. Las de 60-80 cm son perfectas para escenarios de conferencias y conciertos medianos. Las de 100-120 cm se usan para festivales y eventos masivos donde la audiencia necesita mayor visibilidad. Todas incluyen escaleras de acceso con barandal de seguridad." },
  { question: "¿Los escenarios al aire libre resisten el viento?", answer: "Sí. Nuestros escenarios con techo están diseñados para resistir vientos de hasta 80 km/h con anclaje profesional. Utilizamos lastres de concreto de 500 kg por pata, tensores de acero y bases de anclaje certificadas. Para eventos outdoor, realizamos una evaluación previa del terreno y las condiciones meteorológicas. En caso de alerta por vientos superiores a 80 km/h, contamos con protocolos de seguridad que incluyen refuerzo adicional o desmontaje preventivo." },
  { question: "¿Los escenarios con techo protegen contra la lluvia?", answer: "Absolutamente. La cubierta de nuestros escenarios con techo está fabricada en lona PVC impermeable de alta resistencia con tratamiento UV. El diseño incluye pendiente calculada para desagüe eficiente y canaletas laterales que dirigen el agua lejos del escenario. Protege tanto el equipo técnico (iluminación, sonido, pantallas) como a los artistas y presentadores. Hemos operado exitosamente bajo lluvias moderadas a fuertes sin interrumpir eventos." },
  { question: "¿Cuánto tiempo toma instalar una tarima o escenario?", answer: "El tiempo de montaje varía según la dimensión. Una tarima modular de 4x3 m se instala en 2-3 horas. Un escenario de 8x6 m requiere de 4 a 6 horas. Un escenario con techo completo de 10x8 m necesita de 8 a 12 horas, por lo que generalmente se monta el día anterior. Pasarelas y runways requieren de 3 a 5 horas según longitud. Nuestro equipo de montaje incluye entre 4 y 8 técnicos especializados según el proyecto." },
  { question: "¿Con cuánta anticipación debo reservar tarimas y escenarios?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente para escenarios con techo y montajes de gran formato. En temporada alta (noviembre a febrero y mayo-junio), lo ideal es apartar con 2 meses de anticipación. Para tarimas modulares estándar de 4x3 m o 6x4 m, generalmente hay disponibilidad con 2 semanas de anticipación. Solicitudes de último momento se atienden sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Tarimas y Escenarios para Eventos en CDMX",
    description: "Tarimas modulares, escenarios con techo, pasarelas y plataformas niveladas para bodas, conciertos y eventos corporativos. Instalación profesional incluida.",
    url: "/servicios/pistas-baile/tarimas-escenarios/",
    priceRange: { min: 3000, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Tarimas y Escenarios", url: "/servicios/pistas-baile/tarimas-escenarios/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Tarimas y Escenarios para Eventos en CDMX"
  description="Renta de tarimas modulares, escenarios con techo, pasarelas y plataformas niveladas para eventos en CDMX. Instalación profesional incluida. Desde $3,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Estructuras profesionales para cualquier evento"
    title='Renta de <span class="highlight">Tarimas y Escenarios</span> para Eventos en CDMX'
    subtitle="Tarimas modulares de aluminio con altura ajustable de 40 a 120 cm, escenarios con techo, pasarelas para desfiles y plataformas niveladas para cualquier terreno. Instalación profesional y carga certificada de 750 kg/m²."
    primaryCTA={{ label: "Cotiza tu tarima", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar tarimas y escenarios para mi evento` }}
    cards={[
      {
        title: "Tarimas y escenarios de grado profesional para cada evento",
        content: "<strong>Renta de tarimas y escenarios para eventos</strong> con estructuras de aluminio certificadas en CDMX. Tarimas modulares ensamblables con altura ajustable de 40 a 120 cm y capacidad de carga de 750 kg/m² para conferencias, ceremonias y presentaciones. Escenarios con techo tipo truss con puntos de rigging para iluminación y sonido, protección contra lluvia y viento. Pasarelas elevadas con iluminación LED perimetral para desfiles de moda y premiaciones — cada estructura verificada y certificada antes de cada montaje.",
      },
      {
        title: "Instalación profesional con equipo técnico especializado",
        content: "<strong>Servicio de montaje completo</strong> incluido en cada renta de tarimas y escenarios. Nuestro equipo de 4 a 8 técnicos especializados se encarga del transporte, ensamblaje estructural, nivelación con láser, instalación de escaleras y barandales de seguridad, y verificación de carga antes de cada evento. Incluye desmontaje y recolección sin costo adicional dentro de CDMX. Para escenarios con techo, instalamos estructura de truss, cubierta impermeable y sistema de desagüe profesional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un escenario profesional para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con la tarima ideal para tu espacio y tipo de evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de tarima
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Tarimas y Escenarios"
        subtitle="La estructura perfecta para cada tipo de evento"
        description={[
          "Desde tarimas modulares para presentaciones corporativas hasta escenarios completos con techo para conciertos y festivales. Contamos con el inventario de estructuras para eventos más completo de la Ciudad de México.",
          "Cada tarima incluye escaleras de acceso, barandales de seguridad, nivelación con láser y equipo técnico de montaje especializado. Estructuras certificadas para garantizar la seguridad de artistas, presentadores y asistentes."
        ]}
      />

      <div class="grid grid--4">
        {TARIMAS.map((tarima) => (
          <Card
            name={tarima.name}
            excerpt={tarima.excerpt}
            cta={tarima.cta}
            href={tarima.href}
            icon={tarima.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TARIMAS MODULARES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="modulares-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Configuración flexible</span>
          <h2 class="showcase__title" id="modulares-heading">Tarimas Modulares</h2>
          <p class="showcase__subtitle">Plataformas de aluminio ensamblables con altura ajustable para cualquier tipo de evento.</p>
          <p class="showcase__text">Nuestras <strong>tarimas modulares de aluminio</strong> se ensamblan en cualquier configuración gracias a su sistema de paneles de <strong>1x1 m y 2x1 m</strong> que se conectan de forma segura. Altura ajustable desde <strong>40 hasta 120 cm</strong> en incrementos de 20 cm, adaptándose a ceremonias íntimas, conferencias corporativas y escenarios de gran formato. Capacidad de carga certificada de <strong>750 kg/m²</strong> que soporta equipos de sonido, iluminación y grupos de personas con total seguridad.</p>
          <p class="showcase__text">Incluyen <strong>escaleras de acceso con barandal de seguridad, faldones decorativos</strong> en color negro o blanco, superficie antideslizante y nivelación con láser para garantizar una plataforma perfectamente horizontal. Ideales para <strong>bodas, conferencias, presentaciones de producto, ceremonias religiosas y entregas de premios</strong>. El montaje de una tarima de 4x3 m se realiza en 2-3 horas. Combínalas con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para presentaciones con impacto profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">40-120 cm altura</span>
            <span class="showcase__tag">750 kg/m²</span>
            <span class="showcase__tag">Aluminio certificado</span>
            <span class="showcase__tag">Modulares 1x1 m</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Tarimas Modulares
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESCENARIOS CON TECHO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="techo-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Producción completa</span>
          <h2 class="showcase__title" id="techo-heading">Escenarios con Techo</h2>
          <p class="showcase__subtitle">Escenario profesional con estructura de truss, puntos de rigging y protección contra lluvia.</p>
          <p class="showcase__text">Nuestros <strong>escenarios con techo</strong> ofrecen una solución de producción completa para eventos al aire libre. Estructura de <strong>truss de aluminio de alta resistencia</strong> con cubierta de lona PVC impermeable y tratamiento UV. Incluyen <strong>puntos de rigging distribuidos</strong> con capacidad de hasta 500 kg para montar iluminación, pantallas LED, bocinas y elementos decorativos. El diseño con pendiente calculada y <strong>canaletas de desagüe</strong> garantiza protección total contra lluvia.</p>
          <p class="showcase__text">Disponibles en dimensiones desde <strong>6x4 m hasta 12x8 m</strong>, con opciones de cerramiento lateral para eventos privados. El sistema de rigging permite instalar <strong>luces moving head, barras LED, line arrays de sonido y pantallas de video</strong> directamente en la estructura. Ideales para <strong>conciertos, festivales, bodas al aire libre, lanzamientos de producto y eventos corporativos outdoor</strong>. El montaje completo requiere de 8 a 12 horas. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para producciones de nivel espectacular.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Truss aluminio</span>
            <span class="showcase__tag">Rigging 500 kg</span>
            <span class="showcase__tag">Lona impermeable</span>
            <span class="showcase__tag">Hasta 12x8 m</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Escenario con Techo
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
              <line x1="2" y1="3" x2="12" y2="1"/>
              <line x1="22" y1="3" x2="12" y2="1"/>
              <line x1="2" y1="17" x2="2" y2="21"/>
              <line x1="22" y1="17" x2="22" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PASARELAS Y RUNWAYS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pasarelas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Fashion y premiaciones</span>
          <h2 class="showcase__title" id="pasarelas-heading">Pasarelas y Runways</h2>
          <p class="showcase__subtitle">Pasarelas elevadas con alfombra antideslizante e iluminación LED perimetral para desfiles y premiaciones.</p>
          <p class="showcase__text">Nuestras <strong>pasarelas y runways profesionales</strong> están diseñadas para desfiles de moda, premiaciones y eventos especiales que requieren una plataforma elevada de recorrido. Disponibles en configuraciones <strong>recta, en T y en L</strong> con anchos de 1.5 a 3 metros y longitudes de hasta 20 metros. Superficie con <strong>alfombra antideslizante premium</strong> en colores blanco, negro, rojo o personalizado según la temática de tu evento.</p>
          <p class="showcase__text">Incluyen <strong>iluminación LED perimetral integrada</strong> en los bordes que crea un efecto visual espectacular, con opción de cambio de color sincronizado con la música. Estructura de aluminio con <strong>altura de 40 a 80 cm</strong>, escaleras de acceso en ambos extremos y barandales laterales opcionales. Ideales para <strong>fashion shows, premiaciones corporativas, presentaciones de producto, quinceañeras y bodas temáticas</strong>. Combínalas con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para crear áreas VIP y zonas de espectadores elegantes.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Forma T / L / Recta</span>
            <span class="showcase__tag">LED perimetral</span>
            <span class="showcase__tag">Hasta 20 m</span>
            <span class="showcase__tag">Alfombra premium</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pasarela
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="12" y1="2" x2="12" y2="22"/>
              <line x1="4" y1="12" x2="20" y2="12"/>
              <polyline points="4 6 12 2 20 6"/>
              <polyline points="4 18 12 22 20 18"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PLATAFORMAS NIVELADAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="niveladas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Cualquier terreno</span>
          <h2 class="showcase__title" id="niveladas-heading">Plataformas Niveladas</h2>
          <p class="showcase__subtitle">Patas de altura ajustable para instalación perfecta en jardines, pendientes y terrenos irregulares.</p>
          <p class="showcase__text">Nuestras <strong>plataformas niveladas</strong> están diseñadas específicamente para eventos en terrenos irregulares donde se requiere una superficie perfectamente horizontal. Cada módulo cuenta con <strong>patas de altura ajustable independiente</strong> que compensan desniveles de hasta 40 cm por módulo. Sistema de <strong>nivelación con láser de precisión</strong> que garantiza una plataforma completamente plana, sin importar si el terreno es césped, tierra, grava, pendiente o arena.</p>
          <p class="showcase__text">Incluyen <strong>base de distribución de peso</strong> para proteger el césped y evitar hundimientos, faldones perimetrales decorativos y superficie antideslizante certificada. Ideales para <strong>bodas en jardín, eventos en haciendas, fiestas en playa, ceremonias en bosque y celebraciones en azoteas con pendiente</strong>. La instalación incluye evaluación previa del terreno con medición de niveles. Nuestro equipo de montaje de 4-6 técnicos nivela y ensambla una plataforma de 6x4 m en aproximadamente 4 horas. Complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> para crear un espacio completo techado y nivelado.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Ajuste independiente</span>
            <span class="showcase__tag">Nivelación láser</span>
            <span class="showcase__tag">Protege césped</span>
            <span class="showcase__tag">Hasta 40 cm desnivel</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Plataforma Nivelada
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <line x1="3" y1="12" x2="21" y2="12"/>
              <line x1="12" y1="3" x2="12" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Tarimas y Escenarios"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu tarima o escenario, es natural tener preguntas sobre capacidad de carga, alturas, tiempos de montaje y condiciones climáticas. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre tarimas y escenarios al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de tarimas y escenarios para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
