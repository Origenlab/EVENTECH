---
/**
 * ─── EVENTECH.MX — Renta de Tarimas y Escenarios para Eventos (Hub L4, molde hm- 2026) ───
 * Modulares · Con Techo · Pasarelas · Plataformas Niveladas — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/pistas-baile — pista-baile genéricas (faltan fotos de tarima por tipo).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "modulares",
    name: "Tarimas Modulares",
    badge: "El estándar",
    excerpt: "Plataformas de aluminio ensamblables con altura ajustable de 40 a 120 cm y carga máxima de 750 kg/m². Ideales para conferencias, ceremonias y presentaciones.",
    href: "/servicios/pistas-baile/tarimas-escenarios/modulares/",
    image: "/images/pistas-baile/pista-baile-01.avif",
    specs: ["40–120 cm altura", "750 kg/m²", "Aluminio certificado", "Módulos 1×1 m"],
  },
  {
    id: "con-techo",
    name: "Escenarios con Techo",
    badge: "Producción pro",
    excerpt: "Escenario completo con estructura de techo tipo truss, puntos de rigging para iluminación y sonido, y protección contra lluvia. Producción profesional garantizada.",
    href: "/servicios/pistas-baile/tarimas-escenarios/con-techo/",
    image: "/images/pistas-baile/pista-baile-02.avif",
    specs: ["Truss aluminio", "Rigging 500 kg", "Lona impermeable", "Hasta 12×8 m"],
  },
  {
    id: "pasarelas",
    name: "Pasarelas y Runways",
    badge: "Desfiles y moda",
    excerpt: "Pasarelas elevadas con alfombra antideslizante e iluminación LED perimetral. Configuraciones en T, L o recta para desfiles de moda y premiaciones.",
    href: "/servicios/pistas-baile/tarimas-escenarios/pasarelas/",
    image: "/images/pistas-baile/pista-baile-03.avif",
    specs: ["Forma T / L / recta", "LED perimetral", "Hasta 20 m", "Alfombra premium"],
  },
  {
    id: "plataformas-niveladas",
    name: "Plataformas Niveladas",
    badge: "Terreno irregular",
    excerpt: "Patas de altura ajustable para instalación en jardines, pendientes y terrenos irregulares. Superficie perfectamente nivelada garantizada en cualquier terreno.",
    href: "/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/",
    image: "/images/pistas-baile/pista-baile-04.avif",
    specs: ["Ajuste independiente", "Nivelación láser", "Protege césped", "Hasta 40 cm desnivel"],
  },
];

const whyFeatures = [
  {
    title: "Cálculo de carga para cada montaje",
    body: "Una tarima carga peso sobre la gente: equipo, mobiliario y personas. Nuestras tarimas de aluminio soportan 750 kg/m² y los escenarios con techo, 500 kg por punto de rigging. Hacemos evaluación de carga según el montaje específico de tu evento —no un número genérico— para garantizar seguridad estructural real.",
  },
  {
    title: "Escaleras y barandal de seguridad incluidos",
    body: "Subir y bajar de una tarima elevada es donde más accidentes ocurren. Todas nuestras tarimas incluyen escaleras de acceso con barandal de seguridad y bases antideslizantes. La elevación luce profesional sin comprometer la seguridad de ponentes, artistas y staff que suben y bajan durante el evento.",
  },
  {
    title: "Techo truss impermeable con rigging para producción",
    body: "El escenario con techo no solo cubre de la lluvia: es la estructura de la que cuelga toda la producción. Cubierta de lona PVC impermeable con tratamiento UV y pendiente calculada para desagüe, más puntos de rigging para colgar iluminación, sonido y pantallas. Protege equipo y artistas y sostiene el show.",
  },
  {
    title: "Anclaje certificado para viento de 80 km/h",
    body: "Un escenario outdoor mal anclado es un riesgo serio. Usamos lastres de concreto de 500 kg por pata, tensores de acero y bases certificadas que resisten vientos de hasta 80 km/h. Evaluamos el terreno y el clima antes del evento, con protocolo de refuerzo o desmontaje preventivo ante alertas de viento fuerte.",
  },
  {
    title: "Nivelación láser en cualquier terreno",
    body: "Un escenario con escalón o inclinación se nota y es peligroso. Las patas de ajuste independiente con nivelación láser compensan desniveles de hasta 40 cm sobre jardín, pasto o pendiente, protegiendo el césped. La superficie queda perfectamente plana sin importar cómo esté el terreno debajo.",
  },
  {
    title: "Montaje propio e integración con luz y sonido",
    body: "Equipo de montaje propio de 4 a 8 técnicos especializados según el proyecto, con tiempos claros por dimensión. El escenario luce más cuando la iluminación, el rigging y el sonido vienen coordinados del mismo proveedor. Integramos toda la producción desde EVENTECH, con una sola logística.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y cálculo de carga", p: "Evaluamos el venue, el terreno y el montaje que va sobre la tarima (equipo, artistas, mobiliario) para calcular la carga y la estructura. Definimos altura, dimensión y si requiere techo o rigging. En 24-48 horas te enviamos propuesta técnica con el escenario ideal." },
  { n: 2, t: "Propuesta y aparto", p: "Definimos tipo (tarima modular, escenario con techo, pasarela o plataforma nivelada), altura, forma y rigging. Con el anticipo apartamos el equipo y la fecha. Los escenarios con techo y de gran formato requieren apartar con más tiempo, sobre todo en temporada alta." },
  { n: 3, t: "Montaje, nivelación y rigging", p: "Nuestro equipo instala con anticipación: armado de módulos, nivelación láser, escaleras con barandal, techo truss y rigging si aplica, y anclaje certificado en exteriores. Cerramos con prueba de carga y seguridad antes de entregar el escenario." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento el escenario soporta la producción con seguridad certificada. Al finalizar, desmontamos estructura, techo y rigging con protocolo de seguridad. El montaje, la nivelación y el desmontaje están incluidos dentro de CDMX y ZMVM." },
];

const faqs = [
  { question: "¿Cuánto peso soportan las tarimas y escenarios?", answer: "Nuestras tarimas modulares de aluminio soportan hasta 750 kg/m², lo que permite montar con seguridad equipos de sonido, iluminación, mobiliario pesado y grupos de personas. Cada módulo está certificado estructuralmente y cuenta con patas reforzadas con bases antideslizantes. Para escenarios con techo, la estructura de truss soporta hasta 500 kg en puntos de rigging distribuidos. Siempre realizamos una evaluación de carga según el montaje específico de tu evento." },
  { question: "¿Qué opciones de altura tienen las tarimas?", answer: "Ofrecemos alturas ajustables desde 40 cm hasta 120 cm en incrementos de 20 cm. Las tarimas de 40 cm son ideales para ceremonias y presentaciones en salón donde se busca una ligera elevación. Las de 60-80 cm son perfectas para escenarios de conferencias y conciertos medianos. Las de 100-120 cm se usan para festivales y eventos masivos donde la audiencia necesita mayor visibilidad. Todas incluyen escaleras de acceso con barandal de seguridad." },
  { question: "¿Pueden montar el escenario a la medida y forma de mi evento?", answer: "Sí. Al ser un sistema modular de piezas de 1×1 m, armamos prácticamente cualquier dimensión y forma: escenarios rectangulares, en L, en T, con desniveles (risers) para baterías o coros, extensiones tipo thrust hacia el público, y pasarelas integradas. Diseñamos la configuración exacta según tu programa —conferencia, concierto, desfile o ceremonia— y el espacio del venue. En la visita técnica proponemos el layout óptimo y te lo mostramos en un plano antes del montaje." },
  { question: "¿Los escenarios al aire libre resisten el viento?", answer: "Sí. Nuestros escenarios con techo están diseñados para resistir vientos de hasta 80 km/h con anclaje profesional. Utilizamos lastres de concreto de 500 kg por pata, tensores de acero y bases de anclaje certificadas. Para eventos outdoor, realizamos una evaluación previa del terreno y las condiciones meteorológicas. En caso de alerta por vientos superiores a 80 km/h, contamos con protocolos de seguridad que incluyen refuerzo adicional o desmontaje preventivo." },
  { question: "¿Los escenarios con techo protegen contra la lluvia?", answer: "Absolutamente. La cubierta de nuestros escenarios con techo está fabricada en lona PVC impermeable de alta resistencia con tratamiento UV. El diseño incluye pendiente calculada para desagüe eficiente y canaletas laterales que dirigen el agua lejos del escenario. Protege tanto el equipo técnico (iluminación, sonido, pantallas) como a los artistas y presentadores. Hemos operado exitosamente bajo lluvias moderadas a fuertes sin interrumpir eventos." },
  { question: "¿Cuánto tiempo toma instalar una tarima o escenario?", answer: "El tiempo de montaje varía según la dimensión. Una tarima modular de 4x3 m se instala en 2-3 horas. Un escenario de 8x6 m requiere de 4 a 6 horas. Un escenario con techo completo de 10x8 m necesita de 8 a 12 horas, por lo que generalmente se monta el día anterior. Pasarelas y runways requieren de 3 a 5 horas según longitud. Nuestro equipo de montaje incluye entre 4 y 8 técnicos especializados según el proyecto." },
  { question: "¿Con cuánta anticipación debo reservar tarimas y escenarios?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente para escenarios con techo y montajes de gran formato. En temporada alta (noviembre a febrero y mayo-junio), lo ideal es apartar con 2 meses de anticipación. Para tarimas modulares estándar de 4x3 m o 6x4 m, generalmente hay disponibilidad con 2 semanas de anticipación. Solicitudes de último momento se atienden sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Tarimas y Escenarios para Eventos en CDMX",
    description: "Renta de tarimas modulares, escenarios con techo truss, pasarelas y plataformas niveladas en CDMX. Cálculo de carga, rigging y montaje incluidos.",
    url: "/servicios/pistas-baile/tarimas-escenarios/",
    priceRange: { min: 3000, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Tarimas y Escenarios", url: "/servicios/pistas-baile/tarimas-escenarios/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Tarimas y Escenarios" },
];
---

<PageLayout
  title="Renta de Tarimas y Escenarios para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/pistas-baile/pista-baile-02.avif"
  description="Renta de tarimas modulares, escenarios con techo, pasarelas y plataformas niveladas en CDMX. Cálculo de carga, rigging y montaje incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="tarimas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Tarimas y escenarios · CDMX y ZMVM</p>
            <h1 id="tarimas-hero-heading">
              Tarimas y escenarios que elevan <em>al protagonista sobre la audiencia</em>
            </h1>
            <p class="hm-hero__lead">
              Tarimas modulares de altura ajustable, escenarios con techo truss, pasarelas con LED y
              plataformas niveladas para terreno irregular. La base segura de conferencias, conciertos,
              desfiles y ceremonias — con cálculo de carga y montaje incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20tarima%20o%20escenario%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar escenario
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>tarimas y escenarios para eventos</strong> en CDMX con módulos de
              aluminio certificado que soportan <strong>750 kg/m²</strong>: <strong>tarimas modulares</strong>
              de 40 a 120 cm de altura, <strong>escenarios con techo truss</strong> impermeable y rigging
              de 500 kg, <strong>pasarelas</strong> en T, L o recta con LED perimetral, y <strong>plataformas
              niveladas</strong> para terreno irregular. Cada montaje se dimensiona con cálculo de carga.
            </p>
            <p>
              Con <strong>más de 500 escenarios montados</strong> en CDMX, sabemos que una tarima carga
              producción sobre la gente: por eso cada renta incluye cálculo estructural, escaleras con
              barandal y anclaje certificado. Combínala con nuestra
              <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a>,
              <a href="/servicios/audiovisual/sonido/">sonido</a> y
              <a href="/servicios/carpas/hangar/">carpas hangar</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de tarima y escenario disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20tarima%20o%20escenario%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La base de tu producción</p>
            <h2 id="catalogo-heading">¿Qué escenario necesita tu evento?</h2>
            <p class="hm__head-sub">4 soluciones — de la tarima de ceremonia al escenario con techo para concierto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El escenario es lo que pone al protagonista donde todos lo ven: el conferencista, el
              artista, los novios, el modelo en la pasarela. Una tarima bien calculada y nivelada se
              siente firme y segura; una improvisada se mueve, cruje o queda con escalón peligroso.
            </p>
            <p>
              Tarimas modulares para elevar con seguridad. Escenarios con techo para producción
              completa. Pasarelas para desfiles y premiaciones. Plataformas niveladas para instalar en
              cualquier terreno. Una sola empresa para toda la base de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada solución, a fondo</p>
            <h2 id="detalle-heading">Las 4 soluciones de escenario — en detalle</h2>
            <p class="hm__head-sub">Altura, carga, techo y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada tarima hay decisiones que afectan la seguridad y la producción: la altura
              que decide la visibilidad, la carga que soporta el montaje, y el techo y rigging que
              permiten colgar toda la producción sobre el escenario.
            </p>
            <p>
              Conocer estas diferencias te permite dimensionar el escenario con criterio. A
              continuación, lo que realmente importa de cada solución.
            </p>
          </div>
        </div>

        <!-- MODULARES -->
        <article class="hm-feat" aria-labelledby="feat-modulares">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Tarimas Modulares</p>
            <h3 class="hm-feat__title" id="feat-modulares">Módulos de aluminio que se arman a la altura y forma exacta de tu evento</h3>
            <p class="hm-feat__lead">La base versátil de casi cualquier producción. Piezas de 1×1 m que se ensamblan como bloques para crear el escenario del tamaño, altura y forma que el evento necesita.</p>
            <p>
              Plataformas de <strong>aluminio certificado</strong> ensamblables en módulos de
              <strong>1×1 m</strong>, con altura ajustable de <strong>40 a 120 cm</strong> en
              incrementos de 20 cm y carga de <strong>750 kg/m²</strong>. Escaleras con barandal de
              seguridad incluidas. Se arman en rectángulo, L, T o con desniveles (risers).
            </p>
            <p>
              Ideales para <strong>conferencias, ceremonias, presentaciones y conciertos medianos</strong>.
              La altura se elige según la visibilidad que necesita la audiencia. Combínalas con nuestro
              <a href="/servicios/audiovisual/sonido/">sonido</a> e
              <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para una producción completa.
            </p>
            <ul class="hm-feat__stats">
              {["40–120 cm altura", "750 kg/m²", "Aluminio certificado", "Módulos 1×1 m", "Escaleras + barandal"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/pistas-baile/tarimas-escenarios/modulares/">
              Ver Tarimas Modulares
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/pistas-baile/pista-baile-01.avif" alt="Tarima modular de aluminio para presentación en evento en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/pistas-baile/pista-baile-05.avif" alt="Tarima modular con escaleras y barandal de seguridad" loading="lazy" decoding="async" />
              <img src="/images/pistas-baile/pista-baile-06.avif" alt="Módulos de aluminio ensamblados para escenario" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- CON TECHO -->
        <article class="hm-feat" aria-labelledby="feat-con-techo">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Escenarios con Techo</p>
            <h3 class="hm-feat__title" id="feat-con-techo">El escenario de producción completa que protege del clima y sostiene el show</h3>
            <p class="hm-feat__lead">Cuando hay concierto, banda o producción seria, el escenario necesita techo. No solo para la lluvia: es la estructura de la que cuelga toda la iluminación, el sonido y las pantallas.</p>
            <p>
              Escenario completo con <strong>estructura de techo tipo truss</strong>, cubierta de
              <strong>lona PVC impermeable</strong> con tratamiento UV y pendiente para desagüe, y
              <strong>puntos de rigging de 500 kg</strong> para colgar producción. En dimensiones de
              <strong>hasta 12×8 metros</strong>, con anclaje certificado para vientos de 80 km/h.
            </p>
            <p>
              El estándar para <strong>conciertos, festivales, eventos masivos y producciones de
              escenario</strong> en interior o exterior. Protege equipo, artistas y show por igual.
              Combínalo con nuestro <a href="/servicios/iluminacion/escenario/">rig de iluminación</a> y
              <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> colgadas del truss.
            </p>
            <ul class="hm-feat__stats">
