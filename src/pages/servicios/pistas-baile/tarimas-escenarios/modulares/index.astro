---
/**
 * ─── Tarimas Modulares — Pagina de Producto (Nivel 4) ───
 * Tarimas modulares de aluminio con altura ajustable 40-120cm
 * y carga de 750 kg/m² para conferencias y ceremonias.
 *
 * Jerarquia: Servicios > Pistas de Baile > Tarimas y Escenarios > Tarimas Modulares
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Tarimas y Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/" },
  { label: "Tarimas Modulares" },
];

const faqs = [
  { question: "¿Cuánto peso soportan las tarimas modulares?", answer: 'Nuestras tarimas modulares de aluminio soportan hasta <strong>750 kg/m²</strong>, lo que permite montar con total seguridad equipos de sonido, iluminación, mobiliario pesado y grupos de personas. Cada módulo cuenta con patas telescópicas con seguro mecánico y bases antideslizantes que distribuyen el peso uniformemente. Para montajes con equipo especialmente pesado como <a href="/servicios/audiovisual/sonido/">line arrays de sonido</a>, realizamos una evaluación de carga específica antes del evento.' },
  { question: "¿Se puede ajustar la altura de la tarima una vez instalada?", answer: 'No es recomendable ajustar la altura una vez montada y con equipo encima. Sin embargo, nuestras patas telescópicas permiten <strong>ajuste previo de 40 a 120 cm</strong> en incrementos de 20 cm durante la instalación. Nuestro equipo técnico define la altura ideal según el tipo de evento: 40 cm para ceremonias, 60-80 cm para conferencias y 100-120 cm para conciertos y festivales. La nivelación con láser garantiza una superficie perfectamente horizontal.' },
  { question: "¿Las tarimas modulares incluyen escalones de acceso?", answer: 'Sí, <strong>todas nuestras tarimas incluyen escalones laterales con barandal de seguridad</strong> sin costo adicional. Los escalones son de aluminio con superficie antideslizante y se instalan en uno o ambos lados según la configuración. Para alturas de 80 cm o más, los barandales son obligatorios por norma de seguridad. También ofrecemos rampas de acceso para personas con movilidad reducida como complemento opcional.' },
  { question: "¿Se pueden instalar tarimas modulares en jardín o terreno natural?", answer: 'Sí, nuestras tarimas modulares se instalan en prácticamente cualquier terreno: césped, tierra compacta, grava, concreto o piso de salón. Para jardines y terrenos naturales, utilizamos <strong>bases de distribución de peso</strong> que protegen el césped y evitan hundimientos. Las patas telescópicas compensan desniveles menores. Para terrenos con pendiente pronunciada, te recomendamos nuestras <a href="/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/">plataformas niveladas</a> con ajuste independiente por pata.' },
  { question: "¿Se puede combinar la tarima modular con una carpa?", answer: 'Absolutamente. Es una de las configuraciones más solicitadas para eventos al aire libre. La tarima modular se instala dentro o adyacente a nuestras <a href="/servicios/carpas/">carpas profesionales</a> — árabes, estructurales o hangar. Coordinamos las dimensiones de tarima y carpa para un montaje integrado. También combinamos con <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> y <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para producciones completas.' },
  { question: "¿Con cuánta anticipación debo reservar mis tarimas modulares?", answer: 'Recomendamos reservar con <strong>2 a 4 semanas de anticipación</strong> para garantizar disponibilidad de las dimensiones que necesitas. Las tarimas de 4x4 y 6x4 metros son las más solicitadas y se agotan primero en temporada alta (noviembre a febrero). Para configuraciones grandes de 8x6 m o superiores, lo ideal es apartar con <strong>1 mes de anticipación</strong>. También atendemos solicitudes de último momento sujetas a disponibilidad de inventario.' },
];

const specs = [
  { label: "Material", value: "Aluminio reforzado" },
  { label: "Superficie", value: "Madera contrachapada antideslizante" },
  { label: "Altura", value: "Ajustable 40 a 120 cm" },
  { label: "Carga", value: "750 kg/m²" },
  { label: "Módulos", value: "1x2 y 2x2 metros" },
  { label: "Configuraciones", value: "Recta, L, T, U, isla" },
  { label: "Escalones", value: "Laterales con barandal incluidos" },
  { label: "Faldón", value: "Tela decorativa opcional" },
  { label: "Patas", value: "Telescópicas con seguro" },
  { label: "Montaje", value: "Profesional, 2-4 horas" },
];

const sidebarNav = [
  { name: "Tarimas Modulares", href: null, active: true },
  { name: "Escenarios con Techo", href: "/servicios/pistas-baile/tarimas-escenarios/con-techo/" },
  { name: "Pasarelas y Runways", href: "/servicios/pistas-baile/tarimas-escenarios/pasarelas/" },
  { name: "Plataformas Niveladas", href: "/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/" },
];

const sidebarRelated = [
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "María Fernanda López", text: "Rentamos una tarima de 4x4 metros para la ceremonia de nuestra boda en un jardín de Coyoacán. La altura de 60 cm fue perfecta para que todos los invitados vieran el altar. Los escalones con barandal dieron seguridad y el faldón blanco se integró hermosamente con la decoración. El montaje fue rápido y profesional.", rating: 5, date: "2025-11-20" },
  { author: "Carlos Mendoza", text: "Usamos una tarima de 6x4 metros para una conferencia corporativa de 200 personas en un hotel de Polanco. La superficie antideslizante fue ideal para los ponentes y la carga soportó sin problema el podium, las pantallas y todo el equipo audiovisual. Excelente servicio y puntualidad.", rating: 5, date: "2025-10-12" },
  { author: "Andrea Ruiz", text: "Contratamos tarimas modulares en configuración L para un evento de banda en vivo en una hacienda en Tlalpan. La altura de 100 cm permitió que las 300 personas del público vieran perfectamente a los músicos. El equipo de EVENTECH fue muy profesional durante todo el montaje y desmontaje.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Tarimas Modulares para Eventos en CDMX",
    description: "Renta de tarimas modulares de aluminio con altura ajustable de 40 a 120 cm y carga de 750 kg/m² para conferencias y ceremonias en CDMX. Desde $3,000.",
    url: "/servicios/pistas-baile/tarimas-escenarios/modulares/",
    priceRange: { min: 3000, max: 18000 },
    reviews,
    ratingValue: 5,
    reviewCount: 267,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Tarimas y Escenarios", url: "/servicios/pistas-baile/tarimas-escenarios/" },
    { name: "Tarimas Modulares", url: "/servicios/pistas-baile/tarimas-escenarios/modulares/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Tarimas Modulares para Eventos en CDMX"
  description="Renta de tarimas modulares de aluminio con altura ajustable de 40 a 120 cm y carga de 750 kg/m² para conferencias y ceremonias en CDMX. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Altura ajustable de 40 a 120 cm"
    title='Renta de <span class="highlight">Tarimas Modulares</span> para Eventos en CDMX'
    subtitle="Tarimas modulares de aluminio reforzado con altura ajustable, superficie antideslizante y carga certificada de 750 kg/m². Configuraciones en L, T, U o isla con escalones y barandales incluidos."
    primaryCTA={{ label: "Cotiza tu tarima", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar tarimas modulares para mi evento` }}
    cards={[
      {
        title: "Plataformas de aluminio ensamblables con altura ajustable",
        content: "<strong>Renta de tarimas modulares de aluminio</strong> con la estructura más versátil para eventos en CDMX. Plataformas ensamblables con altura ajustable de 40 a 120 cm en incrementos de 20 cm, carga máxima certificada de 750 kg/m² y superficie de madera contrachapada antideslizante. Módulos de 1x2 y 2x2 metros que se ensamblan en cualquier dimensión. Ideales para ceremonias, conferencias, presentaciones de producto y escenarios de bandas en vivo.",
      },
      {
        title: "Configuraciones libres con escalones y barandales de seguridad",
        content: "<strong>Configuraciones personalizadas</strong> en L, T, U o isla según las necesidades de tu evento. Cada tarima incluye escalones laterales con barandal de seguridad, faldón decorativo opcional en color negro o blanco, y nivelación con láser para garantizar una superficie perfectamente horizontal. Patas telescópicas con seguro mecánico que garantizan estabilidad total. Montaje profesional de 2 a 4 horas con equipo técnico especializado. Desmontaje y recolección incluidos sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas una tarima profesional para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta técnica con la configuración ideal para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Tarimas y Escenarios para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas tarimas modulares para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar tarimas modulares para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="12" width="20" height="8" rx="1"/><path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/><path d="M12 6V2"/><path d="M8 6V4"/><path d="M16 6V4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Tarimas Modulares</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Tarima Ceremonia -->
          <section class="section section--alt" aria-labelledby="ceremonia-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Bodas y ceremonias</span>
                <h2 class="showcase__title" id="ceremonia-heading">Tarima Ceremonia</h2>
                <p class="showcase__subtitle">Altar elevado para bodas y ceremonias con acabado elegante y vista privilegiada para todos los invitados.</p>
                <p class="showcase__text">Nuestra <strong>tarima para ceremonias</strong> eleva el altar de tu boda o ceremonia para que cada invitado disfrute una vista perfecta del momento más importante. Con alturas de <strong>40 a 60 cm</strong>, la plataforma crea un escenario íntimo y elegante sin obstruir la visual de la decoración ni el paisaje del venue. Superficie de madera contrachapada con <strong>acabado antideslizante</strong> que permite caminar con tacones, zapatos de vestir y trajes largos con total seguridad.</p>
                <p class="showcase__text">Incluye <strong>faldón decorativo</strong> en blanco, marfil o negro que se integra con la paleta de colores de tu evento, escalones laterales discretos con barandal y <strong>nivelación con láser</strong> para una superficie perfectamente horizontal. Configuraciones desde 3x2 m para ceremonias íntimas hasta 6x4 m para bodas de gran formato. Combínala con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para crear un ambiente mágico e inolvidable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">40-60 cm altura</span>
                  <span class="showcase__tag">Faldón decorativo</span>
                  <span class="showcase__tag">Antideslizante</span>
                  <span class="showcase__tag">Bodas y ceremonias</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tarima Ceremonia
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Tarima Ceremonia</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Tarima Conferencia -->
          <section class="section section--alt" aria-labelledby="conferencia-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Corporativos y paneles</span>
                <h2 class="showcase__title" id="conferencia-heading">Tarima Conferencia</h2>
                <p class="showcase__subtitle">Escenario profesional para ponentes, paneles de discusión y presentaciones corporativas.</p>
                <p class="showcase__text">La <strong>tarima para conferencias</strong> ofrece un escenario profesional para ponentes, moderadores y panelistas con <strong>altura de 60 a 80 cm</strong> que garantiza visibilidad desde cualquier punto del salón. La superficie antideslizante de madera contrachapada soporta podiums, mesas de panel, sillas ejecutivas y equipo audiovisual pesado gracias a su <strong>capacidad de carga de 750 kg/m²</strong>. Módulos de 2x2 m que se ensamblan en configuraciones desde 4x3 hasta 8x6 metros.</p>
                <p class="showcase__text">Incluye <strong>escalones con barandal</strong> en uno o ambos costados para acceso seguro de ponentes, faldón profesional en negro y espacio para <strong>cableado oculto</strong> debajo de la tarima. Compatible con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y <a href="/servicios/audiovisual/sonido/">equipo de sonido</a> para presentaciones con impacto profesional. Ideal para <strong>congresos, keynotes, capacitaciones, lanzamientos de producto y paneles de discusión</strong> en hoteles y centros de convenciones de CDMX.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">60-80 cm altura</span>
                  <span class="showcase__tag">750 kg/m²</span>
                  <span class="showcase__tag">Cableado oculto</span>
                  <span class="showcase__tag">Hasta 8x6 m</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tarima Conferencia
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Tarima Conferencia</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Tarima Banda/DJ -->
          <section class="section section--alt" aria-labelledby="banda-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Música en vivo y DJ</span>
                <h2 class="showcase__title" id="banda-heading">Tarima Banda / DJ</h2>
                <p class="showcase__subtitle">Plataforma reforzada para músicos, equipo de sonido y montaje de DJ profesional.</p>
                <p class="showcase__text">La <strong>tarima para banda y DJ</strong> está diseñada para soportar el peso y las vibraciones de presentaciones musicales en vivo. Con <strong>altura de 80 a 120 cm</strong> y capacidad de carga de 750 kg/m², soporta baterías, amplificadores, cabinas de DJ, torres de bocinas y grupos de hasta 10 músicos simultáneamente. Superficie reforzada con <strong>amortiguación anti-vibración</strong> que reduce la transmisión de golpes al piso y protege el equipo sensible.</p>
                <p class="showcase__text">Configuraciones desde <strong>4x3 m para DJ individual hasta 8x6 m para bandas completas</strong>, con opción de niveles escalonados para bateristas o coristas. Incluye acceso por escaleras laterales o traseras, espacio bajo la tarima para <strong>cableado eléctrico y de audio oculto</strong>, y faldón perimetral. Combínala con nuestra <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para crear un show de nivel profesional. Ideal para <strong>bodas con banda en vivo, fiestas con DJ, conciertos privados y festivales</strong>.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">80-120 cm altura</span>
                  <span class="showcase__tag">Anti-vibración</span>
                  <span class="showcase__tag">Cableado oculto</span>
                  <span class="showcase__tag">Hasta 10 músicos</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Tarima Banda/DJ
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="2" y="12" width="20" height="8" rx="1"/>
                    <path d="M4 12V8a2 2 0 012-2h12a2 2 0 012 2v4"/>
                    <path d="M12 6V2"/>
                    <path d="M8 6V4"/><path d="M16 6V4"/>
                  </svg>
                  <span>Tarima Banda / DJ</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Tarima Completa -->
          <section class="section section--alt" aria-labelledby="kit-heading">
