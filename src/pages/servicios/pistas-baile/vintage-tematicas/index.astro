---
/**
 * ─── Pistas de Baile Vintage y Temáticas — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Pistas de Baile Vintage y Temáticas para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const PISTAS_VINTAGE = [
  {
    name: "Pista Disco con Espejos",
    excerpt: "Paneles de espejo facetados con esfera disco giratoria incluida. Perfecta para fiestas temáticas de los 70s/80s, bodas retro y eventos nostálgicos llenos de brillo.",
    cta: "Disco Espejos",
    href: "#disco-heading",
    icon: "award",
  },
  {
    name: "Pista Damero Blanco y Negro",
    excerpt: "Patrón ajedrezado clásico en blanco y negro de alto impacto visual. Ideal para galas elegantes, desfiles de moda, eventos corporativos y celebraciones sofisticadas.",
    cta: "Damero B&N",
    href: "#damero-heading",
    icon: "layers",
  },
  {
    name: "Pista Acrílico Transparente",
    excerpt: "Paneles de acrílico cristalino que crean un efecto flotante espectacular. Opción de iluminación LED inferior para eventos modernos, minimalistas y de vanguardia.",
    cta: "Acrílico",
    href: "#acrilico-heading",
    icon: "lightbulb",
  },
  {
    name: "Pista Personalizada",
    excerpt: "Vinil personalizado con tu diseño, logo, monograma o colores corporativos. Cubre cualquier superficie y se adapta a bodas, marcas, lanzamientos y eventos temáticos únicos.",
    cta: "Personalizada",
    href: "#personalizada-heading",
    icon: "heart",
  },
];

const faqs = [
  { question: "¿Los paneles de espejo de la pista disco son resistentes y duraderos?", answer: "Sí. Nuestros paneles de espejo están fabricados con acrílico espejado de alta densidad, no vidrio, por lo que son resistentes a impactos y seguros para el uso en pistas de baile. Soportan el peso y movimiento de los invitados sin riesgo de rotura. Cada panel tiene bordes sellados y superficie antiderrapante. Además, los espejos facetados están diseñados para reflejar la luz de la esfera disco y crear un efecto visual envolvente sin deslumbrar." },
  { question: "¿Cuánto peso soporta la pista de acrílico transparente?", answer: "Nuestras pistas de acrílico transparente están fabricadas con paneles de policarbonato de grado industrial de 30 mm de espesor. Cada panel soporta hasta 500 kg por metro cuadrado, lo que permite que múltiples personas bailen simultáneamente con total seguridad. La estructura de soporte de aluminio reforzado distribuye el peso uniformemente. Realizamos pruebas de carga antes de cada evento y certificamos la instalación." },
  { question: "¿Con cuánto tiempo de anticipación necesito solicitar un diseño personalizado?", answer: "Para pistas con vinil personalizado (logos, monogramas, diseños especiales) recomendamos un mínimo de 2 semanas de anticipación para diseño, producción e instalación. Diseños simples como monogramas de boda pueden estar listos en 7 a 10 días. Para proyectos más complejos con arte original o branding corporativo detallado, lo ideal es 3 a 4 semanas. Incluimos hasta 2 rondas de revisión de diseño sin costo adicional." },
  { question: "¿Puedo combinar diferentes estilos de pista en un mismo evento?", answer: "Por supuesto. Muchos de nuestros clientes combinan estilos para crear experiencias únicas. Por ejemplo, puedes tener una pista de damero blanco y negro para la recepción formal y cambiar a la pista disco con espejos para la fiesta nocturna. También es posible combinar secciones: centro en acrílico transparente con LED y bordes en damero. Nuestro equipo de diseño te asesora sobre las mejores combinaciones según tu espacio y temática." },
  { question: "¿Las pistas vintage y temáticas se pueden instalar en exteriores?", answer: "Sí, todas nuestras pistas vintage se pueden instalar en exteriores con las adaptaciones adecuadas. Utilizamos bases niveladoras para terrenos irregulares como jardines y terrazas. La pista de acrílico y la disco requieren protección superior tipo carpa para evitar que la humedad afecte la iluminación LED. La pista damero y la personalizada en vinil son las más versátiles para exterior. Siempre realizamos una visita técnica previa para evaluar el terreno y garantizar una instalación segura." },
  { question: "¿Con cuánta anticipación debo reservar mi pista vintage o temática?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero) y para fines de semana. Las pistas disco con espejos y las de acrílico transparente son las más solicitadas y se agotan primero. Para pistas personalizadas con vinil, se necesita tiempo adicional de diseño y producción. También atendemos solicitudes de último momento (1 a 2 semanas) para pistas estándar, sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile Vintage y Temáticas para Eventos en CDMX",
    description: "Pistas disco con espejos, damero blanco y negro, acrílico transparente y personalizadas para bodas, galas y eventos temáticos. Instalación profesional incluida.",
    url: "/servicios/pistas-baile/vintage-tematicas/",
    priceRange: { min: 2500, max: 30000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Vintage y Temáticas", url: "/servicios/pistas-baile/vintage-tematicas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pistas de Baile Vintage y Temáticas para Eventos en CDMX"
  description="Renta de pistas de baile vintage y temáticas: disco con espejos, damero blanco y negro, acrílico transparente y personalizadas para eventos en CDMX. Desde $2,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diseños únicos que transforman tu evento"
    title='Renta de <span class="highlight">Pistas de Baile Vintage y Temáticas</span> para Eventos en CDMX'
    subtitle="Pistas disco con espejos, damero blanco y negro, acrílico transparente y diseños personalizados. Cada pista es una experiencia visual que convierte tu evento en un momento inolvidable."
    primaryCTA={{ label: "Cotiza tu pista", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile vintage o temática para mi evento` }}
    cards={[
      {
        title: "Pistas vintage y temáticas que crean atmósferas únicas",
        content: "<strong>Renta de pistas de baile vintage y temáticas</strong> con los diseños más exclusivos disponibles en CDMX. Pistas disco con paneles de espejo facetados y esfera giratoria para fiestas retro de los 70s y 80s. Pistas damero en patrón ajedrezado blanco y negro para galas y eventos de alta elegancia. Pistas de acrílico transparente con efecto flotante y opción LED inferior para producciones de vanguardia. Cada pista fabricada con materiales de grado profesional, superficie antiderrapante certificada y estructura de soporte de aluminio reforzado.",
      },
      {
        title: "Personalización total y montaje profesional",
        content: "<strong>Diseño personalizado sin límites</strong> para que tu pista de baile sea tan única como tu evento. Vinil de alta resolución con tu logo, monograma, colores corporativos o diseño artístico original sobre cualquier superficie de pista. Nuestro equipo de instalación se encarga del transporte, nivelación del terreno, ensamblaje de paneles, conexión de iluminación y pruebas de seguridad antes de cada evento. Desmontaje y recolección incluidos sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas una pista de baile con personalidad?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con el diseño ideal para la temática de tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de pista vintage/temática
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pistas Vintage y Temáticas"
        subtitle="Diseños exclusivos que transforman cualquier espacio"
        description={[
          "Desde la nostalgia brillante de una pista disco hasta la elegancia atemporal del patrón damero. Contamos con las pistas de baile temáticas más exclusivas de la Ciudad de México para bodas, galas y eventos especiales.",
          "Cada pista incluye estructura de soporte reforzada, superficie antiderrapante certificada e instalación profesional. También ofrecemos personalización completa con vinil de alta resolución para logos, monogramas y diseños únicos."
        ]}
      />

      <div class="grid grid--4">
        {PISTAS_VINTAGE.map((pista) => (
          <Card
            name={pista.name}
            excerpt={pista.excerpt}
            cta={pista.cta}
            href={pista.href}
            icon={pista.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA DISCO CON ESPEJOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="disco-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Estilo retro</span>
          <h2 class="showcase__title" id="disco-heading">Pista Disco con Espejos</h2>
          <p class="showcase__subtitle">El brillo icónico de los 70s y 80s que convierte cualquier fiesta en una experiencia inolvidable.</p>
          <p class="showcase__text">Nuestra <strong>pista disco con espejos</strong> está compuesta por paneles de acrílico espejado facetado que reflejan la luz en todas direcciones, creando un ambiente envolvente y deslumbrante. Incluye <strong>esfera disco giratoria profesional</strong> con motor silencioso y focos de colores dirigidos que multiplican el efecto visual. Disponible en dimensiones de <strong>3×3, 4×4 y 5×5 metros</strong>, perfecta para <strong>fiestas temáticas de los 70s y 80s, bodas retro, cumpleaños y celebraciones nostálgicas</strong>.</p>
          <p class="showcase__text">Los paneles espejados son de <strong>acrílico de alta densidad, no vidrio</strong>, garantizando seguridad total para los invitados. Superficie antiderrapante certificada y bordes sellados. Combínala con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> de colores y efectos estroboscópicos para recrear la auténtica atmósfera de una discoteca clásica con la seguridad y calidad que tu evento merece.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Espejos facetados</span>
            <span class="showcase__tag">Esfera disco</span>
            <span class="showcase__tag">3×3 a 5×5 m</span>
            <span class="showcase__tag">Retro 70s/80s</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pista Disco
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
              <line x1="12" y1="2" x2="12" y2="6"/>
              <line x1="12" y1="18" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="6" y2="12"/>
              <line x1="18" y1="12" x2="22" y2="12"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA DAMERO BLANCO Y NEGRO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="damero-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Elegancia atemporal</span>
          <h2 class="showcase__title" id="damero-heading">Pista Damero Blanco y Negro</h2>
          <p class="showcase__subtitle">El patrón ajedrezado más elegante y sofisticado para galas, desfiles y eventos de alto nivel.</p>
          <p class="showcase__text">Nuestra <strong>pista damero blanco y negro</strong> presenta un patrón ajedrezado clásico con paneles intercalados de alto contraste que crean un impacto visual inmediato. Fabricada con <strong>paneles de PVC de alta resistencia</strong> con acabado brillante y superficie antiderrapante. Disponible en configuraciones de <strong>3×3, 4×4, 5×5 y 6×6 metros</strong>. El patrón chess-board es un ícono del diseño elegante, perfecto para <strong>galas corporativas, desfiles de moda, eventos black & white y celebraciones sofisticadas</strong>.</p>
          <p class="showcase__text">Cada panel se ensambla con sistema de <strong>engarce mecánico sin tornillos visibles</strong>, logrando una superficie uniforme y continua. La combinación blanco-negro es atemporal y se adapta a cualquier paleta decorativa. Complementa tu evento con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> en tonos neutros para un montaje de revista que impresione a cada invitado desde el primer momento.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Patrón ajedrezado</span>
            <span class="showcase__tag">Alto contraste</span>
            <span class="showcase__tag">3×3 a 6×6 m</span>
            <span class="showcase__tag">Galas y moda</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pista Damero
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="8" height="8" fill="currentColor" opacity="0.3"/>
              <rect x="13" y="3" width="8" height="8"/>
              <rect x="3" y="13" width="8" height="8"/>
              <rect x="13" y="13" width="8" height="8" fill="currentColor" opacity="0.3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA ACRÍLICO TRANSPARENTE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="acrilico-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Efecto flotante</span>
          <h2 class="showcase__title" id="acrilico-heading">Pista Acrílico Transparente</h2>
          <p class="showcase__subtitle">Paneles cristalinos que crean la ilusión de bailar sobre el aire para eventos modernos y de vanguardia.</p>
          <p class="showcase__text">Nuestra <strong>pista de acrílico transparente</strong> está fabricada con paneles de policarbonato de grado industrial de <strong>30 mm de espesor</strong>, cada uno capaz de soportar hasta <strong>500 kg por metro cuadrado</strong>. La transparencia del material crea un <strong>efecto flotante espectacular</strong> que sorprende a los invitados. Disponible con <strong>iluminación LED inferior opcional</strong> en colores programables (blanco, RGB, degradados) que transforma la pista en un espectáculo de luz desde abajo.</p>
          <p class="showcase__text">La estructura de soporte de <strong>aluminio reforzado con niveladores independientes</strong> garantiza estabilidad total en cualquier superficie. Ideal para <strong>eventos modernos, bodas minimalistas, lanzamientos de producto y producciones audiovisuales</strong> donde el diseño contemporáneo es protagonista. Combina con nuestro equipamiento <a href="/servicios/audiovisual/">audiovisual profesional</a> para crear producciones de nivel internacional con proyecciones y mapping sobre la superficie transparente.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Policarbonato 30 mm</span>
            <span class="showcase__tag">LED inferior</span>
            <span class="showcase__tag">500 kg/m²</span>
            <span class="showcase__tag">RGB programable</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pista Acrílico
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" opacity="0.3"/>
              <rect x="6" y="6" width="12" height="12" rx="1" opacity="0.5"/>
              <rect x="9" y="9" width="6" height="6" rx="0.5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA PERSONALIZADA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="personalizada-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Tu diseño único</span>
          <h2 class="showcase__title" id="personalizada-heading">Pista Personalizada</h2>
          <p class="showcase__subtitle">Tu logo, monograma, colores corporativos o diseño artístico sobre cualquier superficie de pista.</p>
          <p class="showcase__text">Nuestra <strong>pista personalizada</strong> utiliza <strong>vinil de alta resolución laminado</strong> que se aplica sobre la superficie de la pista, permitiendo cualquier diseño, logo, monograma o composición gráfica que imagines. Impresión en <strong>1440 DPI con tintas UV resistentes al desgaste</strong> y laminado antiderrapante transparente que protege el diseño durante todo el evento. Desde elegantes monogramas de boda hasta branding corporativo completo con <strong>colores Pantone exactos</strong>.</p>
          <p class="showcase__text">El proceso incluye <strong>diseño gráfico profesional con hasta 2 rondas de revisión</strong>, producción en gran formato e instalación perfecta sin burbujas ni imperfecciones. Ideal para <strong>bodas, lanzamientos de marca, eventos temáticos, XV años y cualquier celebración</strong> que merezca un toque único e irrepetible. Complementa con nuestros <a href="/servicios/accesorios/">accesorios de señalización</a> como backdrops y alfombras personalizadas para una identidad visual completa en tu evento.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Vinil HD 1440 DPI</span>
            <span class="showcase__tag">Logos y monogramas</span>
            <span class="showcase__tag">Pantone exacto</span>
            <span class="showcase__tag">Diseño incluido</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pista Personalizada
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Pistas Vintage y Temáticas"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu pista de baile vintage o temática, es natural tener preguntas sobre materiales, personalización, tiempos de producción y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre pistas vintage y temáticas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de pistas de baile vintage y temáticas para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
