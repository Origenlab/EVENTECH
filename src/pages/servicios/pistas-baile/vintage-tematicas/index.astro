---
/**
 * ─── EVENTECH.MX — Renta de Pistas de Baile Vintage y Temáticas (Hub L4, molde hm- 2026) ───
 * Disco · Damero · Acrílico · Personalizada — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/pistas-baile — pista-led-rgb, madera-negra, acrilica reales.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "disco",
    name: "Pista Disco con Espejos",
    badge: "Retro 70s / 80s",
    excerpt: "Paneles de espejo facetados con esfera disco giratoria incluida. Perfecta para fiestas temáticas de los 70s/80s, bodas retro y eventos nostálgicos llenos de brillo.",
    href: "/servicios/pistas-baile/vintage-tematicas/disco/",
    image: "/images/pistas-baile/pista-led-rgb-fiesta.avif",
    specs: ["Espejos facetados", "Esfera disco", "3×3 a 5×5 m", "Acrílico espejado"],
  },
  {
    id: "damero",
    name: "Pista Damero Blanco y Negro",
    badge: "Galas y moda",
    excerpt: "Patrón ajedrezado clásico en blanco y negro de alto impacto visual. Ideal para galas elegantes, desfiles de moda, eventos corporativos y celebraciones sofisticadas.",
    href: "/servicios/pistas-baile/vintage-tematicas/damero/",
    image: "/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif",
    specs: ["Patrón ajedrezado", "Alto contraste", "3×3 a 6×6 m", "Antiderrapante"],
  },
  {
    id: "acrilico",
    name: "Pista Acrílico Transparente",
    badge: "Efecto flotante",
    excerpt: "Paneles de acrílico cristalino que crean un efecto flotante espectacular. Opción de iluminación LED inferior para eventos modernos, minimalistas y de vanguardia.",
    href: "/servicios/pistas-baile/vintage-tematicas/acrilico/",
    image: "/images/pistas-baile/pista-acrilica-transparente-boda.avif",
    specs: ["Policarbonato 30 mm", "LED inferior RGB", "500 kg/m²", "Efecto flotante"],
  },
  {
    id: "personalizada",
    name: "Pista Personalizada",
    badge: "Tu diseño",
    excerpt: "Vinil personalizado con tu diseño, logo, monograma o colores corporativos. Cubre cualquier superficie y se adapta a bodas, marcas, lanzamientos y eventos temáticos únicos.",
    href: "/servicios/pistas-baile/vintage-tematicas/personalizada/",
    image: "/images/pistas-baile/pista-baile-06.avif",
    specs: ["Vinil HD 1440 DPI", "Logos / monogramas", "Pantone exacto", "Diseño incluido"],
  },
];

const whyFeatures = [
  {
    title: "Diseño personalizado con revisiones incluidas",
    body: "Tu pista, tu diseño. Producimos vinil en alta definición (1440 DPI) con tu logo, monograma o arte, en el color Pantone exacto de tu marca o boda, con hasta 2 rondas de revisión sin costo. No es una plantilla genérica: es una pista pensada para tu evento, lista para ser el mejor fondo de fotos aéreas.",
  },
  {
    title: "Materiales seguros de grado profesional",
    body: "El brillo no está peleado con la seguridad. Los paneles disco son de acrílico espejado —no vidrio— resistentes a impactos, y el acrílico transparente es policarbonato de 30 mm que soporta 500 kg/m². Bordes sellados, superficie antiderrapante y prueba de carga antes de cada evento: espectáculo visual sin riesgo de rotura.",
  },
  {
    title: "Combina estilos por momento del evento",
    body: "No tienes que elegir uno. Muchos clientes montan damero elegante para la recepción y cambian a disco con espejos para la fiesta, o combinan un centro de acrílico con LED y bordes de damero. Nuestro equipo de diseño te asesora sobre las combinaciones que mejor funcionan según tu espacio y temática.",
  },
  {
    title: "LED inferior programable en el acrílico",
    body: "La pista de acrílico transparente lleva iluminación LED RGB inferior programable que se sincroniza con la música y crea un efecto flotante de color imposible con otros materiales. Ideal para eventos modernos y minimalistas donde la pista misma es la pieza de diseño más comentada de la noche.",
  },
  {
    title: "Instalación también en exteriores",
    body: "Todas las pistas vintage se instalan en jardín o terraza con base niveladora para terreno irregular. El damero y la personalizada en vinil son las más versátiles al aire libre; el acrílico y la disco requieren protección superior tipo carpa para cuidar la iluminación. Visita técnica previa para garantizar una instalación segura.",
  },
  {
    title: "Asesoría de estilo según tu temática",
    body: "La pista correcta amplifica el concepto del evento. Te asesoramos según la temática: disco para retro y nostalgia, damero para gala y moda, acrílico para minimalismo y vanguardia, personalizada para branding o boda con monograma. El estilo del piso se vuelve parte de la decoración, no un elemento suelto.",
  },
];

const steps = [
  { n: 1, t: "Asesoría de estilo y diseño", p: "Nos cuentas la temática y estética de tu evento y te recomendamos el estilo de pista que mejor la amplifica. Si es personalizada, recibimos tu logo o idea. En menos de 24 horas te enviamos propuesta con el estilo, tamaño y —si aplica— el boceto de diseño." },
  { n: 2, t: "Propuesta, diseño y aparto", p: "Definimos estilo, medida y —en personalizada— el arte final con hasta 2 rondas de revisión. Con el anticipo apartamos la pista y la fecha. Las pistas con vinil personalizado requieren tiempo de producción, por lo que conviene apartar con 2 a 4 semanas." },
  { n: 3, t: "Producción, montaje y prueba", p: "Producimos el vinil (si es personalizada), instalamos con anticipación, nivelamos el terreno, colocamos la esfera disco o el LED inferior según el estilo, y hacemos prueba de carga e iluminación. Todo queda listo y verificado antes de abrir puertas." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento la pista es parte del show y de la decoración. Al finalizar, desmontamos y retiramos paneles, espejos y estructura con cuidado. El montaje, la nivelación y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Los paneles de espejo de la pista disco son resistentes y duraderos?", answer: "Sí. Nuestros paneles de espejo están fabricados con acrílico espejado de alta densidad, no vidrio, por lo que son resistentes a impactos y seguros para el uso en pistas de baile. Soportan el peso y movimiento de los invitados sin riesgo de rotura. Cada panel tiene bordes sellados y superficie antiderrapante. Además, los espejos facetados están diseñados para reflejar la luz de la esfera disco y crear un efecto visual envolvente sin deslumbrar." },
  { question: "¿Cuánto peso soporta la pista de acrílico transparente?", answer: "Nuestras pistas de acrílico transparente están fabricadas con paneles de policarbonato de grado industrial de 30 mm de espesor. Cada panel soporta hasta 500 kg por metro cuadrado, lo que permite que múltiples personas bailen simultáneamente con total seguridad. La estructura de soporte de aluminio reforzado distribuye el peso uniformemente. Realizamos pruebas de carga antes de cada evento y certificamos la instalación." },
  { question: "¿Qué estilo de pista va mejor con la temática de mi evento?", answer: "Depende del ambiente que buscas. Para bodas y galas elegantes, el damero blanco y negro aporta sofisticación clásica y el acrílico transparente con LED un toque moderno y minimalista. Para fiestas temáticas retro, quinceañeras nostálgicas y eventos de los 70s/80s, la pista disco con espejos y esfera es la elección natural. Para bodas con monograma, activaciones de marca y lanzamientos, la pista personalizada en vinil permite proyectar tu identidad en el piso. Nuestro equipo de diseño te asesora según tu decoración, colores y concepto para que la pista amplifique la temática en lugar de competir con ella." },
  { question: "¿Con cuánto tiempo de anticipación necesito solicitar un diseño personalizado?", answer: "Para pistas con vinil personalizado (logos, monogramas, diseños especiales) recomendamos un mínimo de 2 semanas de anticipación para diseño, producción e instalación. Diseños simples como monogramas de boda pueden estar listos en 7 a 10 días. Para proyectos más complejos con arte original o branding corporativo detallado, lo ideal es 3 a 4 semanas. Incluimos hasta 2 rondas de revisión de diseño sin costo adicional." },
  { question: "¿Puedo combinar diferentes estilos de pista en un mismo evento?", answer: "Por supuesto. Muchos de nuestros clientes combinan estilos para crear experiencias únicas. Por ejemplo, puedes tener una pista de damero blanco y negro para la recepción formal y cambiar a la pista disco con espejos para la fiesta nocturna. También es posible combinar secciones: centro en acrílico transparente con LED y bordes en damero. Nuestro equipo de diseño te asesora sobre las mejores combinaciones según tu espacio y temática." },
  { question: "¿Las pistas vintage y temáticas se pueden instalar en exteriores?", answer: "Sí, todas nuestras pistas vintage se pueden instalar en exteriores con las adaptaciones adecuadas. Utilizamos bases niveladoras para terrenos irregulares como jardines y terrazas. La pista de acrílico y la disco requieren protección superior tipo carpa para evitar que la humedad afecte la iluminación LED. La pista damero y la personalizada en vinil son las más versátiles para exterior. Siempre realizamos una visita técnica previa para evaluar el terreno y garantizar una instalación segura." },
  { question: "¿Con cuánta anticipación debo reservar mi pista vintage o temática?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero) y para fines de semana. Las pistas disco con espejos y las de acrílico transparente son las más solicitadas y se agotan primero. Para pistas personalizadas con vinil, se necesita tiempo adicional de diseño y producción. También atendemos solicitudes de último momento (1 a 2 semanas) para pistas estándar, sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile Vintage y Temáticas en CDMX",
    description: "Renta de pistas de baile disco con espejos, damero, acrílico transparente con LED y personalizadas en vinil en CDMX. Diseño e instalación incluidos. Cotiza hoy.",
    url: "/servicios/pistas-baile/vintage-tematicas/",
    priceRange: { min: 2500, max: 30000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Vintage y Temáticas", url: "/servicios/pistas-baile/vintage-tematicas/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Vintage y Temáticas" },
];
---

<PageLayout
  title="Renta de Pistas de Baile Vintage y Temáticas en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/pistas-baile/pista-acrilica-transparente-boda.avif"
  description="Renta de pistas de baile disco con espejos, damero, acrílico con LED y personalizadas en vinil en CDMX. Diseño e instalación incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="vintage-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Pistas vintage y temáticas · CDMX y ZMVM</p>
            <h1 id="vintage-hero-heading">
              Pistas de baile temáticas que le dan <em>personalidad al piso de tu evento</em>
            </h1>
            <p class="hm-hero__lead">
              Disco con espejos, damero blanco y negro, acrílico transparente con LED y vinil
              personalizado con tu diseño. La pista que combina con la temática y se vuelve parte de
              la decoración — con diseño, producción e instalación incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20tem%C3%A1tica%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar pista
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>pistas de baile vintage y temáticas</strong> en CDMX:
              <strong>disco con espejos facetados</strong> y esfera giratoria para fiestas retro,
              <strong>damero blanco y negro</strong> de alto contraste para galas, <strong>acrílico
              transparente</strong> de policarbonato de 30 mm con LED inferior programable, y
              <strong>pistas personalizadas</strong> en vinil HD con tu logo o monograma en Pantone
              exacto. Cada pista se dimensiona a partir de una visita técnica al venue.
            </p>
            <p>
              Con <strong>más de 500 pistas instaladas</strong> en CDMX, sabemos que el piso también
              comunica la temática del evento: por eso cada renta incluye asesoría de estilo, diseño y
              prueba de carga. Combínala con nuestras
              <a href="/servicios/pistas-baile/pistas-led/">pistas LED</a>,
              <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> y
              <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de pista vintage y temática disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20tem%C3%A1tica%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El piso que cuenta la temática</p>
            <h2 id="catalogo-heading">¿Qué estilo de pista va con tu evento?</h2>
            <p class="hm__head-sub">4 estilos — del disco retro al vinil personalizado con tu monograma.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La pista también comunica. Un damero dice gala, un disco dice fiesta retro, un acrílico
              con LED dice vanguardia y un vinil con monograma dice "esta es nuestra boda". El estilo
              del piso amplifica la temática del evento y se vuelve fondo de las mejores fotos.
            </p>
            <p>
              Disco con espejos para el brillo nostálgico. Damero para la elegancia clásica. Acrílico
              transparente para el efecto flotante moderno. Personalizada para proyectar tu identidad.
              Una sola empresa para toda la pista temática de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada estilo, a fondo</p>
            <h2 id="detalle-heading">Los 4 estilos de pista temática — en detalle</h2>
            <p class="hm__head-sub">Material, efecto, personalización y para qué tipo de evento funciona mejor cada uno.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada estilo hay decisiones que afectan la estética y la seguridad: el material
              que define el efecto visual, la iluminación que le da vida al piso, y la personalización
              que lo vuelve único para tu evento.
            </p>
            <p>
              Conocer estas diferencias te permite elegir la pista que amplifica tu temática. A
              continuación, lo que realmente importa de cada estilo.
            </p>
          </div>
        </div>

        <!-- DISCO -->
        <article class="hm-feat" aria-labelledby="feat-disco">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pista Disco con Espejos</p>
            <h3 class="hm-feat__title" id="feat-disco">El brillo nostálgico de los espejos y la esfera para fiestas retro inolvidables</h3>
            <p class="hm-feat__lead">Nada dice "fiesta" como una pista de espejos bajo la esfera disco. El clásico setentero que sigue arrancando aplausos en bodas retro, quinceañeras temáticas y fiestas nostálgicas.</p>
            <p>
              Paneles de <strong>espejo facetado</strong> en acrílico espejado (no vidrio, resistente a
              impactos) con <strong>esfera disco giratoria incluida</strong>. Los espejos reflejan la luz
              de la esfera y crean un efecto envolvente de destellos por todo el salón. Disponible de
              <strong>3×3 a 5×5 metros</strong> con superficie antiderrapante.
            </p>
            <p>
              El corazón de <strong>fiestas temáticas 70s/80s, bodas retro, XV años nostálgicos y
              eventos con concepto vintage</strong>. Luce espectacular con nuestros
              <a href="/servicios/iluminacion/escenario/">moving heads</a> y
              <a href="/servicios/iluminacion/efectos-especiales/">efectos de humo y láser</a> apuntando
              a los espejos.
            </p>
            <ul class="hm-feat__stats">
              {["Espejos facetados", "Esfera disco", "Acrílico espejado", "3×3 a 5×5 m", "Antiderrapante"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/pistas-baile/vintage-tematicas/disco/">
              Ver Pista Disco con Espejos
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/pistas-baile/pista-led-rgb-fiesta.avif" alt="Pista disco con espejos y esfera para fiesta retro en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/pistas-baile/pista-baile-01.avif" alt="Reflejos de esfera disco sobre pista de espejos" loading="lazy" decoding="async" />
              <img src="/images/pistas-baile/pista-baile-04.avif" alt="Pista de espejos facetados en fiesta temática" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- DAMERO -->
        <article class="hm-feat" aria-labelledby="feat-damero">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pista Damero Blanco y Negro</p>
            <h3 class="hm-feat__title" id="feat-damero">El ajedrezado clásico de alto contraste que dice gala y elegancia</h3>
            <p class="hm-feat__lead">El patrón que nunca pasa de moda. El damero blanco y negro aporta una sofisticación gráfica inmediata — la elección de galas, desfiles y eventos donde la estética manda.</p>
            <p>
              <strong>Patrón ajedrezado clásico</strong> en blanco y negro de <strong>alto contraste</strong>
              y máximo impacto visual, en dimensiones de <strong>3×3 a 6×6 metros</strong> con acabado
