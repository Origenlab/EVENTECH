---
/**
 * ─── EVENTECH.MX — Renta de Pistas de Baile de Madera Clásica (Hub L4, molde hm- 2026) ───
 * Duela Laminada · Parquet Modular · Marco Decorativo · Terreno Irregular — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/pistas-baile — fotos reales de pistas de madera y evento.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "duela-laminada",
    name: "Duela Laminada Premium",
    badge: "La más solicitada",
    excerpt: "Pista de duela laminada de 12 mm con acabado semi-mate antiderrapante y estructura elevada. Elegancia y seguridad para bodas, galas y eventos de alto nivel.",
    href: "/servicios/pistas-baile/madera-clasica/duela-laminada/",
    image: "/images/pistas-baile/pista-madera-natural-boda.avif",
    specs: ["Duela 12 mm", "Semi-mate", "Antiderrapante", "Estructura elevada"],
  },
  {
    id: "parquet-modular",
    name: "Parquet Modular",
    badge: "Montaje ágil",
    excerpt: "Paneles de parquet con sistema de ensamble rápido en múltiples tonos de madera. Montaje ágil y superficie uniforme para cualquier tipo de evento.",
    href: "/servicios/pistas-baile/madera-clasica/parquet-modular/",
    image: "/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif",
    specs: ["Sistema interlock", "Roble / caoba / wengué", "Superficie uniforme", "Montaje rápido"],
  },
  {
    id: "marco-decorativo",
    name: "Pista con Marco Decorativo",
    badge: "Detalle elegante",
    excerpt: "Pista de madera con marco perimetral de aluminio o madera decorativa y opción de iluminación LED en el contorno. El detalle elegante que distingue tu evento.",
    href: "/servicios/pistas-baile/madera-clasica/marco-decorativo/",
    image: "/images/pistas-baile/pista-baile-04.avif",
    specs: ["Marco aluminio / madera", "LED perimetral", "Efectos de color", "Perimetral tallado"],
  },
  {
    id: "terreno-irregular",
    name: "Pista sobre Terreno Irregular",
    badge: "Para jardín y playa",
    excerpt: "Plataforma niveladora profesional que permite instalar pista de madera sobre jardín, pasto, arena o cualquier superficie irregular con total estabilidad.",
    href: "/servicios/pistas-baile/madera-clasica/terreno-irregular/",
    image: "/images/pistas-baile/pista-baile-05.avif",
    specs: ["Jardín / pasto / arena", "Patas ajustables", "500 kg/m²", "Protección geotextil"],
  },
];

const whyFeatures = [
  {
    title: "Visita técnica y nivelación del terreno",
    body: "Una pista mal nivelada se siente y se ve. Hacemos visita técnica para medir el espacio y evaluar la superficie —salón, jardín, pasto o arena— y diseñar la nivelación exacta. La pista queda perfectamente plana y estable, sin escalones ni movimientos, para que nadie tropiece bailando.",
  },
  {
    title: "Estructura elevada de 500 kg/m² con prueba de carga",
    body: "Bailar es peso en movimiento. Nuestra estructura elevada de acero galvanizado soporta hasta 500 kg/m² —más de 6 personas por metro cuadrado bailando a la vez— y hacemos prueba de carga antes de cada evento. La pista aguanta la fiesta completa sin ceder ni crujir.",
  },
  {
    title: "Acabado antiderrapante que aguanta tacones",
    body: "El acabado semi-mate antiderrapante repele líquidos, no marca con tacones y mantiene el agarre toda la noche, incluso con uso intensivo. Nadie resbala y la madera se ve impecable en las fotos de la pista llena — sin rayones ni marcas al final del evento.",
  },
  {
    title: "Instalación en jardín sin dañar el pasto",
    body: "Plataforma niveladora que se ajusta a terrenos irregulares y eleva la pista 10 a 30 cm del suelo. Protegemos el pasto con geotextil y distribuimos el peso para no dañar el jardín. Una pista de baile premium en exterior, sin marcas en el césped al retirarla.",
  },
  {
    title: "Kit de limpieza y asistencia en el evento",
    body: "Incluimos kit de limpieza rápida con paños de microfibra y solución para madera laminada, y nuestro equipo puede asistir durante el evento si se derrama algo. La pista se entrega con limpieza profunda y se mantiene impecable toda la noche, lista para las fotos de cada baile.",
  },
  {
    title: "Integración con iluminación y montaje completo",
    body: "La pista luce más con marco LED perimetral, iluminación decorativa alrededor y coordinada con el resto del montaje. Integramos pista, luz y mobiliario desde EVENTECH, con una sola logística — para que la zona de baile se sienta parte del diseño y no un añadido.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y medida", p: "Evaluamos el venue y la superficie (salón, jardín, pasto, arena) y medimos el espacio para recomendar la dimensión ideal según tu número de invitados. En menos de 24 horas te enviamos propuesta con el tipo de pista, tono de madera y acabado." },
  { n: 2, t: "Propuesta y aparto", p: "Definimos tipo de pista (duela, parquet, marco decorativo o plataforma para terreno irregular), tono de madera y opción de LED perimetral. Con el anticipo apartamos la pista y la fecha. Las de 5×5 y 6×6 con marco son las más solicitadas: conviene apartar con tiempo." },
  { n: 3, t: "Montaje, nivelación y prueba de carga", p: "Instalamos con anticipación: estructura elevada, nivelación láser sobre el terreno, ensamble de la superficie y prueba de carga. Protegemos el pasto con geotextil en exteriores. Entregamos la pista limpia y verificada antes del evento." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento la pista aguanta el baile con seguridad y se mantiene impecable. Al finalizar, desmontamos y retiramos todo sin dejar marcas en el terreno. El montaje, la nivelación y el desmontaje están incluidos dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tipos de madera ofrecen para las pistas de baile?", answer: "Ofrecemos dos opciones principales: duela laminada premium de 12 mm con acabado semi-mate antiderrapante, disponible en tonos maple, nogal y cerezo; y parquet modular con paneles de alta densidad en tonos roble natural, caoba y wengué. Ambas opciones son de grado profesional, resistentes al tráfico intenso de baile y con acabados que no dejan marcas de tacones. Nuestro asesor te ayuda a elegir el tono ideal según la decoración de tu evento." },
  { question: "¿Puedo elegir el tono de madera según mi decoración?", answer: "Sí. Disponemos de tonos claros (maple, roble natural) para bodas luminosas y jardines, tonos medios (nogal, cerezo) para eventos cálidos y elegantes, y tonos oscuros (caoba, wengué, negro) para galas y eventos corporativos sofisticados. Te enviamos muestras físicas o fotos de referencia para que elijas el tono que combine con tu mantelería, mobiliario y paleta de color. La elección del tono no tiene costo adicional y define mucho la estética de la zona de baile." },
  { question: "¿Qué tamaños de pista de madera están disponibles?", answer: "Nuestras pistas de madera están disponibles en dimensiones estándar de 3x3 m (ideales para 30-50 personas), 4x4 m (50-80 personas), 5x5 m (80-120 personas) y 6x6 m (120-180 personas). También fabricamos dimensiones personalizadas según las necesidades de tu venue. Para eventos con más de 200 invitados, podemos ensamblar pistas de hasta 8x8 metros o configuraciones en L. Nuestro equipo evalúa tu espacio y te recomienda la dimensión perfecta." },
  { question: "¿Cuánto peso soporta la pista de madera para bailar?", answer: "Nuestras pistas de madera están diseñadas para soportar baile intenso con total seguridad. La estructura elevada de acero galvanizado tiene una capacidad de carga de hasta 500 kg/m², lo que equivale a más de 6 personas bailando simultáneamente por metro cuadrado. La duela laminada y el parquet están certificados para tráfico pesado y resistentes a impactos de tacones. Realizamos pruebas de carga antes de cada evento para garantizar estabilidad absoluta." },
  { question: "¿Es posible instalar la pista de madera sobre pasto o jardín?", answer: "Sí, es una de nuestras especialidades. Utilizamos una plataforma niveladora profesional de acero y aluminio que se ajusta a terrenos irregulares como jardín, pasto, arena, grava o terrazas con desnivel. La plataforma eleva la pista entre 10 y 30 cm del suelo, creando una superficie perfectamente plana y estable. Protegemos el pasto con geotextil y distribuimos el peso para no dañar el terreno. El resultado es una pista de baile premium incluso en exteriores." },
  { question: "¿Cómo se limpia y mantiene la pista de madera durante el evento?", answer: "La superficie laminada de nuestras pistas tiene un acabado semi-mate antiderrapante que repele líquidos y es fácil de limpiar. Incluimos un kit de limpieza rápida con paños de microfibra y solución especial para madera laminada. Nuestro equipo de montaje realiza una limpieza profunda antes de la entrega y puede asistir durante el evento si se derrama algún líquido. El acabado antiderrapante mantiene su efectividad durante toda la noche, incluso con uso intensivo." },
  { question: "¿Con cuánta anticipación debo reservar la pista de madera?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo-junio para bodas). Las pistas de 5x5 m y 6x6 m con marco decorativo son las más solicitadas y se agotan primero. Para eventos en jardín que requieren plataforma niveladora, lo ideal es apartar con al menos 3 semanas para programar la visita técnica al venue. También atendemos solicitudes de último momento sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile de Madera Clásica en CDMX",
    description: "Renta de pistas de baile de duela laminada, parquet modular, marco decorativo y plataforma para terreno irregular en CDMX. Montaje y nivelación incluidos.",
    url: "/servicios/pistas-baile/madera-clasica/",
    priceRange: { min: 3000, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Madera Clásica", url: "/servicios/pistas-baile/madera-clasica/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Madera Clásica" },
];
---

<PageLayout
  title="Renta de Pistas de Baile de Madera en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/pistas-baile/pista-madera-natural-boda.avif"
  description="Renta de pistas de baile de madera en CDMX: duela laminada, parquet modular, marco decorativo y para terreno irregular. Montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="madera-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Pistas de baile de madera · CDMX y ZMVM</p>
            <h1 id="madera-hero-heading">
              Pistas de baile de madera que dan <em>elegancia y seguridad</em> a cualquier venue
            </h1>
            <p class="hm-hero__lead">
              Duela laminada premium, parquet modular, marco decorativo con LED y plataforma para
              terreno irregular. La pista que aguanta el baile de toda la noche y se ve impecable en
              las fotos — con montaje, nivelación y prueba de carga incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20de%20madera%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar pista
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>pistas de baile de madera</strong> en CDMX con estructura
              elevada de acero galvanizado que soporta <strong>500 kg/m²</strong>: <strong>duela
              laminada premium de 12 mm</strong> antiderrapante, <strong>parquet modular</strong> en
              roble, caoba y wengué, <strong>marco decorativo con LED perimetral</strong> y
              <strong>plataforma niveladora</strong> para instalar sobre jardín, pasto o arena. Cada
              pista se dimensiona a partir de una visita técnica al venue.
            </p>
            <p>
              Con <strong>más de 500 pistas instaladas</strong> en CDMX, sabemos que la pista es donde
              se hace la fiesta: por eso cada renta incluye nivelación, prueba de carga y un acabado
              antiderrapante que aguanta toda la noche. Combínala con nuestras
              <a href="/servicios/pistas-baile/pistas-led/">pistas LED</a>,
              <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> y
              <a href="/servicios/mobiliario/">mobiliario</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de pista de madera disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20de%20madera%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">La zona de baile de tu evento</p>
            <h2 id="catalogo-heading">¿Qué pista de madera necesita tu evento?</h2>
            <p class="hm__head-sub">4 opciones — del clásico de salón a la pista sobre jardín, con la seguridad y el acabado correctos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La pista de baile es el corazón de la fiesta: donde se hace el primer baile, donde se
              llena la noche y donde se toman las mejores fotos. Una pista de madera bien nivelada y
              con buen acabado se ve elegante y aguanta el baile; una improvisada se mueve, cruje o se
              raya a la primera hora.
            </p>
            <p>
              Duela laminada para elegancia clásica. Parquet modular para montaje ágil. Marco
              decorativo con LED para el detalle. Plataforma niveladora para instalar sobre jardín o
              arena. Una sola empresa para toda la zona de baile.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada pista, a fondo</p>
            <h2 id="detalle-heading">Las 4 pistas de madera — en detalle</h2>
            <p class="hm__head-sub">Material, acabado, capacidad y para qué tipo de venue funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada pista hay decisiones que afectan la seguridad y la estética: el acabado
              que decide si resbala o agarra, la estructura que soporta el baile, y el sistema de
              nivelación que permite instalarla sobre cualquier terreno sin que se sienta el desnivel.
            </p>
            <p>
              Conocer estas diferencias te permite elegir la pista con criterio. A continuación, lo
              que realmente importa de cada una.
            </p>
          </div>
        </div>

        <!-- DUELA LAMINADA -->
        <article class="hm-feat" aria-labelledby="feat-duela-laminada">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Duela Laminada Premium</p>
            <h3 class="hm-feat__title" id="feat-duela-laminada">El clásico elegante que aguanta el baile y se ve impecable en las fotos</h3>
            <p class="hm-feat__lead">La opción por defecto de bodas y galas por una razón: la duela laminada premium combina la calidez de la madera con un acabado que resiste tacones, líquidos y el baile de toda la noche.</p>
            <p>
              <strong>Duela laminada de 12 mm</strong> con acabado <strong>semi-mate
              antiderrapante</strong> sobre estructura elevada de acero galvanizado. Disponible en
              tonos <strong>maple, nogal y cerezo</strong>. El acabado repele líquidos y no deja
              marcas de tacón, manteniendo la superficie impecable durante todo el evento.
            </p>
            <p>
              Ideal para <strong>bodas, galas, cenas formales y eventos de alto nivel</strong>. La
              estructura soporta hasta 500 kg/m² con prueba de carga incluida. Combínala con nuestra
              <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para enmarcar la
              zona de baile.
            </p>
            <ul class="hm-feat__stats">
              {["Duela 12 mm", "Semi-mate", "Antiderrapante", "Maple / nogal / cerezo", "500 kg/m²"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/pistas-baile/madera-clasica/duela-laminada/">
              Ver Duela Laminada Premium
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/pistas-baile/pista-madera-natural-boda.avif" alt="Pista de baile de duela laminada natural para boda en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/pistas-baile/pista-baile-01.avif" alt="Pista de madera premium montada en salón de evento" loading="lazy" decoding="async" />
              <img src="/images/pistas-baile/pista-baile-02.avif" alt="Detalle de duela laminada antiderrapante en zona de baile" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- PARQUET MODULAR -->
        <article class="hm-feat" aria-labelledby="feat-parquet-modular">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Parquet Modular</p>
            <h3 class="hm-feat__title" id="feat-parquet-modular">Paneles que se ensamblan rápido, en el tono de madera que combine con tu evento</h3>
            <p class="hm-feat__lead">La versatilidad hecha pista. El parquet modular se arma como un rompecabezas en poco tiempo y viene en tonos que van del roble claro al wengué oscuro para combinar con cualquier decoración.</p>
            <p>
              Paneles de parquet de alta densidad con <strong>sistema de ensamble interlock</strong>
              que permite montaje ágil y una <strong>superficie perfectamente uniforme</strong>.
              Disponibles en tonos <strong>roble natural, caoba y wengué</strong> para adaptarse a la
              paleta de tu evento — claro para jardines, oscuro para galas.
            </p>
            <p>
              Perfecto para <strong>eventos corporativos, ferias, bodas y cualquier evento</strong>
