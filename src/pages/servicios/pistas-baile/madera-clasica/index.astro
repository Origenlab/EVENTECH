    primaryCTA={{ label: "Cotizar pista de madera", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile de madera para mi evento` }}
    variant="accent"
  />
