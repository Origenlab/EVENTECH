---
/**
 * ─── Pistas de Baile de Madera Clásica — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Pistas de Baile de Madera Clásica para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Madera Clásica" },
];

const PISTAS_MADERA = [
  {
    name: "Duela Laminada Premium",
    excerpt: "Pista de baile con duela laminada de 12 mm, acabado semi-mate antiderrapante y estructura elevada. Elegancia y seguridad para bodas, galas y eventos de alto nivel.",
    cta: "Duela Laminada",
    href: "#duela-heading",
    icon: "layers",
  },
  {
    name: "Parquet Modular",
    excerpt: "Paneles de parquet con sistema de ensamble rápido disponibles en múltiples tonos de madera. Montaje ágil y superficie uniforme para cualquier tipo de evento.",
    cta: "Parquet Modular",
    href: "#parquet-heading",
    icon: "package",
  },
  {
    name: "Pista con Marco Decorativo",
    excerpt: "Pista de madera con marco perimetral de aluminio o madera decorativa y opción de iluminación LED en el contorno. El detalle elegante que distingue tu evento.",
    cta: "Marco Decorativo",
    href: "#marco-heading",
    icon: "crown",
  },
  {
    name: "Pista sobre Terreno Irregular",
    excerpt: "Plataforma niveladora profesional que permite instalar pista de madera sobre jardín, pasto, arena o cualquier superficie irregular con total estabilidad.",
    cta: "Terreno Irregular",
    href: "#terreno-heading",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Qué tipos de madera ofrecen para las pistas de baile?", answer: "Ofrecemos dos opciones principales: duela laminada premium de 12 mm con acabado semi-mate antiderrapante, disponible en tonos maple, nogal y cerezo; y parquet modular con paneles de alta densidad en tonos roble natural, caoba y wengué. Ambas opciones son de grado profesional, resistentes al tráfico intenso de baile y con acabados que no dejan marcas de tacones. Nuestro asesor te ayuda a elegir el tono ideal según la decoración de tu evento." },
  { question: "¿Qué tamaños de pista de madera están disponibles?", answer: "Nuestras pistas de madera están disponibles en dimensiones estándar de 3x3 m (ideales para 30-50 personas), 4x4 m (50-80 personas), 5x5 m (80-120 personas) y 6x6 m (120-180 personas). También fabricamos dimensiones personalizadas según las necesidades de tu venue. Para eventos con más de 200 invitados, podemos ensamblar pistas de hasta 8x8 metros o configuraciones en L. Nuestro equipo evalúa tu espacio y te recomienda la dimensión perfecta." },
  { question: "¿Cuánto peso soporta la pista de madera para bailar?", answer: "Nuestras pistas de madera están diseñadas para soportar baile intenso con total seguridad. La estructura elevada de acero galvanizado tiene una capacidad de carga de hasta 500 kg/m², lo que equivale a más de 6 personas bailando simultáneamente por metro cuadrado. La duela laminada y el parquet están certificados para tráfico pesado y resistentes a impactos de tacones. Realizamos pruebas de carga antes de cada evento para garantizar estabilidad absoluta." },
  { question: "¿Es posible instalar la pista de madera sobre pasto o jardín?", answer: "Sí, es una de nuestras especialidades. Utilizamos una plataforma niveladora profesional de acero y aluminio que se ajusta a terrenos irregulares como jardín, pasto, arena, grava o terrazas con desnivel. La plataforma eleva la pista entre 10 y 30 cm del suelo, creando una superficie perfectamente plana y estable. Protegemos el pasto con geotextil y distribuimos el peso para no dañar el terreno. El resultado es una pista de baile premium incluso en exteriores." },
  { question: "¿Cómo se limpia y mantiene la pista de madera durante el evento?", answer: "La superficie laminada de nuestras pistas tiene un acabado semi-mate antiderrapante que repele líquidos y es fácil de limpiar. Incluimos un kit de limpieza rápida con paños de microfibra y solución especial para madera laminada. Nuestro equipo de montaje realiza una limpieza profunda antes de la entrega y puede asistir durante el evento si se derrama algún líquido. El acabado antiderrapante mantiene su efectividad durante toda la noche, incluso con uso intensivo." },
  { question: "¿Con cuánta anticipación debo reservar la pista de madera?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo-junio para bodas). Las pistas de 5x5 m y 6x6 m con marco decorativo son las más solicitadas y se agotan primero. Para eventos en jardín que requieren plataforma niveladora, lo ideal es apartar con al menos 3 semanas para programar la visita técnica al venue. También atendemos solicitudes de último momento sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile de Madera Clásica para Eventos en CDMX",
    description: "Pistas de baile de duela laminada, parquet modular y con marco decorativo para bodas, fiestas y eventos. Instalación sobre cualquier superficie.",
    url: "/servicios/pistas-baile/madera-clasica/",
    priceRange: { min: 1500, max: 18000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Madera Clásica", url: "/servicios/pistas-baile/madera-clasica/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pistas de Baile de Madera Clásica para Eventos en CDMX"
  description="Renta de pistas de baile de madera: duela laminada, parquet modular y marco decorativo para eventos en CDMX. Instalación en cualquier superficie. Desde $1,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Elegancia clásica para tu pista de baile"
    title='Renta de <span class="highlight">Pistas de Baile de Madera</span> para Eventos en CDMX'
    subtitle="Pistas de baile de madera clásica con duela laminada premium, parquet modular y marcos decorativos. Acabado antiderrapante, estructura profesional e instalación sobre cualquier superficie."
    primaryCTA={{ label: "Cotiza tu pista", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile de madera para mi evento` }}
    cards={[
      {
        title: "Pistas de madera de grado profesional para cada celebración",
        content: "<strong>Renta de pistas de baile de madera clásica</strong> con los mejores acabados disponibles en CDMX. Duela laminada premium de 12 mm con superficie semi-mate antiderrapante en tonos maple, nogal y cerezo para bodas y galas de alto nivel. Parquet modular con sistema de ensamble rápido en múltiples tonos de madera natural para eventos corporativos y fiestas sociales. Marcos decorativos de aluminio y madera con opción de iluminación LED perimetral — cada pista fabricada con materiales de primera y verificada antes de cada entrega.",
      },
      {
        title: "Instalación profesional en cualquier superficie",
        content: "<strong>Montaje especializado</strong> incluido en cada renta de pista de madera. Nuestro equipo de instalación se encarga del transporte, nivelación de terreno, ensamble de estructura elevada de acero galvanizado, colocación de paneles y limpieza final. Plataforma niveladora profesional para jardines, pasto, arena y superficies irregulares. Capacidad de carga de 500 kg/m² certificada para baile intenso con total seguridad durante todo el evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la pista de baile perfecta para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con la pista ideal para tu espacio y estilo"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de pista de madera
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pistas de Madera"
        subtitle="La pista de baile clásica perfecta para cada celebración"
        description={[
          "Desde duela laminada premium para bodas elegantes hasta parquet modular para eventos corporativos y fiestas de gran formato. Contamos con el inventario más completo de pistas de baile de madera en la Ciudad de México.",
          "Cada pista incluye estructura elevada profesional, acabado antiderrapante certificado y equipo de montaje dedicado. Instalación garantizada sobre cualquier tipo de superficie."
        ]}
      />

      <div class="grid grid--4">
        {PISTAS_MADERA.map((pista) => (
          <Card
            name={pista.name}
            excerpt={pista.excerpt}
            cta={pista.cta}
            href={pista.href}
            icon={pista.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       DUELA LAMINADA PREMIUM — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="duela-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Acabado premium</span>
          <h2 class="showcase__title" id="duela-heading">Duela Laminada Premium</h2>
          <p class="showcase__subtitle">Elegancia clásica con acabado semi-mate antiderrapante para eventos de alto nivel.</p>
          <p class="showcase__text">Nuestra <strong>pista de duela laminada premium</strong> está fabricada con paneles de <strong>12 mm de espesor</strong> y un acabado <strong>semi-mate antiderrapante</strong> que combina elegancia visual con seguridad para el baile. Disponible en tonos <strong>maple, nogal y cerezo</strong>, cada duela se ensambla sobre una estructura elevada de acero galvanizado que garantiza estabilidad y nivelación perfecta. Ideal para <strong>bodas, galas, cenas de gala y eventos formales</strong> donde cada detalle cuenta.</p>
          <p class="showcase__text">La estructura elevada permite <strong>ocultar cableado de iluminación y sonido</strong> debajo de la pista, manteniendo un aspecto limpio y profesional. El acabado antiderrapante resiste el tráfico intenso de tacones sin dejar marcas ni perder adherencia durante toda la noche. Combínala con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para crear un ambiente de celebración impecable.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">12 mm espesor</span>
            <span class="showcase__tag">Semi-mate</span>
            <span class="showcase__tag">Antiderrapante</span>
            <span class="showcase__tag">Estructura elevada</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Duela Laminada
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="18" rx="2" ry="2"/>
              <line x1="2" y1="9" x2="22" y2="9"/>
              <line x1="2" y1="15" x2="22" y2="15"/>
              <line x1="8" y1="3" x2="8" y2="9"/>
              <line x1="16" y1="3" x2="16" y2="9"/>
              <line x1="12" y1="9" x2="12" y2="15"/>
              <line x1="8" y1="15" x2="8" y2="21"/>
              <line x1="16" y1="15" x2="16" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PARQUET MODULAR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="parquet-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Montaje rápido</span>
          <h2 class="showcase__title" id="parquet-heading">Parquet Modular</h2>
          <p class="showcase__subtitle">Paneles de ensamble rápido en múltiples tonos de madera para montajes eficientes.</p>
          <p class="showcase__text">Nuestro <strong>parquet modular</strong> utiliza un sistema de <strong>paneles con ensamble tipo interlock</strong> que se conectan entre sí de forma rápida y segura, reduciendo significativamente el tiempo de montaje. Disponible en tonos <strong>roble natural, caoba y wengué</strong>, cada panel tiene superficie de alta densidad resistente al desgaste y a la humedad. Configuraciones desde <strong>3×3 metros hasta 8×8 metros</strong> para eventos de cualquier tamaño.</p>
          <p class="showcase__text">El sistema modular permite <strong>ensamble y desensamble en la mitad del tiempo</strong> comparado con la duela tradicional, haciéndolo ideal para eventos con tiempos de montaje limitados. Los paneles se nivelan automáticamente gracias a su base ajustable. Perfecto para <strong>fiestas sociales, eventos corporativos y celebraciones en salón</strong>. Combínalo con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para crear espacios de baile techados en exteriores.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Sistema interlock</span>
            <span class="showcase__tag">Roble natural</span>
            <span class="showcase__tag">Caoba</span>
            <span class="showcase__tag">Wengué</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Parquet Modular
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="9" height="9" rx="1"/>
              <rect x="13" y="2" width="9" height="9" rx="1"/>
              <rect x="2" y="13" width="9" height="9" rx="1"/>
              <rect x="13" y="13" width="9" height="9" rx="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA CON MARCO DECORATIVO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="marco-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Detalle elegante</span>
          <h2 class="showcase__title" id="marco-heading">Pista con Marco Decorativo</h2>
          <p class="showcase__subtitle">Marco perimetral de aluminio o madera con opción de iluminación LED para un acabado de lujo.</p>
          <p class="showcase__text">Nuestra <strong>pista con marco decorativo</strong> eleva la experiencia visual al siguiente nivel con un <strong>borde perimetral de aluminio anodizado o madera tallada</strong> que enmarca la superficie de baile con distinción. El marco está disponible en acabados <strong>plateado, dorado, negro mate y madera natural</strong>, adaptándose a cualquier temática decorativa. Opción de <strong>iluminación LED perimetral</strong> integrada en el marco con efectos de color programables para crear ambientes memorables.</p>
          <p class="showcase__text">La iluminación LED perimetral puede configurarse en <strong>color fijo, cambio gradual o sincronización con la música</strong> para momentos especiales como el primer baile, el vals o la hora loca. El marco además funciona como <strong>elemento de contención</strong> que delimita visualmente la pista y previene tropiezos en los bordes. Ideal para <strong>bodas de ensueño, quinceañeras y galas de lujo</strong>. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para una atmósfera envolvente.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Aluminio anodizado</span>
            <span class="showcase__tag">Madera tallada</span>
            <span class="showcase__tag">LED perimetral</span>
            <span class="showcase__tag">Efectos de color</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Marco Decorativo
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="2"/>
              <rect x="5" y="5" width="14" height="14" rx="1"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
              <line x1="12" y1="5" x2="12" y2="19"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA SOBRE TERRENO IRREGULAR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="terreno-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Instalación en cualquier superficie</span>
          <h2 class="showcase__title" id="terreno-heading">Pista sobre Terreno Irregular</h2>
          <p class="showcase__subtitle">Plataforma niveladora profesional para instalar pistas de madera sobre jardín, pasto, arena o cualquier superficie.</p>
          <p class="showcase__text">Nuestra <strong>plataforma niveladora profesional</strong> hace posible instalar una pista de baile de madera de calidad premium sobre <strong>cualquier tipo de superficie irregular</strong>: jardines con pasto, terrenos con desnivel, arena de playa, grava, adoquín o terrazas con pendiente. La estructura de <strong>acero galvanizado con patas ajustables</strong> se nivela con precisión milimétrica, elevando la pista entre <strong>10 y 30 cm del suelo</strong> para crear una superficie perfectamente plana y estable.</p>
          <p class="showcase__text">Incluye <strong>protección de geotextil</strong> para evitar daños al pasto o jardín, distribución de peso uniforme que no deja hundimientos, y <strong>soporte estructural certificado</strong> para baile intenso con capacidad de 500 kg/m². Ideal para <strong>bodas en haciendas, fiestas en jardín, eventos en playa y celebraciones en terrazas</strong>. Nuestro equipo realiza una visita técnica previa para evaluar el terreno y diseñar la solución perfecta. Combínala con nuestros <a href="/servicios/accesorios/">accesorios para eventos</a> como alfombras de acceso y señalización.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Jardín / Pasto</span>
            <span class="showcase__tag">Arena / Playa</span>
            <span class="showcase__tag">Patas ajustables</span>
            <span class="showcase__tag">500 kg/m²</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Pista en Terreno
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20 L6 16 L10 18 L14 14 L18 16 L22 12"/>
              <rect x="4" y="16" width="16" height="4" rx="1"/>
              <line x1="8" y1="20" x2="8" y2="22"/>
              <line x1="12" y1="20" x2="12" y2="23"/>
              <line x1="16" y1="20" x2="16" y2="21"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Pistas de Madera"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu pista de baile de madera, es natural tener preguntas sobre tipos de madera, tamaños, capacidad y logística de instalación. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre pistas de baile de madera al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de pistas de baile de madera para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
