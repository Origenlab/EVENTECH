---
/**
 * ─── Duela Laminada Premium — Pagina de Producto (Nivel 4) ───
 * Pista de baile con duela laminada de 12mm, acabado semi-mate
 * antiderrapante sobre estructura elevada para bodas y galas.
 *
 * Jerarquia: Servicios > Pistas de Baile > Madera Clásica > Duela Laminada
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Madera Clásica", href: "/servicios/pistas-baile/madera-clasica/" },
  { label: "Duela Laminada" },
];

const faqs = [
  { question: "¿La pista de duela laminada se puede instalar sobre pasto o jardín?", answer: 'Sí, es una de nuestras configuraciones más solicitadas. La pista de duela laminada se monta sobre una <strong>estructura elevada de aluminio con patas ajustables</strong> que se nivela perfectamente sobre pasto, jardín, tierra o cualquier superficie irregular. Incluimos geotextil de protección para no dañar el césped y la plataforma distribuye el peso uniformemente. Para terrenos con desniveles pronunciados, te recomendamos nuestra <a href="/servicios/pistas-baile/madera-clasica/terreno-irregular/">pista sobre terreno irregular</a> con compensación de hasta 30 cm.' },
  { question: "¿La duela laminada resiste tacones altos y zapatos de baile?", answer: "Absolutamente. Nuestra duela laminada de 12 mm cuenta con un <strong>acabado semi-mate antiderrapante de alta resistencia</strong> certificado para tráfico intenso. La superficie no se raya con tacones de aguja, stilettos ni zapatos de baile profesional. El acabado mantiene su adherencia durante toda la noche, incluso con uso intensivo de más de 100 personas bailando simultáneamente. Al finalizar el evento, la pista se retira sin marcas permanentes." },
  { question: "¿Cuánto mide la pista según el número de invitados?", answer: "Recomendamos las siguientes dimensiones: <strong>3x3 metros</strong> para eventos de 30-50 personas (reuniones íntimas, cenas), <strong>4x4 metros</strong> para 50-80 personas (fiestas sociales), <strong>5x5 metros</strong> para 80-120 personas (bodas medianas) y <strong>6x6 metros</strong> para 120-180 personas (bodas grandes y galas). La regla general es calcular que el 40-50% de tus invitados bailará simultáneamente, necesitando aproximadamente 0.5 m² por persona." },
  { question: "¿La pista incluye zóclo perimetral decorativo?", answer: "Sí, <strong>todas nuestras pistas de duela laminada incluyen zóclo perimetral decorativo</strong> sin costo adicional. El zóclo cubre la transición entre la estructura elevada y el suelo, dando un acabado limpio y profesional. Está disponible en el mismo tono de madera que elijas para tu pista (natural, roble, nogal o cerezo). Además de su función decorativa, el zóclo previene tropiezos y protege los bordes de la estructura." },
  { question: "¿Se puede combinar la duela laminada con iluminación LED perimetral?", answer: 'Sí, es una combinación muy popular para bodas y eventos de gala. Puedes agregar un <strong>marco con iluminación LED RGB perimetral</strong> que enmarca la pista con efectos de color programables y sincronizables con la música. Te recomendamos explorar nuestra <a href="/servicios/pistas-baile/madera-clasica/marco-decorativo/">pista con marco decorativo</a> que incluye esta opción de forma integral. También ofrecemos uplighting perimetral como accesorio adicional para cualquier pista de duela.' },
  { question: "¿Con cuánta anticipación debo reservar la pista de duela laminada?", answer: "Recomendamos reservar con <strong>2 a 4 semanas de anticipación</strong>, especialmente en temporada alta (noviembre a febrero y mayo-junio para bodas). Las pistas de 5x5 y 6x6 metros en tono nogal y cerezo son las más solicitadas y se agotan primero. Para eventos en jardín que requieren nivelación especial, lo ideal es apartar con al menos <strong>3 semanas</strong> para programar la visita técnica al venue. También atendemos solicitudes de último momento sujetas a disponibilidad." },
];

const specs = [
  { label: "Material", value: "Duela laminada 12 mm" },
  { label: "Acabado", value: "Semi-mate antiderrapante" },
  { label: "Estructura", value: "Base elevada aluminio 10-15 cm" },
  { label: "Tonos", value: "Natural, roble, nogal, cerezo" },
  { label: "Medidas", value: "3x3, 4x4, 5x5, 6x6 metros" },
  { label: "Módulos", value: "Ensamble machihembrado sin tornillos" },
  { label: "Resistencia", value: "Tacones, sillas, tráfico intenso" },
  { label: "Nivelación", value: "Incluida para terreno irregular" },
  { label: "Zóclo", value: "Perimetral decorativo incluido" },
  { label: "Montaje", value: "Profesional, 3-5 horas" },
];

const sidebarNav = [
  { name: "Duela Laminada", href: null, active: true },
  { name: "Parquet Modular", href: "/servicios/pistas-baile/madera-clasica/parquet-modular/" },
  { name: "Marco Decorativo", href: "/servicios/pistas-baile/madera-clasica/marco-decorativo/" },
  { name: "Terreno Irregular", href: "/servicios/pistas-baile/madera-clasica/terreno-irregular/" },
];

const sidebarRelated = [
  { name: "Pistas LED", href: "/servicios/pistas-baile/pistas-led/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Carpas", href: "/servicios/carpas/" },
  { name: "Sonido", href: "/servicios/audiovisual/sonido/" },
];

const reviews = [
  { author: "Mariana López", text: "Rentamos la pista de duela laminada en tono natural para nuestra boda en un jardín de Coyoacán. La instalación sobre el pasto fue impecable, la superficie quedó perfectamente nivelada y el acabado semi-mate le dio un toque elegante a todo el ambiente. Los invitados no pararon de bailar toda la noche. Servicio puntual y profesional.", rating: 5, date: "2025-11-20" },
  { author: "Fernando Reyes", text: "Para nuestra gala corporativa en un salón de Polanco elegimos la duela en tono nogal y fue la decisión perfecta. El color oscuro combinó con toda la decoración y el zóclo perimetral le dio un acabado de lujo. El montaje fue rápido y discreto, y el equipo se encargó de todo sin que tuviéramos que preocuparnos por nada.", rating: 5, date: "2025-10-05" },
  { author: "Valentina Hernández", text: "Celebramos los XV años de mi hija con la pista de duela en tono roble de 5x5 metros. El acabado antiderrapante fue clave porque los jóvenes bailaron con mucha energía y nadie resbaló. La pista se veía hermosa y el equipo de EVENTECH fue muy atento durante todo el evento. Totalmente recomendable.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Pista de Baile de Duela Laminada para Eventos en CDMX",
    description: "Renta de pista de baile con duela laminada de 12mm, acabado semi-mate antiderrapante sobre estructura elevada para bodas y galas en CDMX. Desde $6,000.",
    url: "/servicios/pistas-baile/madera-clasica/duela-laminada/",
    priceRange: { min: 6000, max: 28000 },
    reviews,
    ratingValue: 5,
    reviewCount: 312,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Madera Clásica", url: "/servicios/pistas-baile/madera-clasica/" },
    { name: "Duela Laminada", url: "/servicios/pistas-baile/madera-clasica/duela-laminada/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pista de Baile de Duela Laminada para Eventos en CDMX"
  description="Renta de pista de baile con duela laminada de 12mm, acabado semi-mate antiderrapante sobre estructura elevada para bodas y galas en CDMX. Desde $6,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Elegancia clásica para bodas y galas"
    title='Renta de <span class="highlight">Pista de Baile de Duela Laminada</span> para Eventos en CDMX'
    subtitle="Pista de baile con duela laminada de 12mm y acabado semi-mate antiderrapante. Estructura elevada de aluminio, 4 tonos de madera disponibles y nivelación profesional sobre cualquier terreno."
    primaryCTA={{ label: "Cotiza tu pista", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de duela laminada para mi evento` }}
    cards={[
      {
        title: "Duela laminada 12mm con acabado semi-mate antiderrapante",
        content: "<strong>Renta de pista de baile con duela laminada premium</strong> de 12 mm de espesor y acabado semi-mate antiderrapante certificado para tráfico intenso. Estructura elevada de aluminio de 10 a 15 cm de altura con ensamble machihembrado sin tornillos visibles. Medidas disponibles de 3x3 a 6x6 metros con módulos intercambiables. Zóclo perimetral decorativo incluido en cada renta. Resistente a tacones, sillas y uso intensivo durante toda la noche.",
      },
      {
        title: "4 tonos de madera disponibles con nivelación profesional",
        content: "<strong>Cuatro tonos de madera a elegir</strong>: natural (claro cálido), roble (medio dorado), nogal (oscuro elegante) y cerezo (rojizo sofisticado). Cada tono se adapta a diferentes estilos de decoración y temáticas de evento. Nivelación profesional incluida para instalación sobre cualquier tipo de terreno — pasto, jardín, adoquín o superficies irregulares. Montaje profesional de 3 a 5 horas con equipo especializado y desmontaje post-evento incluido sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la pista de duela perfecta para tu celebración?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el tono y la medida ideal para tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pistas de Madera para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una pista de duela laminada para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una pista de duela laminada para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/><path d="M12 3v18"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Duela Laminada Premium</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Duela Natural -->
          <section class="section section--alt" aria-labelledby="duela-natural-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tono claro cálido</span>
                <h2 class="showcase__title" id="duela-natural-heading">Duela Natural</h2>
                <p class="showcase__subtitle">El tono claro ideal para bodas románticas y eventos al aire libre con decoración luminosa.</p>
                <p class="showcase__text">Nuestra <strong>duela laminada en tono natural</strong> es la favorita para <strong>bodas románticas, bautizos y eventos diurnos</strong> en la Ciudad de México. Su color claro cálido refleja la luz natural y artificial, amplificando la luminosidad del espacio y creando un ambiente fresco y acogedor. El acabado semi-mate de 12 mm ofrece una superficie <strong>antiderrapante certificada</strong> que resiste tacones, zapatos de baile y tráfico intenso sin perder su brillo natural durante toda la noche.</p>
                <p class="showcase__text">La tonalidad natural combina perfectamente con <strong>decoraciones en blanco, rosa, verde y tonos pastel</strong>, siendo la elección predilecta para bodas de jardín, ceremonias al atardecer y celebraciones estilo boho-chic. La estructura elevada de aluminio permite ocultar el cableado de iluminación y sonido debajo de la pista, manteniendo un aspecto limpio y profesional. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> de fairy lights para un ambiente mágico.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono natural</span>
                  <span class="showcase__tag">Bodas románticas</span>
                  <span class="showcase__tag">12 mm</span>
                  <span class="showcase__tag">Antiderrapante</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Natural
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Duela Natural</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Duela Roble -->
          <section class="section section--alt" aria-labelledby="duela-roble-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tono medio dorado</span>
                <h2 class="showcase__title" id="duela-roble-heading">Duela Roble</h2>
                <p class="showcase__subtitle">El tono medio versátil que combina con cualquier estilo de decoración para eventos elegantes.</p>
                <p class="showcase__text">La <strong>duela laminada en tono roble</strong> ofrece un equilibrio perfecto entre calidez y sofisticación. Su <strong>color medio dorado</strong> se adapta a prácticamente cualquier paleta de colores y temática decorativa, convirtiéndola en la opción más versátil de nuestro catálogo. Ideal para <strong>eventos elegantes, fiestas de aniversario, graduaciones y XV años</strong> donde se busca un ambiente cálido sin ser demasiado claro ni oscuro.</p>
                <p class="showcase__text">El tono roble complementa especialmente bien con <strong>decoraciones en dorado, burdeos, azul marino y tonos tierra</strong>. Su acabado semi-mate refleja la iluminación ambiental de forma equilibrada, creando un brillo sutil que realza la estética del espacio sin generar reflejos excesivos. La superficie de 12 mm con <strong>tratamiento antiderrapante</strong> mantiene su desempeño durante eventos de alta intensidad con más de 150 invitados bailando. Combínala con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> en tonos complementarios.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono roble</span>
                  <span class="showcase__tag">Eventos elegantes</span>
                  <span class="showcase__tag">Versátil</span>
                  <span class="showcase__tag">Semi-mate</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Roble
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Duela Roble</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Duela Nogal -->
          <section class="section section--alt" aria-labelledby="duela-nogal-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tono oscuro elegante</span>
                <h2 class="showcase__title" id="duela-nogal-heading">Duela Nogal</h2>
                <p class="showcase__subtitle">El tono oscuro sofisticado perfecto para galas, cenas de gala y eventos de alto nivel.</p>
                <p class="showcase__text">Nuestra <strong>duela laminada en tono nogal</strong> es la elección predilecta para <strong>galas corporativas, cenas de gala y eventos de lujo</strong> en la Ciudad de México. Su color oscuro profundo transmite elegancia y sofisticación, creando un contraste dramático con la decoración y la iluminación del evento. El acabado semi-mate de 12 mm absorbe los reflejos de forma controlada, generando un <strong>brillo sutil que realza el ambiente sin competir con la decoración</strong>.</p>
                <p class="showcase__text">El tono nogal es especialmente impactante con <strong>iluminación cálida, decoraciones en dorado, plateado, blanco y negro</strong>. Crea un efecto visual de profundidad y lujo que eleva la experiencia de cualquier celebración formal. La superficie antiderrapante mantiene su efectividad incluso con el tono oscuro, garantizando seguridad total para el baile. Ideal para <strong>bodas de noche, premiaciones, lanzamientos de marca y eventos VIP</strong>. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un contraste espectacular.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Tono nogal</span>
                  <span class="showcase__tag">Galas y lujo</span>
                  <span class="showcase__tag">Contraste dramático</span>
                  <span class="showcase__tag">Eventos VIP</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Duela Nogal
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
