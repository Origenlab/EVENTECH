---
/**
 * ─── Pista LED RGB Clasica — Pagina de Producto (Nivel 4) ───
 * Pista de baile LED RGB con 16 millones de colores y sincronizacion DMX
 * para bodas, XV anos y fiestas en CDMX.
 *
 * Jerarquia: Servicios > Pistas de Baile > Pistas LED > LED RGB Clasica
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Pistas LED", href: "/servicios/pistas-baile/pistas-led/" },
  { label: "LED RGB Clásica" },
];

const faqs = [
  { question: "¿Qué tamaño de pista LED RGB necesito según el número de invitados?", answer: 'El tamaño ideal depende directamente de la cantidad de personas que bailarán simultáneamente. Para <strong>fiestas íntimas de 50 a 80 personas</strong>, la pista de 3x3 m (9 m²) es perfecta. Para <strong>bodas y XV años de 100 a 150 invitados</strong>, recomendamos la de 4x4 m (16 m²). Para <strong>eventos grandes de 200+ personas</strong>, la pista de 5x5 m (25 m²) ofrece espacio amplio. Y para <strong>fiestas masivas y festivales</strong>, la de 6x6 m (36 m²) garantiza comodidad total. Nuestro asesor evalúa tu espacio y te recomienda la opción ideal.' },
  { question: "¿La pista LED RGB se sincroniza con la música?", answer: 'Sí, todas nuestras pistas LED RGB incluyen <strong>controlador DMX 512 profesional</strong> con sincronización musical en tiempo real. Los paneles cambian de color, intensidad y patrón al ritmo de cada canción. El técnico coordina directamente con tu DJ para programar efectos especiales en momentos clave como el <strong>primer baile, vals de XV años, brindis y hora loca</strong>. También incluimos modo automático que reacciona al beat sin necesidad de intervención manual.' },
  { question: "¿La superficie de la pista resiste tacones y uso intensivo?", answer: 'Absolutamente. La superficie de nuestras pistas LED RGB está fabricada en <strong>acrílico templado antideslizante</strong> diseñado específicamente para eventos de alto tránsito. Resiste tacones altos, zapatos de vestir y calzado deportivo sin rayarse ni dañarse. Cada panel soporta hasta <strong>750 kg por metro cuadrado</strong>, lo que permite que decenas de personas bailen simultáneamente con total seguridad. La textura antideslizante garantiza estabilidad incluso con movimientos enérgicos de baile.' },
  { question: "¿Se puede usar la pista LED RGB en exteriores?", answer: 'Nuestra pista LED RGB estándar está diseñada para <strong>uso en interiores</strong> — salones, jardines techados y terrazas cubiertas. Para eventos completamente al aire libre, te recomendamos nuestra <a href="/servicios/pistas-baile/pistas-led/exterior/">pista LED Exterior con certificación IP65</a>, resistente al agua y polvo. Si tu evento es nocturno en un jardín sin lluvia, la pista RGB puede funcionar en áreas protegidas. Nuestro equipo evalúa las condiciones de tu venue para recomendarte la mejor opción.' },
  { question: "¿Cuánto tiempo toma el montaje de la pista LED RGB?", answer: 'El tiempo de instalación varía según el tamaño. La pista de <strong>3x3 m se instala en 1.5 horas</strong>, la de 4x4 m en aproximadamente 2 horas, la de 5x5 m en 2.5 horas y la de <strong>6x6 m requiere unas 3.5 horas</strong>. Nuestro equipo llega con anticipación suficiente para tener la pista lista, probada y calibrada antes de que lleguen tus invitados. La instalación incluye nivelación, cableado oculto, pruebas de iluminación y programación de las secuencias de color.' },
  { question: "¿Con cuánta anticipación debo reservar la pista LED RGB?", answer: 'Recomendamos reservar con <strong>3 a 6 semanas de anticipación</strong>, especialmente en temporada alta (noviembre a febrero y temporada de bodas de abril a junio). Las pistas RGB de 4x4 m y 5x5 m son las más solicitadas y se agotan primero los fines de semana. Para eventos que requieren configuraciones especiales o múltiples servicios, lo ideal es apartar con <strong>2 meses de anticipación</strong>. Un anticipo del 30% asegura tu fecha y configuración. También atendemos solicitudes de último momento sujetas a disponibilidad.' },
];

const specs = [
  { label: "Paneles", value: "LED RGB 50x50 cm modulares" },
  { label: "Colores", value: "16 millones, programables" },
  { label: "Control", value: "DMX 512 con sincronización musical" },
  { label: "Medidas", value: "3x3, 4x4, 5x5, 6x6 metros" },
  { label: "Brillo", value: "5,000+ nits" },
  { label: "Superficie", value: "Anti-deslizante, resistente a tacones" },
  { label: "Peso por panel", value: "8 kg" },
  { label: "Instalación", value: "A nivel de suelo, sin desniveles" },
  { label: "Energía", value: "220V, consumo 150W/m²" },
  { label: "Técnico", value: "Operador DMX incluido" },
];

const sidebarNav = [
  { name: "LED RGB Clásica", href: null, active: true },
  { name: "LED Pixel", href: "/servicios/pistas-baile/pistas-led/pixel/" },
  { name: "LED Infinita", href: "/servicios/pistas-baile/pistas-led/infinita/" },
  { name: "LED Exterior", href: "/servicios/pistas-baile/pistas-led/exterior/" },
];

const sidebarRelated = [
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Mariana López", text: "Rentamos la pista LED RGB de 4x4 para nuestra boda en un jardín de Coyoacán. Los colores personalizados con nuestro tema de boda se veían increíbles. El primer baile con la pista en tonos dorados fue mágico. El técnico coordinó perfecto con nuestro DJ. Totalmente recomendado.", rating: 5, date: "2025-11-20" },
  { author: "Fernanda Gutiérrez", text: "La pista LED RGB de 5x5 fue la estrella de los XV años de mi hija. Los efectos de colores sincronizados con la música hicieron que el vals fuera un momento espectacular. Todos los invitados quedaron impresionados. La instalación fue rápida y sin complicaciones.", rating: 5, date: "2025-10-12" },
  { author: "Carlos Mendoza", text: "Usamos la pista RGB de 3x3 para una fiesta corporativa de fin de año. Tamaño perfecto para nuestro salón. Los programas de colores pre-cargados se veían profesionales y el técnico estuvo atento toda la noche. Excelente relación calidad-precio.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Pista de Baile LED RGB para Eventos en CDMX",
    description: "Renta de pista de baile LED RGB con 16 millones de colores y sincronización DMX para bodas y fiestas en CDMX. Paneles 50x50cm. Desde $8,000.",
    url: "/servicios/pistas-baile/pistas-led/rgb/",
    priceRange: { min: 8000, max: 35000 },
    reviews,
    ratingValue: 5,
    reviewCount: 345,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Pistas LED", url: "/servicios/pistas-baile/pistas-led/" },
    { name: "LED RGB Clásica", url: "/servicios/pistas-baile/pistas-led/rgb/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pista de Baile LED RGB para Eventos en CDMX"
  description="Renta de pista de baile LED RGB con 16 millones de colores y sincronización DMX para bodas y fiestas en CDMX. Paneles 50x50cm. Desde $8,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La más popular para bodas y XV años"
    title='Renta de <span class="highlight">Pista de Baile LED RGB</span> para Eventos en CDMX'
    subtitle="Pista de baile LED RGB con paneles modulares de 50x50 cm y 16 millones de colores. Sincronización DMX con música, efectos personalizados y técnico de operación incluido para bodas, XV años y fiestas."
    primaryCTA={{ label: "Cotiza tu pista RGB", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile LED RGB para mi evento` }}
    cards={[
      {
        title: "Paneles LED 50x50cm con 16 millones de colores",
        content: "<strong>Renta de pista de baile LED RGB</strong> con la tecnología más popular para eventos en CDMX. Paneles modulares de 50x50 cm con 16 millones de colores programables y sincronización DMX en tiempo real con la música. Disponible en medidas desde 3x3 hasta 6x6 metros para adaptarse a cualquier salón, jardín o terraza techada. Superficie templada antideslizante que soporta tacones y uso intensivo durante todo tu evento.",
      },
      {
        title: "Controlador DMX incluido con programas pre-cargados",
        content: "<strong>Controlador DMX 512 profesional</strong> incluido en cada renta con biblioteca de programas pre-cargados para cada tipo de celebración. Secuencias románticas para el primer baile, efectos vibrantes para la fiesta libre y transiciones suaves para momentos especiales. Técnico de operación dedicado durante todo el evento que coordina con tu DJ para sincronizar cada cambio de color con la música en tiempo real.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Lista para transformar tu pista de baile con color?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el tamaño ideal para tu espacio y número de invitados"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pistas LED para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una pista LED RGB para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una pista de baile LED RGB para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/><path d="M12 3v18"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Pista LED RGB Clásica</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Pista RGB 3x3 -->
          <section class="section section--alt" aria-labelledby="rgb-3x3-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para fiestas íntimas</span>
                <h2 class="showcase__title" id="rgb-3x3-heading">Pista LED RGB 3x3 Metros</h2>
                <p class="showcase__subtitle">La pista perfecta para fiestas íntimas de 50 a 80 personas con colores vibrantes y sincronización musical.</p>
                <p class="showcase__text">Nuestra <strong>pista LED RGB de 3x3 metros</strong> (9 m²) es la opción ideal para <strong>fiestas íntimas, cumpleaños, despedidas y reuniones sociales</strong> con hasta 80 invitados. Compuesta por 36 paneles LED de 50x50 cm, reproduce 16 millones de colores con transiciones suaves y programables. El controlador DMX permite sincronización en tiempo real con la música de tu DJ, creando un espectáculo visual que reacciona al ritmo de cada canción. Superficie antideslizante que soporta tacones y uso intensivo durante toda la noche.</p>
                <p class="showcase__text">Incluye <strong>programación de secuencias personalizadas</strong> para los momentos clave de tu celebración: pastel, brindis, hora loca y baile libre. El técnico coordina directamente con tu DJ para sincronizar transiciones de color con cada canción seleccionada. Combínala con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> como fairy lights y esferas LED para crear un ambiente envolvente que multiplique el impacto visual de tu fiesta.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">3x3 metros</span>
                  <span class="showcase__tag">36 paneles</span>
                  <span class="showcase__tag">50-80 personas</span>
                  <span class="showcase__tag">DMX sincronizado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pista RGB 3x3
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista LED RGB 3x3</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Pista RGB 4x4 -->
          <section class="section section--alt" aria-labelledby="rgb-4x4-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">La favorita para bodas y XV años</span>
                <h2 class="showcase__title" id="rgb-4x4-heading">Pista LED RGB 4x4 Metros</h2>
                <p class="showcase__subtitle">El tamaño más solicitado para bodas y XV años con 100 a 150 invitados.</p>
                <p class="showcase__text">La <strong>pista LED RGB de 4x4 metros</strong> (16 m²) es nuestra configuración más popular para <strong>bodas, XV años y eventos sociales</strong> de 100 a 150 personas. Con 64 paneles LED de alta luminosidad, ofrece un espacio amplio y cómodo para el primer baile, el vals de quinceañera y la fiesta libre. Los 16 millones de colores se programan a medida para cada celebración: tonos dorados y rosados para bodas románticas, efectos vibrantes multicolor para XV años y secuencias elegantes para galas.</p>
                <p class="showcase__text">El <strong>controlador DMX profesional</strong> incluido permite crear secuencias especiales para cada momento del evento. Para el primer baile programamos transiciones suaves en los colores de tu boda. Para el vals de XV años, un espectáculo de colores que sigue la coreografía. Y para la fiesta libre, efectos automáticos que reaccionan al beat de la música. Combínala con nuestro <a href="/servicios/audiovisual/sonido/">equipo de sonido profesional</a> para una experiencia audiovisual completa.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4x4 metros</span>
                  <span class="showcase__tag">64 paneles</span>
                  <span class="showcase__tag">100-150 personas</span>
                  <span class="showcase__tag">Secuencias personalizadas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pista RGB 4x4
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista LED RGB 4x4</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Pista RGB 5x5 -->
          <section class="section section--alt" aria-labelledby="rgb-5x5-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Para eventos grandes</span>
                <h2 class="showcase__title" id="rgb-5x5-heading">Pista LED RGB 5x5 Metros</h2>
                <p class="showcase__subtitle">Espacio amplio para eventos grandes con más de 200 invitados y máximo impacto visual.</p>
                <p class="showcase__text">La <strong>pista LED RGB de 5x5 metros</strong> (25 m²) es la elección para <strong>eventos grandes, bodas con más de 200 invitados y celebraciones de alto perfil</strong>. Con 100 paneles LED modulares, crea un escenario de luz impresionante donde decenas de personas pueden bailar cómodamente al mismo tiempo. La mayor superficie permite efectos visuales más elaborados: degradados de colores que recorren toda la pista, ondas de luz sincronizadas con la música y patrones geométricos que hipnotizan a los asistentes.</p>
                <p class="showcase__text">Ideal para <strong>salones de banquetes grandes, haciendas con explanadas y jardines amplios techados</strong>. El brillo de 5,000+ nits garantiza que los colores se aprecien con nitidez incluso en espacios con iluminación ambiental. Incluimos <strong>programación avanzada con transiciones multi-zona</strong>: diferentes colores y efectos en distintas áreas de la pista simultáneamente. Complementa con nuestra <a href="/servicios/iluminacion/efectos-especiales/">iluminación de efectos especiales</a> como humo bajo y láser para una producción espectacular.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">5x5 metros</span>
                  <span class="showcase__tag">100 paneles</span>
                  <span class="showcase__tag">200+ personas</span>
                  <span class="showcase__tag">Efectos multi-zona</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pista RGB 5x5
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista LED RGB 5x5</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Pista RGB 6x6 -->
