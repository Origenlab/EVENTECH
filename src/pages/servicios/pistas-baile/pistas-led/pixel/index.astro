---
/**
 * ─── Pista LED Pixel — Pagina de Producto (Nivel 4) ───
 * Pista de baile LED Pixel con control individual por pixel para
 * animaciones, logos y video en eventos en CDMX.
 *
 * Jerarquia: Servicios > Pistas de Baile > Pistas LED > LED Pixel
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Pistas LED", href: "/servicios/pistas-baile/pistas-led/" },
  { label: "LED Pixel" },
];

const faqs = [
  { question: "¿Qué tipo de contenido se puede mostrar en la pista LED Pixel?", answer: 'La pista LED Pixel puede reproducir prácticamente cualquier contenido visual. Acepta <strong>logos corporativos, monogramas de pareja, textos animados, videos en formato MP4, MOV y GIF, animaciones personalizadas y gráficos en PNG</strong>. Para bodas, los monogramas con las iniciales de la pareja y contadores regresivos son los más populares. Para eventos corporativos, logos animados y contenido de marca. El procesador de video dedicado gestiona todo el contenido con fluidez y sin interrupciones durante tu evento.' },
  { question: "¿Incluye el diseño de animaciones personalizadas?", answer: 'Sí, cada renta de pista LED Pixel incluye <strong>diseño básico de contenido personalizado</strong>: monograma con iniciales, logo de empresa en formato animado y 2-3 secuencias de colores temáticas. Para contenido más elaborado como <strong>animaciones complejas, video mapping o secuencias narrativas</strong>, ofrecemos nuestro servicio de diseño premium con un equipo de motion graphics que crea contenido exclusivo para tu evento. El contenido se entrega y aprueba antes del día del evento.' },
  { question: "¿Cuál es la diferencia entre la pista Pixel y la RGB?", answer: 'La diferencia principal está en el nivel de control y resolución. La <strong>pista RGB clásica</strong> ilumina cada panel completo de un solo color — ideal para efectos de colores y sincronización musical. La <strong>pista Pixel</strong> controla cada punto de luz de forma independiente, permitiendo crear imágenes, textos, logos y videos directamente en la superficie de la pista. Piensa en la RGB como un foco de colores y en la Pixel como una pantalla de televisión en el piso. La Pixel es ideal cuando necesitas mostrar contenido visual específico, no solo efectos de color.' },
  { question: "¿Se puede cambiar el contenido durante el evento?", answer: 'Absolutamente. El <strong>procesador de video dedicado</strong> permite cambiar el contenido en tiempo real durante todo el evento. Nuestro técnico puede alternar entre monogramas, animaciones, efectos de color y videos según la programación del evento. Por ejemplo, en una boda: monograma durante la recepción, efectos románticos durante el primer baile, logo de la fiesta durante la cena, y efectos de colores vibrantes para la fiesta libre. Todo se coordina con tu DJ y wedding planner.' },
  { question: "¿Cuánto peso soporta la pista LED Pixel?", answer: 'Nuestras pistas LED Pixel están diseñadas para <strong>uso intensivo en eventos</strong>. Cada panel soporta hasta <strong>750 kg por metro cuadrado</strong>, lo que significa que decenas de personas pueden bailar simultáneamente sin ningún riesgo. La estructura interna de aluminio de aviación y la superficie de acrílico templado garantizan durabilidad y seguridad total. Están certificadas para uso comercial y cumplen con todas las normas de seguridad para eventos masivos.' },
  { question: "¿Con cuánta anticipación debo reservar la pista LED Pixel?", answer: 'Recomendamos reservar con <strong>4 a 8 semanas de anticipación</strong> para garantizar disponibilidad y tiempo suficiente para el diseño de contenido personalizado. Las pistas Pixel son equipo premium con inventario limitado, especialmente en temporada alta (noviembre a febrero). Si tu evento requiere <strong>contenido personalizado complejo</strong> (animaciones, video mapping), lo ideal es apartar con 2 meses de anticipación para el proceso de diseño y aprobación. Un anticipo del 30% asegura tu fecha.' },
];

const specs = [
  { label: "Tecnología", value: "LED Pixel con control individual" },
  { label: "Resolución", value: "Alta densidad de pixeles por panel" },
  { label: "Control", value: "Procesador de video + software dedicado" },
  { label: "Medidas", value: "3x3 a 5x5 metros" },
  { label: "Contenido", value: "Logos, textos, animaciones, video" },
  { label: "Formatos", value: "MP4, MOV, GIF, PNG" },
  { label: "Brillo", value: "6,000+ nits" },
  { label: "Superficie", value: "Anti-deslizante templada" },
  { label: "Personalización", value: "Contenido a medida incluido" },
  { label: "Técnico", value: "Operador de video incluido" },
];

const sidebarNav = [
  { name: "LED RGB Clásica", href: "/servicios/pistas-baile/pistas-led/rgb/" },
  { name: "LED Pixel", href: null, active: true },
  { name: "LED Infinita", href: "/servicios/pistas-baile/pistas-led/infinita/" },
  { name: "LED Exterior", href: "/servicios/pistas-baile/pistas-led/exterior/" },
];

const sidebarRelated = [
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Sonido Profesional", href: "/servicios/audiovisual/sonido/" },
  { name: "Equipo DJ", href: "/servicios/audiovisual/microfonos-dj/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Ricardo Salinas", text: "Usamos la pista LED Pixel para un evento corporativo de lanzamiento de producto. El logo de la empresa animado en la pista impresionó a todos los asistentes. El equipo de EVENTECH diseñó las animaciones a medida y el resultado fue espectacular. Totalmente profesional.", rating: 5, date: "2025-11-08" },
  { author: "Andrea Martínez", text: "Para nuestra boda elegimos la pista Pixel con nuestro monograma personalizado. Ver nuestras iniciales iluminadas en la pista durante el primer baile fue un momento inolvidable. Las fotos y videos quedaron increíbles. El técnico coordinó todo perfecto con nuestro DJ.", rating: 5, date: "2025-10-25" },
  { author: "Javier Domínguez", text: "Contratamos la pista Pixel para el lanzamiento de un nuevo producto de tecnología. El video del producto reproduciéndose en la pista fue un hit total. Los invitados no dejaban de tomar fotos. La calidad de imagen es impresionante. Sin duda la mejor inversión para nuestro evento.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Pista de Baile LED Pixel para Eventos en CDMX",
    description: "Renta de pista de baile LED Pixel con control individual por pixel para animaciones, logos y video en eventos en CDMX. Máxima resolución. Desde $15,000.",
    url: "/servicios/pistas-baile/pistas-led/pixel/",
    priceRange: { min: 15000, max: 55000 },
    reviews,
    ratingValue: 5,
    reviewCount: 189,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Pistas LED", url: "/servicios/pistas-baile/pistas-led/" },
    { name: "LED Pixel", url: "/servicios/pistas-baile/pistas-led/pixel/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pista de Baile LED Pixel para Eventos en CDMX"
  description="Renta de pista de baile LED Pixel con control individual por pixel para animaciones, logos y video en eventos en CDMX. Máxima resolución. Desde $15,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Animaciones, logos y video en el piso"
    title='Renta de <span class="highlight">Pista de Baile LED Pixel</span> para Eventos en CDMX'
    subtitle="Pista de baile LED Pixel con control individual por pixel para animaciones personalizadas, logos corporativos y reproducción de video. Procesador de video dedicado y contenido a medida para eventos premium."
    primaryCTA={{ label: "Cotiza tu pista Pixel", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile LED Pixel para mi evento` }}
    cards={[
      {
        title: "Control individual por pixel para animaciones personalizadas",
        content: "<strong>Renta de pista de baile LED Pixel</strong> con la tecnología más avanzada en resolución para eventos en CDMX. Cada punto de luz se controla de forma independiente, permitiendo crear animaciones personalizadas, reproducir logos corporativos, textos en movimiento y video directamente en la superficie de la pista. Ideal para bodas con monogramas, eventos corporativos con branding y lanzamientos de producto con contenido visual de alto impacto.",
      },
      {
        title: "Procesador de video dedicado con contenido en tiempo real",
        content: "<strong>Máxima resolución LED</strong> con procesador de video dedicado que gestiona contenido pre-programado o en tiempo real durante todo tu evento. Diseño básico de contenido personalizado incluido: monogramas, logos animados y secuencias temáticas. El operador de video coordina con tu DJ y wedding planner para sincronizar cada cambio de contenido con los momentos clave de tu celebración.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres proyectar tu logo o monograma en la pista de baile?"
    subheadline="Cotiza sin compromiso — incluimos diseño de contenido personalizado para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Pistas LED para Eventos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una pista LED Pixel para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una pista de baile LED Pixel para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 12h18"/><path d="M12 3v18"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Pista LED Pixel</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Pixel con Logo -->
          <section class="section section--alt" aria-labelledby="pixel-logo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Branding en la pista</span>
                <h2 class="showcase__title" id="pixel-logo-heading">Pista Pixel con Logo Personalizado</h2>
                <p class="showcase__subtitle">Tu monograma de pareja o logo corporativo iluminado en la pista de baile con animación personalizada.</p>
                <p class="showcase__text">La configuración más solicitada de nuestra <strong>pista LED Pixel con logo personalizado</strong> proyecta tu identidad visual directamente en la superficie de baile. Para <strong>bodas</strong>, creamos monogramas elegantes con las iniciales de la pareja en tipografías y colores que combinan con tu decoración. Para <strong>eventos corporativos</strong>, el logo de tu empresa animado con efectos de entrada, brillo y transiciones profesionales. El logo puede permanecer estático como fondo elegante o animarse con efectos de partículas, resplandor y movimiento.</p>
                <p class="showcase__text">Incluye <strong>diseño básico del monograma o adaptación de logo</strong> sin costo adicional. Nuestro equipo de diseño recibe tu logo o las iniciales de la pareja y crea una versión optimizada para la resolución de la pista. El contenido se envía para aprobación antes del evento. Para bodas, combinamos el monograma con <strong>efectos románticos de estrellas y partículas</strong> que se activan durante el primer baile. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas</a> para reforzar la identidad visual en todo el venue.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Logo animado</span>
                  <span class="showcase__tag">Monograma</span>
                  <span class="showcase__tag">Diseño incluido</span>
                  <span class="showcase__tag">Branding total</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pixel con Logo
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista Pixel con Logo</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Pixel con Animaciones -->
          <section class="section section--alt" aria-labelledby="pixel-animaciones-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Efectos visuales dinámicos</span>
                <h2 class="showcase__title" id="pixel-animaciones-heading">Pista Pixel con Animaciones</h2>
                <p class="showcase__subtitle">Efectos geométricos, patrones de color y animaciones personalizadas que transforman la experiencia de baile.</p>
                <p class="showcase__text">Las <strong>animaciones personalizadas</strong> en la pista LED Pixel crean un espectáculo visual dinámico que mantiene la energía de tu evento al máximo. Ofrecemos una biblioteca de <strong>efectos geométricos, patrones fractales, ondas de color, estrellas, fuego artificial y más de 50 animaciones pre-diseñadas</strong> que se reproducen en secuencia o se sincronizan con la música. Cada animación se programa a la velocidad y colores que prefieras para complementar la temática de tu celebración.</p>
                <p class="showcase__text">Para eventos con temáticas específicas, nuestro equipo de <strong>motion graphics</strong> diseña animaciones exclusivas: patrones Art Deco para galas elegantes, efectos de galaxia para fiestas espaciales, flores para celebraciones de primavera o formas abstractas para eventos de arte. Las animaciones transicionan suavemente entre sí y reaccionan al ritmo de la música gracias al <strong>procesador de video con análisis de audio en tiempo real</strong>. Combínala con nuestra <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para una producción visual envolvente.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">50+ animaciones</span>
                  <span class="showcase__tag">Efectos geométricos</span>
                  <span class="showcase__tag">Sincronización musical</span>
                  <span class="showcase__tag">Motion graphics</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pixel con Animaciones
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista Pixel con Animaciones</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Pixel con Video -->
          <section class="section section--alt" aria-labelledby="pixel-video-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Video bajo tus pies</span>
                <h2 class="showcase__title" id="pixel-video-heading">Pista Pixel con Video</h2>
                <p class="showcase__subtitle">Reproducción de video de alta resolución directamente en la superficie de la pista de baile.</p>
                <p class="showcase__text">La <strong>pista LED Pixel con reproducción de video</strong> lleva la experiencia visual al máximo nivel. Reproduce <strong>videos en formato MP4 y MOV</strong> directamente en la superficie de baile con calidad de imagen impresionante. Para lanzamientos de producto, el video del producto se reproduce bajo los pies de los asistentes. Para bodas, el video retrospectivo de la pareja se proyecta en la pista durante la cena. Para eventos de moda, la pasarela cobra vida con contenido visual dinámico.</p>
                <p class="showcase__text">El <strong>procesador de video de alto rendimiento</strong> gestiona la reproducción con framerate fluido y colores vibrantes. Nuestro técnico adapta el contenido de video a la resolución exacta de la pista para evitar distorsiones. Incluye <strong>reproducción en bucle</strong> para contenido continuo y capacidad de alternar entre múltiples videos durante el evento. Formatos soportados: MP4, MOV, AVI en resolución hasta Full HD. Combínala con nuestras <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para una experiencia multimedia 360 grados.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Video Full HD</span>
                  <span class="showcase__tag">MP4 / MOV</span>
                  <span class="showcase__tag">Reproducción en bucle</span>
                  <span class="showcase__tag">Multi-contenido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Pixel con Video
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <rect x="3" y="3" width="18" height="18" rx="2"/>
                    <path d="M3 12h18"/><path d="M12 3v18"/>
                    <path d="M3 7.5h18"/><path d="M3 16.5h18"/>
                    <path d="M7.5 3v18"/><path d="M16.5 3v18"/>
                  </svg>
                  <span>Pista Pixel con Video</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Pixel Premium -->
          <section class="section section--alt" aria-labelledby="pixel-premium-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Experiencia completa</span>
                <h2 class="showcase__title" id="pixel-premium-heading">Kit Pixel Premium</h2>
                <p class="showcase__subtitle">Pista LED Pixel con contenido personalizado premium, efectos especiales y producción visual completa.</p>
