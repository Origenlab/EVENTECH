---
/**
 * ─── EVENTECH.MX — Renta de Pistas de Baile LED Iluminadas (Hub L4, molde hm- 2026) ───
 * RGB · Pixel · Infinita · Exterior — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/pistas-baile — pista-led-rgb, acrilica y pista-baile reales.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "rgb",
    name: "Pista LED RGB Clásica",
    badge: "La más popular",
    excerpt: "Paneles LED de 50×50 cm con 16 millones de colores y sincronización musical DMX. De 3×3 hasta 6×6 metros, la opción más popular para bodas, XV años y fiestas.",
    href: "/servicios/pistas-baile/pistas-led/rgb/",
    image: "/images/pistas-baile/pista-led-rgb-fiesta.avif",
    specs: ["3×3 a 6×6 m", "16M colores", "DMX", "Sync musical"],
  },
  {
    id: "pixel",
    name: "Pista LED Pixel",
    badge: "Máxima resolución",
    excerpt: "Control individual por pixel para animaciones personalizadas, logos, textos y reproducción de video. Máxima resolución para eventos corporativos y producciones de alto nivel.",
    href: "/servicios/pistas-baile/pistas-led/pixel/",
    image: "/images/pistas-baile/pista-baile-01.avif",
    specs: ["Control por pixel", "Animaciones custom", "Logos y texto", "Video playback"],
  },
  {
    id: "infinita",
    name: "Pista LED Infinita",
    badge: "Factor WOW",
    excerpt: "Efecto espejo infinito con ilusión de profundidad 3D. Crea efectos de estrellas, túneles y galaxias que deslumbran a tus invitados. El factor WOW garantizado.",
    href: "/servicios/pistas-baile/pistas-led/infinita/",
    image: "/images/pistas-baile/pista-baile-02.avif",
    specs: ["Espejo infinito", "Profundidad 3D", "Estrellas / túneles", "Efecto WOW"],
  },
  {
    id: "exterior",
    name: "Pista LED Exterior",
    badge: "IP65 para jardín",
    excerpt: "Certificación IP65 resistente al agua con superficie antideslizante. Instalación a nivel de suelo para jardines, terrazas y eventos al aire libre con total seguridad.",
    href: "/servicios/pistas-baile/pistas-led/exterior/",
    image: "/images/pistas-baile/pista-baile-03.avif",
    specs: ["IP65 waterproof", "Antideslizante", "Nivel de suelo", "Base niveladora"],
  },
];

const whyFeatures = [
  {
    title: "Sincronización con tu DJ y secuencias por momento",
    body: "Una pista LED que solo parpadea al azar se ve barata. La nuestra se sincroniza con DMX a la música de tu DJ, con secuencias programadas para cada momento —primer baile, vals, entrada, clímax de la fiesta— que cambian color, intensidad y patrón al ritmo. Coordinamos directamente con tu DJ para que el piso siga la música.",
  },
  {
    title: "Paneles propios calibrados que soportan 750 kg/m²",
    body: "Paneles LED propios con estructura interna de aluminio de aviación y superficie de acrílico templado que soporta hasta 750 kg/m² — decenas de personas bailando a la vez sin riesgo. Cada panel se revisa y calibra en color antes de salir para que la pista se vea pareja, sin celdas apagadas ni tonos distintos.",
  },
  {
    title: "Logo, monograma o video en la pista (pixel)",
    body: "La pista pixel se controla celda por celda: proyectamos el monograma de los novios, el logo de tu marca, el número de XV años, textos animados o incluso video en el propio piso. El detalle que convierte la pista en la pieza de producción más comentada del evento y el mejor fondo para fotos aéreas.",
  },
  {
    title: "IP65 y antideslizante para exteriores seguros",
    body: "Nuestra línea de exterior tiene certificación IP65 resistente al agua, polvo y rocío nocturno, con superficie antideslizante que mantiene el agarre en jardines y terrazas. Se instala a nivel de suelo con base niveladora para terreno irregular — la magia del LED también al aire libre, sin riesgo de resbalones.",
  },
  {
    title: "Instalación nivelada, probada antes del evento",
    body: "Llegamos con anticipación para instalar, nivelar, ocultar el cableado, probar la iluminación y programar las secuencias antes de que llegue el primer invitado. La pista queda calibrada y verificada — nada de estar ajustando celdas o cargando video cuando la fiesta ya empezó.",
  },
  {
    title: "Integración con el show de luz y efectos",
    body: "La pista LED luce más coordinada con la iluminación de escenario, los efectos y la cabina DJ del mismo proveedor. Integramos el piso con el resto del show de luz desde EVENTECH, con un solo criterio visual y una sola logística — para que todo el diseño lumínico cuente la misma historia.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y medida", p: "Evaluamos el venue (salón, jardín, terraza) y medimos el espacio para recomendar la dimensión ideal según tu número de invitados. En menos de 24 horas te enviamos propuesta con el tipo de pista LED (RGB, pixel, infinita o exterior) y la configuración de efectos." },
  { n: 2, t: "Propuesta, programación y aparto", p: "Definimos tipo de pista, tamaño, secuencias de color y —si es pixel— el logo, monograma o video a reproducir. Con el 30% de anticipo apartamos la pista y la fecha. Para diseños personalizados pedimos el archivo con anticipación para programar y probar." },
  { n: 3, t: "Instalación, nivelación y prueba", p: "Instalamos con anticipación: colocación de paneles, nivelación (base niveladora en exterior), cableado oculto, prueba de iluminación y programación de secuencias sincronizadas con tu DJ. Todo queda listo y calibrado antes de abrir puertas." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "Durante el evento la pista sigue la música (con operador o en modo automático reactivo al beat). Al finalizar, desmontamos y retiramos todo con cuidado. El montaje, la operación y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Qué tamaños de pista LED están disponibles?", answer: "Ofrecemos pistas LED en múltiples dimensiones para adaptarnos a tu evento. Los tamaños estándar son 3x3 m (9 m², ideal para hasta 50 personas), 4x4 m (16 m², para hasta 100 personas), 5x5 m (25 m², para hasta 150 personas) y 6x6 m (36 m², para 200+ personas). También configuramos dimensiones rectangulares como 4x3 m o 6x4 m según el espacio de tu venue. Nuestro equipo técnico evalúa tu salón o jardín y te recomienda el tamaño ideal según número de invitados y distribución del espacio." },
  { question: "¿La pista LED se puede sincronizar con la música?", answer: "Sí. Todas nuestras pistas LED RGB y Pixel incluyen controlador DMX que permite sincronización en tiempo real con la música. Los paneles cambian de color, intensidad y patrón al ritmo de cada canción. Trabajamos directamente con tu DJ para coordinar la programación de efectos. Para bodas, programamos secuencias especiales para el primer baile, vals de XV años y momentos clave. También incluimos modo automático que reacciona al beat sin necesidad de operador dedicado." },
  { question: "¿Pueden proyectar nuestro logo, monograma o nombres en la pista?", answer: "Sí, con la pista LED Pixel. El control individual por pixel nos permite mostrar en el piso el monograma de los novios, las iniciales, el número de XV años, el logo de tu marca, textos animados e incluso video. Solo necesitamos el archivo del diseño (logo vectorial o imagen en alta resolución) con al menos 1 semana de anticipación para programarlo y probarlo. Es uno de los efectos más solicitados para bodas y activaciones corporativas, y funciona espectacular en fotos y video aéreo con dron." },
  { question: "¿Se puede usar la pista LED en exteriores?", answer: "Sí, contamos con pistas LED certificadas IP65, diseñadas específicamente para uso en exteriores. Son resistentes al agua, polvo y humedad. La superficie antideslizante garantiza seguridad incluso con rocío nocturno. Se instalan a nivel de suelo sobre césped, concreto o terraza. Para jardines recomendamos complementar con nuestra base niveladora que se adapta a terrenos irregulares. Las pistas de interior estándar solo se usan en salones cerrados." },
  { question: "¿Cuánto peso soporta la pista LED?", answer: "Nuestras pistas LED están diseñadas para uso intensivo en eventos. Cada panel soporta hasta 750 kg por metro cuadrado, lo que significa que pueden bailar decenas de personas simultáneamente sin riesgo alguno. La estructura interna de aluminio de aviación y la superficie de acrílico templado garantizan durabilidad y seguridad. Están certificadas para uso comercial y cumplen con las normas de seguridad para eventos masivos." },
  { question: "¿Cuánto tiempo toma instalar una pista LED?", answer: "El tiempo de instalación varía según el tamaño. Una pista de 3x3 m se instala en aproximadamente 1.5 horas. Una de 4x4 m requiere unas 2 horas. Las configuraciones de 5x5 m y 6x6 m necesitan entre 2.5 y 3.5 horas. Nuestro equipo técnico llega con anticipación suficiente para tener la pista lista, probada y calibrada antes de que lleguen tus invitados. La instalación incluye nivelación, cableado oculto, pruebas de iluminación y programación de secuencias." },
  { question: "¿Con cuánta anticipación debo reservar la pista LED?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas de abril a junio). Las pistas LED RGB de 4x4 m y 5x5 m son las más solicitadas y se agotan primero. Para eventos en fin de semana, mientras antes reserves, mejor. También atendemos solicitudes de último momento sujetas a disponibilidad. Un anticipo del 30% asegura tu fecha y configuración." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile LED Iluminadas en CDMX",
    description: "Renta de pistas de baile LED RGB, pixel, espejo infinito y exterior IP65 en CDMX. Sincronización musical y logo personalizado. Montaje incluido. Cotiza hoy.",
    url: "/servicios/pistas-baile/pistas-led/",
    priceRange: { min: 2000, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Pistas LED", url: "/servicios/pistas-baile/pistas-led/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Pistas LED" },
];
---

<PageLayout
  title="Renta de Pistas de Baile LED Iluminadas en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/pistas-baile/pista-led-rgb-fiesta.avif"
  description="Renta de pistas de baile LED RGB, pixel, espejo infinito y exterior IP65 en CDMX. Sincronización musical y logo personalizado. Montaje incluido. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="led-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Pistas de baile LED · CDMX y ZMVM</p>
            <h1 id="led-hero-heading">
              Pistas de baile LED que convierten <em>el piso en el show de la fiesta</em>
            </h1>
            <p class="hm-hero__lead">
              Paneles RGB de 16 millones de colores sincronizados con la música, control por pixel
              para logos y video, efecto espejo infinito y versión IP65 de exterior. La pista que se
              ve tan bien como se baila — con sincronización a tu DJ incluida.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20LED%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar pista LED
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>pistas de baile LED</strong> en CDMX con paneles propios de
              50×50 cm que soportan <strong>750 kg/m²</strong>: <strong>RGB de 16 millones de
              colores</strong> sincronizados con música por DMX, <strong>pixel</strong> con control
              celda por celda para logos y video, <strong>espejo infinito</strong> con profundidad 3D
              y línea <strong>IP65 de exterior</strong> antideslizante. Cada pista se dimensiona a
              partir de una visita técnica al venue.
            </p>
            <p>
              Con <strong>más de 500 pistas instaladas</strong> en CDMX, sabemos que una pista LED es
              el efecto que más comparte la gente: por eso cada renta incluye programación con tu DJ,
              nivelación y prueba antes del evento. Combínala con nuestra
              <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a>,
              <a href="/servicios/audiovisual/microfonos-dj/">cabina DJ</a> y
              <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de pista LED disponibles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20LED%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El piso que ilumina la fiesta</p>
            <h2 id="catalogo-heading">¿Qué pista LED necesita tu evento?</h2>
            <p class="hm__head-sub">4 tecnologías — del RGB clásico al pixel con tu logo y el espejo infinito.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Una pista LED no solo se baila: se ve. Es el efecto que enciende la fiesta desde el
              piso, el fondo de las mejores fotos y el detalle que todos comparten en redes. Bien
              programada y sincronizada con la música, transforma la energía de la pista por completo.
            </p>
            <p>
              RGB clásica para color sincronizado con la música. Pixel para logos, texto y video en el
              piso. Infinita para el efecto WOW de profundidad 3D. Exterior IP65 para llevar el LED al
              jardín. Una sola empresa para toda la pista de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada tecnología, a fondo</p>
            <h2 id="detalle-heading">Las 4 pistas LED — en detalle</h2>
            <p class="hm__head-sub">Resolución, control, efecto y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada pista LED hay decisiones que afectan el impacto: el tipo de control que
              define si solo cambia de color o proyecta tu logo, el efecto que decide el factor WOW, y
              la certificación que permite —o no— usarla en exterior con seguridad.
            </p>
            <p>
              Conocer estas diferencias te permite elegir la pista con criterio. A continuación, lo
              que realmente importa de cada una.
            </p>
          </div>
        </div>

        <!-- RGB -->
        <article class="hm-feat" aria-labelledby="feat-rgb">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pista LED RGB Clásica</p>
            <h3 class="hm-feat__title" id="feat-rgb">16 millones de colores sincronizados con la música — la pista LED más pedida</h3>
            <p class="hm-feat__lead">El favorito de bodas y XV años. La pista RGB tiñe el piso de color al ritmo de la música y transforma la energía de la fiesta sin necesidad de configuraciones complejas.</p>
            <p>
              Paneles LED de <strong>50×50 cm con 16 millones de colores</strong> y controlador
              <strong>DMX</strong> que sincroniza color, intensidad y patrón con la música en tiempo
              real. Disponible de <strong>3×3 hasta 6×6 metros</strong>, con secuencias programadas
              para cada momento y modo automático reactivo al beat.
            </p>
            <p>
              La opción más popular para <strong>bodas, XV años, fiestas y eventos sociales</strong>.
              Coordinamos la programación con tu DJ para el primer baile, el vals y los momentos clave.
              Combínala con nuestra <a href="/servicios/audiovisual/microfonos-dj/">cabina DJ</a> para
              una pista con lenguaje visual coherente.
            </p>
            <ul class="hm-feat__stats">
              {["Paneles 50×50 cm", "16M colores", "3×3 a 6×6 m", "DMX", "Sync musical"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/pistas-baile/pistas-led/rgb/">
              Ver Pista LED RGB Clásica
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/pistas-baile/pista-led-rgb-fiesta.avif" alt="Pista LED RGB de colores para fiesta en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/pistas-baile/pista-baile-04.avif" alt="Pista LED RGB sincronizada con la música en boda" loading="lazy" decoding="async" />
              <img src="/images/pistas-baile/pista-baile-05.avif" alt="Paneles LED de color en zona de baile de evento" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- PIXEL -->
        <article class="hm-feat" aria-labelledby="feat-pixel">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pista LED Pixel</p>
            <h3 class="hm-feat__title" id="feat-pixel">Control celda por celda para proyectar tu logo, monograma o video en el piso</h3>
            <p class="hm-feat__lead">La pista que se vuelve pantalla. Con control por pixel, el piso muestra el monograma de los novios, el logo de tu marca o video — el detalle de producción más comentado y el mejor fondo para tomas aéreas con dron.</p>
            <p>
              <strong>Control individual por pixel</strong> que permite <strong>animaciones
              personalizadas, logos, textos y reproducción de video</strong> en el propio piso.
              Máxima resolución para diseños complejos, con transiciones y contenido a medida cargado
              desde tu archivo vectorial o de video.
            </p>
            <p>
              La elección de <strong>eventos corporativos, activaciones de marca, bodas de alto nivel
              y producciones</strong> que buscan impacto y branding. Solo necesitamos tu diseño con
              anticipación para programarlo y probarlo. Combínala con nuestras
              <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> para un lenguaje visual
              coordinado entre piso y pantalla.
            </p>
            <ul class="hm-feat__stats">
              {["Control por pixel", "Logo / monograma", "Texto animado", "Video playback", "Branding"].map((sp) => (<li>{sp}</li>))}
