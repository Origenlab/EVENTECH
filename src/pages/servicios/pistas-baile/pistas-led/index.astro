---
/**
 * ─── Pistas de Baile LED Iluminadas — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Pistas de Baile LED Iluminadas para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { label: "Pistas LED" },
];

const PISTAS_LED = [
  {
    name: "Pista LED RGB Clásica",
    excerpt: "Paneles LED de 50x50 cm con 16 millones de colores y sincronización musical DMX. Desde 3x3 hasta 6x6 metros, la opción más popular para bodas, XV años y fiestas.",
    cta: "LED RGB",
    href: "/servicios/pistas-baile/pistas-led/rgb/",
    icon: "lightbulb",
  },
  {
    name: "Pista LED Pixel",
    excerpt: "Control individual por pixel para animaciones personalizadas, logos, textos y reproducción de video. Máxima resolución para eventos corporativos y producciones de alto nivel.",
    cta: "LED Pixel",
    href: "/servicios/pistas-baile/pistas-led/pixel/",
    icon: "layers",
  },
  {
    name: "Pista LED Infinita",
    excerpt: "Efecto espejo infinito con ilusión de profundidad 3D. Crea efectos de estrellas, túneles y galaxias que deslumbran a tus invitados. El factor WOW garantizado.",
    cta: "LED Infinita",
    href: "/servicios/pistas-baile/pistas-led/infinita/",
    icon: "award",
  },
  {
    name: "Pista LED Exterior",
    excerpt: "Certificación IP65 resistente al agua con superficie antideslizante. Instalación a nivel de suelo para jardines, terrazas y eventos al aire libre con total seguridad.",
    cta: "LED Exterior",
    href: "/servicios/pistas-baile/pistas-led/exterior/",
    icon: "shield",
  },
];

const faqs = [
  { question: "¿Qué tamaños de pista LED están disponibles?", answer: "Ofrecemos pistas LED en múltiples dimensiones para adaptarnos a tu evento. Los tamaños estándar son 3x3 m (9 m², ideal para hasta 50 personas), 4x4 m (16 m², para hasta 100 personas), 5x5 m (25 m², para hasta 150 personas) y 6x6 m (36 m², para 200+ personas). También configuramos dimensiones rectangulares como 4x3 m o 6x4 m según el espacio de tu venue. Nuestro equipo técnico evalúa tu salón o jardín y te recomienda el tamaño ideal según número de invitados y distribución del espacio." },
  { question: "¿La pista LED se puede sincronizar con la música?", answer: "Sí. Todas nuestras pistas LED RGB y Pixel incluyen controlador DMX que permite sincronización en tiempo real con la música. Los paneles cambian de color, intensidad y patrón al ritmo de cada canción. Trabajamos directamente con tu DJ para coordinar la programación de efectos. Para bodas, programamos secuencias especiales para el primer baile, vals de XV años y momentos clave. También incluimos modo automático que reacciona al beat sin necesidad de operador dedicado." },
  { question: "¿Se puede usar la pista LED en exteriores?", answer: "Sí, contamos con pistas LED certificadas IP65, diseñadas específicamente para uso en exteriores. Son resistentes al agua, polvo y humedad. La superficie antideslizante garantiza seguridad incluso con rocío nocturno. Se instalan a nivel de suelo sobre césped, concreto o terraza. Para jardines recomendamos complementar con nuestra base niveladora que se adapta a terrenos irregulares. Las pistas de interior estándar solo se usan en salones cerrados." },
  { question: "¿Cuánto peso soporta la pista LED?", answer: "Nuestras pistas LED están diseñadas para uso intensivo en eventos. Cada panel soporta hasta 750 kg por metro cuadrado, lo que significa que pueden bailar decenas de personas simultáneamente sin riesgo alguno. La estructura interna de aluminio de aviación y la superficie de acrílico templado garantizan durabilidad y seguridad. Están certificadas para uso comercial y cumplen con las normas de seguridad para eventos masivos." },
  { question: "¿Cuánto tiempo toma instalar una pista LED?", answer: "El tiempo de instalación varía según el tamaño. Una pista de 3x3 m se instala en aproximadamente 1.5 horas. Una de 4x4 m requiere unas 2 horas. Las configuraciones de 5x5 m y 6x6 m necesitan entre 2.5 y 3.5 horas. Nuestro equipo técnico llega con anticipación suficiente para tener la pista lista, probada y calibrada antes de que lleguen tus invitados. La instalación incluye nivelación, cableado oculto, pruebas de iluminación y programación de secuencias." },
  { question: "¿Con cuánta anticipación debo reservar la pista LED?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas de abril a junio). Las pistas LED RGB de 4x4 m y 5x5 m son las más solicitadas y se agotan primero. Para eventos en fin de semana, mientras antes reserves, mejor. También atendemos solicitudes de último momento sujetas a disponibilidad. Un anticipo del 30% asegura tu fecha y configuración." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile LED Iluminadas para Eventos en CDMX",
    description: "Pistas LED RGB, Pixel, Infinita y Exterior para bodas, XV años y eventos. Sincronización musical DMX incluida.",
    url: "/servicios/pistas-baile/pistas-led/",
    priceRange: { min: 2000, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
    { name: "Pistas LED", url: "/servicios/pistas-baile/pistas-led/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pistas de Baile LED Iluminadas para Eventos en CDMX"
  description="Renta de pistas de baile LED iluminadas: RGB, Pixel, Infinita y Exterior para eventos en CDMX. Sincronización musical DMX. Desde $2,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Iluminación interactiva para tu pista de baile"
    title='Renta de <span class="highlight">Pistas de Baile LED</span> Iluminadas para Eventos en CDMX'
    subtitle="Pistas de baile LED con paneles iluminados desde 3x3 hasta 6x6 metros. 16 millones de colores, sincronización musical DMX y efectos personalizados para bodas, XV años y eventos corporativos."
    primaryCTA={{ label: "Cotiza tu pista LED", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile LED para mi evento` }}
    cards={[
      {
        title: "Pistas LED de última generación para cada celebración",
        content: "<strong>Renta de pistas de baile LED iluminadas</strong> con la tecnología más avanzada en CDMX. Paneles LED de 50x50 cm con 16 millones de colores y control DMX que se sincronizan al ritmo de la música. Pistas RGB clásicas para bodas y XV años, pistas Pixel con animaciones y logos personalizados para eventos corporativos, pistas Infinitas con efecto espejo 3D para fiestas de alto impacto, y pistas Exterior IP65 para jardines y terrazas — cada pista calibrada y verificada antes de cada entrega.",
      },
      {
        title: "Instalación profesional con técnico dedicado",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de pista LED. Nuestro equipo especializado se encarga del transporte, instalación con nivelación precisa, cableado oculto, programación de secuencias de color personalizadas, calibración de brillo según las condiciones del venue y sincronización directa con tu DJ. Controlador DMX profesional incluido para gestionar efectos, transiciones y momentos especiales durante todo el evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para transformar tu pista de baile?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con la pista LED ideal para tu evento y espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de pista LED
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pistas de Baile LED"
        subtitle="La pista iluminada perfecta para cada tipo de celebración"
        description={[
          "Desde pistas LED clásicas con colores vibrantes para bodas hasta pistas con efecto infinito para fiestas espectaculares. Contamos con el inventario de pistas de baile LED más completo de la Ciudad de México.",
          "Cada pista incluye controlador DMX, cableado profesional, programación de secuencias y técnico de operación dedicado. Colores, efectos y sincronización musical certificados para una experiencia inolvidable."
        ]}
      />

      <div class="grid grid--4">
        {PISTAS_LED.map((pista) => (
          <Card
            name={pista.name}
            excerpt={pista.excerpt}
            cta={pista.cta}
            href={pista.href}
            icon={pista.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA LED RGB CLÁSICA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="rgb-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">La más popular</span>
          <h2 class="showcase__title" id="rgb-heading">Pista LED RGB Clásica</h2>
          <p class="showcase__subtitle">La favorita para bodas, XV años y fiestas sociales con colores vibrantes que se sincronizan con la música.</p>
          <p class="showcase__text">Nuestra <strong>pista LED RGB clásica</strong> está compuesta por paneles modulares de <strong>50x50 cm</strong> con tecnología LED de alta luminosidad. Cada panel reproduce <strong>16 millones de colores</strong> con transiciones suaves y programables. El controlador DMX profesional permite <strong>sincronización en tiempo real con la música</strong>, creando un espectáculo visual que reacciona al ritmo de cada canción. Disponible en configuraciones desde <strong>3x3 metros hasta 6x6 metros</strong> para adaptarse a cualquier espacio.</p>
          <p class="showcase__text">Incluye <strong>programación de secuencias personalizadas</strong> para momentos clave: primer baile, vals de XV años, brindis y fiesta libre. El técnico coordina directamente con tu DJ para sincronizar transiciones de color con cada canción seleccionada. Superficie templada antideslizante que soporta uso intensivo. Combínala con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción de audio y video integrada que multiplique el impacto de tu celebración.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Paneles 50x50 cm</span>
            <span class="showcase__tag">16M colores</span>
            <span class="showcase__tag">DMX sincronizado</span>
            <span class="showcase__tag">3x3 a 6x6 m</span>
          </div>
          <a href="/servicios/pistas-baile/pistas-led/rgb/" class="btn btn--primary btn--lg">
            Ver Pista LED RGB
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="10" rx="2"/>
              <path d="M12 2v4"/>
              <path d="M8 4l4 3 4-3"/>
              <line x1="7" y1="15" x2="7" y2="17"/>
              <line x1="12" y1="15" x2="12" y2="17"/>
              <line x1="17" y1="15" x2="17" y2="17"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA LED PIXEL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="pixel-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Máxima resolución</span>
          <h2 class="showcase__title" id="pixel-heading">Pista LED Pixel</h2>
          <p class="showcase__subtitle">Control individual por pixel para animaciones personalizadas, logos y reproducción de video en tu pista de baile.</p>
          <p class="showcase__text">La <strong>pista LED Pixel</strong> lleva la iluminación de pista de baile al siguiente nivel con <strong>control individual de cada pixel</strong>. A diferencia de la RGB clásica donde cada panel es un solo color, aquí cada punto de luz se controla de forma independiente, permitiendo crear <strong>animaciones personalizadas, logos de empresa, textos en movimiento y reproducción de video</strong> directamente en el suelo. Resolución superior que transforma tu pista en una pantalla interactiva de alta definición.</p>
          <p class="showcase__text">Ideal para <strong>eventos corporativos, lanzamientos de producto, galas y premiaciones</strong> donde necesitas proyectar la identidad de marca en cada superficie. El software de control permite cargar <strong>contenido personalizado en tiempo real</strong>: logos animados, countdowns, gráficos de presentación y secuencias de video. Combínala con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> para crear ambientes inmersivos que dejen huella en cada asistente.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Control por pixel</span>
            <span class="showcase__tag">Animaciones custom</span>
            <span class="showcase__tag">Logos y texto</span>
            <span class="showcase__tag">Video playback</span>
          </div>
          <a href="/servicios/pistas-baile/pistas-led/pixel/" class="btn btn--primary btn--lg">
            Ver Pista LED Pixel
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="6" height="6" rx="1"/>
              <rect x="9" y="2" width="6" height="6" rx="1"/>
              <rect x="16" y="2" width="6" height="6" rx="1"/>
              <rect x="2" y="9" width="6" height="6" rx="1"/>
              <rect x="9" y="9" width="6" height="6" rx="1"/>
              <rect x="16" y="9" width="6" height="6" rx="1"/>
              <rect x="2" y="16" width="6" height="6" rx="1"/>
              <rect x="9" y="16" width="6" height="6" rx="1"/>
              <rect x="16" y="16" width="6" height="6" rx="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA LED INFINITA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="infinita-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Efecto visual WOW</span>
          <h2 class="showcase__title" id="infinita-heading">Pista LED Infinita</h2>
          <p class="showcase__subtitle">Efecto espejo infinito con ilusión de profundidad 3D que crea una experiencia visual deslumbrante.</p>
          <p class="showcase__text">La <strong>pista LED Infinita</strong> utiliza tecnología de <strong>espejo infinito (infinity mirror)</strong> que crea una impresionante ilusión óptica de profundidad tridimensional. Cada panel combina LEDs RGB con un sistema de espejos semitransparentes que genera un <strong>efecto de profundidad 3D</strong> aparentemente sin fin. Tus invitados sentirán que bailan sobre un abismo de luces que se extiende hacia el infinito — el factor WOW más impactante para cualquier celebración.</p>
          <p class="showcase__text">Los <strong>efectos de estrellas, túneles de luz y galaxias</strong> se programan a medida para cada evento. En bodas, creamos secuencias románticas de estrellas titilantes para el primer baile. En fiestas de XV años, túneles de colores vibrantes que reaccionan a la música. Para eventos corporativos, patrones geométricos elegantes que reflejan sofisticación. Combínala con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> como salas lounge y barras iluminadas para crear un ambiente cohesivo de diseño.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Efecto espejo infinito</span>
            <span class="showcase__tag">Profundidad 3D</span>
            <span class="showcase__tag">Estrellas y túneles</span>
            <span class="showcase__tag">Factor WOW</span>
          </div>
          <a href="/servicios/pistas-baile/pistas-led/infinita/" class="btn btn--primary btn--lg">
            Ver Pista LED Infinita
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
              <line x1="12" y1="2" x2="12" y2="4"/>
              <line x1="12" y1="20" x2="12" y2="22"/>
              <line x1="2" y1="12" x2="4" y2="12"/>
              <line x1="20" y1="12" x2="22" y2="12"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTA LED EXTERIOR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="exterior-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Para eventos al aire libre</span>
          <h2 class="showcase__title" id="exterior-heading">Pista LED Exterior</h2>
          <p class="showcase__subtitle">Certificación IP65 resistente al agua con superficie antideslizante para jardines, terrazas y haciendas.</p>
          <p class="showcase__text">Nuestra <strong>pista LED Exterior</strong> está diseñada específicamente para eventos al aire libre con certificación <strong>IP65 resistente al agua, polvo y humedad</strong>. La superficie cuenta con <strong>acabado antideslizante</strong> que garantiza seguridad incluso con rocío nocturno o condiciones de humedad. Cada panel se sella herméticamente con conectores waterproof y cableado protegido para operación segura en jardines, terrazas, haciendas y explanadas al aire libre.</p>
          <p class="showcase__text">La <strong>instalación a nivel de suelo</strong> se adapta a diferentes terrenos: césped, concreto, adoquín y tarimas. Incluimos base niveladora profesional que compensa irregularidades del terreno hasta 5 cm, garantizando una superficie perfectamente plana para bailar. Los LEDs de alto brillo mantienen colores vibrantes incluso en condiciones de luz ambiental exterior. Complementa con nuestras <a href="/servicios/carpas/">carpas y techos</a> para proteger la zona de baile de lluvia inesperada sin perder la magia del aire libre.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">IP65 waterproof</span>
            <span class="showcase__tag">Antideslizante</span>
            <span class="showcase__tag">Nivel de suelo</span>
            <span class="showcase__tag">Base niveladora</span>
          </div>
          <a href="/servicios/pistas-baile/pistas-led/exterior/" class="btn btn--primary btn--lg">
            Ver Pista LED Exterior
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Pistas de Baile LED"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu pista de baile LED, es natural tener preguntas sobre tamaños, efectos, instalación y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre pistas de baile LED al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de pistas de baile LED para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
