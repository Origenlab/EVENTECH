---
/**
 * ─── Pistas de Baile Category Page ───
 * Página de categoría: Renta de Pistas de Baile para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import CtaBar from "@components/CtaBar.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import FaqSection from "@components/FaqSection.astro";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile" },
];

const SUB_SERVICES = [
  {
    name: "Pistas LED Iluminadas",
    excerpt: "Paneles LED RGB programables que crean efectos de color, patrones dinámicos y animaciones sincronizadas con la música. El centro de atención de cualquier fiesta.",
    href: "/servicios/pistas-baile/pistas-led/",
    image: "/images/pistas-baile/pista-led-rgb-fiesta.avif",
    subcategories: [
      { name: "LED RGB Clásica", href: "/servicios/pistas-baile/pistas-led/rgb/" },
      { name: "LED Pixel", href: "/servicios/pistas-baile/pistas-led/pixel/" },
      { name: "LED Infinita", href: "/servicios/pistas-baile/pistas-led/infinita/" },
      { name: "LED Exterior", href: "/servicios/pistas-baile/pistas-led/exterior/" },
    ],
  },
  {
    name: "Pistas de Madera Clásica",
    excerpt: "Duela de madera laminada premium con acabado antiderrapante. La opción elegante y atemporal preferida para bodas, galas y eventos formales.",
    href: "/servicios/pistas-baile/madera-clasica/",
    image: "/images/pistas-baile/pista-madera-natural-boda.avif",
    subcategories: [
      { name: "Madera Natural", href: "/servicios/pistas-baile/madera-clasica/natural/" },
      { name: "Madera Nogal", href: "/servicios/pistas-baile/madera-clasica/nogal/" },
      { name: "Madera Wengué", href: "/servicios/pistas-baile/madera-clasica/wengue/" },
      { name: "Madera Blanca", href: "/servicios/pistas-baile/madera-clasica/blanca/" },
    ],
  },
  {
    name: "Pistas Vintage y Temáticas",
    excerpt: "Pistas estilo disco con espejos, damero blanco y negro, acrílico transparente y diseños personalizados. Para eventos con personalidad única.",
    href: "/servicios/pistas-baile/vintage-tematicas/",
    image: "/images/pistas-baile/pista-acrilica-transparente-boda.avif",
    subcategories: [
      { name: "Disco con Espejos", href: "/servicios/pistas-baile/vintage-tematicas/disco-espejos/" },
      { name: "Damero Blanco y Negro", href: "/servicios/pistas-baile/vintage-tematicas/damero/" },
      { name: "Acrílico Transparente", href: "/servicios/pistas-baile/vintage-tematicas/acrilico/" },
      { name: "Vinil Personalizado", href: "/servicios/pistas-baile/vintage-tematicas/vinil-custom/" },
    ],
  },
  {
    name: "Tarimas y Escenarios",
    excerpt: "Plataformas modulares de aluminio con superficie antiderrapante para escenarios, pasarelas, áreas elevadas y pistas sobre terreno irregular.",
    href: "/servicios/pistas-baile/tarimas-escenarios/",
    image: "/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif",
    subcategories: [
      { name: "Escenarios", href: "/servicios/pistas-baile/tarimas-escenarios/escenarios/" },
      { name: "Pasarelas", href: "/servicios/pistas-baile/tarimas-escenarios/pasarelas/" },
      { name: "Áreas Elevadas", href: "/servicios/pistas-baile/tarimas-escenarios/areas-elevadas/" },
      { name: "Tarimas DJ", href: "/servicios/pistas-baile/tarimas-escenarios/tarimas-dj/" },
    ],
  },
];

const faqs = [
  { question: "¿Qué tamaños de pista de baile tienen disponibles?", answer: "Manejamos pistas modulares desde 3x3 metros (ideal para eventos íntimos de 30-50 personas) hasta 8x8 metros o más para grandes celebraciones de 500+ invitados. Las medidas más solicitadas son 4x4m (50-80 personas), 5x5m (80-120 personas) y 6x6m (120-200 personas). La regla general es que aproximadamente un tercio de tus invitados estará bailando al mismo tiempo, así que calculamos la superficie ideal según tu número total de asistentes." },
  { question: "¿La pista se puede instalar en jardín o terreno irregular?", answer: "Sí. Nuestras pistas se instalan sobre un sistema de niveladores ajustables de acero galvanizado que compensan desniveles de hasta 15 cm. Para jardines, predios y terrenos con pasto, instalamos primero una base de plataformas modulares que protege el terreno y garantiza una superficie perfectamente plana y estable. El proceso es completamente reversible y no daña el piso ni el jardín." },
  { question: "¿La pista LED se puede personalizar con colores o logos?", answer: "Sí. Nuestras pistas LED utilizan paneles RGB de alta resolución controlados por DMX que permiten programar cualquier color, patrón, animación o secuencia sincronizada con la música. Podemos proyectar el monograma de los novios, logo corporativo, countdown, cambios de color por momentos del evento y efectos dinámicos como estrellas, ondas o fuego. El técnico operador programa todo previamente y controla los cambios en tiempo real durante el evento." },
  { question: "¿El montaje y desmontaje están incluidos?", answer: "Sí. Todos nuestros paquetes de pista de baile incluyen entrega, montaje profesional por nuestro equipo certificado y desmontaje al finalizar el evento. El montaje se realiza entre 4 y 8 horas antes del evento dependiendo del tamaño de la pista y si incluye sistema LED o niveladores para terreno irregular. Nuestro equipo se encarga de todo, incluyendo la conexión eléctrica y pruebas de funcionamiento." },
  { question: "¿Con cuánta anticipación debo reservar la pista?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación para garantizar disponibilidad del tamaño y tipo que necesitas. En temporada alta (noviembre a febrero) lo ideal es apartar con 6 semanas. Las pistas LED y las de gran formato (+6x6m) son las más solicitadas, así que conviene reservarlas con mayor anticipación. Realizamos una visita técnica al venue 1-2 semanas antes para planificar el montaje." },
  { question: "¿Es segura la pista LED? ¿Resiste tacones y peso?", answer: "Absolutamente. Nuestras pistas LED están fabricadas con paneles de policarbonato de alta resistencia con capacidad de carga de hasta 750 kg/m², superficie antiderrapante certificada y clasificación IP54 contra derrames de líquidos. Los paneles soportan tacones, zapatos de vestir y uso intensivo durante toda la noche sin rayarse ni dañarse. Cada panel tiene sellado perimetral que impide la entrada de líquidos a los componentes electrónicos." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile para Eventos en CDMX",
    description: "Pistas de baile LED, madera clásica, vintage y tarimas modulares para bodas, XV años y eventos en CDMX. Montaje profesional incluido.",
    url: "/servicios/pistas-baile/",
    priceRange: { min: 2000, max: 65000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Pistas de Baile"
  description="Renta de pistas de baile para eventos: LED RGB, madera clásica, vintage y tarimas en CDMX. Montaje profesional y nivelación en terreno irregular incluidos."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Pistas modulares con instalación en cualquier terreno"
    title='Renta de <span class="highlight">Pistas de Baile</span> para Eventos en CDMX'
    subtitle="Pistas LED iluminadas, madera clásica, vintage con espejos y tarimas modulares con montaje profesional y nivelación incluida. Convierte cualquier espacio — salón, jardín o terraza — en la pista de baile perfecta donde tus invitados no pararán de bailar."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una pista de baile para mi evento en CDMX` }}
    cards={[
      {
        title: "Paneles de grado profesional con superficie antiderrapante certificada",
        content: "<strong>Renta de pistas de baile para eventos</strong> fabricadas con los más altos estándares de seguridad y resistencia. Paneles modulares de policarbonato y madera laminada con capacidad de carga de hasta 750 kg/m², superficie antiderrapante certificada y clasificación IP54 contra derrames. Las pistas LED incorporan tecnología RGB de alta resolución con control DMX512 que permite personalizar colores, patrones, animaciones y sincronización con música en tiempo real. Cada módulo cuenta con conectores de enganche rápido que garantizan una superficie perfectamente uniforme sin juntas visibles.",
      },
      {
        title: "Montaje profesional con nivelación para cualquier tipo de terreno",
        content: "<strong>Servicio integral de pistas de baile</strong> con enfoque llave en mano para cualquier venue. Nuestro equipo realiza una visita técnica gratuita para evaluar el espacio, calcular la superficie óptima según tu número de invitados y diseñar la distribución ideal considerando la ubicación de <strong>DJ, tarima, mesas y flujo de circulación</strong>. Instalamos sobre niveladores de acero galvanizado que compensan desniveles de hasta 15 cm — perfecto para jardines, terrazas y predios. Complementa tu pista con <strong>iluminación perimetral, efectos especiales</strong> y sonido profesional para una experiencia completa.",
      },
    ]}
  />

  <CtaBar headline="¿Qué pista de baile necesitas?" items={[
    { label: "Pistas LED", href: "/servicios/pistas-baile/pistas-led/", icon: "pistas" },
    { label: "Madera Clásica", href: "/servicios/pistas-baile/madera-clasica/", icon: "pistas" },
    { label: "Vintage", href: "/servicios/pistas-baile/vintage-tematicas/", icon: "pistas" },
    { label: "Tarimas", href: "/servicios/pistas-baile/tarimas-escenarios/", icon: "pistas" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="La pista de baile es donde se crean los mejores recuerdos de tu evento"
    subheadline="Recibe una propuesta personalizada con el tamaño, tipo y efectos ideales para tu celebración — sin compromiso"
    primaryCTA={{ label: "Cotizar mi pista", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Pistas de Baile"
        subtitle="La superficie perfecta para cada tipo de evento y estilo de celebración"
        description={[
          "Desde una pista LED espectacular para una boda en un jardín de Coyoacán hasta una tarima elevada para un fashion show corporativo en Santa Fe — contamos con el inventario más completo de pistas de baile para eventos en la Ciudad de México y zona metropolitana.",
          "Cada instalación incluye montaje profesional con nivelación, superficie antiderrapante certificada y la opción de complementar con iluminación perimetral, efectos especiales y sonido profesional para crear la experiencia completa que tus invitados merecen."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <CategoryCard
            title={sub.name}
            subtitle={sub.excerpt}
            href={sub.href}
            image={sub.image}
            subcategories={sub.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTAS LED ILUMINADAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="led-heading">
    <div class="container">
      <ServiceShowcase
    title="Pistas de Baile LED Iluminadas"
    headingId="led-heading"
    badge="La más espectacular y solicitada"
    subtitle="Paneles LED RGB programables que transforman el piso en un lienzo de luz, color y animación. El centro de atención absoluto de cualquier celebración."
    tags={["RGB 144 LEDs/panel", "DMX512 / ArtNet", "IP54", "750 kg/m²", "Monograma Custom", "Sync Musical"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Pistas LED"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>pista de baile LED</strong> es el elemento que eleva cualquier evento de memorable a épico. Nuestros <strong>paneles LED RGB de alta resolución</strong> con 144 LEDs por módulo de 50x50 cm ofrecen brillo uniforme de 1,200 cd/m² visible incluso con iluminación ambiental. Cada panel se controla individualmente mediante protocolo <strong>DMX512 o ArtNet</strong>, permitiendo programar cambios de color, degradados, patrones geométricos, animaciones tipo estrella o fuego, y efectos sincronizados con la música en tiempo real mediante nuestro técnico operador.</p>
      <p class="showcase__text">Personaliza tu pista con el <strong>monograma de los novios, logo corporativo, countdown para la media noche</strong> o cualquier gráfico personalizado. La superficie de <strong>policarbonato de 12 mm con acabado antiderrapante</strong> soporta tacones, derrame de bebidas (IP54) y uso intensivo toda la noche. Disponibles desde <strong>3x3m hasta 8x8m</strong> con la posibilidad de combinar paneles LED con paneles de madera o acrílico para diseños mixtos únicos. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación profesional</a> — wash lights perimetrales y efectos aéreos — para multiplicar el impacto visual.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/pistas-baile/pista-led-rgb-fiesta.avif"
            alt="Pista de baile LED RGB iluminada para fiestas y bodas en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTAS DE MADERA CLÁSICA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="madera-heading">
    <div class="container">
      <ServiceShowcase
    title="Pistas de Baile de Madera Clásica"
    headingId="madera-heading"
    badge="Elegancia atemporal para bodas y galas"
    subtitle="Duela de madera laminada premium con acabado semi-mate y superficie antiderrapante. La opción más elegante y versátil para eventos formales y celebraciones de alto nivel."
    tags={["Duela 12mm", "Natural", "Nogal", "Wengué", "Blanco Polar", "Antiderrapante"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Madera Clásica"
  >
    <Fragment slot="body">
      <p class="showcase__text">La <strong>pista de madera clásica</strong> es la elección preferida de wedding planners y organizadores de galas en CDMX por su combinación de elegancia, calidez y funcionalidad. Nuestra <strong>duela de madera laminada de 12 mm</strong> con acabado semi-mate ofrece un look sofisticado que complementa cualquier estilo de decoración — desde bodas rústicas en haciendas hasta galas corporativas en salones de cinco estrellas. La superficie <strong>antiderrapante de grado comercial</strong> garantiza seguridad total con tacones, zapatos de vestir y calzado de todo tipo.</p>
      <p class="showcase__text">Cada módulo se une mediante <strong>sistema de enganche macho-hembra sin tornillos</strong> que crea una superficie perfectamente uniforme sin juntas visibles ni bordes elevados. Disponibles en acabados <strong>natural, nogal, wengué y blanco polar</strong> para combinar con la paleta de tu evento. Se instala sobre <strong>bastidores de acero galvanizado con niveladores ajustables</strong> que la elevan del terreno natural — ideal para jardines, terrazas con desnivel y predios con pasto. Combina con <a href="/servicios/mobiliario/">mobiliario elegante</a> y <a href="/servicios/iluminacion/">iluminación ambiental</a> para un montaje integral impecable.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/pistas-baile/pista-madera-natural-boda.avif"
            alt="Pista de baile de madera natural para bodas y eventos formales en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTAS VINTAGE Y TEMÁTICAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="vintage-heading">
    <div class="container">
      <ServiceShowcase
    title="Pistas de Baile Vintage y Temáticas"
    headingId="vintage-heading"
    badge="Personalidad única para tu evento"
    subtitle="Pistas estilo disco con espejos, damero blanco y negro, acrílico transparente iluminado y diseños personalizados que convierten la pista de baile en una pieza de decoración protagonista."
    tags={["Espejo Disco", "Damero B&N", "Acrílico Transparente", "Vinil Custom", "Retro / Glam", "Alto Brillo"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Vintage"
  >
    <Fragment slot="body">
      <p class="showcase__text">Las <strong>pistas vintage y temáticas</strong> son para los eventos que buscan un statement visual que sus invitados nunca hayan visto. Nuestra <strong>pista disco con paneles de espejo biselado</strong> refleja la iluminación ambiental y los moving heads creando un efecto caleidoscópico hipnótico — perfecta para fiestas retro, XV años y celebraciones de año nuevo. La <strong>pista damero (tablero de ajedrez) en blanco y negro de alto brillo</strong> es un clásico que nunca pasa de moda, ideal para bodas elegantes y eventos de moda.</p>
      <p class="showcase__text">Para producciones más vanguardistas, ofrecemos <strong>pistas de acrílico transparente iluminadas desde abajo</strong> con LED que crean el efecto de caminar sobre luz pura — espectacular para lanzamientos de producto, pasarelas de moda y eventos de lujo. También diseñamos <strong>pistas con gráficos impresos personalizados</strong>: vinil de alta resolución sobre panel rígido con laminado protector antiderrapante para logos, patrones florales, mapas o cualquier diseño que imagines. Combina con nuestros <a href="/servicios/iluminacion/">efectos especiales</a> — humo bajo y papelitos de mariposas — para una entrada a la pista verdaderamente cinematográfica.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/pistas-baile/pista-acrilica-transparente-boda.avif"
            alt="Pista de baile acrílica transparente para bodas y eventos temáticos en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TARIMAS Y ESCENARIOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tarimas-heading">
    <div class="container">
      <ServiceShowcase
    title="Renta de Tarimas y Escenarios para Eventos"
    headingId="tarimas-heading"
    badge="Escenarios modulares certificados"
    subtitle="Plataformas modulares de aluminio con superficie antiderrapante para escenarios, pasarelas, áreas VIP elevadas y pistas sobre terreno irregular. Capacidad certificada de hasta 500 kg/m²."
    tags={["Aluminio Serie 6000", "500 kg/m²", "20cm a 1.5m", "Multinivel", "Rampa Accesible", "Rigging Certificado"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Tarimas"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestras <strong>tarimas y escenarios modulares</strong> están fabricados con <strong>marco de aluminio serie 6000 y superficie de madera contrachapada de 18 mm</strong> con acabado antiderrapante negro mate o alfombrado en color. Módulos estándar de <strong>1x1m y 1x2m con alturas ajustables de 20 cm a 1.5 metros</strong> que se combinan para crear escenarios de cualquier dimensión — desde una tarima compacta para DJ o grupo musical hasta una pasarela completa para desfiles de moda o un escenario multinivel para conferencias.</p>
      <p class="showcase__text">Cada módulo cuenta con <strong>patas de aluminio telescópicas con sistema de nivelación individual</strong> y conectores de seguridad anti-volcadura. Las <strong>faldillas perimetrales</strong> en negro, blanco o color personalizado ocultan la estructura dando un acabado profesional. Para eventos al aire libre, instalamos sobre terrenos irregulares con desniveles de hasta 60 cm gracias al sistema telescópico. Incluimos escaleras de acceso con pasamanos, rampas para accesibilidad y <strong>puntos de anclaje certificados para rigging</strong> de <a href="/servicios/iluminacion/">iluminación</a> y <a href="/servicios/audiovisual/">equipo audiovisual</a>. Complementa con <a href="/servicios/carpas/">carpas profesionales</a> para eventos al aire libre con escenario protegido.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif"
            alt="Tarimas y escenarios modulares para eventos corporativos y conciertos en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo lucen nuestras pistas de baile?</h2>
      <Gallery4x4 images={[
        { src: "/images/pistas-baile/pista-led-rgb-fiesta.avif", alt: "Pista LED RGB para fiesta" },
        { src: "/images/pistas-baile/pista-madera-natural-boda.avif", alt: "Pista madera natural boda" },
        { src: "/images/pistas-baile/pista-acrilica-transparente-boda.avif", alt: "Pista acrílica transparente boda" },
        { src: "/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif", alt: "Pista madera negra eventos corporativos" },
        { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Silla Tiffany dorada para boda de gala en CDMX" },
        { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas montaje banquete" },
        { src: "/images/mobiliario/lounge-moderno-terciopelo-evento-premium.avif", alt: "Sala lounge moderno terciopelo evento premium" },
        { src: "/images/mobiliario/barra-bebidas-bartender-madera-evento.avif", alt: "Barra de bebidas bartender madera para evento" },
