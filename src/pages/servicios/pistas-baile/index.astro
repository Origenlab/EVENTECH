---
/**
 * ─── EVENTECH.MX — Pistas de Baile (L3, rediseño 2026) ───
 * Renta de pistas LED, madera clásica, vintage y tarimas para eventos en CDMX.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "pistas-led",
    name: "Pistas LED",
    badge: "Efecto visual máximo",
    excerpt: "Paneles LED RGB programables con efectos de color, patrones dinámicos y animaciones sincronizadas. La pista que convierte la zona de baile en el centro de atención absoluto del evento.",
    href: "/servicios/pistas-baile/pistas-led/",
    image: "/images/pistas-baile/pista-led-rgb-fiesta.avif",
    subcategories: [
      { name: "LED RGB Clásica", href: "/servicios/pistas-baile/pistas-led/rgb/" },
      { name: "LED Pixel Programable", href: "/servicios/pistas-baile/pistas-led/pixel/" },
      { name: "LED Infinita", href: "/servicios/pistas-baile/pistas-led/infinita/" },
      { name: "LED para Exterior", href: "/servicios/pistas-baile/pistas-led/exterior/" },
    ],
  },
  {
    id: "madera-clasica",
    name: "Madera Clásica",
    badge: "La más solicitada en bodas",
    excerpt: "Duela de madera laminada premium con acabado antiderrapante certificado. Elegante, atemporal y perfecta para bodas, galas y cualquier evento donde el suelo también es parte del diseño.",
    href: "/servicios/pistas-baile/madera-clasica/",
    image: "/images/pistas-baile/pista-madera-natural-boda.avif",
    subcategories: [
      { name: "Duela Laminada", href: "/servicios/pistas-baile/madera-clasica/duela-laminada/" },
      { name: "Parquet Modular", href: "/servicios/pistas-baile/madera-clasica/parquet-modular/" },
      { name: "Con Marco Decorativo", href: "/servicios/pistas-baile/madera-clasica/marco-decorativo/" },
      { name: "Para Terreno Irregular", href: "/servicios/pistas-baile/madera-clasica/terreno-irregular/" },
    ],
  },
  {
    id: "vintage-tematicas",
    name: "Vintage y Temáticas",
    badge: "Personalidad única",
    excerpt: "Acrílico transparente iluminado, damero blanco y negro, disco con espejo y vinil impreso a medida. Para eventos que no quieren una pista de baile — quieren una declaración de estilo.",
    href: "/servicios/pistas-baile/vintage-tematicas/",
    image: "/images/pistas-baile/pista-acrilica-transparente-boda.avif",
    subcategories: [
      { name: "Acrílico Transparente", href: "/servicios/pistas-baile/vintage-tematicas/acrilico/" },
      { name: "Damero Blanco y Negro", href: "/servicios/pistas-baile/vintage-tematicas/damero/" },
      { name: "Disco con Espejos", href: "/servicios/pistas-baile/vintage-tematicas/disco/" },
      { name: "Pista Personalizada", href: "/servicios/pistas-baile/vintage-tematicas/personalizada/" },
    ],
  },
  {
    id: "tarimas-escenarios",
    name: "Tarimas y Escenarios",
    badge: "Gran formato",
    excerpt: "Plataformas modulares de aluminio para escenarios, pasarelas, áreas elevadas y zonas DJ. La solución que nivela cualquier terreno y define las áreas de producción del evento.",
    href: "/servicios/pistas-baile/tarimas-escenarios/",
    image: "/images/pistas-baile/pista-madera-negra-eventos-corporativos.avif",
    subcategories: [
      { name: "Escenarios con Techo", href: "/servicios/pistas-baile/tarimas-escenarios/con-techo/" },
      { name: "Pasarelas", href: "/servicios/pistas-baile/tarimas-escenarios/pasarelas/" },
      { name: "Plataformas Niveladas", href: "/servicios/pistas-baile/tarimas-escenarios/plataformas-niveladas/" },
      { name: "Tarimas Modulares", href: "/servicios/pistas-baile/tarimas-escenarios/modulares/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "📐",
    title: "Dimensionado correcto desde el inicio",
    body: "Calculamos el tamaño de pista según el número de invitados, el layout del venue y el tipo de evento. Una pista demasiado pequeña mata la energía; una demasiado grande se ve vacía. La medida correcta se define antes de cotizar.",
  },
  {
    icon: "🔩",
    title: "Superficie certificada antiderrapante",
    body: "Todas nuestras pistas cumplen estándar de coeficiente de fricción para superficies de baile. Sin importar el acabado — madera, acrílico, LED o vinil — la seguridad de los invitados es no negociable.",
  },
  {
    icon: "⚡",
    title: "Sistema eléctrico integrado en pistas LED",
    body: "El cableado de las pistas LED va integrado en la estructura modular, sin cables expuestos. La conexión eléctrica se revisa y certifica antes de que pise el primer invitado.",
  },
  {
    icon: "🏗️",
    title: "Nivelación sobre cualquier terreno",
    body: "Nuestro sistema de soporte permite nivelar la pista sobre jardines con pendiente, terrenos irregulares y diferentes alturas. El resultado es una superficie perfectamente plana sin importar lo que haya debajo.",
  },
  {
    icon: "🎨",
    title: "Personalización total en acabados",
    body: "Desde el color del LED hasta el patrón del vinil impreso con el nombre de los novios o el logo corporativo. La pista puede ser parte del concepto visual del evento, no solo un accesorio funcional.",
  },
  {
    icon: "🛡️",
    title: "Montaje el día anterior, garantía el día del evento",
    body: "Instalamos la pista un día antes siempre que el venue lo permite. El día del evento la pista lleva horas verificada — no hay instalaciones de último minuto ni sorpresas durante la celebración.",
  },
];

const steps = [
  { n: 1, t: "Medición del espacio", p: "Calculamos el tamaño ideal de pista según invitados, distribución del venue y área disponible. Te presentamos opciones con renders antes de confirmar." },
  { n: 2, t: "Selección de acabado", p: "Elegimos el tipo de pista — madera, LED, acrílico, temática — que mejor se integra con el concepto visual y el presupuesto del evento." },
  { n: 3, t: "Instalación previa", p: "Montamos la pista el día anterior al evento para tener tiempo de nivelación, conexiones eléctricas (en LED) y verificación completa de seguridad." },
  { n: 4, t: "Retiro limpio y sin interrupciones", p: "Al finalizar el evento nuestro equipo desmonta y retira la pista. Sin impacto sobre el venue y sin que tengas que organizar nada." },
];

const faqs = [
  {
    question: "¿Qué tamaño de pista necesito para mi evento?",
    answer: "La regla general es que aproximadamente un tercio de los invitados estará bailando al mismo tiempo. Para 100 personas recomendamos entre 4×4 m y 4×5 m; para 200 personas, 5×6 m o 6×6 m; para 300 o más, 6×8 m o más. El layout del venue también influye — una pista rectangular funciona diferente a una cuadrada según la posición del escenario y las mesas. Calculamos la medida exacta durante la consulta.",
  },
  {
    question: "¿Las pistas LED necesitan instalación eléctrica especial?",
    answer: "Las pistas LED de tamaño estándar (hasta 5×5 m) funcionan con una toma de 110V/20A estándar. Para pistas más grandes o con controlador de efectos avanzado podemos requerir una toma de 220V. El cableado va integrado en la estructura — sin cables expuestos — y la conexión eléctrica se verifica y certifica antes del evento. Si el venue no tiene la toma adecuada, llevamos tablero de distribución.",
  },
  {
    question: "¿Se puede instalar la pista sobre jardín o pasto?",
    answer: "Sí. Nuestro sistema de soporte modular permite instalar sobre pasto, tierra compactada, losas irregulares y superficies con pendiente moderada. Para jardines con pendiente importante utilizamos soportes ajustables que nivelan la superficie. La pista no daña el pasto de forma permanente — retiramos sin dejar huella visible.",
  },
  {
    question: "¿Qué diferencia hay entre la pista de madera y la acrílica?",
    answer: "La pista de madera tiene un acabado cálido y atemporal, ideal para bodas elegantes y eventos formales. El acrílico transparente iluminado desde abajo crea un efecto flotante muy impactante visualmente — perfecto cuando se combina con iluminación de colores. La elección depende del concepto del evento: si la pista es un elemento elegante que acompaña, la madera; si es el elemento protagonista y de impacto visual, el acrílico o LED.",
  },
  {
    question: "¿Se puede personalizar la pista con el nombre o logo del evento?",
    answer: "Sí. Ofrecemos viniles de alta adherencia impresos a medida que se instalan sobre la pista de madera o acrílico — nombre de los novios, fecha, logo corporativo, patrón personalizado. El vinil no daña la superficie de la pista y se retira sin residuos. Para pistas LED, el controlador puede programarse con colores específicos de la paleta del evento.",
  },
  {
    question: "¿Con cuánta anticipación debo reservar la pista?",
    answer: "Recomendamos 3–4 semanas de anticipación para garantizar disponibilidad del modelo y tamaño que necesitas. En temporada alta (noviembre–febrero) lo ideal es reservar con 6–8 semanas. La instalación se programa el día anterior al evento o la mañana del mismo día según el acceso al venue.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Pistas de Baile para Eventos en CDMX",
    description: "Renta de pistas de baile LED, madera clásica, acrílico y temáticas para bodas, XV años y eventos corporativos en CDMX. Instalación profesional y personalización incluidas.",
    url: "/servicios/pistas-baile/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Pistas de Baile", url: "/servicios/pistas-baile/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Pistas de Baile" },
];
---

<PageLayout
  title="Renta de Pistas de Baile para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/pistas-baile/pista-led-rgb-fiesta.avif"
  description="Renta de pistas de baile LED, madera y acrílico para eventos en CDMX. Desde 3×3 m con instalación profesional y nivelación incluida. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="pistas-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Renta de pistas de baile · CDMX y ZMVM</p>
            <h1 id="pistas-hero-heading">
              La pista de baile que convierte un evento bueno en uno que <em>nadie quiere dejar</em>
            </h1>
            <p class="hm-hero__lead">
              LED programable, madera premium, acrílico transparente o personalizada
              con vinil a medida. Instalación profesional con nivelación incluida,
              conexión eléctrica certificada y montaje el día previo al evento.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver tipos de pista
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 400 pistas de baile instaladas</strong> en Ciudad de México
              y zona metropolitana, EVENTECH es referencia en renta de pistas para bodas,
              XV años y eventos corporativos. Manejamos cuatro familias de producto — LED,
              madera clásica, vintage y tarimas — con inventario de pistas desde
              3×3 m hasta 8×12 m y personalización completa de acabados.
            </p>
            <p>
              Cada instalación incluye <strong>nivelación profesional</strong> sobre cualquier
              tipo de terreno, certificación eléctrica en pistas LED, cableado oculto integrado
              en la estructura y montaje verificado el día previo. El resultado es siempre
              el mismo: una pista de baile que se ve parte del evento, no aparte de él.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Tipos de pista de baile">
      <ul class="hm-menu__grid hm-menu__grid--5">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20una%20pista%20de%20baile%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cuatro tipos para cuatro estilos de evento</p>
            <h2 id="catalogo-heading">¿Qué tipo de pista de baile necesitas?</h2>
            <p class="hm__head-sub">LED, madera clásica, temática o tarima — cada una responde a un concepto distinto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La pista de baile es el elemento que más horas de atención concentra
              en cualquier evento: es donde sucede el primer baile, el vals de
              quinceañera, la fiesta y los momentos más espontáneamente emotivos
              de la celebración. Elegir bien su tipo, tamaño y acabado no es un
              detalle menor — es parte del diseño del evento.
            </p>
            <p>
              No todas las pistas sirven para todos los eventos. Una pista LED en
              una boda clásica puede disonar; una pista de madera en una fiesta
              temática pierde una oportunidad. La elección correcta empieza con
              entender el concepto del evento, no el catálogo del proveedor.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`Renta de pista ${s.name.toLowerCase()} para eventos en CDMX`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada tipo, a fondo</p>
            <h2 id="detalle-heading">Pistas de baile en detalle</h2>
            <p class="hm__head-sub">Qué instalamos, cómo funciona cada acabado y para qué evento es la elección natural.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Una pista de baile es una estructura técnica con requerimientos de seguridad,
              nivelación y acabados específicos. Pero antes que eso, es un elemento visual
              que define la zona más importante de la celebración. Entender qué hace
              cada tipo te permite tomar la decisión correcta desde el primer paso.
            </p>
          </div>
        </div>

        <!-- Pistas LED -->
        <article class="hm-feat" aria-labelledby="feat-led">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pistas LED Iluminadas</p>
            <h3 class="hm-feat__title" id="feat-led">Pista LED RGB — el elemento que convierte la zona de baile en el espectáculo del evento</h3>
            <p class="hm-feat__lead">Cuando la pista tiene luz propia, el área de baile deja de ser un espacio funcional y se convierte en una experiencia visual que ningún invitado puede ignorar.</p>
            <p>
              Nuestras <strong>pistas LED RGB modulares</strong> se construyen con paneles
              de 60×60 cm de policarbonato de alta resistencia sobre estructura de aluminio
              con LEDs de alta densidad integrados. El <strong>controlador DMX512</strong>
              permite programar colores estáticos, transiciones suaves, patrones de
              onda, flashes sincronizados con la música y secuencias personalizadas
              diseñadas para cada momento del evento — diferente durante la cena,
              el brindis y la fiesta.
            </p>
            <p>
              La versión <strong>LED Pixel</strong> escala la experiencia con control
              individual por panel: crea animaciones en movimiento, texto desplazable
              con el nombre de los novios y efectos de oleaje o explosión que recorren
              toda la superficie de la pista. Disponible también en versión
              <strong>IP65 para exterior</strong>, resistente a humedad de jardín y
              eventos bajo <a href="/servicios/carpas/">carpa</a>. Todo el cableado
              va integrado en la estructura modular — sin cables visibles, sin tropiezos,
              sin interrupciones durante el evento.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "LED RGB Clásica", href: "/servicios/pistas-baile/pistas-led/rgb/" },
                { name: "LED Pixel", href: "/servicios/pistas-baile/pistas-led/pixel/" },
                { name: "LED Infinita", href: "/servicios/pistas-baile/pistas-led/infinita/" },
                { name: "LED Exterior", href: "/servicios/pistas-baile/pistas-led/exterior/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/pistas-baile/pistas-led/">
              Ver pistas LED
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/pistas-baile/pista-led-rgb-fiesta.avif" alt="Pista LED RGB programable en fiesta de noche con iluminación de colores" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/pistas-baile/pista-baile-01.avif" alt="Pista LED con panel de control DMX para evento corporativo CDMX" loading="lazy" decoding="async" />
              <img src="/images/pistas-baile/pista-baile-02.avif" alt="Detalle de panel LED RGB integrado en pista de baile modular" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- Madera Clásica -->
        <article class="hm-feat" aria-labelledby="feat-madera">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Pistas de Madera Clásica</p>
            <h3 class="hm-feat__title" id="feat-madera">Duela de madera premium — la elegancia que nunca pasa de moda y que luce perfecta en cualquier fotografía</h3>
            <p class="hm-feat__lead">La pista de madera no compite con nada. Complementa todo — la decoración floral, el mobiliario, la iluminación y la arquitectura del venue.</p>
            <p>
              Nuestras pistas de madera se construyen con <strong>duela laminada de alta
              densidad</strong> en acabados natural, nogal oscuro, wengué y blanco lacado.
              El sistema modular de encaje a presión garantiza una superficie
              <strong>perfectamente plana y sin juntas visibles</strong> desde arriba.
              El tratamiento antiderrapante certificado en todas las superficies cumple
              estándar de coeficiente de fricción dinámico mayor a 0.5 — la seguridad
              de los invitados no se negocia con ningún acabado, incluido el más pulido.
            </p>
            <p>
              La pista de <strong>madera blanca lacada</strong> es la variante más solicitada
              para bodas con paleta clara o contemporánea — absorbe la luz del venue
              de manera uniforme y crea un efecto luminoso suave que complementa
              <a href="/servicios/iluminacion/">cualquier concepto de iluminación</a>.
              La madera <strong>natural y nogal</strong> son la elección estándar para
