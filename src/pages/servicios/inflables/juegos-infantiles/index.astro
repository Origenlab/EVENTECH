              <label class="hm-form__field">
                <span>Fecha del evento</span>
                <input type="date" name="fecha" />
              </label>

              <label class="hm-form__field">
                <span>¿Qué inflable te interesa?</span>
                <select name="modelo">
                  <option value="">No estoy seguro, asesórenme</option>
                  <option>Mini Castillo</option>
                  <option>Dragones Rojos</option>
                  <option>Castillo de Princesas</option>
                  <option>Mini Jungla</option>
                  <option>Gusanitos</option>
                  <option>Barco Pirata</option>
                  <option>Extremo</option>
                  <option>Castillo Blanco</option>
                </select>
