---
/**
 * ─── Juegos Inflables Infantiles para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Juegos Inflables Infantiles para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Juegos Infantiles" },
];

const INFLABLES = [
  {
    name: "Brincolines y Castillos",
    excerpt: "Brincolines y castillos inflables de 3x3 a 6x6 metros con redes de seguridad y materiales certificados. Diversión garantizada para niños de 3 a 12 años en fiestas y eventos familiares.",
    cta: "Brincolines",
    href: "#brincolines-heading",
    icon: "balloon",
  },
  {
    name: "Toboganes Inflables",
    excerpt: "Toboganes inflables secos de 4 a 8 metros de altura con aterrizaje acolchado y monitores de seguridad incluidos. Adrenalina segura para niños y adolescentes en cualquier evento.",
    cta: "Toboganes",
    href: "#toboganes-heading",
    icon: "award",
  },
  {
    name: "Circuitos de Obstáculos",
    excerpt: "Circuitos inflables con túneles, escalada y deslizamiento para carreras cronometradas. Perfectos para fiestas infantiles, eventos escolares y competencias divertidas.",
    cta: "Circuitos",
    href: "#circuitos-heading",
    icon: "layers",
  },
  {
    name: "Inflables Temáticos",
    excerpt: "Castillos de princesas, fortalezas de superhéroes, dinosaurios, unicornios y temas personalizados. El inflable perfecto para la fiesta temática que tu hijo sueña.",
    cta: "Temáticos",
    href: "#tematicos-heading",
    icon: "heart",
  },
];

const faqs = [
  { question: "¿Para qué edades son adecuados los juegos inflables infantiles?", answer: "Nuestros inflables están diseñados para diferentes rangos de edad. Los brincolines pequeños (3x3 m) son ideales para niños de 3 a 6 años, mientras que los castillos medianos (4x4 m) funcionan perfectamente para niños de 4 a 10 años. Los toboganes y circuitos de obstáculos están recomendados para niños de 6 a 12 años. Siempre clasificamos cada inflable por edad y peso máximo para garantizar la seguridad de todos los pequeños." },
  { question: "¿Incluyen supervisión y monitores de seguridad?", answer: "Sí. Todos nuestros paquetes de inflables infantiles incluyen al menos un monitor de seguridad capacitado por cada inflable. El monitor se encarga de controlar el acceso, verificar que los niños se quiten zapatos y objetos punzantes, supervisar el uso correcto y aplicar las reglas de seguridad durante todo el evento. Para inflables grandes como toboganes y circuitos de obstáculos, asignamos dos monitores para mayor control." },
  { question: "¿Cuánto espacio necesito para instalar un inflable?", answer: "El espacio requerido varía según el tamaño del inflable. Un brincolín de 3x3 m necesita un área libre de al menos 4x4 metros (1 metro extra por lado). Un castillo de 5x5 m requiere 6.5x6.5 metros. Los toboganes de 6-8 metros de altura necesitan entre 10 y 14 metros de largo con zona de aterrizaje despejada. Además, se requiere acceso a una toma de corriente de 110V a no más de 20 metros. Realizamos una evaluación previa del espacio sin costo." },
  { question: "¿Qué pasa si llueve el día del evento?", answer: "En caso de lluvia ligera, los inflables pueden seguir operando sin problema ya que están fabricados con lona vinílica impermeable. Sin embargo, por seguridad, si hay lluvia fuerte, tormenta eléctrica o vientos superiores a 40 km/h, detenemos la operación del inflable. Te ofrecemos reprogramación sin costo adicional con al menos 24 horas de aviso, o podemos instalar bajo techo si tu venue cuenta con espacio techado con altura suficiente (mínimo 5 metros)." },
  { question: "¿Cuánto tiempo toma la instalación y el desmontaje?", answer: "La instalación de un brincolín o castillo estándar (3x3 a 5x5 m) toma entre 20 y 40 minutos. Los toboganes grandes (6-8 m de altura) requieren de 45 a 90 minutos para el inflado y anclaje completo. Los circuitos de obstáculos se instalan en aproximadamente 60 minutos. Llegamos con 1 a 2 horas de anticipación al inicio de tu evento para tener todo listo. El desmontaje es más rápido, aproximadamente la mitad del tiempo de instalación." },
  { question: "¿Con cuánta anticipación debo reservar los inflables?", answer: "Recomendamos reservar con 1 a 3 semanas de anticipación, especialmente en temporada alta (abril a junio por Día del Niño, y noviembre a diciembre por fiestas navideñas). Los inflables temáticos (princesas, superhéroes, dinosaurios) y los toboganes grandes son los más solicitados y se agotan primero. Para eventos escolares y fiestas de fin de año, lo ideal es apartar con 1 mes de anticipación. También atendemos solicitudes de último momento sujetas a disponibilidad." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Juegos Inflables Infantiles para Eventos en CDMX",
    description: "Brincolines, toboganes, circuitos de obstáculos e inflables temáticos para fiestas infantiles y eventos familiares. Monitores de seguridad incluidos.",
    url: "/servicios/inflables/juegos-infantiles/",
    priceRange: { min: 800, max: 8000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Juegos Infantiles", url: "/servicios/inflables/juegos-infantiles/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Juegos Inflables Infantiles para Eventos en CDMX"
  description="Renta de brincolines, toboganes, circuitos de obstáculos e inflables temáticos para fiestas infantiles en CDMX. Monitores de seguridad incluidos. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diversión segura para los más pequeños"
    title='Renta de <span class="highlight">Juegos Inflables Infantiles</span> para Eventos en CDMX'
    subtitle="Brincolines, toboganes, circuitos de obstáculos e inflables temáticos para fiestas infantiles y eventos familiares. Materiales certificados, monitores de seguridad incluidos y la mejor diversión garantizada."
    primaryCTA={{ label: "Cotiza tu inflable", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar juegos inflables infantiles para mi evento` }}
    cards={[
      {
        title: "Inflables infantiles certificados para cada celebración",
        content: "<strong>Renta de juegos inflables infantiles para eventos</strong> con los más altos estándares de seguridad en CDMX. Brincolines y castillos inflables desde 3x3 hasta 6x6 metros con redes de seguridad perimetral, costuras reforzadas y materiales certificados libres de plomo. Toboganes secos de 4 a 8 metros de altura con aterrizaje acolchado para fiestas infantiles, eventos escolares y celebraciones familiares. Circuitos de obstáculos inflables con túneles, escalada y deslizamiento para competencias cronometradas — cada inflable inspeccionado y sanitizado antes de cada entrega.",
      },
      {
        title: "Monitores de seguridad y servicio completo incluido",
        content: "<strong>Servicio profesional completo</strong> incluido en cada renta de inflables infantiles. Nuestro equipo se encarga del transporte, instalación con anclaje certificado, inflado con turbinas profesionales y supervisión continua durante todo el evento. Monitor de seguridad capacitado incluido por cada inflable para controlar acceso, verificar edades y garantizar el uso correcto. Inflables temáticos de princesas, superhéroes, dinosaurios y unicornios para hacer realidad la fiesta que tu hijo sueña.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la diversión perfecta para tu fiesta infantil?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con el inflable ideal para la edad y espacio de tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de inflables infantiles
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Inflables Infantiles"
        subtitle="Diversión segura y garantizada para cada tipo de fiesta"
        description={[
          "Desde brincolines clásicos para fiestas íntimas hasta toboganes gigantes y circuitos de obstáculos para eventos escolares y festivales familiares. Contamos con el inventario de inflables infantiles más completo de la Ciudad de México.",
          "Cada inflable incluye instalación profesional con anclaje certificado, turbinas de inflado, monitor de seguridad capacitado y sanitización previa. Materiales certificados y seguros para niños de todas las edades."
        ]}
      />

      <div class="grid grid--4">
        {INFLABLES.map((inflable) => (
          <Card
            name={inflable.name}
            excerpt={inflable.excerpt}
            cta={inflable.cta}
            href={inflable.href}
            icon={inflable.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BRINCOLINES Y CASTILLOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="brincolines-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Los favoritos de los niños</span>
          <h2 class="showcase__title" id="brincolines-heading">Brincolines y Castillos</h2>
          <p class="showcase__subtitle">La atracción clásica e imprescindible para fiestas infantiles con diversión garantizada para todas las edades.</p>
          <p class="showcase__text">Nuestros <strong>brincolines y castillos inflables</strong> están disponibles en múltiples tamaños: <strong>3x3, 4x4, 5x5 y 6x6 metros</strong> para adaptarse a cualquier espacio y número de niños. Diseñados para niños de <strong>3 a 12 años</strong> con capacidad simultánea de 6 a 20 niños según el tamaño. Cada inflable cuenta con <strong>redes de seguridad perimetral</strong> en todas las aberturas, costuras dobles reforzadas y materiales de lona vinílica certificada libre de plomo y ftalatos.</p>
          <p class="showcase__text">Incluyen <strong>turbina de inflado continuo, tapete de seguridad en la entrada y monitor capacitado</strong> durante todo el evento. Los castillos más grandes incluyen torres decorativas, arcos y zonas de escalada interior para mayor entretenimiento. Son perfectos para <strong>fiestas de cumpleaños, bautizos, primeras comuniones y eventos familiares</strong>. Combínalos con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para proteger del sol y crear una zona infantil techada.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">3x3 metros</span>
            <span class="showcase__tag">4x4 metros</span>
            <span class="showcase__tag">5x5 metros</span>
            <span class="showcase__tag">6x6 metros</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Brincolines
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 20h16"/>
              <path d="M4 20V10a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v10"/>
              <path d="M8 8V6a4 4 0 0 1 8 0v2"/>
              <path d="M9 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
              <path d="M15 14a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TOBOGANES INFLABLES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="toboganes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Adrenalina segura</span>
          <h2 class="showcase__title" id="toboganes-heading">Toboganes Inflables</h2>
          <p class="showcase__subtitle">Toboganes secos de gran altura con aterrizaje acolchado y monitores de seguridad para máxima diversión sin riesgos.</p>
          <p class="showcase__text">Nuestros <strong>toboganes inflables secos</strong> están disponibles en alturas de <strong>4, 5, 6 y 8 metros</strong>, ofreciendo una experiencia de adrenalina controlada para niños y adolescentes. Cada tobogán cuenta con <strong>pista de deslizamiento de alta velocidad con superficie pulida</strong>, escaleras antiderrapantes con pasamanos laterales y <strong>zona de aterrizaje acolchado extra grueso</strong> para amortizar cada llegada. Los laterales están completamente cerrados con paredes inflables de seguridad de 1.2 metros de altura.</p>
          <p class="showcase__text">Incluyen <strong>dos monitores de seguridad</strong>: uno en la cima para controlar el acceso y distanciar los descensos, y otro en la base para asistir el aterrizaje. Los toboganes secos son ideales para <strong>fiestas al aire libre, eventos escolares, kermeses y festivales familiares</strong> donde se necesita una atracción de alto impacto sin agua. Complementa con nuestros <a href="/servicios/accesorios/">accesorios para eventos</a> como carpas de sombra y estaciones de hidratación.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">4 metros</span>
            <span class="showcase__tag">6 metros</span>
            <span class="showcase__tag">8 metros</span>
            <span class="showcase__tag">Aterrizaje acolchado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Toboganes
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 17 8 12 13 17 18 7 21 10"/>
              <line x1="21" y1="10" x2="21" y2="17"/>
              <line x1="3" y1="17" x2="21" y2="17"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CIRCUITOS DE OBSTÁCULOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="circuitos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Competencia y diversión</span>
          <h2 class="showcase__title" id="circuitos-heading">Circuitos de Obstáculos</h2>
          <p class="showcase__subtitle">Circuitos inflables con túneles, escalada y deslizamiento para carreras cronometradas y competencias épicas.</p>
          <p class="showcase__text">Nuestros <strong>circuitos de obstáculos inflables</strong> combinan <strong>túneles de gateo, paredes de escalada, columnas esquivables, rampas y toboganes de salida</strong> en recorridos de 10 a 20 metros de largo. Diseñados para carreras cronometradas donde los niños compiten por el mejor tiempo, generando emoción y espíritu deportivo. Disponibles en configuraciones <strong>individuales (un carril) y dobles (dos carriles paralelos)</strong> para competencias cara a cara.</p>
          <p class="showcase__text">Incluyen <strong>cronómetro digital, arco de salida inflable y monitores de seguridad</strong> en puntos estratégicos del recorrido. Son la atracción estrella de <strong>fiestas de cumpleaños, eventos escolares, kermeses, días del niño y festivales deportivos</strong>. Los circuitos dobles permiten torneos eliminatorios que mantienen entretenidos a grupos grandes durante horas. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para musicalizar las competencias y amplificar la emoción.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Túneles</span>
            <span class="showcase__tag">Escalada</span>
            <span class="showcase__tag">Deslizamiento</span>
            <span class="showcase__tag">Carreras cronometradas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Circuitos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1"/>
              <rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/>
              <rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       INFLABLES TEMÁTICOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="tematicos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">El tema que tu hijo ama</span>
          <h2 class="showcase__title" id="tematicos-heading">Inflables Temáticos</h2>
          <p class="showcase__subtitle">Castillos de princesas, fortalezas de superhéroes, dinosaurios y unicornios para fiestas temáticas inolvidables.</p>
          <p class="showcase__text">Nuestros <strong>inflables temáticos</strong> transforman cualquier fiesta en una aventura mágica. Disponemos de <strong>castillos de princesas</strong> con torres y decoraciones en rosa y morado, <strong>fortalezas de superhéroes</strong> con diseños de cómics y colores vibrantes, <strong>mundos de dinosaurios</strong> con figuras jurásicas realistas y <strong>reinos de unicornios</strong> con arcoíris y estrellas. Cada temática incluye detalles impresos de alta resolución en paneles laterales, arcos de entrada decorados y banderas decorativas.</p>
          <p class="showcase__text">También ofrecemos <strong>temas personalizados bajo pedido</strong> para eventos especiales: personajes de películas populares, temáticas deportivas, mundo marino y selva tropical. Los inflables temáticos están disponibles en tamaños de <strong>4x4 a 6x6 metros</strong> y son la pieza central perfecta para <strong>fiestas de cumpleaños, baby showers infantiles y celebraciones del Día del Niño</strong>. Complementa la experiencia con nuestra <a href="/servicios/iluminacion/">iluminación decorativa</a> para crear una atmósfera mágica al atardecer.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Princesas</span>
            <span class="showcase__tag">Superhéroes</span>
            <span class="showcase__tag">Dinosaurios</span>
            <span class="showcase__tag">Unicornios</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Inflable Temático
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Inflables Infantiles"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu inflable infantil, es natural tener preguntas sobre seguridad, edades, espacio y logística. Aquí encontrarás las respuestas a las consultas más comunes de padres y organizadores de eventos.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre inflables infantiles al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de inflables infantiles para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
