---
/**
 * ─── EVENTECH.MX — Juegos Inflables Infantiles (L4, rediseño 2026) ───
 * Hub homologado al sistema hm- (home-2026.css), igual que /servicios/mobiliario/sillas/.
 * Catálogo REAL de 8 inflables (homologado con el proveedor) con imágenes
 * propias, desde src/data/inflables-juegos.ts.
 * Cada tarjeta enlaza a su ficha L5 (ruta dinámica [slug]/index.astro).
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import { INFLABLES, byCat, CAT_LABEL, cardImg, mainImg, photoImg, PRICE_RANGE, type Cat } from "@data/inflables-juegos";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const BASE = "/servicios/inflables/juegos-infantiles";

// Catálogo ordenado por categoría para el grid (chico → mediano → grande)
const catOrder: Record<Cat, number> = { chico: 0, mediano: 1, grande: 2 };
const catalogo = [...INFLABLES].sort((a, b) => catOrder[a.cat] - catOrder[b.cat]);

// ── Grupos por tamaño (módulos detalle hm-feat) — modelos derivados de los datos ──
const GRUPOS: { id: string; cat: Cat; eyebrow: string; title: string; lead: string; body1: string; body2: string }[] = [
  {
    id: "chicos", cat: "chico", eyebrow: "Inflable chico", title: "Para los más pequeños — primeros cumpleaños sin riesgos",
    lead: "Cuando los invitados son bebés y niños de 1 a 3 años, el tamaño y las paredes blandas importan más que la altura o la velocidad.",
    body1: "El <strong>Mini Castillo</strong> es el único inflable del catálogo <strong>apto para interiores</strong>: mide 2 × 2 × 2.5 m y cabe en una sala, terraza o salón pequeño. Paredes acolchonadas, sin bordes rígidos y altura reducida para que la supervisión sea total en primeros cumpleaños en departamento y bautizos.",
    body2: "Llega listo, se instala con anclaje seguro en 15 a 20 minutos y al final lo recogemos. Cada inflable se lava, desinfecta y revisa antes de cada renta. Desde $800 con entrega, instalación y recolección incluidas.",
  },
  {
    id: "medianos", cat: "mediano", eyebrow: "Inflables medianos", title: "El corazón del catálogo — castillos temáticos para fiestas de 3 a 12 años",
    lead: "Cuatro modelos con capacidad para 5 a 7 niños, mallas de seguridad y temáticas que definen la fiesta: dragones, princesas, safari y túneles de colores.",
    body1: "Los <strong>Dragones Rojos</strong> son el modelo más rentado, con dos toboganes integrados. El <strong>Castillo de Princesas</strong> es el favorito de las niñas e incluye resbaladilla. La <strong>Mini Jungla</strong> es un circuito con temática de exploradores y los <strong>Gusanitos</strong> son los más coloridos, con túneles para entrar y salir.",
    body2: "La mayoría necesita un espacio libre de 5 × 5 m, contacto eléctrico cercano y se instala en 20 a 35 minutos. Cada uno con su personalidad para combinar con la decoración del evento. Desde $1,200.",
  },
  {
    id: "grandes", cat: "grande", eyebrow: "Inflables grandes", title: "Atracciones de gran formato — para kermeses, corporativos y eventos formales",
    lead: "Cuando el evento es grande o necesita una pieza central, estos tres modelos cambian la escala: galeón con tobogán, circuito de obstáculos para carreras y castillo formal de gran formato.",
    body1: "El <strong>Barco Pirata</strong> de 7 m con tobogán es la atracción de mayor impacto. El <strong>Extremo</strong> es un circuito de obstáculos para competencias por equipos. Y el <strong>Castillo Blanco</strong>, totalmente blanco y sin personajes, es el más espacioso y elegante para bodas y XV años.",
    body2: "Requieren más espacio y entrega con camión grande, con instalación con anclaje reforzado. Coordinamos el montaje con el resto del equipo del evento. Desde $1,700.",
  },
];

// ── Por qué EVENTECH ─────────────────────────────────────────────────────────
const whyFeatures = [
  { title: "Inflables lavados y desinfectados antes de cada renta", body: "Cada inflable se lava, desinfecta y revisa —costuras, soplador, anclajes y conexiones— antes de salir a tu evento. Sin productos de olor fuerte ni residuos sobre la lona, porque los niños van a estar ahí horas." },
  { title: "Instalación profesional con anclaje seguro", body: "Llegamos 1 a 2 horas antes del evento e instalamos con anclaje acorde al piso (tierra, pasto, cemento o azotea) y los puntos de seguridad correctos. Personal con experiencia, no eventual." },
  { title: "Mallas de seguridad y supervisión", body: "Los modelos medianos y grandes llevan mallas laterales para visibilidad total de los papás. En los circuitos y toboganes grandes asignamos monitor para controlar accesos y turnos." },
  { title: "Servicio integral incluido en el precio", body: "Entrega, instalación, soplador con extensión y recolección al terminar —todo incluido—. No cobramos extra por escaleras, distancia dentro de la zona habitual ni por la hora del evento." },
  { title: "Un solo proveedor para todo el evento", body: "El mismo equipo que lleva el inflable puede llevar mobiliario, carpa, audio e iluminación. Coordinamos el montaje completo desde una sola empresa, sin duplicar logística ni proveedores." },
  { title: "Asesoría según espacio y edad", body: "Si no sabes cuál cabe en tu espacio o va con la edad de los invitados, te orientamos por WhatsApp con base en metros cuadrados y número de niños. Cientos de eventos como referencia." },
];

const steps = [
  { n: 1, t: "Nos cuentas de la fiesta", p: "Mándanos por WhatsApp la fecha, la zona y a quién es la fiesta. Con eso te decimos cuál inflable cabe en tu espacio y cuánto cuesta. Solemos contestar en menos de una hora." },
  { n: 2, t: "Apartas con anticipo", p: "Si la fecha está libre, dejas un anticipo y queda apartada a tu nombre. Te confirmamos por escrito hora de llegada, dirección y forma de pago del resto." },
  { n: 3, t: "Llegamos e instalamos", p: "El día de la fiesta llegamos a la hora acordada, montamos, anclamos y revisamos que todo esté seguro antes de irnos. Te dejamos un teléfono directo por si algo se ofrece." },
  { n: 4, t: "Recogemos al final", p: "Cuando termina la fiesta volvemos, lo desinflamos, doblamos y nos lo llevamos. Tú no mueves nada. La sanitización del siguiente uso queda de nuestro lado." },
];

const faqs = [
  { question: "¿Cuánto cuesta rentar un inflable para fiesta infantil?", answer: "Los inflables chicos comienzan desde $800 (Mini Castillo), los medianos desde $1,200 (Dragones Rojos y Castillo de Princesas) y los grandes desde $1,700 (Castillo Blanco). El precio es por un evento de 4 a 6 horas e incluye entrega, instalación y recolección en CDMX. Te confirmamos el total exacto por WhatsApp según la zona y la duración; en Estado de México puede aplicar un costo de traslado que informamos antes de apartar." },
  { question: "¿Para qué edades es cada inflable?", answer: "El Mini Castillo está pensado para niños de 1 a 3 años. Entre los medianos, los Dragones Rojos son para 4 a 12 años, el Castillo de Princesas y la Mini Jungla para 3 a 10, y los Gusanitos desde los 3. El Barco Pirata funciona desde los 4 años, el Extremo para 6 en adelante (incluidos adolescentes y adultos) y el Castillo Blanco es apto para todas las edades. Cada ficha indica edad y capacidad recomendadas." },
  { question: "¿Cuánto espacio necesito para instalar un inflable?", answer: "Depende del modelo. El Mini Castillo necesita un espacio libre de 3 × 3 m y es apto para interiores. Los medianos requieren de 5 × 5 a 6 × 5 m. El circuito Extremo necesita 8 × 5 m, y el Barco Pirata y el Castillo Blanco de 7 × 6 a 8 × 6 m con 5 m de altura libre. También se requiere un contacto eléctrico de 110V a no más de 15 metros del área. Si no estás seguro, mándanos las medidas por WhatsApp y te recomendamos el inflable ideal." },
  { question: "¿Qué incluye la renta?", answer: "Cada renta incluye entrega a domicilio (gratis en CDMX), instalación profesional con anclaje, sanitización del inflable, soplador silencioso con extensión eléctrica, recolección al terminar y seguro de responsabilidad civil. Sin costos ocultos por escaleras, distancia dentro de la zona habitual ni horario. Lo único que necesitas es un espacio suficiente y un contacto eléctrico cercano." },
  { question: "¿Los inflables están limpios y son seguros?", answer: "Sí. Cada inflable se lava, desinfecta y revisa antes y después de cada evento. Usamos productos seguros, sin olor fuerte, aptos para niños. Todos cuentan con múltiples puntos de anclaje y son instalados por personal capacitado; los modelos medianos y grandes llevan mallas de seguridad." },
  { question: "¿Necesito electricidad en el lugar?", answer: "Sí, necesitamos un contacto eléctrico estándar (110V) a no más de 15 metros del área de instalación. El soplador que mantiene inflado el juego consume aproximadamente lo mismo que una lavadora. Si es en jardín o azotea, cuéntanos y buscamos la solución." },
  { question: "¿En qué zonas entregan?", answer: "Cubrimos las 16 alcaldías de la Ciudad de México con entrega gratuita, y la zona poniente del Estado de México (Satélite, Interlomas, Naucalpan, Huixquilucan, Atizapán, Tlalnepantla y alrededores) con un costo de traslado que te confirmamos antes de apartar." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con al menos 5 a 7 días de anticipación, especialmente en fines de semana y temporada alta (mayo, con el Día del Niño, y diciembre). Los modelos temáticos y los grandes son los más solicitados y se agotan primero. Para última hora, contáctanos: en ocasiones tenemos disponibilidad." },
  { question: "¿Qué pasa si llueve el día de mi fiesta?", answer: "Si llueve fuerte, puedes reagendar sin costo adicional sujeto a disponibilidad, o usar el inflable bajo techo si cuentas con un espacio con altura suficiente. Avísanos con al menos 2 horas de anticipación." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Juegos Inflables Infantiles CDMX",
    description: "Renta de inflables para fiestas infantiles en CDMX y Edomex: Mini Castillo, Dragones Rojos, Castillo de Princesas, Mini Jungla, Gusanitos, Barco Pirata, Extremo y Castillo Blanco. Desde $800, con entrega, instalación y recolección incluidas.",
    url: `${BASE}/`,
    image: mainImg(catalogo[1] ?? catalogo[0]),
    priceRange: { min: PRICE_RANGE.min, max: PRICE_RANGE.max },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Juegos Infantiles", url: `${BASE}/` },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Juegos Infantiles" },
];

const waBase = `https://wa.me/${SITE.contact.whatsapp}?text=`;
---

<PageLayout
  title="Renta de Inflables para Fiestas Infantiles en CDMX y Edomex"
  rawTitle={true}
  description="Renta de inflables para fiestas infantiles en CDMX: Mini Castillo, Dragones Rojos, Castillo de Princesas, Barco Pirata, Extremo y más. Entrega, instalación y recolección incluidas."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="ji-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Inflables para fiestas infantiles · CDMX y Edomex</p>
            <h1 id="ji-hero-heading">Inflables que <em>llegan, se instalan y se van</em></h1>
            <p class="hm-hero__lead">
              Brincolines, castillos temáticos, toboganes y circuitos de obstáculos
              <strong>desde $800</strong>, con entrega, instalación y recolección incluidas.
              Cada inflable lavado, desinfectado y anclado por nuestro equipo.
            </p>
            <div class="sv-hero__ctas">
              <a class="hm__btn hm__btn--gold" href={`${waBase}${encodeURIComponent("Hola, quiero cotizar un inflable para mi fiesta")}`} target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar mi inflable
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>inflables para fiestas infantiles</strong> en CDMX y
              Estado de México con un catálogo curado de 8 modelos para cada tipo y
              tamaño de evento: desde el <strong>Mini Castillo</strong> para primeros
              cumpleaños en departamento hasta el <strong>Barco Pirata</strong> y el circuito
              <strong>Extremo</strong> para kermeses y eventos escolares.
            </p>
            <p>
              Cada inflable se entrega lavado, desinfectado y revisado, se instala con anclaje
              profesional 1 a 2 horas antes del evento y se recoge al terminar. Y como somos
              proveedor integral de equipo para eventos, podemos sumar
              <a href="/servicios/mobiliario/">mobiliario</a>,
              <a href="/servicios/carpas/">carpas</a> e
              <a href="/servicios/iluminacion/">iluminación</a> en un solo contrato coordinado.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV ─────────────────────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Categorías de inflables infantiles">
      <ul class="hm-menu__grid hm-menu__grid--5">
        <li><a class="hm-menu__item" href="#catalogo">Catálogo</a></li>
        <li><a class="hm-menu__item" href="#chicos">Chicos</a></li>
        <li><a class="hm-menu__item" href="#medianos">Medianos</a></li>
        <li><a class="hm-menu__item" href="#grandes">Grandes</a></li>
        <li><a class="hm-menu__item hm-menu__item--cta" href="#cotiza">Cotizar ahora</a></li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">8 inflables curados para cada tipo de fiesta</p>
            <h2 id="catalogo-heading">Nuestro catálogo de inflables infantiles</h2>
            <p class="hm__head-sub">Del más compacto para bebés a las grandes atracciones para kermeses y bodas — con precio y medidas reales.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              No rentamos cualquier inflable: cada modelo del catálogo está seleccionado por
              durabilidad probada en evento real, seguridad de anclaje en distintos pisos y
              rendimiento visual para fotografía. Elige por tamaño de espacio y edad de los
              invitados —y si tienes dudas, te asesoramos.
            </p>
            <p>
              Todos incluyen entrega, instalación profesional, soplador y recolección.
              Cada uno se lava y desinfecta antes de cada renta.
            </p>
          </div>
        </div>

        <div class="hm-cat-grid">
          {catalogo.map((i) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={`${BASE}/${i.slug}/`} aria-label={`Ver ${i.name}`}>
                <img class="hm-cat__img" src={cardImg(i)} alt={`Renta de inflable ${i.name} para fiestas infantiles en CDMX — EVENTECH`} loading="lazy" decoding="async" width="640" height="480" />
                <span class="hm-cat__badge">{i.badge}</span>
                <span class="hm-cat__name">{i.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="ji-price">{i.price} <span>· {CAT_LABEL[i.cat]}</span></p>
                <p class="hm-cat__sub">{i.excerpt}</p>
                <ul class="ji-specs">
                  {i.specsLine.map((s) => (<li>{s}</li>))}
                </ul>
                <a class="hm-cat__cta" href={`${BASE}/${i.slug}/`}>
                  Ver ficha de {i.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE POR TAMAÑO ─────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cómo elegir</p>
            <h2 id="detalle-heading">Inflables por tamaño y edad — en detalle</h2>
            <p class="hm__head-sub">Tres grupos para tres necesidades: chicos para bebés, medianos para la mayoría de fiestas y grandes para gran formato.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              El inflable correcto depende de tres cosas: el espacio que tienes, la edad de los
              invitados y el tipo de evento. Un primer cumpleaños en departamento no pide lo
              mismo que una kermés escolar o una boda en jardín.
            </p>
            <p>
              Por eso organizamos el catálogo en tres grupos. Aquí lo que distingue a cada uno
              y qué modelo conviene en cada caso.
            </p>
          </div>
        </div>

        {GRUPOS.map((g, idx) => {
          const models = byCat(g.cat);
          const hero = models[0];
          return (
          <article class="hm-feat" id={g.id} aria-labelledby={`feat-${g.id}`}>
            <div class="hm-feat__text">
              <p class="hm__eyebrow">{g.eyebrow}</p>
              <h3 class="hm-feat__title" id={`feat-${g.id}`}>{g.title}</h3>
              <p class="hm-feat__lead">{g.lead}</p>
              <p set:html={g.body1} />
              <p set:html={g.body2} />
              <ul class="hm-feat__chips">
                {models.map((m) => (<li><a href={`${BASE}/${m.slug}/`}>{m.name}</a></li>))}
              </ul>
              <a class="hm-feat__cta" href="#catalogo">
                Ver estos inflables
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </div>
            <div class="hm-feat__media hm-feat__media--g3">
              <img class="hm-feat__g3-main" src={mainImg(hero)} alt={`Inflables ${g.eyebrow.toLowerCase()} para fiestas infantiles en CDMX — EVENTECH`} loading="lazy" decoding="async" />
              <div class="hm-feat__g3-thumbs">
                <img src={photoImg(hero.slug, 2, true)} alt={`Renta de inflable ${hero.name} en CDMX`} loading="lazy" decoding="async" />
                <img src={photoImg(hero.slug, 3, true)} alt={`Inflable ${hero.name} para eventos infantiles`} loading="lazy" decoding="async" />
              </div>
            </div>
          </article>
          );
        })}
      </div>
    </section>

    <!-- POR QUÉ EVENTECH ────────────────────────────────────────── -->
    <section class="hm__section hm__section--navy" aria-labelledby="why-heading">
      <div class="hm__wrap">
        <div class="hm__head">
          <p class="hm__eyebrow">Por qué rentar con nosotros</p>
          <h2 id="why-heading">Lo que cuidamos en cada inflable</h2>
          <p class="hm__head-sub">Higiene, seguridad y servicio integral — los detalles que importan el día del evento.</p>
        </div>
        <ul class="hm-why">
          {whyFeatures.map((f) => (
            <li class="hm-why__item">
              <div class="hm-why__ic" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
              </div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- CÓMO FUNCIONA ──────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="proceso-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cómo funciona</p>
            <h2 id="proceso-heading">Pides, llegamos, se infla, se vacía</h2>
            <p class="hm__head-sub">4 pasos simples. Tú no montas, mueves ni desmontas nada.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Nuestro proceso elimina el caos logístico de una fiesta: nos escribes por
              WhatsApp, confirmamos disponibilidad y precio por escrito, llegamos el día
              acordado a la hora acordada y al final recogemos todo.
            </p>
          </div>
        </div>
        <ol class="hm-steps">
          {steps.map((s) => (
            <li class="hm-step">
              <div class="hm-step__num">{s.n}</div>
              <h3>{s.t}</h3>
              <p>{s.p}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- FAQ + FORMULARIO ──────────────────────────────────────── -->
    <section id="cotiza" class="hm__section hm__section--ivory" aria-labelledby="faq-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Antes de apartar</p>
