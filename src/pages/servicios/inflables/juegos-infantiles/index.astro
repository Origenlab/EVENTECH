              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Fiesta de Cumpleaños">Fiesta de Cumpleaños</option>
                <option value="Bautizo">Bautizo</option>
                <option value="Primera Comunión">Primera Comunión</option>
                <option value="Día del Niño">Día del Niño</option>
                <option value="Evento Escolar">Evento Escolar</option>
                <option value="Kermés">Kermés</option>
                <option value="Festival Familiar">Festival Familiar</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoInflableInfantil">
                Tipo de inflable
              </label>
              <select id="tipoInflableInfantil" name="tipoInflableInfantil" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de inflable</option>
                <option value="Brincolín 3x3m">Brincolín 3x3m</option>
                <option value="Brincolín 4x4m">Brincolín 4x4m</option>
                <option value="Castillo 5x5m">Castillo 5x5m</option>
                <option value="Tobogán Seco 4m">Tobogán Seco 4m</option>
                <option value="Tobogán Seco 6m">Tobogán Seco 6m</option>
                <option value="Circuito Obstáculos">Circuito Obstáculos</option>
                <option value="Inflable Princesas">Inflable Princesas</option>
                <option value="Inflable Superhéroes">Inflable Superhéroes</option>
                <option value="Paquete Fiesta Infantil">Paquete Fiesta Infantil</option>
                <option value="Paquete Completo">Paquete Completo</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: edad de los niños, número aproximado de invitados, tipo de espacio (jardín/salón/parque), temática de la fiesta..."
