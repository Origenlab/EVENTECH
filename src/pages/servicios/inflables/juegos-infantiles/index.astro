            {faqs.map((faq) => (
              <details class="hm-faq__item">
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>

          <aside class="hm-faqx__aside" aria-labelledby="jiform-heading">
            <form id="jiForm" class="hm-form" data-wa={SITE.contact.whatsapp}>
              <p class="hm-form__eyebrow">Respuesta en menos de 1 hora</p>
              <h3 id="jiform-heading" class="hm-form__title">Cotiza tu inflable</h3>
              <p class="hm-form__sub">Cuéntanos de la fiesta y te recomendamos el inflable ideal para tu espacio y edad.</p>

              <label class="hm-form__field">
                <span>Nombre</span>
                <input type="text" name="nombre" autocomplete="name" placeholder="Tu nombre" required />
              </label>

              <label class="hm-form__field">
                <span>Tipo de evento</span>
                <select name="tipo">
                  <option value="">Selecciona…</option>
                  <option>Cumpleaños</option>
                  <option>Bautizo</option>
                  <option>Primera comunión</option>
                  <option>Kermés escolar</option>
                  <option>Boda / XV años</option>
                  <option>Evento corporativo</option>
