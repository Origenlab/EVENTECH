---
/**
 * ─── Brincolines y Castillos Inflables — Pagina de Producto (Nivel 4) ───
 * Brincolines de 3x3, 4x4, 5x5 y 6x6 metros con redes de seguridad
 * certificadas para fiestas infantiles y eventos familiares.
 *
 * Jerarquia: Servicios > Inflables > Juegos Infantiles > Brincolines
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Juegos Infantiles", href: "/servicios/inflables/juegos-infantiles/" },
  { label: "Brincolines y Castillos" },
];

const faqs = [
  { question: "¿Para qué edades son recomendados los brincolines?", answer: 'Nuestros brincolines están diseñados para niños de <strong>3 a 12 años</strong>. Los modelos de 3x3 metros son ideales para niños pequeños de 3 a 6 años, con paredes laterales más altas para mayor contención. Los castillos de 4x4 y 5x5 metros funcionan perfectamente para niños de 4 a 10 años. El Mega Castillo de 6x6 metros admite niños hasta 12 años. Siempre clasificamos cada brincolín por edad y peso máximo (40 kg individual) para garantizar la diversión segura de todos los pequeños.' },
  { question: "¿Cuál es la capacidad máxima de niños por brincolín?", answer: 'La capacidad varía según el tamaño del inflable. El brincolín de <strong>3x3 metros admite 4-6 niños</strong> simultáneos, el de 4x4 metros permite <strong>6-8 niños</strong>, el de 5x5 metros soporta <strong>8-12 niños</strong> y el Mega Castillo de 6x6 metros puede albergar hasta <strong>15 niños</strong> al mismo tiempo. El peso máximo total varía de 60 a 90 kg según el modelo. Nuestro monitor de seguridad controla el acceso en todo momento para no exceder la capacidad.' },
  { question: "¿Cuánto espacio necesito para instalar un brincolín?", answer: 'Necesitas un área libre de al menos <strong>1 metro adicional por cada lado</strong> del inflable. Un brincolín de 3x3 m requiere 4x4 metros libres, uno de 5x5 m necesita 6.5x6.5 metros. El Mega Castillo de 6x6 m requiere un espacio de 7.5x7.5 metros mínimo. Además se necesita una toma de corriente de 110V a no más de 20 metros. La superficie ideal es pasto, aunque también instalamos sobre concreto o piso firme con anclaje especial. Hacemos evaluación previa del espacio sin costo.' },
  { question: "¿Qué pasa si llueve o hay mal clima?", answer: 'En caso de <strong>lluvia ligera</strong>, los brincolines pueden seguir operando ya que están fabricados con lona vinílica impermeable. Si hay lluvia fuerte, tormenta eléctrica o vientos superiores a 40 km/h, detenemos la operación por seguridad. Te ofrecemos <strong>reprogramación sin costo</strong> con al menos 24 horas de aviso. También podemos instalar en espacios techados si cuentan con altura mínima de 4 metros (para modelos 3x3 y 4x4) o 5 metros (para modelos más grandes).' },
  { question: "¿Cuánto tiempo toma la instalación?", answer: 'La instalación de un brincolín de <strong>3x3 metros toma 15-20 minutos</strong>, el de 4x4 metros requiere 20-30 minutos, el de 5x5 metros entre 30-40 minutos y el Mega Castillo de 6x6 metros toma aproximadamente 45-60 minutos. Llegamos con <strong>1 a 2 horas de anticipación</strong> al inicio del evento para tener todo listo y probado. El desmontaje es más rápido, aproximadamente la mitad del tiempo de instalación. Todo incluido sin costo adicional.' },
  { question: "¿Qué medidas de seguridad incluyen los brincolines?", answer: 'Cada brincolín cuenta con <strong>redes de seguridad perimetral</strong> en todas las aberturas, costuras dobles reforzadas con hilo de nylon, <strong>anclaje de 4 puntos</strong> al piso (estacas en pasto o pesos de arena en concreto), tapete acolchado en la entrada, lona vinílica de 18 oz certificada ASTM F2374 e ignífuga. Incluimos un <strong>monitor de seguridad capacitado</strong> que supervisa el uso correcto durante todo el evento, controla acceso por edad y peso, y verifica que los niños se quiten zapatos y objetos punzantes.' },
];

const specs = [
  { label: "Tamaños", value: "3x3, 4x4, 5x5, 6x6 metros" },
  { label: "Material", value: "Lona vinílica 18 oz reforzada" },
  { label: "Capacidad", value: "4-15 niños simultáneos según tamaño" },
  { label: "Rango de edad", value: "3 a 12 años" },
  { label: "Peso máximo", value: "90 kg total / 40 kg individual" },
  { label: "Altura", value: "2.5 a 4.5 metros según modelo" },
  { label: "Seguridad", value: "Redes laterales + anclaje 4 puntos" },
  { label: "Monitor", value: "Incluido durante todo el evento" },
  { label: "Inflador", value: "Continuo 1.5 HP, 110V estándar" },
  { label: "Certificación", value: "ASTM F2374, ignífugo" },
];

const sidebarNav = [
  { name: "Brincolines y Castillos", href: null, active: true },
  { name: "Toboganes Inflables", href: "/servicios/inflables/juegos-infantiles/toboganes/" },
  { name: "Circuitos de Obstáculos", href: "/servicios/inflables/juegos-infantiles/circuitos-obstaculos/" },
  { name: "Inflables Temáticos", href: "/servicios/inflables/juegos-infantiles/tematicos/" },
];

const sidebarRelated = [
  { name: "Inflables Acuáticos", href: "/servicios/inflables/acuaticos/" },
  { name: "Inflables para Adultos", href: "/servicios/inflables/adultos/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Catering y Alimentos", href: "/servicios/catering/" },
];

const reviews = [
  { author: "Laura Méndez", text: "Rentamos el brincolín de 5x5 para la fiesta de mi hija con 30 niños invitados. El monitor fue increíble, súper atento con los niños, y el inflable estaba impecable y bien sanitizado. Los niños no pararon de brincar en toda la tarde. Sin duda lo volveremos a rentar para el próximo cumpleaños.", rating: 5, date: "2025-11-20" },
  { author: "Carlos Ramírez", text: "Contratamos el castillo de 4x4 para un cumpleaños en nuestro jardín en Coyoacán. El equipo llegó puntual, instaló todo en menos de 30 minutos y el inflable se veía nuevo. Los niños se divirtieron muchísimo y el monitor mantuvo el orden perfecto. Excelente relación calidad-precio.", rating: 5, date: "2025-10-15" },
  { author: "Diana Ortega", text: "Para el evento escolar del Día del Niño contratamos 3 brincolines de diferentes tamaños. EVENTECH coordinó toda la logística, los tres monitores fueron muy profesionales y los 150 niños disfrutaron al máximo. La instalación y desmontaje fueron impecables. Totalmente recomendados.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Brincolines y Castillos Inflables para Eventos en CDMX",
    description: "Renta de brincolines y castillos inflables de 3x3 a 6x6 metros con redes de seguridad certificadas. Monitor incluido. Para niños de 3 a 12 años. Desde $800 por evento.",
    url: "/servicios/inflables/juegos-infantiles/brincolines/",
    priceRange: { min: 800, max: 3500 },
    reviews,
    ratingValue: 5,
    reviewCount: 245,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Juegos Infantiles", url: "/servicios/inflables/juegos-infantiles/" },
    { name: "Brincolines y Castillos", url: "/servicios/inflables/juegos-infantiles/brincolines/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Brincolines y Castillos Inflables en CDMX | EVENTECH"
  description="Renta de brincolines y castillos inflables de 3x3 a 6x6 metros con redes de seguridad certificadas. Monitor incluido. Para niños de 3 a 12 años. Desde $800 por evento."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El favorito de las fiestas infantiles"
    title='Renta de <span class="highlight">Brincolines y Castillos</span> Inflables para Eventos'
    subtitle="Brincolines y castillos inflables de 3x3 a 6x6 metros con redes de seguridad certificadas, monitor incluido y materiales ASTM. La diversión más segura para niños de 3 a 12 años en fiestas y eventos familiares."
    primaryCTA={{ label: "Cotiza tu brincolín", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar brincolines y castillos inflables para mi evento` }}
    cards={[
      {
        title: "Brincolines de 3x3, 4x4, 5x5 y 6x6 metros con seguridad certificada",
        content: "<strong>Renta de brincolines y castillos inflables</strong> con los más altos estándares de seguridad para eventos en CDMX. Brincolines de 3x3, 4x4, 5x5 y 6x6 metros con redes laterales de seguridad en todas las aberturas, costuras dobles reforzadas, materiales de lona vinílica certificados ASTM F2374 y anclaje profesional de 4 puntos. Capacidad de 4 a 15 niños simultáneos según el tamaño, ideales para fiestas de cumpleaños, bautizos, primeras comuniones y eventos familiares.",
      },
      {
        title: "Monitor de seguridad incluido y servicio profesional completo",
        content: "<strong>Servicio completo de instalación y supervisión</strong> incluido en cada renta de brincolines. Monitor de seguridad capacitado incluido durante todo el evento para controlar acceso, verificar edades y peso, y garantizar el uso correcto. Inflador continuo silencioso de 1.5 HP con conexión 110V estándar, limpieza sanitizada pre-evento y seguro de responsabilidad civil. Transporte, instalación con anclaje certificado y desmontaje incluidos sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas el brincolín perfecto para tu fiesta?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el tamaño ideal para tu espacio y número de niños"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Juegos Infantiles Inflables</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas brincolines para tu fiesta infantil?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar brincolines y castillos inflables para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/><path d="M12 18v4"/><path d="M10 22h4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Brincolines y Castillos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Brincolín Castillo 3x3m -->
          <section class="section section--alt" aria-labelledby="brincolin-3x3-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para fiestas íntimas</span>
                <h2 class="showcase__title" id="brincolin-3x3-heading">Brincolín Castillo 3x3m</h2>
                <p class="showcase__subtitle">El brincolín perfecto para fiestas en espacios reducidos con niños pequeños de 3 a 6 años.</p>
                <p class="showcase__text">Nuestro <strong>brincolín castillo de 3x3 metros</strong> es la opción más compacta y versátil de nuestro catálogo de inflables infantiles. Con una altura de 2.5 metros y capacidad para <strong>4 a 6 niños simultáneos</strong>, es perfecto para fiestas de cumpleaños en jardines pequeños, terrazas y salones con espacio limitado. Fabricado con <strong>lona vinílica de 18 oz certificada ASTM</strong>, costuras dobles reforzadas y redes de seguridad en la entrada para máxima contención.</p>
                <p class="showcase__text">Incluye <strong>monitor de seguridad capacitado, inflador continuo silencioso de 1.5 HP</strong> y tapete acolchado en la entrada. Las paredes laterales de 1.5 metros de altura garantizan que los niños más pequeños brinquen con total seguridad. Ideal para <strong>fiestas de cumpleaños, bautizos y reuniones familiares</strong> con grupos reducidos de niños de 3 a 6 años. Combínalo con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para proteger del sol y crear una zona infantil techada.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">3x3 metros</span>
                  <span class="showcase__tag">4-6 niños</span>
                  <span class="showcase__tag">3-6 años</span>
                  <span class="showcase__tag">Desde $800</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Brincolín 3x3m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Brincolín Castillo 3x3m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Brincolín Castillo 5x5m -->
          <section class="section section--alt" aria-labelledby="brincolin-5x5-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más popular para cumpleaños</span>
                <h2 class="showcase__title" id="brincolin-5x5-heading">Brincolín Castillo 5x5m</h2>
                <p class="showcase__subtitle">El tamaño favorito para fiestas de cumpleaños con 8 a 12 niños brincando al mismo tiempo.</p>
                <p class="showcase__text">El <strong>brincolín castillo de 5x5 metros</strong> es nuestro modelo más solicitado para <strong>fiestas de cumpleaños y eventos familiares</strong>. Con 3.5 metros de altura y capacidad para <strong>8 a 12 niños simultáneos</strong>, ofrece el equilibrio perfecto entre espacio de brinco y tamaño de instalación. Las torres decorativas en las esquinas y el arco de entrada le dan un aspecto de castillo medieval que encanta a niños de 4 a 10 años.</p>
                <p class="showcase__text">Cuenta con <strong>redes de seguridad perimetral, zona de escalada interior</strong> y ventanas de ventilación para mantener fresco el interior. El material de <strong>lona vinílica de 18 oz ignífuga</strong> resiste el uso intensivo durante eventos de varias horas. Perfecto para <strong>cumpleaños, primeras comuniones, eventos del Día del Niño y kermeses escolares</strong>. Incluye monitor de seguridad, inflador continuo y anclaje profesional de 4 puntos. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para fiestas al atardecer.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">5x5 metros</span>
                  <span class="showcase__tag">8-12 niños</span>
                  <span class="showcase__tag">4-10 años</span>
                  <span class="showcase__tag">El más popular</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Brincolín 5x5m
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Brincolín Castillo 5x5m</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Brincolín con Tobogán Integrado -->
          <section class="section section--alt" aria-labelledby="brincolin-tobogan-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Doble diversión en un solo inflable</span>
                <h2 class="showcase__title" id="brincolin-tobogan-heading">Brincolín con Tobogán Integrado</h2>
                <p class="showcase__subtitle">Combina zona de brinco y tobogán de deslizamiento en un solo inflable para máxima diversión.</p>
                <p class="showcase__text">El <strong>brincolín con tobogán integrado</strong> es la atracción 2-en-1 que los niños adoran. Combina una <strong>zona de brinco amplia de 3x3 metros</strong> con un tobogán de deslizamiento de 2 metros de altura en la parte posterior, ofreciendo doble diversión en un solo inflable. Los niños brincan en el área principal y luego suben las escaleras interiores para deslizarse por el tobogán acolchado, creando un circuito de juego continuo que los mantiene entretenidos durante horas.</p>
                <p class="showcase__text">Ideal para <strong>fiestas donde el espacio permite un inflable mediano</strong> pero se quiere maximizar la variedad de actividades. El área total es de aproximadamente 5x4 metros con capacidad para <strong>6-8 niños simultáneos</strong>. Incluye <strong>escalera antiderrapante interior, zona de aterrizaje acolchada</strong> al final del tobogán y redes de seguridad en todos los puntos de acceso. Perfecto para niños de 4 a 10 años. Combínalo con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para musicalizar la fiesta.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Brinco + Tobogán</span>
                  <span class="showcase__tag">6-8 niños</span>
                  <span class="showcase__tag">4-10 años</span>
                  <span class="showcase__tag">2-en-1</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Brincolín con Tobogán
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
