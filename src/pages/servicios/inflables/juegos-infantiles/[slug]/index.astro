---
/**
 * ─── Ficha de Inflable Infantil (L5 dinámica) ───
 * Genera las 20 fichas de producto desde src/data/inflables-juegos.ts con la
 * plantilla L5 homologada (tiffany): l3-shared + l4-shared, ServiceShowcase,
 * specs-table, l4-layout con sidebar, reserva form, acento gold de marca.
 *
 * Jerarquía: Servicios > Inflables > Juegos Infantiles > {inflable}
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import { INFLABLES, CAT_LABEL, faqsFor, photoImg, mainImg, type Inflable } from "@data/inflables-juegos";
import "@styles/l3-shared.css";
import "@styles/l4-shared.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const BASE = "/servicios/inflables/juegos-infantiles";

export async function getStaticPaths() {
  return INFLABLES.map((inf) => ({ params: { slug: inf.slug }, props: { inf } }));
}

const { inf } = Astro.props as { inf: Inflable };
const faqs = faqsFor(inf);

// Galerías según fotos disponibles
const g1 = [1, 2, 3].filter((n) => n <= inf.photos);
const g2 = [4, 5, 6].filter((n) => n <= inf.photos);

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Juegos Infantiles", href: `${BASE}/` },
  { label: inf.name },
];

const sidebarNav = INFLABLES.map((i) => ({ name: i.name, href: i.slug === inf.slug ? null : `${BASE}/${i.slug}/`, active: i.slug === inf.slug }));

const sidebarRelated = [
  { name: "Todos los inflables infantiles", href: `${BASE}/` },
  { name: "Mobiliario para fiestas", href: "/servicios/mobiliario/" },
  { name: "Carpas para eventos", href: "/servicios/carpas/" },
  { name: "Iluminación decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Directorio de salones", href: "/directorio/" },
];

const jsonLd = [
  serviceJsonLd({
    name: `Renta de Inflable ${inf.name} para Fiestas Infantiles en CDMX`,
    description: `Renta del inflable ${inf.name} en CDMX y Edomex. ${inf.excerpt} Entrega, instalación y recolección incluidas.`,
    url: `${BASE}/${inf.slug}/`,
    image: mainImg(inf),
    priceRange: { min: inf.priceFrom, max: inf.priceFrom },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Juegos Infantiles", url: `${BASE}/` },
    { name: inf.name, url: `${BASE}/${inf.slug}/` },
  ]),
  faqJsonLd(faqs),
];

const waModel = `https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, quiero cotizar el inflable ${inf.name} para mi fiesta`)}`;
const priceText = inf.price === "Cotizar" ? "Cotiza precio y disponibilidad" : `${inf.price} MXN`;
---

<PageLayout
  title={`Renta de Inflable ${inf.name} para Fiestas Infantiles CDMX`}
  description={`Renta el inflable ${inf.name} en CDMX y Edomex. ${inf.excerpt}`.slice(0, 158)}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- HERO -->
  <HeroPage
    badge={`Inflable ${CAT_LABEL[inf.cat].toLowerCase()} · ${inf.badge}`}
    title={`Renta del Inflable <span class="highlight">${inf.name}</span> para Fiestas Infantiles`}
    subtitle={`${inf.lead} ${priceText}. Entrega, instalación y recolección incluidas en CDMX y Edomex.`}
    primaryCTA={{ label: "Cotiza este inflable", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: waModel }}
    cards={[
      { title: `${inf.name} — ${inf.badge}`, content: inf.body1 },
      { title: "Servicio integral incluido", content: "Cada renta incluye <strong>entrega a domicilio, instalación profesional con anclaje, soplador con extensión y recolección</strong>. Llegamos 1 a 2 horas antes del evento y dejamos todo seguro. El inflable se <strong>lava, desinfecta y revisa antes de cada renta</strong>." },
    ]}
  />

  <!-- CTA BANNER -->
  <CTABanner
    headline={`Cotiza el inflable ${inf.name} sin compromiso`}
    subheadline="Entrega, instalación y recolección incluidas · Respuesta en menos de 1 hora"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Inflables Infantiles</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Quieres el {inf.name} para tu fiesta?</p>
          <a href={waModel} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/><path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones — Inflable {inf.name}</h2>
              </div>
              <div class="specs-table__body">
                {inf.specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE 1: descripción + galería -->
          <section class="section" aria-labelledby="detalle-heading">
            <ServiceShowcase
              title={`Por qué elegir el ${inf.name}`}
              headingId="detalle-heading"
              badge={inf.badge}
              subtitle={inf.lead}
              tags={inf.specsLine}
              ctaHref="#reserva-heading"
              ctaLabel={`Cotizar ${inf.name}`}
            >
              <Fragment slot="body">
                <p class="showcase__text" set:html={inf.body1} />
                <p class="showcase__text" set:html={inf.body2} />
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main">
                    <img src={photoImg(inf.slug, g1[0])} alt={`Inflable ${inf.name} para fiesta infantil en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                  </div>
                  {g1[1] && <div class="showcase__gallery3-thumb"><img src={photoImg(inf.slug, g1[1], true)} alt={`Renta de inflable ${inf.name} montado en evento`} loading="lazy" decoding="async" /></div>}
                  {g1[2] && <div class="showcase__gallery3-thumb"><img src={photoImg(inf.slug, g1[2], true)} alt={`Inflable ${inf.name} para fiestas infantiles`} loading="lazy" decoding="async" /></div>}
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE 2: servicio (si hay fotos suficientes) -->
          {g2.length > 0 && (
            <section class="section section--alt" aria-labelledby="servicio-heading">
              <ServiceShowcase
                title="Higiene, seguridad y servicio incluido"
                headingId="servicio-heading"
                badge="Sin letra chica"
                subtitle="Entrega, instalación con anclaje, soplador y recolección — y cada inflable lavado y desinfectado antes de tu evento."
                tags={["Entrega incluida", "Anclaje profesional", "Sanitización", "Recolección"]}
                ctaHref="#reserva-heading"
                ctaLabel="Cotizar ahora"
              >
                <Fragment slot="body">
                  <p class="showcase__text">El precio que te damos <strong>incluye entrega a domicilio, instalación profesional con anclaje, soplador con extensión eléctrica y recolección</strong> al terminar. Llegamos 1 a 2 horas antes, montamos y dejamos todo seguro antes de irnos. Tú no mueves, montas ni desmontas nada.</p>
                  <p class="showcase__text">Antes de cada renta, el inflable se <strong>lava, desinfecta y revisa</strong>. Y como somos proveedor integral, podemos sumar <a href="/servicios/mobiliario/">mobiliario infantil</a>, <a href="/servicios/carpas/">carpas</a> e <a href="/servicios/iluminacion/">iluminación</a> en un solo contrato coordinado.</p>
                </Fragment>
                <Fragment slot="media">
                  <div class="showcase__gallery3">
                    <div class="showcase__gallery3-main">
                      <img src={photoImg(inf.slug, g2[0])} alt={`Inflable ${inf.name} instalado para evento infantil en CDMX`} loading="lazy" decoding="async" />
                    </div>
                    {g2[1] && <div class="showcase__gallery3-thumb"><img src={photoImg(inf.slug, g2[1], true)} alt={`Renta de inflable ${inf.name} en CDMX y Edomex`} loading="lazy" decoding="async" /></div>}
                    {g2[2] && <div class="showcase__gallery3-thumb"><img src={photoImg(inf.slug, g2[2], true)} alt={`Inflable ${inf.name} listo para la fiesta`} loading="lazy" decoding="async" /></div>}
                  </div>
                </Fragment>
              </ServiceShowcase>
            </section>
          )}

          <!-- FAQ -->
          <section class="section" aria-labelledby="faq-heading">
            <h2 id="faq-heading" class="l4-faq-title">Preguntas frecuentes sobre el {inf.name}</h2>
            <div class="l4-faq">
              {faqs.map((faq) => (
                <details class="l4-faq__item">
                  <summary class="l4-faq__q">{faq.question}</summary>
                  <div class="l4-faq__a">{faq.answer}</div>
                </details>
              ))}
            </div>
          </section>

        </div>

        <!-- SIDEBAR -->
        <aside class="l4-sidebar" aria-label="Navegación de inflables y servicios">
          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Inflables Infantiles</h2>
            <ul class="sidebar-nav">
              {sidebarNav.map((item) => (
                <li class="sidebar-nav__item">
                  {item.active ? (
                    <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                  ) : (
                    <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                  )}
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-card">
            <h2 class="sidebar-card__title">Servicios Relacionados</h2>
            <p style="font-size: var(--text-xs); color: var(--color-text-light); margin-block-end: var(--space-sm);">Completa tu fiesta infantil:</p>
            <ul class="sidebar-related">
              {sidebarRelated.map((item) => (
                <li>
                  <a href={item.href} class="sidebar-related__link">
                    <span class="sidebar-related__arrow">&rarr;</span>
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <div class="sidebar-card sidebar-card--cta">
            <h2 class="sidebar-card__title">Cotiza Ahora</h2>
            <p class="sidebar-card--cta-text">¿Quieres el {inf.name} para tu fiesta?</p>
            <a href={waModel} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
            <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- RESERVA FORM -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title={`Cotiza el Inflable ${inf.name}`}
        subtitle="Cuéntanos de tu fiesta y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y un asesor te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Te confirmamos disponibilidad de la fecha, precio total y te asesoramos si el inflable cabe en tu espacio."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate data-wa-number={SITE.contact.whatsapp} data-wa-title={`Inflable ${inf.name} — EVENTECH.MX`}>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">Nombre completo <span class="form-field__required">*</span></label>
              <input type="text" id="nombre" name="nombre" class="form-field__input" placeholder="Tu nombre" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="telefono">Teléfono <span class="form-field__required">*</span></label>
              <input type="tel" id="telefono" name="telefono" class="form-field__input" placeholder="55 1234 5678" required />
            </div>
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">Tipo de evento</label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Cumpleaños">Cumpleaños</option>
                <option value="Bautizo">Bautizo</option>
                <option value="Primera Comunión">Primera Comunión</option>
                <option value="Kermés Escolar">Kermés Escolar</option>
                <option value="Día del Niño">Día del Niño</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <div class="form-field">
              <label class="form-field__label" for="fecha">Fecha del evento</label>
              <input type="date" id="fecha" name="fecha" class="form-field__input" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="zona">Zona o alcaldía</label>
              <input type="text" id="zona" name="zona" class="form-field__input" placeholder="Ej. Coyoacán, Naucalpan, Satélite…" />
            </div>
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">Mensaje <span class="form-field__required">*</span></label>
              <textarea id="mensaje" name="mensaje" class="form-field__input form-field__textarea" placeholder="Cuéntanos: número aproximado de niños, edad, tipo de espacio (jardín/salón/departamento)…" rows="4" required></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta en menos de 1 hora</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp durante el horario de atención, los 7 días.</p>
          </div>
          <div class="reserva-card">
            <h3 class="reserva-card__title">Entrega e instalación incluidas</h3>
            <p class="reserva-card__text">El precio incluye entrega, instalación con anclaje, soplador y recolección. Sin sorpresas.</p>
          </div>
          <div class="reserva-card">
            <h3 class="reserva-card__title">Asesoría de espacio</h3>
            <p class="reserva-card__text">¿No sabes si cabe? Mándanos las medidas y te decimos si el {inf.name} entra en tu lugar.</p>
          </div>
          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Domingo: 8:00 - 21:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <ReservaFormScript />

  <!-- CTA FINAL -->
  <CTABanner
    headline="La diversión que tu fiesta infantil necesita"
    subheadline={`Cotiza el inflable ${inf.name} hoy y recibe asesoría sin compromiso.`}
    primaryCTA={{ label: `Cotizar ${inf.name}`, href: "#reserva-heading" }}
    secondaryCTA={{ label: "Ver todos los inflables", href: `${BASE}/` }}
    variant="accent"
  />
</PageLayout>

<!-- Acento institucional dorado de marca — homologado con el sitio -->
<style is:global>
  :root {
    --color-accent: #c2a24a; --color-accent-text: #8a6d2f;
    --color-accent-hover: #a9883a;
    --color-accent-light: #d4b96a;
