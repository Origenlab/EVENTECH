---
/**
 * ─── Juegos Interactivos y Deportivos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Juegos Interactivos y Deportivos para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const INTERACTIVOS = [
  {
    name: "Cancha Futbol Inflable",
    excerpt: "Cancha de futbol inflable de 15x8 metros con porterías incluidas para torneos 5v5 o 3v3. Ideal para eventos corporativos, team building y fiestas deportivas.",
    cta: "Cancha Futbol",
    href: "#futbol-heading",
    icon: "shield",
  },
  {
    name: "Basquetbol Gigante",
    excerpt: "Canasta de basquetbol gigante inflable con balón sobredimensionado para retos por equipos. Diversión garantizada para todas las edades en cualquier evento.",
    cta: "Basquetbol",
    href: "#basquetbol-heading",
    icon: "award",
  },
  {
    name: "Bungee Run",
    excerpt: "Competencia de bungee en doble carril con arnés elástico. Dos participantes corren simultáneamente para ver quién llega más lejos antes de ser jalado de regreso.",
    cta: "Bungee Run",
    href: "#bungee-heading",
    icon: "layers",
  },
  {
    name: "Juegos de Destreza",
    excerpt: "Velcro wall, wrecking ball, human whack-a-mole y retos de habilidad. Juegos interactivos que combinan fuerza, velocidad y estrategia para eventos memorables.",
    cta: "Destreza",
    href: "#destreza-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Cuántas personas pueden jugar simultáneamente en los juegos interactivos?", answer: "Depende del juego. La cancha de futbol inflable permite hasta 10 jugadores simultáneos (5v5) o 6 jugadores en formato 3v3. El bungee run es para 2 competidores a la vez. El basquetbol gigante permite de 2 a 6 jugadores por ronda. Los juegos de destreza como velcro wall aceptan 1-2 personas a la vez, y el wrecking ball hasta 4 jugadores simultáneos. En todos los casos, la rotación es rápida y los tiempos de espera son mínimos para mantener a todos entretenidos." },
  { question: "¿Cuáles son los requisitos de edad para los juegos deportivos?", answer: "La mayoría de nuestros juegos interactivos están diseñados para participantes de 8 años en adelante. La cancha de futbol inflable acepta jugadores desde 6 años. El bungee run y velcro wall requieren mínimo 10 años y un peso mínimo de 30 kg para que el arnés funcione correctamente. El wrecking ball y human whack-a-mole son aptos desde 8 años. Todos nuestros juegos también son seguros para adultos, con límite de peso de hasta 120 kg, lo que los hace perfectos para eventos corporativos y team building." },
  { question: "¿Los juegos interactivos se pueden usar en interiores y exteriores?", answer: "Sí, todos nuestros juegos interactivos funcionan tanto en interiores como en exteriores. Para interiores necesitas una altura mínima de techo de 4 metros y el espacio suficiente según el juego (la cancha de futbol requiere un salón de al menos 18x10 metros). Para exteriores, instalamos sobre pasto, concreto o tierra firme, siempre con estacas o contrapesos de seguridad. En caso de lluvia ligera los juegos pueden seguir operando, pero en condiciones de viento fuerte o lluvia intensa se suspende la operación por seguridad." },
  { question: "¿Qué requerimientos eléctricos tienen los juegos inflables interactivos?", answer: "Cada juego inflable requiere un inflador eléctrico continuo de 1 a 2 HP que funciona con corriente estándar de 110V. Necesitamos acceso a contactos eléctricos dentro de un radio de 15 metros del punto de instalación. Para paquetes de 3 o más juegos, recomendamos un circuito dedicado de 20 amperes para evitar sobrecargas. Si tu venue no cuenta con suficiente capacidad eléctrica, podemos incluir una planta de energía portátil por un costo adicional. El consumo total es bajo: aproximadamente 800W a 1,500W por juego." },
  { question: "¿Se pueden combinar varios juegos interactivos en un mismo evento?", answer: "Por supuesto, y de hecho es lo más recomendado. Los paquetes combinados son nuestra opción más popular. El Paquete Deportivo incluye cancha de futbol + basquetbol gigante. El Paquete Team Building combina bungee run + velcro wall + wrecking ball, ideal para empresas. El Paquete Completo incluye todos los juegos disponibles para eventos de gran escala. Al combinar juegos, ofrecemos descuentos de hasta 20% sobre el precio individual y un coordinador de actividades dedicado que organiza torneos y dinámicas para mantener la energía durante todo el evento." },
  { question: "¿Con cuánta anticipación debo reservar los juegos interactivos?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación para garantizar disponibilidad, especialmente en fines de semana y temporada alta (marzo a junio y noviembre a diciembre). Para eventos corporativos grandes con paquetes de múltiples juegos, lo ideal es apartar con 1 mes de anticipación. La cancha de futbol inflable y el bungee run son nuestros juegos más solicitados y se agotan primero. Atendemos solicitudes de último momento (48-72 horas) sujetas a disponibilidad, aunque la selección puede ser más limitada." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Juegos Interactivos y Deportivos para Eventos en CDMX",
    description: "Juegos interactivos y deportivos inflables para eventos: cancha de futbol, basquetbol gigante, bungee run y juegos de destreza. Montaje incluido.",
    url: "/servicios/inflables/interactivos-deportivos/",
    priceRange: { min: 2000, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Interactivos y Deportivos", url: "/servicios/inflables/interactivos-deportivos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Juegos Interactivos y Deportivos para Eventos en CDMX"
  description="Renta de juegos interactivos y deportivos inflables para eventos en CDMX: cancha de futbol, basquetbol gigante, bungee run, velcro wall y más. Montaje incluido. Desde $2,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Adrenalina y competencia para tu evento"
    title='Renta de <span class="highlight">Juegos Interactivos y Deportivos</span> para Eventos en CDMX'
    subtitle="Juegos inflables interactivos y deportivos que combinan competencia, diversión y adrenalina. Cancha de futbol, basquetbol gigante, bungee run y juegos de destreza con montaje profesional y supervisión incluida."
    primaryCTA={{ label: "Cotiza tu juego", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar juegos interactivos y deportivos para mi evento` }}
    cards={[
      {
        title: "Juegos deportivos inflables de competencia para cada evento",
        content: "<strong>Renta de juegos interactivos y deportivos</strong> con las atracciones más emocionantes disponibles en CDMX. Canchas de futbol inflable de 15x8 y 10x6 metros con porterías profesionales para torneos corporativos y fiestas deportivas. Basquetbol gigante con canasta sobredimensionada para retos por equipos. Bungee run de doble carril con arnés elástico para competencias de velocidad y fuerza. Velcro wall, wrecking ball y human whack-a-mole para activaciones llenas de adrenalina — cada juego supervisado por personal capacitado para garantizar seguridad y máxima diversión.",
      },
      {
        title: "Montaje profesional con coordinador de actividades",
        content: "<strong>Servicio completo de instalación y operación</strong> incluido en cada renta de juegos interactivos. Nuestro equipo se encarga del transporte, inflado, anclaje con estacas o contrapesos, pruebas de seguridad y supervisión durante todo el evento. Para paquetes de 3 o más juegos incluimos un coordinador de actividades que organiza torneos, dinámicas de team building y rotación de participantes para mantener la energía durante todo el evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres activar la adrenalina en tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con los juegos ideales para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de juegos interactivos
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Juegos Interactivos"
        subtitle="Competencia y diversión para eventos de todos los tamaños"
        description={[
          "Desde canchas de futbol inflable para torneos corporativos hasta juegos de destreza para activaciones de marca. Contamos con el inventario de juegos interactivos y deportivos más completo de la Ciudad de México.",
          "Cada juego incluye inflado, anclaje profesional, supervisión durante el evento y personal capacitado en seguridad. Diversión garantizada para niños y adultos por igual."
        ]}
      />

      <div class="grid grid--4">
        {INTERACTIVOS.map((juego) => (
          <Card
            name={juego.name}
            excerpt={juego.excerpt}
            cta={juego.cta}
            href={juego.href}
            icon={juego.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CANCHA DE FUTBOL INFLABLE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="futbol-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Torneo instantáneo</span>
          <h2 class="showcase__title" id="futbol-heading">Cancha de Futbol Inflable</h2>
          <p class="showcase__subtitle">El juego estrella para torneos corporativos, fiestas deportivas y eventos al aire libre.</p>
          <p class="showcase__text">Nuestra <strong>cancha de futbol inflable</strong> de <strong>15x8 metros</strong> cuenta con paredes laterales de 1.5 metros de altura, porterías integradas con red de contención y piso antiderrapante para jugar con total seguridad. Disponible también en formato compacto de <strong>10x6 metros</strong> para espacios reducidos. Perfecta para partidos <strong>5v5 o 3v3</strong> con rotación rápida de equipos. Incluye balón profesional, pecheras de colores y silbato para árbitro.</p>
          <p class="showcase__text">Ideal para <strong>torneos corporativos, eventos de team building, fiestas de cumpleaños y festivales deportivos</strong>. Nuestro coordinador organiza cuadros de eliminación, tabla de posiciones y premiación. Se puede instalar sobre pasto, concreto o tierra firme con anclaje certificado. Combínala con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para crear una zona de descanso y hidratación junto a la cancha.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">15x8 metros</span>
            <span class="showcase__tag">10x6 metros</span>
            <span class="showcase__tag">5v5 / 3v3</span>
            <span class="showcase__tag">Porterías incluidas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Cancha de Futbol
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BASQUETBOL GIGANTE — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="basquetbol-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Diversión XL</span>
          <h2 class="showcase__title" id="basquetbol-heading">Basquetbol Gigante</h2>
          <p class="showcase__subtitle">Canasta sobredimensionada con balón gigante para retos de equipo llenos de risas y emoción.</p>
          <p class="showcase__text">Nuestro <strong>basquetbol gigante inflable</strong> cuenta con una <strong>canasta sobredimensionada de 3 metros de altura</strong> y un <strong>balón gigante</strong> que pesa el doble de uno convencional, lo que añade un desafío extra de coordinación y fuerza. La estructura inflable de 5x4 metros incluye zona de tiro demarcada y tablero de anotación. Perfecto para <strong>competencias por equipos</strong> con formato de eliminación o acumulación de puntos.</p>
          <p class="showcase__text">Ideal para <strong>eventos corporativos, team building, fiestas temáticas deportivas y activaciones de marca</strong>. Los participantes compiten en rondas cronometradas para encestar la mayor cantidad de tiros. Nuestro staff lleva el marcador y organiza las rondas para máxima diversión. Combínalo con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para transmitir el marcador en pantalla y ambientar con música la competencia.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Canasta 3m altura</span>
            <span class="showcase__tag">Balón gigante</span>
            <span class="showcase__tag">Retos por equipos</span>
            <span class="showcase__tag">Todas las edades</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Basquetbol Gigante
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M4.93 4.93l14.14 14.14"/>
              <path d="M19.07 4.93L4.93 19.07"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BUNGEE RUN — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="bungee-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Velocidad y fuerza</span>
          <h2 class="showcase__title" id="bungee-heading">Bungee Run</h2>
          <p class="showcase__subtitle">Competencia de doble carril con arnés elástico: ¿quién llega más lejos antes de ser jalado de regreso?</p>
          <p class="showcase__text">Nuestro <strong>bungee run de doble carril</strong> es una de las atracciones más emocionantes y adictivas para eventos. Dos participantes se colocan un <strong>arnés elástico</strong> conectado a cuerdas bungee de alta resistencia y corren en carriles paralelos de <strong>12 metros de largo</strong>. El objetivo: colocar un velcro lo más lejos posible antes de que la cuerda elástica los jale de regreso. La pista inflable acolchada garantiza aterrizajes suaves y seguros.</p>
          <p class="showcase__text">Perfecto para <strong>eventos corporativos, team building, ferias escolares y fiestas de adultos</strong>. La competencia genera risas, gritos de ánimo y momentos memorables. Incluye arneses ajustables para diferentes tallas (niños desde 10 años y adultos hasta 120 kg), marcadores de distancia y staff dedicado a la operación y seguridad. Combínalo con nuestra <a href="/servicios/iluminacion/">iluminación de escenario</a> para competencias nocturnas espectaculares.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Doble carril</span>
            <span class="showcase__tag">12m de largo</span>
            <span class="showcase__tag">Arnés elástico</span>
            <span class="showcase__tag">Pista acolchada</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Bungee Run
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       JUEGOS DE DESTREZA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="destreza-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Retos mentales y físicos</span>
          <h2 class="showcase__title" id="destreza-heading">Juegos de Destreza</h2>
          <p class="showcase__subtitle">Velcro wall, wrecking ball, human whack-a-mole y retos de habilidad que ponen a prueba cuerpo y mente.</p>
          <p class="showcase__text">Nuestra colección de <strong>juegos de destreza inflables</strong> ofrece las atracciones más originales y divertidas para eventos. El <strong>velcro wall</strong> (muro de velcro) permite a los participantes lanzarse contra una pared pegajosa usando un traje especial y quedar adheridos en las posiciones más cómicas. El <strong>wrecking ball</strong> enfrenta a 4 jugadores sobre pedestales inflables intentando derribarse mutuamente con una bola demoledora acolchada.</p>
          <p class="showcase__text">El <strong>human whack-a-mole</strong> recrea el clásico juego de arcade a tamaño real: los participantes asoman la cabeza por agujeros en una estructura inflable mientras un jugador intenta tocarlos con un mazo de espuma. Complementamos con <strong>retos de habilidad</strong> como laberintos inflables y carreras de obstáculos. Ideal para <strong>activaciones de marca, fiestas corporativas, ferias y eventos familiares</strong>. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario</a> para crear zonas de descanso entre competencias.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Velcro Wall</span>
            <span class="showcase__tag">Wrecking Ball</span>
            <span class="showcase__tag">Human Whack-a-Mole</span>
            <span class="showcase__tag">Retos de habilidad</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Juegos de Destreza
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
              <path d="M9 9h.01"/>
              <path d="M15 9h.01"/>
              <path d="M8 13a4 4 0 0 0 8 0"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Juegos Interactivos"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus juegos interactivos y deportivos, es natural tener preguntas sobre capacidad, edades, espacio y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre juegos interactivos al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de juegos interactivos y deportivos para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Juegos Interactivos"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de juegos interactivos y deportivos. Sin compromiso, sin costos ocultos.",
          "Ya sea una cancha de futbol inflable para tu torneo corporativo o un paquete completo de juegos de destreza para tu festival, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Team Building">Team Building</option>
                <option value="Fiesta Infantil">Fiesta Infantil</option>
                <option value="Festival / Feria">Festival / Feria</option>
                <option value="Activación de Marca">Activación de Marca</option>
                <option value="Fiesta de Cumpleaños">Fiesta de Cumpleaños</option>
                <option value="Evento Escolar">Evento Escolar</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoInteractivo">
                Tipo de juego interactivo
              </label>
              <select id="tipoInteractivo" name="tipoInteractivo" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de juego</option>
                <option value="Cancha Futbol 15x8m">Cancha Futbol 15x8m</option>
                <option value="Cancha Futbol 10x6m">Cancha Futbol 10x6m</option>
                <option value="Basquetbol Gigante">Basquetbol Gigante</option>
                <option value="Bungee Run Doble">Bungee Run Doble</option>
                <option value="Velcro Wall">Velcro Wall</option>
                <option value="Wrecking Ball">Wrecking Ball</option>
                <option value="Human Whack-a-Mole">Human Whack-a-Mole</option>
                <option value="Paquete Deportivo">Paquete Deportivo</option>
                <option value="Paquete Team Building">Paquete Team Building</option>
                <option value="Paquete Completo">Paquete Completo</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de participantes, edades, tipo de espacio (salón/jardín/parque), duración del evento, si necesitas varios juegos..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Visita técnica gratis</h3>
            <p class="reserva-card__text">Evaluamos tu espacio sin costo para recomendarte los juegos ideales según dimensiones y superficie disponible.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para armar el paquete perfecto para tu evento.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const tipoInteractivo = document.getElementById('tipoInteractivo').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva solicitud desde EVENTECH.MX — Interactivos y Deportivos*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (tipoInteractivo) texto += `*Tipo de juego:* ${tipoInteractivo}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
