---
/**
 * ─── Cancha de Futbol Inflable — Pagina de Producto (Nivel 4) ───
 * Cancha de futbol inflable de 15x8 metros con porterias para torneos
 * 5v5 y 3v3 en corporativos y fiestas deportivas.
 *
 * Jerarquia: Servicios > Inflables > Interactivos y Deportivos > Cancha Futbol
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Interactivos y Deportivos", href: "/servicios/inflables/interactivos-deportivos/" },
  { label: "Cancha de Futbol Inflable" },
];

const faqs = [
  { question: "¿Cuántos jugadores pueden jugar simultáneamente en la cancha inflable?", answer: "La cancha de futbol inflable de 15x8 metros permite hasta <strong>10 jugadores simultáneos en formato 5v5</strong> o <strong>6 jugadores en formato 3v3</strong>. La rotación entre equipos es rápida, con partidos de 7-10 minutos, lo que permite que en una hora jueguen hasta 40-60 personas diferentes. Nuestro árbitro/coordinador organiza los tiempos y rotaciones para máxima participación." },
  { question: "¿Qué edades son adecuadas para la cancha de futbol inflable?", answer: "La cancha es apta para jugadores desde <strong>6 años en adelante</strong>, incluyendo adultos. El peso máximo por jugador es de 120 kg. Para torneos mixtos con niños y adultos, recomendamos organizar categorías separadas. Nuestro coordinador adapta las reglas según las edades: partidos más cortos para niños pequeños y formato competitivo para adolescentes y adultos." },
  { question: "¿Cuánto espacio necesito para instalar la cancha de futbol?", answer: "La cancha de 15x8 metros requiere un espacio libre de al menos <strong>18x11 metros</strong> para incluir la zona de inflado perimetral y acceso. Para la versión compacta 3v3, necesitas mínimo 13x9 metros. Se instala sobre pasto, concreto o tierra firme. La altura mínima para instalación en interiores es de <strong>4 metros de techo</strong>. Evaluamos tu espacio sin costo antes del evento." },
  { question: "¿La cancha funciona tanto en interiores como en exteriores?", answer: "Sí, la cancha de futbol inflable funciona en <strong>ambos entornos</strong>. En exteriores se ancla con estacas de seguridad en pasto o contrapesos en concreto. En interiores (salones, naves industriales, gimnasios) se fija con contrapesos. En caso de lluvia ligera puede seguir operando, pero en <strong>viento fuerte o lluvia intensa</strong> se suspende por seguridad. Para exteriores, recomendamos combinar con nuestras <a href=\"/servicios/carpas/\">carpas</a> para zona de descanso." },
  { question: "¿Pueden organizar un torneo completo con la cancha?", answer: "Sí, nuestro <strong>Paquete Torneo Completo</strong> incluye árbitro certificado, <strong>sistema de marcador digital</strong>, tabla de posiciones, chalecos de colores para 8 equipos, balones profesionales, silbatos, cronómetro visible y certificados de participación. Organizamos torneos de eliminación directa o round robin para 4, 6 u 8 equipos. El coordinador gestiona toda la logística deportiva para que tú solo disfrutes." },
  { question: "¿Se puede combinar la cancha de futbol con otros juegos deportivos?", answer: "Por supuesto, los paquetes combinados son nuestra opción más popular. El <strong>Combo Futbol + Futbolito Humano</strong> es ideal para corporativos. También puedes agregar <a href=\"/servicios/inflables/interactivos-deportivos/basquetbol-gigante/\">basquetbol gigante</a> o <a href=\"/servicios/inflables/interactivos-deportivos/bungee-run/\">bungee run</a> para crear una zona deportiva completa. Al combinar 2 o más juegos ofrecemos <strong>descuentos de hasta 20%</strong> y un coordinador de actividades dedicado." },
];

const specs = [
  { label: "Cancha", value: "15x8 metros con paredes laterales" },
  { label: "Porterías", value: "2 integradas reforzadas" },
  { label: "Paredes", value: "1.2 metros de altura con red superior" },
  { label: "Jugadores", value: "10 simultáneos en 5v5 o 6 en 3v3" },
  { label: "Edad mínima", value: "6 años" },
  { label: "Peso máximo", value: "120 kg por jugador" },
  { label: "Material", value: "Lona vinílica 22 oz reforzada" },
  { label: "Árbitro", value: "Incluido como coordinador" },
  { label: "Infladores", value: "2 continuos de 2 HP" },
  { label: "Balones", value: "3 profesionales incluidos" },
];

const sidebarNav = [
  { name: "Cancha Futbol Inflable", href: null, active: true },
  { name: "Basquetbol Gigante", href: "/servicios/inflables/interactivos-deportivos/basquetbol-gigante/" },
  { name: "Bungee Run", href: "/servicios/inflables/interactivos-deportivos/bungee-run/" },
  { name: "Juegos de Destreza", href: "/servicios/inflables/interactivos-deportivos/juegos-destreza/" },
];

const sidebarRelated = [
  { name: "Inflables para Adultos", href: "/servicios/inflables/adultos/" },
  { name: "Juegos Infantiles", href: "/servicios/inflables/juegos-infantiles/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Audiovisual y Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Miguel Rodríguez", text: "Organizamos un torneo corporativo con 8 equipos en la cancha de futbol inflable para el Día de la Empresa. El coordinador armó los cuadros de eliminación, llevó el marcador y entregó trofeos. Fue el evento más exitoso que hemos tenido, todos los departamentos participaron y la competencia fue increíble. Repetiremos el próximo año.", rating: 5, date: "2025-11-20" },
  { author: "Laura Méndez", text: "Rentamos la cancha inflable para la fiesta de cumpleaños de mi hijo de 10 años. Los niños no pararon de jugar durante 4 horas. El árbitro fue muy paciente y organizó partidos por edades. La cancha se veía impecable y segura. Todos los papás quedaron impresionados con la calidad del equipo.", rating: 5, date: "2025-10-05" },
  { author: "Carlos Vega", text: "Usamos la cancha de futbol inflable para el Día de la Familia de nuestra empresa en un parque de Coyoacán. Más de 200 personas rotaron durante el día. El equipo de EVENTECH llegó temprano, instaló todo perfecto y el coordinador mantuvo la energía todo el evento. Servicio profesional de principio a fin.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Cancha de Futbol Inflable para Eventos en CDMX",
    description: "Renta de cancha de futbol inflable de 15x8 metros con porterías para torneos 5v5 y 3v3. Ideal para corporativos y fiestas deportivas. Desde $3,500.",
    url: "/servicios/inflables/interactivos-deportivos/cancha-futbol/",
    priceRange: { min: 3500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 156,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Interactivos y Deportivos", url: "/servicios/inflables/interactivos-deportivos/" },
    { name: "Cancha de Futbol Inflable", url: "/servicios/inflables/interactivos-deportivos/cancha-futbol/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Cancha de Futbol Inflable en CDMX | EVENTECH"
  description="Renta de cancha de futbol inflable de 15x8 metros con porterías para torneos 5v5 y 3v3. Ideal para corporativos y fiestas deportivas. Desde $3,500."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Torneos 5v5 y 3v3 con porterías"
    title='Renta de <span class="highlight">Cancha de Futbol</span> Inflable para Eventos'
    subtitle="Cancha de futbol inflable de 15x8 metros con paredes laterales, porterías integradas y red perimetral. Árbitro coordinador incluido con balones profesionales y equipo para torneos organizados."
    primaryCTA={{ label: "Cotiza tu cancha", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar una cancha de futbol inflable para mi evento` }}
    cards={[
      {
        title: "Cancha inflable de 15x8 metros con porterías profesionales",
        content: "<strong>Cancha inflable de 15x8 metros</strong> con paredes laterales de 1.2m, porterías integradas reforzadas y red perimetral para contención de balón. Formatos 5v5 y 3v3 configurables. Fabricada en lona vinílica de 22 oz reforzada con costuras termoselladas y piso antiderrapante para jugar con total seguridad. Ideal para torneos corporativos, fiestas deportivas, team building y eventos familiares en la Ciudad de México.",
      },
      {
        title: "Árbitro coordinador y equipo completo incluido",
        content: "<strong>Árbitro/coordinador incluido</strong>, balones profesionales, sistema de marcador digital, silbatos y chalecos para torneos organizados. Nuestro coordinador gestiona cuadros de eliminación, tabla de posiciones y rotación de equipos para que todos participen. Incluye transporte, instalación con anclaje profesional, inflado continuo y desmontaje sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres un torneo de futbol inflable en tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el formato ideal para tu espacio y número de participantes"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Interactivos y Deportivos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas una cancha de futbol inflable para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar una cancha de futbol inflable para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Cancha de Futbol Inflable</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Cancha Futbol Clásica -->
          <section class="section section--alt" aria-labelledby="clasica-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El favorito para torneos</span>
                <h2 class="showcase__title" id="clasica-heading">Cancha Futbol Clásica</h2>
                <p class="showcase__subtitle">Cancha inflable de 15x8 metros con porterías y red perimetral para partidos 5v5 con rotación de equipos.</p>
                <p class="showcase__text">Nuestra <strong>cancha de futbol inflable clásica</strong> es la opción más popular para eventos deportivos. Con dimensiones de <strong>15x8 metros</strong>, paredes laterales de 1.2 metros y porterías integradas reforzadas, ofrece una experiencia de juego segura y emocionante. La red perimetral superior evita que el balón salga de la cancha, manteniendo el juego fluido y sin interrupciones. Piso antiderrapante de lona reforzada para máxima tracción.</p>
                <p class="showcase__text">Incluye <strong>3 balones profesionales</strong>, chalecos de colores para distinguir equipos, silbato y cronómetro. Nuestro árbitro/coordinador organiza partidos de 7-10 minutos con rotación rápida, permitiendo que hasta 60 personas jueguen en una hora. Perfecta para <strong>torneos corporativos, fiestas de cumpleaños deportivas y eventos familiares</strong>. Combínala con nuestras <a href="/servicios/carpas/">carpas</a> para zona de descanso e hidratación.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">15x8 metros</span>
                  <span class="showcase__tag">Formato 5v5</span>
                  <span class="showcase__tag">Porterías reforzadas</span>
                  <span class="showcase__tag">Red perimetral</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cancha Clásica
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Cancha Futbol Clásica</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cancha Futbol Nocturna LED -->
          <section class="section section--alt" aria-labelledby="nocturna-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Juega de noche con iluminación LED</span>
                <h2 class="showcase__title" id="nocturna-heading">Cancha Futbol Nocturna LED</h2>
                <p class="showcase__subtitle">Cancha inflable con sistema de iluminación LED perimetral para torneos nocturnos espectaculares.</p>
                <p class="showcase__text">Nuestra <strong>cancha de futbol nocturna LED</strong> transforma los torneos nocturnos en una experiencia visual impactante. Equipada con <strong>tiras LED RGB perimetrales</strong> en las paredes laterales y reflectores LED de alto brillo en las esquinas, la cancha se ilumina completamente para jugar con visibilidad total después del atardecer. Los colores LED cambian según la dinámica del partido — rojo para gol, verde para inicio de juego.</p>
                <p class="showcase__text">Ideal para <strong>eventos corporativos nocturnos, fiestas de fin de año y festivales deportivos</strong> al aire libre. La iluminación LED integrada elimina la necesidad de torres de luz externas y crea un ambiente espectacular que atrae a los espectadores. Incluye todo el equipo de la versión clásica más el <strong>sistema LED con controlador DMX</strong> para efectos programados. Combínala con nuestro <a href="/servicios/audiovisual/sonido/">equipo de sonido</a> para ambientar con música la competencia.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Iluminación LED RGB</span>
                  <span class="showcase__tag">Reflectores LED</span>
                  <span class="showcase__tag">Eventos nocturnos</span>
                  <span class="showcase__tag">Controlador DMX</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cancha Nocturna
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Cancha Nocturna LED</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Torneo Corporativo 5v5 -->
          <section class="section section--alt" aria-labelledby="torneo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Team building deportivo</span>
                <h2 class="showcase__title" id="torneo-heading">Torneo Corporativo 5v5</h2>
                <p class="showcase__subtitle">Paquete completo para organizar torneos corporativos con árbitro, marcador digital y premiación.</p>
                <p class="showcase__text">Nuestro <strong>Paquete Torneo Corporativo 5v5</strong> es la solución integral para eventos de team building y días de la familia empresariales. Incluye la cancha de futbol inflable de 15x8 metros, <strong>árbitro profesional certificado</strong>, sistema de marcador digital visible para espectadores, tabla de posiciones actualizada en tiempo real, chalecos numerados para hasta 8 equipos y cronómetro con alarma sonora.</p>
                <p class="showcase__text">El paquete contempla la organización completa del torneo: <strong>sorteo de grupos, cuadros de eliminación, partidos de semifinal y final</strong>, entrega de trofeos y diploma de participación. Nuestro coordinador gestiona toda la logística deportiva mientras tú disfrutas del evento. Perfecto para empresas de 40 a 80 participantes. Combínalo con nuestro <a href="/servicios/catering/">servicio de catering</a> para zona de hidratación y snacks entre partidos.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Árbitro profesional</span>
                  <span class="showcase__tag">Marcador digital</span>
                  <span class="showcase__tag">Hasta 8 equipos</span>
                  <span class="showcase__tag">Premiación incluida</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Torneo Corporativo
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Torneo Corporativo 5v5</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Mini Cancha 3v3 -->
          <section class="section section--alt" aria-labelledby="mini-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para espacios reducidos</span>
                <h2 class="showcase__title" id="mini-heading">Mini Cancha 3v3</h2>
                <p class="showcase__subtitle">Formato compacto de 10x6 metros perfecto para fiestas infantiles y espacios con área limitada.</p>
