---
/**
 * ─── Basquetbol Gigante Inflable — Pagina de Producto (Nivel 4) ───
 * Canasta de basquetbol gigante inflable con balon sobredimensionado
 * para retos por equipos en corporativos y fiestas.
 *
 * Jerarquia: Servicios > Inflables > Interactivos y Deportivos > Basquetbol Gigante
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Interactivos y Deportivos", href: "/servicios/inflables/interactivos-deportivos/" },
  { label: "Basquetbol Gigante" },
];

const faqs = [
  { question: "¿Cuántos jugadores pueden participar en el basquetbol gigante?", answer: "El basquetbol gigante permite de <strong>2 a 6 jugadores por ronda</strong>. En formato de reto individual, cada participante tiene 60 segundos para encestar la mayor cantidad de tiros. En formato de equipos, se enfrentan grupos de 2-3 personas con acumulación de puntos. La rotación es rápida — cada ronda dura 2-3 minutos — lo que permite que en una hora participen hasta 60-80 personas." },
  { question: "¿Qué edades son adecuadas para el basquetbol gigante?", answer: "El basquetbol gigante es apto para participantes desde <strong>6 años en adelante</strong>. El balón sobredimensionado de foam es seguro y ligero, ideal para niños y adultos. No hay restricción de peso ya que los participantes no suben a la estructura inflable, solo lanzan el balón desde la zona de tiro. Nuestro coordinador ajusta la distancia de tiro según la edad de los participantes." },
  { question: "¿Cuánto espacio necesito para el basquetbol gigante?", answer: "El basquetbol gigante requiere un área de <strong>5x4 metros</strong> para la estructura inflable más <strong>3 metros adicionales</strong> al frente para la zona de tiro, un total de aproximadamente 8x4 metros. La altura mínima de techo para interiores es de <strong>5 metros</strong>. Se instala sobre cualquier superficie plana: pasto, concreto, madera o alfombra." },
  { question: "¿El basquetbol gigante funciona en interiores y exteriores?", answer: "Sí, funciona perfectamente en <strong>ambos entornos</strong>. En exteriores se ancla con estacas en pasto o contrapesos en concreto. En interiores necesitas un techo mínimo de 5 metros. En caso de viento fuerte se recomienda reubicar en zona protegida. Es uno de nuestros juegos más versátiles por su tamaño compacto y facilidad de instalación." },
  { question: "¿Se pueden organizar retos y torneos con el basquetbol?", answer: "Por supuesto. Nuestro <strong>Kit Basquetbol + Premiación</strong> incluye coordinador de retos, sistema de puntuación por rondas con marcador digital visible, tabla de posiciones y medallas para los tres primeros lugares. Organizamos diferentes modalidades: <strong>tiros cronometrados, eliminación por rondas, reto de distancia</strong> y competencia por equipos. El coordinador mantiene la energía y emoción durante todo el evento." },
  { question: "¿Se puede combinar el basquetbol con otros juegos inflables?", answer: "Sí, los combos son nuestra opción más popular. El <strong>Paquete Deportivo</strong> combina basquetbol gigante con <a href=\"/servicios/inflables/interactivos-deportivos/cancha-futbol/\">cancha de futbol inflable</a> para crear una zona deportiva completa. También puedes agregar <a href=\"/servicios/inflables/interactivos-deportivos/bungee-run/\">bungee run</a> o <a href=\"/servicios/inflables/interactivos-deportivos/juegos-destreza/\">juegos de destreza</a>. Al combinar 2 o más juegos ofrecemos <strong>descuentos de hasta 20%</strong>." },
];

const specs = [
  { label: "Altura", value: "4 metros con tablero reforzado" },
  { label: "Aro", value: "Profesional reforzado con red" },
  { label: "Área juego", value: "5x4 metros zona de tiro" },
  { label: "Balón", value: "Foam sobredimensionado seguro" },
  { label: "Jugadores", value: "2-6 por ronda" },
  { label: "Edad mínima", value: "6 años" },
  { label: "Peso máximo", value: "Sin restricción" },
  { label: "Material", value: "Lona vinílica 18 oz + foam" },
  { label: "Coordinador", value: "Incluido durante el evento" },
  { label: "Inflador", value: "Continuo 1.5 HP, 110V" },
];

const sidebarNav = [
  { name: "Cancha Futbol Inflable", href: "/servicios/inflables/interactivos-deportivos/cancha-futbol/" },
  { name: "Basquetbol Gigante", href: null, active: true },
  { name: "Bungee Run", href: "/servicios/inflables/interactivos-deportivos/bungee-run/" },
  { name: "Juegos de Destreza", href: "/servicios/inflables/interactivos-deportivos/juegos-destreza/" },
];

const sidebarRelated = [
  { name: "Inflables para Adultos", href: "/servicios/inflables/adultos/" },
  { name: "Juegos Infantiles", href: "/servicios/inflables/juegos-infantiles/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Audiovisual y Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
];

const reviews = [
  { author: "Andrea Gutiérrez", text: "Rentamos el basquetbol gigante para nuestro evento corporativo de fin de año en un hotel de Santa Fe. Fue la atracción más popular de la noche. El coordinador organizó un torneo por departamentos y todos se divirtieron muchísimo. El equipo llegó puntual y la instalación fue rapidísima. Excelente servicio.", rating: 5, date: "2025-11-28" },
  { author: "Fernando Castillo", text: "Lo usamos para la fiesta de mi hijo adolescente y fue un éxito total. Los chicos no pararon de competir durante 3 horas. El balón de foam es seguro y el aro se ve espectacular. El coordinador fue muy amable y organizó retos creativos que mantuvieron a todos entretenidos. Lo recomiendo ampliamente.", rating: 5, date: "2025-10-12" },
  { author: "Sofía Ramírez", text: "Contratamos el basquetbol gigante para la feria escolar de nuestro colegio. Más de 150 niños participaron durante el día. La estructura se veía impecable, el operador fue muy profesional y los niños estaban felices. Los papás también se animaron a competir. Definitivamente lo rentaremos de nuevo.", rating: 5, date: "2025-09-08" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Basquetbol Gigante Inflable para Eventos en CDMX",
    description: "Renta de canasta de basquetbol gigante inflable con balón sobredimensionado para retos por equipos. Diversión garantizada para todas las edades. Desde $2,000.",
    url: "/servicios/inflables/interactivos-deportivos/basquetbol-gigante/",
    priceRange: { min: 2000, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 134,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Interactivos y Deportivos", url: "/servicios/inflables/interactivos-deportivos/" },
    { name: "Basquetbol Gigante", url: "/servicios/inflables/interactivos-deportivos/basquetbol-gigante/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Basquetbol Gigante Inflable en CDMX | EVENTECH"
  description="Renta de canasta de basquetbol gigante inflable con balón sobredimensionado para retos por equipos. Diversión garantizada para todas las edades. Desde $2,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Retos y tiros imposibles"
    title='Renta de <span class="highlight">Basquetbol Gigante</span> Inflable para Eventos'
    subtitle="Canasta de basquetbol gigante inflable de 4 metros de altura con tablero reforzado, aro profesional y balón sobredimensionado de foam. Coordinador de retos y sistema de puntuación incluidos."
    primaryCTA={{ label: "Cotiza tu basquetbol", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar basquetbol gigante inflable para mi evento` }}
    cards={[
      {
        title: "Canasta gigante de 4 metros con balón sobredimensionado",
        content: "<strong>Canasta de basquetbol gigante inflable</strong> de 4 metros de altura con tablero reforzado, aro profesional y zona de tiro acolchada. Balón sobredimensionado de foam seguro para todas las edades. Estructura inflable de 5x4 metros fabricada en lona vinílica de 18 oz con costuras termoselladas. Zona de tiro demarcada con diferentes distancias para retos progresivos de dificultad.",
      },
      {
        title: "Coordinador de retos y sistema de puntuación incluido",
        content: "<strong>Coordinador de retos incluido</strong>, sistema de puntuación por rondas, zona delimitada de tiro con diferentes distancias y premiación. Nuestro staff organiza torneos de eliminación, retos cronometrados y competencias por equipos. Incluye transporte, instalación con anclaje profesional, inflado continuo y desmontaje sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres retos de basquetbol gigante en tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el formato ideal para tu espacio y audiencia"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Interactivos y Deportivos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas basquetbol gigante para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar basquetbol gigante inflable para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12.01" y2="6"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Basquetbol Gigante</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Basquetbol Gigante Clásico -->
          <section class="section section--alt" aria-labelledby="clasico-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Diversión para todas las edades</span>
                <h2 class="showcase__title" id="clasico-heading">Basquetbol Gigante Clásico</h2>
                <p class="showcase__subtitle">Canasta inflable de 4 metros con balón de foam para retos de tiros libres y competencias por rondas.</p>
                <p class="showcase__text">Nuestro <strong>basquetbol gigante clásico</strong> es la versión estándar que garantiza diversión para participantes de todas las edades. La canasta inflable de <strong>4 metros de altura</strong> con tablero reforzado y aro profesional con red ofrece un reto visual impactante. El <strong>balón sobredimensionado de foam</strong> es seguro, ligero y fácil de manejar, permitiendo que desde niños de 6 años hasta adultos disfruten de la competencia.</p>
                <p class="showcase__text">Incluye zona de tiro demarcada con <strong>3 distancias diferentes</strong> (fácil, media y difícil) para crear retos progresivos. Nuestro coordinador organiza rondas de 60 segundos donde cada participante intenta encestar la mayor cantidad de tiros. Perfecto para <strong>fiestas de cumpleaños, eventos sociales y kermeses</strong>. La rotación rápida permite máxima participación con mínimo tiempo de espera.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">4 metros de altura</span>
                  <span class="showcase__tag">Balón de foam</span>
                  <span class="showcase__tag">3 distancias de tiro</span>
                  <span class="showcase__tag">Todas las edades</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Basquetbol Clásico
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Basquetbol Gigante Clásico</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Basquetbol con Marcador Digital -->
          <section class="section section--alt" aria-labelledby="marcador-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Competencia con tecnología</span>
                <h2 class="showcase__title" id="marcador-heading">Basquetbol con Marcador Digital</h2>
                <p class="showcase__subtitle">Versión premium con pantalla de marcador digital visible para espectadores y sistema de puntuación automático.</p>
                <p class="showcase__text">Nuestra versión <strong>Basquetbol con Marcador Digital</strong> eleva la experiencia competitiva con un <strong>sistema de puntuación visible</strong> para todos los espectadores. Una pantalla LED muestra en tiempo real los puntos de cada participante o equipo, el cronómetro regresivo y la tabla de posiciones del torneo. El marcador se actualiza automáticamente y genera momentos de emoción cuando los competidores se acercan en puntuación.</p>
                <p class="showcase__text">Ideal para <strong>eventos corporativos y activaciones de marca</strong> donde la competencia organizada es clave. Incluye todo el equipo del basquetbol clásico más el sistema de marcador digital, bocina con efectos de sonido para gol y error, y coordinador especializado en dinámicas competitivas. Combínalo con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para transmitir el marcador en pantallas adicionales distribuidas por el evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Marcador digital LED</span>
                  <span class="showcase__tag">Cronómetro visible</span>
                  <span class="showcase__tag">Efectos de sonido</span>
                  <span class="showcase__tag">Tabla de posiciones</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar con Marcador Digital
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Basquetbol con Marcador</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Reto de Tiros por Equipos -->
          <section class="section section--alt" aria-labelledby="reto-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Team building perfecto</span>
                <h2 class="showcase__title" id="reto-heading">Reto de Tiros por Equipos</h2>
                <p class="showcase__subtitle">Formato de competencia grupal con eliminación por rondas, ideal para corporativos y team building.</p>
                <p class="showcase__text">Nuestro <strong>Reto de Tiros por Equipos</strong> transforma el basquetbol gigante en una actividad de team building estructurada. Los participantes se dividen en equipos de 3-5 personas y compiten en <strong>rondas de eliminación</strong> donde cada equipo acumula puntos con los tiros de todos sus integrantes. La estrategia grupal es clave: ¿enviar al mejor tirador en la ronda final o repartir oportunidades?</p>
                <p class="showcase__text">El formato incluye <strong>fase de grupos, semifinales y gran final</strong> con tabla de posiciones en tiempo real. Nuestro coordinador organiza toda la logística deportiva: sorteo de grupos, tiempos de descanso entre rondas y ceremonia de premiación con trofeos. Perfecto para <strong>empresas de 20 a 100 participantes</strong>. Combínalo con nuestro <a href="/servicios/catering/">servicio de catering</a> para zona de hidratación y snacks entre rondas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Equipos de 3-5</span>
                  <span class="showcase__tag">Eliminación por rondas</span>
                  <span class="showcase__tag">Premiación incluida</span>
                  <span class="showcase__tag">20-100 participantes</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Reto por Equipos
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Reto de Tiros por Equipos</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Basquetbol + Premiación -->
          <section class="section section--alt" aria-labelledby="kit-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Paquete completo</span>
                <h2 class="showcase__title" id="kit-heading">Kit Basquetbol + Premiación</h2>
                <p class="showcase__subtitle">Paquete premium con basquetbol gigante, marcador digital, coordinador de torneo y kit completo de premiación.</p>
                <p class="showcase__text">Nuestro <strong>Kit Basquetbol + Premiación</strong> es la opción todo incluido para eventos donde quieres una actividad deportiva memorable con producción profesional. Incluye el basquetbol gigante inflable, <strong>marcador digital LED</strong>, sistema de sonido con efectos y música ambiental, coordinador especializado en dinámicas deportivas, y un <strong>kit de premiación completo</strong> con trofeos dorados para 1er, 2do y 3er lugar.</p>
