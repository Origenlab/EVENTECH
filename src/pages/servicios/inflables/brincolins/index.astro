                Enviar por WhatsApp
              </button>
              <p class="hm-form__note">Se abrirá WhatsApp con tu consulta. Sin compromiso.</p>
            </form>
          </aside>
        </div>
      </div>
    </section>

  </div><!-- /hm -->

  <script>
    const brForm = document.getElementById("brForm");
    if (brForm) {
      brForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const f = e.currentTarget as HTMLFormElement;
        const wa = f.dataset.wa;
        const data = new FormData(f);
        const get = (k: string) => (data.get(k) || "").toString().trim();
        let t = "Hola, quiero cotizar un paquete de fiesta con inflable.";
        if (get("paquete"))   t += `\nPaquete: ${get("paquete")}`;
        if (get("nombre"))    t += `\nNombre: ${get("nombre")}`;
        if (get("invitados")) t += `\nInvitados: ${get("invitados")}`;
        if (get("fecha"))     t += `\nFecha: ${get("fecha")}`;
        if (get("modelo"))    t += `\nInflable: ${get("modelo")}`;
        if (get("zona"))      t += `\nZona: ${get("zona")}`;
        if (get("mensaje"))   t += `\nDetalles: ${get("mensaje")}`;
        window.open(`https://wa.me/${wa}?text=${encodeURIComponent(t)}`, "_blank", "noopener");
      });
    }
  </script>
</PageLayout>

<style>
