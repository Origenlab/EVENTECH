                  <option value="">No estoy seguro, asesórenme</option>
                  <option>Básico — hasta 30 invitados, 4 hrs</option>
                  <option>Premium — hasta 50 invitados, 6 hrs</option>
                  <option>VIP — hasta 80 invitados, 6 hrs</option>
