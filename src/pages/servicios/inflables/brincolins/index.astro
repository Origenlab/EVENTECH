                <span>Número de invitados</span>
                <input type="number" name="invitados" min="1" placeholder="Ej. 45" />
              </label>

              <label class="hm-form__field">
                <span>Fecha del evento</span>
                <input type="date" name="fecha" />
              </label>

              <label class="hm-form__field">
                <span>¿Qué inflable te interesa?</span>
