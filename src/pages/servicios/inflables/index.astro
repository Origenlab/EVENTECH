---
/**
 * ─── Inflables Category Page ───
 * Página de categoría: Renta de Inflables para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CategoryCard from "@components/CategoryCard.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import CtaBar from "@components/CtaBar.astro";
import Gallery4x4 from "@components/Gallery4x4.astro";
import FaqSection from "@components/FaqSection.astro";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables" },
];

const SUB_SERVICES = [
  {
    name: "Juegos Infantiles",
    excerpt: "Brincolines, toboganes inflables, castillos y circuitos de obstáculos diseñados para niños de 3 a 12 años. Diversión segura y supervisada para fiestas infantiles.",
    href: "/servicios/inflables/juegos-infantiles/",
    image: "/images/inflables/castillo-inflable-fiesta-infantil.avif",
    subcategories: [
      { name: "Brincolines y Castillos", href: "/servicios/inflables/juegos-infantiles/brincolines/" },
      { name: "Toboganes Inflables", href: "/servicios/inflables/juegos-infantiles/toboganes/" },
      { name: "Circuitos de Obstáculos", href: "/servicios/inflables/juegos-infantiles/circuitos-obstaculos/" },
      { name: "Inflables Temáticos", href: "/servicios/inflables/juegos-infantiles/tematicos/" },
    ],
  },
  {
    name: "Inflables Acuáticos",
    excerpt: "Toboganes de agua, albercas inflables, resbaladillas splash y circuitos acuáticos para eventos al aire libre en temporada de calor. Máxima diversión refrescante.",
    href: "/servicios/inflables/acuaticos/",
    image: "/images/inflables/tobogan-inflable-agua-verano.avif",
    subcategories: [
      { name: "Toboganes de Agua", href: "/servicios/inflables/acuaticos/toboganes-agua/" },
      { name: "Albercas Inflables", href: "/servicios/inflables/acuaticos/albercas/" },
      { name: "Resbaladillas Splash", href: "/servicios/inflables/acuaticos/resbaladillas-splash/" },
      { name: "Circuitos Acuáticos", href: "/servicios/inflables/acuaticos/circuitos-acuaticos/" },
    ],
  },
  {
    name: "Juegos para Adultos",
    excerpt: "Toro mecánico, futbolito humano, gladiadores, sumo wrestling y pistas de obstáculos extremas. Activaciones dinámicas para corporativos, team buildings y fiestas.",
    href: "/servicios/inflables/adultos/",
    image: "/images/inflables/inflable-obstaculos-kermesse.avif",
    subcategories: [
      { name: "Toro Mecánico", href: "/servicios/inflables/adultos/toro-mecanico/" },
      { name: "Futbolito Humano", href: "/servicios/inflables/adultos/futbolito-humano/" },
      { name: "Gladiadores y Sumo", href: "/servicios/inflables/adultos/gladiadores-sumo/" },
      { name: "Obstáculos Extremos", href: "/servicios/inflables/adultos/obstaculos-extremos/" },
    ],
  },
  {
    name: "Interactivos y Deportivos",
    excerpt: "Cancha de futbol inflable, basquetbol gigante, boxing ring, bungee run y juegos de destreza. Entretenimiento competitivo para eventos de cualquier escala.",
    href: "/servicios/inflables/interactivos-deportivos/",
    image: "/images/inflables/inflable-evento-01.avif",
    subcategories: [
      { name: "Cancha de Futbol", href: "/servicios/inflables/interactivos-deportivos/futbol-inflable/" },
      { name: "Basquetbol Gigante", href: "/servicios/inflables/interactivos-deportivos/basquetbol-gigante/" },
      { name: "Bungee Run", href: "/servicios/inflables/interactivos-deportivos/bungee-run/" },
      { name: "Circuito Multijuego", href: "/servicios/inflables/interactivos-deportivos/circuito-multijuego/" },
    ],
  },
];

const faqs = [
  { question: "¿Qué edades son adecuadas para los inflables?", answer: "Manejamos inflables segmentados por edad: juegos infantiles para niños de 3 a 12 años con alturas y complejidad apropiadas, y juegos para adolescentes y adultos como toro mecánico, futbolito humano, gladiadores y pistas de obstáculos extremas sin restricción de edad (sujeto a condiciones de salud). Cada inflable incluye señalización con capacidad máxima y rango de edad recomendado. Para fiestas mixtas con niños y adultos, armamos paquetes combinados con juegos para todas las edades." },
  { question: "¿Los inflables incluyen monitor o supervisor?", answer: "Sí. Todos nuestros paquetes incluyen al menos un monitor certificado por cada inflable que supervisa el uso correcto, controla la capacidad, asiste a los participantes y garantiza la seguridad durante todo el evento. Para eventos grandes con múltiples inflables asignamos un equipo de 2-4 monitores con coordinador. Los monitores están capacitados en primeros auxilios básicos y manejo de emergencias." },
  { question: "¿Qué espacio se necesita para instalar un inflable?", answer: "Depende del modelo. Los brincolines infantiles estándar requieren un área mínima de 5x5 metros con 3 metros de altura libre. Los toboganes grandes y circuitos de obstáculos pueden necesitar hasta 15x5 metros. Las pistas de obstáculos extremas requieren hasta 20x6 metros. Siempre necesitamos al menos 1.5 metros de espacio libre alrededor del inflable por seguridad. Nuestro equipo evalúa tu espacio disponible y recomienda los modelos que mejor se adaptan." },
  { question: "¿Se pueden instalar en interiores?", answer: "Sí, siempre que el espacio cumpla con los requisitos de altura libre (mínimo 3 metros para infantiles, 5 metros para toboganes grandes) y ventilación adecuada. En interiores se requiere acceso a tomas de corriente de 110V para los motores de inflado continuo. Protegemos el piso del venue con lonas de PVC para evitar cualquier daño. Algunos modelos como el toro mecánico y los juegos de sumo son especialmente populares para salones cerrados." },
  { question: "¿Qué pasa si llueve durante el evento?", answer: "Los inflables secos (brincolines, toboganes, obstáculos) se operan perfectamente con lluvia ligera. En caso de lluvia intensa o tormenta eléctrica, el protocolo de seguridad indica desalojar y desinflar temporalmente hasta que las condiciones mejoren. Los inflables acuáticos están diseñados para operar con agua por lo que la lluvia no afecta su funcionamiento. Todos nuestros inflables están fabricados con lona de PVC laminado de 18 oz resistente a condiciones climáticas." },
  { question: "¿Con cuánta anticipación debo reservar?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación para garantizar disponibilidad del modelo que deseas. En temporada alta (abril a agosto para acuáticos, octubre a diciembre para fiestas) lo ideal es apartar con 4 a 6 semanas. Para eventos corporativos o escolares con múltiples inflables, sugerimos contactarnos con al menos 1 mes de anticipación para diseñar el layout óptimo y garantizar el inventario completo." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Inflables para Eventos en CDMX",
    description: "Brincolines, toboganes, toro mecánico, inflables acuáticos y juegos interactivos para fiestas infantiles, corporativos y eventos en CDMX. Monitor incluido.",
    url: "/servicios/inflables/",
    priceRange: { min: 1500, max: 45000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Inflables para Eventos"
  description="Renta de inflables para fiestas y eventos en CDMX: brincolines, toboganes, toro mecánico, inflables acuáticos y juegos interactivos con monitor incluido."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diversión garantizada con supervisión profesional"
    title='Renta de <span class="highlight">Inflables para Eventos</span> en CDMX'
    subtitle="Brincolines, toboganes, toro mecánico, inflables acuáticos, futbolito humano y juegos interactivos con monitor certificado incluido. La diversión segura y espectacular que hace de cualquier fiesta infantil, corporativo o evento social una experiencia inolvidable para todas las edades."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar inflables para mi evento en CDMX` }}
    cards={[
      {
        title: "Inflables comerciales certificados con lona de grado industrial",
        content: "<strong>Renta de inflables para eventos</strong> fabricados con los más altos estándares de seguridad. Lona de PVC laminado de 18 oz con costura cuádruple reforzada, certificación ASTM F2374 para uso comercial y sistema de anclaje con estacas de acero o lastres de arena según el terreno. Cada inflable cuenta con <strong>motores de inflado continuo UL Listed</strong> que mantienen la presión constante, redes de seguridad perimetrales, rampas de acceso acolchadas y deflectores internos que amortiguan caídas. Inspección y sanitización profesional antes de cada evento.",
      },
      {
        title: "Servicio llave en mano con monitor y logística completa",
        content: "<strong>Servicio integral de inflables</strong> que incluye entrega, montaje profesional, <strong>monitor certificado en primeros auxilios</strong> durante todo el evento y desmontaje al finalizar. Nuestro equipo evalúa tu espacio disponible — jardín, salón, explanada o parque — para recomendar los modelos ideales según el número de asistentes, edades y tipo de evento. Diseñamos layouts con zonas de seguridad perimetral y flujo de circulación óptimo. Complementa con <strong>carpas para sombra, mobiliario infantil</strong> y área de hidratación para un evento completamente organizado.",
      },
    ]}
  />

  <CtaBar headline="¿Qué inflables necesitas?" items={[
    { label: "Infantiles", href: "/servicios/inflables/juegos-infantiles/", icon: "inflables" },
    { label: "Acuáticos", href: "/servicios/inflables/acuaticos/", icon: "inflables" },
    { label: "Adultos", href: "/servicios/inflables/adultos/", icon: "inflables" },
    { label: "Interactivos", href: "/servicios/inflables/interactivos-deportivos/", icon: "inflables" },
  ]} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="La diversión que hace memorable cualquier celebración"
    subheadline="Recibe una propuesta personalizada con los inflables ideales según tu espacio, edades de los invitados y tipo de evento — sin compromiso"
    primaryCTA={{ label: "Cotizar inflables", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Inflables"
        subtitle="Diversión para todas las edades y tipos de evento"
        description={[
          "Desde un brincolin clásico para una fiesta infantil en un jardín de Coyoacán hasta un circuito completo de juegos extremos para un team building corporativo en Santa Fe — contamos con el inventario más completo de inflables para eventos en la Ciudad de México y zona metropolitana.",
          "Cada inflable incluye montaje profesional, monitor certificado en primeros auxilios y sanitización completa previa. No solo rentamos juegos: creamos experiencias de diversión segura que niños, adolescentes y adultos disfrutan por igual."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <CategoryCard
            title={sub.name}
            subtitle={sub.excerpt}
            href={sub.href}
            image={sub.image}
            subcategories={sub.subcategories}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       JUEGOS INFANTILES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="infantiles-heading">
    <div class="container">
      <ServiceShowcase
    title="Juegos Inflables Infantiles"
    headingId="infantiles-heading"
    badge="Lo más solicitado para fiestas infantiles"
    subtitle="Brincolines, toboganes inflables, castillos y circuitos de obstáculos diseñados específicamente para niños de 3 a 12 años con máxima seguridad y diversión garantizada."
    tags={["Brincolines 4x4m", "Castillos Temáticos", "Tobogán 6-10m", "Circuito Obstáculos", "3-12 Años", "ASTM F2374"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Juegos Infantiles"
  >
    <Fragment slot="body">
      <p class="showcase__text">Nuestros <strong>juegos infantiles inflables</strong> son la estrella de toda fiesta para niños. Los <strong>brincolines clásicos</strong> de 4x4m y 5x5m con paredes perimetrales de red y rampa de acceso acolchada son perfectos para fiestas de cumpleaños de 15 a 40 niños. Los <strong>castillos inflables temáticos</strong> — princesas, superhéroes, piratas y dinosaurios — miden entre 5x5m y 7x7m con tobogán integrado, zona de salto y área de juego interactivo. Cada juego está fabricado con <strong>lona de PVC de 18 oz con costura cuádruple</strong> y cuenta con certificación ASTM F2374.</p>
      <p class="showcase__text">Los <strong>toboganes inflables gigantes</strong> de 6 a 10 metros de altura son el hit de cualquier evento infantil — con escalera de acceso segura con pasamanos, canal de deslizamiento doble para mayor capacidad y zona de aterrizaje acolchada. Los <strong>circuitos de obstáculos infantiles</strong> de 12 a 18 metros de largo combinan túneles, escaleras, toboganes y zonas de salto para una experiencia completa de aventura. Complementa con <a href="/servicios/mobiliario/">mobiliario infantil</a> — mesas y sillas coloridas — y una <a href="/servicios/carpas/">carpa de sombra</a> para los papás.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/inflables/castillo-inflable-fiesta-infantil.avif"
            alt="Castillo inflable para fiestas infantiles en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       INFLABLES ACUÁTICOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="acuaticos-heading">
    <div class="container">
      <ServiceShowcase
    title="Inflables Acuáticos para Eventos"
    headingId="acuaticos-heading"
    badge="Temporada de calor: marzo a septiembre"
    subtitle="Toboganes de agua gigantes, resbaladillas splash, albercas inflables y circuitos acuáticos para eventos al aire libre. La opción perfecta para combatir el calor con diversión refrescante."
    tags={["Tobogán Agua 8-12m", "Slip & Slide 20m", "Chapoteadero", "Alberca 4x6m", "Aspersores", "Marzo - Septiembre"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Acuáticos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>inflables acuáticos</strong> transforman cualquier jardín en un parque acuático privado. Nuestros <strong>toboganes de agua gigantes</strong> de 8 a 12 metros de altura con doble canal de deslizamiento y zona de splash aterrizaje son la atracción estrella de eventos al aire libre entre marzo y septiembre. Las <strong>resbaladillas slip & slide</strong> de 12 a 20 metros de largo con sistema de aspersión continua crean la experiencia de deslizamiento acuático más divertida — perfectas para fiestas de adolescentes, cumpleaños y eventos de verano.</p>
      <p class="showcase__text">Los <strong>circuitos acuáticos completos</strong> combinan tobogán, zona de salto con chapoteadero, aspersores y alberca de aterrizaje en un solo sistema de 15 a 25 metros de largo. Las <strong>albercas inflables</strong> de 3x5m y 4x6m con profundidad controlada de 30 a 60 cm son seguras para niños pequeños. Todos los inflables acuáticos incluyen <strong>sistema de recirculación de agua</strong> con bomba y manguera de conexión estándar. Solo necesitas una toma de agua y corriente eléctrica — nuestro equipo se encarga del resto. Complementa con <a href="/servicios/carpas/">carpas de sombra</a> y <a href="/servicios/mobiliario/">camastros y mesas</a> para crear tu pool party perfecta.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/inflables/tobogan-inflable-agua-verano.avif"
            alt="Tobogán inflable de agua para eventos y fiestas de verano en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       JUEGOS PARA ADULTOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="adultos-heading">
    <div class="container">
      <ServiceShowcase
    title="Inflables para Adultos"
    headingId="adultos-heading"
    badge="Activaciones corporativas y team building"
    subtitle="Toro mecánico, futbolito humano, gladiadores inflables, sumo wrestling y pistas de obstáculos extremas. Las activaciones dinámicas que rompen el hielo y generan momentos épicos."
    tags={["Toro Mecánico", "Futbolito Humano", "Gladiadores", "Sumo Wrestling", "Obstáculos 30m", "Team Building"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Juegos Adultos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>juegos inflables para adultos</strong> son el diferenciador que transforma un evento corporativo convencional en una experiencia memorable. Nuestro <strong>toro mecánico profesional</strong> con colchón de seguridad de 5x5m, velocidad regulable y operador dedicado es la atracción más fotografiada en fiestas empresariales, posadas y celebraciones de fin de año. El <strong>futbolito humano inflable</strong> para 12 jugadores simultáneos convierte cualquier explanada en una cancha de competencias por equipos — ideal para team buildings donde se busca fomentar trabajo en equipo.</p>
      <p class="showcase__text">Los <strong>gladiadores inflables</strong> con pedestales acolchados y bastones de espuma, el <strong>sumo wrestling</strong> con trajes acolchados gigantes y el <strong>boxing ring inflable</strong> con guantes oversized crean competencias hilarantes perfectas para romper el hielo en grupos corporativos. Las <strong>pistas de obstáculos extremas</strong> de 20 a 30 metros con escalada, túneles, redes y toboganes son la opción premium para team buildings competitivos y eventos deportivos. Combina con <a href="/servicios/audiovisual/">equipo de sonido profesional</a> para musicalizar las competencias y <a href="/servicios/iluminacion/">iluminación</a> para eventos nocturnos.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/inflables/inflable-obstaculos-kermesse.avif"
            alt="Inflable de obstáculos para adultos en eventos y kermeses en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       INTERACTIVOS Y DEPORTIVOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="interactivos-heading">
    <div class="container">
      <ServiceShowcase
    title="Inflables Interactivos y Deportivos"
    headingId="interactivos-heading"
    badge="Competencias y entretenimiento activo"
    subtitle="Cancha de futbol inflable, basquetbol gigante, bungee run, juegos de destreza y simuladores deportivos inflables. Entretenimiento competitivo que involucra a todos los asistentes."
    tags={["Futbol Inflable 12x6m", "Basquetbol Gigante", "Bungee Run", "Wipeout", "Circuito Multijuego", "Kit Competencia"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Interactivos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Los <strong>juegos interactivos y deportivos inflables</strong> llevan la competencia amistosa a otro nivel. Nuestra <strong>cancha de futbol inflable</strong> de 12x6m con paredes perimetrales y porterías integradas permite partidos de 5 vs 5 en cualquier espacio — desde jardines hasta explanadas corporativas. El <strong>basquetbol gigante</strong> con canastas de 3 metros y pelotas oversized, el <strong>bungee run</strong> doble con arnés elástico donde dos competidores corren en sentido opuesto, y los <strong>juegos de puntería con dardos velcro gigantes</strong> ofrecen entretenimiento para todas las edades simultáneamente.</p>
      <p class="showcase__text">Para eventos más grandes, ofrecemos <strong>circuitos multijuego</strong> que combinan 4 a 8 estaciones inflables en un recorrido competitivo por equipos con sistema de puntuación — perfecto para kermeses escolares, family days corporativos y eventos comunitarios. El <strong>wipeout inflable</strong> con brazo giratorio y plataformas de equilibrio es la atracción más viral en redes sociales — ideal para activaciones de marca. Cada juego incluye <strong>monitor dedicado y kit de competencia</strong> (silbatos, cronómetros, marcadores). Complementa con <a href="/servicios/carpas/">carpas de sombra</a> para zonas de descanso y <a href="/servicios/audiovisual/">sonido ambiental</a> para musicalizar las actividades.</p>
    </Fragment>
    <Fragment slot="media">
      <img
            src="/images/inflables/inflable-evento-01.avif"
            alt="Juegos inflables interactivos y deportivos para eventos en CDMX"
            width="800" height="600"
            loading="lazy" decoding="async"
            class="showcase__img"
          />
    </Fragment>
  </ServiceShowcase>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════════════
       GALERÍA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="galeria-heading">
    <div class="container">
      <h2 id="galeria-heading" style="font-size: var(--text-2xl); font-weight: 800; color: var(--color-primary); margin-bottom: 2rem;">¿Cómo lucen nuestros inflables para eventos?</h2>
      <Gallery4x4 images={[
        { src: "/images/inflables/castillo-inflable-fiesta-infantil.avif", alt: "Castillo inflable fiesta infantil" },
        { src: "/images/inflables/alberca-inflable-fiesta-acuatica.avif", alt: "Alberca inflable fiesta acuática" },
        { src: "/images/inflables/inflable-obstaculos-kermesse.avif", alt: "Inflable obstáculos kermesse" },
        { src: "/images/inflables/tobogan-inflable-agua-verano.avif", alt: "Tobogán inflable agua verano" },
        { src: "/images/mobiliario/silla-tiffany-dorada-boda-gala-01.avif", alt: "Silla Tiffany dorada para boda de gala en CDMX" },
        { src: "/images/mobiliario/salon-mesas-redondas-banquete-montaje.avif", alt: "Salón con mesas redondas montaje banquete" },
