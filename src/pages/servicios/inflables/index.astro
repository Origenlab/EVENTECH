---
/**
 * ─── EVENTECH.MX — Inflables para Eventos (L3, rediseño 2026) ───
 * Renta de inflables: castillos, acuáticos, interactivos y para adultos.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "juegos-infantiles",
    name: "Juegos Infantiles",
    badge: "El favorito de los niños",
    excerpt: "Castillos inflables, brincabrincas y laberintos de colores para fiestas infantiles, kermeses y eventos familiares. Materiales certificados y supervisión de seguridad incluida.",
    href: "/servicios/inflables/juegos-infantiles/",
    image: "/images/inflables/castillo-inflable-fiesta-infantil.avif",
    subcategories: [
      { name: "Castillos Inflables", href: "/servicios/inflables/juegos-infantiles/castillos/" },
      { name: "Brincabrincas Clásicos", href: "/servicios/inflables/juegos-infantiles/brincabrincas/" },
      { name: "Laberintos", href: "/servicios/inflables/juegos-infantiles/laberintos/" },
      { name: "Temáticos", href: "/servicios/inflables/juegos-infantiles/tematicos/" },
    ],
  },
  {
    id: "acuaticos",
    name: "Acuáticos",
    badge: "Para el calor de CDMX",
    excerpt: "Albercas inflables, toboganes de agua y parques acuáticos portátiles. La opción que convierte cualquier jardín en un parque de diversiones de verano.",
    href: "/servicios/inflables/acuaticos/",
    image: "/images/inflables/tobogan-inflable-agua-verano.avif",
    subcategories: [
      { name: "Toboganes de Agua", href: "/servicios/inflables/acuaticos/toboganes/" },
      { name: "Albercas Inflables", href: "/servicios/inflables/acuaticos/albercas/" },
      { name: "Parques Acuáticos", href: "/servicios/inflables/acuaticos/parques/" },
      { name: "Splash Pad", href: "/servicios/inflables/acuaticos/splash-pad/" },
    ],
  },
  {
    id: "interactivos-deportivos",
    name: "Interactivos y Deportivos",
    badge: "Competencia y diversión",
    excerpt: "Obstáculos, arenas de boxeo inflable, escalada, futbolito humano y juegos de competencia para activaciones corporativas, kermeses y eventos donde la participación es el objetivo.",
    href: "/servicios/inflables/interactivos-deportivos/",
    image: "/images/inflables/inflable-obstaculos-kermesse.avif",
    subcategories: [
      { name: "Circuito de Obstáculos", href: "/servicios/inflables/interactivos-deportivos/obstaculos/" },
      { name: "Arena de Boxeo", href: "/servicios/inflables/interactivos-deportivos/boxeo/" },
      { name: "Escalada Inflable", href: "/servicios/inflables/interactivos-deportivos/escalada/" },
      { name: "Futbolito Humano", href: "/servicios/inflables/interactivos-deportivos/futbolito/" },
    ],
  },
  {
    id: "adultos",
    name: "Para Adultos",
    badge: "Sin límite de edad",
    excerpt: "Inflables de gran formato, sumo, mecedoras gigantes y juegos de habilidad diseñados para activaciones corporativas, team building y eventos sociales para adultos.",
    href: "/servicios/inflables/adultos/",
    image: "/images/inflables/alberca-inflable-fiesta-acuatica.avif",
    subcategories: [
      { name: "Sumo Inflable", href: "/servicios/inflables/adultos/sumo/" },
      { name: "Mecedoras Gigantes", href: "/servicios/inflables/adultos/mecedoras/" },
      { name: "Team Building", href: "/servicios/inflables/adultos/team-building/" },
      { name: "Activaciones de Marca", href: "/servicios/inflables/adultos/activaciones/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🛡️",
    title: "Materiales certificados NOM y ASTM",
    body: "Todos nuestros inflables están fabricados en vinilo de PVC de alta densidad, sin plastificantes tóxicos. Certificados para uso con menores en eventos públicos y privados en CDMX.",
  },
  {
    icon: "⚙️",
    title: "Sopladores industriales de respaldo",
    body: "Cada inflable opera con su soplador industrial dedicado más uno de respaldo en sitio. Un soplador que falla no interrumpe el evento — el respaldo entra en segundos.",
  },
  {
    icon: "👷",
    title: "Operador en sitio durante todo el evento",
    body: "Un operador certificado permanece junto al inflable durante toda la renta. Controla aforo, tiempos de uso, seguridad de los participantes y cualquier ajuste de operación.",
  },
  {
    icon: "📐",
    title: "Verificación de espacio antes de confirmar",
    body: "Confirmamos dimensiones del área disponible, altura libre, acceso para instalación y tipo de terreno antes de aceptar cualquier pedido. Sin sorpresas el día del evento.",
  },
  {
    icon: "🧼",
    title: "Desinfección certificada entre eventos",
    body: "Cada inflable se limpia y desinfecta con productos bactericidas aprobados para contacto con piel entre uso y uso. Entregamos certificado de sanitización con cada renta.",
  },
  {
    icon: "🚚",
    title: "Traslado, montaje y desmontaje incluidos",
    body: "El precio de renta incluye transporte, instalación completa y retiro al finalizar. No necesitas contratar flete ni mover un dedo — el inflable llega listo para usar.",
  },
];

const steps = [
  { n: 1, t: "Verificación de espacio", p: "Confirmamos dimensiones del área, altura libre, tipo de terreno y acceso para el vehículo de carga. Sin esta verificación no confirmamos el pedido." },
  { n: 2, t: "Confirmación y reserva", p: "Una vez verificado el espacio, confirmamos disponibilidad del modelo y tamaño. El inflable queda reservado con anticipo del 50%." },
  { n: 3, t: "Instalación en sitio", p: "Nuestro equipo llega 2–3 horas antes del evento para instalar, inflar, verificar estabilidad y dejar el área lista con señalización de seguridad." },
  { n: 4, t: "Operación y retiro", p: "El operador permanece durante todo el evento. Al finalizar, desinflamos, doblamos y retiramos sin dejar rastro en el venue." },
];

const faqs = [
  {
    question: "¿Cuánto espacio necesito para instalar un inflable?",
    answer: "Depende del modelo. Un castillo inflable estándar para niños requiere un área mínima de 5×5 m con al menos 4 m de altura libre. Un tobogán de agua puede requerir 8×4 m con 5 m de altura libre. Un circuito de obstáculos puede ocupar desde 12×4 m. Siempre confirmamos las dimensiones exactas del área disponible en tu venue antes de confirmar el pedido — si el espacio no es suficiente, lo decimos antes, no el día del evento.",
  },
  {
    question: "¿Los inflables se pueden instalar en jardines con pasto?",
    answer: "Sí. El pasto es de hecho la superficie ideal para la mayoría de los inflables — amortigua mejor que el concreto y reduce el riesgo de lesiones por caídas. Para inflables acuáticos el pasto también es perfecto. Sobre concreto o loseta colocamos tapetes de protección debajo del inflable. Lo que no recomendamos es instalar sobre superficies con piedras, raíces expuestas o pendientes mayores a 5%.",
  },
  {
    question: "¿Los inflables acuáticos necesitan conexión de agua especial?",
    answer: "Solo requieren una toma de agua estándar de jardín (manguera de ½ pulgada). El llenado inicial de una alberca inflable tarda entre 20 y 45 minutos según el modelo. Los toboganes funcionan con una manguera conectada en la parte superior que mantiene la superficie húmeda durante el evento. No necesitas presión especial ni instalación hidráulica.",
  },
  {
    question: "¿Se incluye operador durante el evento?",
    answer: "Sí, siempre. Todos nuestros inflables se rentan con operador certificado incluido que permanece junto al equipo durante toda la renta. El operador controla el aforo (número máximo de participantes simultáneos), hace cumplir las reglas de uso, supervisa la seguridad y opera el soplador. Sin operador no rentamos — es parte del servicio estándar.",
  },
  {
    question: "¿Tienen inflables para eventos corporativos o adultos?",
    answer: "Sí. Nuestra línea de inflables para adultos incluye arenas de sumo, circuitos de obstáculos de alto rendimiento, escalada inflable, futbolito humano y mecedoras gigantes — todos diseñados para activaciones corporativas, team building y eventos sociales para adultos. También diseñamos activaciones de marca con inflables personalizados con el logo o colores de la empresa.",
  },
  {
    question: "¿Cuánto tiempo antes hay que reservar?",
    answer: "Recomendamos reservar con 2–3 semanas de anticipación para fechas entre semana, y 4–6 semanas para fines de semana y temporada alta (diciembre, febrero, julio). Para eventos corporativos con inflables personalizados (impresos con logo) necesitamos al menos 4 semanas por el tiempo de producción del vinil.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Inflables para Eventos en CDMX",
    description: "Renta de castillos inflables, toboganes de agua, circuitos de obstáculos e inflables para adultos en CDMX. Operador certificado y traslado incluidos.",
    url: "/servicios/inflables/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables para Eventos", url: "/servicios/inflables/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables para Eventos" },
];
---

<PageLayout
  title="Renta de Inflables para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/inflables/castillo-inflable-fiesta-infantil.avif"
  description="Renta de inflables en CDMX: castillos, toboganes, obstáculos y juegos para adultos. Operador certificado y sanitización incluidos. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="inflables-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Renta de inflables · CDMX y ZMVM</p>
            <h1 id="inflables-hero-heading">
              Inflables que convierten cualquier espacio en un lugar donde <em>nadie quiere irse</em>
            </h1>
            <p class="hm-hero__lead">
              Castillos, toboganes de agua, circuitos de obstáculos e inflables para adultos.
              Operador certificado incluido, materiales sanitizados entre eventos y traslado
              sin costo adicional en CDMX y zona metropolitana.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20un%20inflable%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver tipos de inflable
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 600 eventos atendidos con inflables</strong> en Ciudad de
              México y zona metropolitana, EVENTECH cubre cuatro líneas de producto:
              juegos infantiles clásicos, acuáticos para el calor de verano, interactivos
              y deportivos para activaciones de alto impacto, y una línea completa
              diseñada específicamente para adultos y eventos corporativos.
            </p>
            <p>
              Cada renta incluye <strong>operador certificado en sitio</strong>,
              sanitización con certificado entre eventos, soplador de respaldo y
              traslado dentro de CDMX y ZMVM. El objetivo es que el inflable funcione
              perfectamente durante toda la celebración sin que el organizador
              tenga que pensar en nada relacionado con el equipo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Tipos de inflables para eventos">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20un%20inflable%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cuatro líneas para cuatro tipos de evento</p>
            <h2 id="catalogo-heading">¿Qué tipo de inflable necesita tu evento?</h2>
            <p class="hm__head-sub">Infantiles, acuáticos, interactivos o para adultos — cada línea para un perfil distinto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Un inflable bien elegido puede ser el elemento que más recuerden los invitados
              de cualquier evento. Uno mal elegido — el modelo equivocado para la edad del
              público, sin el espacio adecuado o sin operador presente — se convierte en
              el problema más visible del día. La elección correcta empieza con entender
              para quién es el evento y qué quieres que hagan los asistentes.
            </p>
            <p>
              No vendemos inflables genéricos de catálogo. Recomendamos el modelo
              correcto según el espacio disponible, el rango de edad de los participantes
              y el tipo de actividad que buscas generar — diversión pasiva, competencia
              activa o activación de marca.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`Renta de inflables ${s.name.toLowerCase()} para eventos en CDMX`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada línea, a fondo</p>
            <h2 id="detalle-heading">Inflables en detalle</h2>
            <p class="hm__head-sub">Qué incluye cada tipo, para qué edad y tipo de evento es la elección natural.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Los inflables son el elemento de un evento que más directamente impacta
              la experiencia de los asistentes. No hay decoración, iluminación ni <a href="/servicios/catering/">catering</a>
              que genere las mismas carcajadas y energía que un circuito de obstáculos
              bien instalado o un tobogán de agua en pleno julio en CDMX. Lo que marca
              la diferencia es la calidad del equipo, la seguridad de la operación y
              que el modelo sea el correcto para ese grupo específico de personas.
            </p>
          </div>
        </div>

        <!-- Juegos Infantiles -->
        <article class="hm-feat" aria-labelledby="feat-infantiles">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Juegos Infantiles</p>
            <h3 class="hm-feat__title" id="feat-infantiles">Castillos y brincabrincas — la zona de juego que mantiene a los niños felices durante todo el evento</h3>
            <p class="hm-feat__lead">Cuando los niños están entretenidos y seguros, los adultos disfrutan el evento. Así de simple — y así de importante la elección del inflable correcto.</p>
            <p>
              Nuestros <strong>castillos inflables</strong> están fabricados en vinilo
              de PVC de alta densidad con costuras dobles reforzadas y mallas de ventilación
              lateral que mantienen temperatura interior segura incluso en días soleados.
              Disponibles en modelos <strong>neutros y temáticos</strong> — princesas,
              superhéroes, dinosaurios, Minecraft — en tamaños de 3×3 m hasta 6×4 m
              para grupos de 6 a 20 niños simultáneos. Todos cuentan con
              <strong>rampa de entrada y zona de amortiguación</strong> en la salida.
            </p>
            <p>
              Los <strong>laberintos y túneles inflables</strong> añaden una dimensión
              de exploración que mantiene a los niños activos durante horas. Se instalan
              junto al castillo para crear una zona de juego completa que puede ocupar
              entre 30 y 60 minutos continuos de actividad por niño. Cada unidad opera
              con <strong>soplador industrial de 1.5 HP</strong> con motor térmicamente protegido y soplador de respaldo en sitio. Para eventos en jardines sin suministro eléctrico estable, coordinamos el <a href="/servicios/accesorios/plantas-energia/">generador eléctrico</a> necesario para operar los sopladores. Todos los inflables se
              <strong>sanitizan con solución bactericida certificada</strong> entre
              cada evento — entregamos certificado de limpieza con la renta.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Castillos", href: "/servicios/inflables/juegos-infantiles/castillos/" },
                { name: "Brincabrincas", href: "/servicios/inflables/juegos-infantiles/brincabrincas/" },
                { name: "Laberintos", href: "/servicios/inflables/juegos-infantiles/laberintos/" },
                { name: "Temáticos", href: "/servicios/inflables/juegos-infantiles/tematicos/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/inflables/juegos-infantiles/">
              Ver juegos infantiles
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/inflables/castillo-inflable-fiesta-infantil.avif" alt="Castillo inflable en fiesta infantil en jardín residencial CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/inflables/inflable-evento-01.avif" alt="Brincabrinca infantil temático con rampa en evento familiar" loading="lazy" decoding="async" />
              <img src="/images/inflables/inflable-evento-02.avif" alt="Laberinto inflable para niños en kermés escolar CDMX" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- Acuáticos -->
        <article class="hm-feat" aria-labelledby="feat-acuaticos">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Inflables Acuáticos</p>
            <h3 class="hm-feat__title" id="feat-acuaticos">Toboganes y albercas inflables — el parque acuático portátil que transforma cualquier jardín en verano</h3>
            <p class="hm-feat__lead">En CDMX el calor de marzo a junio convierte cualquier evento con agua en el más recordado del año. La solución no requiere construcción ni permisos especiales.</p>
            <p>
              Nuestros <strong>toboganes de agua inflables</strong> van desde modelos de
              4 m de deslizamiento para niños de 4 a 12 años hasta toboganes de doble
              carril de 8 m para adolescentes y adultos jóvenes. El sistema de agua
              circulante mantiene la superficie lubricada durante todo el evento con
              una simple manguera de jardín — sin presión especial, sin instalación
              hidráulica, sin requisitos técnicos del venue. La zona de llegada incluye
              <strong>alberca de amortiguación</strong> con 20–40 cm de agua que
              garantiza un aterrizaje seguro.
            </p>
            <p>
              Las <strong>albercas inflables de gran formato</strong> (3×6 m hasta 5×10 m)
              son la opción para eventos donde el objetivo es que los invitados pasen
              tiempo en el agua, no solo deslizarse. Ideales para fiestas de cumpleaños
              de adolescentes, eventos familiares de fin de semana y graduaciones con
              ambiente veraniego. Para eventos de mayor escala montamos
              <strong>parques acuáticos combinados</strong> — tobogán + alberca + zona
              splash pad — que pueden atender grupos de 30 a 100 personas simultáneas.
