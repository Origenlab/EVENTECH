  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Cotiza Tus Inflables"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada de inflables. Sin compromiso, sin costos ocultos.",
          "Ya sea un brincolin para una fiesta infantil de 20 niños o un circuito completo para un family day corporativo de 500 personas, estamos aquí para ayudarte."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Fiesta Infantil">Fiesta Infantil</option>
                <option value="XV Años">XV Años</option>
                <option value="Family Day Corporativo">Family Day Corporativo</option>
                <option value="Team Building">Team Building</option>
                <option value="Kermés Escolar">Kermés Escolar</option>
                <option value="Evento Comunitario">Evento Comunitario</option>
                <option value="Fiesta de Verano / Pool Party">Fiesta de Verano / Pool Party</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="equipo">
                Tipo de inflable
              </label>
              <select id="equipo" name="equipo" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de inflable que necesitas</option>
                <option value="Brincolin Infantil">Brincolin / Castillo Infantil</option>
                <option value="Tobogán Inflable">Tobogán Inflable Gigante</option>
                <option value="Circuito de Obstáculos">Circuito de Obstáculos</option>
                <option value="Inflable Acuático">Inflable Acuático / Tobogán de Agua</option>
                <option value="Toro Mecánico">Toro Mecánico</option>
                <option value="Futbolito Humano">Futbolito Humano</option>
                <option value="Gladiadores / Sumo">Gladiadores / Sumo Wrestling</option>
                <option value="Cancha Deportiva Inflable">Cancha Deportiva Inflable</option>
                <option value="Paquete Múltiple">Paquete Múltiple (varios inflables)</option>
                <option value="Otro">Otro / No estoy seguro</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de invitados, edades de los niños/participantes, tipo de espacio (jardín, salón, explanada), duración del evento..."
