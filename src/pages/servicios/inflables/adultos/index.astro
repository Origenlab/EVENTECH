---
/**
 * ─── Juegos Inflables para Adultos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Juegos Inflables para Adultos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Adultos" },
];

const ADULTOS = [
  {
    name: "Toro Mecánico",
    excerpt: "El toro mecánico profesional más solicitado de CDMX con operador certificado, dificultad ajustable y colchón inflable de seguridad perimetral para fiestas y eventos corporativos.",
    cta: "Toro Mecánico",
    href: "/servicios/inflables/adultos/toro-mecanico/",
    icon: "award",
  },
  {
    name: "Futbolito Humano",
    excerpt: "Cancha inflable de futbolito humano para 12 jugadores simultáneos. La actividad de team building favorita para eventos corporativos, despedidas de soltero y fiestas de adultos.",
    cta: "Futbolito Humano",
    href: "/servicios/inflables/adultos/futbolito-humano/",
    icon: "users",
  },
  {
    name: "Gladiadores y Sumo",
    excerpt: "Trajes de sumo profesionales, duelo de gladiadores con bastones acolchados y ring de boxeo inflable. Competencia épica y segura para todo tipo de eventos de adultos.",
    cta: "Gladiadores y Sumo",
    href: "/servicios/inflables/adultos/gladiadores-sumo/",
    icon: "shield",
  },
  {
    name: "Pistas de Obstáculos Extremas",
    excerpt: "Circuitos inflables de 15 a 20 metros con muros de escalada, túneles, resbaladillas y retos físicos. Ideales para competencias corporativas y eventos deportivos de alto impacto.",
    cta: "Pistas Obstáculos",
    href: "/servicios/inflables/adultos/obstaculos-extremos/",
    icon: "layers",
  },
];

const faqs = [
  { question: "¿Cuáles son los límites de peso y estatura para los juegos inflables de adultos?", answer: "Nuestros juegos inflables para adultos están diseñados para soportar personas de hasta 120 kg y 1.95 m de estatura. El toro mecánico soporta hasta 100 kg por seguridad del mecanismo. Los trajes de sumo se ajustan a tallas desde S hasta XXL. Las pistas de obstáculos no tienen restricción de estatura y soportan hasta 8 personas simultáneas de hasta 120 kg cada una. Todos los equipos cuentan con certificación de seguridad y se inspeccionan antes de cada evento." },
  { question: "¿Los juegos inflables para adultos son seguros para eventos corporativos?", answer: "Absolutamente. Todos nuestros juegos inflables para adultos cumplen con normas de seguridad y se entregan con operador profesional certificado. El toro mecánico incluye colchón inflable perimetral de absorción de impacto. Los trajes de sumo tienen protección acolchada integral. Las pistas de obstáculos cuentan con paredes laterales reforzadas y pisos antiderrapantes. Además, proporcionamos un protocolo de seguridad escrito y briefing previo a los participantes. Contamos con seguro de responsabilidad civil para todos nuestros equipos." },
  { question: "¿Cuánto espacio necesito para instalar los juegos inflables de adultos?", answer: "El espacio requerido varía según el juego: el toro mecánico necesita un área de 6x6 metros con 3.5 metros de altura libre. El futbolito humano requiere 15x8 metros. Los gladiadores y sumo necesitan 5x5 metros. Las pistas de obstáculos de 15 metros requieren 18x5 metros, y las de 20 metros necesitan 23x5 metros. Todos los juegos necesitan acceso a corriente eléctrica (110V) para los infladores. Realizamos una visita técnica previa sin costo para verificar que tu espacio sea adecuado." },
  { question: "¿Se pueden combinar los inflables para adultos con servicio de bar o bebidas?", answer: "Sí, es muy común combinar nuestros inflables con zona de bar, pero recomendamos mantener el área de juegos separada del área de bebidas por seguridad. Los participantes deben usar los juegos inflables en estado sobrio — es una política de seguridad estándar. La mejor configuración es alternar turnos: mientras unos participan en los juegos, otros disfrutan del bar, y se van rotando. Muchos clientes complementan con nuestro servicio de carpas para crear zonas diferenciadas de actividad y descanso." },
  { question: "¿Los juegos inflables de adultos se pueden usar en interiores?", answer: "Sí, siempre y cuando el espacio cumpla con las dimensiones mínimas y la altura de techo requerida. El toro mecánico necesita mínimo 3.5 metros de altura libre. El futbolito humano y las pistas de obstáculos requieren al menos 4 metros de altura. Los gladiadores y sumo funcionan perfecto en salones con techo estándar de 3 metros. En interiores se requiere piso firme (no alfombra gruesa) y acceso a corriente eléctrica. Trabajamos en salones de eventos, bodegas industriales, centros de convenciones y gimnasios." },
  { question: "¿Con cuánta anticipación debo reservar los inflables para adultos?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero) y fines de semana. El toro mecánico y el futbolito humano son los más solicitados y se agotan primero. Para eventos corporativos grandes con múltiples juegos o paquetes combinados, lo ideal es apartar con 1 a 2 meses de anticipación. Aceptamos reservas de último momento sujetas a disponibilidad. Un anticipo del 30% garantiza tu fecha." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Juegos Inflables para Adultos en CDMX",
    description: "Toro mecánico, futbolito humano, gladiadores, sumo y pistas de obstáculos extremas para fiestas y eventos corporativos. Operador incluido.",
    url: "/servicios/inflables/adultos/",
    priceRange: { min: 2000, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Adultos", url: "/servicios/inflables/adultos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Juegos Inflables para Adultos en CDMX"
  description="Renta de juegos inflables para adultos en CDMX: toro mecánico, futbolito humano, gladiadores, sumo y pistas de obstáculos. Operador incluido. Desde $2,000. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diversión extrema para eventos de adultos"
    title='Renta de <span class="highlight">Juegos Inflables para Adultos</span> en CDMX'
    subtitle="Toro mecánico, futbolito humano, gladiadores, sumo wrestling y pistas de obstáculos extremas. Operador profesional incluido y máxima seguridad garantizada en cada juego."
    primaryCTA={{ label: "Cotiza tu inflable", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar juegos inflables para adultos para mi evento` }}
    cards={[
      {
        title: "Juegos inflables de grado profesional para adultos",
        content: "<strong>Renta de juegos inflables para adultos</strong> con los equipos más divertidos y seguros del mercado en CDMX. Toro mecánico con operador certificado y dificultad ajustable para fiestas, bodas y eventos corporativos. Futbolito humano inflable para 12 jugadores simultáneos que transforma cualquier evento en una competencia inolvidable. Gladiadores con bastones acolchados, trajes de sumo profesionales y ring de boxeo inflable para competencias épicas — cada juego certificado, inspeccionado y con protocolos de seguridad estrictos.",
      },
      {
        title: "Operador profesional y seguridad garantizada",
        content: "<strong>Servicio completo de instalación y operación</strong> incluido en cada renta de inflables para adultos. Nuestro equipo se encarga del transporte, montaje profesional, inflado, supervisión continua durante todo el evento y desmontaje. Cada juego incluye operador certificado que coordina turnos, explica reglas de seguridad a los participantes y garantiza una experiencia divertida sin riesgos. Colchones de seguridad, arneses y protecciones incluidas según el tipo de atracción.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas diversión extrema para tu próximo evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta con los mejores juegos inflables para adultos en CDMX"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de inflables para adultos
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Inflables para Adultos"
        subtitle="Diversión y adrenalina para cada tipo de evento"
        description={[
          "Desde el clásico toro mecánico para fiestas hasta pistas de obstáculos extremas para competencias corporativas. Contamos con el catálogo de juegos inflables para adultos más completo de la Ciudad de México.",
          "Cada juego incluye operador profesional, instalación completa y protocolos de seguridad certificados. Diversión garantizada sin preocupaciones para organizadores y participantes."
        ]}
      />

      <div class="grid grid--4">
        {ADULTOS.map((adulto) => (
          <Card
            name={adulto.name}
            excerpt={adulto.excerpt}
            cta={adulto.cta}
            href={adulto.href}
            icon={adulto.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TORO MECÁNICO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="toro-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">La atracción estrella</span>
          <h2 class="showcase__title" id="toro-heading">Toro Mecánico</h2>
          <p class="showcase__subtitle">La atracción más solicitada para fiestas de adultos, bodas y eventos corporativos en CDMX.</p>
          <p class="showcase__text">Nuestro <strong>toro mecánico profesional</strong> es la estrella indiscutible de cualquier evento para adultos. Cuenta con <strong>operador certificado</strong> que controla la velocidad y movimientos en tiempo real, ajustando la <strong>dificultad desde nivel principiante hasta experto</strong> según los participantes. El mecanismo hidráulico profesional ofrece movimientos suaves y realistas que desafían el equilibrio sin riesgo de lesiones.</p>
          <p class="showcase__text">Incluye <strong>colchón inflable de seguridad perimetral</strong> de alta absorción de impacto que rodea completamente al toro, garantizando caídas seguras en todas las direcciones. Perfecto para <strong>fiestas temáticas, bodas country, despedidas de soltero y eventos corporativos de team building</strong>. Soporta hasta 100 kg y el operador coordina turnos para que todos los invitados participen. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para ambientar la zona con música y efectos de sonido.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Operador certificado</span>
            <span class="showcase__tag">Dificultad ajustable</span>
            <span class="showcase__tag">Colchón seguridad</span>
            <span class="showcase__tag">Hasta 100 kg</span>
          </div>
          <a href="/servicios/inflables/adultos/toro-mecanico/" class="btn btn--primary btn--lg">
            Ver Toro Mecánico
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="8" r="4"/>
              <path d="M6 20v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2"/>
              <path d="M16 3l2 2-2 2"/>
              <path d="M8 3L6 5l2 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FUTBOLITO HUMANO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="futbolito-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Team building favorito</span>
          <h2 class="showcase__title" id="futbolito-heading">Futbolito Humano</h2>
          <p class="showcase__subtitle">La actividad de integración más divertida para eventos corporativos y fiestas de adultos.</p>
          <p class="showcase__text">Nuestra <strong>cancha inflable de futbolito humano</strong> permite que hasta <strong>12 jugadores simultáneos</strong> (6 por equipo) vivan la experiencia de ser las figuras del futbolito de mesa a escala real. Cada jugador se sujeta a barras acolchadas inflables que limitan el movimiento lateral, recreando la mecánica del clásico futbolito pero con personas reales. Incluye <strong>balón oficial, marcador y árbitro-operador</strong> que coordina los partidos.</p>
          <p class="showcase__text">Es la actividad estrella en <strong>eventos corporativos de team building, despedidas de soltero y solteras, fiestas de cumpleaños y torneos empresariales</strong>. La cancha inflable tiene paredes laterales de 1.5 metros que mantienen el balón en juego y protegen a los participantes. Se puede organizar como torneo con eliminatorias para grupos grandes. Combínalo con nuestras <a href="/servicios/carpas/">carpas</a> para crear un espacio techado de competencia incluso en exteriores.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">12 jugadores</span>
            <span class="showcase__tag">Team building</span>
            <span class="showcase__tag">Torneos</span>
            <span class="showcase__tag">Corporativos</span>
          </div>
          <a href="/servicios/inflables/adultos/futbolito-humano/" class="btn btn--primary btn--lg">
            Ver Futbolito Humano
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
              <path d="M2 12h20"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       GLADIADORES Y SUMO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="gladiadores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Competencia épica</span>
          <h2 class="showcase__title" id="gladiadores-heading">Gladiadores y Sumo</h2>
          <p class="showcase__subtitle">Combates inflables seguros y espectaculares que encienden la competitividad de cualquier evento.</p>
          <p class="showcase__text">Nuestra línea de <strong>combates inflables</strong> incluye tres atracciones épicas: <strong>trajes de sumo profesionales</strong> acolchados de cuerpo completo que transforman a los participantes en luchadores gigantes, <strong>duelo de gladiadores</strong> con bastones acolchados sobre pedestales inflables elevados, y <strong>ring de boxeo inflable</strong> con guantes gigantes acolchados para combates seguros y espectaculares.</p>
          <p class="showcase__text">Los trajes de sumo incluyen <strong>casco protector, protección corporal integral y se ajustan a tallas S hasta XXL</strong>. El duelo de gladiadores se realiza sobre pedestales inflables de 1.2 metros de altura con colchón perimetral de caída. El ring de boxeo inflable cuenta con cuerdas, esquinas y guantes oversized que hacen imposible lastimarse. Cada atracción incluye <strong>operador y réferi</strong> profesional. Complementa con nuestra <a href="/servicios/iluminacion/">iluminación de escenario</a> para crear una arena de combate espectacular.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Trajes de sumo</span>
            <span class="showcase__tag">Gladiadores</span>
            <span class="showcase__tag">Boxing ring</span>
            <span class="showcase__tag">Tallas S-XXL</span>
          </div>
          <a href="/servicios/inflables/adultos/gladiadores-sumo/" class="btn btn--primary btn--lg">
            Ver Gladiadores y Sumo
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PISTAS DE OBSTÁCULOS EXTREMAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="obstaculos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Reto máximo</span>
          <h2 class="showcase__title" id="obstaculos-heading">Pistas de Obstáculos Extremas</h2>
          <p class="showcase__subtitle">Circuitos inflables de alto impacto para competencias corporativas y eventos deportivos.</p>
          <p class="showcase__text">Nuestras <strong>pistas de obstáculos inflables extremas</strong> están disponibles en circuitos de <strong>15 y 20 metros de largo</strong> con múltiples estaciones de reto: <strong>muros de escalada inflables</strong> con agarraderas, <strong>túneles de gateo</strong>, <strong>resbaladillas gigantes</strong>, columnas de equilibrio, redes de trepar y zonas de salto. Cada circuito permite competir a 2 personas simultáneamente en carriles paralelos con cronómetro para registrar tiempos.</p>
          <p class="showcase__text">Son la atracción favorita para <strong>eventos corporativos de team building, competencias empresariales, torneos deportivos y activaciones de marca</strong>. Las pistas de 15 metros son ideales para espacios medianos con 4 estaciones de obstáculo. Las de 20 metros incluyen 6 estaciones y un nivel de dificultad mayor para grupos competitivos. Todos los circuitos cuentan con <strong>pisos antiderrapantes, paredes laterales reforzadas y operador dedicado</strong>. Complementa con nuestros <a href="/servicios/accesorios/">accesorios de señalización</a> como podiums de premiación y backdrops corporativos.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">15-20 metros</span>
            <span class="showcase__tag">Muros de escalada</span>
            <span class="showcase__tag">Túneles y resbaladillas</span>
            <span class="showcase__tag">Carriles duales</span>
          </div>
          <a href="/servicios/inflables/adultos/obstaculos-extremos/" class="btn btn--primary btn--lg">
            Ver Pista de Obstáculos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
              <line x1="6" y1="6" x2="6.01" y2="6"/>
              <line x1="6" y1="18" x2="6.01" y2="18"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Inflables para Adultos"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus juegos inflables para adultos, es natural tener preguntas sobre seguridad, espacio, capacidad y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre inflables para adultos al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de juegos inflables para adultos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
