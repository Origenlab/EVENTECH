---
/**
 * ─── Futbolito Humano — Pagina de Producto (Nivel 4) ───
 * Cancha inflable de futbolito humano para 12 jugadores simultaneos.
 * La actividad de team building favorita para corporativos.
 *
 * Jerarquia: Servicios > Inflables > Adultos > Futbolito Humano
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Adultos", href: "/servicios/inflables/adultos/" },
  { label: "Futbolito Humano" },
];

const faqs = [
  { question: "¿Cuántos jugadores pueden participar en el futbolito humano?", answer: "La cancha inflable permite <strong>12 jugadores simultáneos en formato 6 vs 6</strong>. Cada equipo se distribuye en 3 barras con 2 jugadores por barra, recreando la mecánica del futbolito de mesa tradicional. Para grupos más grandes, organizamos <strong>torneos con sistema de eliminación</strong> donde los equipos se van rotando — un formato que funciona perfecto para grupos de 30, 50 o hasta 100 personas con rotaciones de partidos de 5-7 minutos cada uno." },
  { question: "¿Cuáles son los requisitos de edad y peso para jugar futbolito humano?", answer: "La edad mínima recomendada es de <strong>12 años</strong> y el peso máximo por jugador es de <strong>110 kg</strong>. Las barras acolchadas cuentan con arneses ajustables que se adaptan a diferentes estaturas (desde 1.40 m hasta 1.95 m). Adolescentes de 12-15 años pueden participar en un equipo mixto con adultos sin problema. No hay límite de edad máxima siempre que el participante tenga movilidad para desplazarse lateralmente sujetado a la barra." },
  { question: "¿Cuánto espacio necesito para instalar la cancha de futbolito humano?", answer: "La cancha de futbolito humano inflable mide <strong>15x8 metros</strong>, y recomendamos un área total de <strong>18x10 metros</strong> para incluir espacio de circulación, zona de espera de equipos y área del árbitro. La altura mínima de techo para interiores es de <strong>4 metros</strong>. El piso debe ser firme y nivelado — funciona sobre concreto, pasto firme, piso de salón o duela. Realizamos una visita técnica gratuita para verificar que tu espacio cumpla con los requisitos." },
  { question: "¿El futbolito humano funciona en interiores y exteriores?", answer: "Sí, nuestra cancha de futbolito humano <strong>funciona perfectamente en ambos entornos</strong>. En interiores necesitas mínimo 4 metros de altura de techo, piso firme y acceso a corriente eléctrica para los 2 infladores continuos. En exteriores funciona sobre pasto firme o concreto. En caso de lluvia, la superficie de la cancha puede volverse resbaladiza, por lo que recomendamos combinar con nuestras <a href=\"/servicios/carpas/\">carpas</a> para garantizar operación en cualquier clima." },
  { question: "¿Se puede organizar un torneo de futbolito humano para team building?", answer: "Es nuestra modalidad más popular para eventos corporativos. Nuestro <strong>coordinador-árbitro organiza torneos completos</strong> con formato de eliminación directa, grupos o liga. Para un grupo de 48 personas (8 equipos de 6), un torneo típico dura aproximadamente <strong>2.5 a 3 horas</strong>. Incluimos <strong>tabla de posiciones visible, cronómetro por partido, narración de jugadas y ceremonia de premiación</strong> con trofeo para el equipo campeón. Podemos personalizar el torneo con los nombres de los departamentos de tu empresa." },
  { question: "¿Las barras del futbolito humano son seguras?", answer: "Absolutamente. Las barras están fabricadas con <strong>material acolchado de alta densidad</strong> que absorbe impactos. Cada jugador se sujeta mediante un <strong>arnés ajustable tipo chaleco</strong> que permite movimiento lateral libre pero evita que se suelte de la barra. El piso de la cancha es de <strong>material antiderrapante</strong> y las paredes laterales inflables de 1.5 metros contienen el balón y protegen a los jugadores. Los balones son de <strong>foam reforzado</strong> (no de cuero) para evitar golpes fuertes. El coordinador supervisa cada partido." },
];

const specs = [
  { label: "Cancha", value: "15x8 metros inflable" },
  { label: "Jugadores", value: "12 simultáneos: 6 vs 6" },
  { label: "Barras", value: "Acolchadas con arnés ajustable" },
  { label: "Material", value: "Lona vinílica 22 oz reforzada" },
  { label: "Peso máx. jugador", value: "110 kg" },
  { label: "Edad mínima", value: "12 años" },
  { label: "Árbitro", value: "Incluido como coordinador" },
  { label: "Balones", value: "Foam reforzado: 3 incluidos" },
  { label: "Infladores", value: "2 continuos de 2 HP" },
  { label: "Marcador", value: "Digital con cronómetro" },
];

const sidebarNav = [
  { name: "Toro Mecánico", href: "/servicios/inflables/adultos/toro-mecanico/" },
  { name: "Futbolito Humano", href: null, active: true },
  { name: "Gladiadores y Sumo", href: "/servicios/inflables/adultos/gladiadores-sumo/" },
  { name: "Obstáculos Extremos", href: "/servicios/inflables/adultos/obstaculos-extremos/" },
];

const sidebarRelated = [
  { name: "Interactivos y Deportivos", href: "/servicios/inflables/interactivos-deportivos/" },
  { name: "Juegos Infantiles", href: "/servicios/inflables/juegos-infantiles/" },
  { name: "Carpas para Eventos", href: "/servicios/carpas/" },
  { name: "Audiovisual y Sonido", href: "/servicios/audiovisual/sonido/" },
  { name: "Iluminación Efectos", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Fernanda Gutiérrez", text: "Rentamos el futbolito humano para nuestro evento corporativo de 50 personas en un salón de Santa Fe. Fue la actividad más divertida del día. El coordinador organizó un mini torneo entre departamentos y la competencia fue épica. Todos participaron, desde los directores hasta los becarios. Servicio puntual y profesional.", rating: 5, date: "2025-11-08" },
  { author: "Andrés Morales", text: "Contratamos el futbolito humano para la despedida de soltero de mi hermano. Éramos 24 personas y el coordinador armó 4 equipos con eliminatorias. La risa no paró en 3 horas. Las barras acolchadas son muy seguras y los balones de foam evitan cualquier golpe. Excelente inversión para un evento inolvidable.", rating: 5, date: "2025-10-15" },
  { author: "Laura Sánchez", text: "Organizamos el día del niño de la empresa con futbolito humano y fue un éxito rotundo. El equipo de EVENTECH llegó temprano, montaron todo en 45 minutos y el coordinador hizo que tanto los niños mayores como los adultos disfrutaran. La cancha es enorme y muy segura. Definitivamente repetiremos el próximo año.", rating: 5, date: "2025-09-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Futbolito Humano Inflable en CDMX",
    description: "Renta de cancha inflable de futbolito humano para 12 jugadores. La actividad de team building favorita para corporativos y despedidas. Desde $3,000.",
    url: "/servicios/inflables/adultos/futbolito-humano/",
    priceRange: { min: 3000, max: 7000 },
    reviews,
    ratingValue: 5,
    reviewCount: 164,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Adultos", url: "/servicios/inflables/adultos/" },
    { name: "Futbolito Humano", url: "/servicios/inflables/adultos/futbolito-humano/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Futbolito Humano Inflable en CDMX | EVENTECH"
  description="Renta de cancha inflable de futbolito humano para 12 jugadores. La actividad de team building favorita para corporativos y despedidas. Desde $3,000."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Team building #1 para corporativos"
    title='Renta de <span class="highlight">Futbolito Humano</span> Inflable para Eventos'
    subtitle="Cancha inflable de futbolito humano para 12 jugadores simultáneos en formato 6 vs 6. Árbitro-coordinador incluido, balones de foam y sistema de marcador digital para torneos."
    primaryCTA={{ label: "Cotiza tu futbolito", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar futbolito humano para mi evento` }}
    cards={[
      {
        title: "Cancha inflable de futbolito humano para 12 jugadores",
        content: "<strong>Renta de cancha inflable de futbolito humano</strong> de 15x8 metros con porterías inflables, barras acolchadas ajustables y sistema de sujeción para 12 jugadores simultáneos en formato 6v6. La experiencia más divertida de team building para eventos corporativos, despedidas de soltero y fiestas de adultos en CDMX. Recreación a escala real del clásico futbolito de mesa con personas reales.",
      },
      {
        title: "Árbitro-coordinador incluido y sistema de competencia",
        content: "<strong>Árbitro-coordinador profesional incluido</strong> en cada renta, con balones de foam reforzado, sistema de marcador digital con cronómetro y premiación con trofeo para equipo ganador. El coordinador organiza torneos con sistema de eliminación, narra las jugadas y mantiene el ritmo del evento. Perfecto para grupos de 12 a 100+ personas con rotación de equipos.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la actividad de team building perfecta?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el paquete ideal de futbolito humano para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Inflables para Adultos</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas futbolito humano para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar futbolito humano para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/><path d="M12 18v4"/><path d="M10 22h4"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Futbolito Humano</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Futbolito Humano Clásico -->
          <section class="section section--alt" aria-labelledby="futbolito-clasico-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El favorito para team building</span>
                <h2 class="showcase__title" id="futbolito-clasico-heading">Futbolito Humano Clásico</h2>
                <p class="showcase__subtitle">Cancha inflable completa para 12 jugadores con árbitro y sistema de marcador incluidos.</p>
                <p class="showcase__text">Nuestro <strong>futbolito humano clásico</strong> es la actividad más solicitada para eventos corporativos y fiestas de adultos en CDMX. La cancha inflable de <strong>15x8 metros</strong> cuenta con porterías integradas, paredes laterales de 1.5 metros y 6 barras acolchadas (3 por equipo) con arneses ajustables para 12 jugadores simultáneos. El balón de foam reforzado garantiza partidos intensos sin riesgo de golpes.</p>
                <p class="showcase__text">Incluye <strong>árbitro-coordinador profesional</strong> que explica las reglas, organiza los equipos, narra las jugadas y controla el marcador digital. Cada partido dura entre 5 y 7 minutos — tiempo perfecto para mantener la energía alta y rotar equipos. Para grupos mayores a 12 personas, el coordinador organiza <strong>torneos de eliminación</strong> con tabla de posiciones visible. Complementa con nuestro <a href="/servicios/audiovisual/sonido/">equipo de sonido</a> para narración con micrófono y música ambiental.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">12 jugadores</span>
                  <span class="showcase__tag">Árbitro incluido</span>
                  <span class="showcase__tag">Marcador digital</span>
                  <span class="showcase__tag">Balones foam</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Futbolito Clásico
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Futbolito Humano Clásico</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Futbolito Humano Nocturno LED -->
          <section class="section section--alt" aria-labelledby="futbolito-led-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Experiencia nocturna única</span>
                <h2 class="showcase__title" id="futbolito-led-heading">Futbolito Humano Nocturno LED</h2>
                <p class="showcase__subtitle">Cancha con iluminación LED perimetral y balón luminoso para partidos nocturnos espectaculares.</p>
                <p class="showcase__text">Nuestro <strong>futbolito humano nocturno LED</strong> transforma la experiencia clásica en un espectáculo visual. La cancha cuenta con <strong>iluminación LED RGB perimetral</strong> que marca las líneas de juego, las porterías y las zonas de cada equipo con colores diferentes. El <strong>balón luminoso</strong> se enciende al contacto y deja un rastro visual que hace cada jugada más emocionante en la oscuridad.</p>
                <p class="showcase__text">Las barras de los jugadores también cuentan con <strong>bandas LED</strong> en el color de cada equipo para identificación visual instantánea. El sistema completo funciona con baterías recargables y no requiere instalación eléctrica adicional. Ideal para <strong>eventos nocturnos, fiestas temáticas, after parties corporativos y festivales</strong>. El coordinador gestiona los efectos de luz sincronizados con los goles y momentos clave del partido. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para ambientar toda la zona de juego.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">LED perimetral RGB</span>
                  <span class="showcase__tag">Balón luminoso</span>
                  <span class="showcase__tag">Eventos nocturnos</span>
                  <span class="showcase__tag">Barras LED por equipo</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Futbolito LED
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Futbolito Nocturno LED</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Torneo Corporativo -->
          <section class="section section--alt" aria-labelledby="torneo-corporativo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Integración empresarial garantizada</span>
                <h2 class="showcase__title" id="torneo-corporativo-heading">Torneo Corporativo</h2>
                <p class="showcase__subtitle">Paquete completo de torneo empresarial con sistema de competencia, narración y premiación.</p>
                <p class="showcase__text">Nuestro <strong>paquete de torneo corporativo de futbolito humano</strong> está diseñado específicamente para eventos de empresa. Incluye la cancha inflable completa más un <strong>sistema profesional de torneo</strong> con bracket digital, cronómetro por partido, tabla de posiciones en tiempo real y narración en vivo con micrófono y bocinas. El coordinador actúa como maestro de ceremonias deportivo que mantiene la energía del evento.</p>
                <p class="showcase__text">El paquete incluye <strong>playeras de colores para identificar equipos</strong> (hasta 8 equipos), trofeo para el equipo campeón, medallas para los 3 primeros lugares y certificados de participación personalizables con el logo de tu empresa. Formatos disponibles: <strong>eliminación directa, round robin o liga con playoffs</strong>. Ideal para <strong>team building, kick-offs de ventas, aniversarios de empresa e integraciones entre departamentos</strong>. Complementa con nuestras <a href="/servicios/carpas/">carpas</a> para crear una zona de estadio con gradas para espectadores.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Bracket digital</span>
                  <span class="showcase__tag">Playeras por equipo</span>
                  <span class="showcase__tag">Premiación incluida</span>
                  <span class="showcase__tag">Narración en vivo</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Torneo Corporativo
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5">
                    <path d="M12 2a7 7 0 0 0-7 7c0 5 7 9 7 9s7-4 7-9a7 7 0 0 0-7-7z"/>
                    <path d="M12 18v4"/><path d="M10 22h4"/>
                  </svg>
                  <span>Torneo Corporativo</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Kit Futbolito + Premiación -->
          <section class="section section--alt" aria-labelledby="kit-premiacion-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Experiencia completa de evento</span>
                <h2 class="showcase__title" id="kit-premiacion-heading">Kit Futbolito + Premiación</h2>
                <p class="showcase__subtitle">Paquete todo incluido con cancha, torneo organizado, premiación y ambientación deportiva.</p>
