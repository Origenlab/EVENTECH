---
/**
 * ─── Inflables Acuáticos para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Inflables Acuáticos para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Inflables", href: "/servicios/inflables/" },
  { label: "Acuáticos" },
];

const ACUATICOS = [
  {
    name: "Toboganes de Agua",
    excerpt: "Toboganes inflables de 5, 8 y 10 metros de altura con sistema de flujo de agua continuo y alberca de aterrizaje splash. La atracción estrella de cualquier fiesta acuática al aire libre.",
    cta: "Toboganes",
    href: "#toboganes-heading",
    icon: "award",
  },
  {
    name: "Albercas Inflables",
    excerpt: "Albercas inflables de diversos tamaños con sistema de filtración, bordes de seguridad reforzados y opciones para niños pequeños. Frescura instantánea para eventos en jardín.",
    cta: "Albercas",
    href: "#albercas-heading",
    icon: "layers",
  },
  {
    name: "Resbaladillas Splash",
    excerpt: "Resbaladillas tipo slip-n-slide con aspersores de agua y opción de combo con fiesta de espuma. Diversión acuática para todas las edades en cualquier evento al aire libre.",
    cta: "Resbaladillas",
    href: "#resbaladillas-heading",
    icon: "balloon",
  },
  {
    name: "Circuitos Acuáticos",
    excerpt: "Circuitos de obstáculos inflables con elementos de agua para competencias y team building corporativo. Retos refrescantes que fomentan el trabajo en equipo y la diversión.",
    cta: "Circuitos",
    href: "#circuitos-heading",
    icon: "heart",
  },
];

const faqs = [
  { question: "¿Qué requerimientos de suministro de agua necesitan los inflables acuáticos?", answer: "Necesitamos acceso a una toma de agua estándar (manguera de jardín) dentro de un radio de 30 metros del área de instalación. Para toboganes grandes de 8 y 10 metros se requiere presión mínima de 2 bar. Si tu venue no tiene toma de agua cercana, llevamos tanques de almacenamiento de 2,500 litros y bomba de recirculación. El consumo promedio es de 500 a 1,500 litros por hora dependiendo del inflable. Nuestro equipo técnico evalúa la disponibilidad de agua en tu venue antes del evento." },
  { question: "¿Hay restricciones de edad para los inflables acuáticos?", answer: "Cada inflable tiene rangos de edad recomendados. Los toboganes de 5 metros son aptos para niños desde 4 años. Los de 8 y 10 metros son para mayores de 8 años y adultos. Las albercas infantiles son para niños de 1 a 6 años con supervisión de un adulto. Las resbaladillas splash son para mayores de 5 años. Los circuitos acuáticos están diseñados para mayores de 10 años y adultos. Siempre proporcionamos señalización clara con las restricciones de edad y peso máximo en cada atracción." },
  { question: "¿Incluyen monitores de seguridad con la renta?", answer: "Sí. Todos nuestros paquetes de inflables acuáticos incluyen al menos un monitor de seguridad capacitado por cada atracción. Para toboganes de 8 y 10 metros asignamos dos monitores: uno en la parte superior controlando el acceso y otro en la zona de aterrizaje. Los monitores supervisan el uso correcto, controlan los turnos, verifican que se cumplan las restricciones de edad y peso, y están entrenados en primeros auxilios básicos. También proporcionamos chalecos salvavidas infantiles sin costo adicional." },
  { question: "¿Qué espacio y tipo de terreno necesito para instalar inflables acuáticos?", answer: "El espacio mínimo varía según el inflable: toboganes de 5 m requieren 8x5 metros, los de 10 m necesitan 15x8 metros. Las albercas necesitan de 6x6 a 10x10 metros según tamaño. El terreno ideal es pasto o tierra, que permite anclar con estacas y absorbe el agua. En superficies duras (concreto, adoquín) usamos anclajes con contrapeso y tapetes antiderrapantes. Necesitamos un área de drenaje o declive natural para el desagüe. Realizamos una visita técnica previa para evaluar el terreno y planificar la instalación." },
  { question: "¿En qué temporada están disponibles los inflables acuáticos?", answer: "Nuestros inflables acuáticos están disponibles todo el año, aunque la temporada alta es de marzo a octubre cuando el clima en CDMX es más cálido. En temporada de lluvias (junio a septiembre) recomendamos combinar con nuestras carpas para proteger el área de acceso. Para eventos en temporada fría (noviembre a febrero) ofrecemos la opción de agua temperada con calentadores portátiles. Los fines de semana de abril a agosto son las fechas más solicitadas, por lo que recomendamos reservar con anticipación." },
  { question: "¿Con cuánta anticipación debo reservar inflables acuáticos?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (abril a agosto). Para eventos grandes que requieran múltiples inflables acuáticos o paquetes completos, lo ideal es apartar con 1 a 2 meses. Los fines de semana de mayo, junio y julio son los más demandados y se agotan primero. Para eventos corporativos de team building con circuitos acuáticos, sugerimos reservar con al menos 3 semanas. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Inflables Acuáticos para Eventos en CDMX",
    description: "Toboganes de agua, albercas inflables, resbaladillas splash y circuitos acuáticos para fiestas y eventos. Monitores de seguridad incluidos.",
    url: "/servicios/inflables/acuaticos/",
    priceRange: { min: 1500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Inflables", url: "/servicios/inflables/" },
    { name: "Acuáticos", url: "/servicios/inflables/acuaticos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Inflables Acuáticos para Eventos en CDMX"
  description="Renta de inflables acuáticos: toboganes de agua, albercas inflables, resbaladillas splash y circuitos acuáticos para eventos en CDMX. Monitores incluidos. Desde $1,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diversión acuática para todos los eventos"
    title='Renta de <span class="highlight">Inflables Acuáticos</span> para Eventos en CDMX'
    subtitle="Toboganes de agua de 5 a 10 metros, albercas inflables, resbaladillas splash y circuitos acuáticos con monitores de seguridad incluidos. La atracción más refrescante para tu evento al aire libre."
    primaryCTA={{ label: "Cotiza tu inflable acuático", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar inflables acuáticos para mi evento` }}
    cards={[
      {
        title: "Inflables acuáticos de grado profesional para cada evento",
        content: "<strong>Renta de inflables acuáticos para eventos</strong> con los equipos más seguros y divertidos disponibles en CDMX. Toboganes de agua de 5, 8 y 10 metros de altura con sistema de flujo continuo y alberca de aterrizaje para fiestas infantiles, XV años y celebraciones familiares. Albercas inflables con sistema de filtración y bordes de seguridad para jardines y terrenos amplios. Resbaladillas splash tipo slip-n-slide y circuitos acuáticos de obstáculos para eventos corporativos de team building — cada inflable certificado, sanitizado y verificado antes de cada entrega.",
      },
      {
        title: "Instalación profesional con monitores de seguridad",
        content: "<strong>Servicio completo de seguridad</strong> incluido en cada renta de inflables acuáticos. Nuestro equipo se encarga del transporte, instalación con anclaje certificado, conexión del sistema de agua, pruebas de funcionamiento y supervisión continua durante todo el evento. Monitores de seguridad capacitados en cada atracción que controlan turnos, verifican restricciones de edad y peso, y están entrenados en primeros auxilios. Chalecos salvavidas infantiles y tapetes antiderrapantes incluidos sin costo adicional.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas la atracción más refrescante para tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada con el inflable acuático ideal para tu espacio y tipo de evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de inflable acuático
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Inflables Acuáticos"
        subtitle="La diversión refrescante perfecta para cada tipo de evento"
        description={[
          "Desde toboganes gigantes de agua para fiestas infantiles hasta circuitos acuáticos de obstáculos para team building corporativo. Contamos con el inventario de inflables acuáticos más completo de la Ciudad de México.",
          "Cada inflable incluye sistema de agua, anclaje profesional, monitores de seguridad y equipo de protección. Certificados en seguridad y sanitizados antes de cada evento para garantizar diversión sin preocupaciones."
        ]}
      />

      <div class="grid grid--4">
        {ACUATICOS.map((acuatico) => (
          <Card
            name={acuatico.name}
            excerpt={acuatico.excerpt}
            cta={acuatico.cta}
            href={acuatico.href}
            icon={acuatico.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TOBOGANES DE AGUA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="toboganes-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Máxima diversión refrescante</span>
          <h2 class="showcase__title" id="toboganes-heading">Toboganes de Agua</h2>
          <p class="showcase__subtitle">La atracción estrella de cualquier fiesta acuática con alturas de 5 a 10 metros.</p>
          <p class="showcase__text">Nuestros <strong>toboganes de agua inflables</strong> están disponibles en 3 alturas profesionales: <strong>5, 8 y 10 metros</strong> con sistema de flujo de agua continuo que mantiene la superficie siempre mojada para un deslizamiento suave y seguro. Cada tobogán cuenta con una <strong>alberca de aterrizaje splash</strong> acolchonada en la base que amortigua la llegada y crea una experiencia refrescante. Perfectos para <strong>fiestas infantiles, XV años, cumpleaños y eventos familiares</strong> en jardines y terrenos amplios de CDMX.</p>
          <p class="showcase__text">Incluyen <strong>escaleras con agarraderas antiderrapantes, paredes laterales de seguridad reforzadas y malla de protección</strong> en la parte superior. El sistema de agua se conecta a manguera estándar con bomba de recirculación incluida para optimizar el consumo. Dos monitores de seguridad supervisan el acceso y la zona de aterrizaje en todo momento. Combínalos con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para crear zonas de sombra y descanso junto al tobogán.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">5 metros</span>
            <span class="showcase__tag">8 metros</span>
            <span class="showcase__tag">10 metros</span>
            <span class="showcase__tag">Splash pool</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Toboganes de Agua
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20c2-2 4-3 6-3s4 1 6 3 4 3 6 3"/>
              <path d="M2 16c2-2 4-3 6-3s4 1 6 3 4 3 6 3"/>
              <path d="M17 4l-5 12"/>
              <circle cx="17" cy="4" r="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ALBERCAS INFLABLES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="albercas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Frescura instantánea</span>
          <h2 class="showcase__title" id="albercas-heading">Albercas Inflables</h2>
          <p class="showcase__subtitle">Albercas de diversos tamaños con filtración y bordes de seguridad para eventos al aire libre.</p>
          <p class="showcase__text">Nuestras <strong>albercas inflables profesionales</strong> están disponibles en diversos tamaños: desde <strong>albercas infantiles de 3x2 metros</strong> para los más pequeños hasta <strong>albercas familiares de 8x5 metros</strong> con capacidad para múltiples usuarios simultáneos. Cada alberca incluye un <strong>sistema de filtración portátil</strong> que mantiene el agua limpia y cristalina durante todo el evento. Los <strong>bordes de seguridad reforzados</strong> con doble cámara de aire previenen accidentes y proporcionan un apoyo estable para entrar y salir.</p>
          <p class="showcase__text">Contamos con <strong>albercas para niños pequeños (toddler pools)</strong> de solo 30 cm de profundidad con piso acolchonado y bordes extra anchos, ideales para bebés de 1 a 3 años con supervisión. Las albercas familiares tienen profundidad graduada de 50 cm a 1.2 metros. Incluyen <strong>escalerilla de acceso, tapete antiderrapante perimetral y kit de limpieza</strong>. Combínalas con nuestros <a href="/servicios/accesorios/">accesorios para eventos</a> como sombrillas, camastros y mesas laterales para crear tu propia zona de splash.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Alberca infantil</span>
            <span class="showcase__tag">Alberca familiar</span>
            <span class="showcase__tag">Toddler pool</span>
            <span class="showcase__tag">Filtración incluida</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Albercas Inflables
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="6" width="20" height="12" rx="3" ry="3"/>
              <path d="M2 14c2-1.5 4-2 6-2s4 .5 6 2 4 2 6 2"/>
              <line x1="6" y1="6" x2="6" y2="2"/>
              <line x1="18" y1="6" x2="18" y2="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESBALADILLAS SPLASH — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="resbaladillas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Para todas las edades</span>
          <h2 class="showcase__title" id="resbaladillas-heading">Resbaladillas Splash</h2>
          <p class="showcase__subtitle">Diversión acuática deslizante con aspersores de agua y opción de fiesta de espuma.</p>
          <p class="showcase__text">Nuestras <strong>resbaladillas splash tipo slip-n-slide</strong> son la opción más divertida y accesible para eventos acuáticos. Superficies deslizantes de <strong>10, 15 y 20 metros de largo</strong> con aspersores de agua integrados que mantienen una capa de agua constante para un deslizamiento rápido y emocionante. Disponibles en versión recta y con curvas para mayor diversión. Aptas para <strong>niños desde 5 años hasta adultos</strong>, convirtiéndolas en la atracción perfecta para fiestas de cumpleaños, graduaciones y eventos sociales.</p>
          <p class="showcase__text">Ofrecemos el <strong>combo de fiesta de espuma (foam party)</strong> que añade máquinas de espuma a la experiencia acuática para crear un ambiente de festival único. Los <strong>aspersores de agua (water sprayers)</strong> se pueden configurar como arcos, cortinas o chorros para personalizar la experiencia. Incluyen tapete de recepción acolchonado al final del recorrido y zona de lavado. Complementa con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para ambientar con música y crear la fiesta acuática perfecta.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Slip-n-slide</span>
            <span class="showcase__tag">Water sprayers</span>
            <span class="showcase__tag">Foam party</span>
            <span class="showcase__tag">Todas las edades</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Resbaladillas Splash
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 20l8-16 8 16"/>
              <path d="M2 20h20"/>
              <path d="M8 12c1-1 2-1 4 0s3 1 4 0"/>
              <path d="M7 16c1-1 2-1 4 0s3 1 4 0"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CIRCUITOS ACUÁTICOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="circuitos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Competencia refrescante</span>
          <h2 class="showcase__title" id="circuitos-heading">Circuitos Acuáticos</h2>
          <p class="showcase__subtitle">Circuitos de obstáculos inflables con elementos de agua para team building y competencias.</p>
          <p class="showcase__text">Nuestros <strong>circuitos acuáticos de obstáculos</strong> combinan la emoción de las carreras de obstáculos con la diversión refrescante del agua. Recorridos de <strong>15 a 30 metros de largo</strong> con túneles, muros de escalada, resbaladillas, puentes colgantes y zonas de chapoteo que desafían la agilidad, resistencia y trabajo en equipo. Perfectos para <strong>eventos corporativos de team building, competencias empresariales, fiestas de adultos y festivales deportivos</strong> donde la competencia y la diversión se unen.</p>
          <p class="showcase__text">Los <strong>retos por equipos (team challenges)</strong> incluyen carreras de relevos acuáticas, competencias de velocidad cronometradas y circuitos con puntuación por estaciones. Ideal para <strong>actividades de integración corporativa</strong> donde los equipos compiten mientras se refrescan. Incluyen <strong>cronómetro digital, pizarra de resultados, silbatos y equipo de arbitraje</strong>. Cada circuito puede adaptarse en dificultad según el perfil de los participantes. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario para eventos</a> para crear zonas de descanso, hidratación y premiación junto al circuito.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Obstáculos acuáticos</span>
            <span class="showcase__tag">Team building</span>
            <span class="showcase__tag">Carreras por equipos</span>
            <span class="showcase__tag">Cronometrado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Circuitos Acuáticos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/>
              <line x1="4" y1="22" x2="4" y2="15"/>
              <path d="M2 20c2-1 4-1.5 6-1.5s4 .5 6 1.5 4 1.5 6 1.5"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Inflables Acuáticos"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu inflable acuático, es natural tener preguntas sobre seguridad, requerimientos de agua, espacio y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre inflables acuáticos al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de inflables acuáticos para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
