---
/**
 * ─── Efectos Especiales para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Efectos Especiales para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Efectos Especiales" },
];

const EFECTOS = [
  {
    name: "Humo Bajo y Niebla",
    excerpt: "Máquinas de humo bajo con hielo seco y niebla de glicol para primer baile, pasarelas y entradas dramáticas. Efecto rasante seguro para cualquier venue.",
    cta: "Humo Bajo",
    href: "#humo-heading",
    icon: "layers",
  },
  {
    name: "Láser Multicolor",
    excerpt: "Shows de láser RGB de 2 a 10W con efectos aéreos, túneles, abanicos y ondas. Sincronización DMX/ILDA con música para espectáculos inolvidables.",
    cta: "Láser",
    href: "#laser-heading",
    icon: "lightbulb",
  },
  {
    name: "Sparklers Fríos",
    excerpt: "Máquinas de chispas frías (polvo de titanio) de 2 a 5 metros de altura. Seguras para interiores, ideales para entradas, salidas y corte de pastel.",
    cta: "Sparklers",
    href: "#sparklers-heading",
    icon: "award",
  },
  {
    name: "Confeti y Serpentinas",
    excerpt: "Cañones de confeti CO2 y lanzadores de serpentinas con papeles metálicos, de papel y colores personalizados para momentos de celebración explosiva.",
    cta: "Confeti",
    href: "#confeti-heading",
    icon: "heart",
  },
];

const faqs = [
  { question: "¿El humo bajo es seguro para usar en interiores?", answer: "Sí, completamente seguro. Nuestras máquinas de humo bajo utilizan hielo seco (CO2 sólido) o fluido de glicol de grado alimenticio que genera una niebla densa a nivel del suelo sin dejar residuos ni activar alarmas contra incendio. El efecto se disipa en minutos y no irrita ojos ni vías respiratorias. Trabajamos con ventilación controlada y nuestro técnico monitorea los niveles de CO2 en todo momento para garantizar la seguridad de tus invitados." },
  { question: "¿Los sparklers fríos representan riesgo de incendio?", answer: "No. A diferencia de la pirotecnia tradicional, los sparklers fríos utilizan polvo de titanio que produce chispas a baja temperatura (aproximadamente 60-80°C en la punta). No generan llama real, no queman al contacto con la piel y no encienden materiales inflamables. Son seguros para interiores, salones con alfombra y jardines. Cumplimos con todas las normativas de protección civil de CDMX y siempre realizamos una prueba previa en tu venue." },
  { question: "¿Los láseres son seguros para los ojos de los asistentes?", answer: "Absolutamente. Todos nuestros shows de láser cumplen con normativas internacionales de seguridad (IEC 60825). Los haces se proyectan por encima de la altura de las personas (zona de audiencia segura) y utilizamos sistemas de seguridad con sensores que apagan el láser si detectan una obstrucción en la zona de exclusión. Nuestro operador certificado programa cada show según las dimensiones de tu venue para garantizar que los haces nunca impacten directamente a los ojos." },
  { question: "¿Quién se encarga de la limpieza del confeti después del evento?", answer: "Incluimos la recolección del confeti como parte de nuestro servicio. Después del evento, nuestro equipo recoge el confeti con aspiradoras industriales y escobas. Si tu venue requiere que la limpieza sea inmediata, ofrecemos servicio de limpieza express. También contamos con opciones de confeti biodegradable y soluble en agua para eventos en jardines y espacios abiertos donde la limpieza completa es más compleja." },
  { question: "¿Puedo combinar varios efectos especiales en un mismo evento?", answer: "Por supuesto, y es lo que más recomendamos. Los efectos se potencian entre sí: humo bajo para el primer baile combinado con sparklers fríos para la entrada de los novios, láser durante la fiesta y cañones de confeti para el momento cumbre. Ofrecemos paquetes combinados con descuento que incluyen operador técnico dedicado, programación sincronizada con la música de tu DJ y coordinación con tu wedding planner o productor de eventos." },
  { question: "¿Con cuánta anticipación debo reservar los efectos especiales?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas). Para shows de láser programados o paquetes de efectos completos, lo ideal es apartar con 1 a 2 meses para incluir la visita técnica al venue y la programación personalizada. También atendemos solicitudes de último momento sujetas a disponibilidad de equipo y operadores." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Efectos Especiales para Eventos en CDMX",
    description: "Humo bajo, láser multicolor, sparklers fríos y cañones de confeti para bodas, fiestas y eventos corporativos. Operador incluido.",
    url: "/servicios/iluminacion/efectos-especiales/",
    priceRange: { min: 800, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Efectos Especiales", url: "/servicios/iluminacion/efectos-especiales/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Efectos Especiales para Eventos en CDMX"
  description="Renta de humo bajo, láser multicolor, sparklers fríos y cañones de confeti para eventos en CDMX. Operador incluido. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Momentos que dejan huella"
    title='Renta de <span class="highlight">Efectos Especiales</span> para Eventos en CDMX'
    subtitle="Humo bajo, láser multicolor, sparklers fríos y cañones de confeti para crear momentos espectaculares. Equipo profesional con operador técnico incluido en cada renta."
    primaryCTA={{ label: "Cotiza tus efectos", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar efectos especiales para mi evento` }}
    cards={[
      {
        title: "Efectos especiales de grado profesional para cada evento",
        content: "<strong>Renta de efectos especiales para eventos</strong> con tecnología de última generación disponible en CDMX. Máquinas de humo bajo con hielo seco y niebla de glicol para primer baile y pasarelas. Sistemas láser RGB de 2 a 10W con sincronización DMX/ILDA para shows programados. Sparklers fríos de polvo de titanio seguros para interiores con alturas de 2 a 5 metros. Cañones de confeti CO2 y lanzadores de serpentinas con colores personalizados — cada efecto verificado y probado antes de cada evento.",
      },
      {
        title: "Operación profesional con técnico dedicado",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de efectos especiales. Nuestro operador certificado se encarga del transporte, instalación segura, programación de secuencias sincronizadas con la música, pruebas previas al evento y operación en tiempo real durante toda la celebración. Cumplimos con normativas de protección civil de CDMX y realizamos evaluación previa de cada venue para garantizar seguridad total.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres un momento espectacular en tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta técnica con los efectos ideales para tu celebración"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de efectos especiales
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Efectos Especiales"
        subtitle="La magia visual que transforma cada momento"
        description={[
          "Desde humo bajo para el primer baile hasta shows de láser para la pista. Contamos con el inventario de efectos especiales más completo de la Ciudad de México para bodas, fiestas y eventos corporativos.",
          "Cada efecto incluye equipo profesional certificado, operador técnico dedicado y evaluación previa de tu venue. Seguridad garantizada para interiores y exteriores."
        ]}
      />

      <div class="grid grid--4">
        {EFECTOS.map((efecto) => (
          <Card
            name={efecto.name}
            excerpt={efecto.excerpt}
            cta={efecto.cta}
            href={efecto.href}
            icon={efecto.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HUMO BAJO Y NIEBLA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="humo-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Momento mágico</span>
          <h2 class="showcase__title" id="humo-heading">Humo Bajo y Niebla</h2>
          <p class="showcase__subtitle">El efecto más romántico y cinematográfico para primer baile, pasarelas y entradas dramáticas.</p>
          <p class="showcase__text">Nuestras <strong>máquinas de humo bajo con hielo seco</strong> generan una niebla densa y rasante que cubre el suelo creando el efecto de caminar entre nubes. Utilizamos <strong>hielo seco de grado profesional</strong> que produce una niebla blanca espesa a nivel del piso, perfecta para el <strong>primer baile de bodas, entradas de quinceañeras y pasarelas de moda</strong>. El efecto dura entre 3 y 5 minutos por activación y se disipa sin dejar residuos ni olores.</p>
          <p class="showcase__text">También contamos con <strong>máquinas de niebla de glicol (haze)</strong> para crear una atmósfera envolvente que realza los haces de luz y láser. El haze permanece suspendido en el ambiente durante horas, ideal para <strong>fiestas, conciertos y eventos con iluminación dramática</strong>. Ambos efectos son completamente seguros para interiores y no activan alarmas contra incendio. Combínalos con nuestras <a href="/servicios/pistas-baile/">pistas de baile iluminadas</a> para un momento verdaderamente mágico.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Hielo seco</span>
            <span class="showcase__tag">Niebla glicol</span>
            <span class="showcase__tag">Primer baile</span>
            <span class="showcase__tag">Seguro interior</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Humo Bajo
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 15c2.483 0 4.345-3 4.345-3s1.862 3 4.345 3c2.483 0 4.345-3 4.345-3s1.862 3 4.345 3"/>
              <path d="M3 19c2.483 0 4.345-3 4.345-3s1.862 3 4.345 3c2.483 0 4.345-3 4.345-3s1.862 3 4.345 3"/>
              <path d="M12 3v6m-3-3l3 3 3-3"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LÁSER MULTICOLOR — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="laser-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Espectáculo visual</span>
          <h2 class="showcase__title" id="laser-heading">Láser Multicolor</h2>
          <p class="showcase__subtitle">Shows de láser RGB programados que transforman cualquier espacio en un espectáculo de luz y color.</p>
          <p class="showcase__text">Nuestros <strong>sistemas láser RGB de 2 a 10W</strong> producen haces de luz intensos y nítidos en miles de combinaciones de color. Creamos <strong>efectos aéreos espectaculares</strong> como túneles de láser, abanicos, ondas, vórtices y cortinas de luz que envuelven a tus invitados en una experiencia visual inmersiva. Cada show se <strong>programa a medida con sincronización DMX/ILDA</strong> que permite coordinar los haces de láser con la música de tu DJ o playlist en tiempo real.</p>
          <p class="showcase__text">Disponemos de <strong>láseres de animación para proyectar logos, textos y gráficos</strong> sobre paredes y techos, ideales para lanzamientos de producto y eventos corporativos. Todos nuestros equipos cumplen con normativas internacionales de seguridad IEC 60825 y son operados por técnicos certificados que garantizan que los haces se mantengan en la zona segura por encima de la audiencia. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción de nivel profesional.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">RGB 2-10W</span>
            <span class="showcase__tag">DMX / ILDA</span>
            <span class="showcase__tag">Túnel láser</span>
            <span class="showcase__tag">Sync musical</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Show Láser
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SPARKLERS FRÍOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="sparklers-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Sin fuego real</span>
          <h2 class="showcase__title" id="sparklers-heading">Sparklers Fríos</h2>
          <p class="showcase__subtitle">Chispas frías espectaculares sin riesgo de incendio, seguras para interiores y cualquier tipo de venue.</p>
          <p class="showcase__text">Nuestras <strong>máquinas de sparklers fríos</strong> utilizan <strong>polvo de titanio granulado</strong> que al calentarse produce una cascada de chispas brillantes a baja temperatura (60-80°C en la punta). A diferencia de la pirotecnia tradicional, <strong>no generan llama real, no queman al contacto y no encienden materiales inflamables</strong>. Disponibles con alturas ajustables de <strong>2 a 5 metros</strong>, son el efecto estrella para entradas y salidas de novios, corte de pastel y momentos climáticos de la fiesta.</p>
          <p class="showcase__text">Ofrecemos configuraciones desde <strong>2 hasta 8 máquinas simultáneas</strong> que se activan por control remoto o DMX para crear pasillos de chispas, arcos brillantes y marcos espectaculares. Cada máquina tiene autonomía para múltiples activaciones durante el evento. Cumplimos con todas las <strong>normativas de protección civil de CDMX</strong> y siempre realizamos una prueba técnica previa en tu venue. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario de evento</a> para un montaje integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Polvo titanio</span>
            <span class="showcase__tag">2-5 m altura</span>
            <span class="showcase__tag">Control remoto</span>
            <span class="showcase__tag">Indoor safe</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Sparklers Fríos
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L9 12l3 2 3-2L12 2z"/>
              <path d="M12 14v8"/>
              <path d="M8 18l4-4 4 4"/>
              <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
              <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CONFETI Y SERPENTINAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="confeti-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Celebración explosiva</span>
          <h2 class="showcase__title" id="confeti-heading">Confeti y Serpentinas</h2>
          <p class="showcase__subtitle">Cañones de confeti CO2 y lanzadores de serpentinas para los momentos más explosivos de tu celebración.</p>
          <p class="showcase__text">Nuestros <strong>cañones de confeti CO2</strong> disparan ráfagas de confeti a alturas de <strong>8 a 15 metros</strong> con un efecto visual impresionante que cubre toda la pista de baile. Disponibles en <strong>confeti metálico, papel de colores, biodegradable y holográfico</strong> con la posibilidad de personalizar los colores para que combinen con la temática de tu evento. Los <strong>lanzadores de serpentinas</strong> crean streamers de hasta 10 metros de largo que flotan espectacularmente sobre los invitados.</p>
          <p class="showcase__text">Ofrecemos configuraciones con <strong>múltiples cañones sincronizados por DMX</strong> para crear lluvia de confeti simultánea desde varios puntos del venue. Ideales para <strong>conteos regresivos, brindis, primer baile, entrada de artistas y finales de show</strong>. Incluimos servicio de limpieza post-evento con aspiradoras industriales. También contamos con opciones de confeti soluble en agua para eventos en jardín. Combina con nuestras <a href="/servicios/carpas/">carpas para eventos</a> para celebraciones al aire libre sin preocupaciones.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Cañones CO2</span>
            <span class="showcase__tag">Serpentinas</span>
            <span class="showcase__tag">Colores custom</span>
            <span class="showcase__tag">Biodegradable</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Confeti
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2"/>
              <path d="M8 14s1.5 2 4 2 4-2 4-2"/>
              <line x1="9" y1="9" x2="9.01" y2="9"/>
              <line x1="15" y1="9" x2="15.01" y2="9"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Efectos Especiales"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tus efectos especiales, es natural tener preguntas sobre seguridad, funcionamiento y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre efectos especiales al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de efectos especiales para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
