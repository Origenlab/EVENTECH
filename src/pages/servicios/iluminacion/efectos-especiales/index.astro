            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: tipo de venue (salón/jardín/terraza), momento del evento para los efectos, número de invitados, si ya cuentas con DJ o coordinador..."
