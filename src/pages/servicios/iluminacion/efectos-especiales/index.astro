---
/**
 * ─── EVENTECH.MX — Renta de Efectos Especiales para Eventos (Hub L4, molde hm- 2026) ───
 * Humo Bajo · Láser · Mariposas · Confeti — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/iluminacion — efectos-especiales-humo-bajo, neon-uv reales; evento genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const SUB_SERVICES = [
  {
    id: "humo-bajo",
    name: "Humo Bajo y Niebla",
    badge: "El primer baile",
    excerpt: "Máquinas de humo bajo con hielo seco y niebla de glicol para primer baile, pasarelas y entradas dramáticas. Efecto rasante seguro, sin activar alarmas contra incendio.",
    href: "/servicios/iluminacion/efectos-especiales/humo-bajo/",
    image: "/images/iluminacion/efectos-especiales-humo-bajo.avif",
    specs: ["Hielo seco / glicol", "Rasante", "Sin alarma", "Grado alimenticio"],
  },
  {
    id: "laser",
    name: "Láser Multicolor",
    badge: "Show de fiesta",
    excerpt: "Shows de láser RGB de 2 a 10W con efectos aéreos, túneles, abanicos y ondas. Sincronización DMX/ILDA con música para espectáculos inolvidables.",
    href: "/servicios/iluminacion/efectos-especiales/laser/",
    image: "/images/iluminacion/luces-neon-uv-fiesta-glow.avif",
    specs: ["RGB 2–10W", "ILDA", "Sync música", "IEC 60825"],
  },
  {
    id: "mariposas",
    name: "Papelitos de Mariposas",
    badge: "Efecto mágico",
    excerpt: "Lanzadores de papelitos en forma de mariposa con colores personalizados. Efecto mágico para cumpleaños, XV años, baby showers y fiestas infantiles.",
    href: "/servicios/iluminacion/efectos-especiales/mariposas/",
    image: "/images/iluminacion/iluminacion-evento-03.avif",
    specs: ["Biodegradable", "Colores custom", "Aire comprimido", "Alcance 3–8 m"],
  },
  {
    id: "confeti",
    name: "Confeti y Serpentinas",
    badge: "Momento cumbre",
    excerpt: "Cañones de confeti CO2 y lanzadores de serpentinas con papeles metálicos, de papel y colores personalizados para momentos de celebración explosiva.",
    href: "/servicios/iluminacion/efectos-especiales/confeti/",
    image: "/images/iluminacion/iluminacion-evento-04.avif",
    specs: ["Cañones CO2", "Metálico / papel", "Colores custom", "Recolección incluida"],
  },
  {
    id: "luz-negra",
    name: "Luz Negra UV",
    badge: "Efecto glow neón",
    excerpt: "Luz negra y equipo UV que hace brillar todo lo fluorescente. El efecto glow que convierte una pista en una fiesta neón — el favorito de after parties y XV años.",
    href: "/servicios/iluminacion/efectos-especiales/luz-negra/",
    image: "/images/iluminacion/luces-neon-uv-fiesta-glow.avif",
    specs: ["UV 395nm", "Efecto fluor", "Cobertura pista", "Accesorios glow"],
  },
];

const whyFeatures = [
  {
    title: "Operador técnico que dispara en el momento exacto",
    body: "Un efecto especial disparado tarde arruina el momento. Cada renta incluye un operador que coordina con tu DJ y wedding planner para disparar humo, láser, mariposas o confeti en el segundo preciso —el 'sí, acepto', el primer beso, el momento cumbre de la canción— sincronizado con la música. El timing lo es todo, y por eso no lo dejamos al azar.",
  },
  {
    title: "Efectos seguros y certificados",
    body: "Espectáculo sin riesgo. Nuestros láseres cumplen la norma internacional IEC 60825 con haces sobre la altura del público y sensores de zona de exclusión; el humo bajo es de grado alimenticio que no activa alarmas ni irrita; las mariposas usan aire comprimido, sin fuego ni pirotecnia. Diversión de alto impacto operada con protocolo de seguridad.",
  },
  {
    title: "Limpieza y recolección incluidas",
    body: "El confeti bonito en el aire es un problema en el piso — a menos que alguien lo recoja. Incluimos la recolección con aspiradoras industriales tras el evento, y las mariposas también se recogen. Ofrecemos opciones biodegradables y solubles para jardines. Tú disfrutas el efecto; nosotros nos encargamos de lo que queda después.",
  },
  {
    title: "Sin residuos ni daño al venue",
    body: "Muchos salones y haciendas ponen reglas estrictas por experiencias con proveedores descuidados. Nuestros efectos no manchan, no dejan residuo grasoso ni dañan superficies: humo que se disipa en minutos, confeti soluble, mariposas de papel de seda. Cumplimos con la normativa del venue para que no haya sorpresas ni cargos extra.",
  },
  {
    title: "Personalización de color y material",
    body: "El confeti y las mariposas en los colores de tu evento multiplican el efecto en las fotos. Personalizamos el color y el material —metálico para brillo, papel para elegancia, biodegradable para exteriores— según tu paleta y tu venue. Un detalle que parece pequeño y que se vuelve el clímax visual de la celebración.",
  },
  {
    title: "Paquetes combinados con un solo operador",
    body: "Los efectos se potencian entre sí: humo bajo en el primer baile, mariposas en la sorpresa, láser en la fiesta y confeti en el momento cumbre. Armamos paquetes combinados con descuento, operados por un solo técnico que sincroniza todo con tu DJ — más impacto, una sola logística y mejor precio que contratar cada efecto por separado.",
  },
];

const steps = [
  { n: 1, t: "Asesoría del momento a impactar", p: "Nos cuentas qué momentos quieres realzar: primer baile, entrada, sorpresa, brindis o clímax de la fiesta. Te recomendamos qué efecto va mejor en cada uno y armamos la propuesta. En menos de 24 horas te confirmamos disponibilidad y precio, con opción de paquete combinado." },
  { n: 2, t: "Propuesta, personalización y aparto", p: "Definimos efectos, color y material (confeti metálico o soluble, mariposas biodegradables, potencia del láser). Con el anticipo apartamos el equipo y la fecha. Para shows de láser programados coordinamos la visita técnica y la programación con tiempo." },
  { n: 3, t: "Montaje, programación y prueba", p: "Instalamos el equipo con anticipación, programamos los disparos y —en el caso del láser— configuramos las zonas de seguridad según el venue. Coordinamos con tu DJ los momentos exactos y hacemos prueba antes del evento para que todo dispare a la primera." },
  { n: 4, t: "Operación en vivo y recolección", p: "El operador dispara cada efecto en el momento preciso, sincronizado con la música. Al finalizar, recogemos confeti, mariposas y desmontamos el equipo. La operación y la recolección están incluidas sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿El humo bajo es seguro para usar en interiores?", answer: "Sí, completamente seguro. Nuestras máquinas de humo bajo utilizan hielo seco (CO2 sólido) o fluido de glicol de grado alimenticio que genera una niebla densa a nivel del suelo sin dejar residuos ni activar alarmas contra incendio. El efecto se disipa en minutos y no irrita ojos ni vías respiratorias. Trabajamos con ventilación controlada y nuestro técnico monitorea los niveles de CO2 en todo momento para garantizar la seguridad de tus invitados." },
  { question: "¿Los papelitos de mariposas son seguros para interiores?", answer: "Sí, completamente seguros. Los papelitos de mariposas están fabricados en papel de seda ultraligero y biodegradable que no genera residuos dañinos ni mancha superficies. Los lanzadores utilizan aire comprimido (sin fuego ni pirotecnia) para proyectar las mariposas a alturas de 3 a 8 metros, creando un efecto mágico de mariposas volando. Son aptos para salones, jardines, terrazas y cualquier tipo de venue. Incluimos servicio de recolección posterior al evento." },
  { question: "¿Los láseres son seguros para los ojos de los asistentes?", answer: "Absolutamente. Todos nuestros shows de láser cumplen con normativas internacionales de seguridad (IEC 60825). Los haces se proyectan por encima de la altura de las personas (zona de audiencia segura) y utilizamos sistemas de seguridad con sensores que apagan el láser si detectan una obstrucción en la zona de exclusión. Nuestro operador certificado programa cada show según las dimensiones de tu venue para garantizar que los haces nunca impacten directamente a los ojos." },
  { question: "¿Los venues permiten estos efectos? ¿Requieren permiso?", answer: "La mayoría de los venues permiten nuestros efectos precisamente porque son seguros y limpios: humo de grado alimenticio que no activa alarmas, láser certificado, mariposas y confeti sin fuego. Aun así, cada salón tiene sus reglas, por lo que coordinamos directamente con tu venue para confirmar sus políticas antes del evento. En espacios con detectores de humo muy sensibles usamos humo bajo de hielo seco (que no sube) o coordinamos la desactivación temporal supervisada. Nos encargamos de que todo esté en regla." },
  { question: "¿Quién se encarga de la limpieza del confeti después del evento?", answer: "Incluimos la recolección del confeti como parte de nuestro servicio. Después del evento, nuestro equipo recoge el confeti con aspiradoras industriales y escobas. Si tu venue requiere que la limpieza sea inmediata, ofrecemos servicio de limpieza express. También contamos con opciones de confeti biodegradable y soluble en agua para eventos en jardines y espacios abiertos donde la limpieza completa es más compleja." },
  { question: "¿Puedo combinar varios efectos especiales en un mismo evento?", answer: "Por supuesto, y es lo que más recomendamos. Los efectos se potencian entre sí: humo bajo para el primer baile combinado con papelitos de mariposas para el momento de la sorpresa, láser durante la fiesta y cañones de confeti para el momento cumbre. Ofrecemos paquetes combinados con descuento que incluyen operador técnico dedicado, programación sincronizada con la música de tu DJ y coordinación con tu wedding planner o productor de eventos." },
  { question: "¿Con cuánta anticipación debo reservar los efectos especiales?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y temporada de bodas). Para shows de láser programados o paquetes de efectos completos, lo ideal es apartar con 1 a 2 meses para incluir la visita técnica al venue y la programación personalizada. También atendemos solicitudes de último momento sujetas a disponibilidad de equipo y operadores." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Efectos Especiales para Eventos en CDMX",
    description: "Renta de humo bajo, láser multicolor, papelitos de mariposas y cañones de confeti para bodas y fiestas en CDMX. Operador técnico y recolección incluidos.",
    url: "/servicios/iluminacion/efectos-especiales/",
    priceRange: { min: 800, max: 25000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Efectos Especiales", url: "/servicios/iluminacion/efectos-especiales/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Efectos Especiales" },
];
---

<PageLayout
  title="Renta de Efectos Especiales para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/iluminacion/efectos-especiales-humo-bajo.avif"
  description="Renta de humo bajo, láser multicolor, papelitos de mariposas y cañones de confeti para bodas y fiestas en CDMX. Operador y recolección incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="fx-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Efectos especiales · CDMX y ZMVM</p>
            <h1 id="fx-hero-heading">
              Efectos especiales que crean <em>el momento inolvidable</em> de tu evento
            </h1>
            <p class="hm-hero__lead">
              Humo bajo para el primer baile, láser multicolor para la fiesta, papelitos de
              mariposas y cañones de confeti. Los efectos que convierten un momento en el recuerdo
              de la noche — seguros, limpios y operados por técnico.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20efectos%20especiales%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar efectos
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>efectos especiales para eventos</strong> en CDMX:
              <strong>humo bajo</strong> con hielo seco para el primer baile, <strong>shows de láser
              RGB</strong> de 2 a 10W sincronizados con música, <strong>papelitos de mariposas</strong>
              biodegradables y <strong>cañones de confeti CO2</strong> en colores personalizados. Todos
              seguros, certificados y disparados en el momento exacto por un operador técnico.
            </p>
            <p>
              Con <strong>más de 500 eventos</strong> realzados en CDMX, sabemos que un efecto bien
              disparado se vuelve la foto y el video que todos comparten: por eso cada renta incluye
              operador, sincronización con tu DJ y recolección. Combínalos con nuestra
              <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a>,
              <a href="/servicios/audiovisual/microfonos-dj/">cabina DJ</a> y
              <a href="/servicios/audiovisual/sonido/">sonido</a> para un show completo desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de efectos especiales disponibles">
      <ul class="hm-menu__grid hm-menu--cols6">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20efectos%20especiales%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">El clímax visual de tu evento</p>
            <h2 id="catalogo-heading">¿Qué momento quieres volver inolvidable?</h2>
            <p class="hm__head-sub">5 efectos — del humo del primer baile al confeti del momento cumbre y el glow de luz negra.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Los efectos especiales son lo que convierte un buen momento en EL momento: el humo que
              hace flotar el primer baile, el láser que enciende la fiesta, las mariposas de la
              sorpresa, el confeti que estalla en el clímax. Son la foto y el video que todos comparten
              al día siguiente.
            </p>
            <p>
              Humo bajo para momentos íntimos y dramáticos. Láser para la energía de la fiesta.
              Mariposas para la magia de una sorpresa. Confeti para el estallido de celebración. Una
              sola empresa para todos los efectos de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada efecto, a fondo</p>
            <h2 id="detalle-heading">Los 5 efectos especiales — en detalle</h2>
            <p class="hm__head-sub">Tecnología, seguridad, personalización y para qué momento del evento funciona mejor cada uno.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada efecto hay decisiones que afectan el impacto y la seguridad: el tipo de
              humo que decide si sube o queda rasante, la potencia del láser y sus zonas de exclusión,
              y el material del confeti que define si mancha o se limpia fácil.
            </p>
            <p>
              Conocer estas diferencias te permite elegir el efecto correcto para cada momento. A
              continuación, lo que realmente importa de cada uno.
            </p>
          </div>
        </div>

        <!-- HUMO BAJO -->
        <article class="hm-feat" aria-labelledby="feat-humo-bajo">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Humo Bajo y Niebla</p>
            <h3 class="hm-feat__title" id="feat-humo-bajo">La nube rasante que hace flotar el primer baile</h3>
            <p class="hm-feat__lead">El efecto más romántico y fotografiado de las bodas. Una capa de niebla a ras del piso hace que los novios parezcan bailar sobre las nubes — sin subir a las alturas ni activar una sola alarma.</p>
            <p>
              Máquinas de humo bajo con <strong>hielo seco (CO2 sólido)</strong> o <strong>niebla de
              glicol de grado alimenticio</strong> que generan una niebla densa <strong>a nivel del
              suelo</strong>, sin residuos y sin activar alarmas contra incendio. El efecto se disipa
              en minutos y no irrita ojos ni vías respiratorias.
            </p>
            <p>
              Perfecto para <strong>primer baile, entradas dramáticas, pasarelas y sesiones de
              foto</strong>. Nuestro técnico monitorea los niveles de CO2 con ventilación controlada.
              Combínalo con <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a>
              — los haces de luz sobre la niebla crean el efecto más cinematográfico.
            </p>
            <ul class="hm-feat__stats">
              {["Hielo seco / glicol", "Rasante", "Sin alarma", "Grado alimenticio", "Se disipa rápido"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/iluminacion/efectos-especiales/humo-bajo/">
              Ver Humo Bajo y Niebla
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/iluminacion/efectos-especiales-humo-bajo.avif" alt="Humo bajo rasante para primer baile de boda en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/iluminacion/iluminacion-evento-01.avif" alt="Niebla baja iluminada con haces de luz en escenario" loading="lazy" decoding="async" />
              <img src="/images/iluminacion/iluminacion-evento-05.avif" alt="Efecto de humo bajo en entrada dramática de evento" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- LÁSER -->
        <article class="hm-feat" aria-labelledby="feat-laser">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Láser Multicolor</p>
            <h3 class="hm-feat__title" id="feat-laser">Haces de láser que encienden la pista con energía de concierto</h3>
            <p class="hm-feat__lead">Cuando la fiesta necesita subir de nivel, el láser lo hace. Túneles, abanicos y ondas de luz sincronizados con el beat transforman una pista de baile en un show de festival.</p>
            <p>
