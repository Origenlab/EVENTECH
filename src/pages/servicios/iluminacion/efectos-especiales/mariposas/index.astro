---
/**
 * ─── Papelitos de Mariposas — Página de Producto (Nivel 4) ───
 * Lanzadores de papel de seda para cumpleaños, XV años y celebraciones.
 *
 * Jerarquía: Servicios > Iluminación > Efectos Especiales > Papelitos de Mariposas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
  { label: "Papelitos de Mariposas" },
];

const faqs = [
  { question: "¿Los papelitos de mariposas son seguros para interiores?", answer: "Sí, completamente seguros. Los papelitos de mariposas están fabricados en papel de seda ultraligero y biodegradable que no genera residuos dañinos ni mancha superficies. Los lanzadores utilizan aire comprimido (sin fuego, sin pirotecnia, sin químicos) para proyectar las mariposas a alturas de 3 a 8 metros. Son aptos para salones cerrados, jardines, terrazas y cualquier tipo de venue. No representan riesgo para niños, adultos mayores ni personas con alergias." },
  { question: "¿Puedo personalizar los colores de las mariposas?", answer: "Por supuesto. Ofrecemos mariposas en una amplia gama de colores que se pueden combinar para crear paletas personalizadas. Tonos pastel (rosa, lila, celeste, menta) para baby showers, rosa y dorado para XV años, blanco y plateado para bodas, multicolor para cumpleaños infantiles, y combinaciones con los colores de tu marca para eventos corporativos. Envíanos tu paleta de colores y preparamos la mezcla exacta para tu evento." },
  { question: "¿Quién se encarga de la limpieza después del lanzamiento?", answer: "Incluimos servicio de recolección como parte del paquete. Después de cada lanzamiento, nuestro equipo recoge los papelitos con aspiradoras y escobas. Si tu venue requiere limpieza inmediata entre lanzamientos, coordinamos tiempos de recolección con tu wedding planner o coordinador. Los papelitos de papel de seda son 100% biodegradables, así que en eventos en jardín también se pueden dejar como parte de la decoración sin impacto ambiental." },
  { question: "¿Se pueden combinar mariposas con otros efectos especiales?", answer: 'Sí, y es una combinación espectacular. Las mariposas combinan perfectamente con <a href="/servicios/iluminacion/efectos-especiales/confeti/">cañones de confeti</a> para crear lluvia de mariposas + confeti en momentos cumbre, o con <a href="/servicios/iluminacion/efectos-especiales/humo-bajo/">humo bajo</a> para que las mariposas caigan sobre una capa de niebla rasante. Ofrecemos paquetes combinados con descuento que incluyen coordinación técnica entre todos los efectos para sincronizar las activaciones.' },
  { question: "¿Se pueden usar los lanzadores de mariposas en exteriores?", answer: "Sí, funcionan perfectamente en exteriores. Sin embargo, en condiciones de viento fuerte recomendamos ajustar la posición de los lanzadores y la dirección del disparo para que las mariposas caigan sobre la zona deseada. En jardines y terrazas sin viento, el efecto es espectacular: las mariposas flotan y descienden suavemente creando una lluvia mágica. Nuestro técnico evalúa las condiciones del espacio antes del evento y posiciona los lanzadores estratégicamente." },
  { question: "¿Con cuánta anticipación debo reservar papelitos de mariposas?", answer: "Recomendamos reservar con 2 a 3 semanas de anticipación para garantizar disponibilidad de lanzadores y la preparación de mariposas en los colores personalizados que elijas. En temporada alta (mayo para Día de las Madres, noviembre-diciembre para posadas y fin de año) lo ideal es apartar con 1 mes. Para pedidos con colores estándar (blanco, rosa, multicolor), podemos atender solicitudes con 1 semana de anticipación sujetas a disponibilidad." },
];

const specs = [
  { label: "Material", value: "Papel de seda ultraligero biodegradable" },
  { label: "Forma", value: "Mariposa recortada (varios tamaños)" },
  { label: "Colores", value: "Personalizable (paleta completa disponible)" },
  { label: "Altura de vuelo", value: "3 – 8 metros" },
  { label: "Activación", value: "Aire comprimido / Control remoto" },
  { label: "Biodegradable", value: "Sí — 100% papel de seda, sin plásticos" },
  { label: "Unidades disponibles", value: "2 – 6 lanzadores simultáneos" },
  { label: "Autonomía", value: "Múltiples activaciones por lanzador" },
  { label: "Limpieza", value: "Recolección post-evento incluida" },
  { label: "Seguridad", value: "Sin fuego, sin pirotecnia, apto todas las edades" },
];

const sidebarNav = [
  { name: "Humo Bajo y Niebla", href: "/servicios/iluminacion/efectos-especiales/humo-bajo/" },
  { name: "Láser Multicolor", href: "/servicios/iluminacion/efectos-especiales/laser/" },
  { name: "Papelitos de Mariposas", href: null, active: true },
  { name: "Confeti y Serpentinas", href: "/servicios/iluminacion/efectos-especiales/confeti/" },
];

const sidebarRelated = [
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Equipo Audiovisual", href: "/servicios/audiovisual/" },
  { name: "Mobiliario Premium", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Sofía Hernández", text: "Contratamos mariposas de papel para el cumpleaños de mi hija de 7 años. El momento en que las mariposas salieron volando fue mágico — todos los niños gritaron de emoción. Elegimos colores pastel rosa y lila que combinaron perfecto con la decoración. El equipo fue muy amable y la limpieza fue rapidísima. Lo más bonito de la fiesta.", rating: 5, date: "2025-11-25" },
  { author: "Gabriela Torres", text: "Para los XV años de mi hija pedimos mariposas en rosa y dorado. El lanzamiento durante el vals fue el momento más especial de toda la noche — literalmente llovieron mariposas sobre ella y su chambelán. Las fotos quedaron espectaculares. El técnico coordinó perfectamente el momento con el DJ. 100% recomendable.", rating: 5, date: "2025-10-12" },
  { author: "Patricia Mendoza", text: "Usamos mariposas azules y blancos para el baby shower de mi hermana. La sorpresa fue increíble cuando las mariposas volaron al momento de revelar el género del bebé. Efecto precioso, seguro y sin manchas. El equipo de Eventech fue puntual y profesional. Ya estamos planeando usarlos para el bautizo también.", rating: 5, date: "2025-09-20" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Papelitos de Mariposas para Eventos en CDMX",
    description: "Lanzadores de papelitos en forma de mariposa con colores personalizados para cumpleaños, XV años y baby showers en CDMX. Biodegradable y seguro. Operador incluido. Desde $600.",
    url: "/servicios/iluminacion/efectos-especiales/mariposas/",
    priceRange: { min: 600, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 42,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Efectos Especiales", url: "/servicios/iluminacion/efectos-especiales/" },
    { name: "Papelitos de Mariposas", url: "/servicios/iluminacion/efectos-especiales/mariposas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Papelitos de Mariposas para Eventos en CDMX"
  description="Renta de lanzadores de papelitos de mariposas con colores personalizados para cumpleaños, XV años y baby showers en CDMX. Biodegradable y seguro. Desde $600. Cotiza hoy."
  jsonLd={jsonLd}
>
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <HeroPage
    badge="Magia en el aire para celebraciones"
    title='Renta de <span class="highlight">Papelitos de Mariposas</span> para Eventos en CDMX'
    subtitle="Lanzadores de papelitos en forma de mariposa con colores personalizados para cumpleaños, XV años y baby showers. Efecto mágico de mariposas volando con aire comprimido. Seguro, biodegradable y con recolección incluida."
    primaryCTA={{ label: "Cotiza tus mariposas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar papelitos de mariposas para mi evento` }}
    cards={[
      {
        title: "Mariposas de papel de seda con colores personalizados",
        content: "<strong>Renta de papelitos de mariposas para eventos</strong> con lanzadores de aire comprimido que proyectan cientos de mariposas de papel de seda a alturas de 3 a 8 metros. Colores totalmente personalizables: tonos pastel para baby showers, rosa y dorado para XV años, multicolor para cumpleaños infantiles. Configuraciones de 2 a 6 lanzadores simultáneos con múltiples activaciones por evento. 100% biodegradable y seguro para todas las edades.",
      },
      {
        title: "Sin pirotecnia, seguro para interiores y todas las edades",
        content: "<strong>Efecto mágico sin riesgos</strong> — los lanzadores utilizan aire comprimido (sin fuego, sin químicos) para crear una lluvia de mariposas que flotan y descienden suavemente. Aptos para salones cerrados, jardines y terrazas. Incluye operador técnico que coordina las activaciones con tu DJ o coordinador de evento. Servicio de recolección post-lanzamiento incluido para dejar el venue impecable.",
      },
    ]}
  />

  <CTABanner
    headline="¿Quieres una lluvia de mariposas en tu celebración?"
    subheadline="Cotiza sin compromiso — te ayudamos a elegir los colores perfectos para tu evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Efectos Especiales</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas mariposas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar papelitos de mariposas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN CONTENT + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Papelitos de Mariposas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Mariposas para Cumpleaños -->
          <section class="section section--alt" aria-labelledby="cumple-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El favorito de los niños</span>
                <h2 class="showcase__title" id="cumple-heading">Mariposas para Cumpleaños</h2>
                <p class="showcase__subtitle">Lluvia de mariposas multicolor para el momento de soplar las velitas y la piñata.</p>
                <p class="showcase__text">Las <strong>mariposas para cumpleaños</strong> son nuestro efecto más solicitado para fiestas infantiles. Los lanzadores disparan cientos de mariposas de papel de seda multicolor que vuelan hasta <strong>5 metros de altura</strong> y descienden suavemente sobre los invitados, creando un momento mágico que los niños recuerdan para siempre. Activación por control remoto para sincronizar el lanzamiento con el momento exacto de soplar las velitas, la piñata o la sorpresa.</p>
                <p class="showcase__text">Configuraciones de <strong>2 a 4 lanzadores</strong> posicionados alrededor de la mesa del pastel o en la zona de celebración para crear una lluvia envolvente desde múltiples ángulos. Colores personalizables según la temática de la fiesta: unicornios en rosa y lila, dinosaurios en verde y azul, princesas en rosa y dorado, superhéroes en rojo y azul. Los papelitos son <strong>ultraligeros e inofensivos</strong> — los niños disfrutan atrapándolos mientras caen. Incluye recolección posterior.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cumpleaños infantil</span>
                  <span class="showcase__tag">2-4 lanzadores</span>
                  <span class="showcase__tag">Colores temáticos</span>
                  <span class="showcase__tag">Seguro niños</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Mariposas Cumpleaños
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Mariposas para Cumpleaños</span>
                </div>
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Mariposas para XV Años -->
          <section class="section section--alt" aria-labelledby="xv-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Momento de princesa</span>
                <h2 class="showcase__title" id="xv-heading">Mariposas para XV Años</h2>
                <p class="showcase__subtitle">Lluvia de mariposas rosa y dorado para el vals, el brindis y la coronación de la quinceañera.</p>
                <p class="showcase__text">Las <strong>mariposas para XV años</strong> crean uno de los momentos más emotivos de la celebración. Durante el vals o la coronación, los lanzadores disparan una lluvia de <strong>mariposas en rosa, dorado y blanco</strong> que envuelven a la quinceañera en un efecto mágico digno de una princesa. La combinación de mariposas descendiendo suavemente con la iluminación del salón produce fotografías y videos espectaculares.</p>
                <p class="showcase__text">Recomendamos <strong>4 a 6 lanzadores</strong> posicionados estratégicamente alrededor de la pista de baile para crear una experiencia envolvente de 360°. Coordinamos la activación con tu DJ para sincronizar el lanzamiento con el momento más emotivo de la canción del vals. Las mariposas pueden llevar <strong>detalles de glitter biodegradable</strong> para un brillo extra bajo las luces del salón. Complementa con <a href="/servicios/iluminacion/efectos-especiales/humo-bajo/">humo bajo</a> para que las mariposas caigan sobre una capa de niebla — el efecto es impresionante.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">XV Años</span>
                  <span class="showcase__tag">4-6 lanzadores</span>
                  <span class="showcase__tag">Rosa y dorado</span>
                  <span class="showcase__tag">Glitter biodegradable</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Mariposas XV Años
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Mariposas para XV Años</span>
                </div>
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Mariposas para Baby Shower -->
          <section class="section section--alt" aria-labelledby="baby-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Revelación mágica</span>
                <h2 class="showcase__title" id="baby-heading">Mariposas para Baby Shower</h2>
                <p class="showcase__subtitle">Revelación de género con mariposas azules o rosas, y lluvia pastel para la celebración.</p>
                <p class="showcase__text">Las <strong>mariposas para baby shower</strong> son perfectas para crear un momento sorpresa mágico. Para la <strong>revelación de género</strong>, los lanzadores se cargan con mariposas azules o rosas (según el caso) dentro de una caja decorativa — al abrirse, las mariposas vuelan revelando si es niño o niña con un efecto visual hermoso y emotivo que genera fotos y videos inolvidables para compartir con familia y amigos.</p>
                <p class="showcase__text">Para la celebración general del baby shower, ofrecemos mariposas en <strong>tonos pastel suaves</strong> (menta, lavanda, rosa pálido, amarillo) que combinan con la decoración típica de estos eventos. Configuraciones desde <strong>2 lanzadores</strong> para momentos puntuales hasta 4 para crear una experiencia envolvente. Los papelitos de seda son tan ligeros que flotan durante varios segundos antes de posarse, creando un efecto de mariposas en vuelo verdaderamente mágico. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario de evento</a> para un montaje integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Baby shower</span>
                  <span class="showcase__tag">Gender reveal</span>
                  <span class="showcase__tag">Tonos pastel</span>
                  <span class="showcase__tag">2-4 lanzadores</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Mariposas Baby Shower
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Mariposas para Baby Shower</span>
                </div>
              </div>
            </div>
          </section>

          <!-- SHOWCASE: Kit Mariposas + Decoración -->
          <section class="section section--alt" aria-labelledby="kit-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Paquete completo</span>
                <h2 class="showcase__title" id="kit-heading">Kit Mariposas + Decoración</h2>
                <p class="showcase__subtitle">Paquete completo: lanzadores múltiples + confeti complementario + coordinación con decorador.</p>
                <p class="showcase__text">Nuestro <strong>kit de mariposas + decoración</strong> combina los lanzadores de mariposas con <strong>confeti complementario en colores coordinados</strong> para crear una experiencia visual doble: primero vuelan las mariposas grandes y después cae una lluvia fina de confeti que llena todo el espacio. El resultado es un momento de celebración explosivo que genera aplausos y fotos espectaculares desde todos los ángulos.</p>
