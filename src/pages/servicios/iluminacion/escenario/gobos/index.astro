---
/**
 * ─── Gobos y Proyección de Monogramas — Página de Producto (Nivel 4) ───
 * Gobos metálicos y de vidrio, monogramas de novios y branding corporativo.
 * Color accent amber #c2a24a (jerarquía L4).
 *
 * Jerarquía: Servicios > Iluminación > Escenario > Gobos
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Escenario", href: "/servicios/iluminacion/escenario/" },
  { label: "Gobos" },
];

const faqs = [
  { question: "¿Puedo proyectar mi logo o monograma personalizado?", answer: 'Sí, es nuestra especialidad. Fabricamos un <strong>gobo a medida</strong> con tu logo corporativo, el monograma de los novios o las iniciales de la festejada a partir de tu diseño en vectores. Lo grabamos en acero (para proyección monocromática) o lo imprimimos en vidrio dicroico (para proyección a todo color) y lo montamos en un proyector LED. El resultado es tu marca o tu símbolo proyectado con nitidez sobre la pista, un muro o el escenario. También ofrecemos gobos estándar de patrones geométricos, florales, de estrellas y texturas incluidos sin costo adicional.' },
  { question: "¿Cuál es la diferencia entre un gobo de metal y uno de vidrio?", answer: 'El <strong>gobo metálico</strong> se corta en acero inoxidable y proyecta en un solo color — es la opción más económica y resistente, ideal para monogramas, logos e iniciales en un tono. El <strong>gobo de vidrio</strong> se fabrica con vidrio dicroico y permite proyectar <strong>a todo color y con degradados</strong>, con mayor detalle y definición: perfecto para logos corporativos multicolor, ilustraciones y patrones complejos. Te asesoramos para elegir el material según tu diseño y tu presupuesto.' },
  { question: "¿En qué superficies puedo proyectar los gobos?", answer: 'Prácticamente en cualquier superficie plana y de color claro: <strong>piso de la pista de baile, muros, techos, telones y fachadas</strong>. Las superficies claras y mate ofrecen el mejor contraste; sobre superficies oscuras o muy texturizadas la proyección pierde intensidad. Para vestir muros y fachadas completas combinamos los gobos con nuestra <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a>, integrando ambos sistemas en un solo montaje.' },
  { question: "¿Con cuánta anticipación debo enviar mi diseño?", answer: 'Para un <strong>gobo personalizado</strong> necesitamos tu diseño en vectores (AI, EPS, SVG o PDF de alta resolución) con al menos <strong>2 semanas de anticipación</strong>, ya que el gobo se fabrica a medida en metal o en vidrio. Si tu evento es antes de ese plazo, contamos con una biblioteca de gobos estándar (patrones geométricos, florales, de estrellas y texturas) disponibles de inmediato y sin costo de fabricación. Nuestro equipo revisa tu archivo y te confirma la viabilidad antes de mandarlo a producción.' },
  { question: "¿La proyección puede ser a color?", answer: 'Sí. Con un <strong>gobo de vidrio dicroico</strong> proyectamos tu logo o patrón a todo color, tal cual lo diseñaste. Con un <strong>gobo metálico</strong> la proyección es monocromática, pero podemos teñirla con filtros de color en el proyector para que combine con la paleta de tu evento. Además, mediante control DMX ajustamos la intensidad (dimmer) y activamos la rotación del gobo para crear movimiento y cambios de ambiente a lo largo de la noche.' },
  { question: "¿Cuál es el tamaño máximo de proyección?", answer: 'El tamaño depende de la <strong>distancia entre el proyector y la superficie</strong> y de la potencia del equipo. Con nuestros proyectores LED de 200W a 300W logramos proyecciones nítidas de entre <strong>1 y 6 metros de diámetro</strong>: entre más lejos se coloca el proyector, más grande (aunque más tenue) resulta la imagen. Para proyecciones de gran formato sobre muros o fachadas empleamos varios proyectores de mayor potencia. En la visita técnica calculamos la distancia y el equipo exactos para el tamaño de imagen que necesitas.' },
];

const specs = [
  { label: "Proyector", value: "LED 200W – 300W (alto contraste)" },
  { label: "Tipo de gobo", value: "Metálico (monocromo) y de vidrio (a color)" },
  { label: "Gobo personalizado", value: "A medida: logo, monograma o iniciales" },
  { label: "Ruedas de gobo", value: "Fijas + rotatorias (efecto de giro)" },
  { label: "Enfoque", value: "Motorizado / manual, nítido a distancia" },
  { label: "Tamaño de proyección", value: "1 – 6 m de diámetro (según distancia)" },
  { label: "Superficies", value: "Piso, muro, techo y fachada" },
  { label: "Control", value: "DMX 512 (dimmer y rotación de gobo)" },
  { label: "Fabricación del gobo", value: "≈ 2 semanas (diseño personalizado)" },
  { label: "Montaje", value: "Instalación, enfoque y operación incluidos" },
];

const sidebarNav = [
  { name: "Par LED RGBWA", href: "/servicios/iluminacion/escenario/par-led/" },
  { name: "Moving Heads", href: "/servicios/iluminacion/escenario/moving-heads/" },
  { name: "Follow Spots", href: "/servicios/iluminacion/escenario/follow-spots/" },
  { name: "Barras LED Motorizadas", href: "/servicios/iluminacion/escenario/barras-led/" },
  { name: "Sky Trackers", href: "/servicios/iluminacion/escenario/sky-tracker/" },
  { name: "Gobos", href: null, active: true },
];

const sidebarRelated = [
  { name: "Iluminación de Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Moving Heads", href: "/servicios/iluminacion/escenario/moving-heads/" },
  { name: "Fachadas", href: "/servicios/iluminacion/arquitectonica/fachadas/" },
  { name: "Audiovisual", href: "/servicios/audiovisual/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Mariana Beltrán", text: "Proyectamos el monograma con nuestras iniciales sobre la pista de baile de nuestra boda en un jardín de Cuernavaca y fue el detalle que más nos elogiaron. El gobo de vidrio se veía nítido y a color, justo como lo diseñamos. El técnico llegó puntual, enfocó la proyección y quedó impecable toda la noche. Un detalle que valió cada peso.", rating: 5, date: "2025-11-08" },
  { author: "Ricardo Salas", text: "Rentamos cuatro gobos para proyectar el logo de la empresa en los muros y el escenario de nuestra convención anual en un salón de Santa Fe. La marca se veía en todos lados y las fotos quedaron espectaculares. Mandamos el diseño con dos semanas de anticipación y el gobo personalizado salió perfecto. Servicio muy profesional de principio a fin.", rating: 5, date: "2025-10-22" },
  { author: "Gabriela Núñez", text: "Para los XV años de mi hija contratamos gobos con patrones que llenaron los muros y el techo del salón de texturas. Cambió por completo el ambiente del lugar sin necesidad de más decoración. Excelente asesoría para elegir los diseños y muy buen precio comparado con otras opciones que cotizamos. Los recomiendo totalmente.", rating: 5, date: "2025-09-14" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Gobos y Proyección de Monogramas en CDMX",
    description: "Renta de gobos y proyección de monogramas personalizados para eventos en CDMX. Gobos metálicos y de vidrio a medida con tu logo, monograma o iniciales; patrones y texturas sobre piso, muros, techos y fachadas. Control DMX, fabricación e instalación incluidas. Desde $1,500.",
    url: "/servicios/iluminacion/escenario/gobos/",
    priceRange: { min: 1500, max: 15000 },
    reviews,
    ratingValue: 5,
    reviewCount: 28,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Escenario", url: "/servicios/iluminacion/escenario/" },
    { name: "Gobos", url: "/servicios/iluminacion/escenario/gobos/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Gobos y Monogramas para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de gobos y proyección de monogramas personalizados para bodas y eventos corporativos en CDMX: logos, iniciales y patrones. Instalación incluida. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Tu sello proyectado en luz"
    title='Renta de <span class="highlight">Gobos</span> y Proyección de Monogramas en CDMX'
    subtitle="Proyectamos tu logo, monograma o iniciales sobre pista, muros, techos y fachadas con proyectores LED y gobos metálicos o de vidrio a medida. Fabricación del gobo personalizado, control DMX, instalación y enfoque incluidos para bodas, XV años y eventos corporativos."
    primaryCTA={{ label: "Cotiza tus gobos", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar gobos y proyección de monogramas para mi evento` }}
    cards={[
      {
        title: "Gobos y monogramas a medida para cada evento",
        content: "<strong>Renta de gobos y proyección de monogramas</strong> para eventos en la Ciudad de México. Fabricamos gobos a medida con tu logo corporativo, el monograma de los novios o las iniciales de la festejada, grabados en acero para proyección monocromática o impresos en vidrio dicroico para proyección a todo color. Proyectores LED de 200W a 300W con enfoque nítido y ruedas fijas y rotatorias para gobos estándar de patrones geométricos, florales y texturas. Ideales para bodas, XV años, eventos corporativos y activaciones de marca.",
      },
      {
        title: "Fabricación, instalación y enfoque incluidos",
        content: "<strong>Servicio técnico integral</strong> en cada renta de gobos. Diseño y fabricación del gobo personalizado a partir de tus vectores, control DMX del proyector (dimmer y rotación del gobo), montaje discreto, enfoque profesional y operación durante todo el evento. Proyectamos sobre piso, muros, techos y fachadas, calculando en visita técnica la distancia y el equipo exactos para el tamaño de imagen que necesitas.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres proyectar tu monograma o logo en tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con el diseño de tu gobo personalizado y el plano de proyección"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Iluminación de Escenario</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas gobos o un monograma para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar gobos y proyección de monogramas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Gobos y Monogramas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: 1 Gobo / Monograma -->
          <section class="section" aria-labelledby="monograma-heading">
            <ServiceShowcase
    title="1 Gobo / Monograma"
    headingId="monograma-heading"
    badge="El detalle que todos recuerdan"
    subtitle="Un solo proyector con el monograma de los novios sobre la pista de baile: elegante, personal e inolvidable."
    tags={["Monograma de novios", "1 proyector LED", "Gobo a medida", "Pista de baile"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 1 gobo / monograma"
  >
    <Fragment slot="body">
      <p class="showcase__text">La opción <strong>1 Gobo / Monograma</strong> es el punto de partida perfecto: un proyector LED con tu <strong>monograma o las iniciales de los novios</strong> grabados en un gobo a medida, enfocado con nitidez sobre la pista de baile. Es el detalle personal que convierte un salón en <em>tu</em> evento — los invitados lo fotografían, aparece en cada foto de la pista y se vuelve el sello visual de la noche. Elige gobo metálico para una proyección monocromática limpia o gobo de vidrio para reproducir tu diseño a todo color.</p>
      <p class="showcase__text">Incluye el <strong>diseño y la fabricación del gobo personalizado</strong>, el montaje discreto del proyector, el enfoque profesional y la operación durante el evento. Si quieres que el monograma <strong>gire o cambie de posición</strong> durante la fiesta, también proyectamos gobos en movimiento con nuestros <a href="/servicios/iluminacion/escenario/moving-heads/">moving heads spot</a>, que suman ruedas rotatorias y cambios de color por DMX.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion-arquitectonica/banador-puntual-gobo-monograma-boda.avif" alt="Gobo con monograma de novios proyectado en pista de baile" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion-arquitectonica/fachada-gobos-proyectados-edificio.avif" alt="Gobos proyectados sobre la fachada de un edificio en un evento — detalle" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/iluminacion-evento-04.avif" alt="Proyección de gobos e iluminación en un evento en CDMX — montaje" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: 2 Gobos Sincronizados -->
          <section class="section" aria-labelledby="dos-gobos-heading">
            <ServiceShowcase
    title="2 Gobos Sincronizados"
    headingId="dos-gobos-heading"
    badge="Doble impacto visual"
    subtitle="Dos proyecciones coordinadas para vestir dos puntos clave del venue: pista y muro principal, o entrada y escenario."
    tags={["2 proyectores", "Doble proyección", "Muro + piso", "Sincronizados"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 2 gobos"
  >
    <Fragment slot="body">
      <p class="showcase__text">Con <strong>2 Gobos Sincronizados</strong> multiplicas la presencia de tu diseño: colocamos dos proyectores en puntos estratégicos para que tu monograma o logo aparezca en <strong>dos superficies a la vez</strong> — por ejemplo, el piso de la pista y el muro principal, o la entrada y el escenario. Puedes repetir el mismo gobo para reforzar tu marca, o combinar dos diseños distintos (monograma en la pista + patrón decorativo en el muro) para una ambientación más rica.</p>
      <p class="showcase__text">Ambos proyectores se controlan por <strong>DMX 512</strong>, lo que permite igualar intensidad, coordinar la rotación y encender o atenuar las proyecciones según el momento del evento. Es la configuración ideal para <strong>bodas y XV años</strong> que quieren impacto en más de un punto sin llegar a una cobertura total del venue.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion/iluminacion-evento-04.avif" alt="Proyección de gobos e iluminación en un evento en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion-arquitectonica/banador-puntual-gobo-monograma-boda.avif" alt="Gobo con monograma de novios proyectado en pista de baile — detalle" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion-arquitectonica/fachada-gobos-proyectados-edificio.avif" alt="Gobos proyectados sobre la fachada de un edificio en un evento — montaje" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: 4 Gobos — Cobertura Total -->
          <section class="section" aria-labelledby="cuatro-gobos-heading">
            <ServiceShowcase
    title="4 Gobos — Cobertura Total"
    headingId="cuatro-gobos-heading"
    badge="Ambientación completa"
    subtitle="Cuatro proyectores con patrones y texturas que visten muros, techos y pisos de todo el venue."
    tags={["4 proyectores", "Patrones y texturas", "Cobertura 360°", "Ambientación"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 4 gobos"
  >
    <Fragment slot="body">
      <p class="showcase__text">La configuración <strong>4 Gobos — Cobertura Total</strong> transforma por completo la atmósfera de un salón: cuatro proyectores distribuidos para llenar <strong>muros, techos y pisos</strong> con patrones, texturas y gobos decorativos que dan profundidad y ambiente sin necesidad de decoración física adicional. Estrellas, follaje, geometrías, texturas orgánicas o tu diseño personalizado repetido — el espacio se viste de luz de pared a pared.</p>
      <p class="showcase__text">Es la solución preferida para <strong>venues amplios</strong> (salones de banquetes, terrazas, naves) donde una sola proyección se perdería. Combinamos gobos fijos y rotatorios para dar movimiento sutil a las texturas, todo coordinado por <strong>DMX 512</strong>. Puedes integrar esta cobertura con nuestra <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a> para un diseño lumínico completo en el que gobos, wash y efectos trabajan juntos.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion-arquitectonica/fachada-gobos-proyectados-edificio.avif" alt="Gobos proyectados sobre la fachada de un edificio en un evento" loading="lazy" decoding="async" /></div>
