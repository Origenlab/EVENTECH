---
/**
 * ─── Sky Trackers — Página de Producto (Nivel 4) ───
 * Reflectores de haz de alta potencia visibles a kilómetros para eventos.
 * Color accent amber #c2a24a (jerarquía L4).
 *
 * Jerarquía: Servicios > Iluminación > Escenario > Sky Trackers
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Escenario", href: "/servicios/iluminacion/escenario/" },
  { label: "Sky Trackers" },
];

const faqs = [
  { question: "¿Desde qué distancia se ve un sky tracker?", answer: 'En condiciones de cielo despejado y noche cerrada, el haz de un sky tracker de <strong>4,000 a 7,000W</strong> es visible a distancias de entre <strong>5 y 15 kilómetros</strong>, dependiendo de la potencia del equipo, la humedad y la contaminación lumínica de la zona. En la Ciudad de México lo habitual es una visibilidad efectiva de <strong>varios kilómetros a la redonda</strong>, suficiente para que el haz funcione como faro que guía a tus invitados hasta el venue. Entre más limpio el aire y más oscuro el entorno, más alto y definido sube el haz al cielo.' },
  { question: "¿Necesito algún permiso o autorización aeronáutica?", answer: 'Para eventos estándar en salones, jardines y haciendas <strong>no se requiere permiso especial</strong>: la operación es puntual, nocturna y a baja inclinación. Sin embargo, cuando el venue está en las <strong>cercanías de un aeropuerto o helipuerto</strong>, o el evento es de varios días, gestionamos la revisión correspondiente y ajustamos el ángulo de proyección para cumplir con la normativa. Nuestro técnico evalúa la ubicación durante la visita previa y, de ser necesario, orienta los haces en barrido lateral en lugar de vertical directo. Siempre operamos dentro del marco permitido.' },
  { question: "¿Funciona con lluvia o mal clima?", answer: 'Los sky trackers cuentan con <strong>carcasa sellada con protección IP54</strong>, apta para intemperie y resistente a rocío, humedad y lluvia ligera. Ante lluvia intensa o tormenta eléctrica suspendemos la operación por seguridad, igual que con cualquier equipo eléctrico de alta potencia. Curiosamente, una atmósfera con algo de <strong>humedad o neblina ayuda</strong> a que el haz se vea más sólido y espectacular, porque las partículas suspendidas reflejan la luz. Para eventos al aire libre siempre coordinamos un punto de resguardo del equipo y, si lo necesitas, montamos los reflectores bajo nuestras <a href="/servicios/carpas/">carpas profesionales</a> con el haz proyectando hacia el exterior.' },
  { question: "¿El sky tracker requiere planta de luz?", answer: 'Depende de la infraestructura del venue. Cada sky tracker consume una potencia considerable y opera con <strong>corriente de 220V</strong>; si el lugar cuenta con una toma trifásica dedicada y capacidad suficiente, nos conectamos directo. Cuando el venue no tiene la carga disponible —muy común en jardines, campos y haciendas— incluimos una <strong>planta de luz silenciosa</strong> dimensionada al número de equipos, con combustible y operador. Durante la cotización revisamos el cuadro eléctrico del lugar y te decimos con exactitud si se requiere planta, para que no haya sorpresas el día del evento.' },
  { question: "¿Cuántos sky trackers recomiendan por tipo de evento?", answer: 'La cantidad se define por el efecto que buscas y el tamaño del venue. Para una <strong>boda íntima o jardín</strong>, <strong>1 sky tracker</strong> funciona como faro y punto de referencia elegante. Para una <strong>hacienda o boda grande</strong> recomendamos <strong>2 equipos</strong> que crean haces cruzados sobre la fachada, con gran simetría. Para un <strong>corporativo o gala nocturna</strong>, <strong>4 sky trackers</strong> en barrido programado maximizan la presencia de marca y la visibilidad a distancia. Para <strong>conciertos y eventos masivos</strong> trabajamos con <strong>varios equipos sincronizados</strong> por DMX como parte de un show de cielo. Puedes combinarlos con <a href="/servicios/iluminacion/escenario/moving-heads/">moving heads</a> y <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> para un impacto visual completo.' },
  { question: "¿Con cuánta anticipación debo reservar mis sky trackers?", answer: 'Recomendamos reservar con <strong>3 a 4 semanas de anticipación</strong>, especialmente en temporada alta (primavera, diciembre y fines de semana de mayo a noviembre), cuando la disponibilidad de equipos de alta potencia se satura rápido. Para producciones grandes con varios sky trackers sincronizados o eventos que requieren planta de luz y logística especial, lo ideal es apartar con <strong>4 a 6 semanas</strong>. Dicho esto, siempre vale la pena escribirnos: manejamos inventario propio y de nuestra red de aliados, por lo que muchas veces resolvemos solicitudes de última hora. Cotiza cuanto antes y aseguramos tu fecha.' },
];

const specs = [
  { label: "Potencia por equipo", value: "4,000W – 7,000W (según modelo)" },
  { label: "Alcance visual", value: "Hasta 15 km en cielo despejado" },
  { label: "Cabezal", value: "Rotatorio motorizado 360° / barrido programable" },
  { label: "Color del haz", value: "Blanco puro o color (filtros dicroicos)" },
  { label: "Ángulo del haz", value: "Concentrado 1.5° – 3°" },
  { label: "Alimentación", value: "220V trifásico / planta de luz incluida si aplica" },
  { label: "Control", value: "DMX512 o barrido automático / manual" },
  { label: "Montaje", value: "Base contrapesada a nivel de piso" },
  { label: "Clima / Protección", value: "Carcasa sellada IP54, apta para exterior" },
  { label: "Operación", value: "Técnico operador incluido toda la noche" },
];

const sidebarNav = [
  { name: "Par LED RGBWA", href: "/servicios/iluminacion/escenario/par-led/" },
  { name: "Moving Heads", href: "/servicios/iluminacion/escenario/moving-heads/" },
  { name: "Follow Spots", href: "/servicios/iluminacion/escenario/follow-spots/" },
  { name: "Barras LED Motorizadas", href: "/servicios/iluminacion/escenario/barras-led/" },
  { name: "Sky Trackers", href: null, active: true },
  { name: "Gobos", href: "/servicios/iluminacion/escenario/gobos/" },
];

const sidebarRelated = [
  { name: "Iluminación de Escenario", href: "/servicios/iluminacion/escenario/" },
  { name: "Cabezas Móviles", href: "/servicios/iluminacion/escenario/moving-heads/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Audiovisual", href: "/servicios/audiovisual/" },
];

const reviews = [
  { author: "Mariana Robledo", text: "Rentamos un sky tracker para nuestra boda en un jardín de Tepoztlán y fue el detalle que nadie esperaba. El haz subiendo al cielo se veía desde la carretera y varios invitados nos dijeron que lo usaron para ubicar el lugar. El técnico llegó con tiempo, montó todo sin ruido y lo operó toda la noche. Un faro precioso que le dio un toque de gran producción a la fiesta.", rating: 5, date: "2025-11-08" },
  { author: "Ricardo Ávalos", text: "Contratamos 4 sky trackers para la cena de gala de fin de año de la empresa en un venue de Santa Fe. Los haces en barrido programado se veían a kilómetros y le dieron una presencia impresionante al evento; nuestros directivos quedaron encantados. Incluyeron la planta de luz porque la terraza no tenía la carga suficiente, y todo funcionó sin un solo apagón. Muy profesionales.", rating: 5, date: "2025-10-19" },
  { author: "Paulina Serrano", text: "Para los XV de mi hija pusimos 2 sky trackers cruzados sobre la fachada de la hacienda y el efecto fue de revista. La simetría de los dos haces se veía espectacular en las fotos del cielo nocturno. El equipo coordinó la instalación con el resto de la iluminación sin problema y respetaron el horario al pie de la letra. Repetiría sin dudarlo.", rating: 5, date: "2025-09-06" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Sky Trackers para Eventos en CDMX",
    description: "Renta de sky trackers y reflectores de haz de 4,000 a 7,000W para eventos en CDMX. Haces visibles a varios kilómetros, cabezal rotatorio motorizado, blanco o color, con instalación, planta de luz y operación incluidas. Desde $3,500 por equipo.",
    url: "/servicios/iluminacion/escenario/sky-tracker/",
    priceRange: { min: 3500, max: 35000 },
    reviews,
    ratingValue: 5,
    reviewCount: 24,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Escenario", url: "/servicios/iluminacion/escenario/" },
    { name: "Sky Trackers", url: "/servicios/iluminacion/escenario/sky-tracker/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Sky Trackers para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de sky trackers para eventos en CDMX: reflectores de haz visibles a kilómetros para bodas, XV años y corporativos. Instalación y operación incluidas."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El faro que se ve a kilómetros"
    title='Renta de <span class="highlight">Sky Trackers</span> para Eventos en CDMX'
    subtitle="Reflectores de haz de 4,000 a 7,000W con cabezal rotatorio motorizado que proyectan una columna de luz visible a varios kilómetros. El faro perfecto para bodas, XV años, galas corporativas y festivales. Instalación, planta de luz y operador técnico incluidos."
    primaryCTA={{ label: "Cotiza tus sky trackers", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar sky trackers para mi evento` }}
    cards={[
      {
        title: "Reflectores de haz que convierten tu venue en un punto de referencia",
        content: "<strong>Renta de sky trackers para eventos</strong> con reflectores de haz de alta potencia (4,000W a 7,000W) en la Ciudad de México. El cabezal rotatorio motorizado proyecta una columna de luz concentrada de 1.5° a 3° visible a varios kilómetros a la redonda, funcionando como faro que guía a tus invitados hasta el lugar. Disponibles en blanco puro o color mediante filtros dicroicos, con barrido programable o movimiento estático. Ideales para bodas en jardín, haciendas, galas corporativas, aperturas y festivales.",
      },
      {
        title: "Instalación, planta de luz y operación técnica incluidas",
        content: "<strong>Servicio integral</strong> en cada renta de sky tracker. Montaje sobre base contrapesada a nivel de piso, técnico operador dedicado durante toda la noche y planta de luz silenciosa cuando el venue no cuenta con la carga eléctrica necesaria. Carcasa sellada IP54 apta para exterior, control DMX512 para sincronizar varios equipos y ajuste del ángulo de proyección según la ubicación y la normativa. Nos encargamos de todo: llegada con anticipación, operación y desmontaje.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas sky trackers para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con la cantidad de equipos, alcance esperado y logística eléctrica personalizada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Iluminación de Escenario</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas sky trackers para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar sky trackers para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Sky Trackers</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: 1 Sky Tracker -->
          <section class="section" aria-labelledby="uno-heading">
            <ServiceShowcase
    title="1 Sky Tracker"
    headingId="uno-heading"
    badge="El faro para bodas íntimas"
    subtitle="Un solo haz de luz que sube al cielo y convierte tu jardín o terraza en un punto de referencia elegante."
    tags={["1 haz de luz", "Boda íntima / jardín", "Alcance varios km", "Faro de bienvenida"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 1 Sky Tracker"
  >
    <Fragment slot="body">
      <p class="showcase__text">Un <strong>sky tracker individual</strong> es la forma más elegante y económica de darle a tu evento una presencia de gran producción. La columna de luz de 4,000W a 5,000W sube al cielo nocturno y se convierte en un <strong>faro visible a varios kilómetros</strong>, guiando a tus invitados hasta la entrada del venue. Es la elección perfecta para <strong>bodas íntimas, jardines y terrazas</strong>, donde un solo punto de luz vertical crea un efecto sofisticado sin saturar el espacio.</p>
      <p class="showcase__text">Se instala sobre base contrapesada a nivel de piso, en un rincón discreto del jardín o junto a la fachada, y lo opera un técnico durante toda la noche. Puedes elegir <strong>blanco puro</strong> para un look clásico o <strong>color</strong> mediante filtros dicroicos para combinar con tu paleta. Si buscas sumar dinamismo puntual sobre la pista o la mesa principal, combínalo con un <a href="/servicios/iluminacion/escenario/follow-spots/">follow spot</a> que siga a los novios en los momentos clave.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion/iluminacion-evento-03.avif" alt="Haz de sky tracker proyectado al cielo nocturno en evento en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/iluminacion-evento-05.avif" alt="Sky tracker iluminando el cielo sobre un venue en CDMX — detalle" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/cabezas-moviles-beam-evento.avif" alt="Reflector de haz de sky tracker en evento nocturno — montaje" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: 2 Sky Trackers -->
          <section class="section" aria-labelledby="dos-heading">
            <ServiceShowcase
    title="2 Sky Trackers"
    headingId="dos-heading"
    badge="Haces cruzados sobre la fachada"
    subtitle="Dos columnas de luz que se cruzan en el cielo para crear simetría y un efecto de revista sobre haciendas y bodas grandes."
    tags={["2 haces sincronizados", "Hacienda / boda grande", "Efecto cruzado", "Simetría en fachada"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 2 Sky Trackers"
  >
    <Fragment slot="body">
      <p class="showcase__text">La configuración de <strong>dos sky trackers</strong> es la favorita para <strong>haciendas y bodas grandes</strong>. Colocados a ambos lados de la fachada o la entrada principal, los dos haces se elevan y se <strong>cruzan en el cielo</strong> formando una V invertida de gran simetría que enmarca el venue y luce espectacular en las fotografías nocturnas y en las tomas con dron. Es un efecto de escenografía a cielo abierto que transmite de inmediato la magnitud de tu celebración.</p>
      <p class="showcase__text">Ambos equipos se sincronizan para moverse al unísono o en espejo, con barrido lento y elegante o posición fija. Cada uno lleva su base contrapesada y su operador, y ajustamos el ángulo de cruce según la altura del venue y su entorno. Para eventos al aire libre en campo abierto complementamos el montaje con nuestras <a href="/servicios/carpas/">carpas profesionales</a>, resguardando el equipo y a los invitados sin perder el impacto del show de cielo.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion/iluminacion-evento-05.avif" alt="Dos sky trackers con haces cruzados en el cielo sobre una hacienda en CDMX" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/cabezas-moviles-beam-evento.avif" alt="Haces de sky tracker cruzados sobre la fachada de un venue — detalle" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/iluminacion-evento-03.avif" alt="Columnas de luz de sky trackers en boda nocturna en CDMX — montaje" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: 4 Sky Trackers -->
          <section class="section" aria-labelledby="cuatro-heading">
            <ServiceShowcase
    title="4 Sky Trackers"
    headingId="cuatro-heading"
    badge="Presencia de marca nocturna"
    subtitle="Cuatro haces en barrido programado que maximizan la visibilidad y la presencia de tu evento corporativo o gala."
    tags={["4 haces", "Corporativo / gala nocturna", "Barrido programado", "Máxima visibilidad"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar 4 Sky Trackers"
  >
    <Fragment slot="body">
      <p class="showcase__text">Cuatro <strong>sky trackers de 5,000W a 7,000W</strong> distribuidos alrededor del venue generan un <strong>abanico de haces en barrido programado</strong> que se ve a kilómetros de distancia y comunica de inmediato que ahí está sucediendo algo importante. Es la configuración ideal para <strong>eventos corporativos, galas nocturnas, inauguraciones y lanzamientos</strong>, donde la presencia de marca y la visibilidad a distancia son parte del mensaje. Los cuatro equipos se controlan por DMX512 para moverse en secuencia coreografiada.</p>
      <p class="showcase__text">Coordinamos la logística eléctrica completa: si el venue no tiene la carga necesaria para los cuatro equipos, incluimos <strong>planta de luz silenciosa</strong> dimensionada al consumo total. Para amplificar el impacto dentro del recinto, integramos los sky trackers con <a href="/servicios/iluminacion/escenario/moving-heads/">moving heads</a> en el escenario y <a href="/servicios/iluminacion/efectos-especiales/">efectos especiales</a> como haze y CO2, logrando una producción visual coherente de adentro hacia afuera.</p>
    </Fragment>
