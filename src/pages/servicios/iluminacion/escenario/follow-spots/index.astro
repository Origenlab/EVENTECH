---
/**
 * ─── Follow Spots — Página de Producto (Nivel 4) ───
 * Seguimiento profesional de luz para protagonistas en eventos.
 * Accent amber #e17055.
 *
 * Jerarquía: Servicios > Iluminación > Escenario > Follow Spots
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Escenario", href: "/servicios/iluminacion/escenario/" },
  { label: "Follow Spots" },
];

const faqs = [
  { question: "¿Cuántos follow spots necesito para mi evento?", answer: "Depende del tipo de evento y la cantidad de protagonistas. Para <strong>bodas y galas</strong> con un solo protagonista (novia, festejado, presentador), 1 follow spot es suficiente. Para eventos con <strong>múltiples protagonistas o cross-fade</strong> entre presentadores, recomendamos 2 unidades. Para <strong>conciertos, desfiles de moda y producciones a gran escala</strong>, utilizamos 3 a 4 follow spots con operadores coordinados para seguimiento simultáneo de diferentes artistas. Nuestro diseñador de iluminación evalúa tu evento y recomienda la cantidad exacta." },
  { question: "¿El operador del follow spot está incluido en la renta?", answer: "Sí, siempre. Cada follow spot incluye un <strong>operador profesional dedicado</strong> durante todo el evento. El operador está capacitado en protocolo de eventos (bodas, galas, conciertos) y se coordina con el DJ, MC o director de escena para seguir con precisión milimétrica a cada protagonista. El operador maneja zoom, iris, filtros de color y dimmer en tiempo real. También se encarga del montaje, enfoque y desmontaje del equipo." },
  { question: "¿El follow spot es ruidoso? ¿Afectará mi ceremonia?", answer: 'Los modelos <strong>HMI 1200W</strong> tienen un ventilador de enfriamiento que genera ruido moderado, lo que los hace ideales para conciertos, fiestas y eventos con música amplificada. Para <strong>ceremonias religiosas, votos y momentos íntimos</strong>, utilizamos follow spots <strong>LED de funcionamiento prácticamente silencioso</strong>, sin ventilador audible. Evaluamos tu evento y seleccionamos el modelo adecuado. Si necesitas iluminación base silenciosa, nuestros <a href="/servicios/iluminacion/escenario/par-led/">par LED RGBWA</a> son el complemento perfecto.' },
  { question: "¿Desde qué distancia funciona el follow spot?", answer: "El <strong>follow spot HMI 1200W</strong> tiene un alcance efectivo de <strong>30 a 80 metros</strong>, ideal para auditorios, teatros y venues grandes. El <strong>follow spot LED 600W</strong> alcanza de <strong>15 a 40 metros</strong>, perfecto para salones de eventos, jardines y espacios medianos. Realizamos una visita técnica gratuita para medir las distancias exactas de tu venue y recomendarte el modelo correcto. Si tu escenario supera los 80 metros, podemos configurar múltiples follow spots con posiciones estratégicas." },
  { question: "¿Puedo usar filtros de color con el follow spot?", answer: "Sí. Todos nuestros follow spots incluyen una <strong>rueda de 6 colores</strong> más filtros adicionales: <strong>CTO</strong> (conversión a cálido/tungsteno), <strong>CTB</strong> (conversión a frío/daylight), y <strong>frost</strong> (difusión suave). Podemos agregar <strong>filtros de gel personalizados</strong> para colores específicos que coincidan con la paleta de tu evento, marca corporativa o temática de fiesta. El operador cambia los filtros en tiempo real según el momento del evento — cálido para ceremonia, colores vibrantes para fiesta." },
  { question: "¿Dónde se coloca el follow spot?", answer: "El follow spot se monta sobre un <strong>trípode profesional de alta resistencia</strong> en una posición elevada al fondo del venue: balcón, plataforma técnica, mezzanine o posición dedicada. La ubicación ideal es a <strong>30-45 grados de ángulo</strong> respecto al escenario para evitar deslumbramiento y lograr un haz de luz natural. Realizamos una <strong>visita técnica gratuita</strong> para evaluar las opciones de posicionamiento en tu venue y determinar el ángulo óptimo de proyección y visibilidad." },
];

const specs = [
  { label: "Fuente de luz", value: "HMI 1200W / LED 600W+" },
  { label: "CRI", value: "90+ (colores naturales)" },
  { label: "Temperatura de color", value: "5600K (daylight) / 3200K con filtro" },
  { label: "Zoom", value: "8° – 22° manual" },
  { label: "Iris", value: "Variable, apertura controlada" },
  { label: "Filtros", value: "Rueda de 6 colores + frost + CTO/CTB" },
  { label: "Dimmer", value: "Mecánico suave (sin parpadeo)" },
  { label: "Alcance", value: "30 – 80 metros efectivos" },
  { label: "Montaje", value: "Trípode profesional / Plataforma elevada" },
  { label: "Peso", value: "25 – 35 kg (con trípode)" },
];

const sidebarNav = [
  { name: "Par LED RGBWA", href: "/servicios/iluminacion/escenario/par-led/" },
  { name: "Moving Heads", href: "/servicios/iluminacion/escenario/moving-heads/" },
  { name: "Follow Spots", href: null, active: true },
  { name: "Barras LED Motorizadas", href: "/servicios/iluminacion/escenario/barras-led/" },
];

const sidebarRelated = [
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Equipo Audiovisual", href: "/servicios/audiovisual/" },
  { name: "Mobiliario Premium", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
];

const reviews = [
  { author: "Alejandra Vega", text: "El follow spot para nuestra boda fue espectacular. El operador siguió a los novios durante la entrada, primer baile y brindis con una precisión impresionante. El filtro cálido CTO le dio un tono romántico hermoso a cada momento. Las fotos y video quedaron increíbles gracias a la luz del follow spot. Totalmente recomendado para bodas.", rating: 5, date: "2025-11-28" },
  { author: "Miguel Ángel Torres", text: "Contratamos 3 follow spots para nuestra gala corporativa con premiación. Cada presentador y premiado fue seguido con precisión milimétrica durante su momento en el escenario. Los operadores se coordinaron perfectamente con nuestro director de escena. Servicio puntual, profesional y el equipo llegó 3 horas antes para montaje y pruebas.", rating: 5, date: "2025-10-18" },
  { author: "Daniela Rosas", text: "Usamos follow spots para un desfile de moda en CDMX y el resultado fue de nivel internacional. El seguimiento de las modelos en la pasarela fue impecable, sin perder a ninguna en ningún momento. Los cambios de color con la rueda de filtros añadieron dramatismo a cada colección. El equipo de EVENTECH conoce su oficio a la perfección.", rating: 5, date: "2025-09-12" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Follow Spots para Eventos en CDMX",
    description: "Follow spots HMI 1200W y LED 600W+ con operador profesional dedicado para bodas, galas, conciertos y desfiles. CRI 90+, filtros de color, alcance hasta 80 metros. Desde $2,500 por evento.",
    url: "/servicios/iluminacion/escenario/follow-spots/",
    priceRange: { min: 2500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 29,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Escenario", url: "/servicios/iluminacion/escenario/" },
    { name: "Follow Spots", url: "/servicios/iluminacion/escenario/follow-spots/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Follow Spots para Eventos en CDMX"
  description="Renta de follow spots 1200W+ HMI y LED para eventos en CDMX: seguimiento profesional, CRI 90+, filtros de color, operador dedicado. Ideal para galas, bodas y conciertos. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El protagonista siempre iluminado"
    title='Renta de <span class="highlight">Follow Spots</span> para Eventos en CDMX'
    subtitle="Follow spots HMI 1200W+ y LED de alta potencia con CRI 90+, tracking manual preciso, filtros de color intercambiables y operador profesional dedicado. Seguimiento de luz para bodas, galas, conciertos y espectáculos en vivo."
    primaryCTA={{ label: "Cotiza tus follow spots", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar follow spots para mi evento` }}
    cards={[
      {
        title: "Seguidores de luz de alto rendimiento",
        content: "<strong>Renta de follow spots para eventos</strong> con fuentes HMI de 1200W+ o LED de 600W+ que producen luz blanca brillante con CRI 90+ para una reproducción de color natural y fiel. Zoom manual de 8° a 22° para ajustar el tamaño del haz con precisión, iris variable para control de apertura, filtros de color en rueda de 6 posiciones, y dimmer mecánico suave sin parpadeo. Ideales para galas, discursos, desfiles de moda, ceremonias y espectáculos en vivo.",
      },
      {
        title: "Operador profesional dedicado durante todo el evento",
        content: "<strong>Operador capacitado incluido</strong> en cada renta de follow spot. El operador sigue al presentador, novia, artista o protagonista con precisión milimétrica durante todo el evento, coordinándose con el DJ, MC o director de escena. Manejo profesional de zoom, iris, filtros y dimmer en tiempo real según el momento del evento. Trípode profesional de alta resistencia, filtros de gel y set completo de CTO/CTB incluidos en la renta.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas follow spots para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con evaluación técnica de tu venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Iluminación de Escenario</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas follow spots para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar follow spots para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Follow Spots</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Follow Spot HMI 1200W+ -->
          <section class="section section--alt" aria-labelledby="hmi-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Potencia de grado profesional</span>
                <h2 class="showcase__title" id="hmi-heading">Follow Spot HMI 1200W+</h2>
                <p class="showcase__subtitle">Lámpara de descarga HMI de máxima potencia: luz blanca brillante que alcanza hasta 80 metros.</p>
                <p class="showcase__text">El <strong>follow spot HMI 1200W+</strong> utiliza una lámpara de descarga HMI que produce un haz de luz intensamente brillante, balanceado a <strong>daylight (5600K)</strong> con un CRI superior a 90. Los colores de la ropa, maquillaje, decoraciones y escenografía se reproducen de forma natural y fiel. Zoom manual de <strong>8° a 22°</strong> para ajustar el tamaño del haz con precisión al protagonista, e iris variable para control fino de la apertura del círculo de luz.</p>
                <p class="showcase__text">Ideal para <strong>auditorios grandes, teatros, recintos y venues de 400+ personas</strong> donde se necesita alcance de 30 a 80 metros efectivos. El dimmer mecánico permite fade-in y fade-out suaves sin parpadeo, creando transiciones elegantes. Montaje sobre trípode profesional de alta resistencia o plataforma elevada para ángulo óptimo. Combínalo con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción integral de escenario.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">HMI 1200W+</span>
                  <span class="showcase__tag">CRI 90+</span>
                  <span class="showcase__tag">Alcance 80m</span>
                  <span class="showcase__tag">Daylight 5600K</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Follow Spot HMI
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Follow Spot HMI 1200W+</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Follow Spot LED -->
          <section class="section section--alt" aria-labelledby="led-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tecnología LED de nueva generación</span>
                <h2 class="showcase__title" id="led-heading">Follow Spot LED</h2>
                <p class="showcase__subtitle">LED de alta potencia con arranque instantáneo, menor consumo y funcionamiento silencioso.</p>
                <p class="showcase__text">El <strong>follow spot LED 600W+</strong> ofrece arranque instantáneo sin tiempo de calentamiento (a diferencia de los HMI que requieren varios minutos de warm-up). Funcionamiento <strong>prácticamente silencioso</strong> al no necesitar ventilador de alta potencia, lo que lo hace ideal para ceremonias, votos matrimoniales y momentos íntimos donde el ruido es inaceptable. Temperatura de color ajustable de <strong>3200K a 6500K vía DMX</strong> sin necesidad de cambiar geles físicos.</p>
                <p class="showcase__text">Menor consumo energético que los modelos HMI, lo que se traduce en <strong>ahorro de energía y menor carga al generador</strong>. Sin riesgo de fallo de lámpara durante el evento (los LEDs no explotan como las HMI). Cuerpo más compacto y ligero para transporte y montaje ágil. Ideal para <strong>bodas, XV años, eventos corporativos y ceremonias</strong> donde la discreción sonora es prioridad. Combínalo con nuestros <a href="/servicios/iluminacion/escenario/par-led/">par LED RGBWA</a> como base de iluminación de escenario.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">LED 600W+</span>
                  <span class="showcase__tag">Arranque Instantáneo</span>
                  <span class="showcase__tag">Silencioso</span>
                  <span class="showcase__tag">3200-6500K</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Follow Spot LED
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Follow Spot LED</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Follow Spot para Bodas y Galas -->
          <section class="section section--alt" aria-labelledby="bodas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El momento que merece luz propia</span>
                <h2 class="showcase__title" id="bodas-heading">Follow Spot para Bodas y Galas</h2>
                <p class="showcase__subtitle">Seguimiento profesional para entrada de novios, primer baile, brindis y todos los momentos especiales.</p>
                <p class="showcase__text">Operador dedicado capacitado específicamente en <strong>protocolo de bodas y galas</strong>: entrada de la novia, primer baile, lanzamiento de ramo, brindis, baile padre-hija, corte de pastel y todos los momentos que merecen protagonismo. Filtro <strong>CTO cálido</strong> para un look romántico y favorecedor en tonos dorados que embellece el vestido, el maquillaje y la decoración. Control de iris para revelación gradual — el haz se abre lentamente sobre la novia mientras camina al altar.</p>
                <p class="showcase__text">Se combina con <strong>iluminación base de par LED</strong> para cobertura general del salón mientras el follow spot destaca al protagonista. Transiciones suaves de dimmer mecánico para entradas y salidas elegantes sin cortes abruptos de luz. El operador se coordina con el DJ/MC para timing perfecto en cada momento — sabe exactamente cuándo encender, cuándo seguir y cuándo hacer fade-out. Complementa con nuestra <a href="/servicios/iluminacion/decorativa/">iluminación decorativa</a> para un ambiente integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Bodas y Galas</span>
                  <span class="showcase__tag">Filtro CTO Warm</span>
                  <span class="showcase__tag">Operador Dedicado</span>
                  <span class="showcase__tag">Protocolo Evento</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Follow Spot Bodas
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder" aria-hidden="true">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/></svg>
                  <span>Follow Spot para Bodas y Galas</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Follow Spot para Conciertos y Espectáculos -->
          <section class="section section--alt" aria-labelledby="conciertos-heading">
            <div class="showcase">
              <div class="showcase__content">
