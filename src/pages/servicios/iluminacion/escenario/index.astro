---
/**
 * ─── EVENTECH.MX — Renta de Iluminación de Escenario para Eventos (Hub L4, molde hm- 2026) ───
 * Par LED · Moving Heads · Follow Spots · Barras LED — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/iluminacion — cabezas-moviles real; iluminacion-evento genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const SUB_SERVICES = [
  {
    id: "par-led",
    name: "Par LED RGBWA",
    badge: "Iluminación base",
    excerpt: "Luminarias de 18×15W con mezcla de color 5-en-1 (rojo, verde, azul, blanco, ámbar). Haz de 25°, modo silencioso para ceremonias y control DMX512 profesional.",
    href: "/servicios/iluminacion/escenario/par-led/",
    image: "/images/iluminacion/iluminacion-evento-01.avif",
    specs: ["RGBWA 5-en-1", "18×15W", "DMX512", "Modo silencioso"],
  },
  {
    id: "moving-heads",
    name: "Moving Heads",
    badge: "Dinamismo y show",
    excerpt: "Cabezas móviles tipo beam, spot y wash con rotación 360° pan/tilt continuo. Ruedas de gobos, efectos de prisma y control DMX para conciertos y galas.",
    href: "/servicios/iluminacion/escenario/moving-heads/",
    image: "/images/iluminacion/cabezas-moviles-beam-evento.avif",
    specs: ["Beam 230W", "Gobos", "Prisma", "Pan/tilt 360°"],
  },
  {
    id: "follow-spots",
    name: "Follow Spots",
    badge: "El foco protagonista",
    excerpt: "Seguidor de luz de 1200W+ de alto rendimiento con tracking manual. Ideales para discursos, presentaciones en tarima, desfiles de moda y performances en vivo.",
    href: "/servicios/iluminacion/escenario/follow-spots/",
    image: "/images/iluminacion/iluminacion-evento-05.avif",
    specs: ["1200W+", "Tracking manual", "Iris / dimmer", "Alto alcance"],
  },
  {
    id: "barras-led",
    name: "Barras LED Motorizadas",
    badge: "Efectos lineales",
    excerpt: "Barras de wash LED con pixel mapping individual para efectos lineales dinámicos. Montaje en truss para backdrops de escenario con control DMX avanzado.",
    href: "/servicios/iluminacion/escenario/barras-led/",
    image: "/images/iluminacion/iluminacion-evento-03.avif",
    specs: ["Pixel mapping", "Truss", "Motorizado", "Backdrop"],
  },
  {
    id: "sky-tracker",
    name: "Sky Trackers",
    badge: "Impacto a kilómetros",
    excerpt: "Reflectores de haz que lanzan luz al cielo, visibles desde kilómetros. El anuncio luminoso de que algo grande está pasando — bodas en hacienda, XV años y grandes aperturas.",
    href: "/servicios/iluminacion/escenario/sky-tracker/",
    image: "/images/iluminacion/iluminacion-evento-03.avif",
    specs: ["4,000–7,000W", "Haz al cielo", "Visible a km", "Planta de luz"],
  },
  {
    id: "gobos",
    name: "Gobos y Monogramas",
    badge: "Tu sello proyectado",
    excerpt: "Proyección de monogramas, logos y patrones sobre pista, muros o techo. El detalle personalizado que aparece en cada foto — de las iniciales de los novios al logo corporativo.",
    href: "/servicios/iluminacion/escenario/gobos/",
    image: "/images/iluminacion-arquitectonica/banador-puntual-gobo-monograma-boda.avif",
    specs: ["Gobo a medida", "Metal o vidrio", "Enfoque nítido", "Personalizado"],
  },
];

const whyFeatures = [
  {
    title: "Operador de consola DMX certificado",
    body: "Un show de luz no se enciende y ya: se opera. Cada renta incluye un operador de consola DMX512 que programa las escenas antes del evento y las ejecuta en vivo —número musical, discurso, primer baile, fiesta— ajustando intensidad, color y efectos en tiempo real. La luz sigue el ritmo del evento, no se queda estática.",
  },
  {
    title: "Truss y rigging certificado según tu venue",
    body: "Colgar decenas de luminarias sobre la gente exige estructura seria. Usamos truss de aluminio ground support para salones y rigging aéreo con motores de cadena certificados para producciones grandes. Evaluamos los puntos de anclaje y la capacidad de carga del techo antes del montaje — el truss y el rigging van incluidos.",
  },
  {
    title: "Modo silencioso para ceremonias",
    body: "El zumbido de un ventilador arruina un voto matrimonial. Nuestros pares LED tienen modo silencioso por debajo de 25 dB, imperceptibles durante ceremonias y discursos. Reservamos los moving heads —que hacen ruido por sus motores— para los momentos de fiesta. Luz de calidad sin que se escuche el equipo.",
  },
  {
    title: "Color exacto de la paleta de tu evento",
    body: "Con tecnología RGBWA de 5 canales reproducimos prácticamente cualquier color del espectro. Programamos los tonos exactos de tu paleta —colores corporativos, temática de boda— a partir de tus códigos Pantone, HEX o RGB, con secuencias sincronizadas a música y transiciones suaves entre escenas.",
  },
  {
    title: "Capas de luz que dan profundidad al escenario",
    body: "Un escenario profesional no se ilumina con un solo tipo de luz. Combinamos pares LED de base, moving heads para dinamismo, follow spots para el protagonista y barras para efectos lineales — capas que se complementan y dan la profundidad que distingue una producción de un montaje plano.",
  },
  {
    title: "Producción integral: luz, audio, imagen y estructura",
    body: "La luz de escenario luce más sincronizada con el sonido, las pantallas y el rigging del mismo proveedor. Integramos todo desde EVENTECH —iluminación, line array, pantallas LED y truss— con un solo equipo técnico y un solo diseño de show, para que nada se contradiga sobre el escenario.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y diseño de show", p: "Evaluamos el venue, los puntos de anclaje y la capacidad de carga del techo, y definimos el diseño de iluminación según el programa del evento (ceremonia, presentaciones, números musicales, fiesta). En 24-48 horas te enviamos propuesta con las luminarias, el truss y las escenas propuestas." },
  { n: 2, t: "Propuesta, escenas y aparto", p: "Definimos cantidad y tipo de luminarias, truss/rigging, y la paleta de color a partir de tus códigos. Con el anticipo apartamos el equipo y la fecha. Para producciones grandes con rigging aéreo, coordinamos con tu productor y el venue con tiempo suficiente." },
  { n: 3, t: "Montaje, rigging y programación", p: "Instalamos con anticipación: montaje de truss (ground o fly system con motores certificados), colgado y direccionado de luminarias, cableado DMX y programación de todas las escenas. Hacemos prueba completa del show antes de abrir puertas." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "El operador ejecuta el show de luz en tiempo real durante todo el evento, sincronizado con el programa y la música. Al cierre, desmontamos truss, rigging y luminarias con protocolo de seguridad. El montaje, la operación y el desmontaje están incluidos dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre un par LED y un moving head?", answer: "El par LED RGBWA es una luminaria estática que proyecta un haz de color fijo en una dirección, ideal para baños de color en escenarios, paredes y ambientación general. El moving head es una cabeza motorizada que se mueve en dos ejes (pan y tilt) de forma continua, proyectando haces dinámicos, gobos y efectos prismáticos. Los pares LED son perfectos para iluminación base y ceremonias; los moving heads aportan dinamismo y espectáculo para conciertos, galas y fiestas. En la mayoría de producciones profesionales se combinan ambos para crear capas de iluminación completas." },
  { question: "¿El servicio incluye operador de consola DMX?", answer: "Sí, todos nuestros paquetes de iluminación de escenario incluyen un operador de consola DMX certificado durante todo el evento. El operador programa las escenas de iluminación previas al evento, opera en tiempo real durante presentaciones y números musicales, y ajusta la intensidad y efectos según el momento (ceremonia, cena, fiesta, discursos). La consola DMX512, el cableado profesional y la programación previa están incluidos sin costo adicional." },
  { question: "¿Pueden sincronizar la iluminación con la música en vivo?", answer: "Sí. Ofrecemos dos formas de sincronización: sound-to-light, donde las luminarias reaccionan en tiempo real al ritmo y los graves de la música (ideal para fiesta y DJ), y programación por timecode, donde cada cambio de luz está sincronizado exactamente con una pista o show (para números musicales, pasarelas y producciones coreografiadas). Para eventos con banda en vivo, el operador opera manualmente siguiendo la música. Coordinamos con tu DJ o director musical el método que mejor se ajuste a tu evento." },
  { question: "¿Qué estructuras de truss y rigging necesito para la iluminación?", answer: "Depende del tipo y cantidad de luminarias. Para eventos en salón con hasta 20 luminarias, utilizamos truss de aluminio ground support (desde el piso) en configuraciones de 6 a 12 metros lineales. Para producciones grandes con 40+ luminarias y moving heads, implementamos rigging aéreo fly system con motores de cadena certificados. Nuestro equipo técnico realiza una evaluación del venue para determinar los puntos de anclaje seguros y la capacidad de carga del techo. Todo el truss y rigging está incluido en el paquete." },
  { question: "¿Las luminarias pueden operar en modo silencioso para ceremonias?", answer: "Sí. Nuestros pares LED RGBWA cuentan con modo de ventilador silencioso (silent mode) que reduce el ruido a menos de 25 dB, haciéndolos imperceptibles durante ceremonias religiosas, votos matrimoniales y discursos. Los moving heads generan más ruido por sus motores internos, por lo que los reservamos para momentos de fiesta y música. Para ceremonias, utilizamos exclusivamente pares LED y fresneles LED que garantizan silencio absoluto sin sacrificar calidad de iluminación." },
  { question: "¿Puedo programar colores específicos para mi evento?", answer: "Absolutamente. Con la tecnología RGBWA de 5 canales, podemos crear prácticamente cualquier color del espectro visible. Programamos los colores exactos de tu paleta de evento (colores corporativos, temáticos de boda, etc.) en la consola DMX antes del montaje. También creamos secuencias de cambio de color sincronizadas con música, transiciones suaves entre escenas y efectos de fade. Envíanos tus códigos de color (Pantone, HEX o RGB) y los replicamos con precisión en la iluminación." },
  { question: "¿Con cuánta anticipación debo reservar iluminación de escenario?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo a junio). Las producciones grandes con más de 30 luminarias y rigging aéreo requieren al menos 1 mes para la planificación técnica, visita al venue y programación. Los paquetes básicos de 8 a 16 pares LED pueden confirmarse con 2 semanas de antelación. También atendemos solicitudes urgentes sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación de Escenario para Eventos en CDMX",
    description: "Renta de pares LED RGBWA, moving heads, follow spots y barras LED con control DMX y rigging en CDMX. Operador de consola incluido. Cotiza hoy.",
    url: "/servicios/iluminacion/escenario/",
    priceRange: { min: 1000, max: 40000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Escenario", url: "/servicios/iluminacion/escenario/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Escenario" },
];
---

<PageLayout
  title="Renta de Iluminación de Escenario para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/iluminacion/cabezas-moviles-beam-evento.avif"
  description="Renta de pares LED RGBWA, moving heads, follow spots y barras LED con control DMX y rigging en CDMX. Operador de consola incluido. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="esc-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Iluminación de escenario · CDMX y ZMVM</p>
            <h1 id="esc-hero-heading">
              Iluminación de escenario que convierte <em>un evento en un show</em>
            </h1>
            <p class="hm-hero__lead">
              Pares LED RGBWA, moving heads beam/spot/wash, follow spots y barras motorizadas con
              pixel mapping. La luz que da dinamismo y espectáculo a conciertos, galas y fiestas —
              con operador de consola DMX y rigging incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20de%20escenario%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar iluminación
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>iluminación de escenario para eventos</strong> en CDMX:
              <strong>pares LED RGBWA</strong> 5-en-1 con modo silencioso, <strong>moving heads</strong>
              beam, spot y wash con gobos y prisma, <strong>follow spots</strong> de 1200W+ y
              <strong>barras LED motorizadas</strong> con pixel mapping. Todo con control DMX512,
              truss y rigging certificado, operado por un técnico de consola durante el show.
            </p>
            <p>
              Con <strong>más de 500 producciones iluminadas</strong> en CDMX, sabemos que la luz de
              escenario es la diferencia entre un evento plano y un show: por eso cada renta incluye
              diseño, programación de escenas y operador en vivo. Para producción completa integramos
              <a href="/servicios/audiovisual/sonido/">line array</a>,
              <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y
              <a href="/servicios/carpas/hangar/">rigging de hangar</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de iluminación de escenario disponibles">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(7, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20de%20escenario%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Luz que da espectáculo</p>
            <h2 id="catalogo-heading">¿Qué necesita el escenario de tu evento?</h2>
            <p class="hm__head-sub">6 tipos de luminaria — de la base de color al haz que sube al cielo y el gobo que proyecta tu monograma.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La iluminación de escenario es lo que separa un evento que se ve bien de uno que se
              siente como un show. No alumbra por alumbrar: da profundidad, marca el ritmo, enfoca al
              protagonista y convierte cada número musical en un momento con presencia visual.
            </p>
            <p>
              Pares LED para la base de color. Moving heads para el dinamismo. Follow spots para
              seguir al protagonista. Barras motorizadas para efectos lineales de backdrop. Una sola
              empresa para todo el diseño de luz de tu escenario.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada luminaria, a fondo</p>
            <h2 id="detalle-heading">Los 6 tipos de luz de escenario — en detalle</h2>
            <p class="hm__head-sub">Tecnología, control, potencia y para qué momento del show funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada luminaria hay decisiones que afectan el show: el tipo de fuente que
              define si la luz es base o efecto, el movimiento que decide el dinamismo, y el control
              que marca si la luz sigue el ritmo del evento o se queda quieta toda la noche.
            </p>
            <p>
              Conocer estas diferencias te permite diseñar un show con criterio y no solo encender
              luces de colores. A continuación, lo que realmente importa de cada tipo.
            </p>
          </div>
        </div>

        <!-- PAR LED -->
        <article class="hm-feat" aria-labelledby="feat-par-led">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Par LED RGBWA</p>
            <h3 class="hm-feat__title" id="feat-par-led">La base de color de todo escenario — silenciosa hasta para una ceremonia</h3>
            <p class="hm-feat__lead">El caballo de batalla del diseño de escenario. Los pares LED ponen la base de color sobre la que se construye todo el show, y son lo suficientemente silenciosos para una ceremonia.</p>
            <p>
              Luminarias de <strong>18×15W con mezcla de color 5-en-1</strong> (rojo, verde, azul,
              blanco, ámbar) y haz de 25°, controladas por <strong>DMX512</strong>. Su
              <strong>modo silencioso (&lt;25 dB)</strong> las hace imperceptibles durante ceremonias,
              votos y discursos — donde el ruido de un ventilador arruinaría el momento.
            </p>
            <p>
              Ideales para <strong>baños de color en escenario, ambientación, ceremonias y
              backdrops</strong>. Se combinan con moving heads para crear capas de luz completas.
              Programamos el color exacto de tu paleta. Combínalos con
              <a href="/servicios/iluminacion/arquitectonica/">wash lights arquitectónicos</a> para
              teñir todo el venue.
            </p>
            <ul class="hm-feat__stats">
              {["RGBWA 5-en-1", "18×15W", "Haz 25°", "DMX512", "Modo silencioso"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/iluminacion/escenario/par-led/">
              Ver Par LED RGBWA
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/iluminacion/iluminacion-evento-01.avif" alt="Pares LED RGBWA iluminando escenario de evento en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/iluminacion/iluminacion-evento-02.avif" alt="Par LED de color como base de escenario" loading="lazy" decoding="async" />
              <img src="/images/iluminacion/iluminacion-evento-06.avif" alt="Baño de color RGBWA en backdrop de escenario" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- MOVING HEADS -->
        <article class="hm-feat" aria-labelledby="feat-moving-heads">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Moving Heads</p>
            <h3 class="hm-feat__title" id="feat-moving-heads">Cabezas móviles que llenan de haces, gobos y movimiento la pista y el escenario</h3>
