---
/**
 * ─── Iluminación de Escenario para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Iluminación de Escenario para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Escenario" },
];

const EQUIPOS = [
  {
    name: "Par LED RGBWA",
    excerpt: "Luminarias de 18x15W con mezcla de color 5-en-1 (rojo, verde, azul, blanco, ámbar). Haz de 25°, modo silencioso para ceremonias y control DMX512 profesional.",
    cta: "Par LED",
    href: "#parled-heading",
    icon: "lightbulb",
  },
  {
    name: "Moving Heads",
    excerpt: "Cabezas móviles tipo beam, spot y wash con rotación 360° pan/tilt continuo. Ruedas de gobos, efectos de prisma y control DMX para conciertos y galas.",
    cta: "Moving Heads",
    href: "#movingheads-heading",
    icon: "layers",
  },
  {
    name: "Follow Spots",
    excerpt: "Seguidor de luz de 1200W+ de alto rendimiento con tracking manual. Ideales para discursos, presentaciones en tarima, desfiles de moda y performances en vivo.",
    cta: "Follow Spots",
    href: "#followspots-heading",
    icon: "award",
  },
  {
    name: "Barras LED Motorizadas",
    excerpt: "Barras de wash LED con pixel mapping individual para efectos lineales dinámicos. Montaje en truss para backdrops de escenario con control DMX avanzado.",
    cta: "Barras LED",
    href: "#barrasled-heading",
    icon: "package",
  },
];

const faqs = [
  { question: "¿Cuál es la diferencia entre un par LED y un moving head?", answer: "El par LED RGBWA es una luminaria estática que proyecta un haz de color fijo en una dirección, ideal para baños de color en escenarios, paredes y ambientación general. El moving head es una cabeza motorizada que se mueve en dos ejes (pan y tilt) de forma continua, proyectando haces dinámicos, gobos y efectos prismáticos. Los pares LED son perfectos para iluminación base y ceremonias; los moving heads aportan dinamismo y espectáculo para conciertos, galas y fiestas. En la mayoría de producciones profesionales se combinan ambos para crear capas de iluminación completas." },
  { question: "¿El servicio incluye operador de consola DMX?", answer: "Sí, todos nuestros paquetes de iluminación de escenario incluyen un operador de consola DMX certificado durante todo el evento. El operador programa las escenas de iluminación previas al evento, opera en tiempo real durante presentaciones y números musicales, y ajusta la intensidad y efectos según el momento (ceremonia, cena, fiesta, discursos). La consola DMX512, el cableado profesional y la programación previa están incluidos sin costo adicional." },
  { question: "¿Qué estructuras de truss y rigging necesito para la iluminación?", answer: "Depende del tipo y cantidad de luminarias. Para eventos en salón con hasta 20 luminarias, utilizamos truss de aluminio ground support (desde el piso) en configuraciones de 6 a 12 metros lineales. Para producciones grandes con 40+ luminarias y moving heads, implementamos rigging aéreo fly system con motores de cadena certificados. Nuestro equipo técnico realiza una evaluación del venue para determinar los puntos de anclaje seguros y la capacidad de carga del techo. Todo el truss y rigging está incluido en el paquete." },
  { question: "¿Las luminarias pueden operar en modo silencioso para ceremonias?", answer: "Sí. Nuestros pares LED RGBWA cuentan con modo de ventilador silencioso (silent mode) que reduce el ruido a menos de 25 dB, haciéndolos imperceptibles durante ceremonias religiosas, votos matrimoniales y discursos. Los moving heads generan más ruido por sus motores internos, por lo que los reservamos para momentos de fiesta y música. Para ceremonias, utilizamos exclusivamente pares LED y fresneles LED que garantizan silencio absoluto sin sacrificar calidad de iluminación." },
  { question: "¿Puedo programar colores específicos para mi evento?", answer: "Absolutamente. Con la tecnología RGBWA de 5 canales, podemos crear prácticamente cualquier color del espectro visible. Programamos los colores exactos de tu paleta de evento (colores corporativos, temáticos de boda, etc.) en la consola DMX antes del montaje. También creamos secuencias de cambio de color sincronizadas con música, transiciones suaves entre escenas y efectos de fade. Envíanos tus códigos de color (Pantone, HEX o RGB) y los replicamos con precisión en la iluminación." },
  { question: "¿Con cuánta anticipación debo reservar iluminación de escenario?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo a junio). Las producciones grandes con más de 30 luminarias y rigging aéreo requieren al menos 1 mes para la planificación técnica, visita al venue y programación. Los paquetes básicos de 8 a 16 pares LED pueden confirmarse con 2 semanas de antelación. También atendemos solicitudes urgentes sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación de Escenario para Eventos en CDMX",
    description: "Par LED RGBWA, moving heads, follow spots y barras LED motorizadas para bodas, conciertos, galas y festivales. Operador DMX incluido.",
    url: "/servicios/iluminacion/escenario/",
    priceRange: { min: 1500, max: 35000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Escenario", url: "/servicios/iluminacion/escenario/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Iluminación de Escenario para Eventos en CDMX"
  description="Renta de iluminación de escenario: par LED RGBWA, moving heads, follow spots y barras LED motorizadas para eventos en CDMX. Operador DMX incluido. Desde $1,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Iluminación profesional de escenario"
    title='Renta de <span class="highlight">Iluminación de Escenario</span> para Eventos en CDMX'
    subtitle="Par LED RGBWA, moving heads, follow spots y barras LED motorizadas con operador de consola DMX incluido. Diseño lumínico profesional para cada momento de tu evento."
    primaryCTA={{ label: "Cotiza tu iluminación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar iluminación de escenario para mi evento` }}
    cards={[
      {
        title: "Luminarias de grado profesional para cada producción",
        content: "<strong>Renta de iluminación de escenario para eventos</strong> con el equipo más avanzado disponible en CDMX. Pares LED RGBWA de 18x15W con mezcla de color 5-en-1 y modo silencioso para ceremonias. Moving heads beam, spot y wash con rotación 360° continua para conciertos y galas. Follow spots de 1200W+ para seguimiento de protagonistas en tarima. Barras LED motorizadas con pixel mapping para backdrops espectaculares — cada luminaria verificada y calibrada antes de cada evento.",
      },
      {
        title: "Operador DMX y diseño lumínico incluido",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de iluminación de escenario. Nuestro operador certificado programa las escenas en consola DMX512 según tu guión de evento, opera en tiempo real durante cada momento (ceremonia, cena, fiesta, discursos) y ajusta intensidad, color y efectos para crear la atmósfera perfecta. Truss de aluminio, rigging profesional, cableado DMX y eléctrico incluidos en cada paquete.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas iluminación profesional para tu escenario?"
    subheadline="Cotiza sin compromiso y recibe un diseño lumínico personalizado para tu evento y venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de iluminación de escenario
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Iluminación de Escenario"
        subtitle="Luminarias profesionales para cada tipo de producción"
        description={[
          "Desde pares LED para ambientación elegante hasta moving heads para espectáculos de gran formato. Contamos con el inventario de iluminación de escenario más completo de la Ciudad de México.",
          "Cada luminaria incluye cableado DMX, estructura de montaje y operador de consola dedicado. Potencia, haz y color calibrados para garantizar una producción lumínica impecable."
        ]}
      />

      <div class="grid grid--4">
        {EQUIPOS.map((equipo) => (
          <Card
            name={equipo.name}
            excerpt={equipo.excerpt}
            cta={equipo.cta}
            href={equipo.href}
            icon={equipo.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAR LED RGBWA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="parled-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Versatilidad profesional</span>
          <h2 class="showcase__title" id="parled-heading">Par LED RGBWA</h2>
          <p class="showcase__subtitle">La base de toda iluminación de escenario profesional con mezcla de color 5-en-1.</p>
          <p class="showcase__text">Nuestros <strong>pares LED RGBWA</strong> integran <strong>18 LEDs de 15W</strong> cada uno con tecnología de mezcla de color 5-en-1 (rojo, verde, azul, blanco y ámbar) que permite reproducir prácticamente cualquier tonalidad del espectro visible. Con un <strong>ángulo de haz de 25°</strong> y lentes de alta eficiencia, proyectan baños de color uniformes sobre escenarios, paredes, columnas y elementos arquitectónicos. Disponibles en configuraciones de 8, 16, 24 y 32 unidades según la dimensión de tu evento.</p>
          <p class="showcase__text">Cuentan con <strong>modo silencioso (silent mode)</strong> que reduce el ruido del ventilador a menos de 25 dB, haciéndolos ideales para <strong>ceremonias religiosas, votos matrimoniales y discursos</strong> donde el silencio es esencial. Control <strong>DMX512 de 6 a 10 canales</strong> por unidad con dimmer suave de 0-100%, strobo variable y macros de color preprogramados. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para producciones completas con sonido e imagen sincronizados.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">18x15W RGBWA</span>
            <span class="showcase__tag">Haz 25°</span>
            <span class="showcase__tag">Silent Mode</span>
            <span class="showcase__tag">DMX512</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Par LED RGBWA
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOVING HEADS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="movingheads-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Dinamismo total</span>
          <h2 class="showcase__title" id="movingheads-heading">Moving Heads</h2>
          <p class="showcase__subtitle">Cabezas móviles beam, spot y wash con rotación 360° para espectáculos de gran impacto.</p>
          <p class="showcase__text">Nuestros <strong>moving heads profesionales</strong> están disponibles en tres modalidades: <strong>beam</strong> (haz concentrado de alto impacto), <strong>spot</strong> (haz definido con gobos y enfoque) y <strong>wash</strong> (baño de color amplio). Cada unidad ofrece <strong>rotación continua de 360° en pan y tilt</strong> con velocidad variable, permitiendo crear barridos, persecuciones y efectos aéreos que transforman cualquier escenario en un espectáculo visual. Ruedas de gobos intercambiables con diseños geométricos, florales y personalizados.</p>
          <p class="showcase__text">Incluyen <strong>efectos de prisma (3, 6 y 8 facetas)</strong> que multiplican el haz de luz creando patrones tridimensionales espectaculares. Control DMX de 16 a 24 canales con funciones de <strong>focus motorizado, zoom variable y color mixing CMY</strong>. Ideales para <strong>conciertos, galas corporativas, festivales de música y fiestas de alto nivel</strong>. El montaje en truss aéreo maximiza su impacto visual. Complementa con nuestras <a href="/servicios/pistas-baile/">pistas de baile LED</a> para crear una experiencia visual de 360° envolvente.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Beam / Spot / Wash</span>
            <span class="showcase__tag">360° Pan/Tilt</span>
            <span class="showcase__tag">Gobos + Prisma</span>
            <span class="showcase__tag">CMY Color</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Moving Heads
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FOLLOW SPOTS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="followspots-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">El protagonista iluminado</span>
          <h2 class="showcase__title" id="followspots-heading">Follow Spots</h2>
          <p class="showcase__subtitle">Seguidor de luz de alto rendimiento para destacar a los protagonistas de tu evento.</p>
          <p class="showcase__text">Nuestros <strong>follow spots de 1200W+</strong> de alta potencia permiten seguir manualmente a personas en movimiento sobre el escenario con un haz concentrado y definido. Equipados con <strong>lámpara de descarga HMI o LED de última generación</strong> que produce una luz blanca brillante con CRI superior a 90, garantizando que los colores de vestuario y maquillaje se vean naturales. Zoom manual de 8° a 22° para ajustar el tamaño del haz según la distancia al escenario.</p>
          <p class="showcase__text">Incluyen <strong>filtros de color intercambiables, iris variable y dimmer mecánico suave</strong> para transiciones elegantes de encendido y apagado. Un operador dedicado manipula el follow spot durante todo el evento, siguiendo al presentador, novios, conferencista o artista con precisión milimétrica. Esenciales para <strong>eventos con discursos, entregas de premios, performances en vivo, desfiles de moda y pasarelas</strong>. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario de escenario</a> como podiums y tarimas para una producción integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">1200W+ HMI/LED</span>
            <span class="showcase__tag">CRI 90+</span>
            <span class="showcase__tag">Zoom 8°-22°</span>
            <span class="showcase__tag">Operador dedicado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Follow Spots
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BARRAS LED MOTORIZADAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="barrasled-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Efectos lineales</span>
          <h2 class="showcase__title" id="barrasled-heading">Barras LED Motorizadas</h2>
          <p class="showcase__subtitle">Barras de wash LED con pixel mapping para backdrops de escenario espectaculares.</p>
          <p class="showcase__text">Nuestras <strong>barras LED motorizadas</strong> combinan múltiples LEDs RGBW alineados en formato lineal con <strong>control de pixel mapping individual</strong> que permite crear efectos de persecución, degradados, arcoíris y patrones dinámicos a lo largo de cada barra. Disponibles en longitudes de <strong>0.5, 1 y 1.2 metros</strong> con rotación motorizada de tilt para dirigir el haz desde el frente del escenario hasta 180°. Cada barra produce un baño de color uniforme y homogéneo perfecto para iluminar backdrops, cicloramas y telones.</p>
          <p class="showcase__text">Se montan en <strong>truss horizontal sobre el escenario</strong> en configuraciones de 4, 8, 12 o 16 barras para crear muros de luz lineales que responden al ritmo musical. El <strong>pixel mapping</strong> permite proyectar textos, gráficos simples y efectos de video de baja resolución directamente en el arreglo de barras, creando un backdrop lumínico sin necesidad de pantalla LED. Ideales para <strong>conciertos, festivales, DJ sets y producciones teatrales</strong>. Complementa con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para eventos al aire libre con estructura de truss integrada.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">RGBW Pixel Mapping</span>
            <span class="showcase__tag">Tilt Motorizado</span>
            <span class="showcase__tag">0.5 - 1.2 m</span>
            <span class="showcase__tag">Montaje Truss</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Barras LED
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="7" width="20" height="4" rx="1"/>
              <rect x="2" y="13" width="20" height="4" rx="1"/>
              <line x1="6" y1="3" x2="6" y2="7"/>
              <line x1="12" y1="3" x2="12" y2="7"/>
              <line x1="18" y1="3" x2="18" y2="7"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Iluminación de Escenario"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu iluminación de escenario, es natural tener preguntas sobre tipos de luminarias, control DMX, truss y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor técnico te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre iluminación de escenario al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de iluminación de escenario para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
