---
/**
 * ─── Candiles y Candelabros — Página de Producto (Nivel 4) ───
 * Candiles de cristal cortado, candelabros vintage y velas LED para eventos.
 * Color accent: Amber #e17055 (nivel 4). Layout con sidebar de interlinking.
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Candiles
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const faqs = [
  { question: "¿El techo de mi salón soporta un candil de cristal?", answer: 'Antes de cada instalación realizamos una <strong>visita técnica gratuita</strong> donde evaluamos la estructura del techo, puntos de anclaje y capacidad de carga. Nuestros candiles pesan entre 15 y 40 kg dependiendo del modelo y diámetro. Si el techo no soporta el peso directamente, utilizamos <strong>estructuras de truss portátiles autosoportadas</strong> con motor eléctrico que no requieren contacto con el techo — la misma solución que usamos en <a href="/servicios/carpas/">carpas profesionales</a> y venues con techos decorativos. Cada instalación incluye cables de seguridad certificados como medida de protección adicional obligatoria.' },
  { question: "¿Cuántos candiles necesito para una boda de 200 invitados?", answer: 'La cantidad depende del layout del salón y el efecto deseado. Como referencia típica para 200 invitados: <strong>1 candil grande (100-120 cm)</strong> como pieza central sobre la pista de baile + <strong>2-3 candiles medianos (60-80 cm)</strong> sobre la mesa principal y áreas lounge. Para eventos de 200+ personas con mayor impacto visual, recomendamos hasta 5 candiles a diferentes alturas creando una composición aérea dramática. La visita técnica es clave para determinar la cantidad exacta según las dimensiones y distribución de tu venue. Combínalos con <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights y guirnaldas</a> para una atmósfera completa.' },
  { question: "¿Las velas LED realmente se ven como velas reales?", answer: 'Sí. Nuestras velas LED utilizan <strong>tecnología de flickering (parpadeo)</strong> que replica fielmente el movimiento natural de una llama real con variaciones aleatorias de intensidad y dirección. La batería dura hasta 24 horas y cada vela incluye control remoto para encendido/apagado y regulación de brillo. Muchos venues y haciendas en la CDMX <strong>prohíben llamas abiertas por regulación</strong>, lo que convierte a las velas LED en la opción obligatoria. A distancia de mesa, los invitados no distinguen las velas LED de las reales — el efecto romántico es idéntico sin riesgo de cera derretida ni incendio.' },
  { question: "¿Puedo mezclar diferentes estilos de candiles en un mismo evento?", answer: 'Sí, y de hecho es una de las tendencias más solicitadas en eventos de lujo. Las combinaciones más populares: <strong>candil grande de cristal K9 sobre la pista de baile + candelabros vintage dorados en las mesas de invitados</strong>. También se solicitan 3 candiles de diferente tamaño colgados a distintas alturas para crear profundidad y dinamismo visual. Nuestro diseñador de iluminación crea un <strong>plan cohesivo</strong> que armoniza los diferentes estilos con la paleta de color de tu evento. Para complementar, las <a href="/servicios/iluminacion/decorativa/esferas-led/">esferas y figuras LED</a> añaden puntos de luz flotantes entre los candiles.' },
  { question: "¿Qué pasa si mi venue no permite instalaciones en el techo?", answer: 'Contamos con dos soluciones: la primera es una <strong>estructura de truss portátil con motor eléctrico</strong> — una estructura autosoportada que no toca el techo y puede sostener múltiples candiles con capacidad de hasta 200 kg. Se instala en cualquier espacio con altura mínima de 3 metros. La segunda opción son <strong>candelabros de piso (floor-standing)</strong> de 1.5 a 2 metros de altura que no requieren ninguna instalación aérea: se colocan estratégicamente alrededor de la pista de baile, altar o mesa principal para lograr un efecto de luces de cristal sin tocar techo ni estructura.' },
  { question: "¿Los candiles incluyen instalación y desmontaje?", answer: 'Sí, el servicio es completamente integral. El precio de renta incluye: <strong>visita técnica previa</strong> para evaluar estructura y puntos de anclaje, transporte de ida y vuelta, instalación con sistema de suspensión certificado y cables de seguridad, prueba completa de encendido y regulación, <strong>control de dimmer durante todo el evento</strong> para ajustar intensidad según cada momento (ceremonia, cena, fiesta), y desmontaje al día siguiente. Nuestro equipo de instalación llega <strong>4 a 6 horas antes del evento</strong> para garantizar que todo esté listo y probado antes de la llegada de los invitados.' },
];

const specs = [
  { label: "Material", value: "Cristal cortado K9 / Acrílico premium / Metal forjado" },
  { label: "Diámetros disponibles", value: "60cm, 80cm, 100cm, 120cm" },
  { label: "Peso", value: "15 a 40 kg (según modelo)" },
  { label: "Iluminación", value: "LED warm white 2700K, dimmer regulable" },
  { label: "Carga máxima soporte", value: "Truss: 200kg / Motor: 150kg" },
  { label: "Velas LED", value: "Flickering realista, batería 24h, control remoto" },
  { label: "Acabados", value: "Cristal transparente, dorado, plateado, bronce, negro" },
  { label: "Montaje", value: "Suspensión certificada + cable de seguridad" },
  { label: "Instalación aérea", value: "Motor eléctrico + estructura truss portátil" },
  { label: "Altura ajustable", value: "2.5m a 6m (con motor)" },
];

const sidebarNav = [
  { name: "Fairy Lights y Guirnaldas", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Candiles y Candelabros", href: null, active: true },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras y Números Luminosos", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
];

const sidebarRelated = [
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Mobiliario Premium", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Laura Martínez del Campo", text: "Contratamos una composición de 5 candiles para una gala corporativa en un salón de Polanco y el resultado fue impresionante. El candil central de cristal K9 de 120cm era la pieza protagonista — las refracciones de luz llenaban todo el salón de destellos. El equipo de instalación llegó 5 horas antes con estructura de truss y motores, todo quedó perfecto. Cada detalle fue cuidado al máximo, desde la altura de cada candil hasta la regulación del dimmer durante la cena.", rating: 5, date: "2025-11-22" },
  { author: "Roberto Guzmán", text: "Para nuestra boda en una hacienda colonial en Tlalpan rentamos candelabros vintage dorados para todas las mesas de invitados más un candil grande de cristal sobre la pista de baile. La combinación creó una atmósfera increíblemente romántica. Lo que más nos impresionó fue el control de dimmer durante la ceremonia religiosa — cuando dijimos los votos, el técnico bajó la intensidad y fue un momento mágico. Servicio completo y equipo muy profesional.", rating: 5, date: "2025-10-15" },
  { author: "Mariana Estrada", text: "Rentamos un candil de cristal de 100cm para los XV años de mi hija en una hacienda con techos de 6 metros. Pensé que sería imposible instalar algo así, pero el equipo llegó con estructura de truss portátil y en 4 horas ya estaba todo montado. El candil fue la estrella de todas las fotos — los destellos de cristal con la iluminación warm white crearon un efecto de cuento de hadas. También añadimos velas LED en caminos de luz hacia el altar y quedó espectacular.", rating: 5, date: "2025-09-03" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Candiles de Cristal y Candelabros para Eventos en CDMX",
    description: "Candiles de cristal cortado K9, candelabros vintage y velas LED para bodas, galas y eventos de lujo en CDMX. Instalación aérea certificada, dimmer regulable, diámetros de 60 a 120cm. Desde $1,500.",
    url: "/servicios/iluminacion/decorativa/candiles/",
    priceRange: { min: 1500, max: 12000 },
    reviews,
    ratingValue: 5,
    reviewCount: 56,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Candiles y Candelabros", url: "/servicios/iluminacion/decorativa/candiles/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Candiles de Cristal y Candelabros para Eventos en CDMX"
  description="Renta de candiles de cristal cortado, candelabros vintage y velas LED para bodas, galas y eventos de lujo en CDMX. Instalación aérea certificada incluida. Diámetros de 60 a 120cm. Desde $1,500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Elegancia incomparable para eventos de lujo"
    title='Renta de <span class="highlight">Candiles de Cristal</span> y Candelabros para Eventos'
    subtitle="Candiles de cristal cortado K9, candelabros vintage dorados y velas LED con flickering realista. Instalación aérea certificada con motor eléctrico, dimmer regulable y servicio técnico completo incluido."
    primaryCTA={{ label: "Cotiza tus candiles", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar candiles de cristal y candelabros para mi evento` }}
    cards={[
      {
        title: "Candiles de cristal K9 de 60 a 120cm que deslumbran",
        content: "<strong>Renta de candiles de cristal cortado para eventos</strong> con piezas de cristal K9 de alta pureza en diámetros de 60, 80, 100 y 120 cm. Cada candil refracta miles de destellos con iluminación LED warm white 2700K y dimmer regulable para crear la atmósfera perfecta en cada momento de tu evento. Acabados en cristal transparente, dorado, plateado, bronce y negro. Ideales para bodas elegantes, galas corporativas, cenas de gala y cualquier celebración donde la elegancia sea protagonista.",
      },
      {
        title: "Instalación aérea certificada con motor y estructura truss",
        content: "<strong>Servicio técnico integral</strong> en cada renta de candiles: visita técnica previa, transporte, instalación con sistema de suspensión certificado, motor eléctrico para ajuste de altura (2.5 a 6 m), cables de seguridad obligatorios y estructura truss portátil para venues sin puntos de anclaje en techo. Control de dimmer durante todo el evento y desmontaje al día siguiente. Sin preocupaciones técnicas — nosotros nos encargamos de todo.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas el toque de elegancia definitivo para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con plan de instalación personalizado para tu venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Iluminación Decorativa</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas candiles para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar candiles de cristal y candelabros para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Candiles y Candelabros</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Candiles de Cristal Cortado -->
          <section class="section section--alt" aria-labelledby="cristal-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Elegancia incomparable</span>
                <h2 class="showcase__title" id="cristal-heading">Candiles de Cristal Cortado</h2>
                <p class="showcase__subtitle">Piezas de cristal K9 de 80 a 120cm que refractan miles de destellos — la joya luminosa de salones de boda, galas y cenas premium.</p>
                <p class="showcase__text">Los <strong>candiles de cristal cortado K9</strong> son las piezas más solicitadas para bodas elegantes, galas corporativas y cenas de alto nivel en la Ciudad de México. Fabricados con <strong>cristal de alta pureza K9</strong> cortado a mano en facetas múltiples, cada pieza refracta la luz LED warm white 2700K en miles de destellos que llenan el salón de magia. Disponibles en diámetros de 80, 100 y 120 cm con acabados en cristal transparente, dorado y plateado.</p>
                <p class="showcase__text">Cada candil incluye <strong>iluminación LED interior regulable con dimmer</strong> para adaptar la intensidad a cada momento: luz suave durante la ceremonia, brillo medio en la cena y destellos vibrantes en la fiesta. El sistema de suspensión certificado con motor eléctrico permite ajustar la altura entre 2.5 y 6 metros. La pieza central perfecta que se complementa con nuestras <a href="/servicios/mobiliario/salas-lounge/">salas lounge premium</a> para crear un ambiente de lujo integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cristal K9</span>
                  <span class="showcase__tag">80-120cm</span>
                  <span class="showcase__tag">Warm white 2700K</span>
                  <span class="showcase__tag">Dimmer regulable</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Candil de Cristal
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                  <span>Candil de Cristal K9</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Composiciones Aéreas -->
          <section class="section section--alt" aria-labelledby="composiciones-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Impacto visual dramático</span>
                <h2 class="showcase__title" id="composiciones-heading">Composiciones Aéreas Multi-Candil</h2>
                <p class="showcase__subtitle">Múltiples candiles a diferentes alturas sobre pista de baile y mesa principal — profundidad, drama y sofisticación en cada ángulo.</p>
                <p class="showcase__text">Las <strong>composiciones aéreas multi-candil</strong> son la tendencia más impactante en iluminación decorativa para eventos de lujo. Se instalan de <strong>3 a 5 candiles de cristal a diferentes alturas</strong> creando una cascada luminosa que transforma por completo el espacio aéreo del salón. El candil central de 120 cm se suspende sobre la pista de baile como pieza protagonista, mientras que candiles de 80 y 60 cm flanquean la mesa principal y las áreas lounge a alturas escalonadas.</p>
                <p class="showcase__text">Cada candil se instala con <strong>motor eléctrico independiente</strong> que permite ajustar su altura individual durante el evento — se pueden bajar para fotos de detalle y subir durante la cena para ampliar la visual. La estructura de truss portátil soporta hasta 200 kg, permitiendo composiciones de 5+ candiles sin comprometer la seguridad. La combinación ideal con nuestras <a href="/servicios/pistas-baile/">pistas de baile iluminadas</a> para un escenario central deslumbrante donde la luz y el movimiento se fusionan.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Multi-chandelier</span>
                  <span class="showcase__tag">Alturas variables</span>
                  <span class="showcase__tag">Motor eléctrico</span>
                  <span class="showcase__tag">Truss portátil</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Composición Aérea
                </a>
              </div>
              <div class="showcase__image">
                <div class="showcase__placeholder">
                  <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
                  <span>Composición Aérea</span>
                </div>
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Candelabros Vintage de Mesa -->
          <section class="section section--alt" aria-labelledby="vintage-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Centros de mesa con carácter</span>
                <h2 class="showcase__title" id="vintage-heading">Candelabros Vintage de Mesa</h2>
                <p class="showcase__subtitle">Candelabros dorados, plateados y bronce con velas LED flickering para mesas de invitados — estética clásica y romántica sin llama abierta.</p>
                <p class="showcase__text">Los <strong>candelabros vintage de mesa</strong> añaden personalidad y calidez a cada rincón de tu evento. Disponibles en acabados <strong>dorado envejecido, plateado pulido, bronce antiguo y negro mate</strong>, cada pieza está elaborada en metal forjado con detalles artesanales que evocan la elegancia de épocas pasadas. Alturas de 40 a 70 cm para generar verticalidad en las mesas sin obstruir la conversación entre invitados.</p>
