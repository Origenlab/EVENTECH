---
/**
 * ─── Letras y Números Luminosos — Página de Producto (Nivel 4) ───
 * Letras LOVE, iniciales, números XV y marquee signs corporativos.
 * Color accent: Amber #e17055 (nivel 4). Layout con sidebar de interlinking.
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Letras Luminosas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';

const faqs = [
  { question: "¿Con cuánta anticipación debo reservar las letras LOVE?", answer: 'Las letras LOVE e iniciales son los artículos más solicitados de nuestro catálogo de iluminación decorativa. En temporada alta (noviembre a febrero y mayo para bodas) te recomendamos reservar con 3 a 4 semanas de anticipación para garantizar disponibilidad. En temporada baja, 1 a 2 semanas suele ser suficiente. Para números XV, 2 semanas de anticipación es generalmente adecuado. Las solicitudes de último momento están sujetas a disponibilidad y no siempre podemos confirmarlas. Nuestra recomendación: reserva tus letras luminosas en cuanto confirmes la fecha de tu boda o evento para asegurar tu set.' },
  { question: "¿Puedo pedir letras o símbolos personalizados fuera del catálogo?", answer: 'Sí. Contamos con el alfabeto completo A-Z, números del 0 al 9 y símbolos como & y corazón en inventario permanente. Para caracteres especiales, logotipos o tipografías no estándar, ofrecemos fabricación personalizada con un tiempo de producción de 2 a 3 semanas. Si necesitas una solución más rápida para formas y logos personalizados, nuestro <a href="/servicios/iluminacion/decorativa/esferas-led/">neon flex personalizado</a> es una alternativa con tiempos de entrega más cortos y diseño totalmente libre.' },
  { question: "¿Las letras luminosas funcionan en exteriores?", answer: 'Sí, todas nuestras letras utilizan tecnología LED que funciona perfectamente en exteriores. Sin embargo, la estructura metálica con acabado pintado no es resistente al agua (no son waterproof). Para contingencia de lluvia, recomendamos colocarlas bajo <a href="/servicios/carpas/">carpas</a> o en áreas techadas. Si necesitas señalización completamente resistente a la intemperie con certificación IP65, considera nuestra opción de neon flex que está sellada contra agua y polvo.' },
  { question: "¿Dónde se colocan las letras en una boda típica?", answer: "La ubicación más popular es LOVE o AMOR detrás de la mesa de dulces, creando un punto focal espectacular para fotos. Las iniciales de los novios se colocan frecuentemente en la entrada o área de recepción como bienvenida personalizada. Otras ubicaciones populares: LOVE como backdrop de photocall, junto a la mesa de regalos, iluminando el camino en el jardín, flanqueando la mesa principal o en la pista de baile para las fotos de la entrada triunfal. Nuestro equipo te ayuda a elegir la mejor ubicación durante la visita al venue, considerando iluminación ambiental, flujo de invitados y puntos de fotografía." },
  { question: "¿Las letras incluyen montaje y desmontaje?", answer: "Sí, el servicio completo está incluido en cada renta: transporte al venue, instalación con bases estabilizadoras, conexiones eléctricas con extensiones ocultas, prueba de encendido y verificación de seguridad, y desmontaje al día siguiente del evento. El montaje toma aproximadamente 30 minutos por set de letras. Nuestro equipo coordina la hora de llegada directamente con tu wedding planner o coordinador del venue para no interferir con otros proveedores." },
  { question: "¿Cuál es la diferencia entre marquee lights y neon flex?", answer: 'Las marquee lights (lo que ofrecemos aquí) son letras con estructura metálica 3D con focos LED estilo vintage, que dan un look clásico Hollywood/retro. Son independientes y sustanciales, con alturas de 60 a 120 cm, ideales para colocar en piso o mesa. El <a href="/servicios/iluminacion/decorativa/esferas-led/">neon flex</a> es un tubo LED flexible moldeado en cualquier diseño y montado sobre un respaldo plano — moderno, elegante y completamente personalizable en forma y tipografía. En resumen: marquee = clásico/romántico, neon flex = moderno/artístico. Ambos están disponibles para renta y se pueden combinar en un mismo evento.' },
];

const specs = [
  { label: "Material", value: "Estructura metálica + acabado blanco mate" },
  { label: "Alturas disponibles", value: "60 cm, 90 cm, 120 cm" },
  { label: "Iluminación", value: "LED warm white 2700K estilo vintage" },
  { label: "Consumo eléctrico", value: "5W por letra / número" },
  { label: "Peso por unidad", value: "3 a 8 kg por letra (según altura)" },
  { label: "Caracteres disponibles", value: "A-Z, 0-9, &, corazón" },
  { label: "Acabados", value: "Blanco mate, dorado, plateado, natural" },
  { label: "Montaje", value: "Base estabilizadora, instalación en 30 min" },
  { label: "Combinaciones populares", value: "LOVE, AMOR, MR&MRS, iniciales, XV, edad" },
  { label: "Base / Soporte", value: "Piso o mesa (adaptadores incluidos)" },
];

const sidebarNav = [
  { name: "Fairy Lights y Guirnaldas", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Candiles y Candelabros", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras y Números Luminosos", href: null, active: true },
];

const sidebarRelated = [
  { name: "Iluminación Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Mobiliario Premium", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Sofía Ramírez", text: "Rentamos las letras LOVE de 120cm en blanco para colocarlas detrás de la mesa de dulces y las iniciales M&J de 90cm en la entrada de la recepción. Fueron los elementos más fotografiados de toda la boda. El brillo cálido vintage era exactamente lo que buscábamos — romántico sin ser demasiado llamativo. Todos los invitados se tomaron fotos con las letras. Servicio impecable.", rating: 5, date: "2025-12-05" },
  { author: "Carmen Delgado", text: "Para los XV años de mi hija rentamos los números XV en dorado de 90cm como backdrop del área de fotos, combinados con una decoración de corona. A mi hija le encantaron — se veían elegantes y llamativos. El montaje fue rapidísimo, el equipo llegó puntual y todo quedó perfecto en menos de media hora. Muy profesionales, lo recomiendo ampliamente.", rating: 5, date: "2025-11-08" },
  { author: "Alejandro Prieto", text: "Contratamos letras marquee con el hashtag de nuestra campaña para un evento corporativo. Los empleados no paraban de tomarse fotos — el engagement en redes sociales fue increíble. Excelente para activaciones de marca y brand awareness. Las letras se veían premium y profesionales, justo lo que necesitábamos para la imagen de la empresa.", rating: 5, date: "2025-10-01" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Letras Luminosas y Marquee para Eventos en CDMX",
    description: "Renta de letras LOVE, iniciales luminosas, números XV y marquee lights para bodas, XV años y eventos corporativos en CDMX. Alturas de 60 a 120cm, LED cálido vintage, montaje incluido. Desde $300 por letra.",
    url: "/servicios/iluminacion/decorativa/letras-luminosas/",
    priceRange: { min: 300, max: 5000 },
    reviews,
    ratingValue: 5,
    reviewCount: 73,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Letras y Números Luminosos", url: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Letras Luminosas y Marquee para Bodas y XV Años en CDMX"
  description="Renta de letras LOVE, iniciales luminosas, números XV y marquee lights para bodas, XV años y eventos en CDMX. Altura 60-120cm, LED cálido vintage. Montaje incluido. Desde $300/letra. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El elemento más fotografiado de tu evento"
    title='Renta de <span class="highlight">Letras Luminosas</span> y Marquee para Bodas y XV Años'
    subtitle="Letras LOVE, iniciales personalizadas, números XV y marquee signs corporativos en alturas de 60 a 120 cm con LED cálido vintage. Estructura metálica premium con montaje profesional incluido."
    primaryCTA={{ label: "Cotiza tus letras luminosas", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar letras luminosas para mi evento` }}
    cards={[
      {
        title: "Letras LOVE, AMOR e iniciales que iluminan tu celebración",
        content: "<strong>Renta de letras luminosas para bodas y eventos</strong> con estructura metálica de alta calidad y LED warm white 2700K estilo vintage en la Ciudad de México. Disponibles en blanco mate, dorado, plateado y acabado natural, con alturas de 60, 90 y 120 cm. Las letras LOVE y AMOR son el elemento decorativo más fotografiado en bodas — ideales como fondo de mesa de dulces, photocall, recepción o pista de baile. Iniciales personalizadas A-Z con símbolo & para crear combinaciones únicas como M&J, A+R o cualquier par de letras.",
      },
      {
        title: "Números XV, edades, hashtags y marquee signs con montaje profesional",
        content: "<strong>Números luminosos y marquee signs corporativos</strong> para XV años, cumpleaños, aniversarios y activaciones de marca. Números del 0 al 9 disponibles en todas las alturas para crear XV dorado, edades de cumpleaños o años de aniversario. Para eventos corporativos, armamos hashtags, frases y nombres de marca en letras marquee. Servicio completo incluido: transporte, montaje con bases estabilizadoras en 30 minutos, conexiones eléctricas con cables ocultos y desmontaje al día siguiente.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres que tu nombre brille en tu gran día?"
    subheadline="Cotiza sin compromiso — te enviamos propuesta con visita al venue para elegir la ubicación perfecta de tus letras"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Iluminación Decorativa</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas letras luminosas para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar letras luminosas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 4 4 20 4 20 7"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="12" y1="4" x2="12" y2="20"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Letras y Números Luminosos</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: LOVE / AMOR (Bodas) -->
          <section class="section section--alt" aria-labelledby="love-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">El más fotografiado</span>
                <h2 class="showcase__title" id="love-heading">Letras LOVE / AMOR para Bodas</h2>
                <p class="showcase__subtitle">Letras de 90 a 120 cm en blanco o dorado: el centro de atención de tu recepción y el fondo perfecto para cada foto.</p>
                <p class="showcase__text">Las <strong>letras LOVE y AMOR</strong> son el elemento decorativo más solicitado y más fotografiado en bodas en la Ciudad de México. Con alturas de 90 y 120 cm, estructura metálica robusta y <strong>LED warm white 2700K estilo vintage</strong>, crean un punto focal irresistible que atrae a todos los invitados. Disponibles en acabado blanco mate para bodas clásicas y dorado para celebraciones más glamurosas. Cada letra pesa entre 5 y 8 kg según la altura, garantizando estabilidad total durante todo el evento.</p>
                <p class="showcase__text">La ubicación más popular es detrás de la <strong>mesa de dulces</strong>, donde las letras enmarcan la presentación y sirven como fondo de foto para cada invitado que se acerca. También funcionan espectacularmente como <strong>photocall principal</strong>, backdrop de la pista de baile para la entrada triunfal de los novios, o iluminando el camino del jardín. Para un montaje completo, combínalas con nuestra <a href="/servicios/accesorios/senalizacion-alfombras/">señalización y alfombras</a> que complementan el recorrido visual del evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">LOVE / AMOR</span>
                  <span class="showcase__tag">90–120 cm</span>
                  <span class="showcase__tag">LED warm white</span>
                  <span class="showcase__tag">Photocall estrella</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Letras LOVE
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/placeholder-letras-love-boda.avif" alt="Letras LOVE luminosas de 120cm en blanco detrás de mesa de dulces en boda elegante" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Iniciales Personalizadas -->
          <section class="section section--alt" aria-labelledby="iniciales-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tan único como tu evento</span>
                <h2 class="showcase__title" id="iniciales-heading">Iniciales Personalizadas</h2>
                <p class="showcase__subtitle">Combinaciones M&J, A+R o cualquier par de letras con símbolo &: tu monograma iluminado en el evento más importante de tu vida.</p>
                <p class="showcase__text">Las <strong>iniciales luminosas personalizadas</strong> son la forma más elegante de poner tu sello personal en la decoración de tu boda o evento. Disponemos del <strong>alfabeto completo A-Z y el símbolo &</strong> en todas las alturas (60, 90 y 120 cm) y acabados (blanco, dorado, plateado, natural). Crea combinaciones clásicas como M&J, A+R o cualquier par de iniciales que represente tu historia. Las letras se colocan en formato horizontal, vertical o escalonado según el espacio disponible y tu preferencia estética.</p>
                <p class="showcase__text">Ideales para la <strong>entrada de la recepción</strong> como bienvenida personalizada, junto a la mesa de regalos, o flanqueando la mesa principal. El acabado dorado es especialmente popular para bodas con paleta metálica, mientras que el blanco mate es el favorito para bodas clásicas y románticas. Cada letra tiene base estabilizadora independiente, lo que permite jugar con el espaciado y la disposición. Para potenciar el efecto, rodea tus iniciales con <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights y guirnaldas</a> que enmarquen el conjunto con un halo de luz cálida.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">A-Z personalizable</span>
                  <span class="showcase__tag">Símbolo &</span>
                  <span class="showcase__tag">Dorado / Plateado</span>
                  <span class="showcase__tag">Formato libre</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Iniciales
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/placeholder-iniciales-luminosas-boda.avif" alt="Iniciales luminosas personalizadas M&J en dorado de 90cm en entrada de recepción de boda" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Números XV Años y Cumpleaños -->
          <section class="section section--alt" aria-labelledby="numeros-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Marca la fecha en grande</span>
                <h2 class="showcase__title" id="numeros-heading">Números XV Años y Cumpleaños</h2>
                <p class="showcase__subtitle">Números XV dorados, edades de cumpleaños y años de aniversario: celebra cada cifra con luz y estilo.</p>
                <p class="showcase__text">Los <strong>números luminosos</strong> son el complemento perfecto para XV años, cumpleaños y aniversarios. Contamos con los <strong>números del 0 al 9 en alturas de 60, 90 y 120 cm</strong> para crear cualquier combinación: XV dorado como punto focal de la fiesta de quince años, edad del cumpleañero para fiestas de cualquier edad (del 1 al 99), o el año de aniversario para bodas de plata, oro y todas las celebraciones intermedias. El acabado dorado es el más solicitado para XV años, combinado con coronas decorativas y marcos LED que potencian el brillo del conjunto.</p>
                <p class="showcase__text">Funcionan espectacularmente como <strong>backdrop del área de fotos</strong>, donde cada invitado se toma su selfie con el número de la celebración. Para XV años, el set XV + corona LED crea un escenario de ensueño que las quinceañeras adoran. Para fiestas temáticas y cumpleaños infantiles, combina los números con nuestros <a href="/servicios/inflables/">inflables y juegos</a> para crear una zona de entretenimiento completa. El montaje incluye bases estabilizadoras y adaptadores para colocación en piso o mesa según la logística del venue.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Números 0-9</span>
                  <span class="showcase__tag">XV dorado</span>
                  <span class="showcase__tag">Coronas LED</span>
                  <span class="showcase__tag">Cumpleaños</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Números Luminosos
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/placeholder-numeros-xv-luminosos.avif" alt="Números XV luminosos en dorado de 90cm como backdrop de foto en fiesta de XV años" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Marquee Signs Corporativos -->
          <section class="section section--alt" aria-labelledby="marquee-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tu marca iluminada</span>
                <h2 class="showcase__title" id="marquee-heading">Marquee Signs Corporativos</h2>
                <p class="showcase__subtitle">Hashtags, logos, frases de campaña y nombres de marca en letras marquee: ilumina tu activación y dispara el engagement.</p>
