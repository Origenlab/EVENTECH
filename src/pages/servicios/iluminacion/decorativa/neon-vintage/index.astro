---
/**
 * ─── Luces Neón y Vintage — Página de Producto (Nivel 4) ───
 * Letreros de neón LED personalizados y luces vintage Edison para eventos.
 * Color accent amber #c2a24a (jerarquía L4).
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Neón y Vintage
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { label: "Neón y Vintage" },
];

const faqs = [
  { question: "¿Puedo poner mi nombre o una frase en un letrero de neón?", answer: 'Sí, es nuestra especialidad. Fabricamos <strong>letreros de neón LED totalmente personalizados</strong> con el nombre de los novios, la frase que elijas, el hashtag de tu evento o el logo de tu marca. Partimos de tu texto y la tipografía que prefieras — <strong>script, cursiva o mayúsculas</strong> — y te enviamos un render digital para tu aprobación antes de fabricar, para que valides tamaño, color y acabado. Si buscas letras individuales grandes tipo marquesina, revisa también nuestras <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras y letreros luminosos</a>.' },
  { question: "¿Cuánto tarda en fabricarse un letrero personalizado?", answer: 'Un <strong>letrero de neón personalizado</strong> requiere de <strong>7 a 15 días hábiles</strong> de fabricación, según el tamaño, la cantidad de texto y el acabado del backing (acrílico transparente, negro o cortado a la forma del texto). Para eventos con fecha próxima contamos con <strong>letreros de neón de stock</strong> con frases populares ("Love", "Mr &amp; Mrs", "Cheers", "Oh Baby") disponibles de inmediato. Te recomendamos reservar con al menos <strong>3 semanas de anticipación</strong> para garantizar tu diseño a medida.' },
  { question: "¿Qué colores de neón hay disponibles?", answer: 'El <strong>neón LED flexible</strong> está disponible en una amplia gama: blanco cálido, blanco frío, dorado, rosa, rojo, azul, turquesa, verde, morado y multicolor <strong>RGB</strong>. El RGB permite cambiar de color por control remoto e incluso programar efectos de fundido durante la noche. Para el estilo <strong>vintage</strong> ofrecemos focos Edison de filamento en tono ámbar cálido (~2700K). Podemos combinar varios colores en un mismo letrero para lograr exactamente la paleta de tu evento.' },
  { question: "¿Es neón real de vidrio o neón LED?", answer: 'Trabajamos con <strong>neón LED flexible</strong>, no con tubo de vidrio y gas. El neón LED reproduce fielmente el brillo continuo del neón tradicional, pero es <strong>más seguro, más ligero, no se calienta, no se rompe y consume mucha menos energía</strong>. Esto lo hace ideal para eventos: se transporta sin riesgo, se monta en muros, backdrops o atriles, y opera toda la noche sin sobrecalentarse. El acabado visual es prácticamente idéntico al neón de vidrio, con la ventaja de la durabilidad y la seguridad.' },
  { question: "¿Funcionan en interior y exterior?", answer: 'Ambos. Nuestros <strong>letreros de neón LED</strong> y las <strong>guirnaldas vintage Edison</strong> funcionan perfectamente en salones, terrazas y jardines. Para <strong>exterior</strong> utilizamos versiones con protección contra humedad y aseguramos la instalación eléctrica ante lluvia o rocío. En venues sin toma de corriente cercana llevamos extensiones y, si hace falta, coordinamos planta de luz. Siempre revisamos el punto de montaje durante la visita técnica gratuita.' },
  { question: "¿Puedo combinarlo con guirnaldas y otras luces?", answer: 'Totalmente, y es lo que más recomendamos para un ambiente cálido y fotogénico. Un <strong>letrero de neón</strong> como punto focal detrás del backdrop principal, combinado con <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights y guirnaldas</a> de fondo y focos Edison colgados, crea capas de luz con mucha profundidad. Para la fiesta también sumamos <a href="/servicios/iluminacion/efectos-especiales/luz-negra/">luz negra UV</a> y efectos glow. Nuestro equipo diseña la combinación completa según tu venue y tu estilo.' },
];

const specs = [
  { label: "Tecnología", value: "Neón LED flexible (silicón) + focos Edison" },
  { label: "Personalización", value: "Texto, frase y forma a medida" },
  { label: "Colores de neón", value: "Blanco cálido/frío, dorado, rosa, rojo, azul, verde, RGB" },
  { label: "Focos vintage", value: "Edison de filamento (E27) estilo retro" },
  { label: "Temperatura de color", value: "Cálida ~2700K (ámbar vintage)" },
  { label: "Montaje", value: "Muro, backdrop, atril o base de piso" },
  { label: "Consumo", value: "Bajo consumo LED, opera toda la noche" },
  { label: "Seguridad", value: "No se calienta, no se rompe, bajo voltaje" },
  { label: "Fabricación de letrero", value: "7-15 días hábiles (diseño a medida)" },
  { label: "Control", value: "Encendido, dimmer y RGB por control remoto" },
];

const sidebarNav = [
  { name: "Fairy Lights y Guirnaldas", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Candiles de Cristal", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras y Letreros", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Neón y Vintage", href: null, active: true },
  { name: "Cascadas LED", href: "/servicios/iluminacion/decorativa/cascadas-led/" },
];

const sidebarRelated = [
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Fairy Lights", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Luz Negra UV", href: "/servicios/iluminacion/efectos-especiales/luz-negra/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
];

const reviews = [
  { author: "Mariana Gutiérrez", text: "Rentamos un letrero de neón personalizado con nuestros nombres para el backdrop de la boda y quedó espectacular. El color rosa cálido combinó perfecto con las guirnaldas Edison que también nos instalaron. Fue el rincón más fotografiado de toda la noche, y el render que nos enviaron antes de fabricar nos dio mucha tranquilidad. Instalación impecable.", rating: 5, date: "2025-11-08" },
  { author: "Diego Hernández", text: "Para los XV de mi hija pedimos un letrero de neón azul RGB y ambiente glow para la pista. El efecto fue justo lo que buscábamos: súper vibrante y moderno. Llegaron a tiempo, montaron todo en el muro sin dañar nada y lo retiraron al final sin problema. La combinación con la luz negra encendió la fiesta. Muy recomendables.", rating: 5, date: "2025-10-12" },
  { author: "Paulina Ramírez", text: "Contratamos luces vintage Edison para la terraza de un evento de la empresa y el ambiente cálido cambió por completo el espacio. Se veía elegante y acogedor en las fotos, con esa luz ámbar tan bonita. El equipo fue muy profesional con la instalación eléctrica en exterior y con el dimmer ajustamos la intensidad durante la cena. Repetiremos sin duda.", rating: 5, date: "2025-09-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Luces Neón y Vintage para Eventos en CDMX",
    description: "Renta de luces neón LED personalizadas y luces vintage Edison para eventos en CDMX. Letreros a medida con tu nombre o frase, focos Edison de luz cálida, montaje en muro o backdrop. Instalación incluida. Desde $1,500.",
    url: "/servicios/iluminacion/decorativa/neon-vintage/",
    priceRange: { min: 1500, max: 20000 },
    reviews,
    ratingValue: 5,
    reviewCount: 31,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Neón y Vintage", url: "/servicios/iluminacion/decorativa/neon-vintage/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Luces Neón y Vintage para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de luces neón LED personalizadas y luces vintage Edison para bodas, XV años y fiestas en CDMX: letreros a medida, ambiente cálido. Instalación incluida. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Ambiente cálido y fotogénico"
    title='Renta de <span class="highlight">Luces Neón y Vintage</span> para Eventos en CDMX'
    subtitle="Letreros de neón LED personalizados con tu nombre o frase, y luces vintage Edison de luz cálida para bodas, XV años, fiestas y eventos corporativos. Diseño a medida, instalación y desmontaje incluidos en la Ciudad de México."
    primaryCTA={{ label: "Cotiza tu letrero de neón", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar luces neón y vintage para mi evento` }}
    cards={[
      {
        title: "Letreros de neón LED a medida y luz vintage con encanto retro",
        content: "<strong>Renta de luces neón y vintage para eventos</strong> en la Ciudad de México. Fabricamos letreros de <strong>neón LED flexible</strong> totalmente personalizados con el nombre de los novios, una frase, un hashtag o el logo de tu marca, en colores como blanco cálido, dorado, rosa, azul y RGB. Los complementamos con <strong>focos Edison de filamento</strong> y guirnaldas de luz cálida (~2700K) que dan ese ambiente acogedor y fotogénico tan buscado en bodas, XV años y fiestas.",
      },
      {
        title: "Diseño, instalación y operación incluidos",
        content: "<strong>Servicio integral</strong> en cada renta. Partimos de tu texto y tipografía para entregarte un <strong>render digital de aprobación</strong> antes de fabricar tu letrero. Montamos en muro, backdrop, atril o base de piso, cuidando la instalación eléctrica y la seguridad — el neón LED no se calienta ni se rompe y es de bajo consumo. Incluye traslado, colocación, dimmer/control remoto y desmontaje al finalizar tu evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres un letrero de neón personalizado para tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos un render de tu diseño y una propuesta con ambiente vintage a medida"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Iluminación Decorativa</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas luces neón y vintage para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar luces neón y vintage para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Luces Neón y Vintage</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Letrero Neón Personalizado -->
          <section class="section" aria-labelledby="letrero-heading">
            <ServiceShowcase
    title="Letrero Neón Personalizado"
    headingId="letrero-heading"
    badge="Tu nombre o frase en luz"
    subtitle="Neón LED flexible fabricado a medida con el texto, la tipografía y el color que elijas."
    tags={["Diseño a medida", "Neón LED flexible", "Render de aprobación", "Multicolor / RGB"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Letrero Neón"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>letrero de neón personalizado</strong> es el protagonista de cualquier backdrop. Fabricamos tu <strong>nombre, frase, hashtag o logo</strong> en neón LED flexible sobre backing de acrílico (transparente, negro o cortado a la forma del texto), a partir de la tipografía que prefieras — script, cursiva o mayúsculas. Antes de producir te enviamos un <strong>render digital</strong> para que apruebes tamaño, color y acabado con total confianza.</p>
      <p class="showcase__text">Disponible en blanco cálido, dorado, rosa, azul, verde, morado y <strong>RGB con control remoto</strong> para cambiar de color durante la noche. Es el detalle que más fotografían tus invitados en bodas, XV años y activaciones de marca. Si prefieres letras individuales grandes tipo marquesina, revisa nuestras <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras y letreros luminosos</a>.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion/luces-neon-uv-fiesta-glow.avif" alt="Luces de neón LED en fiesta con efecto glow" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/guirnaldas-led-vintage-decorativa-noche.avif" alt="Guirnaldas LED vintage decorativas de noche" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/guirnaldas-vintage-iluminacion-boda.avif" alt="Guirnaldas vintage iluminando una boda" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Ambiente Vintage Edison -->
          <section class="section" aria-labelledby="vintage-heading">
            <ServiceShowcase
    title="Ambiente Vintage Edison"
    headingId="vintage-heading"
    badge="Luz cálida y acogedora"
    subtitle="Focos Edison de filamento y guirnaldas de luz ámbar para un ambiente retro y elegante."
    tags={["Focos Edison", "Luz cálida ~2700K", "Guirnaldas colgantes", "Estilo retro"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Ambiente Vintage"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>ambiente vintage Edison</strong> transforma cualquier espacio con luz cálida y acogedora. Colgamos <strong>focos Edison de filamento</strong> en tono ámbar (~2700K) sobre terrazas, jardines, pérgolas y salones, creando ese techo de luz tan característico de las bodas al aire libre y las cenas íntimas. La luz tenue y dorada favorece la fotografía y da una sensación de calidez inmediata al venue.</p>
      <p class="showcase__text">Combinamos los focos Edison con <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights y guirnaldas</a> para sumar capas de luz y profundidad. Todo con <strong>dimmer</strong> para ajustar la intensidad según el momento — más brillante en la cena, más tenue en la fiesta. Ideal para quienes buscan elegancia sin estridencias, con un estilo natural y atemporal.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/guirnaldas/renta-luces-edison-evento-terraza.avif" alt="Luces Edison colgadas en terraza de evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/guirnaldas-vintage-iluminacion-boda.avif" alt="Guirnaldas vintage iluminando una boda" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/guirnaldas-led-vintage-decorativa-noche.avif" alt="Guirnaldas LED vintage decorativas de noche" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: Neón + Glow Party -->
          <section class="section" aria-labelledby="glow-heading">
            <ServiceShowcase
    title="Neón + Glow Party"
    headingId="glow-heading"
    badge="Energía vibrante para la fiesta"
    subtitle="Neón vibrante y efecto glow para llenar la pista de color y energía juvenil."
    tags={["Neón vibrante", "Efecto glow", "RGB dinámico", "Ideal para pista"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Neón + Glow"
  >
    <Fragment slot="body">
      <p class="showcase__text">Para la parte de <strong>fiesta</strong>, el neón sube de intensidad. Letreros y tiras de <strong>neón LED en colores vibrantes</strong> — rosa eléctrico, azul, verde y RGB dinámico — encienden la pista de baile con energía juvenil y moderna. Perfecto para XV años, after parties y activaciones de marca donde el ambiente pide algo audaz, colorido y muy fotogénico.</p>
      <p class="showcase__text">Potenciamos el efecto con <a href="/servicios/iluminacion/efectos-especiales/luz-negra/">luz negra UV</a> y detalles glow que hacen resaltar el blanco y los colores neón en la ropa y la decoración. Coordinamos el encendido del neón con el arranque de la fiesta para marcar un cambio de ambiente claro entre la cena y el baile.</p>
    </Fragment>
    <Fragment slot="media">
      <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/iluminacion/luces-neon-uv-fiesta-glow.avif" alt="Luces de neón LED en fiesta con efecto glow" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/guirnaldas-vintage-iluminacion-boda.avif" alt="Guirnaldas vintage iluminando una boda" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-luces-edison-evento-terraza.avif" alt="Luces Edison colgadas en terraza de evento" loading="lazy" decoding="async" /></div>
                </div>
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 7. SHOWCASE: Producción Neón -->
