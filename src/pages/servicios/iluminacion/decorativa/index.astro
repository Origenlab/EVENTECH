---
/**
 * ─── Iluminacion Decorativa para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Iluminación Decorativa para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const DECORATIVA = [
  {
    name: "Fairy Lights y Guirnaldas",
    excerpt: "Cortinas de luces cálidas, canopy de techo, guirnaldas vintage y tree wrap para crear ambientes mágicos en bodas, jardines y recepciones al aire libre.",
    cta: "Fairy Lights",
    href: "#fairylights-heading",
    icon: "heart",
  },
  {
    name: "Candiles y Candelabros",
    excerpt: "Candiles de cristal cortado, candelabros vintage de mesa y velas LED para salones de banquetes, haciendas y eventos de gala con elegancia clásica.",
    cta: "Candiles",
    href: "#candiles-heading",
    icon: "crown",
  },
  {
    name: "Esferas y Figuras LED",
    excerpt: "Esferas luminosas de diferentes tamaños, figuras geométricas iluminadas, neon flex personalizado y centros de mesa LED para decoración moderna.",
    cta: "Esferas LED",
    href: "#esferas-heading",
    icon: "lightbulb",
  },
  {
    name: "Letras y Números Luminosos",
    excerpt: "Letras marquee LOVE, iniciales personalizadas y números luminosos para XV años y cumpleaños. Altura de 60 a 120 cm con iluminación LED cálida.",
    cta: "Letras LED",
    href: "#letras-heading",
    icon: "award",
  },
];

const faqs = [
  { question: "¿Las fairy lights funcionan tanto en interiores como en exteriores?", answer: "Sí. Contamos con dos líneas de fairy lights: interior (IP44) para salones, carpas y techos, y exterior (IP65) resistentes a lluvia y humedad para jardines, terrazas y patios. Ambas versiones están disponibles en tonos warm white, cool white y multicolor. Para exteriores recomendamos las de cable transparente que se integran con la vegetación, mientras que para interiores las de cable dorado o cobrizo aportan un toque vintage. Nuestro equipo técnico evalúa tu venue para seleccionar la versión adecuada." },
  { question: "¿Qué se necesita para colgar un candil de cristal en mi venue?", answer: "Para instalar candiles de cristal necesitamos un punto de anclaje estructural en el techo capaz de soportar entre 15 y 40 kg según el modelo. Realizamos una visita técnica previa para evaluar la estructura de tu salón o carpa. Si el techo no tiene soporte suficiente, utilizamos estructuras de truss portátiles con motor eléctrico que permiten colgar candiles de forma segura en cualquier espacio. El montaje incluye cableado oculto, regulador de intensidad (dimmer) y pruebas de seguridad completas." },
  { question: "¿Puedo pedir letras o números personalizados?", answer: "Sí. Ofrecemos letras marquee en todo el abecedario, los números del 0 al 9, y símbolos como & y corazones. Las combinaciones más populares son LOVE, AMOR, los iniciales de los novios (M&J, A+R), y números para XV años, edades de cumpleaños y aniversarios. Están disponibles en alturas de 60, 90 y 120 cm con iluminación LED cálida integrada. Para diseños especiales o logos corporativos, solicita una cotización personalizada con al menos 2 semanas de anticipación." },
  { question: "¿Es mejor usar velas LED o velas reales en eventos?", answer: "Recomendamos velas LED por seguridad y practicidad. Nuestras velas LED de alta calidad replican el parpadeo natural de la llama con tecnología flickering, son indistinguibles a simple vista y eliminan riesgos de incendio, manchas de cera y restricciones de venues. Son ideales para centros de mesa, candelabros y caminos de velas. Además, muchos salones y haciendas en CDMX prohíben llama abierta por normativas de protección civil, por lo que las LED son la opción obligada en esos espacios." },
  { question: "¿Qué opciones de color tienen disponibles en iluminación decorativa?", answer: "Nuestra gama de colores es amplia. En fairy lights y guirnaldas: warm white (2700K), cool white (4000K), multicolor y ámbar vintage. En esferas y figuras LED: disponemos de 16 colores con control remoto RGB incluyendo blanco, azul, rojo, verde, morado y rosa, con opción de cambio automático o color fijo. Los candiles de cristal trabajan en warm white con dimmer regulable. Las letras y números usan LED cálido (2700K) fijo. Para eventos con temática de color específica, diseñamos combinaciones personalizadas." },
  { question: "¿Con cuánta anticipación debo reservar iluminación decorativa?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo para bodas). Las letras LOVE y los candiles de cristal grande son los artículos más solicitados y se agotan primero. Para paquetes decorativos completos que incluyan fairy lights de techo, candiles y letras luminosas, lo ideal es apartar con 1 mes de anticipación para asegurar disponibilidad. También atendemos solicitudes de último momento sujetas a inventario disponible." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación Decorativa para Eventos en CDMX",
    description: "Fairy lights, candiles de cristal, esferas LED y letras luminosas para bodas, XV años y eventos sociales. Instalación profesional incluida.",
    url: "/servicios/iluminacion/decorativa/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Iluminación Decorativa para Eventos en CDMX"
  description="Renta de fairy lights, candiles de cristal, esferas LED y letras luminosas para eventos en CDMX. Instalación profesional incluida. Desde $500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Ambientes mágicos con luz decorativa"
    title='Renta de <span class="highlight">Iluminación Decorativa</span> para Eventos en CDMX'
    subtitle="Fairy lights, candiles de cristal, esferas LED y letras luminosas que transforman cualquier espacio en un escenario inolvidable. Instalación profesional y diseño de iluminación incluidos."
    primaryCTA={{ label: "Cotiza tu iluminación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar iluminación decorativa para mi evento` }}
    cards={[
      {
        title: "Iluminación decorativa profesional para cada celebración",
        content: "<strong>Renta de iluminación decorativa para eventos</strong> con el catálogo más completo de CDMX. Fairy lights y guirnaldas en warm white y multicolor para crear canopys de techo, cortinas luminosas y envolventes de árboles en jardines y terrazas. Candiles de cristal cortado y candelabros vintage para salones de banquetes y haciendas. Esferas y figuras LED con cambio de color RGB para decoración moderna de centros de mesa y espacios lounge. Letras y números marquee luminosos personalizados para bodas, XV años y cumpleaños — cada pieza verificada y probada antes de cada instalación.",
      },
      {
        title: "Diseño de iluminación e instalación profesional",
        content: "<strong>Servicio completo de diseño e instalación</strong> incluido en cada renta de iluminación decorativa. Nuestro equipo de iluminación realiza una visita técnica a tu venue para diseñar la distribución ideal de luces según las dimensiones, altura de techo y estilo de tu evento. Instalación con cableado oculto, reguladores dimmer para ajustar intensidad, temporizadores automáticos y estructuras de soporte cuando se requieren. Montaje anticipado al evento y desmontaje incluido sin costo adicional dentro de CDMX.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres crear un ambiente mágico en tu evento?"
    subheadline="Cotiza sin compromiso y recibe una propuesta de diseño de iluminación decorativa personalizada para tu espacio"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de iluminación decorativa
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Iluminación Decorativa"
        subtitle="Luces que transforman espacios en experiencias memorables"
        description={[
          "Desde fairy lights para bodas íntimas en jardín hasta candiles de cristal para galas en salón y letras luminosas personalizadas. Contamos con el inventario de iluminación decorativa más variado de la Ciudad de México.",
          "Cada elemento incluye instalación profesional, cableado oculto, reguladores de intensidad y equipo técnico de montaje. Calidad, seguridad y estética garantizadas para que tu evento brille."
        ]}
      />

      <div class="grid grid--4">
        {DECORATIVA.map((item) => (
          <Card
            name={item.name}
            excerpt={item.excerpt}
            cta={item.cta}
            href={item.href}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FAIRY LIGHTS Y GUIRNALDAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="fairylights-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">El favorito para bodas</span>
          <h2 class="showcase__title" id="fairylights-heading">Fairy Lights y Guirnaldas</h2>
          <p class="showcase__subtitle">La forma más romántica y versátil de iluminar bodas, jardines, terrazas y recepciones al aire libre.</p>
          <p class="showcase__text">Nuestras <strong>fairy lights y guirnaldas</strong> están disponibles en tonos <strong>warm white (2700K) y multicolor</strong> con tecnología LED de bajo consumo y larga duración. Creamos <strong>canopys de techo</strong> que envuelven salones y carpas en un manto de estrellas, <strong>cortinas luminosas</strong> que transforman muros y ventanales en cascadas de luz, y <strong>tree wraps</strong> que visten árboles y columnas para jardines y terrazas. Cada instalación incluye cable transparente o cobrizo según el estilo de tu evento.</p>
          <p class="showcase__text">Disponemos de <strong>más de 5,000 metros de fairy lights</strong> para cubrir espacios desde 50 hasta 500 metros cuadrados. Las guirnaldas vintage con focos Edison son perfectas para ambientes rústicos y boho, mientras que las micro LED son ideales para decoraciones elegantes y minimalistas. Incluyen <strong>regulador dimmer y temporizador automático</strong> para control total de la ambientación. Combínalas con nuestras <a href="/servicios/carpas/">carpas árabes y estructurales</a> para crear techos luminosos espectaculares en eventos al aire libre.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Warm White</span>
            <span class="showcase__tag">Multicolor</span>
            <span class="showcase__tag">Canopy Techo</span>
            <span class="showcase__tag">Cortina Luces</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Fairy Lights
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CANDILES Y CANDELABROS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="candiles-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Elegancia clásica</span>
          <h2 class="showcase__title" id="candiles-heading">Candiles y Candelabros</h2>
          <p class="showcase__subtitle">Piezas de cristal cortado y diseños vintage que aportan sofisticación a salones, haciendas y eventos de gala.</p>
          <p class="showcase__text">Nuestros <strong>candiles de cristal</strong> están disponibles en modelos clásicos y contemporáneos con diámetros de <strong>60, 80, 100 y 120 centímetros</strong>. Los <strong>crystal chandeliers</strong> con cuentas de cristal cortado refractan la luz en miles de destellos, creando una atmósfera de elegancia incomparable para bodas de salón, cenas de gala y eventos corporativos premium. Los <strong>candelabros vintage de mesa</strong> en acabados dorado, plateado y bronce son el centro de mesa perfecto para recepciones formales.</p>
          <p class="showcase__text">Incluimos <strong>velas LED con tecnología flickering</strong> que replican el parpadeo natural de la llama sin riesgo de incendio ni restricciones de venue. Las <strong>hanging installations</strong> con múltiples candiles a diferentes alturas crean composiciones dramáticas sobre pistas de baile y mesas principales. Cada candil incluye <strong>sistema de suspensión certificado, dimmer regulable y cableado oculto</strong>. Complementa con nuestro <a href="/servicios/mobiliario/">mobiliario premium de salones lounge</a> para una ambientación de revista.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Cristal Cortado</span>
            <span class="showcase__tag">Candelabros Vintage</span>
            <span class="showcase__tag">Velas LED</span>
            <span class="showcase__tag">Instalación Aérea</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Candiles
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              <circle cx="12" cy="12" r="4"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ESFERAS Y FIGURAS LED — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="esferas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Decoración moderna</span>
          <h2 class="showcase__title" id="esferas-heading">Esferas y Figuras LED</h2>
          <p class="showcase__subtitle">Elementos luminosos contemporáneos que aportan color, geometría y un toque vanguardista a tu evento.</p>
          <p class="showcase__text">Nuestras <strong>esferas luminosas LED</strong> están disponibles en diámetros de <strong>20, 40, 60 y 80 centímetros</strong> con control remoto RGB de 16 colores. Son perfectas como decoración de jardín, piscina, caminos de acceso y zonas lounge. Las <strong>figuras geométricas iluminadas</strong> — cubos, prismas, cilindros y pirámides — crean composiciones arquitectónicas modernas para eventos corporativos, lanzamientos de producto y galas contemporáneas.</p>
          <p class="showcase__text">Ofrecemos también <strong>neon flex personalizado</strong> para crear siluetas, palabras y logos luminosos sobre muros y backdrops, y <strong>centros de mesa LED</strong> sumergibles y de superficie que cambian de color para ambientar recepciones y cenas. Todos los elementos son <strong>inalámbricos con batería recargable</strong> de 8 a 12 horas, eliminando cables visibles. Resistentes a salpicaduras (IP65) para uso en exteriores. Combínalos con nuestras <a href="/servicios/pistas-baile/">pistas de baile LED iluminadas</a> para una experiencia visual inmersiva.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Esferas RGB</span>
            <span class="showcase__tag">Figuras Geométricas</span>
            <span class="showcase__tag">Neon Flex</span>
            <span class="showcase__tag">Centros de Mesa LED</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Esferas LED
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="4"/>
              <line x1="12" y1="2" x2="12" y2="8"/>
              <line x1="12" y1="16" x2="12" y2="22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       LETRAS Y NÚMEROS LUMINOSOS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="letras-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Personalización total</span>
          <h2 class="showcase__title" id="letras-heading">Letras y Números Luminosos</h2>
          <p class="showcase__subtitle">Marquee letters personalizadas que se convierten en el centro de atención y el backdrop perfecto para fotos.</p>
          <p class="showcase__text">Nuestras <strong>letras marquee luminosas</strong> son el elemento decorativo más fotogénico para bodas y eventos sociales. Disponibles en <strong>todo el abecedario, números del 0 al 9 y símbolos especiales</strong> (& y corazones). Las combinaciones más populares incluyen <strong>LOVE, AMOR, iniciales de los novios</strong> (M&J, A+R) y <strong>números para XV años y edades de cumpleaños</strong>. Cada letra mide entre <strong>60 y 120 cm de altura</strong> con acabado en blanco mate y bombillas LED cálidas estilo vintage.</p>
          <p class="showcase__text">Fabricadas en estructura metálica resistente con <strong>iluminación LED warm white (2700K)</strong> de bajo consumo que no genera calor. Incluyen base estabilizadora para colocación en piso y opción de montaje en mesa principal o backdrop. Son el complemento perfecto para <strong>mesas de dulces, photocalls, recepción de invitados y pistas de baile</strong>. El montaje toma 30 minutos e incluye extensiones eléctricas ocultas. Combínalas con nuestros <a href="/servicios/accesorios/">accesorios de señalización y alfombras</a> para un recibimiento impactante.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">LOVE / AMOR</span>
            <span class="showcase__tag">Iniciales</span>
            <span class="showcase__tag">Números XV</span>
            <span class="showcase__tag">60-120 cm</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Letras Luminosas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 7 4 4 20 4 20 7"/>
              <line x1="9" y1="20" x2="15" y2="20"/>
              <line x1="12" y1="4" x2="12" y2="20"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Iluminación Decorativa"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu iluminación decorativa, es natural tener preguntas sobre tipos de luces, instalación, colores y logística. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas sobre iluminación decorativa al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de iluminación decorativa para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
