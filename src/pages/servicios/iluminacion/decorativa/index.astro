---
/**
 * ─── EVENTECH.MX — Renta de Iluminación Decorativa para Eventos (Hub L4, molde hm- 2026) ───
 * Fairy Lights · Candiles · Esferas LED · Letras Luminosas — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: los paquetes por metraje viven ahora en el hub L4 /servicios/iluminacion/guirnaldas/ (Fase 1, 2026-07-09).
 * Todas las L5 de decorativa son hoja → specs pills.
 * IMG: /images/iluminacion — guirnaldas-edison, neon-uv reales; iluminacion-evento genéricas.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const SUB_SERVICES = [
  {
    id: "fairy-lights",
    name: "Fairy Lights y Guirnaldas",
    badge: "Ambiente mágico",
    excerpt: "Cortinas de luces cálidas, canopy de techo, guirnaldas vintage Edison y tree wrap para crear ambientes mágicos en bodas, jardines y recepciones al aire libre.",
    href: "/servicios/iluminacion/decorativa/fairy-lights/",
    image: "/images/iluminacion/guirnaldas-edison-jardin-boda.avif",
    specs: ["Warm white", "Canopy de techo", "Edison vintage", "50–400 m"],
  },
  {
    id: "candiles",
    name: "Candiles y Candelabros",
    badge: "Elegancia clásica",
    excerpt: "Candiles de cristal cortado, candelabros vintage de mesa y velas LED para salones de banquetes, haciendas y eventos de gala con elegancia clásica.",
    href: "/servicios/iluminacion/decorativa/candiles/",
    image: "/images/iluminacion/iluminacion-evento-02.avif",
    specs: ["Cristal cortado", "Velas LED", "Dimmer", "Truss con motor"],
  },
  {
    id: "esferas-led",
    name: "Esferas y Figuras LED",
    badge: "Decoración moderna",
    excerpt: "Esferas luminosas de diferentes tamaños, figuras geométricas iluminadas, neon flex personalizado y centros de mesa LED para decoración moderna y fiestas.",
    href: "/servicios/iluminacion/decorativa/esferas-led/",
    image: "/images/iluminacion/luces-neon-uv-fiesta-glow.avif",
    specs: ["RGB 16 colores", "Inalámbrico", "IP65", "Neon flex"],
  },
  {
    id: "letras-luminosas",
    name: "Letras y Números Luminosos",
    badge: "El favorito de la foto",
    excerpt: "Letras marquee LOVE, iniciales personalizadas y números luminosos para XV años y cumpleaños. Altura de 60 a 120 cm con iluminación LED cálida.",
    href: "/servicios/iluminacion/decorativa/letras-luminosas/",
    image: "/images/iluminacion/iluminacion-evento-04.avif",
    specs: ["LOVE / AMOR", "Iniciales", "60–120 cm", "LED cálido"],
  },
  {
    id: "neon-vintage",
    name: "Neón y Vintage",
    badge: "Letreros a medida",
    excerpt: "Letreros de neón LED personalizados y luces vintage Edison. El nombre de los novios en neón o el ambiente cálido retro que llena de calidez jardines y terrazas.",
    href: "/servicios/iluminacion/decorativa/neon-vintage/",
    image: "/images/iluminacion/luces-neon-uv-fiesta-glow.avif",
    specs: ["Neón LED a medida", "Focos Edison", "Color cálido", "Personalizado"],
  },
  {
    id: "cascadas-led",
    name: "Cascadas y Cortinas LED",
    badge: "Fondos de luz",
    excerpt: "Cortinas de luces LED con efecto lluvia y meteoro para fondos de mesa de novios, arcos de ceremonia y backdrops de escenario. La pared de luz que hace fotogénico cualquier ángulo.",
    href: "/servicios/iluminacion/decorativa/cascadas-led/",
    image: "/images/guirnaldas/renta-guirnaldas-cortina-lluvia-luces.avif",
    specs: ["Cortina LED", "Efecto lluvia", "Blanco cálido/RGB", "Fondos y arcos"],
  },
];

const whyFeatures = [
  {
    title: "Diseño decorativo pensado para tu venue",
    body: "La luz decorativa mal colgada se ve improvisada. Hacemos visita técnica para definir dónde y cómo va cada elemento —el canopy de fairy lights en el techo, los candiles sobre la mesa principal, las letras en el punto de foto— según la arquitectura y el flujo de tu evento. No entregamos una caja de luces: entregamos un ambiente diseñado.",
  },
  {
    title: "Instalación segura de candiles y estructuras",
    body: "Un candil de cristal pesa de 15 a 40 kg y colgarlo mal es un riesgo real. Evaluamos el punto de anclaje de tu techo y, si no soporta, montamos truss portátil con motor eléctrico para colgarlo con seguridad en cualquier espacio. Cableado oculto, dimmer y prueba de carga incluidos — la elegancia no está peleada con la seguridad.",
  },
  {
    title: "Velas LED que cumplen con protección civil",
    body: "Muchos salones y haciendas de CDMX prohíben llama abierta por normativa. Nuestras velas LED con tecnología flickering replican el parpadeo real, son indistinguibles a simple vista y eliminan riesgo de incendio, cera y sanciones. La estética de las velas sin el problema de la llama — permitidas en cualquier venue.",
  },
  {
    title: "Versión correcta para interior o exterior",
    body: "Fairy lights de interior (IP44) para salones, carpas y techos, y de exterior (IP65) resistentes a lluvia y humedad para jardines y terrazas. Cable transparente para integrarse con la vegetación o dorado/cobrizo para el toque vintage. Elegimos la línea correcta según tu venue para que la luz aguante toda la noche sin fallar.",
  },
  {
    title: "Personalización de letras, iniciales y color",
    body: "Letras y números en todo el abecedario y del 0 al 9, iniciales de los novios, LOVE, AMOR y edades de XV años, en alturas de 60 a 120 cm. Esferas y figuras en 16 colores RGB con control remoto. Diseñamos combinaciones a la temática de tu evento — el detalle que se vuelve el fondo fotográfico de la noche.",
  },
  {
    title: "Integración con el diseño de luz completo",
    body: "La iluminación decorativa luce más cuando se coordina con la arquitectónica y la de escenario del mismo proveedor: el warm white de las fairy lights afinado con el ámbar del uplighting, sin choques de temperatura. Integramos todo el diseño de luz desde EVENTECH, con un solo criterio estético y una sola logística.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y diseño decorativo", p: "Visitamos tu venue sin costo para definir qué elementos van y dónde: canopy de fairy lights, candiles, esferas, letras y su punto de foto. Evaluamos anclajes, puntos de energía y la estética del espacio. En menos de 24 horas te enviamos propuesta con el diseño decorativo completo." },
  { n: 2, t: "Propuesta, personalización y aparto", p: "Definimos elementos, color, letras/iniciales personalizadas y metros de guirnalda. Con el 30% de anticipo apartamos el equipo y la fecha. Las letras y candiles de cristal grande son los más solicitados: conviene apartar con tiempo, sobre todo en temporada de bodas." },
  { n: 3, t: "Instalación y prueba", p: "Instalamos con anticipación: anclaje seguro de candiles (truss con motor si el techo no soporta), tendido de fairy lights, colocación de esferas y letras, cableado oculto y dimmer. Probamos cada elemento antes de abrir puertas para que todo encienda a la primera." },
  { n: 4, t: "Evento y desmontaje", p: "Durante el evento la decoración luminosa crea el ambiente sin que tengas que preocuparte por nada. Al finalizar, desmontamos y retiramos todo con cuidado (el cristal y las letras requieren manejo especial). El montaje y desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Las fairy lights funcionan tanto en interiores como en exteriores?", answer: "Sí. Contamos con dos líneas de fairy lights: interior (IP44) para salones, carpas y techos, y exterior (IP65) resistentes a lluvia y humedad para jardines, terrazas y patios. Ambas versiones están disponibles en tonos warm white, cool white y multicolor. Para exteriores recomendamos las de cable transparente que se integran con la vegetación, mientras que para interiores las de cable dorado o cobrizo aportan un toque vintage. Nuestro equipo técnico evalúa tu venue para seleccionar la versión adecuada." },
  { question: "¿Cuántos metros de guirnalda necesito para mi evento?", answer: "Depende de la superficie a cubrir y el efecto deseado. Manejamos guirnaldas en tramos de 50, 100, 200 y 400 metros. Como referencia: para un canopy de techo sobre pista de baile de 6x6 m se usan de 100 a 200 metros; para bordear el perímetro de un jardín mediano, de 200 a 400 metros; para tree wrap (envolver árboles) calculamos según la altura y cantidad de árboles. En la visita técnica medimos el espacio y te decimos los metros exactos y el patrón de instalación (canopy, cortina, perimetral o tree wrap)." },
  { question: "¿Qué se necesita para colgar un candil de cristal en mi venue?", answer: "Para instalar candiles de cristal necesitamos un punto de anclaje estructural en el techo capaz de soportar entre 15 y 40 kg según el modelo. Realizamos una visita técnica previa para evaluar la estructura de tu salón o carpa. Si el techo no tiene soporte suficiente, utilizamos estructuras de truss portátiles con motor eléctrico que permiten colgar candiles de forma segura en cualquier espacio. El montaje incluye cableado oculto, regulador de intensidad (dimmer) y pruebas de seguridad completas." },
  { question: "¿Puedo pedir letras o números personalizados?", answer: "Sí. Ofrecemos letras marquee en todo el abecedario, los números del 0 al 9, y símbolos como & y corazones. Las combinaciones más populares son LOVE, AMOR, los iniciales de los novios (M&J, A+R), y números para XV años, edades de cumpleaños y aniversarios. Están disponibles en alturas de 60, 90 y 120 cm con iluminación LED cálida integrada. Para diseños especiales o logos corporativos, solicita una cotización personalizada con al menos 2 semanas de anticipación." },
  { question: "¿Es mejor usar velas LED o velas reales en eventos?", answer: "Recomendamos velas LED por seguridad y practicidad. Nuestras velas LED de alta calidad replican el parpadeo natural de la llama con tecnología flickering, son indistinguibles a simple vista y eliminan riesgos de incendio, manchas de cera y restricciones de venues. Son ideales para centros de mesa, candelabros y caminos de velas. Además, muchos salones y haciendas en CDMX prohíben llama abierta por normativas de protección civil, por lo que las LED son la opción obligada en esos espacios." },
  { question: "¿Qué opciones de color tienen disponibles en iluminación decorativa?", answer: "Nuestra gama de colores es amplia. En fairy lights y guirnaldas: warm white (2700K), cool white (4000K), multicolor y ámbar vintage. En esferas y figuras LED: disponemos de 16 colores con control remoto RGB incluyendo blanco, azul, rojo, verde, morado y rosa, con opción de cambio automático o color fijo. Los candiles de cristal trabajan en warm white con dimmer regulable. Las letras y números usan LED cálido (2700K) fijo. Para eventos con temática de color específica, diseñamos combinaciones personalizadas." },
  { question: "¿Con cuánta anticipación debo reservar iluminación decorativa?", answer: "Recomendamos reservar con 2 a 4 semanas de anticipación, especialmente en temporada alta (noviembre a febrero y mayo para bodas). Las letras LOVE y los candiles de cristal grande son los artículos más solicitados y se agotan primero. Para paquetes decorativos completos que incluyan fairy lights de techo, candiles y letras luminosas, lo ideal es apartar con 1 mes de anticipación para asegurar disponibilidad. También atendemos solicitudes de último momento sujetas a inventario disponible." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación Decorativa para Eventos en CDMX",
    description: "Renta de fairy lights, candiles de cristal, esferas LED y letras luminosas para bodas, XV años y eventos sociales en CDMX. Instalación profesional incluida.",
    url: "/servicios/iluminacion/decorativa/",
    priceRange: { min: 500, max: 15000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Decorativa" },
];
---

<PageLayout
  title="Renta de Iluminación Decorativa para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/iluminacion/guirnaldas-edison-jardin-boda.avif"
  description="Renta de fairy lights, candiles de cristal, esferas LED y letras luminosas para bodas y XV años en CDMX. Instalación profesional incluida. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="deco-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Iluminación decorativa · CDMX y ZMVM</p>
            <h1 id="deco-hero-heading">
              Iluminación decorativa que da <em>calidez y magia</em> a bodas, XV años y jardines
            </h1>
            <p class="hm-hero__lead">
              Fairy lights y guirnaldas Edison, candiles de cristal, esferas y figuras LED, y
              letras luminosas personalizadas. Los detalles de luz que vuelven mágico cualquier
              evento — con diseño e instalación profesional incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20decorativa%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar iluminación
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>iluminación decorativa para eventos</strong> en CDMX:
              <strong>fairy lights y guirnaldas Edison</strong> en tramos de 50 a 400 metros para
              canopy y tree wrap, <strong>candiles de cristal</strong> con velas LED, <strong>esferas
              y figuras LED</strong> en 16 colores RGB, y <strong>letras y números luminosos</strong>
              personalizados. Cada elemento se coloca según un diseño decorativo hecho a partir de
              la visita técnica al venue.
            </p>
            <p>
              Con <strong>más de 500 eventos decorados</strong> en CDMX, sabemos que los detalles de
              luz son los que se vuelven el fondo fotográfico de la noche: por eso cada renta incluye
              diseño, instalación segura y velas LED que cumplen con protección civil. Complementa
              con <a href="/servicios/iluminacion/arquitectonica/">iluminación arquitectónica</a> y
              <a href="/servicios/carpas/carpas-arabes/">carpas</a> para un ambiente completamente
              diseñado desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de iluminación decorativa disponibles">
      <ul class="hm-menu__grid hm-menu--cols7">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20decorativa%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Detalles de luz que crean ambiente</p>
            <h2 id="catalogo-heading">¿Qué le falta de magia a tu evento?</h2>
            <p class="hm__head-sub">6 familias — del canopy de fairy lights al candil de cristal, el neón personalizado y la cascada de luz.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La iluminación decorativa es lo que se recuerda y lo que se fotografía: el techo
              cubierto de lucecitas cálidas sobre la pista, los candiles que dan elegancia a la mesa
              principal, las letras que se vuelven el punto de foto de todos los invitados. No
              alumbra el espacio — le da alma.
            </p>
            <p>
              Fairy lights para envolver el venue en calidez. Candiles para la elegancia clásica de
              una gala. Esferas y figuras para un toque moderno. Letras luminosas para el detalle que
              todos fotografían. Una sola empresa para toda la decoración de luz.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada familia, a fondo</p>
            <h2 id="detalle-heading">Las 6 familias decorativas — en detalle</h2>
            <p class="hm__head-sub">Estilo, tecnología, personalización y para qué tipo de evento funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada familia decorativa hay decisiones que afectan la estética y la
              seguridad: el tipo de luz que define la calidez del ambiente, el anclaje que garantiza
              que un candil cuelgue seguro, y la personalización que vuelve único el detalle.
            </p>
            <p>
              Conocer estas diferencias te permite decorar con luz y criterio, no solo colgar
              lucecitas. A continuación, lo que realmente importa de cada familia.
            </p>
          </div>
        </div>

        <!-- FAIRY LIGHTS -->
        <article class="hm-feat" aria-labelledby="feat-fairy-lights">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Fairy Lights y Guirnaldas</p>
            <h3 class="hm-feat__title" id="feat-fairy-lights">El techo de lucecitas cálidas que vuelve mágica cualquier boda de jardín</h3>
            <p class="hm-feat__lead">Ningún elemento transforma tanto un espacio por tan poco. Un canopy de fairy lights sobre la pista convierte un jardín en un cielo estrellado — es el efecto más fotografiado de las bodas.</p>
            <p>
              Cortinas de luces cálidas, <strong>canopy de techo</strong>, guirnaldas vintage
              <strong>Edison</strong> y <strong>tree wrap</strong> para envolver árboles. Disponibles
              en tramos de <strong>50, 100, 200 y 400 metros</strong>, en warm white, cool white y
              multicolor, con versión interior (IP44) y exterior (IP65).
            </p>
            <p>
              El recurso estrella de <strong>bodas, jardines y recepciones al aire libre</strong>.
              Cable transparente para integrarse con la vegetación o dorado para el toque vintage.
              Combínalas bajo nuestras <a href="/servicios/carpas/carpas-arabes/">carpas</a> para un
              cielo estrellado interior. Elige tus metros en
              <a href="/servicios/iluminacion/guirnaldas/">guirnaldas por longitud</a>.
            </p>
            <ul class="hm-feat__stats">
              {["Warm white", "Canopy / tree wrap", "Edison vintage", "50–400 m", "IP44 / IP65"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/iluminacion/decorativa/fairy-lights/">
              Ver Fairy Lights y Guirnaldas
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
