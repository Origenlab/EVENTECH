---
/**
 * ─── Fairy Lights y Guirnaldas — Página de Producto (Nivel 4) ───
 * Cortinas de luces, canopy de techo, guirnaldas Edison y tree wrap IP65.
 * Color accent: Amber #e17055 (nivel 4). Layout con sidebar de interlinking.
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Fairy Lights
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { label: "Fairy Lights" },
];

const faqs = [
  { question: "¿Cuántos metros de fairy lights necesito para cubrir el techo de mi salón?", answer: 'Depende del área total y la densidad de cobertura deseada. Como referencia: para un canopy de techo denso tipo cielo de estrellas necesitas aproximadamente 10 metros de micro LED por cada metro cuadrado de techo. Un salón de 200 m² requiere alrededor de 2,000 metros de fairy lights. Para un efecto más sutil y separado, basta con 5 metros por m². Nuestro equipo realiza una visita técnica gratuita donde mide tu espacio y calcula la cantidad exacta según el efecto que deseas. También tomamos en cuenta la altura del techo, el color de la superficie y los puntos de sujeción disponibles.' },
  { question: "¿Las fairy lights se pueden usar en exteriores con lluvia?", answer: 'Sí. Contamos con dos líneas: interior (IP44) para salones y carpas techadas, y exterior (IP65) certificadas para lluvia, humedad y rocío. Las IP65 tienen conectores waterproof sellados, cable de silicona resistente a UV y transformadores con protección contra cortocircuito. Las hemos usado en bodas de jardín bajo lluvia ligera sin ningún problema. Para lluvias fuertes el técnico puede desconectar preventivamente el circuito en segundos. Recomendamos las IP65 para cualquier evento donde exista posibilidad de intemperie — siempre es mejor prevenir.' },
  { question: "¿Puedo regular la intensidad de las fairy lights durante el evento?", answer: 'Absolutamente. Todas nuestras instalaciones de fairy lights incluyen regulador dimmer que permite ajustar la intensidad del 10% al 100%. Esto es clave para adaptar la ambientación a cada etapa de tu evento: intensidad baja y romántica durante la cena, brillo medio para el brindis y máximo impacto para la fiesta. Además, incluimos temporizador automático para encendido y apagado programado. En modelos multicolor también puedes seleccionar modos de cascada, fade suave y parpadeo tenue que crean efectos de movimiento sutil.' },
  { question: "¿Cuál es la diferencia entre fairy lights y guirnaldas Edison?", answer: 'Las fairy lights (micro LED) son hilos de luces diminutas que crean un efecto etéreo y delicado — ideales para canopys de techo, cortinas luminosas y envolventes de árboles donde buscas un manto de estrellas. Las guirnaldas Edison son cables con focos tipo vintage más grandes (estilo filamento) que emiten luz cálida visible individualmente — perfectas para ambientes rústicos, boho e industriales donde cada foco es un elemento decorativo. Ambas usan tecnología LED de bajo consumo. Puedes combinarlas: canopy de fairy lights en el techo + guirnaldas Edison en el perímetro exterior para un look romántico-vintage completo.' },
  { question: "¿El montaje del canopy de techo daña el salón o la carpa?", answer: 'No. Utilizamos sistemas de sujeción profesional sin perforaciones: cables de acero tensados entre puntos estructurales existentes (vigas, columnas, truss), ganchos magnéticos para techos metálicos, y clips de presión para estructuras de <a href="/servicios/carpas/">carpas</a>. En salones sin puntos de anclaje, montamos un sistema de cable perimetral con tensores que sostiene todo el canopy sin tocar el techo. El desmontaje es igual de limpio. Años de experiencia nos han enseñado a trabajar en cualquier tipo de venue — desde haciendas coloniales hasta salones modernos — sin dejar marcas.' },
  { question: "¿Se pueden combinar fairy lights con candiles u otra iluminación?", answer: 'Sí, y de hecho lo recomendamos. Las combinaciones más populares son: canopy de fairy lights en el techo + <a href="/servicios/iluminacion/decorativa/candiles/">candiles de cristal</a> colgantes sobre la pista de baile, fairy lights perimetrales + <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas LOVE</a> en la mesa de dulces, y guirnaldas Edison en el exterior + <a href="/servicios/iluminacion/decorativa/esferas-led/">esferas luminosas</a> en el jardín. Nuestro diseñador de iluminación crea un plano integral donde cada elemento se complementa en intensidad, temperatura de color y distribución.' },
];

const specs = [
  { label: "Tipo de LED", value: "Micro LED warm white / Edison vintage filamento" },
  { label: "Temperatura de color", value: "2700K (cálido) / 4000K (neutro) / Multicolor" },
  { label: "Longitud disponible", value: "Cortinas: 2-6m / Guirnaldas: 5-100m / Canopy: hasta 500m²" },
  { label: "Consumo", value: "3W-8W por metro (LED bajo consumo)" },
  { label: "Clasificación IP", value: "IP44 (interior) / IP65 (exterior)" },
  { label: "Alimentación", value: "120V con transformador incluido / Solar disponible" },
  { label: "Cable", value: "Transparente, cobrizo, dorado o negro" },
  { label: "Dimmer", value: "Regulador incluido (10%-100%) + temporizador" },
  { label: "Modos de luz", value: "Fijo, parpadeo suave, cascada, fade" },
  { label: "Cobertura", value: "Hasta 500m² de techo con canopy" },
];

const sidebarNav = [
  { name: "Fairy Lights y Guirnaldas", href: null, active: true },
  { name: "Candiles y Candelabros", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras y Números Luminosos", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
];

const sidebarRelated = [
  { name: "Wash Lights LED", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
  { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Mobiliario Premium", href: "/servicios/mobiliario/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Valentina Herrera", text: "El canopy de fairy lights en nuestra boda fue lo más mágico que he visto. Nos casamos en un jardín de Coyoacán y el techo de estrellas hizo que todos los invitados dijeran 'wow' al entrar. El equipo montó más de 3,000 metros de micro LED warm white y la regulación de intensidad durante la cena fue perfecta. Sin duda la mejor inversión de toda la boda.", rating: 5, date: "2025-12-01" },
  { author: "Gabriela Soto", text: "Rentamos guirnaldas Edison para los XV años de mi hija en una hacienda en Tlalpan. El estilo vintage fue exactamente lo que queríamos — cada foto se veía espectacular con la luz cálida de fondo. El técnico llegó 4 horas antes y dejó todo impecable, con cable dorado que combinaba perfectamente con la decoración rústica.", rating: 5, date: "2025-11-10" },
  { author: "Patricia Durán", text: "Usamos cortinas luminosas y tree wrap en nuestra cena navideña corporativa para 200 personas. Las cortinas detrás de la mesa principal crearon un backdrop increíble para las fotos y los árboles del jardín envueltos en fairy lights IP65 transformaron el espacio. Muy profesionales, puntuales y el resultado superó nuestras expectativas.", rating: 5, date: "2025-10-18" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Fairy Lights y Guirnaldas para Eventos en CDMX",
    description: "Fairy lights micro LED, cortinas de luces, canopy de techo y guirnaldas Edison vintage para bodas y eventos en CDMX. +5,000 metros de luces LED warm white. Instalación profesional incluida. Desde $800.",
    url: "/servicios/iluminacion/decorativa/fairy-lights/",
    priceRange: { min: 800, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Fairy Lights y Guirnaldas", url: "/servicios/iluminacion/decorativa/fairy-lights/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Fairy Lights y Guirnaldas en CDMX"
  description="Renta de fairy lights, cortinas de luces, canopy de techo y guirnaldas Edison para bodas y eventos en CDMX. +5,000 metros de luces LED warm white. Instalación profesional. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Lo más solicitado para bodas en CDMX"
    title='Renta de <span class="highlight">Fairy Lights y Guirnaldas</span> para Bodas y Eventos'
    subtitle="Cortinas de luces cálidas, canopy de techo tipo cielo de estrellas y guirnaldas Edison vintage. Más de 5,000 metros de LED disponibles con instalación profesional, dimmer regulable y técnico dedicado."
    primaryCTA={{ label: "Cotiza tus fairy lights", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar fairy lights y guirnaldas para mi evento` }}
    cards={[
      {
        title: "Más de 5,000 metros de fairy lights para cualquier espacio",
        content: "<strong>Renta de fairy lights y guirnaldas LED para eventos</strong> con el inventario más grande de la Ciudad de México. Micro LED warm white (2700K) y multicolor para crear canopys de techo que envuelven salones y carpas en un manto de estrellas, cortinas luminosas que transforman muros en cascadas de luz, y tree wraps que visten árboles y columnas para jardines y terrazas. Cable transparente, cobrizo, dorado o negro según tu estilo. Modelos IP44 para interior e IP65 certificados para lluvia y exteriores.",
      },
      {
        title: "Guirnaldas Edison vintage y regulación total de intensidad",
        content: "<strong>Guirnaldas con focos Edison LED</strong> de filamento visible en cable negro o dorado para ambientes rústicos, boho e industriales — cada foco es un punto de luz decorativo con personalidad. Todas las instalaciones incluyen regulador dimmer (10%-100%) para adaptar la intensidad a cada momento del evento, temporizador automático de encendido/apagado y modos de cascada, fade y parpadeo suave. Montaje profesional con cableado oculto y desmontaje incluido sin costo.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Sueñas con un techo de estrellas para tu boda?"
    subheadline="Cotiza sin compromiso — te enviamos una propuesta con diseño de canopy personalizado para tu venue"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       PAQUETES DE GUIRNALDAS EDISON
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="paquetes-heading">
    <div class="container">
      <SectionHeader
        id="paquetes-heading"
        title="Paquetes de Guirnaldas Edison"
        subtitle="Elige el metraje ideal para tu evento"
        description={[
          "3 paquetes con focos LED Edison vintage de filamento visible, sockets cada 50 cm y cable negro industrial. Desde eventos íntimos de 50 personas hasta festivales de 500+. Todos incluyen dimmer, montaje profesional y desmontaje.",
          "Cada paquete es encadenable — puedes combinar dos o más para cubrir espacios más amplios."
        ]}
      />
      <div class="grid grid--4">
        <Card
          name="Guirnaldas 50 Metros"
          excerpt="~100 focos Edison LED vintage con sockets cada 50 cm. Ideal para mesas de banquete, patios y terrazas íntimas de 50-80 personas. Montaje en 1-2 horas."
          cta="Ver Paquete 50m"
          href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-50m/"
          image="/images/guirnaldas/renta-guirnaldas-edison-50m-hero.avif"
        />
        <Card
          name="Guirnaldas 100 Metros"
          excerpt="~200 focos Edison LED vintage — el más popular para bodas de 100-200 personas. Cobertura de ~100 m² con banquete, pista y coctel. Montaje en 2-3 horas."
          cta="Ver Paquete 100m"
          href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-100m/"
          image="/images/guirnaldas/renta-guirnaldas-edison-100m-hero.avif"
        />
        <Card
          name="Guirnaldas 200 Metros"
          excerpt="~400 focos Edison LED vintage para eventos grandes de 200+ personas, haciendas, festivales y ferias. Cobertura de ~200 m². Equipo de 2-3 técnicos."
          cta="Ver Paquete 200m"
          href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-200m/"
          image="/images/guirnaldas/renta-guirnaldas-edison-200m-hero.avif"
        />
        <Card
          name="Guirnaldas 400 Metros"
          excerpt="~800 focos Edison LED vintage para eventos masivos de 500+ personas, festivales multi-día y haciendas completas. Cobertura de ~400 m². Equipo de 3-4 técnicos."
          cta="Ver Paquete 400m"
          href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-400m/"
          image="/images/guirnaldas/renta-guirnaldas-edison-400m-hero.avif"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Iluminación Decorativa</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas fairy lights para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar fairy lights y guirnaldas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Fairy Lights y Guirnaldas</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Canopy de Techo -->
          <section class="section section--alt" aria-labelledby="canopy-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Lo más solicitado para bodas</span>
                <h2 class="showcase__title" id="canopy-heading">Canopy de Techo (Cielo de Estrellas)</h2>
                <p class="showcase__subtitle">Miles de micro LED warm white cubriendo el techo completo de tu salón o carpa para recrear un firmamento romántico.</p>
                <p class="showcase__text">El <strong>canopy de techo con fairy lights</strong> es el servicio de iluminación decorativa más solicitado para bodas en la Ciudad de México. Consiste en una red densa de micro LED warm white (2700K) instalada a lo largo de todo el techo, creando un efecto de <strong>cielo estrellado</strong> que envuelve a los invitados en una atmósfera mágica e íntima. Cada punto de luz brilla como una pequeña estrella, generando una profundidad visual que transforma por completo cualquier espacio — desde salones de hotel hasta haciendas coloniales.</p>
                <p class="showcase__text">Cubrimos techos de <strong>hasta 500 m²</strong> con más de 5,000 metros de micro LED. Utilizamos cables de acero tensado entre vigas o columnas como soporte, sin perforaciones ni daño a la estructura. El resultado es un <strong>manto uniforme sin cables visibles</strong>, solo puntos de luz flotantes. Incluye dimmer para regular la intensidad — brillo suave durante la cena, máximo impacto en la fiesta. Combinación perfecta con nuestras <a href="/servicios/carpas/">carpas árabes y estructurales</a> para eventos al aire libre donde el canopy se convierte en el protagonista del espacio.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cielo de estrellas</span>
                  <span class="showcase__tag">Hasta 500m²</span>
                  <span class="showcase__tag">Warm white 2700K</span>
                  <span class="showcase__tag">Dimmer incluido</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Canopy de Techo
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Renta de guirnaldas canopy de techo para bodas en CDMX" width="1200" height="686" loading="lazy" />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Cortinas Luminosas -->
          <section class="section section--alt" aria-labelledby="cortinas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Transformación instantánea</span>
                <h2 class="showcase__title" id="cortinas-heading">Cortinas Luminosas (Light Curtains)</h2>
                <p class="showcase__subtitle">Cascadas verticales de luz que convierten muros, ventanales y backdrops en lienzos luminosos espectaculares.</p>
                <p class="showcase__text">Las <strong>cortinas luminosas</strong> son paneles verticales de fairy lights que caen desde el techo hasta el piso, creando cascadas de luz que transforman cualquier superficie plana en un backdrop fotogénico. Disponibles en anchos de <strong>2 a 6 metros y alturas de 2 a 4 metros</strong>, son ideales para decorar muros detrás de la mesa principal, ventanales de salón, separadores de espacio en recepciones amplias y backdrops de photocall para invitados.</p>
                <p class="showcase__text">Cada cortina utiliza <strong>micro LED en cable transparente</strong> prácticamente invisible durante el día, que al encenderse genera un efecto de lluvia de luz cálida. Disponibles en modo fijo, cascada (encendido secuencial de arriba a abajo) y parpadeo suave. Combinan espectacularmente con <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas LOVE o iniciales</a> colocadas delante de la cortina para un contraste dramático que se convierte en la foto más compartida de tu evento. Incluyen ganchos de sujeción y extensiones ocultas.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Light curtains</span>
                  <span class="showcase__tag">2-6m de ancho</span>
                  <span class="showcase__tag">Efecto cascada</span>
                  <span class="showcase__tag">Backdrop perfecto</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Cortinas Luminosas
                </a>
              </div>
              <div class="showcase__image">
