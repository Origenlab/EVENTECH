---
/**
 * ─── Guirnaldas Edison 50 Metros — Página de Paquete (Nivel 5) ───
 * Paquete de 50m con ~100 focos LED Edison, sockets cada 0.5m, cable negro.
 * Color accent: Amber #e17055 (nivel 4/5). Layout con sidebar de interlinking.
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Fairy Lights > Guirnaldas 50m
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { label: "Fairy Lights", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { label: "Guirnaldas 50m" },
];

const faqs = [
  { question: "¿Para cuántas personas alcanza el paquete de 50 metros de guirnaldas Edison?", answer: 'El paquete de 50 metros es ideal para eventos íntimos de <strong>50 a 80 personas</strong>. Cubre perfectamente una línea de mesas de banquete de hasta 25 metros en zigzag, un patio o terraza de aproximadamente 50 m², o el perímetro de un área de recepción pequeña. Si tu evento es más grande, puedes combinar este paquete con nuestro <a href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-100m/">paquete de 100 metros</a> para cubrir más área, ya que las guirnaldas son interconectables entre sí.' },
  { question: "¿Puedo combinar el paquete de 50m con otros tramos de guirnaldas?", answer: 'Sí, nuestras guirnaldas Edison son 100% interconectables gracias a su sistema plug & play. Puedes combinar el paquete de 50 metros con cualquier otro paquete — por ejemplo, 50m + 100m para cubrir 150 metros totales, o dos paquetes de 50m para 100 metros. Solo necesitas verificar que la instalación eléctrica soporte el consumo total (cada 50 metros consume ~200W). Nuestro técnico realiza esta verificación durante el montaje y distribuye los circuitos de forma segura.' },
  { question: "¿Las guirnaldas Edison de 50 metros funcionan en exteriores?", answer: 'Sí. Todas nuestras guirnaldas Edison incluyen versiones IP44 (interior y exterior techado) e IP65 (exterior a la intemperie, resistentes a lluvia). Para eventos en jardines, terrazas abiertas o patios sin techo, instalamos la versión IP65 con conectores waterproof sellados. El cable negro industrial calibre 16 AWG es resistente a UV y humedad. Para eventos con probabilidad de lluvia, recomendamos siempre la versión IP65 — mejor prevenir.' },
  { question: "¿Cuánto tiempo toma el montaje de 50 metros de guirnaldas?", answer: 'El montaje profesional de 50 metros de guirnaldas Edison toma entre <strong>1 y 2 horas</strong>, dependiendo de la complejidad del espacio. Esto incluye la instalación de puntos de anclaje (ganchos, cables de acero, tensores), tendido de las guirnaldas en el patrón acordado (zigzag, paralelas o perímetro), conexión eléctrica con dimmer y prueba completa del sistema. Nuestro técnico llega al venue con anticipación suficiente para que todo esté listo antes de que lleguen los invitados.' },
  { question: "¿El desmontaje tiene costo adicional?", answer: 'No. El desmontaje está incluido en el precio de la renta, sin costos ocultos. Nuestro equipo regresa al venue después del evento (o al día siguiente si el evento termina tarde) para retirar todas las guirnaldas, ganchos y cableado. Dejamos el espacio exactamente como estaba antes del montaje, sin marcas ni residuos. El desmontaje de 50 metros toma aproximadamente 45 minutos a 1 hora.' },
  { question: "¿Incluyen dimmer para regular la intensidad de los focos Edison?", answer: 'Sí, todas nuestras instalaciones de guirnaldas Edison incluyen <strong>regulador dimmer profesional</strong> que permite ajustar la intensidad del 10% al 100%. Esto es fundamental para crear diferentes ambientes: luz tenue y romántica durante la cena, brillo medio para el brindis y máxima intensidad para la fiesta. También incluimos temporizador automático para encendido y apagado programado, y extensiones ocultas para una instalación limpia sin cables visibles.' },
];

const specs = [
  { label: "Longitud total", value: "50 metros" },
  { label: "Número de focos", value: "~100 focos LED Edison" },
  { label: "Separación entre sockets", value: "50 cm" },
  { label: "Tipo de foco", value: "LED Edison vintage filamento 2W" },
  { label: "Temperatura de color", value: "2700K (warm white)" },
  { label: "Cable", value: "Negro industrial, calibre 16 AWG" },
  { label: "Conexión", value: "Plug & play, encadenable" },
  { label: "Consumo total", value: "~200W" },
  { label: "Clasificación IP", value: "IP44 interior / IP65 disponible" },
  { label: "Incluye", value: "Dimmer, extensiones, ganchos de sujeción" },
];

const sidebarNav = [
  { name: "Guirnaldas 50m (100 focos)", href: null, active: true },
  { name: "Guirnaldas 100m (200 focos)", href: "/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-100m/" },
  { name: "Guirnaldas 200m (400 focos)", href: "/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-200m/" },
  { name: "Guirnaldas 400m (800 focos)", href: "/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-400m/" },
];

const sidebarRelated = [
  { name: "Candiles y Candelabros", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras Luminosas", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Wash Lights LED", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
  { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
];

const reviews = [
  { author: "Andrea Villalobos", text: "Rentamos el paquete de 50 metros de guirnaldas Edison para nuestra cena íntima en un patio de Coyoacán. El efecto fue mágico — cada foto salió espectacular con la luz cálida de fondo. El técnico llegó 3 horas antes y dejó todo perfecto. Las guirnaldas en zigzag sobre las mesas crearon el ambiente romántico exacto que queríamos.", rating: 5, date: "2025-11-20" },
  { author: "Roberto Méndez", text: "Usamos 50 metros de Edison para una terraza corporativa de 60 personas. La instalación fue rápida (menos de 2 horas), el dimmer nos permitió bajar la intensidad durante la presentación y subirla para el coctel. Muy profesionales, el cable negro industrial se veía elegante y los focos no fallaron ni uno en toda la noche.", rating: 5, date: "2025-10-05" },
  { author: "Mariana Torres", text: "Para los XV de mi hija queríamos algo diferente y las guirnaldas Edison fueron la elección perfecta. Con 50 metros cubrimos toda la terraza del jardín y el resultado fue precioso. El equipo de Eventech fue muy atento, nos asesoraron sobre la mejor distribución y el desmontaje fue impecable al día siguiente.", rating: 5, date: "2025-09-15" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Guirnaldas Edison 50 Metros para Eventos en CDMX",
    description: "Renta de guirnaldas Edison de 50 metros con 100 focos LED vintage, sockets cada 50cm, cable negro. Ideal para mesas de banquete, patios y terrazas íntimas. Instalación incluida en CDMX.",
    url: "/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-50m/",
    priceRange: { min: 1500, max: 3500 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Fairy Lights", url: "/servicios/iluminacion/decorativa/fairy-lights/" },
    { name: "Guirnaldas 50m", url: "/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-50m/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Guirnaldas Edison 50m — 100 Focos LED CDMX"
  description="Renta de guirnaldas Edison de 50 metros con 100 focos LED vintage, sockets cada 50cm, cable negro. Ideal para mesas de banquete, patios y terrazas íntimas. Instalación incluida en CDMX. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Paquete para eventos íntimos"
    title='Renta de <span class="highlight">Guirnaldas Edison 50 Metros</span> — 100 Focos LED'
    subtitle="Paquete de 50 metros de guirnaldas con ~100 focos LED Edison vintage, sockets cada 50 cm y cable negro industrial. Ideal para mesas de banquete, patios y terrazas íntimas de 50 a 80 personas. Dimmer incluido."
    primaryCTA={{ label: "Cotiza el paquete 50m", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar el paquete de guirnaldas Edison de 50 metros` }}
    cards={[
      {
        title: "100 focos Edison LED con luz cálida vintage de 2700K",
        content: "<strong>Paquete de 50 metros de guirnaldas Edison LED</strong> con aproximadamente 100 focos de filamento visible estilo vintage distribuidos cada 50 centímetros en cable negro industrial calibre 16 AWG. Cada foco emite una luz cálida de 2700K (warm white) que recrea la estética de las bombillas clásicas con tecnología LED de bajo consumo (2W por foco). Sistema plug & play encadenable con otros paquetes para cubrir distancias mayores. Clasificación IP44 para interior e IP65 disponible para exterior.",
      },
      {
        title: "Instalación profesional con dimmer y montaje incluido",
        content: "<strong>Montaje profesional en 1-2 horas</strong> con técnico especializado que instala puntos de anclaje, tiende las guirnaldas en el patrón acordado (zigzag, paralelas o perímetro) y conecta el sistema eléctrico con dimmer regulable del 10% al 100%. Incluye extensiones ocultas, ganchos de sujeción, temporizador automático y desmontaje sin costo. Consumo total de solo ~200W — equivalente a dos focos domésticos. Ideal para eventos donde se busca un ambiente cálido e íntimo sin gran despliegue técnico.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Buscas iluminación cálida para tu evento íntimo?"
    subheadline="Cotiza el paquete de 50 metros sin compromiso — ideal para cenas, terrazas y patios de hasta 80 personas"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Paquetes Guirnaldas Edison</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas guirnaldas Edison para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el paquete de guirnaldas Edison de 50 metros`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Guirnaldas Edison 50m</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Mesas de Banquete y Terrazas -->
          <section class="section section--alt" aria-labelledby="mesas-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Ideal para cenas íntimas</span>
                <h2 class="showcase__title" id="mesas-heading">Mesas de Banquete y Terrazas</h2>
                <p class="showcase__subtitle">50 metros de guirnaldas Edison en zigzag sobre mesas de banquete crean el ambiente perfecto para cenas de 50 a 80 personas.</p>
                <p class="showcase__text">El <strong>paquete de 50 metros de guirnaldas Edison</strong> es la opción ideal para vestir mesas de banquete en bodas íntimas y cenas elegantes. Con 100 focos LED distribuidos cada 50 cm, cubrimos hasta 25 metros lineales de mesa en patrón zigzag — suficiente para una mesa imperial larga o 4-5 mesas redondas. Cada foco Edison emite una <strong>luz cálida de 2700K</strong> que baña a los comensales en un resplandor dorado que favorece las conversaciones y la fotografía.</p>
                <p class="showcase__text">La instalación en terrazas y patios es nuestra especialidad. Montamos las guirnaldas entre postes, árboles, columnas o pérgolas existentes, usando cable de acero tensado como soporte invisible. El resultado es un <strong>techo de focos flotantes</strong> que transforma cualquier espacio exterior en un comedor al aire libre de revista. Combinación perfecta con nuestras <a href="/servicios/mobiliario/mesas/">mesas de banquete</a> para un montaje integral.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">50-80 personas</span>
                  <span class="showcase__tag">Zigzag sobre mesas</span>
                  <span class="showcase__tag">Patios y terrazas</span>
                  <span class="showcase__tag">Bodas íntimas</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar para Mesas de Banquete
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/guirnaldas/guirnaldas-edison-50-metros-mesa-banquete.avif" alt="Guirnaldas Edison 50 metros sobre mesa de banquete y terraza" width="1200" height="686" loading="lazy" />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Patios y Jardines Pequeños -->
          <section class="section section--alt" aria-labelledby="patios-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Cobertura de ~50 m²</span>
                <h2 class="showcase__title" id="patios-heading">Patios y Jardines Pequeños</h2>
                <p class="showcase__subtitle">Zigzag entre postes y árboles para cubrir hasta 50 m² de patio o jardín con luz cálida Edison.</p>
                <p class="showcase__text">Para <strong>patios y jardines de hasta 50 m²</strong>, el paquete de 50 metros ofrece una cobertura generosa. Instalamos las guirnaldas Edison en zigzag entre puntos de anclaje (postes, árboles, muros), creando un patrón de líneas cruzadas que distribuye la luz de manera uniforme sobre todo el espacio. Con focos cada 50 cm, la densidad lumínica es perfecta para crear un ambiente acogedor sin zonas oscuras.</p>
                <p class="showcase__text">Si tu espacio es más amplio, puedes escalar al <a href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-100m/">paquete de 100 metros</a> que cubre hasta 100 m². Nuestras guirnaldas son interconectables, así que también puedes combinar dos paquetes de 50m si ya tienes uno reservado. El técnico evalúa tu jardín y diseña la distribución óptima durante una visita gratuita previa al evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Hasta 50 m²</span>
                  <span class="showcase__tag">Zigzag entre postes</span>
                  <span class="showcase__tag">Jardines pequeños</span>
                  <span class="showcase__tag">Combinable</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar para Patios y Jardines
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/guirnaldas/renta-guirnaldas-50m-patio-terraza.avif" alt="Renta guirnaldas Edison 50m para patio y terraza" width="1200" height="686" loading="lazy" />
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Montaje Profesional y Personalización -->
          <section class="section section--alt" aria-labelledby="montaje-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Instalación en 1-2 horas</span>
                <h2 class="showcase__title" id="montaje-heading">Montaje Profesional y Personalización</h2>
                <p class="showcase__subtitle">Técnico especializado, dimmer regulable, sistema encadenable y desmontaje incluido sin costo.</p>
                <p class="showcase__text">El <strong>montaje profesional del paquete de 50 metros</strong> toma entre 1 y 2 horas e incluye todo lo necesario: instalación de puntos de anclaje con ganchos y cables de acero, tendido de las guirnaldas en el patrón personalizado para tu espacio, conexión eléctrica segura y configuración del <strong>dimmer regulable</strong> (10%-100%). Nuestro técnico llega con anticipación al venue para tener todo listo antes de los invitados.</p>
                <p class="showcase__text">El sistema es <strong>plug & play y encadenable</strong> — puedes conectar este paquete de 50m con nuestro <a href="/servicios/iluminacion/decorativa/fairy-lights/guirnaldas-200m/">paquete de 200 metros</a> si decides ampliar la cobertura para una zona adicional. El consumo de solo ~200W permite conectar a cualquier toma doméstica estándar. El desmontaje está incluido sin costo y se realiza después del evento dejando el espacio impecable.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Montaje 1-2h</span>
                  <span class="showcase__tag">Dimmer incluido</span>
                  <span class="showcase__tag">Plug & play</span>
                  <span class="showcase__tag">Desmontaje gratis</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Montaje Profesional
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/guirnaldas/guirnaldas-edison-50m-montaje-profesional.avif" alt="Montaje profesional de guirnaldas Edison 50 metros" width="1200" height="686" loading="lazy" />
              </div>
            </div>
          </section>

          <!-- GALERÍA: Guirnaldas Edison 50 Metros -->
          <section class="section" aria-labelledby="galeria-heading">
            <div class="container">
              <h2 class="section-header__title" id="galeria-heading">Galería — Guirnaldas Edison 50 Metros</h2>
              <p class="section-header__description">Proyectos reales de guirnaldas Edison de 50 metros: bodas íntimas, patios, terrazas y jardines en CDMX.</p>
              <div class="galeria-grid">
                <img src="/images/guirnaldas/renta-guirnaldas-edison-50m-hero.avif" alt="Renta guirnaldas Edison 50 metros para eventos" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/renta-guirnaldas-edison-50m-boda-intima.avif" alt="Guirnaldas Edison 50m boda íntima" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/guirnaldas-50-metros-jardin-pequeno.avif" alt="Guirnaldas 50 metros jardín pequeño" width="600" height="343" loading="lazy" />
