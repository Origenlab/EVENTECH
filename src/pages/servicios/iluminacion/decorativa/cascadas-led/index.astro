---
/**
 * ─── Cascadas y Cortinas LED — Página de Producto (Nivel 4) ───
 * Telones y cortinas de luz LED con efecto meteoro, lluvia y twinkle para eventos.
 * Color accent amber #c2a24a (jerarquía L4).
 *
 * Jerarquía: Servicios > Iluminación > Decorativa > Cascadas y Cortinas LED
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";
import ReservaFormScript from "@components/ReservaFormScript.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { label: "Cascadas LED" },
];

const faqs = [
  { question: "¿Qué es una cascada o cortina de luces LED?", answer: 'Una <strong>cortina de luces LED</strong> (también llamada telón o cascada LED) es un panel de hilos de luces verticales que se cuelga como fondo. Cada hilo lleva pequeños LED que pueden encenderse de forma estática o con efectos animados de <strong>meteoro, lluvia (waterfall) y twinkle</strong>, simulando gotas de luz que caen. Se usa como fondo de escenario, detrás de la mesa de novios, en arcos de ceremonia o para vestir muros completos, y está disponible en blanco cálido, blanco frío y RGB multicolor.' },
  { question: "¿Qué medidas de cortina LED tienen disponibles?", answer: 'Manejamos módulos de <strong>2×1 m, 3×3 m y 3×6 m</strong>, y los unimos para cubrir superficies más grandes — hasta 6 metros de altura por módulo apilados en truss. Como el sistema es modular, diseñamos el fondo a la medida exacta de tu escenario, presídium o muro. Si nos compartes las dimensiones del espacio y una foto, te proponemos la combinación de cortinas ideal y su costo.' },
  { question: "¿Hacen el efecto lluvia o meteoro?", answer: 'Sí. Las cortinas RGB y las de tira blanca cuentan con <strong>efecto meteoro y lluvia (waterfall)</strong>, en el que la luz cae de arriba hacia abajo de forma continua, además de <strong>twinkle</strong> (destello aleatorio tipo estrellas) y modo estático fijo. Los efectos se activan por control remoto RF o por DMX512, lo que permite cambiarlos en vivo y sincronizarlos con la música o los momentos clave del evento.' },
  { question: "¿Sirve como fondo para la mesa de novios?", answer: 'Es uno de sus usos más solicitados. Una cortina LED en <strong>blanco cálido con efecto twinkle</strong> detrás de la mesa de novios crea un fondo de luz suave y romántico que se ve espectacular en fotos y video. Con una sola cortina de 3×3 m cubrimos el ancho típico de un presídium de novios; para mesas imperiales largas unimos dos o más módulos. La combinamos con frecuencia con <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights</a> en el techo para completar el ambiente.' },
  { question: "¿Se pueden instalar en interior y exterior?", answer: 'Sí, en ambos. Para <strong>interiores</strong> el montaje es directo sobre truss, estructura o barra soporte. Para <strong>exteriores</strong> usamos módulos con protección adecuada y aseguramos la estructura contra viento; en jardines y terrazas recomendamos protegerlas bajo carpa o techo cuando hay pronóstico de lluvia. La alimentación es de <strong>bajo voltaje (12/24V)</strong>, segura al tacto incluso cerca de los invitados. Siempre incluimos instalación y operación por nuestro equipo técnico.' },
  { question: "¿Puedo combinarlas con guirnaldas o wash lights?", answer: 'Totalmente, y es lo más recomendable para un diseño de iluminación con profundidad. Las cortinas LED funcionan como fondo, mientras que las <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights</a> y <a href="/servicios/iluminacion/guirnaldas/">guirnaldas</a> aportan luz cálida en techos y perímetros, los <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights</a> bañan de color muros y estructuras, y los <a href="/servicios/iluminacion/decorativa/neon-vintage/">letreros de neón y piezas vintage</a> suman un acento moderno. Diseñamos el conjunto completo y lo operamos desde una sola coordinación para que todas las capas de luz trabajen juntas.' },
];

const specs = [
  { label: "Tipo", value: "Cortina y telón LED (rain / meteor curtain)" },
  { label: "Dimensiones (alto × ancho)", value: "2×1 m, 3×3 m y 3×6 m — modulares a medida" },
  { label: "Efectos", value: "Meteoro, lluvia (waterfall), twinkle y estático" },
  { label: "Color de luz", value: "Blanco cálido, blanco frío y RGB multicolor" },
  { label: "Control", value: "Remoto RF + DMX512 (modelos RGB)" },
  { label: "Montaje", value: "Truss, estructura o barra soporte" },
  { label: "Altura máxima", value: "Hasta 6 m por módulo (apilable en truss)" },
  { label: "Uso", value: "Interior y exterior (con protección adecuada)" },
  { label: "Alimentación", value: "Bajo voltaje 12/24V — seguro al tacto" },
  { label: "Instalación", value: "Montaje, operación y desmontaje incluidos" },
];

const sidebarNav = [
  { name: "Fairy Lights (micro LED)", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Candiles de Cristal", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras y Letreros", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Neón y Vintage", href: "/servicios/iluminacion/decorativa/neon-vintage/" },
  { name: "Cascadas LED", href: null, active: true },
];

const sidebarRelated = [
  { name: "Iluminación Decorativa", href: "/servicios/iluminacion/decorativa/" },
  { name: "Fairy Lights", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Wash Lights", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Mobiliario", href: "/servicios/mobiliario/" },
];

const reviews = [
  { author: "Mariana Rentería", text: "Rentamos una cortina LED en blanco cálido como fondo de la mesa de novios para nuestra boda en un salón de la Condesa. El efecto twinkle se veía increíble en todas las fotos y fue el detalle que más nos comentaron los invitados. La instalaron temprano, la dejaron probada y el desmontaje fue igual de rápido. Servicio impecable.", rating: 5, date: "2025-11-05" },
  { author: "Diego Salcedo", text: "Contratamos dos cortinas LED RGB como backdrop del escenario para el evento anual de la empresa. Poder cambiar el color y activar el efecto meteoro durante las presentaciones le dio un nivel de producción que no esperábamos. El equipo coordinó todo con nuestro proveedor de audio sin ningún problema. Muy recomendables.", rating: 5, date: "2025-10-08" },
  { author: "Paulina Guerrero", text: "Para los XV de mi hija cubrimos tres muros del salón con cortinas de luces y quedó de ensueño — parecía otro lugar. Nos ayudaron a elegir las medidas según el espacio y combinaron blanco cálido en la pista con RGB en la zona de fotos. Puntuales y muy profesionales en el montaje.", rating: 5, date: "2025-09-14" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Cascadas y Cortinas LED para Eventos en CDMX",
    description: "Renta de cascadas y cortinas de luces LED para bodas y eventos en CDMX. Efectos meteoro, lluvia y twinkle en blanco cálido y RGB. Fondos de escenario, arcos de ceremonia y mesa de novios. Instalación, operación y desmontaje incluidos. Desde $2,000.",
    url: "/servicios/iluminacion/decorativa/cascadas-led/",
    priceRange: { min: 2000, max: 25000 },
    reviews,
    ratingValue: 5,
    reviewCount: 26,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Decorativa", url: "/servicios/iluminacion/decorativa/" },
    { name: "Cascadas LED", url: "/servicios/iluminacion/decorativa/cascadas-led/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Cascadas y Cortinas LED para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de cascadas y cortinas de luces LED para bodas y eventos en CDMX: fondos de escenario, arcos de ceremonia y mesa de novios. Instalación incluida. Cotiza hoy."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="El fondo luminoso que enamora"
    title='Renta de <span class="highlight">Cascadas y Cortinas LED</span> en CDMX'
    subtitle="Telones y cortinas de luz LED con efecto meteoro, lluvia y twinkle en blanco cálido y RGB. Fondos de escenario, arcos de ceremonia y mesa de novios con instalación, operación y desmontaje incluidos para bodas, XV años y eventos corporativos."
    primaryCTA={{ label: "Cotiza tus cortinas LED", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar cascadas y cortinas LED para mi evento` }}
    cards={[
      {
        title: "Cortinas y cascadas de luz que redefinen cualquier fondo",
        content: "<strong>Renta de cascadas y cortinas de luces LED</strong> para bodas y eventos en la Ciudad de México. Telones luminosos con efecto meteoro, lluvia (waterfall) y twinkle en blanco cálido, blanco frío y RGB multicolor, en módulos de 2, 3 y 6 metros que se combinan a la medida de tu escenario. Ideales como fondo de mesa de novios, arco de ceremonia, backdrop de escenario y cobertura completa de muros.",
      },
      {
        title: "Diseño, instalación y operación incluidos",
        content: "<strong>Servicio integral</strong> en cada renta de cortinas LED. Montamos sobre truss, estructura o barra soporte con rigging seguro, operamos los efectos por control remoto RF o DMX512 y desmontamos al finalizar. Alimentación de bajo voltaje (12/24V) segura al tacto, apta para interior y exterior. Entregamos el montaje listo y probado antes de que llegue el primer invitado.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Necesitas un fondo de luz espectacular para tu próximo evento?"
    subheadline="Cotiza sin compromiso — te enviamos una propuesta con diseño de fondo luminoso y medidas a la medida de tu escenario"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px, entre CTA y specs
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <!-- Nav card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Iluminación Decorativa</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <!-- Related card -->
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas cortinas LED para tu evento?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar cascadas y cortinas LED para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Cascadas y Cortinas LED</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: 1 Cortina -->
          <section class="section" aria-labelledby="una-cortina-heading">
            <ServiceShowcase
              title="1 Cortina"
              headingId="una-cortina-heading"
              badge="Mesa de novios o arco"
              subtitle="Una cortina LED para el punto focal: el fondo perfecto detrás de la mesa de novios o el arco de la ceremonia."
              tags={["1 telón LED", "2×1 a 3×3 m", "Blanco cálido", "Efecto twinkle"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar 1 Cortina LED"
            >
              <Fragment slot="body">
                <p class="showcase__text">Una sola <strong>cortina de luces LED</strong> es suficiente para transformar el punto más fotografiado de tu evento. La instalamos como fondo detrás de la mesa de novios o enmarcando el arco de la ceremonia, con efecto twinkle o estático en blanco cálido para un ambiente romántico y elegante. Las medidas de 2×1 m y 3×3 m se adaptan a la mayoría de los presídiums y altares.</p>
                <p class="showcase__text">Es la opción ideal para bodas íntimas, pedidas de mano y sesiones de fotos. Para reforzar el ambiente puedes sumar <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights</a> y <a href="/servicios/iluminacion/guirnaldas/">guirnaldas</a> en el techo o las paredes cercanas, creando capas de luz cálida que envuelven el espacio. Incluye montaje, operación y desmontaje por nuestro equipo técnico.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Cortina de luces LED como fondo de mesa de novios en boda" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-guirnaldas-cortina-lluvia-luces.avif" alt="Cortina de luces LED con efecto lluvia detrás de la mesa de novios" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-fairy-lights-canopy-techo.avif" alt="Cortina de fairy lights para arco de ceremonia" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: 2 Cortinas -->
          <section class="section" aria-labelledby="dos-cortinas-heading">
            <ServiceShowcase
              title="2 Cortinas"
              headingId="dos-cortinas-heading"
              badge="Fondo completo de escenario"
              subtitle="Dos cortinas LED que cubren todo el ancho del escenario: un backdrop luminoso continuo de gran impacto."
              tags={["2 telones LED", "Hasta 6 m de ancho", "RGB multicolor", "Efecto meteoro"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar 2 Cortinas LED"
            >
              <Fragment slot="body">
                <p class="showcase__text">Con <strong>dos cortinas LED</strong> unidas cubrimos el ancho completo de un escenario o presídium, generando un backdrop luminoso continuo de hasta 6 metros. En versión RGB puedes cambiar el color según cada momento — cálido para la ceremonia, multicolor para la fiesta — y activar el efecto meteoro o lluvia que da sensación de movimiento descendente.</p>
                <p class="showcase__text">Es la configuración favorita para escenarios de banda en vivo, booth de DJ y templetes de discursos corporativos. El control por DMX512 permite sincronizar los cambios de color con el resto de la iluminación del evento. Combínalas con <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights</a> para bañar de color los muros laterales y ampliar el fondo luminoso.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/guirnaldas/renta-guirnaldas-cortina-lluvia-luces.avif" alt="Dos cortinas de luces LED formando el fondo completo del escenario" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Cortina de luces LED como backdrop de escenario en evento" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/iluminacion/iluminacion-evento-03.avif" alt="Fondo de escenario iluminado con cortinas LED" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: 4 Cortinas — Cobertura de Salón -->
          <section class="section" aria-labelledby="cuatro-cortinas-heading">
            <ServiceShowcase
              title="4 Cortinas — Cobertura de Salón"
              headingId="cuatro-cortinas-heading"
              badge="Muros y backdrops"
              subtitle="Cuatro o más cortinas LED para vestir muros completos, esquinas y varios backdrops del salón."
              tags={["4+ telones LED", "Cobertura de muros", "Sistema modular", "Blanco + RGB"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar Cobertura de Salón"
            >
              <Fragment slot="body">
                <p class="showcase__text">A partir de <strong>cuatro cortinas LED</strong> vestimos muros completos, esquinas y varios puntos del salón al mismo tiempo, envolviendo a tus invitados en un ambiente inmersivo de luz. El sistema es modular: apilamos y unimos telones para cubrir superficies grandes o irregulares, con altura de hasta 6 metros por módulo.</p>
                <p class="showcase__text">Perfecto para XV años, bodas de gran formato y activaciones de marca donde el salón entero es el escenario. Alternamos blanco cálido y RGB por zonas para diferenciar la pista, el lounge y la zona de fotos. Para un acento más moderno puedes integrar <a href="/servicios/iluminacion/decorativa/neon-vintage/">letreros de neón y piezas vintage</a> sobre las cortinas.</p>
              </Fragment>
              <Fragment slot="media">
                <div class="showcase__gallery3">
                  <div class="showcase__gallery3-main"><img src="/images/guirnaldas/renta-fairy-lights-canopy-techo.avif" alt="Cortinas de luces LED cubriendo muros y techo del salón" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-guirnaldas-cortina-lluvia-luces.avif" alt="Cortina de luces LED con efecto lluvia sobre un muro del salón" loading="lazy" decoding="async" /></div>
                  <div class="showcase__gallery3-thumb"><img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Backdrop de cortinas LED en cobertura completa de salón" loading="lazy" decoding="async" /></div>
                </div>
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- 7. SHOWCASE: Producción -->
          <section class="section" aria-labelledby="produccion-heading">
            <ServiceShowcase
              title="Producción"
              headingId="produccion-heading"
