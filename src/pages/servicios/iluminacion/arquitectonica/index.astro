---
/**
 * ─── EVENTECH.MX — Renta de Iluminación Arquitectónica para Eventos (Hub L4, molde hm- 2026) ───
 * Wash Lights · Uplighting · Bañadores · Fachadas — CDMX y ZMVM
 * Homologado al molde de sillas/index.astro (sistema hm-, dorado institucional).
 * NOTA: las L5 son hojas (sin L6) → los specs se muestran como pills no enlazadas.
 * IMG: /images/iluminacion-arquitectonica — fotos reales específicas por tipo.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const IMG = "/images/iluminacion-arquitectonica";

const SUB_SERVICES = [
  {
    id: "wash-lights",
    name: "Wash Lights LED",
    badge: "El más versátil",
    excerpt: "Luminarias RGBWA de alta potencia para baños de color uniformes en techos, muros y escenarios. Control DMX con mezcla de color infinita y temperatura de 2700K a 6500K.",
    href: "/servicios/iluminacion/arquitectonica/wash-lights/",
    image: `${IMG}/wash-lights-led-truss-escenario-colores.avif`,
    specs: ["RGBWA", "DMX512", "2700K–6500K", "Interior / exterior"],
  },
  {
    id: "uplighting",
    name: "Uplighting Perimetral",
    badge: "Favorito de bodas",
    excerpt: "Barras LED perimetrales que transforman cualquier salón, jardín o terraza con color ambiental. Paletas personalizadas, wireless DMX y cambio de escenas programado.",
    href: "/servicios/iluminacion/arquitectonica/uplighting/",
    image: `${IMG}/uplighting-led-salon-boda-elegante.avif`,
    specs: ["Wireless DMX", "Batería 10 h", "IP65", "Escenas programadas"],
  },
  {
    id: "banadores",
    name: "Bañadores de Muros",
    badge: "Texturas y pixel",
    excerpt: "Wall washers lineales y puntuales para resaltar texturas, columnas y superficies arquitectónicas. Efectos de degradado, pixel mapping y control individualizado.",
    href: "/servicios/iluminacion/arquitectonica/banadores/",
    image: `${IMG}/banadores-led-pixel-mapping-columnas.avif`,
    specs: ["Pixel mapping", "Lineal / puntual", "Gradient", "Gobos"],
  },
  {
    id: "fachadas",
    name: "Iluminación de Fachadas",
    badge: "Exterior IP65",
    excerpt: "Luminarias IP65 de exterior para iluminar edificios, monumentos y fachadas con color y gobos proyectados. Alto brillo, resistencia a intemperie y montaje seguro.",
    href: "/servicios/iluminacion/arquitectonica/fachadas/",
    image: `${IMG}/iluminacion-fachada-iglesia-boda.avif`,
    specs: ["IP65 outdoor", "10,000+ lm", "Gobos", "Flood / spot"],
  },
  {
    id: "city-color",
    name: "City Color",
    badge: "Color de fachada",
    excerpt: "Cañones de color de alta potencia que bañan fachadas, haciendas y grandes superficies con RGB saturado. Iluminación arquitectónica que se ve desde la calle.",
    href: "/servicios/iluminacion/arquitectonica/city-color/",
    image: `${IMG}/fachada-flood-rgbw-edificio-moderno.avif`,
    specs: ["250–1,500W", "RGB saturado", "IP65 exterior", "Gran alcance"],
  },
  {
    id: "city-light",
    name: "City Light",
    badge: "Ambientación de salón",
    excerpt: "Paquetes de PAR LED (8, 16, 24) para ambientar el salón completo con el color de tu paleta. La capa de color que envuelve todo el venue, con modo silencioso para ceremonias.",
    href: "/servicios/iluminacion/arquitectonica/city-light/",
    image: `${IMG}/uplighting-rgbwa-boda-salon-dorado.avif`,
    specs: ["PAR LED RGBWA", "8/16/24", "Color a tu paleta", "Modo silencioso"],
  },
];

const whyFeatures = [
  {
    title: "Diseñador de iluminación y plano personalizado",
    body: "La luz bien hecha se diseña, no se improvisa. Un diseñador hace visita técnica gratuita para medir el espacio, la altura de techos, el color de muros y los puntos de energía, y entrega un plano de iluminación con la cantidad exacta de luminarias y su ubicación. No cotizamos un número al azar: partimos del diseño de tu venue.",
  },
  {
    title: "Control DMX y técnico operador dedicado",
    body: "Cada renta incluye consola DMX profesional, cableado, programación de escenas y un técnico que opera la luz todo el evento. Las transiciones de color se programan según tu timeline —ceremonia cálida, cena neutra, fiesta con color— y se ejecutan en tiempo real. La luz cambia con el momento, no se queda estática toda la noche.",
  },
  {
    title: "Inventario propio RGBWA e IP65 calibrado",
    body: "Luminarias propias RGBWA de alta potencia y equipo IP65 de exterior en bodega CDMX. Cada unidad se revisa y calibra en color antes de salir para que todas den exactamente el mismo tono —nada peor que 12 wash lights con 12 blancos distintos. Lo que cotizamos es lo que existe, verificado antes de cada entrega.",
  },
  {
    title: "Wireless DMX y batería para jardines",
    body: "Uplighting con wireless DMX y batería de hasta 10 horas para instalar donde el cableado no llega: jardines, terrazas, haciendas y venues sin infraestructura. Sin cables cruzando el salón, sin extensiones a la vista — solo la luz, colocada exactamente donde el diseño la pide.",
  },
  {
    title: "Escenas por momento del evento",
    body: "Programamos paletas y escenas distintas para cada etapa: entrada, ceremonia, cóctel, cena, primer baile y fiesta. La luz acompaña la emoción del momento con transiciones suaves —del ámbar romántico de la cena al color pleno de la pista— sin que nadie tenga que tocar un control.",
  },
  {
    title: "Integración con audio, pantallas y escenario",
    body: "La iluminación arquitectónica luce más cuando se coordina con el sonido, las pantallas y la luz de escenario del mismo proveedor. Integramos todo desde EVENTECH con un solo diseño, un solo equipo técnico y una sola logística — para que color, imagen y audio cuenten la misma historia.",
  },
];

const steps = [
  { n: 1, t: "Visita técnica y plano de luz", p: "Un diseñador visita tu venue sin costo para medir el espacio, evaluar altura de techos, color de muros y puntos de energía. Con eso entregamos un plano de iluminación con la cantidad de luminarias, su ubicación y la paleta de color propuesta para tu evento." },
  { n: 2, t: "Propuesta, escenas y aparto", p: "Definimos tipo de luminarias (wash, uplighting, bañadores, fachada), paleta de color y escenas por momento del evento. Con el 30% de anticipo apartamos el equipo y la fecha. Coordinamos con tu wedding planner o el venue para el acceso y la energía." },
  { n: 3, t: "Montaje, programación y prueba", p: "Instalamos con anticipación: colocación de luminarias, cableado o wireless DMX, y programación de escenas según tu timeline. Hacemos prueba completa de color y transiciones antes de abrir puertas, para que la luz esté afinada desde el primer invitado." },
  { n: 4, t: "Operación en vivo y desmontaje", p: "El técnico opera la iluminación durante todo el evento, ejecutando las transiciones de escena en tiempo real. Al cierre, desmontamos y retiramos todo el equipo. El montaje, la operación y el desmontaje están incluidos sin costo adicional dentro de CDMX." },
];

const faqs = [
  { question: "¿Cuántos wash lights necesito para mi venue?", answer: "Depende del tamaño del espacio y el efecto deseado. Como referencia general: para un salón de hasta 200 m² recomendamos 8 a 12 wash lights, para espacios de 200 a 500 m² entre 12 y 20 unidades, y para venues grandes de 500+ m² desde 20 luminarias en adelante. Nuestro diseñador de iluminación realiza una visita técnica gratuita para evaluar tu espacio, considerar la altura de techos, color de muros y puntos de energía, y entregarte un plano de iluminación personalizado con la cantidad exacta." },
  { question: "¿Qué temperatura de color recomiendan para mi evento?", answer: "La elección depende del ambiente que quieras crear. Para bodas y eventos elegantes, recomendamos temperatura cálida de 2700K a 3000K que genera un ambiente íntimo y romántico. Para eventos corporativos y presentaciones, una temperatura neutra de 4000K a 4500K ofrece claridad profesional. Para fiestas y celebraciones dinámicas, la mezcla RGBWA permite cambiar colores durante el evento. Nuestros wash lights cubren todo el rango de 2700K a 6500K y se ajustan en tiempo real según la etapa de tu evento: ceremonia cálida, cena neutra y fiesta con color." },
  { question: "¿Pueden proyectar nuestro logo o monograma con gobos?", answer: "Sí. Fabricamos gobos personalizados con tu monograma, logo, nombres o la fecha del evento para proyectarlos sobre muros, pista de baile, techo o fachada. Ofrecemos gobos en acero (un color) y en cristal a todo color para diseños complejos. Para bodas, el monograma de los novios proyectado en la pista es uno de los detalles más solicitados. Requiere el archivo del diseño con 2 semanas de anticipación para fabricación y prueba." },
  { question: "¿El control DMX viene incluido en la renta?", answer: "Sí. Todos nuestros paquetes de iluminación arquitectónica incluyen consola DMX profesional, cableado DMX completo, programación de escenas personalizadas y un técnico operador dedicado durante todo el evento. El técnico programa previamente las transiciones de color según tu timeline (ceremonia, cena, brindis, fiesta) y las ejecuta en tiempo real. También incluimos la opción de wireless DMX para instalaciones donde el cableado no es viable, como jardines y terrazas." },
  { question: "¿La iluminación de exterior resiste lluvia y viento?", answer: "Nuestras luminarias de exterior cuentan con certificación IP65, lo que significa protección total contra polvo y chorros de agua desde cualquier dirección. Soportan lluvia moderada, humedad alta y temperaturas de 0°C a 45°C. Para condiciones de viento fuerte, utilizamos bases lastradas y clamps de seguridad que garantizan estabilidad. Sin embargo, en caso de tormenta eléctrica severa, por seguridad desconectamos el equipo temporalmente. Cada luminaria exterior incluye cable de seguridad adicional y conexiones waterproof." },
  { question: "¿Qué requerimientos de energía eléctrica necesita la iluminación arquitectónica?", answer: "Nuestros wash lights LED son de bajo consumo comparados con la iluminación convencional. Cada luminaria consume entre 80W y 200W dependiendo del modelo. Un paquete estándar de 12 wash lights requiere aproximadamente un circuito de 20 amperes a 120V. Para instalaciones grandes de 20+ luminarias, necesitamos 2 a 3 circuitos independientes. Nuestro técnico evalúa la capacidad eléctrica de tu venue antes del evento y, si es necesario, incluimos distribuidores de energía con protección térmica. También ofrecemos plantas de energía para venues sin infraestructura eléctrica suficiente." },
  { question: "¿Con cuánta anticipación debo reservar iluminación arquitectónica?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación para garantizar disponibilidad de equipo y tiempo suficiente para la visita técnica, diseño del plano de iluminación y programación de escenas. En temporada alta (noviembre a febrero y mayo), lo ideal es apartar con 2 meses de anticipación. Para eventos con diseño de iluminación complejo que incluya fachadas, mapping o instalaciones especiales, sugerimos contactarnos con al menos 2 meses. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación Arquitectónica para Eventos en CDMX",
    description: "Renta de wash lights LED, uplighting perimetral, bañadores de muros e iluminación de fachadas con control DMX en CDMX. Diseñador de luz y técnico incluidos.",
    url: "/servicios/iluminacion/arquitectonica/",
    priceRange: { min: 800, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Arquitectónica", url: "/servicios/iluminacion/arquitectonica/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Arquitectónica" },
];
---

<PageLayout
  title="Renta de Iluminación Arquitectónica para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/iluminacion-arquitectonica/hero-iluminacion-arquitectonica-eventos.avif"
  description="Renta de wash lights LED, uplighting, bañadores de muros e iluminación de fachadas con control DMX en CDMX. Diseñador y técnico incluidos. Cotiza hoy."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO ─────────────────────────────────────────────────── -->
    <section class="hm-hero" aria-labelledby="arqui-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Iluminación arquitectónica · CDMX y ZMVM</p>
            <h1 id="arqui-hero-heading">
              Iluminación que transforma <em>un salón vacío en un ambiente diseñado</em>
            </h1>
            <p class="hm-hero__lead">
              Wash lights RGBWA, uplighting perimetral, bañadores de muros y luminarias de
              fachada con control DMX profesional. Transforma cualquier espacio con color,
              textura y profundidad — con diseñador de luz y técnico operador incluidos.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20arquitect%C3%B3nica%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar iluminación
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver catálogo completo
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              EVENTECH renta <strong>iluminación arquitectónica para eventos</strong> en CDMX con
              inventario propio calibrado: <strong>wash lights RGBWA</strong> con temperatura de
              2700K a 6500K, <strong>uplighting perimetral</strong> con wireless DMX y batería,
              <strong>bañadores de muros</strong> con pixel mapping, y <strong>luminarias de
              fachada IP65</strong> con gobos proyectados. Cada instalación parte de un plano de
              iluminación diseñado a partir de la visita técnica al venue.
            </p>
            <p>
              Con <strong>más de 500 eventos iluminados</strong> en CDMX, sabemos que la luz es lo
              que hace que un salón se sienta diseñado y no solo alumbrado: por eso cada renta
              incluye diseñador de iluminación, control DMX y técnico operador que ejecuta las
              escenas por momento del evento. Para producción completa integramos
              <a href="/servicios/iluminacion/escenario/">iluminación de escenario</a>,
              <a href="/servicios/audiovisual/sonido/">sonido</a> y
              <a href="/servicios/audiovisual/pantallas-led/">pantallas</a> desde una sola empresa.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS ──────────────────────────────────────── -->
    <nav class="hm-menu" aria-label="Tipos de iluminación arquitectónica disponibles">
      <ul class="hm-menu__grid hm-menu--cols7">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20arquitect%C3%B3nica%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO ──────────────────────────────────────────────── -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Diseño de luz para cada espacio</p>
            <h2 id="catalogo-heading">¿Qué necesita iluminar tu evento?</h2>
            <p class="hm__head-sub">6 técnicas — del baño de color ambiental a la fachada proyectada, con control DMX y diseñador incluido.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La iluminación es lo que convierte un salón blanco en un ambiente con carácter, y
              lo que define el tono emocional de cada momento del evento. No se trata solo de
              alumbrar: se trata de color, textura, profundidad y transiciones que acompañan la
              ceremonia, la cena y la fiesta.
            </p>
            <p>
              Wash lights para baños de color uniformes. Uplighting para transformar el perímetro.
              Bañadores para resaltar muros y columnas. Fachadas para proyectar sobre el exterior.
              Una sola empresa para todo el diseño de luz de tu evento.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-feat__stats hm-cat__specs">
                  {s.specs.map((sp) => (<li>{sp}</li>))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DETALLE ────────────────────────────────────────── -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada técnica, a fondo</p>
            <h2 id="detalle-heading">Las 6 técnicas de iluminación — en detalle</h2>
            <p class="hm__head-sub">Tecnología, control, alcance y para qué tipo de espacio funciona mejor cada una.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada técnica hay decisiones de diseño que afectan el ambiente: el tipo de
              luminaria que decide la calidad y uniformidad del color, el control que define si la
              luz cambia con el evento, y la ubicación que marca si el efecto resalta o desentona.
            </p>
            <p>
              Conocer estas diferencias te permite diseñar la luz con criterio y no solo encender
              focos de colores. A continuación, lo que realmente importa de cada técnica.
            </p>
          </div>
        </div>

        <!-- WASH LIGHTS -->
        <article class="hm-feat" aria-labelledby="feat-wash-lights">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Wash Lights LED</p>
            <h3 class="hm-feat__title" id="feat-wash-lights">Baños de color uniformes que visten techos, muros y escenarios</h3>
            <p class="hm-feat__lead">La herramienta base del diseño de luz. Un wash light bien calibrado inunda una superficie de color parejo, sin manchas ni puntos calientes — la diferencia entre "luz de colores" y un ambiente diseñado.</p>
            <p>
              Luminarias <strong>RGBWA de alta potencia</strong> con mezcla de color infinita y
              temperatura de <strong>2700K a 6500K</strong>, controladas por <strong>DMX512</strong>.
              Bañan techos, muros y escenarios con color uniforme, desde el ámbar cálido de una
              cena hasta el color pleno de la pista, ajustable en tiempo real.
            </p>
            <p>
              Ideales para <strong>bodas, galas, eventos corporativos y escenarios</strong>, en
              interior y exterior. Cada unidad se calibra en color antes de salir para que todas
              den exactamente el mismo tono. Combínalos con nuestro
              <a href="/servicios/iluminacion/escenario/">equipo de escenario</a> para producciones
              completas.
            </p>
            <ul class="hm-feat__stats">
              {["RGBWA", "DMX512", "2700K–6500K", "Color uniforme", "Interior / exterior"].map((sp) => (<li>{sp}</li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/iluminacion/arquitectonica/wash-lights/">
              Ver Wash Lights LED
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src={`${IMG}/wash-lights-led-truss-escenario-colores.avif`} alt="Wash lights LED en truss de escenario proyectando colores en CDMX" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src={`${IMG}/wash-light-rgbwa-uv-alta-potencia.avif`} alt="Wash light RGBWA UV de alta potencia para evento" loading="lazy" decoding="async" />
