              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Festival / Concierto">Festival / Concierto</option>
                <option value="Feria / Expo">Feria / Expo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="tipoArquitectonica">
                Tipo de iluminación
              </label>
              <select id="tipoArquitectonica" name="tipoArquitectonica" class="form-field__input form-field__select">
                <option value="">Selecciona el tipo de iluminación</option>
                <option value="Wash Lights RGBWA">Wash Lights RGBWA</option>
                <option value="Uplighting Perimetral Interior">Uplighting Perimetral Interior</option>
                <option value="Uplighting Exterior IP65">Uplighting Exterior IP65</option>
                <option value="Bañadores de Muros">Bañadores de Muros</option>
                <option value="Iluminación Fachada">Iluminación Fachada</option>
                <option value="Par LED RGBWA">Par LED RGBWA</option>
                <option value="Barras LED Motorizadas">Barras LED Motorizadas</option>
                <option value="Paquete Boda">Paquete Boda</option>
                <option value="Paquete Corporativo">Paquete Corporativo</option>
                <option value="Paquete Completo">Paquete Completo</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: número de invitados, tipo de venue (salón/jardín/terraza), colores deseados, dimensiones del espacio..."
