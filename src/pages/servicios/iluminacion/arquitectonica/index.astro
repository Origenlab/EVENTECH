---
/**
 * ─── Iluminación Arquitectónica para Eventos — Sub-subcategoría (Nivel 3) ───
 * Página especializada: Renta de Iluminación Arquitectónica para Eventos en CDMX.
 * Color accent: Indigo #6c5ce7 (diferencia visual del nivel 2 teal).
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';

const ARQUITECTONICA = [
  {
    name: "Wash Lights LED",
    excerpt: "Luminarias RGBWA de alta potencia para baños de color uniformes en techos, muros y escenarios. Control DMX con mezcla de color infinita y temperatura de 2700K a 6500K.",
    cta: "Wash Lights",
    href: "#wash-heading",
    icon: "lightbulb",
  },
  {
    name: "Uplighting Perimetral",
    excerpt: "Barras LED perimetrales que transforman cualquier salón, jardín o terraza con color ambiental. Paletas personalizadas, wireless DMX y cambio de escenas programado.",
    cta: "Uplighting",
    href: "#uplighting-heading",
    icon: "layers",
  },
  {
    name: "Bañadores de Muros",
    excerpt: "Wall washers lineales y puntuales para resaltar texturas, columnas y superficies arquitectónicas. Efectos de degradado, pixel mapping y control individualizado.",
    cta: "Bañadores",
    href: "#banadores-heading",
    icon: "package",
  },
  {
    name: "Iluminación de Fachadas",
    excerpt: "Luminarias IP65 de exterior para iluminar edificios, monumentos y fachadas con color y gobos proyectados. Alto brillo, resistencia a intemperie y montaje seguro.",
    cta: "Fachadas",
    href: "#fachadas-heading",
    icon: "award",
  },
];

const faqs = [
  { question: "¿Cuántos wash lights necesito para mi venue?", answer: "Depende del tamaño del espacio y el efecto deseado. Como referencia general: para un salón de hasta 200 m² recomendamos 8 a 12 wash lights, para espacios de 200 a 500 m² entre 12 y 20 unidades, y para venues grandes de 500+ m² desde 20 luminarias en adelante. Nuestro diseñador de iluminación realiza una visita técnica gratuita para evaluar tu espacio, considerar la altura de techos, color de muros y puntos de energía, y entregarte un plano de iluminación personalizado con la cantidad exacta." },
  { question: "¿Qué temperatura de color recomiendan para mi evento?", answer: "La elección depende del ambiente que quieras crear. Para bodas y eventos elegantes, recomendamos temperatura cálida de 2700K a 3000K que genera un ambiente íntimo y romántico. Para eventos corporativos y presentaciones, una temperatura neutra de 4000K a 4500K ofrece claridad profesional. Para fiestas y celebraciones dinámicas, la mezcla RGBWA permite cambiar colores durante el evento. Nuestros wash lights cubren todo el rango de 2700K a 6500K y se ajustan en tiempo real según la etapa de tu evento: ceremonia cálida, cena neutra y fiesta con color." },
  { question: "¿El control DMX viene incluido en la renta?", answer: "Sí. Todos nuestros paquetes de iluminación arquitectónica incluyen consola DMX profesional, cableado DMX completo, programación de escenas personalizadas y un técnico operador dedicado durante todo el evento. El técnico programa previamente las transiciones de color según tu timeline (ceremonia, cena, brindis, fiesta) y las ejecuta en tiempo real. También incluimos la opción de wireless DMX para instalaciones donde el cableado no es viable, como jardines y terrazas." },
  { question: "¿La iluminación de exterior resiste lluvia y viento?", answer: "Nuestras luminarias de exterior cuentan con certificación IP65, lo que significa protección total contra polvo y chorros de agua desde cualquier dirección. Soportan lluvia moderada, humedad alta y temperaturas de 0°C a 45°C. Para condiciones de viento fuerte, utilizamos bases lastradas y clamps de seguridad que garantizan estabilidad. Sin embargo, en caso de tormenta eléctrica severa, por seguridad desconectamos el equipo temporalmente. Cada luminaria exterior incluye cable de seguridad adicional y conexiones waterproof." },
  { question: "¿Qué requerimientos de energía eléctrica necesita la iluminación arquitectónica?", answer: "Nuestros wash lights LED son de bajo consumo comparados con la iluminación convencional. Cada luminaria consume entre 80W y 200W dependiendo del modelo. Un paquete estándar de 12 wash lights requiere aproximadamente un circuito de 20 amperes a 120V. Para instalaciones grandes de 20+ luminarias, necesitamos 2 a 3 circuitos independientes. Nuestro técnico evalúa la capacidad eléctrica de tu venue antes del evento y, si es necesario, incluimos distribuidores de energía con protección térmica. También ofrecemos plantas de energía para venues sin infraestructura eléctrica suficiente." },
  { question: "¿Con cuánta anticipación debo reservar iluminación arquitectónica?", answer: "Recomendamos reservar con 3 a 6 semanas de anticipación para garantizar disponibilidad de equipo y tiempo suficiente para la visita técnica, diseño del plano de iluminación y programación de escenas. En temporada alta (noviembre a febrero y mayo), lo ideal es apartar con 2 meses de anticipación. Para eventos con diseño de iluminación complejo que incluya fachadas, mapping o instalaciones especiales, sugerimos contactarnos con al menos 2 meses. También atendemos solicitudes de última hora sujetas a disponibilidad de inventario." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación Arquitectónica para Eventos en CDMX",
    description: "Wash lights LED, uplighting perimetral, bañadores de muros e iluminación de fachadas para bodas, eventos corporativos y celebraciones. Técnico DMX incluido.",
    url: "/servicios/iluminacion/arquitectonica/",
    priceRange: { min: 800, max: 20000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Arquitectónica", url: "/servicios/iluminacion/arquitectonica/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Iluminación Arquitectónica para Eventos en CDMX"
  description="Renta de iluminación arquitectónica para eventos en CDMX: wash lights RGBWA, uplighting perimetral, bañadores de muros y fachadas. Técnico DMX incluido. Desde $800. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diseño de luz profesional para cada espacio"
    title='Renta de <span class="highlight">Iluminación Arquitectónica</span> para Eventos en CDMX'
    subtitle="Wash lights RGBWA, uplighting perimetral, bañadores de muros y luminarias de fachada con control DMX profesional. Transforma cualquier espacio con color, textura y profundidad."
    primaryCTA={{ label: "Cotiza tu iluminación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar iluminación arquitectónica para mi evento` }}
    cards={[
      {
        title: "Iluminación arquitectónica de grado profesional para cada evento",
        content: "<strong>Renta de iluminación arquitectónica para eventos</strong> con tecnología LED de última generación disponible en CDMX. Wash lights RGBWA de alta potencia con mezcla de color infinita y temperatura ajustable de 2700K a 6500K para bodas, galas y eventos corporativos. Uplighting perimetral con barras LED que transforman salones, jardines y terrazas en segundos. Bañadores de muros lineales para resaltar texturas y crear profundidad visual — cada luminaria calibrada y posicionada según un plano de iluminación diseñado específicamente para tu venue.",
      },
      {
        title: "Control DMX profesional con técnico dedicado",
        content: "<strong>Servicio técnico completo</strong> incluido en cada renta de iluminación arquitectónica. Nuestro diseñador de iluminación programa escenas personalizadas según el timeline de tu evento: ceremonia cálida, cena con ambiente íntimo, brindis con spotlight y fiesta con color dinámico. Consola DMX profesional con transiciones suaves, wireless DMX para instalaciones sin cableado visible y monitoreo en tiempo real durante todo el evento para ajustes instantáneos.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres transformar tu espacio con luz y color?"
    subheadline="Cotiza sin compromiso y recibe un plano de iluminación personalizado para tu venue y evento"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — 4 tipos de iluminación arquitectónica
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Iluminación Arquitectónica"
        subtitle="Diseño de luz profesional para cada tipo de espacio y evento"
        description={[
          "Desde wash lights para baños de color en techos y escenarios hasta luminarias IP65 para iluminar fachadas y monumentos. Contamos con el inventario de iluminación arquitectónica más completo de la Ciudad de México.",
          "Cada luminaria incluye control DMX, cableado profesional y técnico de operación dedicado. Potencia, ángulo de apertura y temperatura de color certificados para garantizar un diseño de iluminación impecable."
        ]}
      />

      <div class="grid grid--4">
        {ARQUITECTONICA.map((item) => (
          <Card
            name={item.name}
            excerpt={item.excerpt}
            cta={item.cta}
            href={item.href}
            icon={item.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       WASH LIGHTS LED — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="wash-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Base de todo diseño</span>
          <h2 class="showcase__title" id="wash-heading">Wash Lights LED</h2>
          <p class="showcase__subtitle">Luminarias RGBWA de alta potencia para baños de color uniformes que definen la atmósfera de tu evento.</p>
          <p class="showcase__text">Nuestros <strong>wash lights LED RGBWA</strong> son la base fundamental de cualquier diseño de iluminación arquitectónica profesional. Con tecnología de <strong>mezcla de color RGBWA (rojo, verde, azul, blanco y ámbar)</strong>, ofrecen un espectro infinito de colores con transiciones suaves y precisas. Temperatura ajustable de <strong>2700K a 6500K</strong> que permite desde ambientes cálidos e íntimos para ceremonias de boda hasta luz neutra y profesional para presentaciones corporativas.</p>
          <p class="showcase__text">Cada luminaria cuenta con <strong>control DMX individual de 512 canales</strong>, ángulo de apertura de 15° a 60° con zoom motorizado y potencia de 100W a 300W según el modelo. Ideales para <strong>baños de color en techos, escenarios, columnas y espacios abiertos</strong>. Nuestro diseñador programa escenas personalizadas: ceremonia en ámbar cálido, cena en blanco suave, brindis con spotlight y fiesta con cambios dinámicos de color. Combínalos con nuestras <a href="/servicios/carpas/">carpas estructurales</a> para crear ambientes mágicos bajo techo temporal.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">RGBWA</span>
            <span class="showcase__tag">2700K-6500K</span>
            <span class="showcase__tag">DMX 512</span>
            <span class="showcase__tag">Zoom motorizado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Wash Lights LED
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       UPLIGHTING PERIMETRAL — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="uplighting-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Transformación instantánea</span>
          <h2 class="showcase__title" id="uplighting-heading">Uplighting Perimetral</h2>
          <p class="showcase__subtitle">Barras LED perimetrales que transforman cualquier salón, jardín o terraza con paletas de color personalizadas.</p>
          <p class="showcase__text">El <strong>uplighting perimetral</strong> es la técnica más efectiva para transformar un espacio en minutos. Nuestras <strong>barras LED RGBWA de 1 metro</strong> se colocan a nivel de piso alrededor del perímetro del venue, proyectando luz hacia arriba sobre muros, columnas y cortinajes. El resultado: un <strong>cambio dramático de atmósfera</strong> que convierte cualquier salón blanco en un espacio vibrante con la paleta de color de tu evento — los colores de tu boda, tu marca corporativa o la temática de tu fiesta.</p>
          <p class="showcase__text">Incluyen <strong>wireless DMX para instalación sin cables visibles</strong>, baterías recargables de hasta 10 horas de autonomía para ubicaciones sin acceso a corriente eléctrica, y programación de hasta 20 escenas de color con transiciones suaves. Cada barra ofrece mezcla de color individual que permite crear <strong>degradados perimetrales, zonas de color diferenciadas</strong> (pista de baile en un tono, área de mesas en otro) y efectos de pulso sincronizados con música. Combínalos con nuestro <a href="/servicios/mobiliario/">mobiliario premium</a> para una experiencia visual integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Wireless DMX</span>
            <span class="showcase__tag">Batería 10h</span>
            <span class="showcase__tag">Paletas personalizadas</span>
            <span class="showcase__tag">20 escenas</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Uplighting Perimetral
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <line x1="3" y1="9" x2="21" y2="9"/>
              <line x1="9" y1="21" x2="9" y2="9"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       BAÑADORES DE MUROS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="banadores-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Profundidad y textura</span>
          <h2 class="showcase__title" id="banadores-heading">Bañadores de Muros</h2>
          <p class="showcase__subtitle">Wall washers lineales para resaltar texturas arquitectónicas y crear profundidad visual en salones, jardines y fachadas.</p>
          <p class="showcase__text">Los <strong>bañadores de muros (wall washers)</strong> son luminarias lineales diseñadas para proyectar un baño de luz uniforme sobre superficies verticales. A diferencia del uplighting puntual, los wall washers cubren <strong>tramos completos de muro con luz homogénea</strong>, resaltando texturas de piedra, ladrillo, madera y tela con una profundidad visual impresionante. Disponibles en longitudes de <strong>0.5, 1 y 1.5 metros</strong> con ángulos de apertura asimétricos de 10°×60° optimizados para superficies verticales.</p>
          <p class="showcase__text">Ofrecen <strong>efectos de degradado de color (gradient)</strong> donde cada sección del wall washer puede mostrar un tono diferente, creando transiciones cromáticas a lo largo del muro. También incluyen modo <strong>pixel mapping para efectos dinámicos</strong> de olas de color, persecuciones y patrones programados. Ideales para <strong>salones de eventos con columnas, jardines con muros de piedra, terrazas con bardas decorativas y espacios industriales</strong>. Combínalos con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción integral de imagen y sonido.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Wall Wash Lineal</span>
            <span class="showcase__tag">Gradient Effect</span>
            <span class="showcase__tag">Pixel Mapping</span>
            <span class="showcase__tag">Asimétrico 10°×60°</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Bañadores de Muros
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 20h20"/>
              <path d="M5 20V8l7-5 7 5v12"/>
              <path d="M9 20v-6h6v6"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ILUMINACIÓN DE FACHADAS — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="fachadas-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Impacto exterior</span>
          <h2 class="showcase__title" id="fachadas-heading">Iluminación de Fachadas</h2>
          <p class="showcase__subtitle">Luminarias IP65 de alto brillo para iluminar edificios, monumentos y fachadas con color y proyección de gobos.</p>
          <p class="showcase__text">La <strong>iluminación de fachadas</strong> crea un impacto visual espectacular desde el exterior que recibe a tus invitados antes de entrar al evento. Nuestras luminarias de <strong>exterior IP65 de alto brillo (10,000+ lúmenes)</strong> están diseñadas para iluminar edificios, monumentos históricos, iglesias, haciendas y fachadas de salones de eventos con colores vibrantes y proyecciones nítidas. Resistentes a lluvia, polvo y temperaturas extremas con carcasa de aluminio fundido.</p>
          <p class="showcase__text">Incluyen <strong>proyección de gobos personalizados</strong> — logos, nombres, monogramas y patrones decorativos proyectados directamente sobre la fachada — ideales para bodas (iniciales de los novios), eventos corporativos (logo de la empresa) y celebraciones temáticas. Disponibles en configuraciones de <strong>spot (haz concentrado) y flood (haz amplio)</strong> con zoom motorizado de 8° a 50°. Nuestro equipo de montaje utiliza <strong>bases lastradas y clamps certificados</strong> para una instalación segura sin perforar superficies. Complementa con nuestros <a href="/servicios/accesorios/">accesorios de señalización</a> como alfombras rojas y backdrops para una bienvenida memorable.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">IP65 Outdoor</span>
            <span class="showcase__tag">10,000+ lúmenes</span>
            <span class="showcase__tag">Gobos personalizados</span>
            <span class="showcase__tag">Spot & Flood</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Iluminación de Fachadas
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 21h18"/>
              <path d="M5 21V7l8-4 8 4v14"/>
              <path d="M9 21v-4h6v4"/>
              <path d="M10 9h1"/>
              <path d="M14 9h1"/>
              <path d="M10 13h1"/>
              <path d="M14 13h1"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Iluminación Arquitectónica"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu iluminación arquitectónica, es natural tener preguntas sobre tipos de luminarias, temperaturas de color, control DMX y requerimientos técnicos. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un diseñador de iluminación te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un diseñador de iluminación resolverá todas tus dudas sobre iluminación arquitectónica al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre la renta de iluminación arquitectónica para eventos`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">¿Prefieres atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
