---
/**
 * ─── Iluminación de Fachadas — Página de Producto (Nivel 4) ───
 * Luminarias IP65 de alto brillo para iluminar edificios, monumentos,
 * haciendas y fachadas con color RGBW, gobos proyectados y efectos dinámicos.
 * Color accent: Amber #e17055 (nivel 4). Layout con sidebar de interlinking.
 *
 * Jerarquía: Servicios > Iluminación > Arquitectónica > Iluminación de Fachadas
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@data/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Arquitectónica", href: "/servicios/iluminacion/arquitectonica/" },
  { label: "Fachadas" },
];

const faqs = [
  { question: "¿Cuántas luminarias necesito para iluminar la fachada de mi venue?", answer: "La cantidad depende de la altura, anchura y geometría de la fachada. Como referencia profesional: para una fachada de hasta 10 metros de alto por 15 metros de ancho (150 m²), recomendamos entre 8 y 12 luminarias de 200W distribuidas en 2 líneas — una rasante desde la base y otra en ángulo desde 5-8 metros de distancia. Para fachadas monumentales de 20+ metros de altura se requieren proyectores de 300-500W con ópticas narrow de 8°-15°. Nuestro diseñador de iluminación realiza un levantamiento fotométrico gratuito del inmueble, modela la distribución de luz en software especializado y te entrega un plano con posición, ángulo y potencia exacta de cada luminaria." },
  { question: "¿La iluminación de fachadas resiste lluvia, viento y condiciones extremas?", answer: "Todas nuestras luminarias de fachada cuentan con certificación IP65 o superior, lo que garantiza protección total contra polvo fino y chorros de agua a presión desde cualquier dirección. Las carcasas son de aluminio fundido a presión con tratamiento anticorrosivo y pintura electrostática, soportando temperaturas de -10°C a 50°C y humedad relativa de hasta 100%. Para condiciones de viento fuerte utilizamos bases lastradas de 15-25 kg con anclajes de seguridad y cables de acero inoxidable anticaída. Cada conector es de grado marino tipo Seetronic IP65 con junta tórica doble. En caso de tormenta eléctrica severa, el sistema cuenta con protección contra sobretensión y el técnico desconecta preventivamente." },
  { question: "¿Se pueden proyectar logos, monogramas o patrones sobre la fachada?", answer: "Sí, es una de nuestras especialidades. Utilizamos proyectores de gobos profesionales con lentes de cristal de alta definición que permiten proyectar con nitidez: logos corporativos, monogramas de boda (iniciales de los novios), escudos institucionales, patrones decorativos (encaje, geometría, follaje) y texto personalizado. Los gobos se fabrican a medida en cristal dicroico con resolución fotográfica — el arte final se entrega en 3-5 días hábiles. También ofrecemos gobos rotativos que crean efectos de movimiento sobre la fachada: nubes en desplazamiento, lluvia de estrellas y texturas en rotación continua." },
  { question: "¿Puedo elegir cualquier color para la fachada? ¿Se pueden hacer cambios durante el evento?", answer: 'Nuestras luminarias RGBW de fachada ofrecen mezcla de color infinita con millones de tonalidades posibles, incluyendo blancos cálidos naturales de 2700K gracias al canal blanco dedicado. Puedes proporcionar colores exactos por código hex, Pantone, muestra de tela o referencia fotográfica. Durante el evento, el técnico ejecuta cambios de color programados según tu timeline: llegada de invitados en dorado cálido, ceremonia en blanco puro, cena en la paleta de tu boda y fiesta con colores dinámicos. Las transiciones pueden ser graduales (fade de 5 a 60 segundos) o instantáneas, todo controlado en tiempo real desde la consola DMX. Para que la fachada y el interior se sincronicen, nuestros <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights</a> y <a href="/servicios/iluminacion/arquitectonica/uplighting/">uplighting</a> interiores se operan desde la misma consola.' },
  { question: "¿Se necesita perforar o modificar la fachada para instalar las luminarias?", answer: "No. Nuestro sistema de montaje profesional es 100% no invasivo — no perforamos, atornillamos ni adherimos nada a la superficie del inmueble. Utilizamos bases lastradas de acero con contrapeso de 15-25 kg que se posicionan en el suelo frente a la fachada, trípodes telescópicos con patas de goma antideslizante, y clamps de presión certificados para barandales, columnas y estructuras existentes. Cada luminaria incluye cable de seguridad anticaída de acero inoxidable como respaldo. Todo el montaje se retira al finalizar el evento sin dejar rastro. Para inmuebles históricos y patrimoniales seguimos protocolos especiales de conservación." },
  { question: "¿Con cuánta anticipación debo reservar iluminación de fachadas?", answer: "Recomendamos reservar con 4 a 8 semanas de anticipación. Esto permite: visita técnica y levantamiento fotométrico del inmueble (semana 1), diseño del plano de iluminación con simulación 3D (semana 2), fabricación de gobos personalizados si aplica (semana 3-4), y coordinación logística de montaje con la administración del venue. En temporada alta (noviembre a febrero) sugerimos apartar con 2-3 meses de anticipación. Para eventos con fachadas monumentales, mapping o instalaciones especiales que requieren coordinación con autoridades municipales, el plazo ideal es de 3 meses. También atendemos solicitudes urgentes sujetas a disponibilidad de equipo." },
];

const specs = [
  { label: "Tecnología LED", value: "RGBW 4-en-1 / RGBWA+UV 6-en-1 / Monocromático blanco" },
  { label: "Potencia por luminaria", value: "150W a 500W (según modelo y distancia de proyección)" },
  { label: "Flujo luminoso", value: "10,000 a 45,000 lúmenes por unidad" },
  { label: "Ópticas disponibles", value: "Narrow 8°, Medium 15°-25°, Wide 40°-60°, Ellipsoidal asimétrica" },
  { label: "Distancia de proyección", value: "5m a 50m (según potencia y óptica)" },
  { label: "Control", value: "DMX-512, W-DMX wireless, RDM, Art-Net, sACN" },
  { label: "Clasificación IP", value: "IP65 / IP66 (inmersión parcial certificada)" },
  { label: "Temperatura operativa", value: "-10°C a 50°C, humedad hasta 100%" },
  { label: "Gobos personalizados", value: "Cristal dicroico HD, rotativos y estáticos" },
  { label: "Peso por unidad", value: "8 – 18 kg (base lastrada 15-25 kg adicional)" },
];

const sidebarNav = [
  { name: "Wash Lights LED", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
  { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
  { name: "Bañadores de Muros", href: "/servicios/iluminacion/arquitectonica/banadores/" },
  { name: "Iluminación de Fachadas", href: null, active: true },
];

const sidebarRelated = [
  { name: "Fairy Lights y Guirnaldas", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Letras y Números Luminosos", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Carpas Profesionales", href: "/servicios/carpas/" },
  { name: "Señalización y Alfombras", href: "/servicios/accesorios/senalizacion-alfombras/" },
  { name: "Efectos Especiales", href: "/servicios/iluminacion/efectos-especiales/" },
];

const reviews = [
  { author: "Gabriela Montoya", text: "Contratamos iluminación de fachada para nuestra boda en una hacienda del siglo XVIII en Tlalpan. El resultado fue impresionante — la fachada de cantera iluminada en dorado cálido con nuestro monograma proyectado recibió a cada invitado como en un cuento. El diseñador hizo un levantamiento previo y la simulación 3D que nos envió fue exacta al resultado final. Servicio de otro nivel.", rating: 5, date: "2025-12-18" },
  { author: "Roberto Camacho", text: "Iluminamos la fachada completa de un edificio corporativo para la celebración del 25 aniversario de la empresa. 16 luminarias de 300W con los colores institucionales y el logo proyectado en alta definición sobre 20 metros de altura. El montaje fue completamente limpio, sin perforar nada, y el equipo llegó 6 horas antes para tener todo calibrado. Los directivos quedaron impresionados. Totalmente profesional.", rating: 5, date: "2025-11-07" },
  { author: "Valentina Ochoa", text: "Para los XV años de mi hija iluminamos la fachada del salón en rosa y dorado. Lo que más me impresionó fue que el técnico programó cambios de color durante toda la noche — rosa suave para la llegada, blanco para el vals, y colores dinámicos para la fiesta. Los gobos con el nombre de mi hija proyectados en la entrada fueron el toque especial que todos fotografiaron. Increíble relación calidad-precio.", rating: 5, date: "2025-09-14" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Iluminación de Fachadas LED para Eventos en CDMX",
    description: "Luminarias LED IP65 de alto brillo para iluminar fachadas, edificios y monumentos en CDMX. RGBW hasta 45,000 lúmenes, gobos personalizados, montaje no invasivo y técnico DMX incluido. Desde $500 por luminaria.",
    url: "/servicios/iluminacion/arquitectonica/fachadas/",
    priceRange: { min: 500, max: 8000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Arquitectónica", url: "/servicios/iluminacion/arquitectonica/" },
    { name: "Iluminación de Fachadas", url: "/servicios/iluminacion/arquitectonica/fachadas/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Iluminación de Fachadas en CDMX"
  description="Renta de iluminación de fachadas LED IP65 para eventos en CDMX: luminarias RGBW de 10,000-45,000 lm, gobos personalizados, montaje no invasivo, técnico DMX incluido. Desde $500. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="La primera impresión que define tu evento"
    title='Renta de <span class="highlight">Iluminación de Fachadas</span> LED para Eventos en CDMX'
    subtitle="Luminarias IP65 de alto brillo con ópticas profesionales, gobos personalizados y color RGBW para iluminar edificios, haciendas, monumentos y fachadas de venues. Montaje no invasivo con técnico DMX dedicado."
    primaryCTA={{ label: "Cotiza tu fachada", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar iluminación de fachada para mi evento` }}
    cards={[
      {
        title: "Luminarias de exterior IP65 que transforman cualquier fachada en espectáculo visual",
        content: "<strong>Renta de iluminación de fachadas LED para eventos</strong> con luminarias IP65 de grado profesional en la Ciudad de México. Proyectores RGBW de 150W a 500W con flujo luminoso de <strong>10,000 a 45,000 lúmenes</strong> por unidad — potencia suficiente para iluminar edificios de hasta 50 metros de altura con color vibrante y definición nítida. Ópticas intercambiables narrow (8°), medium (15°-25°) y wide (40°-60°) que permiten cubrir desde columnas puntuales hasta fachadas monumentales completas. Carcasas de aluminio fundido con tratamiento anticorrosivo, certificadas para operación bajo lluvia, polvo y temperaturas extremas.",
      },
      {
        title: "Gobos personalizados en cristal HD y montaje 100% no invasivo",
        content: "<strong>Proyección de gobos en cristal dicroico de alta definición</strong> para logos corporativos, monogramas de boda, escudos institucionales y patrones decorativos directamente sobre la fachada de tu venue. Gobos estáticos y rotativos fabricados a medida con resolución fotográfica. <strong>Sistema de montaje completamente no invasivo</strong> — bases lastradas, trípodes y clamps de presión que no perforan, atornillan ni adhieren nada a la superficie del inmueble. Ideal para edificios históricos, haciendas patrimoniales y venues con restricciones de modificación estructural. Técnico operador DMX dedicado durante todo el evento.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Quieres que tu fachada sea la primera impresión inolvidable de tu evento?"
    subheadline="Cotiza sin compromiso — te enviamos simulación 3D con el diseño de iluminación de tu fachada"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Iluminación Arquitectónica</h3>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h3 class="sidebar-card__title">Servicios Relacionados</h3>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h3 class="sidebar-card__title">Cotiza Ahora</h3>
          <p class="sidebar-card--cta-text">¿Necesitas iluminar la fachada de tu venue?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar iluminación de fachada para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Iluminación de Fachadas LED</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Flood RGBW -->
          <section class="section section--alt" aria-labelledby="flood-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Cobertura total de fachadas completas</span>
                <h2 class="showcase__title" id="flood-heading">Proyector Flood RGBW de Alta Potencia</h2>
                <p class="showcase__subtitle">Luminarias de 300-500W con óptica wide 40°-60° para baños de color uniformes sobre fachadas de gran superficie.</p>
                <p class="showcase__text">Los <strong>proyectores flood RGBW de alta potencia</strong> son nuestra solución principal para iluminar fachadas completas con color uniforme y vibrante. Con <strong>300W a 500W de potencia LED y flujo luminoso de 25,000 a 45,000 lúmenes</strong> por unidad, cubren superficies de hasta 200 m² por proyector a una distancia de 15-30 metros. Óptica wide de 40°-60° con distribución homogénea que elimina puntos calientes y sombras irregulares — el resultado es un baño de color perfectamente uniforme de esquina a esquina.</p>
                <p class="showcase__text">Tecnología <strong>RGBW 4-en-1 con dimmer de 16-bit</strong> para transiciones ultra-suaves sin escalonamiento visible, CRI de 90+ para reproducción cromática fiel, y canal blanco dedicado que produce blancos cálidos de 2700K imposibles de lograr con RGB estándar. Control DMX-512 y Art-Net para integración con cualquier sistema profesional. Cada proyector incluye <strong>base lastrada de 25 kg con ángulo ajustable de 0° a 90°</strong> y cable de seguridad anticaída. La elección profesional para haciendas, salones de eventos y <a href="/servicios/carpas/">carpas estructurales</a> donde la fachada es la carta de presentación del evento.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">300-500W</span>
                  <span class="showcase__tag">45,000 lúmenes</span>
                  <span class="showcase__tag">Óptica Wide 40°-60°</span>
                  <span class="showcase__tag">CRI 90+</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector Flood
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/iluminacion-arquitectonica/fachada-flood-rgbw-edificio-moderno.avif" alt="Iluminación flood RGBW de fachada de edificio moderno con columnas iluminadas en teal y ámbar" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 5. SHOWCASE: Spot Narrow Beam -->
          <section class="section section--alt" aria-labelledby="spot-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Precisión quirúrgica en elementos clave</span>
                <h2 class="showcase__title" id="spot-heading">Proyector Spot Narrow Beam</h2>
                <p class="showcase__subtitle">Luminarias de haz concentrado 8°-15° para columnas, torres, campanarios y detalles arquitectónicos a gran altura.</p>
                <p class="showcase__text">Los <strong>proyectores spot narrow beam</strong> están diseñados para iluminar elementos arquitectónicos específicos a distancias de <strong>20 a 50 metros</strong> con un haz de luz concentrado y definido. Ópticas de 8° y 15° con lentes de vidrio templado anti-reflejo que mantienen la intensidad y nitidez del haz incluso a distancias extremas. Potencia de <strong>200W a 400W RGBW con 15,000 a 35,000 lúmenes</strong> — suficiente para iluminar el campanario de una iglesia, la torre de un edificio corporativo o las columnas de una hacienda colonial.</p>
                <p class="showcase__text">La clave del spot narrow es el <strong>recorte limpio del haz</strong>: la luz incide exclusivamente sobre el elemento deseado sin derramarse sobre superficies adyacentes, creando un contraste dramático entre lo iluminado y la oscuridad circundante. Zoom motorizado para ajuste fino en campo sin tocar la luminaria, iris mecánico para control de diámetro del haz y <strong>barn doors opcionales</strong> para recorte rectangular preciso. El complemento perfecto de los flood para crear esquemas multi-capa con <a href="/servicios/iluminacion/arquitectonica/banadores/">bañadores de muros</a> en las superficies y spots en los detalles.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Narrow 8°-15°</span>
                  <span class="showcase__tag">35,000 lúmenes</span>
                  <span class="showcase__tag">Alcance 50m</span>
                  <span class="showcase__tag">Zoom motorizado</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector Spot
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/iluminacion-arquitectonica/fachada-spot-iglesia-boda-noche.avif" alt="Iluminación spot de fachada de iglesia colonial para boda nocturna con pareja de novios" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 6. SHOWCASE: Gobo Projector -->
          <section class="section section--alt" aria-labelledby="gobo-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Tu marca o monograma proyectado en HD</span>
                <h2 class="showcase__title" id="gobo-heading">Proyector de Gobos Personalizado</h2>
                <p class="showcase__subtitle">Proyección de logos, iniciales, patrones y texturas en cristal dicroico HD directamente sobre la fachada de tu venue.</p>
                <p class="showcase__text">Los <strong>proyectores de gobos personalizados</strong> son el recurso de mayor impacto para branding y personalización de fachadas. Utilizamos <strong>gobos de cristal dicroico de alta definición</strong> fabricados a medida con resolución fotográfica que permite reproducir desde logos corporativos con degradados y tipografía fina hasta monogramas de boda con ornamentación detallada. La proyección alcanza tamaños de <strong>2 a 15 metros de diámetro</strong> según la distancia y la óptica, con bordes nítidos y colores fieles al diseño original.</p>
                <p class="showcase__text">Disponibles en configuración <strong>estática y rotativa</strong>. Los gobos rotativos crean efectos hipnóticos de movimiento sobre la fachada: nubes en desplazamiento, lluvia de estrellas, texturas de agua en movimiento y patrones geométricos en rotación continua. Cada proyector acepta <strong>hasta 6 gobos intercambiables</strong> en rueda motorizada para cambiar diseños durante el evento sin intervención manual. Potencia de 300W con lente de cristal de alta calidad, enfoque motorizado y control DMX integrado. Combina con nuestro <a href="/servicios/audiovisual/">equipo audiovisual</a> de pantallas LED y <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights LED</a> en el interior para una producción integral de primer nivel.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Cristal dicroico HD</span>
                  <span class="showcase__tag">Estático + rotativo</span>
                  <span class="showcase__tag">6 gobos/rueda</span>
                  <span class="showcase__tag">2-15m diámetro</span>
                </div>
                <a href="#reserva-heading" class="btn btn--primary btn--lg">
                  Cotizar Proyector de Gobos
                </a>
              </div>
              <div class="showcase__image">
                <img src="/images/iluminacion-arquitectonica/fachada-gobos-proyectados-edificio.avif" alt="Gobos personalizados proyectados en fachada de edificio con diseños botánicos en colores" width="800" height="436" loading="lazy" class="showcase__img" />
              </div>
            </div>
          </section>

          <!-- 7. SHOWCASE: Architectural Grazing -->
          <section class="section section--alt" aria-labelledby="grazing-heading">
            <div class="showcase">
              <div class="showcase__content">
                <span class="showcase__badge">Revela cada textura y relieve</span>
                <h2 class="showcase__title" id="grazing-heading">Iluminación Rasante (Grazing)</h2>
                <p class="showcase__subtitle">Luminarias de montaje rasante a la base de la fachada que revelan texturas de piedra, cantera, ladrillo y relieves ornamentales.</p>
                <p class="showcase__text">La <strong>iluminación rasante (grazing)</strong> es la técnica más sofisticada para fachadas con textura. Las luminarias se posicionan a <strong>30-50 centímetros de la base del muro</strong>, proyectando luz en ángulo extremadamente rasante que incide sobre la superficie casi paralela al plano. El resultado: cada relieve, cada grieta, cada juntura de piedra o ladrillo genera <strong>sombras microscópicas que magnifican la textura natural</strong> del material, creando una profundidad tridimensional espectacular invisible bajo iluminación frontal convencional.</p>
                <p class="showcase__text">Utilizamos <strong>barras lineales IP66 de 72W a 144W</strong> con óptica asimétrica ultra-rasante de 5°×60° diseñada específicamente para esta técnica. Disponibles en RGBW para color dinámico o blanco cálido de alta fidelidad cromática (CRI 95+) para resaltar el tono natural de materiales nobles. Ideales para <strong>fachadas de cantera, piedra volcánica, ladrillo artesanal, concreto aparente y maderas expuestas</strong>. Montaje sobre bases rasantes de perfil ultra-bajo que desaparecen visualmente. Complementa con <a href="/servicios/iluminacion/arquitectonica/uplighting/">uplighting perimetral</a> en el perímetro interior y <a href="/servicios/accesorios/senalizacion-alfombras/">alfombras y señalización</a> para crear un recorrido de bienvenida espectacular desde el estacionamiento hasta la entrada.</p>
                <div class="showcase__tags">
                  <span class="showcase__tag">Rasante 5°×60°</span>
                  <span class="showcase__tag">IP66 exterior</span>
                  <span class="showcase__tag">CRI 95+</span>
