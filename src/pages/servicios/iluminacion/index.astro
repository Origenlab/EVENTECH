---
/**
 * ─── EVENTECH.MX — Iluminación para Eventos (L3, rediseño 2026) ───
 * Diseño lumínico profesional: arquitectónica, decorativa, escenario y efectos.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import "@styles/home-2026.css";
import Breadcrumbs from "@components/Breadcrumbs.astro";

const SUB_SERVICES = [
  {
    id: "arquitectonica",
    name: "Arquitectónica",
    badge: "Base del diseño lumínico",
    excerpt: "Wash lights, uplighting y bañadores LED que transforman muros, columnas y techos con color. La capa base que define la atmósfera de todo el espacio.",
    href: "/servicios/iluminacion/arquitectonica/",
    image: "/images/iluminacion/iluminacion-arquitectonica-hacienda.avif",
    subcategories: [
      { name: "Wash Lights LED", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
      { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
      { name: "Bañadores de Muros", href: "/servicios/iluminacion/arquitectonica/banadores/" },
      { name: "Fachadas Exteriores", href: "/servicios/iluminacion/arquitectonica/fachadas/" },
    ],
  },
  {
    id: "decorativa",
    name: "Decorativa",
    badge: "Más solicitada en bodas",
    excerpt: "Fairy lights, guirnaldas Edison, candiles de cristal cortado y esferas LED. El elemento que convierte cualquier venue en un escenario irresistiblemente fotogénico.",
    href: "/servicios/iluminacion/decorativa/",
    image: "/images/iluminacion/guirnaldas-edison-jardin-boda.avif",
    subcategories: [
      { name: "Fairy Lights y Guirnaldas", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
      { name: "Candiles de Cristal", href: "/servicios/iluminacion/decorativa/candiles/" },
      { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
      { name: "Letras y Letreros Neón", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
    ],
  },
  {
    id: "escenario",
    name: "Escenario",
    badge: "Producción profesional",
    excerpt: "Par LED RGBWA, moving heads, follow spots y truss de aluminio para tarimas, pasarelas y shows en vivo. Control DMX completo con técnico operador certificado.",
    href: "/servicios/iluminacion/escenario/",
    image: "/images/iluminacion/cabezas-moviles-beam-evento.avif",
    subcategories: [
      { name: "Par LED RGBWA", href: "/servicios/iluminacion/escenario/par-led/" },
      { name: "Moving Heads", href: "/servicios/iluminacion/escenario/moving-heads/" },
      { name: "Follow Spots", href: "/servicios/iluminacion/escenario/follow-spots/" },
      { name: "Truss y Rigging", href: "/servicios/iluminacion/escenario/barras-led/" },
    ],
  },
  {
    id: "efectos-especiales",
    name: "Efectos Especiales",
    badge: "Momentos WOW",
    excerpt: "Humo bajo con hielo seco, papelitos de mariposas, láser RGB, cañones de CO₂ criogénico y confeti. Los efectos que convierten instantes clave en recuerdos épicos.",
    href: "/servicios/iluminacion/efectos-especiales/",
    image: "/images/iluminacion/efectos-especiales-humo-bajo.avif",
    subcategories: [
      { name: "Humo Bajo / Ice Fog", href: "/servicios/iluminacion/efectos-especiales/humo-bajo/" },
      { name: "Papelitos de Mariposas", href: "/servicios/iluminacion/efectos-especiales/mariposas/" },
      { name: "Láser Multicolor", href: "/servicios/iluminacion/efectos-especiales/laser/" },
      { name: "CO₂ y Confeti", href: "/servicios/iluminacion/efectos-especiales/confeti/" },
    ],
  },
];

const whyFeatures = [
  {
    icon: "🎛️",
    title: "Control DMX512 profesional",
    body: "Todas nuestras producciones se operan desde consolas GrandMA, Avolites o ChamSys. Control individual por canal, transiciones programadas y sincronización milimétrica con cada momento del evento.",
  },
  {
    icon: "🎨",
    title: "Diseño lumínico previo al evento",
    body: "Nuestro diseñador crea un concepto visual personalizado — moodboard, paleta de temperatura de color y plano técnico por zona — aprobado por el cliente antes de instalar una sola luminaria.",
  },
  {
    icon: "⚡",
    title: "Visita técnica de rigor",
    body: "Evaluamos puntos de corriente, arquitectura del espacio, altura de techo y condiciones de luz natural antes de cotizar. Sin visita no hay propuesta: los detalles del venue determinan el montaje.",
  },
  {
    icon: "👨‍🔧",
    title: "Técnicos certificados en sitio",
    body: "Cada evento cuenta con un operador DMX que permanece durante toda la celebración. Para producciones de escenario asignamos equipo completo: director de iluminación + operadores de seguimiento.",
  },
  {
    icon: "🔋",
    title: "Energía asegurada",
    body: "Para eventos con demanda eléctrica alta llevamos tableros de distribución portátiles y plantas de luz silenciosas. Sin apagones, sin sorpresas: la infraestructura eléctrica es parte del servicio.",
  },
  {
    icon: "🔗",
    title: "Integración total con producción",
    body: "Coordinamos con audio, video y decoración desde el mismo equipo. El diseño lumínico no va aislado: forma parte de una producción coherente donde cada elemento refuerza la experiencia visual.",
  },
];

const steps = [
  { n: 1, t: "Consulta y concepto", p: "Conversamos sobre el estilo del evento, paleta de colores, momentos clave y venue. Definimos el concepto lumínico antes de cualquier número." },
  { n: 2, t: "Visita técnica", p: "Visitamos el venue para evaluar corriente disponible, puntos de anclaje, alturas y arquitectura. Presentamos plano técnico y moodboard para aprobación." },
  { n: 3, t: "Montaje certificado", p: "Nuestro equipo instala, cablea y programa todas las luminarias el día previo al evento. Entregamos el espacio verificado y listo para operar." },
  { n: 4, t: "Operación y desmontaje", p: "El técnico DMX opera en vivo durante el evento, sincronizando cada transición. Al terminar, nuestro equipo desmonta y retira todo el equipo sin que muevas un dedo." },
];

const faqs = [
  {
    question: "¿Qué iluminación recomiendan para una boda?",
    answer: "Para bodas la combinación más solicitada es wash lights en ámbar cálido (2700K–3000K) como base ambiental que baña muros y cortinas, fairy lights o guirnaldas Edison como elemento estrella en jardines y techos, y spots direccionables para resaltar mesa de novios, pastel y centros de mesa. Si el evento es bajo carpa, el uplighting perimetral transforma la lona en un lienzo de color. Diseñamos un plano personalizado para cada venue.",
  },
  {
    question: "¿Incluyen operador técnico durante el evento?",
    answer: "Sí, sin excepción. Todos nuestros paquetes incluyen un operador DMX certificado que permanece durante todo el evento. El operador gestiona consola, sincroniza cambios de ambiente con los momentos clave (ceremonia, brindis, primer baile, fiesta) y resuelve cualquier ajuste en tiempo real. Para eventos de escenario asignamos director de iluminación más operadores de follow spot.",
  },
  {
    question: "¿Se puede combinar iluminación interior y exterior en el mismo evento?",
    answer: "Es una de nuestras especialidades. Usamos luminarias IP65 para jardines, fachadas y caminos exteriores, controladas desde la misma consola que maneja el interior. Esto permite transiciones coordinadas entre espacios — por ejemplo, guiar a los invitados de un coctel exterior con uplighting azul hacia un salón con ambiental dorado cálido, todo sincronizado.",
  },
  {
    question: "¿Necesito instalación eléctrica especial?",
    answer: "Para eventos medianos (hasta 150 personas) suelen bastar los contactos del venue. Para montajes grandes o con efectos especiales podemos requerir una acometida de 220V o tablero trifásico. Evaluamos la demanda eléctrica en la visita técnica y, si es necesario, llevamos planta de luz silenciosa o tablero de distribución portátil sin costo adicional en paquetes premium.",
  },
  {
    question: "¿Qué tan anticipado debo reservar?",
    answer: "Recomendamos 3–4 semanas de anticipación para garantizar equipo y agenda del operador. En temporada alta (noviembre–febrero) lo ideal es reservar con 6–8 semanas. La visita técnica se programa 2–3 semanas antes del evento para diseñar el plano y coordinar con el venue.",
  },
  {
    question: "¿Los efectos especiales como humo bajo son seguros dentro del salón?",
    answer: "Sí. Las máquinas de ice fog con hielo seco generan una niebla densa a ras de piso que se disipa en minutos sin activar detectores de humo ni afectar la visibilidad. Trabajamos con detectores de humo del venue desactivados puntualmente y con autorización del encargado. Todos nuestros efectos se operan con protocolos de seguridad certificados y coordinación previa con el venue.",
  },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación para Eventos en CDMX",
    description: "Diseño lumínico profesional con wash lights, fairy lights, moving heads y efectos especiales. Operador DMX y técnico certificado incluidos para bodas, XV años y eventos corporativos en CDMX.",
    url: "/servicios/iluminacion/",
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación para Eventos", url: "/servicios/iluminacion/" },
  ]),
  faqJsonLd(faqs),
];

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación para Eventos" },
];
---

<PageLayout
  title="Renta de Iluminación para Eventos en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/iluminacion/iluminacion-arquitectonica-hacienda.avif"
  description="Diseño lumínico para eventos en CDMX: iluminación arquitectónica, decorativa, escenario y efectos especiales. Operador DMX incluido. Cotización en 24h."
  jsonLd={jsonLd}
>

  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />
  <div class="hm">

    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="ilum-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Diseño lumínico profesional · CDMX y ZMVM</p>
            <h1 id="ilum-hero-heading">
              Iluminación que no ilumina espacios — <em>construye atmósferas</em>
            </h1>
            <p class="hm-hero__lead">
              Wash lights, fairy lights, moving heads y efectos especiales operados por técnicos
              DMX certificados. Diseño lumínico personalizado, visita técnica incluida y un concepto
              visual que tus invitados van a recordar mucho después del evento.
            </p>
            <div class="sv-hero__ctas">
              <a
                class="hm__btn hm__btn--gold"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20profesional%20para%20mi%20evento`}
                target="_blank" rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z"/></svg>
                Cotizar ahora
              </a>
              <a class="hm__btn hm__btn--ghost" href="#catalogo">
                Ver tipos de iluminación
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 500 producciones de iluminación</strong> en Ciudad de México,
              EVENTECH diseña y opera sistemas lumínicos para bodas, XV años, eventos
              corporativos y shows en vivo. No rentamos equipo — diseñamos experiencias
              visuales completas con visita técnica, plano lumínico personalizado y
              operador DMX certificado en cada evento.
            </p>
            <p>
              Nuestro catálogo cubre <strong>los cuatro pilares del diseño lumínico profesional</strong>:
              iluminación arquitectónica para transformar el espacio, decorativa para crear
              atmósferas irresistiblemente fotogénicas, de escenario para producciones de
              alto impacto, y efectos especiales para los momentos que nadie va a olvidar.
              Todo desde una sola empresa, con una sola coordinación. Para eventos donde el suministro eléctrico del venue es limitado, coordinamos los <a href="/servicios/accesorios/plantas-energia/">generadores de respaldo</a> necesarios para el sistema lumínico.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- NAV SUBCATEGORÍAS -->
    <nav class="hm-menu" aria-label="Tipos de iluminación para eventos">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        {SUB_SERVICES.map((s) => (
          <li><a class="hm-menu__item" href={s.href}>{s.name}</a></li>
        ))}
        <li>
          <a
            class="hm-menu__item hm-menu__item--cta"
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20quiero%20cotizar%20iluminaci%C3%B3n%20para%20mi%20evento`}
            target="_blank" rel="noopener noreferrer"
          >Cotizar ahora</a>
        </li>
      </ul>
    </nav>

    <!-- CATÁLOGO -->
    <section id="catalogo" class="hm__section" aria-labelledby="catalogo-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cuatro pilares del diseño lumínico</p>
            <h2 id="catalogo-heading">¿Qué tipo de iluminación necesita tu evento?</h2>
            <p class="hm__head-sub">Arquitectónica, decorativa, de escenario o efectos — cada una con propósito distinto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La iluminación de un evento no se elige por catálogo. Depende del venue,
              el estilo de la celebración, la temperatura de color que complementa la
              decoración y los momentos clave que merece destacar. Una boda en hacienda
              pide calidez y profundidad; un lanzamiento corporativo pide impacto y
              precisión técnica; un XV años pide magia y sorpresa.
            </p>
            <p>
              Por eso empezamos con un diseño, no con un presupuesto. Esa diferencia
              es lo que separa una empresa de renta de una empresa de producción lumínica.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {SUB_SERVICES.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`${s.name} para eventos en CDMX — EVENTECH`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.badge}</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.excerpt}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver todo en {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- MÓDULOS DESTACADOS -->
    <section class="hm__section hm__section--ivory" aria-labelledby="detalle-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cada tipo, en profundidad</p>
            <h2 id="detalle-heading">Iluminación a detalle</h2>
            <p class="hm__head-sub">Qué instalamos, cómo lo operamos y por qué cada tipo define un resultado distinto.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Detrás de cada tipo de iluminación hay un universo técnico de temperaturas
              de color, protocolos de control, ángulos de apertura y comportamientos
              del haz de luz en distintos tipos de superficie. No hace falta que lo
              conozcas — para eso están nuestros diseñadores y técnicos.
            </p>
            <p>
              Lo que sí vale la pena entender es qué hace cada tipo, qué emoción genera
              y para qué tipo de evento es la elección natural. Eso es lo que encontrarás
              en cada módulo a continuación.
            </p>
          </div>
        </div>

        <!-- Arquitectónica -->
        <article class="hm-feat" aria-labelledby="feat-arq">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Iluminación Arquitectónica</p>
            <h3 class="hm-feat__title" id="feat-arq">Wash lights y uplighting — la capa que define el color del ambiente en todo el espacio</h3>
            <p class="hm-feat__lead">La primera decisión en cualquier diseño lumínico profesional: ¿qué temperatura de color va a envolver el espacio entero?</p>
            <p>
              Nuestros <strong>wash lights LED RGBWA+UV de 18×15W</strong> bañan superficies
              verticales — muros, columnas, cortinas de carpa, fachadas — con color
              infinitamente mezclable desde una consola DMX. Un ámbar cálido a 2700K
              convierte cualquier salón en un abrazo dorado; un azul eléctrico a alta
              saturación comunica marca corporativa desde el primer vistazo. El
              <strong>uplighting perimetral con luminarias IP65</strong> resuelve jardines,
              explanadas y exteriores con la misma precisión cromática que el interior.
            </p>
            <p>
              Todo opera con protocolo <strong>DMX512 desde consolas GrandMA2 o Avolites</strong>,
              permitiendo transiciones suaves programadas por momento del evento —
              blanco cálido para la ceremonia, dorado profundo para el brindis, colores
              dinámicos para la fiesta. Complementamos con
              <a href="/servicios/carpas/">carpas y estructuras</a> donde el uplighting
              transforma la lona en un lienzo de luz que envuelve a los invitados.
            </p>
            <ul class="hm-feat__chips">
              {[
                { name: "Wash Lights", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
                { name: "Uplighting", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
                { name: "Bañadores", href: "/servicios/iluminacion/arquitectonica/banadores/" },
                { name: "Fachadas", href: "/servicios/iluminacion/arquitectonica/fachadas/" },
              ].map((sc) => (<li><a href={sc.href}>{sc.name}</a></li>))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/iluminacion/arquitectonica/">
              Ver iluminación arquitectónica
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </a>
          </div>
          <div class="hm-feat__media hm-feat__media--g3">
            <img class="hm-feat__g3-main" src="/images/iluminacion/iluminacion-arquitectonica-hacienda.avif" alt="Iluminación arquitectónica con wash lights LED en hacienda para boda" loading="lazy" decoding="async" />
            <div class="hm-feat__g3-thumbs">
              <img src="/images/iluminacion/iluminacion-evento-01.avif" alt="Uplighting perimetral en salón para evento corporativo CDMX" loading="lazy" decoding="async" />
              <img src="/images/iluminacion/iluminacion-evento-02.avif" alt="Wash lights LED bañando muros con color cálido en boda" loading="lazy" decoding="async" />
            </div>
          </div>
        </article>

        <!-- Decorativa -->
        <article class="hm-feat" aria-labelledby="feat-dec">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Iluminación Decorativa</p>
            <h3 class="hm-feat__title" id="feat-dec">Fairy lights, candiles y guirnaldas — la capa que hace que cada foto del evento sea perfecta</h3>
            <p class="hm-feat__lead">La diferencia entre un espacio que se ve bonito y uno que detiene a los invitados a mitad del camino para sacar el teléfono.</p>
            <p>
              Las <strong>fairy lights de LED blanco cálido 2700K</strong> son el elemento
              más solicitado en bodas de CDMX — instaladas en cascada sobre cortinas de tela,
              como cielo estrellado sobre la <a href="/servicios/pistas-baile/">pista de baile</a> o entrelazadas en follaje natural,
              crean una profundidad visual que ninguna otra luminaria logra. Nuestras
              <strong>guirnaldas Edison con filamento vintage de 60W</strong> en recorridos
              de hasta 200 metros añaden calidez industrial-bohemia perfecta para jardines
              y terrazas. Los <strong>candiles de cristal cortado</strong> en 60, 80 y 100 cm
              aportan elegancia clásica suspendida que refleja cada punto de luz del espacio.
            </p>
            <p>
              Cada instalación decorativa se diseña según la <strong>arquitectura real del venue</strong>:
              altura de techo, puntos de anclaje disponibles y cómo la luz va a interactuar con
              la decoración floral y el <a href="/servicios/mobiliario/">mobiliario</a>. Todo con
              <strong>rigging profesional certificado</strong> — eslingas de acero, puntos de
              anclaje verificados — para piezas suspendidas sobre invitados. Añadimos
              <strong>letras luminosas de 80 cm</strong> y letreros neón personalizados
