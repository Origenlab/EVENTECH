---
/**
 * ─── Iluminación Category Page ───
 * Página de categoría: Renta de Iluminación para Eventos en CDMX.
 * Sigue el layout de subcategoría principal aprobado.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@utils/seo";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación" },
];

const SUB_SERVICES = [
  {
    name: "Iluminación Arquitectónica",
    excerpt: "Wash lights, uplighting y bañadores de muros LED que transforman cualquier espacio con color y profundidad. La base de todo diseño de iluminación profesional.",
    cta: "Arquitectónica",
    href: "/servicios/iluminacion/arquitectonica/",
    icon: "sun",
  },
  {
    name: "Iluminación Decorativa",
    excerpt: "Fairy lights, candiles de cristal, esferas LED y guirnaldas vintage. El toque mágico que convierte cualquier venue en un escenario de ensueño.",
    cta: "Decorativa",
    href: "/servicios/iluminacion/decorativa/",
    icon: "star",
  },
  {
    name: "Iluminación de Escenario",
    excerpt: "Par LED RGBWA, moving heads, follow spots y barras motorizadas para tarimas, pasarelas y presentaciones. Control DMX profesional incluido.",
    cta: "Escenario",
    href: "/servicios/iluminacion/escenario/",
    icon: "zap",
  },
  {
    name: "Efectos Especiales",
    excerpt: "Máquinas de humo bajo, láser multicor, cañones de confeti, sparklers fríos y pantallas de agua. Momentos WOW que nadie olvidará.",
    cta: "Efectos Especiales",
    href: "/servicios/iluminacion/efectos-especiales/",
    icon: "activity",
  },
];

const faqs = [
  { question: "¿Qué tipo de iluminación recomiendan para una boda?", answer: "Para bodas recomendamos una combinación de iluminación arquitectónica con wash lights ámbar cálido (2700K-3000K) como base ambiental, fairy lights o guirnaldas como elemento decorativo estrella, y spots direccionables para resaltar la mesa de novios, pastel y pista de baile. Si tu boda es en jardín o bajo carpa, complementamos con uplighting perimetral que baña las paredes o cortinas de la estructura con el color de tu paleta. Nuestro diseñador de iluminación crea un plano personalizado según tu venue y estilo." },
  { question: "¿Incluyen operador técnico durante el evento?", answer: "Sí. Todos nuestros paquetes de iluminación profesional incluyen un técnico operador certificado que permanece durante todo el evento. El operador gestiona la consola DMX, sincroniza los cambios de iluminación con los momentos clave (primer baile, brindis, fiesta) y resuelve cualquier ajuste en tiempo real. Para eventos grandes o con requerimientos complejos asignamos un equipo de 2-3 técnicos con director de iluminación." },
  { question: "¿Se puede combinar iluminación interior y exterior?", answer: "Por supuesto. De hecho, diseñar un concepto integral interior-exterior es una de nuestras especialidades. Utilizamos wash lights IP65 (resistentes a intemperie) para jardines, fachadas y caminos, combinados con iluminación interior controlada desde la misma consola DMX. Esto permite transiciones coordinadas entre espacios — por ejemplo, guiar a los invitados desde un coctel en jardín iluminado con uplighting azul hacia un salón con ambiental cálido dorado." },
  { question: "¿Necesito instalación eléctrica especial para la iluminación?", answer: "Depende del tamaño del montaje. Para eventos medianos (hasta 150 invitados) generalmente basta con los contactos regulares del venue. Para eventos grandes o montajes con más de 20 luminarias y efectos especiales, podemos requerir una acometida de 220V o tableros de distribución trifásicos. Nuestro equipo realiza una evaluación eléctrica durante la visita técnica y, si es necesario, llevamos plantas de luz silenciosas o tableros portátiles sin costo adicional en paquetes premium." },
  { question: "¿Con cuánta anticipación debo reservar el servicio de iluminación?", answer: "Recomendamos reservar con 3 a 4 semanas de anticipación para garantizar disponibilidad del equipo y agenda del operador técnico. En temporada alta (noviembre a febrero) lo ideal es apartar con 6 a 8 semanas. La visita técnica al venue se programa 2-3 semanas antes del evento para diseñar el plano de iluminación y coordinar con el venue los puntos de corriente y estructura de montaje." },
  { question: "¿Ofrecen diseño de iluminación personalizado?", answer: "Sí. Nuestro servicio incluye un diseñador de iluminación que crea un concepto visual personalizado basado en tu paleta de colores, estilo del evento, arquitectura del venue y momentos clave de la celebración. Presentamos un render o moodboard previo para tu aprobación antes del evento. El diseño considera la temperatura de color, intensidad, direccionalidad y efectos de cada zona del espacio para crear la atmósfera exacta que imaginas." },
];

const jsonLd = [
  serviceJsonLd({
    name: "Renta de Iluminación para Eventos en CDMX",
    description: "Iluminación arquitectónica, decorativa, de escenario y efectos especiales para bodas, corporativos y eventos sociales. Operador DMX incluido.",
    url: "/servicios/iluminacion/",
    priceRange: { min: 2500, max: 85000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Renta de Iluminación para Eventos en CDMX"
  description="Renta de iluminación profesional para eventos en CDMX. Wash lights, fairy lights, par LED, moving heads y efectos especiales con operador DMX incluido. Cotiza hoy."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="container">
    <Breadcrumbs items={breadcrumbItems} />
  </div>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Diseño lumínico profesional con operador DMX"
    title='Renta de <span class="highlight">Iluminación para Eventos</span> en CDMX'
    subtitle="Iluminación arquitectónica, decorativa, de escenario y efectos especiales con control DMX profesional y operador técnico incluido. Transforma cualquier venue en una experiencia visual inmersiva que tus invitados recordarán por siempre."
    primaryCTA={{ label: "Cotiza tu evento", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar iluminación profesional para mi evento en CDMX` }}
    cards={[
      {
        title: "Equipo LED de última generación con control DMX512",
        content: "<strong>Renta de iluminación profesional para eventos</strong> con el inventario más completo de CDMX. Luminarias LED de alta eficiencia con CRI 95+ para una reproducción cromática impecable — wash lights RGBWA+UV de 18x15W, par LED de 54x3W, moving heads beam/spot/wash de 230W y 280W, barras de LEDs motorizadas, follow spots de 1200W y spots elipsoidales ETC Source Four. Todo operado desde consolas DMX512 profesionales (GrandMA, Avolites, ChamSys) por técnicos certificados que garantizan sincronización perfecta con cada momento de tu celebración.",
      },
      {
        title: "Diseño lumínico personalizado con visita técnica incluida",
        content: "<strong>Servicio integral de iluminación</strong> que va más allá de rentar equipo. Nuestro diseñador de iluminación realiza una visita técnica gratuita a tu venue para evaluar arquitectura del espacio, puntos de corriente, estructura de montaje y condiciones de luz natural. Creamos un concepto lumínico personalizado con moodboard y plano técnico que contempla <strong>temperatura de color, intensidad por zona, transiciones sincronizadas</strong> con los momentos clave de tu evento y coordinación total con <strong>sonido, video y decoración</strong> para una producción impecable.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="La iluminación correcta transforma un evento bueno en uno inolvidable"
    subheadline="Recibe un diseño lumínico personalizado con render previo y operador técnico DMX incluido — sin compromiso"
    primaryCTA={{ label: "Cotizar iluminación", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CATÁLOGO — Sub-servicios con Cards
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="catalogo-heading">
    <div class="container">
      <SectionHeader
        id="catalogo-heading"
        title="Nuestro Catálogo de Iluminación"
        subtitle="El concepto lumínico perfecto para cada tipo de evento y presupuesto"
        description={[
          "Desde un ambiental íntimo con fairy lights y velas LED para una boda en un jardín de Coyoacán, hasta un montaje de escenario completo con moving heads y láser para un concierto corporativo en Santa Fe — contamos con el inventario más completo de iluminación profesional para eventos en la Ciudad de México y zona metropolitana.",
          "Cada montaje incluye operador técnico certificado, consola DMX profesional y diseño lumínico personalizado. No solo rentamos equipo: creamos experiencias visuales que transforman por completo la atmósfera de tu celebración."
        ]}
      />

      <div class="grid grid--4">
        {SUB_SERVICES.map((sub) => (
          <Card
            name={sub.name}
            excerpt={sub.excerpt}
            cta={sub.cta}
            href={sub.href}
            icon={sub.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ILUMINACIÓN ARQUITECTÓNICA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="arquitectonica-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Base de todo diseño lumínico</span>
          <h2 class="showcase__title" id="arquitectonica-heading">Iluminación Arquitectónica</h2>
          <p class="showcase__subtitle">Wash lights, uplighting y bañadores de muros LED que transforman la arquitectura del venue con color, profundidad y dimensión profesional.</p>
          <p class="showcase__text">La <strong>iluminación arquitectónica</strong> es el cimiento de cualquier diseño lumínico profesional. Nuestros <strong>wash lights LED RGBWA+UV de 18x15W</strong> bañan muros, columnas, cortinas y techos con color infinitamente personalizable — desde ámbar cálido para bodas elegantes hasta azul eléctrico para lanzamientos corporativos. El <strong>uplighting perimetral</strong> con luminarias IP65 (resistentes a intemperie) es perfecto para jardines, fachadas y eventos al aire libre. Complementa con nuestras <a href="/servicios/carpas/">carpas profesionales</a> y el uplighting transforma la lona en un lienzo de color que envuelve todo el espacio.</p>
          <p class="showcase__text">Cada luminaria opera con protocolo <strong>DMX512 desde consolas GrandMA o Avolites</strong>, permitiendo control individual de color, intensidad y transiciones programadas. Nuestro técnico sincroniza cambios de ambiente con los momentos clave: ceremonia en blanco cálido, brindis en dorado, primer baile en rosa suave, fiesta en colores dinámicos. Incluimos <strong>barras LED de piso y techo</strong>, bañadores de 36x3W para grandes superficies y spots de acento para destacar centros de mesa, pastel o arreglos florales. Combina con <a href="/servicios/audiovisual/">equipo audiovisual</a> para una producción integral.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Wash LED RGBWA+UV</span>
            <span class="showcase__tag">Uplighting IP65</span>
            <span class="showcase__tag">DMX512</span>
            <span class="showcase__tag">Barras LED</span>
            <span class="showcase__tag">CRI 95+</span>
            <span class="showcase__tag">Interior & Exterior</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Arquitectónica
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"/>
              <line x1="12" y1="1" x2="12" y2="3"/>
              <line x1="12" y1="21" x2="12" y2="23"/>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
              <line x1="1" y1="12" x2="3" y2="12"/>
              <line x1="21" y1="12" x2="23" y2="12"/>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ILUMINACIÓN DECORATIVA — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="decorativa-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Lo más solicitado para bodas y sociales</span>
          <h2 class="showcase__title" id="decorativa-heading">Iluminación Decorativa</h2>
          <p class="showcase__subtitle">Fairy lights, candiles de cristal cortado, esferas LED, guirnaldas vintage y velas LED que crean atmósferas mágicas e irresistiblemente fotogénicas.</p>
          <p class="showcase__text">La <strong>iluminación decorativa</strong> es el elemento que convierte un espacio bonito en un escenario de ensueño. Nuestras <strong>fairy lights (luces de hada) de LED blanco cálido 2700K</strong> se instalan como cielo estrellado sobre pistas de baile, en cascadas sobre cortinas o entrelazadas en follaje natural — el efecto más fotografiado en bodas de CDMX. Los <strong>candiles de cristal cortado</strong> en formatos de 60, 80 y 100 cm de diámetro aportan elegancia clásica, mientras que las <strong>esferas LED suspendidas</strong> y las <strong>guirnaldas estilo Edison con filamento vintage</strong> crean un look bohemio-industrial perfecto para jardines y terrazas.</p>
          <p class="showcase__text">Cada instalación decorativa se diseña a medida según la <strong>arquitectura del venue, altura de techo y concepto del evento</strong>. Nuestro equipo instala con rigging profesional certificado — eslingas de acero, motores CM Lodestar y puntos de anclaje verificados — garantizando seguridad total para piezas suspendidas sobre invitados. Complementa con <a href="/servicios/mobiliario/">mobiliario premium</a> y centros de mesa iluminados para una decoración integral. Incluimos <strong>velas LED de cera real con timer</strong>, letras luminosas gigantes y letreros neón personalizados con el nombre de los novios o hashtag del evento.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Fairy Lights 2700K</span>
            <span class="showcase__tag">Candiles Cristal</span>
            <span class="showcase__tag">Esferas LED</span>
            <span class="showcase__tag">Edison Vintage</span>
            <span class="showcase__tag">Letras Luminosas</span>
            <span class="showcase__tag">Neón Personalizado</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Decorativa
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ILUMINACIÓN DE ESCENARIO — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="escenario-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Producción de escenario profesional</span>
          <h2 class="showcase__title" id="escenario-heading">Iluminación de Escenario</h2>
          <p class="showcase__subtitle">Par LED RGBWA, moving heads, follow spots, barras motorizadas y truss de aluminio para tarimas, pasarelas, presentaciones y shows en vivo con control DMX completo.</p>
          <p class="showcase__text">Nuestra <strong>iluminación de escenario</strong> está diseñada para producciones que requieren impacto visual profesional. Equipamos tarimas y escenarios con <strong>par LED de 54x3W RGBWA</strong> como base de color, <strong>moving heads beam 230W Sharpy</strong> para efectos aéreos de alto impacto, <strong>moving heads spot/wash 280W</strong> con gobos personalizables para proyecciones, y <strong>follow spots de 1200W</strong> con operador dedicado para seguir al presentador, novios o artista principal. Todo montado sobre <strong>truss de aluminio certificado</strong> (12", 20" o 24") con rigging profesional.</p>
          <p class="showcase__text">El sistema se controla desde <strong>consolas DMX profesionales GrandMA2/3, Avolites Tiger Touch o ChamSys</strong> operadas por técnicos con experiencia en producción de conciertos, convenciones y shows corporativos. Programamos cues de iluminación sincronizados con la música, presentaciones y momentos clave del evento. Para <strong>conciertos y festivales</strong>, ofrecemos riders técnicos compatibles con artistas nacionales e internacionales. Combina con nuestro <a href="/servicios/audiovisual/">equipo audiovisual profesional</a> — pantallas LED, sonido line array y video — para una producción escénica completa.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Par LED 54x3W</span>
            <span class="showcase__tag">Moving Head 230W</span>
            <span class="showcase__tag">Follow Spot 1200W</span>
            <span class="showcase__tag">Truss Aluminio</span>
            <span class="showcase__tag">GrandMA / Avolites</span>
            <span class="showcase__tag">Rider Compatible</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Escenario
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EFECTOS ESPECIALES — Showcase section
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="efectos-heading">
    <div class="container">
      <div class="showcase">
        <div class="showcase__content">
          <span class="showcase__badge">Momentos WOW garantizados</span>
          <h2 class="showcase__title" id="efectos-heading">Efectos Especiales</h2>
          <p class="showcase__subtitle">Máquinas de humo bajo, láser multicolor, cañones de confeti, sparklers fríos (chispas frías), CO2 criogénico y burbujas. Los efectos que convierten momentos clave en recuerdos épicos.</p>
          <p class="showcase__text">Los <strong>efectos especiales</strong> son el ingrediente secreto de los eventos más memorables. Nuestras <strong>máquinas de humo bajo (ice fog) con hielo seco</strong> crean el icónico efecto nube a ras de piso para el primer baile de los novios — denso, controlado y que se disipa en minutos sin activar alarmas. Los <strong>sparklers fríos (chispas frías)</strong> de titanio generan una cascada de chispas doradas de hasta 3 metros de altura sin calor, sin humo y 100% seguros para interiores — el efecto favorito para la entrada de los novios o el momento del pastel.</p>
          <p class="showcase__text">Para producciones de mayor escala, ofrecemos <strong>láser multicolor de 5W RGB con protocolo ILDA</strong> para shows aéreos programados, <strong>cañones de CO2 criogénico</strong> con chorros de hasta 8 metros que generan explosiones de niebla fría instantánea, <strong>cañones de confeti y serpentinas</strong> manuales o eléctricos, y <strong>máquinas de burbujas profesionales</strong> con fluido no tóxico. Cada efecto se opera con protocolos de seguridad certificados y coordinación con el venue. Complementa con <a href="/servicios/carpas/">carpas profesionales</a> para eventos al aire libre donde los efectos crean un espectáculo sin restricciones de espacio.</p>
          <div class="showcase__tags">
            <span class="showcase__tag">Humo Bajo / Ice Fog</span>
            <span class="showcase__tag">Sparklers Fríos</span>
            <span class="showcase__tag">Láser RGB 5W</span>
            <span class="showcase__tag">CO2 Criogénico</span>
            <span class="showcase__tag">Confeti & Serpentinas</span>
            <span class="showcase__tag">100% Seguro</span>
          </div>
          <a href="#reserva-heading" class="btn btn--primary btn--lg">
            Cotizar Efectos Especiales
          </a>
        </div>
        <div class="showcase__image">
          <div class="showcase__placeholder">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
            </svg>
            <span class="showcase__placeholder-text">Imagen próximamente</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes sobre Iluminación"
        subtitle="Resolvemos tus dudas"
        description={[
          "Antes de reservar tu iluminación, es natural tener preguntas sobre tipos de luminarias, potencia necesaria, operador técnico y logística de montaje. Aquí encontrarás las respuestas a las consultas más comunes de nuestros clientes.",
          "Si no encuentras la respuesta que buscas, escríbenos por WhatsApp y un asesor te responderá de inmediato."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          {faqs.map((faq) => (
            <details class="faq-item">
              <summary class="faq-item__question">
                <span>{faq.question}</span>
                <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="faq-item__answer">
                <p>{faq.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
