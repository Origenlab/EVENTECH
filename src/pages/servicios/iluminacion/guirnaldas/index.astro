  <!-- ── Nav de 4 paquetes + CTA full-width ──
       Nota: se usa <style is:global> con media queries en lugar del atributo
       inline `style=` porque un inline gana siempre a las media queries de
       home-2026.css y rompía el responsive del hm-menu en móvil. -->
  <style is:global>
    .hm-menu__grid--guirnaldas {
      grid-template-columns: repeat(4, 1fr);
    }
    .hm-menu__grid--guirnaldas li:nth-child(4n + 1) {
      border-left: 0;
    }
    .hm-menu__grid--guirnaldas .hm-menu__cta-row {
      grid-column: 1 / -1;
      border-left: 0 !important;
      border-top: 1px solid var(--color-hairline);
    }
    .hm-menu__grid--guirnaldas .hm-menu__item--cta {
      background: var(--color-gold);
      color: #fff;
    }
    @media (max-width: 560px) {
      .hm-menu__grid--guirnaldas {
        grid-template-columns: repeat(2, 1fr);
      }
      .hm-menu__grid--guirnaldas li:nth-child(4n + 1) {
        border-left: 1px solid var(--color-hairline);
      }
      .hm-menu__grid--guirnaldas li:nth-child(2n + 1) {
        border-left: 0;
      }
    }
  </style>

  <script>
    const guirnaldasForm = document.getElementById("guirnaldasForm");
    if (guirnaldasForm) {
      guirnaldasForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const f = e.currentTarget as HTMLFormElement;
        const wa = f.dataset.wa;
        const data = new FormData(f);
        const get = (k: string) => (data.get(k) || "").toString().trim();
        let t = "Hola, quiero cotizar guirnaldas de luces para mi evento.";
        if (get("nombre"))  t += `\nNombre: ${get("nombre")}`;
        if (get("tipo"))    t += `\nTipo de evento: ${get("tipo")}`;
        if (get("fecha"))   t += `\nFecha: ${get("fecha")}`;
        if (get("paquete")) t += `\nPaquete: ${get("paquete")}`;
        if (get("mensaje")) t += `\nDetalles: ${get("mensaje")}`;
        window.open(`https://wa.me/${wa}?text=${encodeURIComponent(t)}`, "_blank", "noopener");
      });
    }
  </script>

