---
/**
 * ─── Canopy de Techo — Patrón de Montaje (Nivel 5, hoja) ───
 * Cielo de focos Edison sobre pista, banquete o carpa. Cable de acero + catenaria.
 * Molde: Template-L5-producto (variante hoja, sin ProductCard de L6).
 * Sin `reviews` — no se publican testimonios que no existan (ver Registro Fase 2).
 *
 * Jerarquía: Servicios > Iluminación > Guirnaldas (hub L4) > Patrón de montaje
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Guirnaldas", href: "/servicios/iluminacion/guirnaldas/" },
  { label: "Canopy de Techo" },
];

const faqs = [
  { question: "¿Cuántos metros de guirnalda necesito para un canopy?", answer: 'Depende del área y de la separación entre líneas. Nuestra separación estándar es de <strong>90 cm a 1.2 m</strong> entre líneas paralelas. Una pista de 6×6 m con líneas cada 90 cm lleva 7 tendidos de 6 metros más las caídas hacia los anclajes: entre <strong>50 y 60 metros</strong> en total. Un área de 10×8 m con la misma densidad ronda los <strong>100 metros</strong>. Si quieres el efecto más denso —techo casi cerrado de focos— bajamos la separación a 60 cm y el metraje sube cerca de un 50%. En la visita técnica medimos y te damos el número exacto, no una estimación.' },
  { question: "¿A qué altura se cuelga un canopy sobre la pista de baile?", answer: 'Entre <strong>2.8 y 3.5 metros</strong> sobre el nivel de piso terminado, medidos en el punto más bajo de la curva. Más arriba de 3.5 m el efecto se diluye y los focos dejan de leerse como un techo; más abajo de 2.8 m un invitado alto se incomoda y las manos levantadas alcanzan el cable. En banquetes, donde nadie está de pie, podemos bajar a 2.6 m sobre la mesa y el efecto envolvente es mayor. La altura se define en sitio, con la gente en mente — no con un número de catálogo.' },
  { question: "¿La guirnalda aguanta el peso o hay que tensar un cable aparte?", answer: 'Se tensa un cable aparte, <strong>siempre</strong>. La guirnalda no es un elemento estructural: si la tensas para que quede recta, el cable se estira, los sockets sufren y a las pocas horas la línea se descuelga desigual. Nosotros montamos un <strong>cable de acero galvanizado con tensores</strong> de anclaje a anclaje, y la guirnalda va colgada de ese cable con ganchos cada metro. La guirnalda solo carga su propio peso —unos 0.35 kg por metro con focos— y la tensión la absorbe el acero.' },
  { question: "¿Por qué la línea no queda recta? ¿Es un defecto?", answer: 'Es intencional y se llama <strong>catenaria</strong>: la curva natural que forma un cable colgado entre dos puntos. Una línea perfectamente tensa se ve rígida, transmite la tensión a los anclajes y termina cediendo de forma irregular. Dejamos una caída deliberada —del orden de <strong>30 a 50 cm por cada 6 metros de claro</strong>— que se ve orgánica, reparte el esfuerzo y aguanta viento sin latigazo. Las fotos de canopy que te gustaron en Pinterest tienen esa curva; solo que nadie la nombra.' },
  { question: "¿Se puede montar un canopy en un salón sin puntos de anclaje?", answer: 'Sí. Cuando no hay vigas, columnas ni estructura de la que colgar, montamos un <strong>perímetro de postes telescópicos de aluminio</strong> con base lastrada, o un <strong>truss perimetral</strong> si el evento lo justifica. Ninguna de las dos soluciones perfora ni toca el techo del venue. En carpas, el canopy va tensado entre los postes de la estructura, nunca de la lona. Y si el salón sí tiene anclajes, los evaluamos antes: el techo de un salón no siempre soporta lo que aparenta.' },
  { question: "¿Un canopy funciona al aire libre con viento?", answer: 'Funciona, con dos ajustes. Primero, aumentamos la caída de la catenaria: una línea más floja oscila, una tensa da latigazo y castiga los anclajes. Segundo, todo el cableado va en versión <strong>IP65</strong>, certificada para lluvia directa. Lo que sí evaluamos con honestidad es la exposición: un canopy sobre una explanada abierta en zona de rachas fuertes se monta con menos claro entre postes, y a veces conviene pasar a un patrón perimetral. Te lo decimos en la visita, no el día del evento.' },
  { question: "¿Cuánto tarda el montaje de un canopy?", answer: 'De <strong>3 a 5 horas</strong> para un canopy de pista estándar (50 a 100 metros), y de 6 a 10 horas cuando se cubren áreas de 200 metros o más. El tiempo se va en lo que no se ve: definir y probar los anclajes, tensar los cables de acero, nivelar la altura de cada línea. El tendido de la guirnalda y el encendido de prueba son la última hora. Por eso llegamos con margen, y en montajes grandes trabajamos el día anterior.' },
  { question: "¿Se puede combinar el canopy con otra iluminación?", answer: 'Es lo habitual y lo recomendable. El canopy resuelve el plano superior pero deja los muros oscuros. La combinación que más montamos en bodas: <strong>canopy sobre la pista + <a href="/servicios/iluminacion/arquitectonica/uplighting/">uplighting ámbar</a> en columnas y muros</strong>, ambos a 2700K para que no choquen las temperaturas de color. Si el techo es muy alto y quieres el efecto de cielo estrellado en vez de focos visibles, lo correcto no es guirnalda Edison sino <a href="/servicios/iluminacion/decorativa/fairy-lights/">fairy lights de micro LED</a>.' },
];

const specs = [
  { label: "Patrón", value: "Líneas paralelas, cruce en aspa o radial desde punto central" },
  { label: "Separación entre líneas", value: "60 cm (denso) · 90 cm–1.2 m (estándar)" },
  { label: "Altura de montaje", value: "2.8–3.5 m sobre pista · 2.6 m sobre mesa" },
  { label: "Caída (catenaria)", value: "30–50 cm por cada 6 m de claro" },
  { label: "Estructura de soporte", value: "Cable de acero galvanizado con tensores de anclaje a anclaje" },
  { label: "Sujeción de la guirnalda", value: "Ganchos al cable de acero cada metro — la guirnalda no tensa" },
  { label: "Peso de la guirnalda", value: "~0.35 kg por metro lineal, con focos" },
  { label: "Anclajes", value: "Vigas, columnas, truss perimetral o postes telescópicos lastrados" },
  { label: "Clasificación IP", value: "IP44 interior / IP65 exterior certificado para lluvia" },
  { label: "Tiempo de montaje", value: "3–5 h (50–100 m) · 6–10 h (200 m+)" },
  { label: "Metraje típico", value: "Pista 6×6 m ≈ 50–60 m · Área 10×8 m ≈ 100 m" },
];

const sidebarNav = [
  { name: "Canopy de Techo", href: null, active: true },
  { name: "Tree Wrap (envolver árboles)", href: "/servicios/iluminacion/guirnaldas/tree-wrap/" },
  { name: "Perimetral y Zigzag", href: "/servicios/iluminacion/guirnaldas/perimetral-y-zigzag/" },
  { name: "Pérgolas y Arcos", href: "/servicios/iluminacion/guirnaldas/pergolas-y-arcos/" },
];

const sidebarPaquetes = [
  { name: "50 metros — $3,500", href: "/servicios/iluminacion/guirnaldas/50-metros/" },
  { name: "100 metros — $6,500", href: "/servicios/iluminacion/guirnaldas/100-metros/" },
  { name: "200 metros — $11,500", href: "/servicios/iluminacion/guirnaldas/200-metros/" },
  { name: "500 metros — $24,000", href: "/servicios/iluminacion/guirnaldas/500-metros/" },
];

const sidebarRelated = [
  { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
  { name: "Fairy Lights Micro LED", href: "/servicios/iluminacion/decorativa/fairy-lights/" },
  { name: "Carpas Estructurales", href: "/servicios/carpas/estructurales/" },
  { name: "Pistas de Baile", href: "/servicios/pistas-baile/" },
  { name: "Plantas de Energía", href: "/servicios/accesorios/plantas-energia/" },
];

const jsonLd = [
  serviceJsonLd({
    name: "Canopy de Guirnaldas de Luces sobre Pista y Banquete en CDMX",
    description: "Montaje de canopy de guirnaldas Edison sobre pista de baile, banquete y carpas en CDMX. Cable de acero con tensores, catenaria calculada y altura ajustada al venue. Desde $3,500.",
    url: "/servicios/iluminacion/guirnaldas/canopy-de-techo/",
    image: "/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif",
    priceRange: { min: 3500, max: 24000 },
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Guirnaldas", url: "/servicios/iluminacion/guirnaldas/" },
    { name: "Canopy de Techo", url: "/servicios/iluminacion/guirnaldas/canopy-de-techo/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Canopy de Guirnaldas sobre Pista y Banquete en CDMX | Equipo para eventos en México"
  rawTitle={true}
  image="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif"
  description="Canopy de guirnaldas Edison sobre pista, banquete o carpa en CDMX. Cable de acero, catenaria calculada y altura ajustada al venue. Desde $3,500."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- 1. HERO -->
  <HeroPage
    badge="El patrón más fotografiado"
    title='<span class="highlight">Canopy de guirnaldas</span> — el techo de focos que convierte un jardín en un cielo'
    subtitle="Líneas de focos Edison tendidas sobre la pista, el banquete o toda la carpa. Cable de acero con tensores, catenaria calculada y altura pensada para la gente que va a estar debajo. El efecto que aparece en cada foto de la noche."
    primaryCTA={{ label: "Cotizar mi canopy", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un canopy de guirnaldas para mi evento` }}
    cards={[
      {
        title: "El plano que nadie ilumina y todos miran",
        content: "Un salón bien decorado sigue teniendo un techo negro encima. El <strong>canopy</strong> resuelve ese vacío: tiende líneas paralelas de focos Edison de anclaje a anclaje, a una altura donde se leen como un techo bajo de luz cálida y no como cables colgados. Separación estándar de <strong>90 cm a 1.2 m</strong> entre líneas; a 60 cm el efecto es un techo casi cerrado. Es el patrón que la gente fotografía sin que nadie se lo pida, y el que hace que el espacio se sienta más íntimo de lo que mide.",
      },
      {
        title: "La curva es el oficio",
        content: "La diferencia entre un canopy profesional y unas luces colgadas está en dos decisiones invisibles. La primera: <strong>la guirnalda nunca carga tensión</strong>. Va colgada de un cable de acero galvanizado tensado aparte, con ganchos cada metro. La segunda: <strong>la catenaria</strong> —la caída deliberada de 30 a 50 cm por cada 6 metros de claro— que hace que la línea se vea orgánica, reparta el esfuerzo y aguante viento sin latigazo. Tensar la guirnalda para que quede recta es el error que descuelga la mitad del montaje a las tres horas.",
      },
    ]}
  />

  <!-- 2. CTA BANNER -->
  <CTABanner
    headline="¿Tienes las medidas de tu pista o de tu carpa?"
    subheadline="Con eso y unas fotos calculamos el metraje exacto, la altura y los puntos de anclaje — propuesta el mismo día"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- MOBILE SIDEBAR -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Patrones de Montaje</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Paquetes por Metraje</h2>
          <ul class="sidebar-related">
            {sidebarPaquetes.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Quieres un canopy sobre tu pista?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar un canopy de guirnaldas para mi evento`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAIN + SIDEBAR -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <div class="l4-main">

          <!-- SPECS -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones de montaje — Canopy de techo</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- SHOWCASE 1 -->
          <section class="section" aria-labelledby="pista-heading">
            <ServiceShowcase
              title="Canopy sobre la pista de baile"
              headingId="pista-heading"
              badge="El punto de foto de la noche"
              subtitle="Líneas cada 90 cm a 3 metros de altura: el techo de focos bajo el que se baila y se fotografía toda la fiesta."
              tags={["Pista 6×6 m ≈ 50–60 m", "Altura 2.8–3.5 m", "Cable de acero", "Dimmer por zona"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar canopy de pista"
            >
              <Fragment slot="body">
                <p class="showcase__text">La pista es el único lugar del evento donde la gente mira hacia arriba. Un canopy de <strong>líneas paralelas cada 90 centímetros</strong>, tendido a <strong>3 metros sobre el piso</strong>, cierra visualmente ese plano y baja la escala del espacio: una pista de 6×6 m en medio de un jardín enorme deja de sentirse expuesta y se vuelve un cuarto sin paredes.</p>
                <p class="showcase__text">El metraje sale de la cuenta, no del ojo: siete tendidos de 6 metros más las caídas hacia los anclajes suman entre <strong>50 y 60 metros</strong> — justo el <a href="/servicios/iluminacion/guirnaldas/50-metros/">paquete de 50 m</a>, o el de 100 si además quieres cubrir el banquete. Sumamos <strong>dimmer</strong> para que la pista viva a media intensidad durante la cena y llegue al 100% cuando arranca la música. La luz acompaña el guion del evento, no lo aplana.</p>
              </Fragment>
              <Fragment slot="media">
                <img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Canopy de guirnaldas Edison sobre pista de baile en boda en CDMX" width="1200" height="686" loading="lazy" />
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE 2 -->
          <section class="section" aria-labelledby="carpa-heading">
            <ServiceShowcase
              title="Canopy dentro de carpa"
              headingId="carpa-heading"
              badge="Sin tocar la lona"
              subtitle="Tendido entre los postes de la estructura: la carpa deja de ser un techo blanco y se vuelve un cielo cálido."
              tags={["Anclaje a estructura", "Nunca a la lona", "Interior IP44", "Carpas estructurales"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar canopy en carpa"
            >
              <Fragment slot="body">
                <p class="showcase__text">Una carpa resuelve el clima y crea un problema estético: por dentro es una superficie blanca, plana y alta que aplana todo lo que hay debajo. El canopy la corrige sin tocarla. Las líneas se tensan <strong>entre los postes de la estructura metálica</strong>, nunca de la lona —la lona no es un punto de anclaje, y quien la usa como tal termina con desgarres y una discusión con el proveedor de la <a href="/servicios/carpas/estructurales/">carpa</a>.</p>
                <p class="showcase__text">Bajo carpa trabajamos con la línea <strong>IP44 de interior</strong>, que basta y cuesta menos de operar. La altura se ajusta a la del faldón: en una carpa de 3 m de altura libre bajamos el canopy a 2.8 m y el efecto envolvente aumenta. Si el evento es de <a href="/servicios/iluminacion/guirnaldas/200-metros/">200 metros o más</a>, dividimos el tendido en circuitos independientes para poder regular la carpa por zonas.</p>
              </Fragment>
              <Fragment slot="media">
                <img src="/images/guirnaldas/renta-guirnaldas-100m-techo-carpa.avif" alt="Canopy de guirnaldas tendido entre los postes de una carpa para evento" width="1200" height="686" loading="lazy" />
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- SHOWCASE 3 -->
          <section class="section" aria-labelledby="combo-heading">
            <ServiceShowcase
              title="Canopy + uplighting: arriba y abajo"
              headingId="combo-heading"
              badge="La combinación que más montamos"
              subtitle="El canopy resuelve el techo pero deja los muros negros. El uplighting ámbar cierra el diseño con una sola temperatura de color."
              tags={["2700K en ambos", "Un solo traslado", "Diseño integral", "Haciendas"]}
              ctaHref="#reserva-heading"
              ctaLabel="Cotizar el combo completo"
            >
              <Fragment slot="body">
                <p class="showcase__text">Un canopy solo ilumina el plano superior. Si los muros, columnas o arcos de la hacienda se quedan oscuros, el ojo lee el espacio como una isla de luz flotando en la nada. La corrección es <a href="/servicios/iluminacion/arquitectonica/uplighting/">uplighting perimetral</a> bañando las superficies verticales — y la clave está en que ambos vayan a la misma temperatura de color.</p>
                <p class="showcase__text">Trabajamos los dos a <strong>2700K</strong>: el ámbar del uplighting continúa el tono del filamento Edison en lugar de pelearse con él. Un uplighting frío bajo un canopy cálido produce esa sensación de "algo no cuadra" que nadie sabe nombrar y todo el mundo percibe en las fotos. Al contratar ambos con nosotros compartes traslado, montaje y operador — y el técnico afina las dos capas con el mismo criterio.</p>
              </Fragment>
              <Fragment slot="media">
                <img src="/images/guirnaldas/guirnaldas-100m-combo-canopy-uplighting.avif" alt="Canopy de guirnaldas combinado con uplighting ámbar en columnas de hacienda" width="1200" height="686" loading="lazy" />
              </Fragment>
            </ServiceShowcase>
          </section>

          <!-- GALERÍA -->
          <section class="section" aria-labelledby="galeria-heading">
            <div class="container">
              <h2 class="section-header__title" id="galeria-heading">Galería — Canopy de guirnaldas</h2>
              <p class="section-header__description">Montajes de canopy sobre pista, banquete, carpa y salón en CDMX y zona metropolitana.</p>
              <div class="galeria-grid">
                <img src="/images/guirnaldas/renta-guirnaldas-canopy-techo-boda.avif" alt="Canopy de guirnaldas sobre pista en boda de jardín" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/renta-guirnaldas-100m-techo-carpa.avif" alt="Canopy de guirnaldas tendido en el techo de una carpa" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/guirnaldas-edison-techo-salon-eventos.avif" alt="Canopy de focos Edison en el techo de un salón de eventos" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/guirnaldas-100m-iluminacion-pista-baile.avif" alt="Pista de baile iluminada con canopy de guirnaldas Edison" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/guirnaldas-100m-combo-canopy-uplighting.avif" alt="Canopy de guirnaldas combinado con uplighting perimetral" width="600" height="343" loading="lazy" />
                <img src="/images/guirnaldas/renta-guirnaldas-50m-zigzag-techo.avif" alt="Canopy en cruce de aspa sobre área de banquete" width="600" height="343" loading="lazy" />
