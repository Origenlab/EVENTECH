---
/**
 * ─── Guirnaldas Edison 500 Metros — Página de Paquete (Nivel 5) ───
 * Paquete de 500m con ~1,000 focos LED Edison, sockets cada 0.5m, cable negro.
 * Para bodas monumentales, festivales multi-día y explanadas. Color accent: Amber #c2a24a.
 *
 * Jerarquía: Servicios > Iluminación > Guirnaldas (hub L4) > Paquete 500m
 */
import PageLayout from "@layouts/PageLayout.astro";
import ServiceShowcase from "@components/ServiceShowcase.astro";
import HeroPage from "@components/HeroPage.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import { SITE } from "@config/site";
import { serviceWithReviewJsonLd, breadcrumbJsonLd, faqJsonLd } from "@lib/seo";
import '@styles/l3-shared.css';
import '@styles/l4-shared.css';
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProveedorIluminacion from "@components/ProveedorIluminacion.astro";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Servicios", href: "/servicios/" },
  { label: "Iluminación", href: "/servicios/iluminacion/" },
  { label: "Guirnaldas", href: "/servicios/iluminacion/guirnaldas/" },
  { label: "Guirnaldas 500m" },
];

const faqs = [
  { question: "¿Para cuántas personas alcanza el paquete de 500 metros de guirnaldas Edison?", answer: 'El paquete de 500 metros está diseñado para <strong>eventos de gran escala de 500 a 1,000+ personas</strong>. Cubre hasta 500 m² de espacio con 1,000 focos LED Edison — ideal para bodas monumentales en haciendas con explanadas amplias, festivales gastronómicos de varios días, ferias corporativas con decenas de stands, bazares navideños y eventos masivos al aire libre. Con este metraje puedes cubrir múltiples zonas completas sin comprometer la densidad lumínica en ningún área.' },
  { question: "¿500 metros de guirnaldas necesitan instalación eléctrica especial?", answer: 'Sí, el consumo total de 500 metros es de aproximadamente <strong>2,000W</strong>, lo que requiere distribuir la carga en <strong>al menos 5 circuitos eléctricos</strong> independientes para operar con seguridad. Nuestro equipo técnico realiza una evaluación eléctrica previa del venue y diseña un plano de distribución de circuitos. En venues con capacidad limitada de tomas, incluimos <strong>tableros de distribución portátiles</strong> sin costo adicional. Para festivales o explanadas sin instalación fija, coordinamos con proveedores de <a href="/servicios/accesorios/plantas-energia/">plantas de energía</a>.' },
  { question: "¿Cuánto tiempo toma el montaje de 500 metros de guirnaldas?", answer: 'El montaje profesional de 500 metros toma entre <strong>8 y 12 horas</strong>, dependiendo de la complejidad del espacio y la cantidad de zonas a cubrir. Para esta escala, nuestro equipo de <strong>4-5 técnicos</strong> trabaja en paralelo dividiendo el venue en secciones. Recomendamos programar el montaje <strong>el día anterior al evento</strong> para tener margen de ajustes y pruebas de iluminación al atardecer. Para festivales de varios días, el montaje se realiza con mayor anticipación. El desmontaje posterior toma aproximadamente 5-6 horas.' },
  { question: "¿Se puede cubrir un festival completo de varios días con 500 metros?", answer: 'Absolutamente. El paquete de 500 metros es nuestra opción principal para <strong>festivales, ferias y eventos multi-día</strong>. Las guirnaldas Edison LED tienen una vida útil de más de 25,000 horas — pueden permanecer encendidas durante días sin degradación. Para festivales, incluimos <strong>revisión técnica diaria</strong> donde verificamos que todos los focos funcionen correctamente y ajustamos la tensión de los cables si es necesario. La versión IP65 soporta lluvia, humedad y cambios de temperatura durante toda la duración del evento.' },
  { question: "¿Puedo combinar 500 metros de Edison con otras iluminaciones para un evento masivo?", answer: 'Sí, y para eventos de esta escala es altamente recomendable crear un <strong>diseño de iluminación integral por zonas</strong>. Las combinaciones más populares para 500m+: Edison sobre pasillos y food courts + <a href="/servicios/iluminacion/decorativa/candiles/">candiles de cristal</a> en zona VIP + <a href="/servicios/iluminacion/decorativa/esferas-led/">esferas luminosas</a> en jardines + <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights</a> en escenario + <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas</a> de marca en la entrada. Nuestro diseñador crea un master plan donde cada tipo de iluminación cumple un rol específico.' },
  { question: "¿Cuántos dimmers incluye el paquete de 500 metros?", answer: 'El paquete de 500 metros incluye <strong>5 dimmers regulables independientes</strong> — uno por cada circuito de 100 metros. Esto permite controlar la intensidad de cada zona del evento por separado: más tenue en la zona de cena, brillo medio en pasillos, máxima intensidad en la zona de bienvenida, y regulación especial para la zona de coctel. Los dimmers permiten ajustar del 10% al 100% y también incluyen <strong>temporizadores automáticos</strong> para encendido y apagado programado — útil para festivales donde las luces se encienden al atardecer y se apagan al cierre.' },
];

const specs = [
  { label: "Precio del paquete", value: "$24,000 MXN + IVA — transporte, montaje, operación y desmontaje incluidos" },
  { label: "Longitud total", value: "500 metros" },
  { label: "Número de focos", value: "~1,000 focos LED Edison" },
  { label: "Separación entre sockets", value: "50 cm" },
  { label: "Tipo de foco", value: "LED Edison vintage filamento 2W" },
  { label: "Temperatura de color", value: "2700K (warm white)" },
  { label: "Cable", value: "Negro industrial, calibre 16 AWG" },
  { label: "Conexión", value: "Plug & play, encadenable" },
  { label: "Consumo total", value: "~2,000W (5 circuitos recomendados)" },
  { label: "Cobertura aproximada", value: "~500 m²" },
  { label: "Clasificación IP", value: "IP44 interior / IP65 disponible" },
  { label: "Incluye", value: "5 dimmers, tablero distribución, ganchos, montaje y desmontaje" },
];

const sidebarNav = [
  { name: "Guirnaldas 50m (100 focos)", href: "/servicios/iluminacion/guirnaldas/50-metros/" },
  { name: "Guirnaldas 100m (200 focos)", href: "/servicios/iluminacion/guirnaldas/100-metros/" },
  { name: "Guirnaldas 200m (400 focos)", href: "/servicios/iluminacion/guirnaldas/200-metros/" },
  { name: "Guirnaldas 500m (1,000 focos)", href: null, active: true },
];

const sidebarRelated = [
  { name: "Canopy de Techo", href: "/servicios/iluminacion/guirnaldas/canopy-de-techo/" },
  { name: "Perimetral y Zigzag", href: "/servicios/iluminacion/guirnaldas/perimetral-y-zigzag/" },
  { name: "Pérgolas y Arcos", href: "/servicios/iluminacion/guirnaldas/pergolas-y-arcos/" },
  { name: "Candiles y Candelabros", href: "/servicios/iluminacion/decorativa/candiles/" },
  { name: "Esferas y Figuras LED", href: "/servicios/iluminacion/decorativa/esferas-led/" },
  { name: "Letras Luminosas", href: "/servicios/iluminacion/decorativa/letras-luminosas/" },
  { name: "Wash Lights LED", href: "/servicios/iluminacion/arquitectonica/wash-lights/" },
  { name: "Uplighting Perimetral", href: "/servicios/iluminacion/arquitectonica/uplighting/" },
];

const reviews = [
  { author: "Ricardo Salazar", text: "Organizamos un festival gastronómico de 3 días para 2,000 personas y las 500 metros de guirnaldas Edison fueron el alma del evento. Cubrieron 12 pasillos entre food trucks, la zona de mesas comunales y el escenario de música. El efecto de mercado europeo fue exactamente lo que buscábamos. El equipo de 4 técnicos montó todo en un día y la revisión diaria mantuvo todo impecable los 3 días.", rating: 5, date: "2025-12-20" },
  { author: "Paulina Navarro", text: "Nuestra boda fue en una hacienda enorme en Tepotzotlán con 400 invitados. Con 500 metros de Edison cubrimos la explanada, el corredor, los jardines laterales y el patio de coctel. Fue como entrar a otro mundo — cada rincón de la hacienda brillaba con esa luz cálida vintage. Los 1,000 focos crearon un escenario de película que todos nuestros invitados recordarán por siempre.", rating: 5, date: "2025-11-15" },
  { author: "Marcos Delgado", text: "Para nuestro evento corporativo de fin de año de 600 personas en una terraza industrial de Polanco, las guirnaldas Edison de 500 metros transformaron por completo el espacio. El equipo de Eventech fue excepcional — los 5 dimmers nos permitieron crear ambientes diferentes en cada zona. La combinación con wash lights en el escenario fue espectacular. Definitivamente repetiremos.", rating: 5, date: "2025-10-28" },
];

const jsonLd = [
  serviceWithReviewJsonLd({
    name: "Renta de Guirnaldas Edison 500 Metros para Eventos Masivos en CDMX",
    description: "Renta de guirnaldas Edison de 500 metros con 1,000 focos LED vintage para bodas monumentales, festivales y eventos corporativos masivos en CDMX.",
    url: "/servicios/iluminacion/guirnaldas/500-metros/",
    priceRange: { min: 24000, max: 24000 },
    reviews,
    ratingValue: 5,
    reviewCount: 3,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Servicios", url: "/servicios/" },
    { name: "Iluminación", url: "/servicios/iluminacion/" },
    { name: "Guirnaldas", url: "/servicios/iluminacion/guirnaldas/" },
    { name: "Guirnaldas 500m", url: "/servicios/iluminacion/guirnaldas/500-metros/" },
  ]),
  faqJsonLd(faqs),
];
---

<PageLayout
  title="Guirnaldas Edison 500m — 1,000 Focos LED en CDMX | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de guirnaldas Edison de 500 metros con 1,000 focos LED vintage para bodas monumentales, festivales y eventos corporativos masivos en CDMX."
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <!-- ═══════════════════════════════════════════════════════════════════════
       1. HERO (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Para eventos masivos y festivales"
    title='Renta de <span class="highlight">Guirnaldas Edison 500 Metros</span> — 1,000 Focos LED'
    subtitle="Nuestro paquete más grande para bodas monumentales de 500+ invitados, festivales multi-día, ferias corporativas y explanadas completas. 1,000 focos LED Edison vintage con cobertura de hasta 500 m². Equipo de 4-5 técnicos con montaje el día previo."
    primaryCTA={{ label: "Cotiza el paquete 500m", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar el paquete de guirnaldas Edison de 500 metros` }}
    cards={[
      {
        title: "1,000 focos Edison LED — cobertura total para eventos masivos",
        content: "<strong>Paquete de 500 metros de guirnaldas Edison LED</strong> con aproximadamente 1,000 focos de filamento visible estilo vintage distribuidos cada 50 centímetros. Cobertura de hasta 500 m² — suficiente para explanadas completas de haciendas, festivales con decenas de stands, food courts multi-pasillo, ferias corporativas y bodas monumentales con múltiples zonas simultáneas. Cable negro industrial calibre 16 AWG, clasificación IP44 interior e IP65 disponible para exteriores. Sistema plug & play distribuido en 5 circuitos eléctricos independientes con tablero de distribución.",
      },
      {
        title: "Equipo de 4-5 técnicos y montaje el día previo",
        content: "<strong>Equipo profesional de 4-5 técnicos especializados</strong> para montaje de 8-12 horas (programado el día anterior al evento). Incluye instalación de todos los puntos de anclaje, tendido de guirnaldas en diseño personalizado, conexión eléctrica con 5 dimmers regulables independientes (10%-100%) para control por zonas, tablero de distribución portátil, extensiones profesionales y desmontaje completo sin costo. Técnico de guardia durante el evento para ajustes en tiempo real. Para festivales multi-día, revisión técnica diaria incluida.",
      },
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       2. CTA BANNER (full-width)
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Planeas un evento masivo de 500+ personas?"
    subheadline="El paquete de 500 metros cubre explanadas completas, festivales y haciendas monumentales — cotiza sin compromiso"
    primaryCTA={{ label: "Cotizar ahora", href: "#reserva-heading" }}
    secondaryCTA={{ label: "Llamar a un asesor", href: `tel:${SITE.contact.phoneRaw}` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       MOBILE SIDEBAR — Se muestra solo en ≤1024px
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="l4-mobile-nav" aria-label="Navegación rápida">
    <div class="container">
      <div class="l4-sidebar--mobile">
        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Paquetes de Guirnaldas</h2>
          <ul class="sidebar-nav">
            {sidebarNav.map((item) => (
              <li class="sidebar-nav__item">
                {item.active ? (
                  <span class="sidebar-nav__link sidebar-nav__link--active">{item.name}</span>
                ) : (
                  <a href={item.href} class="sidebar-nav__link">{item.name}</a>
                )}
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card">
          <h2 class="sidebar-card__title">Servicios Relacionados</h2>
          <ul class="sidebar-related">
            {sidebarRelated.map((item) => (
              <li>
                <a href={item.href} class="sidebar-related__link">
                  <span class="sidebar-related__arrow">&rarr;</span>
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div class="sidebar-card sidebar-card--cta">
          <h2 class="sidebar-card__title">Cotiza Ahora</h2>
          <p class="sidebar-card--cta-text">¿Necesitas guirnaldas Edison para tu evento masivo?</p>
          <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, quiero cotizar el paquete de guirnaldas Edison de 500 metros`} target="_blank" rel="noopener noreferrer" class="sidebar-cta__btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="sidebar-cta__phone">{SITE.contact.phone}</a>
          <a href="#reserva-heading" class="sidebar-cta__form-link">O completa el formulario &darr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       MAIN CONTENT + SIDEBAR (desktop grid)
       ═══════════════════════════════════════════════════════════════════════ -->
  <div class="l4-content-section">
    <div class="container">
      <div class="l4-layout">
        <!-- ═══════════════════════════════════════════════════════════════
             MAIN CONTENT COLUMN
             ═══════════════════════════════════════════════════════════════ -->
        <div class="l4-main">

          <!-- 3. SPECS TABLE -->
          <section aria-labelledby="specs-heading">
            <div class="specs-table">
              <div class="specs-table__header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                <h2 class="specs-table__header-title" id="specs-heading">Especificaciones Técnicas — Guirnaldas Edison 500m</h2>
              </div>
              <div class="specs-table__body">
                {specs.map((spec) => (
                  <div class="specs-table__row">
                    <div class="specs-table__label">{spec.label}</div>
                    <div class="specs-table__value">{spec.value}</div>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <!-- 4. SHOWCASE: Bodas Monumentales y Haciendas -->
          <section class="section" aria-labelledby="bodas-heading">
            <ServiceShowcase
    title="Bodas Monumentales y Haciendas Completas"
    headingId="bodas-heading"
    badge="Para 500+ invitados"
    subtitle="1,000 focos Edison cubriendo explanadas, jardines, corredores y múltiples zonas simultáneas en haciendas y fincas de gran escala."
    tags={["500+ invitados", "Haciendas completas", "Cobertura 500 m²", "4 zonas independientes"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar para Boda Monumental"
  >
    <Fragment slot="body">
      <p class="showcase__text">El <strong>paquete de 500 metros de guirnaldas Edison</strong> transforma haciendas y fincas completas en escenarios de ensueño para bodas de 500+ invitados. Con 1,000 focos LED Edison cubrimos hasta 500 m² — suficiente para <strong>explanada de ceremonia + banquete completo + pista de baile + coctel + corredores de acceso + zona de fotografía</strong>, todo bajo un manto continuo de luz cálida vintage que envuelve cada rincón del venue.</p>
      <p class="showcase__text">La distribución típica para haciendas monumentales: 150-200m en zigzag sobre la explanada principal de banquete, 80-100m cubriendo los corredores y pasillos de acceso, 60-80m en el jardín de coctel y zona de ceremonia, y 40-60m enmarcando la pista de baile y zona de bar. Los <strong>5 dimmers independientes</strong> permiten modular cada zona — luz íntima en el banquete, brillo festivo en la pista. Combinación espectacular con <a href="/servicios/carpas/estructurales/">carpas estructurales</a> para bodas donde parte del evento es bajo techo y parte al aire libre.</p>
    </Fragment>
    <Fragment slot="media">
      <img src="/images/guirnaldas/guirnaldas-edison-400-metros-evento-masivo.avif" alt="Guirnaldas Edison 500 metros para evento masivo y boda monumental" width="1200" height="686" loading="lazy" />
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 5. SHOWCASE: Festivales, Ferias y Eventos Multi-Día -->
          <section class="section" aria-labelledby="festivales-heading">
            <ServiceShowcase
    title="Festivales, Ferias y Eventos Multi-Día"
    headingId="festivales-heading"
    badge="Festivales y ferias multi-día"
    subtitle="1,000 focos Edison sobre food courts, pasillos de stands, escenarios y zonas de descanso para festivales de gran formato."
    tags={["Festivales gastronómicos", "Bazares navideños", "Multi-día", "Revisión técnica diaria"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar para Festival o Feria"
  >
    <Fragment slot="body">
      <p class="showcase__text">Las <strong>500 metros de guirnaldas Edison</strong> son la solución para festivales gastronómicos, bazares navideños, ferias corporativas y eventos multi-día de gran formato. La distribución típica para un festival: <strong>líneas paralelas sobre 15-20 pasillos</strong> entre stands o food trucks, zonas de mesas comunales con zigzag denso, perímetro del escenario principal y área de descanso. Los 1,000 focos crean una <strong>atmósfera envolvente de mercado vintage</strong> que unifica visualmente todo el evento.</p>
      <p class="showcase__text">Para festivales de varios días, nuestras guirnaldas Edison LED tienen vida útil de 25,000+ horas — operan sin degradación durante toda la duración del evento. Incluimos <strong>revisión técnica diaria</strong> (verificación de focos, tensión de cables, conexiones eléctricas) y técnico disponible para reparaciones inmediatas. La versión IP65 soporta lluvia, humedad y cambios de temperatura. Combinación ideal con <a href="/servicios/catering/estaciones-servicio/">estaciones de servicio de catering</a> para crear zonas gastronómicas con ambientación profesional de primera.</p>
    </Fragment>
    <Fragment slot="media">
      <img src="/images/guirnaldas/renta-guirnaldas-500m-festival-musica.avif" alt="Renta guirnaldas Edison 500m festival de música" width="1200" height="686" loading="lazy" />
    </Fragment>
  </ServiceShowcase>
          </section>

          <!-- 6. SHOWCASE: Master Plan de Iluminación Integral -->
          <section class="section" aria-labelledby="masterplan-heading">
            <ServiceShowcase
    title="Master Plan — Iluminación Integral a Gran Escala"
    headingId="masterplan-heading"
    badge="Diseño de iluminación completo"
    subtitle="Edison como base + candiles + esferas + wash lights + letras: un master plan de iluminación que transforma todo el venue."
    tags={["Master plan", "Control centralizado", "Múltiples elementos", "Clase mundial"]}
    ctaHref="#reserva-heading"
    ctaLabel="Cotizar Master Plan"
  >
    <Fragment slot="body">
      <p class="showcase__text">Para eventos de esta magnitud, el <strong>paquete de 500 metros de guirnaldas Edison</strong> se convierte en la columna vertebral de un <strong>master plan de iluminación integral</strong>. La base Edison cubre el espacio general con luz cálida vintage uniforme, sobre la cual se superponen elementos focales: <a href="/servicios/iluminacion/decorativa/candiles/">candiles de cristal</a> sobre la zona VIP, <a href="/servicios/iluminacion/decorativa/esferas-led/">esferas luminosas</a> en jardines, <a href="/servicios/iluminacion/arquitectonica/wash-lights/">wash lights LED</a> bañando escenarios y fachadas, y <a href="/servicios/iluminacion/decorativa/letras-luminosas/">letras luminosas</a> gigantes de marca o nombre del evento en la entrada principal.</p>
      <p class="showcase__text">Nuestro <strong>diseñador de iluminación</strong> crea un plano técnico por zonas donde cada tipo de luz cumple un rol específico: Edison para ambientación general, candiles para elegancia focal, esferas para puntos de interés, wash para drama arquitectónico y letras para branding. Los 5 dimmers del paquete 500m + los controladores de los demás elementos se coordinan desde un <strong>punto de control centralizado</strong> que permite orquestar la iluminación completa del evento. Este nivel de diseño integral es lo que distingue un evento de clase mundial.</p>
    </Fragment>
    <Fragment slot="media">
      <img src="/images/guirnaldas/guirnaldas-500m-feria-exposicion-cdmx.avif" alt="Guirnaldas Edison 500m feria exposición CDMX" width="1200" height="686" loading="lazy" />
    </Fragment>
  </ServiceShowcase>
