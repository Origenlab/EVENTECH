---
/**
 * ─── Blog Post Dynamic Route ───
 * Generates a page for each blog post in the content collection.
 */
import BlogLayout from "@layouts/BlogLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }: CollectionEntry<"blog">) => !data.draft);
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props as CollectionEntry<"blog">;
const { Content } = await render(post);
---

<BlogLayout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.seoDescription ?? post.data.description}
  date={post.data.date}
  updatedDate={post.data.updatedDate}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  heroIntro={post.data.heroIntro}
  author={post.data.author}
  body={post.body}
  slug={post.id}
  category={post.data.category}
  tags={post.data.tags}
  relatedPosts={post.data.relatedPosts}
>
  <Content />
</BlogLayout>
