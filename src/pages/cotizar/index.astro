---
/**
 * ─── Cotizar ───
 * Página de cotización general. Formulario WhatsApp con las 8 categorías de servicio.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import Card from "@components/Card.astro";
import { SITE } from "@data/site";
import { breadcrumbJsonLd } from "@utils/seo";

const breadcrumbItems = [
  { name: "Inicio", url: "/" },
  { name: "Cotizar", url: "/cotizar/" },
];
---

<PageLayout
  title="Cotiza tu Evento en CDMX"
  description="Solicita una cotización personalizada para tu evento. Mobiliario, audiovisual, carpas, iluminación, pistas de baile, inflables, catering y accesorios. Respuesta en menos de 30 minutos."
  jsonLd={[breadcrumbJsonLd(breadcrumbItems)]}
>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Cotización gratuita y sin compromiso"
    title='Cotiza tu <span class="highlight">Evento</span> en CDMX'
    subtitle="Completa el formulario y recibe una cotización personalizada por WhatsApp en menos de 30 minutos. Mobiliario, audiovisual, carpas, iluminación y más para bodas, XV años, corporativos y eventos sociales."
    primaryCTA={{ label: "Ir al formulario", href: "#cotizar-heading" }}
    secondaryCTA={{ label: "Ver catálogo", href: "/servicios/" }}
    cards={[
      {
        title: "Cotización personalizada",
        content: "<strong>Cotiza sin compromiso</strong> y recibe una propuesta adaptada a tu evento. Nuestro equipo de asesores analiza tus necesidades — tipo de evento, número de invitados, sede y fecha — para ofrecerte el paquete ideal con los mejores precios del mercado."
      },
      {
        title: "Respuesta inmediata por WhatsApp",
        content: "<strong>Respuesta garantizada</strong> en menos de 30 minutos durante horario de atención. Te contactamos directamente por WhatsApp con tu cotización detallada, opciones de paquetes y disponibilidad para tu fecha."
      }
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Más de 500 eventos realizados en CDMX"
    subheadline="Desde bodas íntimas hasta festivales de 2,000 personas. Cuéntanos sobre tu evento y te ayudamos a hacerlo realidad."
    primaryCTA={{ label: "Cotizar ahora", href: "#cotizar-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICIOS DISPONIBLES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="servicios-heading">
    <div class="container">
      <SectionHeader
        id="servicios-heading"
        title="Nuestros Servicios"
        subtitle="Todo lo que necesitas para tu evento"
        description={[
          "Contamos con el catálogo más completo de equipo para eventos en la Ciudad de México. Desde mobiliario premium y sistemas audiovisuales hasta carpas estructurales e iluminación profesional.",
          "Selecciona la categoría que te interesa en el formulario de abajo, o elige 'Paquete integral' si necesitas varios servicios para tu evento."
        ]}
      />

      <div class="grid grid--4">
        <Card
          name="Mobiliario"
          excerpt="Sillas, mesas, salas lounge y barras para cualquier tipo de evento."
          cta="Ver mobiliario"
          href="/servicios/mobiliario/"
          icon="chair"
        />
        <Card
          name="Audiovisual"
          excerpt="Pantallas LED, sonido profesional, proyectores y equipo DJ."
          cta="Ver audiovisual"
          href="/servicios/audiovisual/"
          icon="speaker"
        />
        <Card
          name="Carpas"
          excerpt="Carpas árabes, estructurales, hangar y complementos."
          cta="Ver carpas"
          href="/servicios/carpas/"
          icon="tent"
        />
        <Card
          name="Iluminación"
          excerpt="Arquitectónica, decorativa, escenario y efectos especiales."
          cta="Ver iluminación"
          href="/servicios/iluminacion/"
          icon="lightbulb"
        />
        <Card
          name="Pistas de Baile"
          excerpt="LED, madera clásica, vintage, tarimas y escenarios."
          cta="Ver pistas"
          href="/servicios/pistas-baile/"
          icon="music"
        />
        <Card
          name="Inflables"
          excerpt="Juegos infantiles, acuáticos, adultos e interactivos."
          cta="Ver inflables"
          href="/servicios/inflables/"
          icon="balloon"
        />
        <Card
          name="Catering"
          excerpt="Estaciones, cocina móvil, vajilla y refrigeración."
          cta="Ver catering"
          href="/servicios/catering/"
          icon="utensils"
        />
        <Card
          name="Accesorios"
          excerpt="Mantelería, señalización, plantas de energía y clima."
          cta="Ver accesorios"
          href="/servicios/accesorios/"
          icon="package"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FORMULARIO DE COTIZACIÓN
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="cotizar-heading">
    <div class="container">
      <SectionHeader
        id="cotizar-heading"
        title="Solicita tu Cotización"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Ya sea un evento para 50 personas o una producción para 2,000 invitados, estamos aquí para ayudarte a hacerlo realidad."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="cotizarForm" novalidate>
          <div class="reserva-form__grid">
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <div class="form-field">
              <label class="form-field__label" for="invitados">
                Número de invitados
              </label>
              <select id="invitados" name="invitados" class="form-field__input form-field__select">
                <option value="">Selecciona un rango</option>
                <option value="1-50">1 – 50 personas</option>
                <option value="50-100">50 – 100 personas</option>
                <option value="100-200">100 – 200 personas</option>
                <option value="200-500">200 – 500 personas</option>
                <option value="500-1000">500 – 1,000 personas</option>
                <option value="1000+">Más de 1,000 personas</option>
              </select>
            </div>

            <div class="form-field">
              <label class="form-field__label" for="servicio">
                Servicio de interés
              </label>
              <select id="servicio" name="servicio" class="form-field__input form-field__select">
                <option value="">Selecciona un servicio</option>
                <option value="Mobiliario">Mobiliario (sillas, mesas, lounge, barras)</option>
                <option value="Audiovisual">Audiovisual (pantallas, sonido, proyectores)</option>
                <option value="Carpas">Carpas (árabes, estructurales, hangar)</option>
                <option value="Iluminación">Iluminación (decorativa, escenario, efectos)</option>
                <option value="Pistas de Baile">Pistas de Baile (LED, madera, tarimas)</option>
                <option value="Inflables">Inflables (infantiles, acuáticos, adultos)</option>
                <option value="Catering">Catering (estaciones, cocina, vajilla)</option>
                <option value="Accesorios">Accesorios (mantelería, energía, clima)</option>
                <option value="Paquete Integral">Paquete Integral (varios servicios)</option>
              </select>
            </div>

            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles: tipo de evento, sede, equipo que necesitas, presupuesto aproximado..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar cotización por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Cotización detallada</h3>
            <p class="reserva-card__text">Recibe un desglose completo con precios, opciones de paquetes y disponibilidad para tu fecha.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para tu presupuesto.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 – 19:00<br/>Sábados: 9:00 – 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('cotizarForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const invitados = document.getElementById('invitados').value;
      const servicio = document.getElementById('servicio').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      if (!nombre || !telefono || !mensaje) {
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      let texto = `*Nueva cotización desde EVENTECH.MX*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (invitados) texto += `*Invitados:* ${invitados}\n`;
      if (servicio) texto += `*Servicio de interés:* ${servicio}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Tu evento perfecto comienza aquí"
    subheadline="Más de 500 eventos exitosos nos respaldan. Cotiza hoy y recibe asesoría personalizada sin compromiso."
    primaryCTA={{ label: "Cotizar ahora", href: "#cotizar-heading" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: `https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento` }}
    variant="accent"
  />
</PageLayout>

<style>
  @import "@styles/l3-shared.css";
</style>
