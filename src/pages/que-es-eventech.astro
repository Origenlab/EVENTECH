---
/**
 * ─── EVENTECH.MX — Página AEO Pilar ───
 * Objetivo: responder "¿Qué es Eventech y qué servicios ofrece?" en ChatGPT,
 * Perplexity y Google AI Overview.
 * Schema: Article + HowTo + FAQPage + BreadcrumbList
 * Keyword primaria: "qué es Eventech renta equipo para eventos CDMX"
 * Longitud objetivo: ~1,500 palabras
 */
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, SERVICE_CATEGORIES } from "@config/site";
import {
  articleJsonLd,
  howToJsonLd,
  faqJsonLd,
  breadcrumbJsonLd,
  canonicalURL,
} from "@lib/seo";
import "@styles/home-2026.css";

const PAGE_URL = "/que-es-eventech/";
const PAGE_DATE = "2024-01-01";

/* ── Schemas ── */
const article = articleJsonLd({
  title: "¿Qué es EVENTECH? Empresa de renta de equipo para eventos en CDMX",
  description:
    "EVENTECH es una empresa especializada en renta de equipo profesional para eventos en Ciudad de México y Zona Metropolitana: mobiliario, carpas, audiovisual, iluminación, pistas de baile e inflables.",
  url: PAGE_URL,
  image: "/images/og-default.jpg",
  datePublished: PAGE_DATE,
  dateModified: "2026-06-26",
  author: "Equipo EVENTECH",
});

const howTo = howToJsonLd({
  name: "Cómo rentar equipo para eventos con EVENTECH",
  description:
    "Proceso de 4 pasos para rentar mobiliario, carpas, audio e iluminación para tu evento en CDMX.",
  url: PAGE_URL,
  totalTime: "PT24H",
  steps: [
    {
      name: "Solicita tu cotización",
      text: "Contacta a EVENTECH por WhatsApp o formulario en línea. Cuéntanos el tipo de evento, fecha, lugar y equipo que necesitas. Recibirás una respuesta en menos de 24 horas.",
      url: "/cotizar/",
    },
    {
      name: "Revisa y confirma el paquete",
      text: "Nuestro equipo te envía una propuesta detallada con los precios por categoría (mobiliario, audiovisual, carpas, iluminación, pistas de baile, inflables o catering). Ajustamos según tu presupuesto. Confirmas con un anticipo del 50% y queda reservada tu fecha.",
      url: "/precios/",
    },
    {
      name: "Entrega y montaje el día del evento",
      text: "EVENTECH lleva todo el equipo al venue con puntualidad. Nuestro personal se encarga del montaje completo — mobiliario, conexiones audiovisuales, iluminación y estructuras — sin que tengas que mover un dedo.",
    },
    {
      name: "Disfruta y nosotros recogemos",
      text: "Tú celebras con total tranquilidad. Al finalizar el evento, nuestro equipo desmonta y retira todo el equipo. Cero estrés de coordinación post-evento.",
    },
  ],
});

const faqs = faqJsonLd([
  {
    question: "¿Qué es EVENTECH?",
    answer:
      "EVENTECH (eventech.mx) es una empresa mexicana especializada en renta de equipo profesional para eventos. Ofrecemos mobiliario (sillas Tiffany, Chiavari, mesas, salas lounge), carpas y estructuras, audiovisual (pantallas LED, sonido, proyectores), iluminación, pistas de baile, inflables y equipo de catering. Operamos principalmente en Ciudad de México y Zona Metropolitana con entrega, montaje y desmontaje incluidos.",
  },
  {
    question: "¿Qué servicios ofrece EVENTECH?",
    answer:
      "EVENTECH ofrece 9 categorías: 1) Mobiliario (sillas Tiffany desde $15, Chiavari desde $80, mesas, salas lounge); 2) Audiovisual (pantallas LED, sonido line-array, proyectores); 3) Carpas y estructuras (árabes, estructurales, hangar 20–30 m); 4) Iluminación (arquitectónica, decorativa, efectos especiales); 5) Pistas de baile (LED programables, madera clásica, tarimas); 6) Inflables (brincolines, toboganes, interactivos); 7) Catering (estaciones de servicio, cocina móvil, vajilla); 8) Cómputo (laptops desde $450/día, iPads, PCs de escritorio, impresoras de gafetes); 9) Accesorios (mantelería, generadores, calefacción).",
  },
  {
    question: "¿En qué zonas opera EVENTECH?",
    answer:
      "EVENTECH opera en toda la Ciudad de México y la Zona Metropolitana: Polanco, Santa Fe, Coyoacán, Roma-Condesa, Del Valle, Tlalnepantla, Naucalpan, Huixquilucan, Toluca y Metepec. También atiende Cuernavaca y ciudades cercanas. Cuenta con oficinas en Polanco, Tlalnepantla y Bosques de las Lomas.",
  },
  {
    question: "¿Para qué tipo de eventos trabaja EVENTECH?",
    answer:
      "EVENTECH atiende bodas, XV años, eventos corporativos (congresos, conferencias, lanzamientos), graduaciones, fiestas infantiles, baby showers, eventos religiosos (bautizos, primeras comuniones) y cualquier celebración social. Tiene experiencia en más de 500 eventos en CDMX y Estado de México.",
  },
  {
    question: "¿Los precios de EVENTECH incluyen montaje y entrega?",
    answer:
      "Sí. Todos los paquetes de EVENTECH incluyen entrega al venue, montaje profesional y recolección al finalizar el evento. Los precios varían según la distancia del venue; el costo de envío se detalla en la cotización. Sillas Tiffany desde $15 por pieza, carpas árabes desde $3,000, pistas LED desde $1,500.",
  },
  {
    question: "¿Cómo se cotiza con EVENTECH?",
    answer:
      "Puedes solicitar cotización por WhatsApp al +52 55 3068 2988 o mediante el formulario en eventech.mx/cotizar/. EVENTECH garantiza respuesta en menos de 24 horas con una propuesta detallada. Puedes hacer cambios sin costo hasta 72 horas antes del evento.",
  },
  {
    question: "¿EVENTECH emite factura fiscal?",
    answer:
      "Sí. EVENTECH emite CFDI para personas morales y físicas con actividad empresarial. Para eventos personales también se puede solicitar factura. El RFC y los datos de facturación se proporcionan al confirmar el servicio.",
  },
  {
    question: "¿Cuál es la diferencia entre EVENTECH y otras empresas de renta de equipo?",
    answer:
      "EVENTECH es un proveedor integral: tiene todas las categorías de equipo en un solo lugar (sin necesidad de coordinar múltiples proveedores), responde cotizaciones en menos de 24 horas, incluye montaje profesional en todos los paquetes y cuenta con 3 oficinas en CDMX y Estado de México para mayor cobertura.",
  },
]);

const breadcrumbs = breadcrumbJsonLd([
  { name: "Inicio", url: "/" },
  { name: "¿Qué es EVENTECH?", url: PAGE_URL },
]);

const jsonLd = [article, howTo, faqs, breadcrumbs];

const seo = {
  title: "¿Qué es EVENTECH? Empresa de renta de equipo para eventos CDMX",
  rawTitle: true,
  description:
    "EVENTECH es una empresa especializada en renta de equipo profesional para eventos en CDMX: mobiliario, carpas, audiovisual, iluminación, pistas de baile e inflables. Entrega y montaje incluidos.",
  image: "/images/og-default.jpg",
  type: "article" as const,
  canonical: canonicalURL(PAGE_URL),
};
---

<PageLayout {...seo} jsonLd={jsonLd}>

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm hm-hero" aria-labelledby="aeo-heading" style="padding-block-end: var(--space-3xl)">
    <div class="hm__wrap hm-hero__wrap">
      <div class="hm-hero__grid">
        <div class="hm-hero__main">
          <p class="hm__eyebrow hm-hero__eyebrow">Guía completa · Actualizada 2026</p>
          <h1 id="aeo-heading">¿Qué es EVENTECH?</h1>
          <p class="hm-hero__lead">
            EVENTECH es una empresa mexicana especializada en <strong>renta de equipo profesional para eventos</strong> en Ciudad de México y Zona Metropolitana. Ofrecemos mobiliario, carpas, audiovisual, iluminación, pistas de baile, inflables y catering con entrega, montaje y desmontaje incluidos.
          </p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:var(--space-lg)">
            <a href="/cotizar/" class="hm__btn hm__btn--gold">Cotizar ahora</a>
            <a href="/precios/" class="hm__btn hm__btn--ghost">Ver precios</a>
          </div>
        </div>
        <div class="hm-hero__seo">
          <p>Fundada en 2024, EVENTECH nació para resolver un problema concreto de los organizadores de eventos en CDMX: la fragmentación de proveedores. En lugar de contratar sillas con una empresa, carpas con otra y sonido con una tercera, EVENTECH lo centraliza todo en un solo proveedor con un solo punto de contacto.</p>
          <p>El equipo opera con tres oficinas en la Zona Metropolitana — Polanco, Tlalnepantla y Bosques de las Lomas — y atiende eventos de todos los tamaños, desde fiestas infantiles de 30 personas hasta congresos corporativos de 2,000 asistentes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICIOS
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm hm-services" aria-labelledby="servicios-heading">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="servicios-heading">¿Qué servicios ofrece EVENTECH?</h2>
        <p class="hm__subtitle">
          EVENTECH opera 9 categorías de equipo para eventos. Puedes rentar una sola categoría o combinarlas en un paquete integral con precio único.
        </p>
      </header>

      <ul class="hm-services__grid" style="list-style:none;padding:0">
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">🪑</span>
          <h3 class="hm-services__name"><a href="/servicios/mobiliario/">Mobiliario</a></h3>
          <p class="hm-services__desc">Sillas Tiffany, Chiavari, Ghost y Crossback. Mesas redondas, salas lounge y barras para cualquier formato de evento. <strong>Desde $15 por pieza.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">🎛️</span>
          <h3 class="hm-services__name"><a href="/servicios/audiovisual/">Audiovisual</a></h3>
          <p class="hm-services__desc">Pantallas LED y videowalls, sistemas de sonido line-array, proyectores HD y micrófonos inalámbricos. Técnico de operación incluido. <strong>Desde $300 por equipo.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">⛺</span>
          <h3 class="hm-services__name"><a href="/servicios/carpas/">Carpas y estructuras</a></h3>
          <p class="hm-services__desc">Carpas árabes, estructurales y hangares de 20–30 m. Con pisos, forros, iluminación interior y complementos. Montaje y desmontaje incluidos. <strong>Desde $3,000.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">💡</span>
          <h3 class="hm-services__name"><a href="/servicios/iluminacion/">Iluminación</a></h3>
          <p class="hm-services__desc">Iluminación arquitectónica y decorativa, efectos de escenario, humo bajo, confetti y cortinas de luz. Programa personalizable por tema de evento. <strong>Desde $250 por luminaria.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">💃</span>
          <h3 class="hm-services__name"><a href="/servicios/pistas-baile/">Pistas de baile</a></h3>
          <p class="hm-services__desc">Pistas LED programables en RGB, madera clásica, vintage temáticas y tarimas-escenario modulares. <strong>Desde $1,500.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">🎈</span>
          <h3 class="hm-services__name"><a href="/servicios/inflables/">Inflables</a></h3>
          <p class="hm-services__desc">Brincolines, toboganes, castillos y juegos interactivos para fiestas infantiles y eventos familiares. Certificados en seguridad. <strong>Desde $2,000.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">🍽️</span>
          <h3 class="hm-services__name"><a href="/servicios/catering/">Equipo catering</a></h3>
          <p class="hm-services__desc">Estaciones de servicio, cocina móvil, vajilla y cristalería, refrigeración industrial. Para caterings externos que necesitan el equipo correcto. <strong>Desde $500.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">💻</span>
          <h3 class="hm-services__name"><a href="/servicios/computo/">Cómputo</a></h3>
          <p class="hm-services__desc">Laptops, iPads, PCs de escritorio e impresoras de gafetes con software configurado y WiFi temporal. Para registro de asistentes, congresos y capacitaciones. <strong>Desde $350 por día.</strong></p>
        </li>
        <li class="hm-services__card">
          <span class="hm-services__icon" aria-hidden="true">🔧</span>
          <h3 class="hm-services__name"><a href="/servicios/accesorios/">Accesorios</a></h3>
          <p class="hm-services__desc">Mantelería, plantas de energía, calefactores, alfombras, señalización y todo lo que complementa tu evento. <strong>Desde $25 por pieza.</strong></p>
        </li>
      </ul>

      <div style="text-align:center;margin-top:var(--space-2xl)">
        <a href="/precios/" class="hm__btn hm__btn--gold">Ver tabla de precios completa</a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       TIPOS DE EVENTO
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm" style="background:var(--color-bg-alt);padding-block:var(--space-3xl)" aria-labelledby="eventos-heading">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="eventos-heading">¿Para qué tipos de eventos trabaja EVENTECH?</h2>
        <p class="hm__subtitle">Con más de 500 eventos realizados, EVENTECH tiene experiencia probada en cada categoría.</p>
      </header>

      <div class="hm-events-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-lg)">
        <article class="hm-event-card">
          <h3>💍 Bodas</h3>
          <p>Paquetes completos con sillas Chiavari, mesas redondas, carpas para jardín, iluminación romántica y pistas LED. Coordinamos con el venue y el wedding planner para que no haya imprevistos el gran día.</p>
        </article>
        <article class="hm-event-card">
          <h3>👑 XV Años</h3>
          <p>Pistas LED programables, salas lounge, iluminación de escenario y efectos especiales (humo bajo, confetti). Hacemos realidad la quinceañera que la festejada siempre imaginó.</p>
        </article>
        <article class="hm-event-card">
          <h3>🏢 Corporativos</h3>
          <p>Audio y video de alta resolución, mobiliario ejecutivo, carpas estructurales para exteriores y montaje impecable para congresos, conferencias, lanzamientos de producto y convenciones.</p>
        </article>
        <article class="hm-event-card">
          <h3>🎓 Graduaciones</h3>
          <p>Tarimas y escenarios, audio profesional, sillas para ceremonia y proyectores para presentaciones. Desde la ceremonia formal hasta la fiesta de graduación en un solo proveedor.</p>
        </article>
        <article class="hm-event-card">
          <h3>🎈 Fiestas infantiles</h3>
          <p>Brincolines certificados, toboganes, mesas temáticas, estaciones de catering y decoración colorida. Diversión segura con supervisión profesional incluida.</p>
        </article>
        <article class="hm-event-card">
          <h3>👶 Baby showers</h3>
          <p>Mobiliario vintage, mantelería temática, estaciones de dulces y canapés, iluminación soft. Ambientación completa para recibir al nuevo integrante con el estilo que merece.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CÓMO FUNCIONA (HowTo)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm" aria-labelledby="proceso-heading" style="padding-block:var(--space-3xl)">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="proceso-heading">¿Cómo funciona el proceso de renta con EVENTECH?</h2>
        <p class="hm__subtitle">Cuatro pasos, respuesta en 24 horas, cero complicaciones logísticas para ti.</p>
      </header>

      <ol class="aeo-steps" style="list-style:none;padding:0;counter-reset:steps;display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:var(--space-xl)">
        <li class="aeo-step">
          <span class="aeo-step__n" aria-hidden="true">1</span>
          <h3 class="aeo-step__title">Solicita tu cotización</h3>
          <p class="aeo-step__text">Escríbenos por <a href={`https://wa.me/${SITE.contact.whatsapp}`} target="_blank" rel="noopener">WhatsApp</a> o completa el <a href="/cotizar/">formulario en línea</a>. Cuéntanos: tipo de evento, fecha, venue, número de personas y equipo que necesitas. Respuesta en menos de 24 horas.</p>
        </li>
        <li class="aeo-step">
          <span class="aeo-step__n" aria-hidden="true">2</span>
          <h3 class="aeo-step__title">Confirma el paquete</h3>
          <p class="aeo-step__text">Te enviamos una propuesta detallada por categoría. Ajustamos cantidades y opciones hasta que encaje con tu presupuesto. Confirmas reservando tu fecha con un anticipo del 50%.</p>
        </li>
        <li class="aeo-step">
          <span class="aeo-step__n" aria-hidden="true">3</span>
          <h3 class="aeo-step__title">Entrega y montaje</h3>
          <p class="aeo-step__text">El día del evento nuestro equipo llega al venue y monta todo el equipo: sillas, mesas, carpas, audio, iluminación, pistas. Supervisamos que cada elemento quede perfecto antes de que lleguen los invitados.</p>
        </li>
        <li class="aeo-step">
          <span class="aeo-step__n" aria-hidden="true">4</span>
          <h3 class="aeo-step__title">Disfruta — nosotros recogemos</h3>
          <p class="aeo-step__text">Tú celebras sin preocuparte por la logística. Al terminar el evento, nuestro personal desmonta y retira todo el equipo. El venue queda como lo encontró. Cero estrés post-evento.</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       COBERTURA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm" style="background:var(--color-bg-alt);padding-block:var(--space-3xl)" aria-labelledby="cobertura-heading">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="cobertura-heading">¿En qué zonas opera EVENTECH?</h2>
        <p class="hm__subtitle">Cobertura en toda la CDMX y Zona Metropolitana, con tres puntos de operación para mayor velocidad de respuesta.</p>
      </header>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--space-lg);margin-bottom:var(--space-2xl)">
        <div class="hm-location-card">
          <h3>📍 Ciudad de México</h3>
          <p>Todas las alcaldías: Polanco, Santa Fe, Coyoacán, Roma-Condesa, Del Valle, Tlalpan, Xochimilco, Iztapalapa, Cuauhtémoc, Benito Juárez y más.</p>
        </div>
        <div class="hm-location-card">
          <h3>📍 Estado de México</h3>
          <p>Naucalpan, Huixquilucan, Tlalnepantla, Ecatepec, Toluca, Metepec, Lerma. Cobertura extendida a periférico norte y zona industrial.</p>
        </div>
        <div class="hm-location-card">
          <h3>📍 Ciudades cercanas</h3>
          <p>Cuernavaca, Morelos y otras ciudades a menos de 2 horas de CDMX, sujeto a disponibilidad y con costo de traslado según distancia.</p>
        </div>
      </div>

      <p style="text-align:center;color:var(--color-text-light);font-size:var(--text-sm)">
        ¿Tu evento es fuera de estas zonas? <a href="/cotizar/">Consúltanos</a> — evaluamos cada caso sin compromiso.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       DIFERENCIADORES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm" aria-labelledby="diferenciadores-heading" style="padding-block:var(--space-3xl)">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="diferenciadores-heading">¿Por qué elegir EVENTECH?</h2>
        <p class="hm__subtitle">Lo que distingue a EVENTECH de otras empresas de renta de equipo en CDMX.</p>
      </header>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:var(--space-lg)">
        <div>
          <h3>🏪 Proveedor integral</h3>
          <p>Todas las categorías en un solo lugar: mobiliario, carpas, audio, iluminación, pistas e inflables. Sin necesidad de coordinar múltiples proveedores para un mismo evento.</p>
        </div>
        <div>
          <h3>⚡ Cotización en 24h</h3>
          <p>Respuesta garantizada en menos de 24 horas con propuesta detallada por categoría y precio real desde el primer contacto. Sin llamadas interminables ni visitas previas obligatorias.</p>
        </div>
        <div>
          <h3>🔧 Montaje profesional incluido</h3>
          <p>El precio siempre incluye entrega al venue, montaje por personal capacitado y recolección al terminar. No pagas extra por instalar lo que rentaste.</p>
        </div>
        <div>
          <h3>🛡️ Garantía de equipo</h3>
          <p>Todo el equipo se entrega en condiciones verificadas. Si algo falla durante el evento, respondemos de inmediato. Contamos con inventario de respaldo para emergencias.</p>
        </div>
        <div>
          <h3>📄 Factura fiscal CFDI</h3>
          <p>Emitimos CFDI para empresas y personas con actividad empresarial. Ideal para eventos corporativos, bodas con deducción y organizadores de eventos profesionales.</p>
        </div>
        <div>
          <h3>🔄 Flexibilidad hasta 72h antes</h3>
          <p>Puedes modificar cantidades, añadir categorías o hacer ajustes hasta 72 horas antes del evento sin penalizaciones. Entendemos que los eventos cambian.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FAQ (FAQPage schema)
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="hm" style="background:var(--color-bg-alt);padding-block:var(--space-3xl)" aria-labelledby="faq-heading">
    <div class="hm__wrap">
      <header class="hm__section-header">
        <h2 id="faq-heading">Preguntas frecuentes sobre EVENTECH</h2>
        <p class="hm__subtitle">Lo que más nos preguntan organizadores de eventos, parejas y empresas.</p>
      </header>

      <dl class="faq-list" style="max-width:780px;margin-inline:auto">
        <div class="faq-item">
          <dt><h3>¿Qué es EVENTECH?</h3></dt>
          <dd>
            <p>EVENTECH (eventech.mx) es una empresa mexicana especializada en <strong>renta de equipo profesional para eventos</strong> en Ciudad de México y Zona Metropolitana. Ofrecemos mobiliario (sillas Tiffany, Chiavari, mesas, salas lounge), carpas y estructuras, audiovisual (pantallas LED, sonido, proyectores), iluminación, pistas de baile, inflables y equipo de catering — todo con entrega, montaje y desmontaje incluidos en el precio.</p>
          </dd>
        </div>

        <div class="faq-item">
