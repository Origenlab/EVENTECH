---
/**
 * ─── EVENTECH.MX Home Page ───
 * Landing page optimizada para SEO con todas las secciones estratégicas:
 * Hero, Trust Stats, Servicios, Eventos, Diferenciadores, Zonas, CTA
 *
 * Keyword primaria: "renta de equipo para eventos CDMX"
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroHome from "@components/HeroHome.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import ReviewCard from "@components/ReviewCard.astro";
import { SITE, SERVICE_CATEGORIES, EVENT_TYPES, TRUST_STATS, FEATURES, REVIEWS } from "@data/site";

// JSON-LD para LocalBusiness (SEO Local)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}/#localbusiness`,
  name: SITE.organization.name,
  description: SITE.seo.description,
  url: SITE.url,
  telephone: SITE.contact.phone,
  email: SITE.contact.email,
  priceRange: SITE.business.priceRange,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Ciudad de México",
    addressRegion: "CDMX",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: SITE.business.geo.latitude,
    longitude: SITE.business.geo.longitude,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: SITE.business.openingHours.weekdays.opens,
      closes: SITE.business.openingHours.weekdays.closes,
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: SITE.business.openingHours.saturday.opens,
      closes: SITE.business.openingHours.saturday.closes,
    },
  ],
  areaServed: SITE.business.areaServed.map((area) => ({
    "@type": "City",
    name: area,
  })),
  sameAs: SITE.organization.sameAs,
};
---

<PageLayout
  title="Renta de Equipo para Eventos en CDMX"
  description="Renta de mobiliario, equipo audiovisual, carpas e iluminación para bodas, XV años, eventos corporativos y sociales en CDMX. Cotiza en línea, respuesta en 24h."
  jsonLd={[localBusinessSchema]}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroHome />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER - Llamada a acción principal
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para hacer tu evento inolvidable?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada en menos de 24 horas"
    primaryCTA={{ label: "Ver nuestros servicios", href: "/servicios/" }}
    secondaryCTA={{ label: "Contactar ahora", href: "/contacto/" }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICIOS SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="servicios-heading">
    <div class="container">
      <SectionHeader
        id="servicios-heading"
        title="Nuestros Servicios"
        subtitle="Todo el equipamiento que necesitas para tu evento, en un solo lugar"
        description={[
          "En EVENTECH contamos con el catálogo más completo de renta de equipo para eventos en la Ciudad de México. Desde mobiliario elegante hasta sistemas de audio profesional, cada pieza está cuidadosamente seleccionada para garantizar la calidad que tu evento merece.",
          "Nuestro equipo de especialistas te asesora en cada paso para que elijas exactamente lo que necesitas. Ya sea una boda íntima en Polanco o un congreso corporativo en Santa Fe, tenemos la solución perfecta para ti."
        ]}
      />

      <div class="grid grid--3">
        {SERVICE_CATEGORIES.map((service) => (
          <Card
            name={service.name}
            excerpt={service.excerpt}
            cta={service.cta}
            href={service.href}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EVENTOS SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="eventos-heading">
    <div class="container">
      <SectionHeader
        id="eventos-heading"
        title="Equipamiento para Todo Tipo de Eventos"
        subtitle="Soluciones especializadas según el tipo de celebración"
        description={[
          "Cada evento tiene su propia personalidad y necesidades únicas. Por eso, hemos desarrollado paquetes especializados para bodas, XV años, eventos corporativos y fiestas sociales, asegurándonos de que cada detalle esté perfectamente cubierto.",
          "Con más de 500 eventos exitosos en CDMX, conocemos las tendencias, los mejores venues y lo que funciona para cada tipo de celebración. Deja que nuestra experiencia trabaje para ti."
        ]}
      />

      <div class="grid grid--4">
        {EVENT_TYPES.map((event) => (
          <Card
            name={event.name}
            excerpt={event.excerpt}
            cta={event.cta}
            href={event.href}
            icon={event.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       POR QUÉ ELEGIRNOS
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="porque-heading">
    <div class="container">
      <SectionHeader
        id="porque-heading"
        title="¿Por Qué Elegir EVENTECH?"
        subtitle="La diferencia está en los detalles"
        description={[
          "Sabemos que organizar un evento puede ser estresante. Por eso, en EVENTECH nos enfocamos en hacer tu vida más fácil: cotizaciones rápidas, precios transparentes, entrega puntual y equipo siempre en perfectas condiciones. Tu tranquilidad es nuestra prioridad.",
          "No somos solo proveedores, somos socios de tu evento. Nuestro equipo te acompaña desde la primera llamada hasta el desmontaje, asegurándonos de que todo salga exactamente como lo planeaste."
        ]}
      />

      <div class="grid grid--4">
        {FEATURES.map((feature) => (
          <Card
            name={feature.name}
            excerpt={feature.excerpt}
            cta={feature.cta}
            href={feature.href}
            icon={feature.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESEÑAS EMPRESARIALES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="resenas-heading">
    <div class="container">
      <SectionHeader
        id="resenas-heading"
        title="Empresas que Confían en Nosotros"
        subtitle="Más de 500 eventos exitosos nos respaldan"
        description={[
          "No lo decimos nosotros, lo dicen nuestros clientes. Desde corporativos Fortune 500 hasta los venues más exclusivos de la Ciudad de México, hemos construido relaciones de confianza basadas en resultados.",
          "Cada reseña representa un evento donde cumplimos nuestra promesa: calidad impecable, puntualidad garantizada y servicio profesional de principio a fin."
        ]}
      />

      <div class="grid grid--3">
        {REVIEWS.map((review) => (
          <ReviewCard
            company={review.company}
            author={review.author}
            role={review.role}
            rating={review.rating}
            text={review.text}
            event={review.event}
            website={review.website}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       ZONAS DE COBERTURA
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="zonas-heading">
    <div class="container">
      <SectionHeader
        id="zonas-heading"
        title="Cobertura en CDMX y Zona Metropolitana"
        subtitle="Llevamos el equipo a donde lo necesites"
        description={[
          "Nuestra flota de entrega cubre toda la Ciudad de México y la Zona Metropolitana. Desde Polanco hasta Coyoacán, de Santa Fe a Tlalpan, llegamos a los venues y salones más exclusivos de la capital con puntualidad garantizada.",
          "Para eventos fuera de CDMX, también atendemos Toluca, Metepec, Cuernavaca y otras ciudades cercanas. Consulta disponibilidad y costos de envío para tu ubicación específica."
        ]}
      />

      <div class="zones-grid">
        <div class="zone-group">
          <h3 class="zone-group__title">CDMX</h3>
          <ul class="zone-list">
            <li><a href="/zonas/cdmx/polanco/">Polanco</a></li>
            <li><a href="/zonas/cdmx/santa-fe/">Santa Fe</a></li>
            <li><a href="/zonas/cdmx/coyoacan/">Coyoacán</a></li>
            <li><a href="/zonas/cdmx/roma/">Roma - Condesa</a></li>
            <li><a href="/zonas/cdmx/del-valle/">Del Valle</a></li>
            <li><a href="/zonas/cdmx/tlalpan/">Tlalpan</a></li>
            <li><a href="/zonas/cdmx/xochimilco/">Xochimilco</a></li>
            <li><a href="/zonas/cdmx/">Ver todas →</a></li>
          </ul>
        </div>

        <div class="zone-group">
          <h3 class="zone-group__title">Estado de México</h3>
          <ul class="zone-list">
            <li><a href="/zonas/estado-de-mexico/naucalpan/">Naucalpan</a></li>
            <li><a href="/zonas/estado-de-mexico/huixquilucan/">Huixquilucan</a></li>
            <li><a href="/zonas/estado-de-mexico/tlalnepantla/">Tlalnepantla</a></li>
            <li><a href="/zonas/estado-de-mexico/metepec/">Metepec</a></li>
            <li><a href="/zonas/estado-de-mexico/toluca/">Toluca</a></li>
            <li><a href="/zonas/estado-de-mexico/">Ver todas →</a></li>
          </ul>
        </div>

        <div class="zone-info">
          <div class="zone-info__icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <h3>Entrega el mismo día</h3>
          <p>En pedidos confirmados antes de las 2pm, entregamos el mismo día en CDMX.</p>
          <a href="/cotizar/" class="btn btn--primary">Cotiza ahora</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA FINAL - Antes del Footer
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="Haz realidad el evento que siempre soñaste"
    subheadline="Más de 500 eventos exitosos en CDMX nos respaldan. Cotiza hoy y recibe asesoría personalizada sin compromiso."
    primaryCTA={{ label: "Explorar servicios", href: "/servicios/" }}
    secondaryCTA={{ label: "Hablar con un asesor", href: "/contacto/" }}
    variant="accent"
  />
</PageLayout>

<style>
  /* ═══════════════════════════════════════════════════════════════════════
     SECTION STYLES
     ═══════════════════════════════════════════════════════════════════════ */
  .section__header {
    text-align: center;
    margin-block-end: var(--space-2xl);
  }

  .section__title {
    font-size: var(--text-3xl);
    margin-block-end: var(--space-sm);
  }

  .section__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-light);
    max-width: 50ch;
    margin-inline: auto;
  }

  .section__footer {
    text-align: center;
    margin-block-start: var(--space-2xl);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     ZONES GRID
     ═══════════════════════════════════════════════════════════════════════ */
  .zones-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  .zone-group {
    background: var(--color-bg);
    padding: var(--space-xl);
    border-radius: var(--radius-md);
  }

  .zone-group__title {
    font-size: var(--text-lg);
    margin-block-end: var(--space-md);
    padding-block-end: var(--space-sm);
    border-block-end: 2px solid var(--color-primary);
  }

  .zone-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .zone-list a {
    color: var(--color-text);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .zone-list a:hover {
    color: var(--color-primary);
  }

  .zone-info {
    background: var(--color-primary);
    color: white;
    padding: var(--space-xl);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .zone-info__icon {
    margin-block-end: var(--space-md);
    opacity: 0.9;
  }

  .zone-info h3 {
    font-size: var(--text-xl);
    margin-block-end: var(--space-sm);
  }

  .zone-info p {
    font-size: var(--text-sm);
    opacity: 0.9;
    margin-block-end: var(--space-lg);
  }

  .zone-info .btn {
    background: white;
    color: var(--color-primary);
  }

  .zone-info .btn:hover {
    background: var(--color-bg-alt);
  }

  @media (max-width: 1024px) {
    .zones-grid {
      grid-template-columns: 1fr 1fr;
    }

    .zone-info {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .zones-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
