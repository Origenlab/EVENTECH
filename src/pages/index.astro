              alt="Renta de equipo de catering para eventos en CDMX: mesa de bufet montada para un banquete corporativo"
              loading="lazy"
              decoding="async"
            />
          </div>
        </article>

        <!-- MÓDULO 8: Accesorios — inline (tono "lo invisible que sostiene todo") -->
        <article class="hm-feat" aria-labelledby="feat-accesorios">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Accesorios e infraestructura</p>
            <h3 class="hm-feat__title" id="feat-accesorios">Lo que nadie aplaude, pero todos agradecen</h3>
            <p>
              Una alfombra que da la bienvenida, manteles que amarran el montaje, una planta de
              luz para que nadie se quede a oscuras y calefactores para cuando, ya entrada la
              noche, baja la temperatura en la terraza. Es la parte que no sale en las fotos y,
              aun así, hace que todo lo demás funcione.
            </p>
            <p class="hm-feat__inline">
              {SERVICE_CATEGORIES[7].subcategories.map((sc, i) => (
                <>
                  {i > 0 && <i>·</i>}
                  <a href={sc.href}>{sc.name}</a>
                </>
              ))}
            </p>
            <a class="hm-feat__cta" href="/servicios/accesorios/">
              Ver accesorios
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
