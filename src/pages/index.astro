                <select name="tipo">
                  <option value="">Selecciona…</option>
                  <option>Boda</option>
                  <option>XV años</option>
                  <option>Corporativo</option>
                  <option>Evento social</option>
                  <option>Fiesta infantil</option>
                  <option>Otro</option>
                </select>
              </label>

