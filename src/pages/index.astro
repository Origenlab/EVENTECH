---
/**
 * ─── EVENTECH.MX Home Page ───
 * Landing page optimizada para SEO con todas las secciones estratégicas:
 * Hero, Trust Stats, Servicios, Eventos, Diferenciadores, Zonas, CTA
 *
 * Keyword primaria: "renta de equipo para eventos CDMX"
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroHome from "@components/HeroHome.astro";
import CTABanner from "@components/CTABanner.astro";
import SectionHeader from "@components/SectionHeader.astro";
import Card from "@components/Card.astro";
import ReviewCard from "@components/ReviewCard.astro";
import { SITE, SERVICE_CATEGORIES, EVENT_TYPES, TRUST_STATS, FEATURES, REVIEWS } from "@data/site";

// JSON-LD para LocalBusiness (SEO Local)
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": `${SITE.url}/#localbusiness`,
  name: SITE.organization.name,
  description: SITE.seo.description,
  url: SITE.url,
  telephone: SITE.contact.phone,
  email: SITE.contact.email,
  priceRange: SITE.business.priceRange,
  address: {
    "@type": "PostalAddress",
    addressLocality: "Ciudad de México",
    addressRegion: "CDMX",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: SITE.business.geo.latitude,
    longitude: SITE.business.geo.longitude,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: SITE.business.openingHours.weekdays.opens,
      closes: SITE.business.openingHours.weekdays.closes,
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: SITE.business.openingHours.saturday.opens,
      closes: SITE.business.openingHours.saturday.closes,
    },
  ],
  areaServed: SITE.business.areaServed.map((area) => ({
    "@type": "City",
    name: area,
  })),
  sameAs: SITE.organization.sameAs,
};
---

<PageLayout
  title="Renta de Equipo para Eventos en CDMX"
  description="Renta de mobiliario, equipo audiovisual, carpas e iluminación para bodas, XV años, eventos corporativos y sociales en CDMX. Cotiza en línea, respuesta en 24h."
  jsonLd={[localBusinessSchema]}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroHome />

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER - Llamada a acción principal
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Listo para hacer tu evento inolvidable?"
    subheadline="Cotiza sin compromiso y recibe una propuesta personalizada en menos de 24 horas"
    primaryCTA={{ label: "Ver nuestros servicios", href: "/servicios/" }}
    secondaryCTA={{ label: "Contactar ahora", href: "/contacto/" }}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       SERVICIOS SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="servicios-heading">
    <div class="container">
      <SectionHeader
        id="servicios-heading"
        title="Nuestros Servicios"
        subtitle="Todo el equipamiento que necesitas para tu evento, en un solo lugar"
        description={[
          "En EVENTECH contamos con el catálogo más completo de renta de equipo para eventos en la Ciudad de México. Desde mobiliario elegante hasta sistemas de audio profesional, cada pieza está cuidadosamente seleccionada para garantizar la calidad que tu evento merece.",
          "Nuestro equipo de especialistas te asesora en cada paso para que elijas exactamente lo que necesitas. Ya sea una boda íntima en Polanco o un congreso corporativo en Santa Fe, tenemos la solución perfecta para ti."
        ]}
      />

      <div class="grid grid--3">
        {SERVICE_CATEGORIES.map((service) => (
          <Card
            name={service.name}
            excerpt={service.excerpt}
            cta={service.cta}
            href={service.href}
            icon={service.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       EVENTOS SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="eventos-heading">
    <div class="container">
      <SectionHeader
        id="eventos-heading"
        title="Equipamiento para Todo Tipo de Eventos"
        subtitle="Soluciones especializadas según el tipo de celebración"
        description={[
          "Cada evento tiene su propia personalidad y necesidades únicas. Por eso, hemos desarrollado paquetes especializados para bodas, XV años, eventos corporativos y fiestas sociales, asegurándonos de que cada detalle esté perfectamente cubierto.",
          "Con más de 500 eventos exitosos en CDMX, conocemos las tendencias, los mejores venues y lo que funciona para cada tipo de celebración. Deja que nuestra experiencia trabaje para ti."
        ]}
      />

      <div class="grid grid--4">
        {EVENT_TYPES.map((event) => (
          <Card
            name={event.name}
            excerpt={event.excerpt}
            cta={event.cta}
            href={event.href}
            icon={event.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       POR QUÉ ELEGIRNOS
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="porque-heading">
    <div class="container">
      <SectionHeader
        id="porque-heading"
        title="¿Por Qué Elegir EVENTECH?"
        subtitle="La diferencia está en los detalles"
        description={[
          "Sabemos que organizar un evento puede ser estresante. Por eso, en EVENTECH nos enfocamos en hacer tu vida más fácil: cotizaciones rápidas, precios transparentes, entrega puntual y equipo siempre en perfectas condiciones. Tu tranquilidad es nuestra prioridad.",
          "No somos solo proveedores, somos socios de tu evento. Nuestro equipo te acompaña desde la primera llamada hasta el desmontaje, asegurándonos de que todo salga exactamente como lo planeaste."
        ]}
      />

      <div class="grid grid--4">
        {FEATURES.map((feature) => (
          <Card
            name={feature.name}
            excerpt={feature.excerpt}
            cta={feature.cta}
            href={feature.href}
            icon={feature.icon}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESEÑAS EMPRESARIALES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="resenas-heading">
    <div class="container">
      <SectionHeader
        id="resenas-heading"
        title="Empresas que Confían en Nosotros"
        subtitle="Más de 500 eventos exitosos nos respaldan"
        description={[
          "No lo decimos nosotros, lo dicen nuestros clientes. Desde corporativos Fortune 500 hasta los venues más exclusivos de la Ciudad de México, hemos construido relaciones de confianza basadas en resultados.",
          "Cada reseña representa un evento donde cumplimos nuestra promesa: calidad impecable, puntualidad garantizada y servicio profesional de principio a fin."
        ]}
      />

      <div class="grid grid--3">
        {REVIEWS.map((review) => (
          <ReviewCard
            company={review.company}
            author={review.author}
            role={review.role}
            rating={review.rating}
            text={review.text}
            event={review.event}
            website={review.website}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       PREGUNTAS FRECUENTES
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" aria-labelledby="faq-heading">
    <div class="container">
      <SectionHeader
        id="faq-heading"
        title="Preguntas Frecuentes"
        subtitle="Todo lo que necesitas saber antes de rentar"
        description={[
          "Sabemos que organizar un evento implica muchas decisiones. Aquí resolvemos las dudas más comunes de nuestros clientes para que puedas planificar con total confianza.",
          "Si no encuentras la respuesta que buscas, no dudes en contactarnos directamente. Nuestro equipo está listo para asesorarte."
        ]}
      />

      <div class="faq-layout">
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿Con cuánta anticipación debo reservar el equipo para mi evento?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Recomendamos reservar con al menos 2 semanas de anticipación para garantizar disponibilidad, especialmente en temporada alta (noviembre a febrero). Para eventos grandes como bodas o congresos, lo ideal es apartar con 1 a 2 meses de anticipación. Sin embargo, también atendemos solicitudes de último momento sujetas a disponibilidad.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿El precio incluye entrega, montaje y recolección?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Sí. Todos nuestros paquetes incluyen entrega en el venue, montaje profesional por nuestro equipo y recolección al finalizar el evento. El costo de envío puede variar según la ubicación, pero siempre lo detallamos en tu cotización antes de confirmar.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿Qué zonas cubren para la entrega de equipo?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Cubrimos toda la Ciudad de México y Zona Metropolitana, incluyendo Polanco, Santa Fe, Coyoacán, Roma-Condesa, Del Valle, Naucalpan, Huixquilucan y Tlalnepantla. También atendemos Toluca, Metepec, Cuernavaca y otras ciudades cercanas con costos de envío accesibles.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿Puedo hacer cambios en mi pedido después de reservar?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Por supuesto. Entendemos que los detalles de un evento pueden cambiar. Puedes modificar cantidades, agregar o quitar equipo hasta 72 horas antes de tu evento sin costo adicional. Cambios con menor anticipación están sujetos a disponibilidad.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿Qué métodos de pago aceptan?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Aceptamos transferencia bancaria, depósito en efectivo, tarjeta de crédito y débito. Para reservar tu equipo solicitamos un anticipo del 50%, y el resto se liquida antes de la entrega. Emitimos factura fiscal (CFDI) para empresas que lo requieran.</p>
            </div>
          </details>

          <details class="faq-item">
            <summary class="faq-item__question">
              <span>¿Qué pasa si algún equipo se daña durante el evento?</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq-item__answer">
              <p>Todo nuestro equipo cuenta con un seguro básico que cubre desgaste normal de uso. En caso de daños mayores o pérdida, se evalúa según las condiciones acordadas en el contrato de renta. Te explicamos todo de forma transparente antes de firmar para que no haya sorpresas.</p>
            </div>
          </details>
        </div>

        <aside class="faq-sidebar">
          <div class="faq-sidebar-card faq-sidebar-card--accent">
            <h3 class="faq-sidebar-card__title">¿No encuentras tu pregunta?</h3>
            <p class="faq-sidebar-card__text">Escríbenos directamente por WhatsApp y un asesor resolverá todas tus dudas al instante.</p>
            <a href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, tengo una duda sobre el servicio de renta de equipo`} target="_blank" rel="noopener noreferrer" class="faq-sidebar-card__btn">
              Escribir por WhatsApp
            </a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Llámanos</h3>
            <p class="faq-sidebar-card__text">Prefiere atención telefónica? Estamos disponibles de lunes a viernes de 9:00 a 19:00.</p>
            <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-sidebar-card__link faq-sidebar-card__link--phone">{SITE.contact.phone}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Correo electrónico</h3>
            <p class="faq-sidebar-card__text">Envíanos los detalles de tu evento y te respondemos en menos de 24 horas.</p>
            <a href={`mailto:${SITE.contact.email}`} class="faq-sidebar-card__link">{SITE.contact.email}</a>
          </div>

          <div class="faq-sidebar-card">
            <h3 class="faq-sidebar-card__title">Cotización express</h3>
            <p class="faq-sidebar-card__text">Completa el formulario de abajo y recibe una propuesta personalizada sin compromiso.</p>
            <a href="#reserva-heading" class="faq-sidebar-card__link">Ir al formulario ↓</a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       RESERVA TU EVENTO - Formulario de contacto / WhatsApp
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section section--alt" aria-labelledby="reserva-heading">
    <div class="container">
      <SectionHeader
        id="reserva-heading"
        title="Reserva Tu Evento"
        subtitle="Cuéntanos sobre tu evento y te contactamos de inmediato"
        description={[
          "Completa el formulario con los detalles de tu evento y uno de nuestros asesores te responderá por WhatsApp con una cotización personalizada. Sin compromiso, sin costos ocultos.",
          "Ya sea que tengas una fecha definida, necesites equipo específico o simplemente quieras explorar opciones, estamos aquí para ayudarte a crear un evento inolvidable."
        ]}
      />

      <div class="reserva-layout">
        <form class="reserva-form" id="reservaForm" novalidate>
          <div class="reserva-form__grid">
            <!-- Nombre -->
            <div class="form-field">
              <label class="form-field__label" for="nombre">
                Nombre completo <span class="form-field__required">*</span>
              </label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                class="form-field__input"
                placeholder="Tu nombre"
                required
              />
            </div>

            <!-- Teléfono -->
            <div class="form-field">
              <label class="form-field__label" for="telefono">
                Teléfono <span class="form-field__required">*</span>
              </label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                class="form-field__input"
                placeholder="55 1234 5678"
                required
              />
            </div>

            <!-- Tipo de evento -->
            <div class="form-field">
              <label class="form-field__label" for="tipoEvento">
                Tipo de evento
              </label>
              <select id="tipoEvento" name="tipoEvento" class="form-field__input form-field__select">
                <option value="">Selecciona una opción</option>
                <option value="Boda">Boda</option>
                <option value="XV Años">XV Años</option>
                <option value="Evento Corporativo">Evento Corporativo</option>
                <option value="Fiesta Social">Fiesta Social</option>
                <option value="Congreso / Conferencia">Congreso / Conferencia</option>
                <option value="Graduación">Graduación</option>
                <option value="Baby Shower">Baby Shower</option>
                <option value="Otro">Otro</option>
              </select>
            </div>

            <!-- Fecha del evento -->
            <div class="form-field">
              <label class="form-field__label" for="fecha">
                Fecha del evento
              </label>
              <input
                type="date"
                id="fecha"
                name="fecha"
                class="form-field__input"
              />
            </div>

            <!-- Equipo de interés -->
            <div class="form-field form-field--full">
              <label class="form-field__label" for="equipo">
                Equipo de interés
              </label>
              <select id="equipo" name="equipo" class="form-field__input form-field__select">
                <option value="">Selecciona el equipo que necesitas</option>
                <option value="Mobiliario">Mobiliario</option>
                <option value="Audio e Iluminación">Audio e Iluminación</option>
                <option value="Carpas y Estructuras">Carpas y Estructuras</option>
                <option value="Equipo Audiovisual">Equipo Audiovisual</option>
                <option value="Paquete Completo">Paquete Completo</option>
                <option value="Otro">Otro / No estoy seguro</option>
              </select>
            </div>

            <!-- Mensaje -->
            <div class="form-field form-field--full">
              <label class="form-field__label" for="mensaje">
                Mensaje <span class="form-field__required">*</span>
              </label>
              <textarea
                id="mensaje"
                name="mensaje"
                class="form-field__input form-field__textarea"
                placeholder="Cuéntanos los detalles de tu evento: número de invitados, ubicación, equipo que necesitas..."
                rows="4"
                required
              ></textarea>
            </div>
          </div>

          <button type="submit" class="reserva-form__submit" id="btnEnviar">
            <svg class="reserva-form__submit-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>
        </form>

        <aside class="reserva-sidebar">
          <div class="reserva-card">
            <h3 class="reserva-card__title">Respuesta inmediata</h3>
            <p class="reserva-card__text">Te respondemos por WhatsApp en menos de 30 minutos durante horario de atención.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Reserva tu fecha</h3>
            <p class="reserva-card__text">Aparta tu equipo con anticipación y asegura disponibilidad para tu evento.</p>
          </div>

          <div class="reserva-card">
            <h3 class="reserva-card__title">Sin compromiso</h3>
            <p class="reserva-card__text">Cotiza gratis y sin presiones. Recibe asesoría personalizada para tu presupuesto.</p>
          </div>

          <div class="reserva-card reserva-card--highlight">
            <h3 class="reserva-card__title">Horario de atención</h3>
            <p class="reserva-card__text">Lunes a Viernes: 9:00 - 19:00<br/>Sábados: 9:00 - 14:00</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ whatsapp: SITE.contact.whatsapp }}>
    document.getElementById('reservaForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const nombre = document.getElementById('nombre').value.trim();
      const telefono = document.getElementById('telefono').value.trim();
      const tipoEvento = document.getElementById('tipoEvento').value;
      const fecha = document.getElementById('fecha').value;
      const equipo = document.getElementById('equipo').value;
      const mensaje = document.getElementById('mensaje').value.trim();

      // Validación
      if (!nombre || !telefono || !mensaje) {
        // Marcar campos vacíos
        if (!nombre) document.getElementById('nombre').classList.add('form-field__input--error');
        if (!telefono) document.getElementById('telefono').classList.add('form-field__input--error');
        if (!mensaje) document.getElementById('mensaje').classList.add('form-field__input--error');
        return;
      }

      // Formatear fecha legible
      let fechaTexto = 'No especificada';
      if (fecha) {
        const d = new Date(fecha + 'T12:00:00');
        fechaTexto = d.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
      }

      // Construir mensaje de WhatsApp
      let texto = `*Nueva solicitud desde EVENTECH.MX*\n\n`;
      texto += `*Nombre:* ${nombre}\n`;
      texto += `*Teléfono:* ${telefono}\n`;
      if (tipoEvento) texto += `*Tipo de evento:* ${tipoEvento}\n`;
      texto += `*Fecha del evento:* ${fechaTexto}\n`;
      if (equipo) texto += `*Equipo de interés:* ${equipo}\n`;
      texto += `\n*Mensaje:*\n${mensaje}`;

      const url = `https://wa.me/${whatsapp}?text=${encodeURIComponent(texto)}`;
      window.open(url, '_blank');
    });

    // Limpiar estado de error al escribir
    document.querySelectorAll('.form-field__input').forEach(function(input) {
      input.addEventListener('input', function() {
        this.classList.remove('form-field__input--error');
      });
    });
  </script>

  <!-- ═══════════════════════════════════════════════════════════════════════
