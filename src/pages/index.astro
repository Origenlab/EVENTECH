---
/**
 * ─── EVENTECH.MX — Home (rediseño 2026) ───
 * Layout premium orientado a conversión. Estilos en `@styles/home-2026.css`
 * (namespaced `hm-`, sin animaciones). Contenido data-driven desde `@data/site`.
 *
 * Keyword primaria: "renta de equipo para eventos CDMX"
 */
import PageLayout from "@layouts/PageLayout.astro";
import {
  SITE,
  SERVICE_CATEGORIES,
  EVENT_TYPES,
  FEATURES,
  REVIEWS,
} from "@data/site";
import { localBusinessJsonLd, faqJsonLd } from "@utils/seo";
import "@styles/home-2026.css";

const services = SERVICE_CATEGORIES.slice(0, 8);
const eventTypes = EVENT_TYPES.slice(0, 4);

// Imágenes existentes por tipo de evento (los campos `image` del data apuntan a
// archivos aún no subidos; usamos los heros disponibles).
const eventImages: Record<string, string> = {
  bodas: "/images/eventos/bodas-hero.avif",
  "xv-anos": "/images/eventos/xv-hero.avif",
  corporativos: "/images/eventos/corporativos-hero.avif",
  sociales: "/images/moviliario-para-eventos/lounge-boda-sofa-blanco-dorado-elegante.avif",
};
const features = FEATURES.slice(0, 6);
// Reseñas de empresas aliadas. REDEIL primero, luego el resto (ver vault: Resenas).
// Muestra hasta 12; al agregar más a REVIEWS aparecen automáticamente.
const reviews = [
  ...REVIEWS.filter((r) => r.company === "REDEIL"),
  ...REVIEWS.filter((r) => r.company !== "REDEIL"),
].slice(0, 12);

const sectionMenu = [
  { label: "Servicios", href: "/servicios/" },
  { label: "Eventos", href: "/eventos/" },
  { label: "Salones", href: "/directorio/" },
  { label: "Nosotros", href: "/nosotros/" },
  { label: "Blog", href: "/blog/" },
  { label: "Cotizar", href: "/cotizar/" },
];


const steps = [
  { n: 1, t: "Cotiza", p: "Cuéntanos tu evento, fecha y venue. Respuesta en 24 horas." },
  { n: 2, t: "Confirma", p: "Ajustamos el paquete a tu presupuesto y reservas tu fecha." },
  { n: 3, t: "Entregamos", p: "Llevamos y montamos todo el día del evento, puntuales." },
  { n: 4, t: "Disfruta", p: "Tú celebras; al final desmontamos y recogemos." },
];

const gallery = [
  "/images/moviliario-para-eventos/boda-salon-mesas-redondas-flores-dorado-34.avif",
  "/images/moviliario-para-eventos/boda-mesas-redondas-sillas-blancas-luces-53.avif",
  "/images/iluminacion/iluminacion-evento-03.jpg",
  "/images/moviliario-para-eventos/lounge-boda-sofa-blanco-dorado-elegante.avif",
  "/images/moviliario-para-eventos/boda-salon-mesas-redondas-flores-blancas-05.avif",
];

const homeFaqs = [
  {
    question: "¿Con cuánta anticipación debo reservar el equipo para mi evento?",
    answer: "Recomendamos reservar con al menos 2 semanas de anticipación para garantizar disponibilidad, especialmente en temporada alta (noviembre a febrero). Para eventos grandes como bodas o congresos, lo ideal es apartar con 1 a 2 meses de anticipación. También atendemos solicitudes de último momento sujetas a disponibilidad.",
  },
  {
    question: "¿El precio incluye entrega, montaje y recolección?",
    answer: "Sí. Todos nuestros paquetes incluyen entrega en el venue, montaje profesional por nuestro equipo y recolección al finalizar el evento. El costo de envío puede variar según la ubicación, pero siempre lo detallamos en tu cotización antes de confirmar.",
  },
  {
    question: "¿Qué zonas cubren para la entrega de equipo?",
    answer: "Cubrimos toda la Ciudad de México y Zona Metropolitana, incluyendo Polanco, Santa Fe, Coyoacán, Roma-Condesa, Del Valle, Naucalpan, Huixquilucan y Tlalnepantla. También atendemos Toluca, Metepec, Cuernavaca y otras ciudades cercanas con costos de envío accesibles.",
  },
  {
    question: "¿Puedo hacer cambios en mi pedido después de reservar?",
    answer: "Por supuesto. Puedes modificar cantidades, agregar o quitar equipo hasta 72 horas antes de tu evento sin costo adicional. Cambios con menor anticipación están sujetos a disponibilidad.",
  },
  {
    question: "¿Qué métodos de pago aceptan?",
    answer: "Aceptamos transferencia bancaria, depósito en efectivo, tarjeta de crédito y débito. Para reservar tu equipo solicitamos un anticipo del 50%, y el resto se liquida antes de la entrega. Emitimos factura fiscal (CFDI) para empresas que lo requieran.",
  },
  {
    question: "¿Qué pasa si algún equipo se daña durante el evento?",
    answer: "Todo nuestro equipo cuenta con un seguro básico que cubre desgaste normal de uso. En caso de daños mayores o pérdida, se evalúa según las condiciones acordadas en el contrato de renta. Te explicamos todo de forma transparente antes de firmar.",
  },
];

const jsonLd = [localBusinessJsonLd(), faqJsonLd(homeFaqs)];

// Módulos destacados por categoría (estructura homologada, contenido profesional).
// `cat` es el índice en SERVICE_CATEGORIES; de ahí salen subcategorías, href y nombre.
const featuredModules = [
  {
    cat: 0,
    eyebrow: "Mobiliario",
    title: "Mobiliario que define el carácter de tu evento",
    lead: "Es la primera decisión estética del evento y la que aparece en cada fotografía.",
    body: [
      "Manejamos inventario propio de <strong>sillas Tiffany, Chiavari y Crossback, mesas redondas e imperiales, salas lounge y barras de diseño</strong>, en acabados que van de lo clásico a lo contemporáneo. Seleccionamos cada pieza para que dialogue con tu mantelería, tu paleta de color y el estilo del venue, y la entregamos limpia, montada y lista antes de que llegue el primer invitado.",
      "Tres décadas equipando bodas, XV años y eventos corporativos en CDMX y el Estado de México nos permiten dimensionar con precisión: cuántas mesas caben sin saturar el salón, qué silla resiste un evento de pie y cómo distribuir las áreas para que el espacio fluya. Tú defines la visión; nosotros la sostenemos pieza por pieza.",
    ],
    cta: "Explorar mobiliario",
    image: "/images/moviliario-para-eventos/boda-salon-mesas-redondas-flores-dorado-34.avif",
    alt: "Renta de mobiliario para eventos en CDMX: salón con mesas redondas, sillas y decoración dorada",
  },
  {
    cat: 1,
    eyebrow: "Audiovisual",
    title: "Producción audiovisual que se ve y se escucha impecable",
    lead: "El audio y el video solo se notan cuando fallan; nuestro trabajo es que nunca fallen.",
    body: [
      "Rentamos <strong>pantallas LED y videowalls de alta resolución, sistemas de sonido line-array, proyección 4K y microfonía inalámbrica profesional</strong>, con cableado oculto y equipo de respaldo en sitio. Diseñamos la configuración según la acústica del recinto y el aforo, y la calibramos durante el evento para que cada palabra y cada nota lleguen con claridad hasta la última fila.",
      "Nuestro equipo técnico opera en vivo de principio a fin —conferencias, bodas, lanzamientos de marca o conciertos— anticipando cualquier contingencia antes de que el público la perciba. La tecnología importa; la operación experta que hay detrás es lo que marca la diferencia.",
    ],
    cta: "Ver equipo audiovisual",
    image: "/images/audiovisual/pantalla-led-videowall-evento-corporativo.avif",
    alt: "Renta de equipo audiovisual para eventos en CDMX: pantalla LED y videowall en evento corporativo",
  },
  {
    cat: 2,
    eyebrow: "Carpas y estructuras",
    title: "Carpas y estructuras que amplían cualquier espacio",
    lead: "Una buena estructura convierte un jardín, una terraza o un terreno abierto en el recinto que imaginaste.",
    body: [
      "Montamos <strong>carpas árabes, estructurales, tipo hangar y transparentes</strong>, con piso nivelado, forros, climatización e iluminación interior integrados. Cada estructura se calcula según el terreno, el aforo y el diseño del evento, y se instala bajo estrictos criterios de seguridad y acabado, resistente a sol, viento y lluvia.",
      "Con más de 30 años levantando estructuras temporales en CDMX y el Estado de México, resolvemos desde una boda íntima en jardín hasta un congreso de gran formato con la misma exigencia: que, una vez dentro, nadie note que está bajo una carpa.",
    ],
    cta: "Cotizar carpas",
    image: "/images/carpas/carpa-transparente-boda-elegante.avif",
    alt: "Renta de carpas para eventos en CDMX: carpa transparente montada para una boda elegante",
  },
  {
    cat: 3,
    eyebrow: "Iluminación",
    title: "Iluminación que construye la atmósfera de cada momento",
    lead: "Es el recurso más poderoso —y más subestimado— para transformar por completo un espacio.",
    body: [
      "Diseñamos esquemas de <strong>iluminación arquitectónica, decorativa, de escenario y efectos especiales</strong>: uplighting, cabezas robóticas, guirnaldas, neón y humo bajo, controlados desde consola. Definimos contigo una paleta de luz para cada etapa del evento —recepción, cena, primer baile y pista— y la operamos en vivo para acompañar el ritmo de la noche.",
      "Tres décadas creando ambientes nos enseñaron que una misma sala cuenta historias distintas según cómo se ilumine. Por eso cada montaje se calibra al detalle —temperatura de color, intensidad y tiempos— con un operador dedicado de principio a fin.",
    ],
    cta: "Diseñar iluminación",
    image: "/images/iluminacion/iluminacion-arquitectonica-hacienda.avif",
    alt: "Renta de iluminación profesional para eventos en CDMX: iluminación arquitectónica en una hacienda",
  },
  {
    cat: 4,
    eyebrow: "Pistas de baile",
    title: "Pistas de baile que se vuelven el centro de la fiesta",
    lead: "Es el punto donde la celebración deja de ser un evento y se convierte en una fiesta.",
    body: [
      "Rentamos <strong>pistas LED programables, de madera clásica, acrílicas, además de tarimas y escenarios a medida</strong>. Nivelamos e instalamos sobre cualquier superficie —pasto, terraza o salón— con estructura firme y acabado profesional, calculando las dimensiones exactas para que la pista luzca llena y nunca quede vacía.",
      "Después de tres décadas montando celebraciones, sabemos que una pista bien proporcionada e iluminada transforma la energía del evento. Combina pista, tarima y escenario con un solo proveedor y un montaje pensado para que el centro de atención esté justo donde debe estar.",
    ],
    cta: "Elegir pista",
    image: "/images/pistas-baile/pista-led-rgb-fiesta.avif",
    alt: "Renta de pistas de baile para eventos en CDMX: pista LED RGB iluminada en una fiesta",
  },
  {
    cat: 5,
    eyebrow: "Inflables",
    title: "Inflables que garantizan diversión segura",
    lead: "Son la atracción que mantiene felices a los invitados más jóvenes de principio a fin.",
    body: [
      "Contamos con <strong>brincolines y castillos, juegos acuáticos, circuitos interactivos y deportivos, e inflables para adultos</strong>. Cada unidad se entrega higienizada, correctamente anclada y revisada pieza por pieza, con materiales resistentes y un montaje seguro acorde al rango de edad de cada juego.",
      "Te asesoramos para elegir el inflable adecuado según la edad de los invitados, el espacio disponible y el tipo de celebración —cumpleaños, kermesse, posada o activación de marca— e incluimos soplador y supervisión opcional, para que la diversión transcurra con total tranquilidad.",
    ],
    cta: "Ver inflables",
    image: "/images/inflables/castillo-inflable-fiesta-infantil.avif",
    alt: "Renta de inflables para eventos en CDMX: castillo inflable en una fiesta infantil",
  },
  {
    cat: 6,
    eyebrow: "Equipo de catering",
    title: "Infraestructura de catering a la altura de tu menú",
    lead: "Un servicio de alimentos memorable depende tanto del menú como de la infraestructura que lo hace posible.",
    body: [
      "Rentamos <strong>estaciones de servicio, cocina móvil, equipo de refrigeración y vajilla y cristalería premium</strong>, montados y listos para operar. Coordinamos directamente con tu chef o banquetero la capacidad de cocción y la conservación en frío y caliente, para que cada platillo salga a tiempo y a su temperatura ideal.",
      "Con más de 30 años equipando banquetes en CDMX y el Estado de México, dimensionamos la infraestructura según el número de invitados y el formato del servicio —banquete sentado, bufé o estaciones— e integramos todo bajo un mismo proveedor, para que la logística detrás de la cocina sea invisible para tus invitados.",
    ],
    cta: "Equipar banquete",
    image: "/images/catering/mesa-bufet-banquete-corporativo.avif",
    alt: "Renta de equipo de catering para eventos en CDMX: mesa de bufet montada para un banquete corporativo",
  },
  {
    cat: 7,
    eyebrow: "Accesorios e infraestructura",
    title: "Los complementos que sostienen todo el evento",
    lead: "Son los detalles que rara vez se mencionan y que, sin embargo, determinan que todo funcione.",
    body: [
      "Rentamos <strong>señalización y alfombras, mantelería y textiles, plantas de energía y equipos de calefacción y clima</strong>. Resolvemos desde la primera impresión en el acceso hasta el suministro eléctrico respaldado y el control de temperatura en exteriores y carpas, con instalación profesional y material en perfecto estado.",
      "Tres décadas de experiencia nos permiten anticipar lo que cada venue necesita: la potencia eléctrica correcta, la climatización adecuada y la mantelería que unifica el montaje. Un solo proveedor para todos los complementos, para que ningún detalle quede al azar.",
    ],
    cta: "Ver accesorios",
    image: "/images/accesorios/manteles-premium-boda-elegante.avif",
    alt: "Renta de accesorios para eventos en CDMX: mantelería premium en una boda elegante",
  },
];
---

<PageLayout
  title="Renta de equipo para eventos | Equipo para eventos en México"
  rawTitle={true}
  description="Renta de equipo para eventos en México: mobiliario, audio, carpas e iluminación para bodas, XV años y eventos corporativos. Entrega, montaje y cotización en 24h."
  jsonLd={jsonLd}
>
  <div class="hm">
    <!-- HERO -->
    <section class="hm-hero" aria-labelledby="hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">
              Renta de equipo para eventos · CDMX y Estado de México
            </p>
            <h1 id="hero-heading">Renta de equipo para eventos, montado a la <em>perfección</em></h1>
            <p class="hm-hero__lead">
              Mobiliario, audio, carpas, iluminación y más. Entrega, montaje y
              asesoría incluidos — para que tú solo disfrutes.
            </p>
          </div>
          <div class="hm-hero__seo">
            <p>
              Con <strong>más de 30 años de experiencia</strong>, EVENTECH es una
              de las empresas con mayor trayectoria en la renta de equipo para
              eventos sociales en México. Tres décadas equipando bodas, XV años,
              eventos corporativos y celebraciones privadas en la Ciudad de México
              y el Estado de México nos respaldan como un proveedor de confianza
              para wedding planners, empresas y familias que no dejan nada al azar.
            </p>
            <p>
              Esa experiencia se traduce en un inventario propio y verificado
              —mobiliario, audio, carpas, iluminación y pistas de baile— con
              entrega, montaje y desmontaje siempre incluidos. Conocemos los venues,
              los tiempos y la logística de CDMX y su zona metropolitana, así que
              anticipamos cada detalle para que tu evento luzca impecable y se
              desarrolle con la puntualidad que solo dan <strong>30 años de oficio</strong>.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- MENU DE SECCIONES (full-width, botones iguales) -->
    <nav class="hm-menu" aria-label="Secciones principales del sitio">
      <ul class="hm-menu__grid">
        {sectionMenu.map((m) => (
          <li>
            <a class="hm-menu__item" href={m.href}>{m.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- SERVICIOS -->
    <section class="hm__section" aria-labelledby="servicios-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Todo en un solo lugar</p>
            <h2 id="servicios-heading">Nuestros servicios</h2>
            <p class="hm__head-sub">Equipamiento integral para bodas, XV años, corporativos y eventos sociales.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Rentamos cada categoría de equipo que un evento necesita —mobiliario,
              audio e iluminación, carpas, pistas de baile y producción— bajo un mismo
              proveedor. Eso elimina la coordinación entre múltiples empresas: un solo
              contrato, una sola logística de entrega y un equipo que monta y desmonta
              en tiempo, para que tu evento empiece y termine sin contratiempos.
            </p>
            <p>
              Con más de 30 años montando bodas, XV años y eventos corporativos en CDMX
              y Estado de México, asesoramos cada renta según tu venue, número de
              invitados y presupuesto. Cotiza en línea y recibe una propuesta clara, con
              equipo en óptimas condiciones y entrega puntual garantizada.
            </p>
          </div>
        </div>
        <div class="hm-cat-grid">
          {services.map((s) => (
            <article class="hm-cat">
              <a class="hm-cat__media" href={s.href} aria-label={`Ver categoría ${s.name}`}>
                <img class="hm-cat__img" src={s.image} alt={`Renta de ${s.name.toLowerCase()} para eventos`} loading="lazy" decoding="async" />
                <span class="hm-cat__badge">{s.subcategories.length} subcategorías</span>
                <span class="hm-cat__name">{s.name}</span>
              </a>
              <div class="hm-cat__body">
                <p class="hm-cat__sub">{s.description}</p>
                <ul class="hm-cat__menu">
                  {s.subcategories.map((sc) => (
                    <li>
                      <a href={sc.href}>
                        <span>{sc.name}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M9 18l6-6-6-6" />
                        </svg>
                      </a>
                    </li>
                  ))}
                </ul>
                <a class="hm-cat__cta" href={s.href}>
                  Ver todo en {s.name}
                  <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M13 6l6 6-6 6" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <!-- MÓDULOS DESTACADOS POR CATEGORÍA (estructura homologada, data-driven) -->
        {featuredModules.map((m) => (
          <article class="hm-feat" aria-labelledby={`feat-${m.cat}`}>
            <div class="hm-feat__text">
              <p class="hm__eyebrow">{m.eyebrow}</p>
              <h3 class="hm-feat__title" id={`feat-${m.cat}`}>{m.title}</h3>
              <p class="hm-feat__lead">{m.lead}</p>
              {m.body.map((para) => <p set:html={para} />)}
              <ul class="hm-feat__menu">
                {SERVICE_CATEGORIES[m.cat].subcategories.map((sc) => (
                  <li>
                    <a href={sc.href}>
                      <span>{sc.name}</span>
                      <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18l6-6-6-6" />
                      </svg>
                    </a>
                  </li>
                ))}
              </ul>
              <a class="hm-feat__cta" href={SERVICE_CATEGORIES[m.cat].href}>
                {m.cta}
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
            <div class="hm-feat__media">
              <img src={m.image} alt={m.alt} loading="lazy" decoding="async" />
            </div>
          </article>
        ))}

        <!-- MÓDULO 6: Inflables — chips (tono familiar/cálido) -->
        <article class="hm-feat" aria-labelledby="feat-inflables">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Inflables</p>
            <h3 class="hm-feat__title" id="feat-inflables">Para que lleguen a casa rendidos</h3>
            <p>
              Brincolines, toboganes, juegos de agua para el calor y retos para los grandes que
              también quieren jugar. Llegan limpios, bien anclados y revisados pieza por pieza,
              porque sabemos que mientras los niños brincan tú quieres estar tranquila, no
              vigilando.
            </p>
            <p>
              Dinos las edades y el espacio que tienes; te decimos qué cabe y qué los va a
              divertir más. Si quieres, dejamos a alguien cuidando el juego toda la tarde.
            </p>
            <ul class="hm-feat__chips">
              {SERVICE_CATEGORIES[5].subcategories.map((sc) => (
                <li><a href={sc.href}>{sc.name}</a></li>
              ))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/inflables/">
              Ver inflables
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>
          <div class="hm-feat__media">
            <img
              src="/images/inflables/castillo-inflable-fiesta-infantil.avif"
              alt="Renta de inflables para eventos en CDMX: castillo inflable en una fiesta infantil"
              loading="lazy"
              decoding="async"
            />
          </div>
        </article>

        <!-- MÓDULO 7: Catering — reverse + checklist (tono B2B, banquetero) -->
        <article class="hm-feat hm-feat--reverse" aria-labelledby="feat-catering">
          <div class="hm-feat__text">
            <p class="hm__eyebrow">Equipo de catering</p>
            <h3 class="hm-feat__title" id="feat-catering">Tu banquetero pone el menú; lo demás, nosotros</h3>
            <p>
              Estaciones de servicio, cocina móvil, refrigeración y vajilla que se ve bien en
              la foto. Nos sentamos con tu chef a revisar lo aburrido pero importante: cuánta
              potencia hace falta, cuánto frío, cuánto calor, para que cada platillo salga a
              tiempo y a su temperatura.
            </p>
            <p>
              Tú te concentras en cómo sabe; nosotros, en que la cocina detrás funcione sin que
              nadie del salón se entere de que existe.
            </p>
            <ul class="hm-feat__checks">
              {SERVICE_CATEGORIES[6].subcategories.map((sc) => (
                <li>
                  <a href={sc.href}>
                    <svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {sc.name}
                  </a>
                </li>
              ))}
            </ul>
            <a class="hm-feat__cta" href="/servicios/catering/">
              Equipar mi banquete
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </a>
          </div>
          <div class="hm-feat__media">
            <img
