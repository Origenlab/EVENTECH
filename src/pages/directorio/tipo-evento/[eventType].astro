// Generate static paths for all event types
export async function getStaticPaths() {
  // Fuente única de verdad: src/lib/directorio-taxonomy.ts
  return EVENT_TYPE_SLUGS.map(eventType => ({
    params: { eventType },
    props: { eventType }
  }));
}

// Get all venues
const allVenues: CollectionEntry<"venues">[] = await getCollection("venues");

const { eventType } = Astro.props as { eventType: string };
const config = eventTypeConfig[eventType];

if (!config) {
  return Astro.redirect("/directorio/");
}

// Filter venues that support this event type
const filteredVenues = allVenues.filter(v =>
  v.data.eventTypes?.includes(eventType)
).sort((a, b) => {
  // Sort by: featured first, then premium, then by rating
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.premium !== b.data.premium) return a.data.premium ? -1 : 1;
  return (b.data.rating || 0) - (a.data.rating || 0);
});

// Group by region for stats
const cdmxCount = filteredVenues.filter(v => v.data.region === "cdmx").length;
const edomexCount = filteredVenues.filter(v => v.data.region === "estado-mexico").length;

// Venue type labels
const venueTypeLabels: Record<string, string> = {
  "salon": "Salón",
  "jardin": "Jardín",
  "hacienda": "Hacienda",
  "terraza": "Terraza",
  "hotel": "Hotel",
  "restaurante": "Restaurante",
  "foro": "Foro",
  "quinta": "Quinta",
  "mansion": "Mansión",
  "centro-convenciones": "Centro de Convenciones",
  "rooftop": "Rooftop",
};

// Breadcrumbs
const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Directorio", href: "/directorio/" },
  { label: config.label },
];

// JSON-LD with ItemList schema
const jsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Directorio", url: "/directorio/" },
    { name: config.label, url: `/directorio/tipo-evento/${eventType}/` },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `Venues para ${config.label} en CDMX y Estado de México`,
    description: config.seoDescription,
    numberOfItems: filteredVenues.length,
    itemListElement: filteredVenues.slice(0, 20).map((venue, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "EventVenue",
        name: venue.data.name,
        url: canonicalURL(`/directorio/${venue.data.region}/${venue.data.zoneSlug}/${venue.id.split('/').pop()?.replace('.md', '')}/`),
        address: {
          "@type": "PostalAddress",
          addressLocality: venue.data.zone,
          addressRegion: venue.data.region === "cdmx" ? "Ciudad de México" : "Estado de México",
        },
        maximumAttendeeCapacity: venue.data.capacity.max,
        // aggregateRating omitido: ratings legacy sin fuente verificable
        // (ver Template-Ficha-Venue en el vault) — riesgo fake-reviews Google.
      }
    })),
  }
];
---

<PageLayout
  title={config.seoTitle}
  description={config.seoDescription}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  <div class="hm">

    {/* HERO */}
    <section class="hm-hero" aria-labelledby="te-hero-heading">
      <div class="hm__wrap hm-hero__wrap">
        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">Directorio · Venues para {config.label}</p>
            <h1 id="te-hero-heading">Salones para <em>{config.label}</em> en CDMX y Edo. México</h1>
            <p class="hm-hero__lead">{config.heroSubtitle}</p>
            <div class="sv-hero__ctas">
              <a class="hm__btn hm__btn--gold" href="#venues">
                Ver todos los venues
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7" /></svg>
              </a>
              <a class="hm__btn hm__btn--ghost" href="/cotizar/">Cotizar equipo</a>
            </div>
          </div>
          <div class="hm-hero__seo">
            {config.heroCards.map((c) => (<p set:html={`<strong>${c.title}.</strong> ${c.content}`} />))}
          </div>
        </div>
      </div>
    </section>

    {/* STATS */}
    <section class="dr-stats" aria-label={`Indicadores de venues para ${config.plural}`}>
      <div class="hm__wrap dr-stats__wrap">
        <dl class="dr-stats__grid">
          <div class="dr-stats__item"><dt class="dr-stats__num">{filteredVenues.length}</dt><dd class="dr-stats__label">Para {config.plural}</dd></div>
          <div class="dr-stats__item"><dt class="dr-stats__num">{cdmxCount}</dt><dd class="dr-stats__label">En CDMX</dd></div>
          <div class="dr-stats__item"><dt class="dr-stats__num">{edomexCount}</dt><dd class="dr-stats__label">En Edo. Méx.</dd></div>
          <div class="dr-stats__item"><dt class="dr-stats__num">{filteredVenues.filter(v => v.data.verified).length}</dt><dd class="dr-stats__label">Verificados</dd></div>
        </dl>
      </div>
    </section>

    {/* VENUES */}
    <section id="venues" class="hm__section" aria-labelledby="te-venues-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">{filteredVenues.length} opciones</p>
            <h2 id="te-venues-heading">Venues para {config.label}</h2>
            <p class="hm__head-sub">Ordenados por relevancia.</p>
          </div>
          <div class="hm__head-copy">
            <p>Todos los venues que reciben {config.plural} en CDMX y Estado de México, verificados de primera mano: primero destacados, premium y mejor calificados.</p>
            <p>Conocemos sus requerimientos técnicos y podemos coordinar el equipo —mobiliario, audio, iluminación, carpas y pistas— directamente con cada espacio.</p>
          </div>
        </div>

        {filteredVenues.length > 0 ? (
          <div class="dr-venue-grid dr-venue-grid--3">
            {filteredVenues.map(venue => <VenueCard venue={venue} typeLabel={venueTypeLabels[venue.data.type] || venue.data.type} />)}
          </div>
        ) : (
          <div class="dr-nav" style="justify-content:center;margin-top:32px;">
            <a href="/directorio/" class="dr-nav__link">No hay venues por ahora — ver todo el directorio</a>
          </div>
        )}
      </div>
    </section>

    {/* OTROS TIPOS DE EVENTO */}
    <section class="hm__section hm__section--ivory" aria-labelledby="te-other-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Más opciones</p>
            <h2 id="te-other-heading">Explora por tipo de evento</h2>
            <p class="hm__head-sub">Cada celebración es distinta.</p>
          </div>
          <div class="hm__head-copy">
            <p>Una boda no necesita el mismo espacio que un corporativo o unos XV años. Cambia de categoría para ver venues con experiencia en tu tipo de evento.</p>
          </div>
        </div>
        <div class="dr-etype-grid">
          {Object.entries(eventTypeConfig).filter(([key]) => key !== eventType).map(([key, cfg]) => (
            <a href={`/directorio/tipo-evento/${key}/`} class="dr-etype-tag">
              <span class="dr-etype-tag__name">{cfg.label}</span>
              <span class="dr-etype-tag__count">{allVenues.filter(v => v.data.eventTypes?.includes(key)).length}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* CTA */}
    <section class="hm__section hm-cta">
      <div class="hm__wrap">
        <h2>¿Tus {config.plural} serán en alguno de estos venues?</h2>
        <p>Cotiza mobiliario, carpas, iluminación, audio y pistas. Llevamos todo a donde sea tu evento y te asesoramos sin costo.</p>
        <div class="hm-cta__row">
          <a class="hm__btn hm__btn--gold" href="/cotizar/">Cotizar equipo</a>
          <a class="hm__btn hm__btn--ghost" href="/servicios/">Ver servicios</a>
        </div>
      </div>
    </section>

  </div>
</PageLayout>
