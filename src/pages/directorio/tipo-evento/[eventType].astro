};

// Generate static paths for all event types
export async function getStaticPaths() {
  // List event type slugs that have configuration
  const eventTypes = [
    "bodas",
    "xv-anos",
    "corporativos",
    "graduaciones",
    "bautizos",
    "aniversarios",
    "cumpleanos",
    "cenas-gala",
    "lanzamientos"
  ];

  return eventTypes.map(eventType => ({
    params: { eventType },
    props: { eventType }
  }));
}

// Get all venues
const allVenues = await getCollection("venues");

const { eventType } = Astro.props;
const config = eventTypeConfig[eventType];

if (!config) {
  return Astro.redirect("/directorio/");
}

// Filter venues that support this event type
const filteredVenues = allVenues.filter(v =>
  v.data.eventTypes?.includes(eventType)
).sort((a, b) => {
  // Sort by: featured first, then premium, then by rating
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  if (a.data.premium !== b.data.premium) return a.data.premium ? -1 : 1;
  return (b.data.rating || 0) - (a.data.rating || 0);
});

// Group by region for stats
const cdmxCount = filteredVenues.filter(v => v.data.region === "cdmx").length;
const edomexCount = filteredVenues.filter(v => v.data.region === "estado-mexico").length;

// Venue type labels
const venueTypeLabels: Record<string, string> = {
  "salon": "Salón",
  "jardin": "Jardín",
  "hacienda": "Hacienda",
  "terraza": "Terraza",
  "hotel": "Hotel",
  "restaurante": "Restaurante",
  "foro": "Foro",
  "quinta": "Quinta",
  "mansion": "Mansión",
  "centro-convenciones": "Centro de Convenciones",
  "rooftop": "Rooftop",
};

// Breadcrumbs
const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Directorio", href: "/directorio/" },
  { label: config.label },
];

// JSON-LD with ItemList schema
const jsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Directorio", url: "/directorio/" },
    { name: config.label, url: `/directorio/tipo-evento/${eventType}/` },
  ]),
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: `Venues para ${config.label} en CDMX y Estado de México`,
    description: config.seoDescription,
    numberOfItems: filteredVenues.length,
    itemListElement: filteredVenues.slice(0, 20).map((venue, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "EventVenue",
        name: venue.data.name,
        url: canonicalURL(`/directorio/${venue.data.region}/${venue.data.zoneSlug}/${venue.id.split('/').pop()?.replace('.md', '')}/`),
        address: {
          "@type": "PostalAddress",
          addressLocality: venue.data.zone,
          addressRegion: venue.data.region === "cdmx" ? "Ciudad de México" : "Estado de México",
        },
        maximumAttendeeCapacity: venue.data.capacity.max,
        ...(venue.data.rating && venue.data.reviewCount && {
          aggregateRating: {
            "@type": "AggregateRating",
            ratingValue: venue.data.rating,
            reviewCount: venue.data.reviewCount,
          }
        }),
      }
    })),
  }
];
---

<PageLayout
  title={config.seoTitle}
  description={config.seoDescription}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} />

  <HeroPage
    badge={`Venues para ${config.label}`}
    title={`Salones para <span class="highlight">${config.label}</span>`}
    subtitle={config.heroSubtitle}
    primaryCTA={{ label: "Ver todos los venues", href: "#venues" }}
    secondaryCTA={{ label: "Cotizar equipo", href: "/cotizar/" }}
    cards={config.heroCards}
  />

  <!-- Stats Bar -->
  <section class="section section--compact">
    <div class="container">
      <div class="dir-stats-bar">
        <div class="dir-stats-bar__item">
          <span class="dir-stats-bar__number">{filteredVenues.length}</span>
          <span class="dir-stats-bar__label">Venues para {config.plural}</span>
        </div>
        <div class="dir-stats-bar__item">
          <span class="dir-stats-bar__number">{cdmxCount}</span>
          <span class="dir-stats-bar__label">En CDMX</span>
        </div>
        <div class="dir-stats-bar__item">
          <span class="dir-stats-bar__number">{edomexCount}</span>
          <span class="dir-stats-bar__label">En Edo. México</span>
        </div>
        <div class="dir-stats-bar__item">
          <span class="dir-stats-bar__number">{filteredVenues.filter(v => v.data.verified).length}</span>
          <span class="dir-stats-bar__label">Verificados</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Venues Grid -->
  <section class="section" id="venues">
    <div class="container">
      <SectionHeader
        title={`Venues para ${config.label}`}
        subtitle={`${filteredVenues.length} opciones`}
        description={[
          `Todos los venues que aceptan ${config.plural} en CDMX y Estado de México.`,
          `Ordenados por relevancia: primero destacados, premium y mejor calificados.`
        ]}
      />

      <div class="dir-grid dir-grid--3">
        {filteredVenues.map(venue => (
          <article class="venue-card">
            <a href={`/directorio/${venue.data.region}/${venue.data.zoneSlug}/${venue.id.split('/').pop()?.replace('.md', '')}/`} class="venue-card__link">
              <div class="venue-card__image-wrapper">
                <img
                  src={venue.data.image || "/images/placeholder-venue.jpg"}
                  alt={venue.data.name}
                  class="venue-card__image"
                  loading="lazy"
                  width="400"
                  height="300"
                />
                <div class="venue-card__badges">
                  {venue.data.premium && <span class="venue-card__badge venue-card__badge--premium">Premium</span>}
                  {venue.data.verified && <span class="venue-card__badge venue-card__badge--verified">Verificado</span>}
                </div>
                <span class="venue-card__price-badge">{venue.data.priceRange}</span>
              </div>
              <div class="venue-card__content">
                <span class="venue-card__type">{venueTypeLabels[venue.data.type] || venue.data.type}</span>
                <h3 class="venue-card__name">{venue.data.name}</h3>
                <p class="venue-card__location">
                  <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {venue.data.zone}, {venue.data.region === "cdmx" ? "CDMX" : "Edo. Méx."}
                </p>
                <p class="venue-card__description">{venue.data.shortDescription}</p>
                <div class="venue-card__meta">
                  <span class="venue-card__capacity"><strong>{venue.data.capacity.min}-{venue.data.capacity.max}</strong> personas</span>
                  {venue.data.rating && (
                    <span class="venue-card__rating">
                      <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {venue.data.rating}
                    </span>
                  )}
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      {filteredVenues.length === 0 && (
        <div class="dir-empty-state">
          <p>No encontramos venues para {config.plural} en este momento.</p>
          <a href="/directorio/" class="btn btn--primary">Ver todo el directorio</a>
        </div>
      )}
    </div>
  </section>

  <!-- Related Event Types -->
  <section class="section section--alt">
    <div class="container">
      <SectionHeader
        title="Explora por Tipo de Evento"
        subtitle="Más opciones"
        description={[
          "Cada tipo de evento tiene requerimientos diferentes.",
          "Explora otras categorías para encontrar el venue ideal."
        ]}
      />

      <div class="dir-event-types-grid">
        {Object.entries(eventTypeConfig).filter(([key]) => key !== eventType).slice(0, 6).map(([key, cfg]) => (
          <a href={`/directorio/tipo-evento/${key}/`} class="dir-event-type-card">
            <span class="dir-event-type-card__name">{cfg.label}</span>
            <span class="dir-event-type-card__count">
              {allVenues.filter(v => v.data.eventTypes?.includes(key)).length} venues
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    headline={`¿Tu ${config.plural.toLowerCase()} será en alguno de estos venues?`}
    subheadline="Cotiza el equipo que necesitas: mobiliario, carpas, iluminación, audio y más. Llevamos todo a donde sea tu evento."
    primaryCTA={{ label: "Cotizar equipo", href: "/cotizar/" }}
    secondaryCTA={{ label: "Ver servicios", href: "/servicios/" }}
    variant="accent"
  />
</PageLayout>
