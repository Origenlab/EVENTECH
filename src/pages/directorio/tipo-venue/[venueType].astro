  },
  "salones": {
    type: "salon",
    label: "Salón",
    labelPlural: "Salones",
    description: "Salones de eventos cerrados. Espacios climatizados con todas las amenidades para cualquier clima.",
    heroSubtitle: "Salones de eventos profesionales con climatización, iluminación y sonido incluido. La garantía de un evento perfecto sin importar el clima.",
