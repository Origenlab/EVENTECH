      venues.slice(0, 10).map(v => ({
        name: v.data.name,
        url: `/directorio/${region}/${v.data.zoneSlug}/${v.id.split('/').pop()?.replace('.md', '')}/`,
        image: v.data.image,
        description: v.data.shortDescription,
      }))
    ),
  ] : []),
  // Add CollectionPage schema for zone pages
  ...(type === "zone" && venues ? [
    collectionPageJsonLd({
      name: `Venues para Eventos en ${zoneName}`,
      description: `Salones, jardines y haciendas para bodas, XV años y eventos en ${zoneName}, ${regionLabels[region]}`,
      url: `/directorio/${region}/${zone}/`,
      numberOfItems: venues.length,
      areaServed: `${zoneName}, ${regionLabels[region]}`,
    }),
    itemListJsonLd(
      venues.map(v => ({
        name: v.data.name,
        url: `/directorio/${region}/${zone}/${v.id.split('/').pop()?.replace('.md', '')}/`,
        image: v.data.image,
        description: v.data.shortDescription,
      }))
    ),
    ...(zonasDirectorio[zone]?.faqs ? [faqJsonLd(zonasDirectorio[zone]!.faqs!)] : []),
  ] : []),
  // Add venue schema for venue pages
  ...(type === "venue" && venue ? [
    venueJsonLd({
      name: venue.data.name,
      description: venue.data.seoDescription || venue.data.shortDescription,
      url: `/directorio/${region}/${zone}/${venue.data.slug}/`,
      image: heroSrc,
      address: {
        street: venue.data.address,
        locality: venue.data.zone,
        region: venue.data.region === "cdmx" ? "Ciudad de México" : "Estado de México",
        postalCode: venue.data.postalCode,
      },
      geo: venue.data.coordinates,
      telephone: venue.data.contact?.phone,
      email: venue.data.contact?.email,
      priceRange: venue.data.priceRange,
      capacity: venue.data.capacity,
      // aggregateRating solo si la ficha tiene reviewsSource (fuente real
      // citable). Ratings sin fuente en structured data = fake reviews para
      // Google, riesgo de acción manual. Ver vault Template-Ficha-Venue.
      rating: hasPublicReviewSource ? venue.data.rating : undefined,
      reviewCount: hasPublicReviewSource ? venue.data.reviewCount : undefined,
      amenities: venue.data.amenities,
      openingHours: venue.data.schedule,
    }),
    // FAQ Schema — activa rich results (FAQ accordion) en SERP de Google
    ...(venue.data.faqs && venue.data.faqs.length > 0
      ? [faqJsonLd(venue.data.faqs)]
      : []
    ),
    // Review Schema — solo fichas con reviewsSource (misma regla que aggregateRating)
    ...(hasPublicReviewSource && venue.data.reviews && venue.data.reviews.length > 0
      ? [{
          "@context": "https://schema.org",
          "@type": "EventVenue",
          "@id": `${SITE.url}/directorio/${region}/${zone}/${venue.data.slug}/#venue`,
          name: venue.data.name,
          review: venue.data.reviews.map((r: VenueReview) => ({
            "@type": "Review",
            author: { "@type": "Person", name: r.author },
            datePublished: r.date,
            reviewRating: {
              "@type": "Rating",
              ratingValue: r.rating,
              bestRating: 5,
              worstRating: 1,
            },
            reviewBody: r.text,
          })),
        }]
      : []
    ),
  ] : []),
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  jsonLd={jsonLd}
>
  <Breadcrumbs items={breadcrumbItems} slot="breadcrumbs" />

  {/* ═══════════════════════════════════════════════════════════════════════
      REGION PAGE
      ═══════════════════════════════════════════════════════════════════════ */}
  {type === "region" && venues && (() => {
    const regionZones = [...new Set(venues.map(v => v.data.zone))].sort();
    const premiumTotal = venues.filter(v => v.data.premium).length;
    const coloniasTotal = new Set(venues.map(v => v.data.neighborhood).filter(Boolean)).size;
    return (
    <div class="hm">

      {/* HERO */}
      <section class="hm-hero" aria-labelledby="rg-hero-heading">
        <div class="hm__wrap hm-hero__wrap">
          <div class="hm-hero__grid">
            <div class="hm-hero__main">
              <p class="hm__eyebrow hm-hero__eyebrow">Directorio · {regionLabels[region]}</p>
              <h1 id="rg-hero-heading">Salones y venues para eventos en <em>{regionLabels[region]}</em></h1>
              <p class="hm-hero__lead">
                {venues.length}+ espacios documentados en {regionZones.length} {region === "cdmx" ? "zonas" : "municipios"}.
                Los conocemos desde adentro porque llevamos el equipo.
              </p>
              <div class="sv-hero__ctas">
                <a class="hm__btn hm__btn--gold" href="#venues">
                  Ver todos los venues
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7" /></svg>
                </a>
                <a class="hm__btn hm__btn--ghost" href="/cotizar/">Cotizar equipo</a>
              </div>
            </div>
            <div class="hm-hero__seo">
              <p>
                Cubrimos {regionLabels[region]} con datos de primera mano: capacidades reales,
                accesos de carga, restricciones técnicas y los detalles que los planners necesitan
                pero los directorios genéricos no publican.
              </p>
              <p>
                Selecciona la zona donde será tu evento y explora los venues disponibles. Conocemos
                los proveedores locales y la logística de cada una.
              </p>
            </div>
          </div>
        </div>
      </section>

      {/* STATS */}
      <section class="dr-stats" aria-label="Indicadores de la región">
        <div class="hm__wrap dr-stats__wrap">
          <dl class="dr-stats__grid">
            <div class="dr-stats__item"><dt class="dr-stats__num">{venues.length}<span>+</span></dt><dd class="dr-stats__label">Venues</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{regionZones.length}</dt><dd class="dr-stats__label">{region === "cdmx" ? "Zonas" : "Municipios"}</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{premiumTotal}</dt><dd class="dr-stats__label">Premium</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{coloniasTotal}</dt><dd class="dr-stats__label">Colonias</dd></div>
          </dl>
        </div>
      </section>

      {/* ZONAS */}
      <section class="hm__section" aria-labelledby="rg-zonas-heading">
        <div class="hm__wrap">
          <div class="hm__head hm__head--split">
            <div class="hm__head-title">
              <p class="hm__eyebrow">Explora por ubicación</p>
              <h2 id="rg-zonas-heading">{region === "cdmx" ? "Zonas" : "Municipios"} en {regionLabels[region]}</h2>
              <p class="hm__head-sub">Selecciona dónde será tu evento.</p>
            </div>
            <div class="hm__head-copy">
              <p>Cada zona tiene una atmósfera y una logística distintas. Te mostramos cuántos venues hay en cada una para que empieces por donde mejor te convenga.</p>
              <p>Hemos montado eventos en la mayoría de estos espacios, así que podemos asesorarte sobre cuál funciona mejor para tu tipo de celebración y presupuesto.</p>
            </div>
          </div>

          <div class="dr-zone-grid">
            {regionZones.map(zn => {
              const zoneVenues = venues.filter(v => v.data.zone === zn);
              const zoneSlug = zoneVenues[0]?.data.zoneSlug;
              const allTypes = [...new Set(zoneVenues.map(v => venueTypeLabels[v.data.type] || v.data.type))];
              const types = allTypes.slice(0, 3);
              const premiumCount = zoneVenues.filter(v => v.data.premium).length;
              const coloniasCount = new Set(zoneVenues.map(v => v.data.neighborhood).filter(Boolean)).size;
              return (
                <a href={`/directorio/${region}/${zoneSlug}/`} class="dr-zone-card">
                  <div class="dr-zone-card__top">
                    <span class="dr-zone-card__ic">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    </span>
                    {premiumCount > 0 && <span class="dr-zone-card__badge">{premiumCount} Premium</span>}
                  </div>
                  <h3 class="dr-zone-card__name">{zn}</h3>
                  <p class="dr-zone-card__desc">{zoneVenues.length} venues para bodas, XV años y eventos corporativos.</p>
                  <div class="dr-zone-card__types">
                    {types.map(t => <span class="dr-zone-card__type">{t}</span>)}
                    {allTypes.length > 3 && <span class="dr-zone-card__type dr-zone-card__type--more">+{allTypes.length - 3}</span>}
                  </div>
                  <div class="dr-zone-card__stats">
                    <div class="dr-zone-card__stat"><span class="dr-zone-card__stat-value">{zoneVenues.length}</span><span class="dr-zone-card__stat-label">Venues</span></div>
                    <div class="dr-zone-card__stat"><span class="dr-zone-card__stat-value">{coloniasCount}</span><span class="dr-zone-card__stat-label">Colonias</span></div>
                    <div class="dr-zone-card__stat"><span class="dr-zone-card__stat-value">{allTypes.length}</span><span class="dr-zone-card__stat-label">Tipos</span></div>
                  </div>
                  <span class="dr-zone-card__cta">
                    Ver venues
                    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>

      {/* TODOS LOS VENUES */}
      <section id="venues" class="hm__section hm__section--ivory" aria-labelledby="rg-venues-heading">
        <div class="hm__wrap">
          <div class="hm__head hm__head--split">
            <div class="hm__head-title">
              <p class="hm__eyebrow">{venues.length} opciones</p>
              <h2 id="rg-venues-heading">Todos los venues en {regionLabels[region]}</h2>
              <p class="hm__head-sub">Capacidades, precios y servicios documentados.</p>
            </div>
            <div class="hm__head-copy">
              <p>Hemos trabajado en muchos de estos espacios y conocemos sus características técnicas: toma eléctrica, altura de techo, accesos de carga y restricciones.</p>
              <p>Si necesitas equipo —mobiliario, audio, iluminación, carpas o pistas— lo coordinamos directamente con el venue para que el día del evento no haya fricciones.</p>
            </div>
          </div>

          <div class="dr-venue-grid">
            {venues.map(v => <VenueCard venue={v} typeLabel={venueTypeLabels[v.data.type] || v.data.type} />)}
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="hm__section hm-cta">
        <div class="hm__wrap">
          <h2>¿Tu evento será en {regionLabels[region]}?</h2>
          <p>Cotiza el equipo que necesitas: mobiliario, carpas, audio, iluminación y pistas. Conocemos estos venues y te asesoramos sin costo.</p>
          <div class="hm-cta__row">
            <a class="hm__btn hm__btn--gold" href="/cotizar/">Cotizar equipo</a>
            <a class="hm__btn hm__btn--ghost" href="/directorio/">Ver todo el directorio</a>
          </div>
        </div>
      </section>

    </div>
    );
  })()}

  {/* ═══════════════════════════════════════════════════════════════════════
      ZONE PAGE
      ═══════════════════════════════════════════════════════════════════════ */}
  {type === "zone" && venues && (() => {
    const zoneInfo = zoneConfig[zone] || {
      description: `${zoneName} ofrece venues de calidad para todo tipo de eventos. Explora las opciones disponibles y encuentra el espacio perfecto.`,
      highlights: ["Venues verificados", "Variedad de estilos", "Asesoría disponible"],
      character: "Versatilidad"
    };
    const zoneVenueTypes = [...new Set(venues.map(v => v.data.type))];
    const zoneEventTypes = [...new Set(venues.flatMap(v => v.data.eventTypes || []))];
    const avgCapacity = Math.round(venues.reduce((sum, v) => sum + v.data.capacity.max, 0) / venues.length);
    const premiumCount = venues.filter(v => v.data.premium).length;
    const zoneColoniasCount = new Set(venues.map(v => v.data.neighborhood).filter(Boolean)).size;

    return (
    <div class="hm">

      {/* HERO */}
      <section class="hm-hero" aria-labelledby="zn-hero-heading">
        <div class="hm__wrap hm-hero__wrap">
          <div class="hm-hero__grid">
            <div class="hm-hero__main">
              <p class="hm__eyebrow hm-hero__eyebrow">{regionLabels[region]} · {zoneInfo.character}</p>
              <h1 id="zn-hero-heading">Salones y venues para eventos en <em>{zoneName}</em></h1>
              <p class="hm-hero__lead">
                {venues.length} {venues.length === 1 ? "venue verificado" : "venues verificados"} ·
                capacidad promedio {avgCapacity} personas.
              </p>
              <div class="sv-hero__ctas">
                <a class="hm__btn hm__btn--gold" href="#venues">
                  Ver venues
                  <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M5 12l7 7 7-7" /></svg>
                </a>
                <a class="hm__btn hm__btn--ghost" href="/cotizar/">Cotizar equipo</a>
              </div>
            </div>
            <div class="hm-hero__seo">
              <p>{zoneInfo.description}</p>
              <p>Lo que destaca: {zoneInfo.highlights.map((h, i) => (<>{i > 0 && " · "}<strong>{h}</strong></>))}.</p>
              {zonasDirectorio[zone]?.intro?.map((p) => (<p set:html={p} />))}
            </div>
          </div>
        </div>
      </section>

      {/* STATS */}
      <section class="dr-stats" aria-label={`Indicadores de ${zoneName}`}>
        <div class="hm__wrap dr-stats__wrap">
          <dl class="dr-stats__grid dr-stats__grid--5">
            <div class="dr-stats__item"><dt class="dr-stats__num">{venues.length}</dt><dd class="dr-stats__label">Venues</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{zoneVenueTypes.length}</dt><dd class="dr-stats__label">Tipos</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{premiumCount}</dt><dd class="dr-stats__label">Premium</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{zoneColoniasCount}</dt><dd class="dr-stats__label">Colonias</dd></div>
            <div class="dr-stats__item"><dt class="dr-stats__num">{avgCapacity}</dt><dd class="dr-stats__label">Cap. prom.</dd></div>
          </dl>
        </div>
      </section>

      {/* TIPOS DE EVENTO + TIPOS DE VENUE */}
      {(zoneEventTypes.length > 0 || zoneVenueTypes.length > 1) && (
        <section class="hm__section" aria-labelledby="zn-filters-heading">
          <div class="hm__wrap">
            <div class="hm__head hm__head--split">
              <div class="hm__head-title">
                <p class="hm__eyebrow">Afina tu búsqueda</p>
                <h2 id="zn-filters-heading">Explora {zoneName} por categoría</h2>
                <p class="hm__head-sub">Por tipo de evento o de espacio.</p>
              </div>
              <div class="hm__head-copy">
                <p>Cada celebración tiene requerimientos distintos y cada tipo de espacio una atmósfera propia. Filtra para llegar más rápido a lo que buscas.</p>
                <p>Los enlaces te llevan a más venues similares en toda la región, no solo en {zoneName}.</p>
              </div>
            </div>

            {zoneEventTypes.length > 0 && (
              <>
                <p class="hm__eyebrow" style="margin-bottom:6px;">Por tipo de evento</p>
                <div class="dr-etype-grid" style="margin-top:0;">
                  {zoneEventTypes.filter(hasEventTypePage).slice(0, 10).map(eventType => {
                    const countInZone = venues.filter(v => v.data.eventTypes?.includes(eventType)).length;
                    return (
                      <a href={`/directorio/tipo-evento/${eventType}/`} class="dr-etype-tag">
                        <span class="dr-etype-tag__name">{eventTypeLabels[eventType] || eventType}</span>
                        <span class="dr-etype-tag__count">{countInZone}</span>
                      </a>
                    );
                  })}
                </div>
              </>
            )}

            {zoneVenueTypes.length > 1 && (
              <>
                <p class="hm__eyebrow" style="margin:32px 0 6px;">Por tipo de venue</p>
                <div class="dr-etype-grid" style="margin-top:0;">
                  {zoneVenueTypes.map(venueType => {
                    const countInZone = venues.filter(v => v.data.type === venueType).length;
                    const typeSlug = venueTypeSlugs[venueType];
                    const label = venueTypeLabels[venueType] || venueType;
                    // Sin landing publicada → etiqueta de texto, no enlace roto.
                    if (!typeSlug || !hasVenueTypePage(typeSlug)) {
                      return (
                        <span class="dr-etype-tag">
                          <span class="dr-etype-tag__name">{label}</span>
                          <span class="dr-etype-tag__count">{countInZone}</span>
                        </span>
                      );
                    }
                    return (
                      <a href={`/directorio/tipo-venue/${typeSlug}/`} class="dr-etype-tag">
                        <span class="dr-etype-tag__name">{label}</span>
                        <span class="dr-etype-tag__count">{countInZone}</span>
                      </a>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        </section>
      )}

      {/* TODOS LOS VENUES */}
      <section id="venues" class="hm__section hm__section--ivory" aria-labelledby="zn-venues-heading">
        <div class="hm__wrap">
          <div class="hm__head hm__head--split">
            <div class="hm__head-title">
              <p class="hm__eyebrow">{venues.length} opciones</p>
              <h2 id="zn-venues-heading">Todos los venues en {zoneName}</h2>
              <p class="hm__head-sub">Verificados de primera mano.</p>
            </div>
            <div class="hm__head-copy">
              <p>Hemos montado eventos en muchos de estos espacios y conocemos su logística técnica: tomas eléctricas, accesos de carga, altura de techo y restricciones de ruido.</p>
              <p>Eso nos permite asesorarte sobre qué equipo funciona mejor en cada uno y coordinar la instalación directamente con el venue.</p>
            </div>
          </div>

          {showZoneFilters && (
            <div class="dr-filters" id="drFilters">
              <div class="dr-filters__group">
                <label class="dr-filters__label" for="drFilterColonia">Colonia</label>
                <select class="dr-filters__select" id="drFilterColonia">
                  <option value="">Todas ({venues.length})</option>
                  {zoneColonias.map(([c, n]) => <option value={c}>{c} ({n})</option>)}
                </select>
              </div>
              <div class="dr-filters__group">
                <span class="dr-filters__label">Capacidad</span>
                <div class="dr-filters__pills" data-filter="cap">
                  <button class="dr-filters__pill dr-filters__pill--active" data-value="">Todas</button>
                  <button class="dr-filters__pill" data-value="s">Hasta 150</button>
                  <button class="dr-filters__pill" data-value="m">150–400</button>
                  <button class="dr-filters__pill" data-value="l">400+</button>
                </div>
              </div>
              <div class="dr-filters__group">
                <span class="dr-filters__label">Precio</span>
                <div class="dr-filters__pills" data-filter="precio">
                  <button class="dr-filters__pill dr-filters__pill--active" data-value="">Todos</button>
                  <button class="dr-filters__pill" data-value="$">$</button>
                  <button class="dr-filters__pill" data-value="$$">$$</button>
                  <button class="dr-filters__pill" data-value="$$$">$$$</button>
                  <button class="dr-filters__pill" data-value="$$$$">$$$$</button>
                </div>
              </div>
              <p class="dr-filters__count" id="drFilterCount" aria-live="polite"></p>
            </div>
          )}

          <div class="dr-venue-grid" id="drVenueGrid">
            {venues.map(v => (
              <div
                class="dr-fitem"
                data-colonia={v.data.neighborhood || "Otras"}
                data-cap={v.data.capacity.max <= 150 ? "s" : v.data.capacity.max <= 400 ? "m" : "l"}
                data-precio={v.data.priceRange}
              >
                <VenueCard venue={v} typeLabel={venueTypeLabels[v.data.type] || v.data.type} location={v.data.neighborhood || v.data.zone} />
              </div>
            ))}
          </div>
          {showZoneFilters && (
            <p class="dr-filters__empty" id="drFilterEmpty" hidden>
              Ningún venue coincide con esos filtros. <button class="dr-filters__reset" id="drFilterReset">Limpiar filtros</button>
            </p>
          )}
        </div>
      </section>

      {showZoneFilters && (
        <script is:inline>
          (function () {
            var state = { colonia: "", cap: "", precio: "" };
            var items = Array.prototype.slice.call(document.querySelectorAll("#drVenueGrid .dr-fitem"));
            var count = document.getElementById("drFilterCount");
            var empty = document.getElementById("drFilterEmpty");
            function apply() {
              var visible = 0;
              items.forEach(function (el) {
                var ok = (!state.colonia || el.dataset.colonia === state.colonia)
                  && (!state.cap || el.dataset.cap === state.cap)
                  && (!state.precio || el.dataset.precio === state.precio);
                el.style.display = ok ? "" : "none";
                if (ok) visible++;
              });
              if (count) count.textContent = (state.colonia || state.cap || state.precio)
                ? visible + " de " + items.length + " venues"
                : "";
              if (empty) empty.hidden = visible !== 0;
            }
            var sel = document.getElementById("drFilterColonia");
            if (sel) sel.addEventListener("change", function () { state.colonia = sel.value; apply(); });
            document.querySelectorAll(".dr-filters__pills").forEach(function (group) {
              var key = group.dataset.filter;
              group.addEventListener("click", function (e) {
                var btn = e.target.closest(".dr-filters__pill");
                if (!btn) return;
                group.querySelectorAll(".dr-filters__pill").forEach(function (b) { b.classList.remove("dr-filters__pill--active"); });
                btn.classList.add("dr-filters__pill--active");
                state[key] = btn.dataset.value;
                apply();
              });
            });
            var reset = document.getElementById("drFilterReset");
            if (reset) reset.addEventListener("click", function () {
              state = { colonia: "", cap: "", precio: "" };
              if (sel) sel.value = "";
              document.querySelectorAll(".dr-filters__pills").forEach(function (group) {
                group.querySelectorAll(".dr-filters__pill").forEach(function (b, i) {
                  b.classList.toggle("dr-filters__pill--active", i === 0);
                });
              });
              apply();
            });
          })();
        </script>
      )}

      {/* FAQ */}
      {zonasDirectorio[zone]?.faqs && (
        <section class="hm__section" aria-labelledby="zn-faq-heading">
          <div class="hm__wrap">
            <div class="hm__head">
              <p class="hm__eyebrow">Preguntas frecuentes</p>
              <h2 id="zn-faq-heading">Salones para eventos en {zoneName}: dudas comunes</h2>
            </div>
            <div class="dr-zfaq">
              {zonasDirectorio[zone]!.faqs!.map((f) => (
                <details class="dr-zfaq__item">
                  <summary class="dr-zfaq__q">{f.question}</summary>
                  <div class="dr-zfaq__a" set:html={f.answer} />
                </details>
              ))}
            </div>
          </div>
        </section>
      )}

      {/* NAV */}
      <section class="hm__section" style="padding-block:clamp(32px,4vw,48px);">
        <div class="hm__wrap">
          <div class="dr-nav">
            <a href={`/directorio/${region}/`} class="dr-nav__link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
              Todas las zonas en {regionLabels[region]}
            </a>
            <a href="/directorio/" class="dr-nav__link">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Todo el directorio
            </a>
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="hm__section hm-cta">
        <div class="hm__wrap">
          <h2>¿Tu evento será en {zoneName}?</h2>
          <p>Cotiza mobiliario, carpas, audio, iluminación y pistas. Conocemos los venues de la zona y te asesoramos sin costo.</p>
          <div class="hm-cta__row">
            <a class="hm__btn hm__btn--gold" href="/cotizar/">Cotizar equipo</a>
            <a class="hm__btn hm__btn--ghost" href="/servicios/">Ver servicios</a>
          </div>
        </div>
      </section>

    </div>
    );
  })()}

  {/* ═══════════════════════════════════════════════════════════════════════
      VENUE PAGE
      ═══════════════════════════════════════════════════════════════════════ */}
  {type === "venue" && venue && (
    <div class="hm">

      {/* HERO */}
      <section class="dr-vhero">
        <div class="hm__wrap dr-vhero__wrap">
          <div class="dr-vhero__badges">
            <span class="dr-vhero__badge dr-vhero__badge--type">{venueTypeLabels[venue.data.type] || venue.data.type}</span>
            {venue.data.premium && <span class="dr-vhero__badge dr-vhero__badge--premium">Premium</span>}
            {hasPublicReviewSource && <span class="dr-vhero__badge dr-vhero__badge--verified" title="Calificación y datos contrastados con fuente pública">Datos verificados</span>}
          </div>
          <h1>{venue.data.name}</h1>
          <p class="dr-vhero__location">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {venue.data.address}, {venue.data.zone}
            {venue.data.reviewsSource && venue.data.rating && (
              <span class="dr-vhero__rating">★ {venue.data.rating}{venue.data.reviewCount ? ` (${venue.data.reviewCount})` : ""}</span>
            )}
          </p>
        </div>
      </section>

      <section class="hm__section">
        <div class="hm__wrap">
          <div class="dr-vp">
            {/* ── MAIN ── */}
            <main class="dr-vp__main">

              {/* Galería */}
              <div class={`dr-vgal${galleryImgs.length > 0 ? "" : " dr-vgal--solo"}`}>
                <div class="dr-vgal__main">
                  <img src={heroSrc} alt={venue.data.name} width="800" height="550" fetchpriority="high" decoding="async" />
                </div>
                {galleryImgs.length > 0 && (
                  <div class="dr-vgal__thumbs">
                    {galleryImgs.slice(0, 2).map((img: string, i: number) => (
                      <div class="dr-vgal__thumb">
                        <img src={img} alt={`${venue.data.name} — ${i + 1}`} loading="lazy" width="300" height="220" />
                      </div>
                    ))}
                  </div>
                )}
              </div>

              {/* Descripción / contenido markdown */}
              <div class="dr-prose dr-vsec">
                {VenueContent ? <VenueContent /> : (
                  <>
                    <h2 class="dr-vsec__title">Acerca del venue</h2>
                    <p>{venue.data.description}</p>
                  </>
                )}
              </div>

              {/* Amenidades */}
              {venue.data.amenities && venue.data.amenities.length > 0 && (
                <div class="dr-vsec">
                  <h2 class="dr-vsec__title">Amenidades</h2>
                  <div class="dr-amenities">
                    {venue.data.amenities.map((amenity: string) => (
                      <div class="dr-amenity">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        {amenityLabels[amenity] || amenity}
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Ideal para */}
              {venue.data.eventTypes && venue.data.eventTypes.length > 0 && (
                <div class="dr-vsec">
                  <h2 class="dr-vsec__title">Ideal para</h2>
                  <div class="dr-chips">
                    {venue.data.eventTypes.map((eventType: string) => {
                      const label = eventTypeLabels[eventType] || eventType;
                      // Sin landing publicada → chip de texto, no enlace roto.
                      return hasEventTypePage(eventType)
                        ? <a href={`/directorio/tipo-evento/${eventType}/`} class="dr-chip">{label}</a>
                        : <span class="dr-chip">{label}</span>;
                    })}
                  </div>
                  <p class="dr-vsec__hint">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                    Haz clic en cualquier tipo de evento para ver más venues similares.
                  </p>
                </div>
              )}

              {/* Servicios incluidos */}
              {venue.data.servicesIncluded && venue.data.servicesIncluded.length > 0 && (
                <div class="dr-vsec">
                  <h2 class="dr-vsec__title">Servicios incluidos</h2>
                  <div class="dr-included">
                    {venue.data.servicesIncluded.map((service: string) => (
                      <div class="dr-included__item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                        <span>{service.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase())}</span>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Horarios + precios */}
              {(venue.data.schedule || venue.data.pricePerPerson || venue.data.rentalPrice) && (
                <div class="dr-infobox">
                  {venue.data.schedule && (
                    <div class="dr-infobox__item">
                      <div class="dr-infobox__ic">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      </div>
                      <div class="dr-infobox__c">
                        <h3>Horarios</h3>
                        {venue.data.schedule.weekdays && <p><strong>Entre semana:</strong> {venue.data.schedule.weekdays}</p>}
                        {venue.data.schedule.weekends && <p><strong>Fines de semana:</strong> {venue.data.schedule.weekends}</p>}
                        {venue.data.schedule.minHours && <p class="dr-infobox__note">Mínimo {venue.data.schedule.minHours} horas</p>}
                      </div>
                    </div>
                  )}
                  {(venue.data.pricePerPerson || venue.data.rentalPrice) && (
                    <div class="dr-infobox__item">
                      <div class="dr-infobox__ic">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                      </div>
                      <div class="dr-infobox__c">
                        <h3>Precios</h3>
                        {venue.data.pricePerPerson && <p><strong>Por persona:</strong> ${venue.data.pricePerPerson.min.toLocaleString()} – ${venue.data.pricePerPerson.max.toLocaleString()} MXN</p>}
                        {venue.data.rentalPrice && <p><strong>Renta:</strong> ${venue.data.rentalPrice.min.toLocaleString()} – ${venue.data.rentalPrice.max.toLocaleString()} MXN</p>}
                        <span class="dr-infobox__price">{venue.data.priceRange}</span>
                      </div>
                    </div>
                  )}
                </div>
              )}

              {/* Restricciones */}
              {venue.data.restrictions && venue.data.restrictions.length > 0 && (
                <div class="dr-warn">
                  <h3 class="dr-warn__title">
                    <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    Consideraciones importantes
                  </h3>
                  <ul>{venue.data.restrictions.map((r: string) => <li>{r}</li>)}</ul>
                </div>
              )}

              {/* Reviews — solo con fuente real citable (reviewsSource) */}
              {venue.data.reviewsSource && venue.data.reviews && venue.data.reviews.length > 0 && (
                <div class="dr-vsec">
                  <h2 class="dr-vsec__title">Opiniones</h2>
                  <div class="dr-reviews">
                    {venue.data.reviews.map((review: { author: string; date: string; rating: number; text: string; eventType?: string }) => (
                      <div class="dr-review">
                        <div class="dr-review__head">
                          <span class="dr-review__author">{review.author}</span>
                          <span class="dr-review__stars">{"★".repeat(review.rating)}<span style="opacity:.3;">{"★".repeat(5 - review.rating)}</span></span>
                        </div>
                        <p class="dr-review__text">{review.text}</p>
                        <p class="dr-review__meta">{[review.eventType, review.date].filter(Boolean).join(" • ")}</p>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {/* Partner EVENTECH */}
              {venue.data.eventechPartner && (
                <div class="dr-partner">
                  <div class="dr-partner__ic">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
                  </div>
                  <div>
                    <h3>Partner oficial EVENTECH</h3>
                    <p>Hemos trabajado en este venue y conocemos sus instalaciones. Podemos asesorarte sobre el equipo ideal para tu evento.</p>
                    {venue.data.eventechDiscount && <span class="dr-partner__discount">{venue.data.eventechDiscount}</span>}
                  </div>
                </div>
              )}

              {/* Ubicación */}
              {venue.data.googleMapsUrl && (
                <div class="dr-vsec">
                  <h2 class="dr-vsec__title">Ubicación</h2>
                  {/* Mapa estático self-hosted (tiles OSM compuestos en build).
                      El iframe de terceros se descartó: OSM embed exige WebGL y
                      Google output=embed no renderiza tiles confiablemente. */}
                  {hasStaticMap && (
                    <a class="dr-loc__map" href={venue.data.googleMapsUrl} target="_blank" rel="noopener noreferrer" title="Abrir en Google Maps">
                      <img src={staticMapSrc} alt={`Mapa de ubicación de ${venue.data.name}`} loading="lazy" width="1032" height="460" />
                    </a>
                  )}
                  <div class="dr-loc">
                    <div>
                      <p class="dr-loc__address">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        {venue.data.address}
                      </p>
                      <p class="dr-loc__zone">{[venue.data.neighborhood, venue.data.zone].filter(Boolean).join(", ")}</p>
                      {venue.data.postalCode && <p class="dr-loc__postal">C.P. {venue.data.postalCode}</p>}
                    </div>
                    <a href={venue.data.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="hm__btn hm__btn--navy">
                      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
                      Ver en Google Maps
                    </a>
                  </div>
                </div>
              )}
            </main>

            {/* ── SIDEBAR ── */}
            <aside class="dr-vp__aside">

              {/* Quick info */}
              <div class="dr-card dr-card--navy">
                <h3 class="dr-quick__name">{venue.data.name}</h3>
                <p class="dr-quick__type">{venueTypeLabels[venue.data.type] || venue.data.type}</p>
                <div class="dr-quick__stats">
                  <div class="dr-quick__stat">
                    <span class="dr-quick__stat-value">{venue.data.capacity.max}</span>
                    <span class="dr-quick__stat-label">Cap. máx.</span>
                  </div>
                  {venue.data.reviewsSource && venue.data.rating && (
                    <div class="dr-quick__stat">
                      <span class="dr-quick__stat-value">
                        <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {venue.data.rating}
                      </span>
                      <span class="dr-quick__stat-label">{venue.data.reviewCount} reseñas</span>
                    </div>
                  )}
                </div>
              </div>

              {/* CTA EVENTECH */}
              <div class="dr-card dr-card--navy">
                <h3 class="dr-ctacard__title">¿Tu evento será aquí?</h3>
                <p class="dr-ctacard__text">Cotiza el equipo que necesitas: mobiliario, audio, iluminación, carpas y pistas.</p>
                <a href={`https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent(`Hola, me interesa cotizar equipo para un evento en ${venue.data.name}`)}`} class="dr-ctacard__btn" target="_blank" rel="noopener noreferrer">
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Cotizar con EVENTECH
                </a>
              </div>

              {/* Contacto del venue */}
              {venue.data.contact && (venue.data.contact.whatsapp || venue.data.contact.phone || venue.data.contact.email || venue.data.contact.website || venue.data.contact.facebook || venue.data.contact.instagram) && (
                <div class="dr-card">
                  <h3 class="dr-card__title">Contacto del venue</h3>
                  <p class="dr-card__sub">Trato directo con el espacio</p>
                  <div class="dr-contact">
                    {venue.data.contact.whatsapp && (
                      <a href={`https://wa.me/52${venue.data.contact.whatsapp.replace(/\s/g, '')}`} class="dr-contact__item dr-contact__item--whatsapp" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                        WhatsApp del venue
                      </a>
                    )}
                    {venue.data.contact.phone && (
                      <a href={`tel:${venue.data.contact.phone.replace(/\s/g, '')}`} class="dr-contact__item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        {venue.data.contact.phone}
                      </a>
                    )}
                    {venue.data.contact.email && (
                      <a href={`mailto:${venue.data.contact.email}`} class="dr-contact__item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        Email
                      </a>
                    )}
                    {venue.data.contact.website && (
                      <a href={venue.data.contact.website} class="dr-contact__item" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                        Sitio oficial
                      </a>
                    )}
                    {venue.data.contact.facebook && (
                      <a href={venue.data.contact.facebook.startsWith("http") ? venue.data.contact.facebook : `https://www.facebook.com/${venue.data.contact.facebook}`} class="dr-contact__item" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                        Facebook
                      </a>
                    )}
                    {venue.data.contact.instagram && (
                      <a href={`https://www.instagram.com/${venue.data.contact.instagram.replace('@','')}/`} class="dr-contact__item" target="_blank" rel="noopener noreferrer">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                        Instagram
                      </a>
                    )}
                  </div>
                </div>
              )}

              {/* Capacidad */}
              <div class="dr-card">
                <h3 class="dr-card__title">Capacidad</h3>
                <div class="dr-cap">
                  <div class="dr-cap__item"><span class="dr-cap__label">Banquete</span><span class="dr-cap__value">{venue.data.capacity.min} – {venue.data.capacity.max}</span></div>
                  {venue.data.capacity.cocktail && <div class="dr-cap__item"><span class="dr-cap__label">Cóctel</span><span class="dr-cap__value">{venue.data.capacity.cocktail}</span></div>}
                  {venue.data.capacity.ceremony && <div class="dr-cap__item"><span class="dr-cap__label">Ceremonia</span><span class="dr-cap__value">{venue.data.capacity.ceremony}</span></div>}
                </div>
              </div>

              {/* Servicios EVENTECH */}
              <div class="dr-card">
                <h3 class="dr-card__title">Servicios EVENTECH</h3>
                <p class="dr-card__sub">Equipo profesional para tu evento</p>
                <div class="dr-svc-grid">
                  {relevantServices.map(service => (
                    <a href={service.href} class="dr-svc-link">
                      {service.icon === "chair" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 18v3h4v-3"/><path d="M16 18v3h4v-3"/><path d="M12 14v4"/><path d="M4 6h16a2 2 0 0 1 2 2v4a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2z"/></svg>}
                      {service.icon === "speaker" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"/><circle cx="12" cy="14" r="4"/><line x1="12" y1="6" x2="12" y2="6"/></svg>}
                      {service.icon === "tent" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/><path d="M12 22V12"/></svg>}
                      {service.icon === "lightbulb" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7z"/></svg>}
                      {service.icon === "music" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="5.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="15.5" r="2.5"/><path d="M8 17V5l12-2v12"/></svg>}
                      {service.icon === "utensils" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/></svg>}
                      {service.icon === "balloon" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2c-3.3 0-6 2.7-6 6 0 3.6 2.7 6.4 6 6.9 3.3-.5 6-3.3 6-6.9 0-3.3-2.7-6-6-6z"/><path d="M12 14.9V18"/><path d="M10.5 21c.5-1 2.5-1 3 0"/></svg>}
                      {service.icon === "laptop" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="12" rx="1"/><path d="M2 20h20"/></svg>}
                      {service.icon === "package" && <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>}
                      <span class="dr-svc-link__name">{service.name}</span>
                    </a>
                  ))}
                </div>
                <a href="/servicios/" class="dr-card__link">Ver todos los servicios →</a>
              </div>

              {/* Más en la zona — enlace keyword-rich a la página de zona en TODA
                  ficha (antes solo aparecía con relatedVenues>0; las fichas únicas
                  en su alcaldía quedaban sin enlace interno a su categoría). */}
              <div class="dr-card">
                <h3 class="dr-card__title">Más en {venue.data.zone}</h3>
                {relatedVenues.length > 0 && (
                  <div class="dr-related">
                    {relatedVenues.map(v => (
                      <a href={`/directorio/${v.data.region}/${v.data.zoneSlug}/${v.id.split('/').pop()?.replace('.md', '')}/`} class="dr-related__item">
                        <span>
                          <span class="dr-related__name">{v.data.name}</span>
                          <span class="dr-related__type">{venueTypeLabels[v.data.type] || v.data.type}</span>
                        </span>
                        <span class="dr-related__cap">{v.data.capacity.max} pers.</span>
                      </a>
                    ))}
                  </div>
                )}
                <a href={`/directorio/${venue.data.region}/${venue.data.zoneSlug}/`} class="dr-card__link">Ver salones de fiestas en {venue.data.zone} →</a>
              </div>

              {/* Explorar */}
              <div class="dr-card">
                <h3 class="dr-card__title">Explorar directorio</h3>
                <div class="dr-explore">
                  <a href="/directorio/cdmx/" class="dr-explore__link"><span>CDMX</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
                  <a href="/directorio/estado-mexico/" class="dr-explore__link"><span>Estado de México</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
                  <a href="/directorio/" class="dr-explore__link"><span>Todo el directorio</span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg></a>
                </div>
              </div>
            </aside>
          </div>
        </div>
      </section>

      {/* CTA */}
      <section class="hm__section hm-cta">
        <div class="hm__wrap">
          <h2>¿Encontraste tu venue?</h2>
          <p>Cotiza el equipo que necesitas: mobiliario, carpas, iluminación, audio y pistas. Conocemos este espacio y podemos asesorarte.</p>
          <div class="hm-cta__row">
            <a class="hm__btn hm__btn--gold" href="/cotizar/">Cotizar equipo</a>
            <a class="hm__btn hm__btn--ghost" href="/servicios/">Ver servicios</a>
          </div>
        </div>
      </section>

    </div>
  )}
</PageLayout>

<style>
  .dr-zfaq {
    display: grid;
    gap: 0;
    max-width: 820px;
    margin-inline: auto;
    border-top: 1px solid color-mix(in srgb, currentColor 14%, transparent);
  }
  .dr-zfaq__item {
    border-bottom: 1px solid color-mix(in srgb, currentColor 14%, transparent);
  }
  .dr-zfaq__q {
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 6px;
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .dr-zfaq__q::-webkit-details-marker { display: none; }
  .dr-zfaq__q::after {
    content: "+";
    font-size: 1.5em;
    line-height: 1;
    opacity: .5;
    flex: none;
    transition: transform .2s ease;
  }
  .dr-zfaq__item[open] .dr-zfaq__q::after { transform: rotate(45deg); }
  .dr-zfaq__a {
    padding: 0 6px 22px;
    max-width: 72ch;
    line-height: 1.7;
    opacity: .9;
  }
  .dr-zfaq__a :global(p) { margin: 0 0 .7em; }
  .dr-zfaq__a :global(p:last-child) { margin-bottom: 0; }
  .dr-zfaq__a :global(a) {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    font-weight: 600;
  }
</style>
