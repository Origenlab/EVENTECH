// Props tipados por tipo de página del directorio
type DirectorioProps =
  | { type: "region"; region: string; venues: CollectionEntry<"venues">[]; zones: string[] }
  | { type: "zone"; region: string; zone: string; zoneName: string; venues: CollectionEntry<"venues">[] }
  | { type: "venue"; region: string; zone: string; zoneName: string; venue: CollectionEntry<"venues"> };

// Generate static paths
export async function getStaticPaths() {
  const allVenues: CollectionEntry<"venues">[] = await getCollection("venues");
  const paths: Array<{ params: { slug: string }, props: DirectorioProps }> = [];

  // Regiones derivadas de la colección; las conocidas primero para orden estable.
  const KNOWN_REGIONS = ["cdmx", "estado-mexico"];
  const foundRegions = [...new Set(allVenues.map(v => v.data.region))];
  const regions = [...KNOWN_REGIONS.filter(r => foundRegions.includes(r)),
    ...foundRegions.filter(r => !KNOWN_REGIONS.includes(r))];
  // Aviso en build si aparece una región nueva (antes se omitía en silencio → venues invisibles)
  for (const r of foundRegions) {
    if (!KNOWN_REGIONS.includes(r)) {
      console.warn(`[directorio] Región no reconocida "${r}" — se genera igualmente; revisa taxonomía/labels.`);
    }
  }
  for (const region of regions) {
    const regionVenues = allVenues.filter(v => v.data.region === region);
    const zones = [...new Set(regionVenues.map(v => v.data.zoneSlug))];

    paths.push({
      params: { slug: region },
      props: {
        type: "region",
        region,
        venues: regionVenues,
        zones
      }
    });

    // Zone paths: /directorio/cdmx/polanco/
    for (const zone of zones) {
      const zoneVenues = regionVenues.filter(v => v.data.zoneSlug === zone);
      const zoneName = zoneVenues[0]?.data.zone || zone;

      paths.push({
        params: { slug: `${region}/${zone}` },
        props: {
          type: "zone",
          region,
          zone,
          zoneName,
          venues: zoneVenues
        }
      });

      // Venue paths: /directorio/cdmx/polanco/hacienda-morales/
      for (const venue of zoneVenues) {
        const venueSlug = venue.id.split('/').pop()?.replace('.md', '') || venue.id;
        paths.push({
          params: { slug: `${region}/${zone}/${venueSlug}` },
          props: {
            type: "venue",
            region,
            zone,
            zoneName,
            venue
          }
        });
      }
    }
  }

  return paths;
}

// Nota: cast plano (no union) porque el template accede a los campos según `type`;
// el union DirectorioProps garantiza el tipado en getStaticPaths, que es donde se construyen.
const { type, region, zone, zoneName, venues, venue } = Astro.props as {
  type: "region" | "zone" | "venue";
