const showZoneFilters: boolean = type === "zone" && Array.isArray(venues) && venues.length >= 6;
const zoneColonias: Array<[string, number]> = showZoneFilters
  ? [...venues.reduce((m: Map<string, number>, v: CollectionEntry<"venues">) => {
      const c = v.data.neighborhood || "Otras";
      m.set(c, (m.get(c) || 0) + 1);
      return m;
    }, new Map())].sort((a, b) => a[0].localeCompare(b[0], "es"))
  : [];

