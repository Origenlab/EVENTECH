---
/**
 * ─── EVENTECH.MX — Directorio (L2 hub, rediseño 2026) ───
 * Hub del directorio de salones, jardines, haciendas y venues en CDMX y EdoMex.
 * Homologado al Home (L1) y /servicios/: importa home-2026.css, usa clases `hm-`.
 * CSS exclusivo de esta página: namespace `dr-` al final del archivo.
 *
 * Keyword primaria: "directorio de salones para eventos CDMX"
 * Ángulo editorial: EVENTECH conoce estos venues de adentro — no de catálogo.
 */
import PageLayout from "@layouts/PageLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { SITE } from "@data/site";
import {
  breadcrumbJsonLd,
  itemListJsonLd,
  collectionPageJsonLd,
  faqJsonLd,
} from "@utils/seo";
import "@styles/home-2026.css";

// ── Venue data ───────────────────────────────────────────────────────────────
const allVenues: CollectionEntry<"venues">[] = await getCollection("venues");
const cdmxVenues = allVenues.filter((v) => v.data.region === "cdmx");
const edomexVenues = allVenues.filter(
  (v) => v.data.region === "estado-mexico"
);
const cdmxZones = [...new Set(cdmxVenues.map((v) => v.data.zone))].sort();
const edomexZones = [...new Set(edomexVenues.map((v) => v.data.zone))].sort();

const totalVenues = allVenues.length;
const totalZones = cdmxZones.length + edomexZones.length;

// Featured venues
const featuredList = allVenues
  .filter((v) => v.data.featured)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  .slice(0, 4);

// Venue type counts
const countByType = (type: string) =>
  allVenues.filter((v) => v.data.type === type).length;

// Event type counts
const countByEvent = (ev: string) =>
  allVenues.filter((v) => v.data.eventTypes?.includes(ev)).length;

// Helper — venue URL
const venueUrl = (v: CollectionEntry<"venues">) =>
  `/directorio/${v.data.region}/${v.data.zoneSlug}/${v.id.split("/").pop()?.replace(".md", "")}/`;

// ── Venue types config ───────────────────────────────────────────────────────
const venueTypesList = [
  {
    slug: "haciendas",
    type: "hacienda",
    label: "Haciendas",
    desc: "Historia y jardines monumentales",
    icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  },
  {
    slug: "jardines",
    type: "jardin",
    label: "Jardines",
    desc: "Aire libre, vegetación y luz natural",
    icon: `<path d="M12 22V10"/><path d="M5 10a7 7 0 0 1 7-7 7 7 0 0 1 7 7"/><path d="M5 14a7 7 0 0 0 7 7 7 7 0 0 0 7-7"/>`,
  },
  {
    slug: "salones",
    type: "salon",
    label: "Salones",
    desc: "Climatizados, equipados y versátiles",
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>`,
  },
  {
    slug: "hoteles",
    type: "hotel",
    label: "Hoteles",
    desc: "Servicio completo y hospedaje integrado",
    icon: `<path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16"/><path d="M1 21h22"/><path d="M9 21V11h6v10"/>`,
  },
  {
    slug: "terrazas",
    type: "terraza",
    label: "Terrazas",
    desc: "Vistas panorámicas sobre la ciudad",
    icon: `<polyline points="22 12 16 12 14 15 10 15 8 12 2 12"/><path d="M5.45 5.11 2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z"/>`,
  },
  {
    slug: "quintas",
    type: "quinta",
    label: "Quintas",
    desc: "Privacidad y espacios amplios",
    icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
  },
  {
    slug: "restaurantes",
    type: "restaurante",
    label: "Restaurantes",
    desc: "Gastronomía y ambiente curado",
    icon: `<path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>`,
  },
  {
    slug: "foros",
    type: "foro",
    label: "Foros",
    desc: "Escenarios y producción profesional",
    icon: `<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`,
  },
  {
    slug: "centros-convenciones",
    type: "centro-convenciones",
    label: "Centros Conv.",
    desc: "Gran formato y congresos",
    icon: `<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  },
];

// ── Event types config ───────────────────────────────────────────────────────
const eventTypesList = [
  { slug: "bodas", key: "bodas", label: "Bodas" },
  { slug: "xv-anos", key: "xv-anos", label: "XV Años" },
  { slug: "corporativos", key: "corporativos", label: "Corporativos" },
  { slug: "graduaciones", key: "graduaciones", label: "Graduaciones" },
  { slug: "bautizos", key: "bautizos", label: "Bautizos" },
  { slug: "cumpleanos", key: "cumpleanos", label: "Cumpleaños" },
  { slug: "aniversarios", key: "aniversarios", label: "Aniversarios" },
  { slug: "cenas-gala", key: "cenas-gala", label: "Cenas de Gala" },
  { slug: "lanzamientos", key: "lanzamientos", label: "Lanzamientos" },
];

// ── Why trust us — features list ─────────────────────────────────────────────
const dirFeatures = [
  {
    title: "Datos de primera mano",
    text: "No recopilamos fichas de internet. Cada venue lo conocemos porque hemos montado eventos dentro. Sabemos la acústica, los accesos de carga y los puntos de luz.",
  },
  {
    title: "Especificaciones técnicas reales",
    text: "Capacidad eléctrica, altura de techo, tipo de piso, restricciones de ruido y accesibilidad para camiones de equipo — los datos que los planners necesitan y que los directorios genéricos no tienen.",
  },
  {
    title: "Restricciones verificadas",
    text: "Sabemos qué venues no permiten pirotecnia, qué jardines tienen límite de hora, y qué salones cobran extra por música amplificada. Sin sorpresas el día del evento.",
  },
  {
    title: "Compatibilidad con equipo",
    text: "Te decimos si el venue necesita pista de baile especial sobre el césped, si la distribución eléctrica aguanta el sistema de sonido o si hay estacionamiento para nuestros camiones.",
  },
  {
    title: "Cobertura sin zonas ciegas",
    text: `${totalVenues}+ venues en ${totalZones} zonas de CDMX y Estado de México, desde Polanco y Santa Fe hasta Valle de Bravo y Tepotzotlán. Llegamos a donde sea el evento.`,
  },
  {
    title: "Un proveedor para todo",
    text: "Elegiste el venue; nosotros llevamos el equipo. Mobiliario, carpas, audio, iluminación y pistas — en un solo contrato coordinado directamente con el venue.",
  },
];

// ── FAQ ──────────────────────────────────────────────────────────────────────
const dirFaqs = [
  {
    question: "¿Cómo elijo el venue ideal para mi evento?",
    answer:
      "Los factores decisivos son: capacidad real (no la máxima del salón — la cómoda con tu mobiliario), accesibilidad para tus invitados, qué incluye el precio, si permiten proveedores externos y el límite de hora. Te recomendamos visitar al menos dos opciones con tu planner antes de firmar, y verificar la logística de carga con tu proveedor de equipo.",
  },
  {
    question: "¿Cuándo debo reservar el venue?",
    answer:
      "Para bodas y XV años: reserva con 8–12 meses de anticipación, especialmente si tu fecha cae en temporada alta (octubre–febrero). Para eventos corporativos: 2–4 meses es suficiente. Para celebraciones privadas: 1–2 meses. Los venues premium en Polanco, Coyoacán y haciendas de Valle de Bravo se agotan primero.",
  },
  {
    question: "¿Qué preguntas debo hacer al visitar un venue?",
    answer:
      "Las preguntas críticas: ¿Qué incluye el precio? ¿Puedo traer proveedores externos? ¿Hay límite de hora y cuánto es la hora extra? ¿Tienen planta de luz de respaldo? ¿Cuántos cajones de estacionamiento hay? ¿Qué restricciones tienen (pirotecnia, música amplificada, confeti)? ¿Cuál es la política de cancelación y de lluvia si es jardín?",
  },
  {
    question: "¿Cuál es el rango de precios en CDMX y Zona Metropolitana?",
    answer:
      "$ (económico): $150–$300 por persona, espacio y mobiliario básico. $$ (moderado): $400–$800, banquete estándar incluido. $$$ (premium): $900–$1,500, banquete completo con coordinación. $$$$ (lujo): $1,800+, servicio todo incluido en venues exclusivos. Los precios varían según día de semana, temporada y servicios incluidos.",
  },
  {
    question: "¿EVENTECH trabaja con los venues del directorio?",
    answer:
      "Sí — hemos llevado equipo a la gran mayoría de los venues listados. Eso nos da un conocimiento técnico que ningún directorio genérico puede ofrecer: sabemos qué tipo de iluminación realza mejor cada espacio, qué venues requieren tarima especial para pistas de baile sobre jardín, o si el acceso de carga es compatible con nuestros camiones.",
  },
  {
    question: "¿Puedo necesitar equipo adicional aunque el venue tenga todo incluido?",
    answer:
      "Casi siempre. Los venues ofrecen mobiliario estándar — si quieres sillas Chiavari, pista LED, sistema de sonido profesional, iluminación personalizada o una carpa sobre el jardín, necesitas un proveedor externo. En EVENTECH rentamos todo eso con instalación coordinada directamente con el venue para que el día del evento no haya fricciones.",
  },
];

// ── JSON-LD ──────────────────────────────────────────────────────────────────
const jsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Directorio de salones", url: "/directorio/" },
  ]),
  collectionPageJsonLd({
    name: "Directorio de Salones y Venues para Eventos",
    description:
      "Directorio completo de salones, jardines, haciendas y venues para eventos en CDMX y Estado de México. Datos verificados de primera mano.",
    url: "/directorio/",
    numberOfItems: totalVenues,
    areaServed: "Ciudad de México y Estado de México",
  }),
  ...(featuredList.length > 0
    ? [
        itemListJsonLd(
          featuredList.map((v) => ({
            name: v.data.name,
            url: venueUrl(v),
            image: v.data.image,
            description: v.data.shortDescription,
          }))
        ),
      ]
    : []),
  faqJsonLd(dirFaqs),
];
---

<PageLayout
  title="Directorio de salones para eventos CDMX"
  rawTitle={true}
  description={`Directorio de ${totalVenues}+ salones, jardines, haciendas y venues para eventos en CDMX y Estado de México. Datos verificados de primera mano: capacidades, zonas, tipos y precios.`}
  jsonLd={jsonLd}
>

  <div slot="breadcrumbs" class="hm-breadcrumb-bar">
    <div class="hm__wrap">
      <nav class="sv-breadcrumb" aria-label="Migas de pan">
                <ol>
                  <li><a href="/">Inicio</a></li>
                  <li aria-hidden="true">›</li>
                  <li><span aria-current="page">Directorio</span></li>
                </ol>
              </nav>
    </div>
  </div>
  <div class="hm">

    <!-- ══════════════════════════════════════════════════════════════
         HERO
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm-hero" aria-labelledby="dr-hero-heading">
      <div class="hm__wrap hm-hero__wrap">

        <div class="hm-hero__grid">
          <div class="hm-hero__main">
            <p class="hm__eyebrow hm-hero__eyebrow">
              Directorio verificado · CDMX y Estado de México
            </p>
            <h1 id="dr-hero-heading">
              Encuentra el venue perfecto para tu <em>evento</em>
            </h1>
            <p class="hm-hero__lead">
              {totalVenues}+ salones, jardines, haciendas y venues en {totalZones} zonas.
              Datos de primera mano porque los conocemos desde adentro.
            </p>
            <div class="sv-hero__ctas">
              <a class="hm__btn hm__btn--gold" href="#regiones">
                Explorar por región
                <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 5v14M5 12l7 7 7-7" />
                </svg>
              </a>
              <a
                class="hm__btn hm__btn--ghost"
                href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola,%20busco%20un%20venue%20para%20mi%20evento`}
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z" />
                </svg>
                Asesoría gratuita
              </a>
            </div>
          </div>
          <div class="hm-hero__seo">
            <p>
              La mayoría de los directorios de venues son listas agregadas de internet.
              El nuestro es diferente: llevamos <strong>más de 30 años equipando eventos</strong>
              en CDMX y Estado de México, lo que significa que conocemos estos espacios
              desde adentro — sus accesos de carga, su acústica, sus restricciones técnicas
              y los detalles que los planners necesitan pero los sitios genéricos no publican.
            </p>
            <p>
              Nuestro directorio cubre <strong>{totalVenues}+ venues en {totalZones} zonas</strong>:
              desde haciendas coloniales en Tepotzotlán hasta rooftops en Polanco, jardines en
              Coyoacán, centros de convenciones en Santa Fe y quintas en Valle de Bravo. Todos
              verificados. Todos con datos reales de capacidad, precio y servicios disponibles.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         NAV RÁPIDA
         ══════════════════════════════════════════════════════════════ -->
    <nav class="hm-menu" aria-label="Navegación del directorio">
      <ul class="hm-menu__grid" style="grid-template-columns: repeat(5, 1fr);">
        <li><a class="hm-menu__item" href="#regiones">Por región</a></li>
        <li><a class="hm-menu__item" href="#tipos-venue">Por tipo de venue</a></li>
        <li><a class="hm-menu__item" href="#tipos-evento">Por tipo de evento</a></li>
        <li><a class="hm-menu__item" href="/directorio/cdmx/">CDMX</a></li>
        <li><a class="hm-menu__item" href="/directorio/estado-mexico/">Estado de México</a></li>
      </ul>
    </nav>

    <!-- ══════════════════════════════════════════════════════════════
         EXPLORAR POR REGIÓN
         ══════════════════════════════════════════════════════════════ -->
    <section id="regiones" class="hm__section" aria-labelledby="regiones-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Cobertura completa</p>
            <h2 id="regiones-heading">Explora por región</h2>
            <p class="hm__head-sub">Desde la capital hasta la Zona Metropolitana.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Cubrimos la Ciudad de México con sus 24 zonas —de Polanco y Santa Fe hasta
              Xochimilco y el Centro Histórico— y el Estado de México con 22 municipios
              que incluyen Metepec, Huixquilucan, Valle de Bravo y Tepotzotlán.
            </p>
            <p>
              No importa dónde sea el evento: conocemos los accesos, las restricciones y
              los proveedores locales de cada zona. Eso nos permite asesorarte sobre qué
              espacio funciona mejor para tu tipo de celebración y presupuesto.
            </p>
          </div>
        </div>

        <div class="dr-regions">
          <!-- CDMX -->
          <article class="dr-region-card">
            <div class="dr-region-card__head">
              <p class="hm__eyebrow" style="color:var(--color-gold,#c2a24a);">Ciudad de México</p>
              <h3>CDMX</h3>
              <p class="dr-region-card__tagline">
                La mayor concentración de venues premium del país, desde jardines históricos
                hasta rooftops contemporáneos.
              </p>
            </div>
            <div class="dr-region-card__body">
              <p class="dr-region-card__zones-label">Zonas disponibles</p>
              <div class="dr-region-card__zones">
                {cdmxZones.map((zone) => (
                  <a
                    class="dr-region-card__zone"
                    href={`/directorio/cdmx/${zone.toLowerCase().replace(/\s+/g, "-").normalize("NFD").replace(/[̀-ͯ]/g, "")}/`}
                  >
                    {zone}
                  </a>
                ))}
              </div>
              <dl class="dr-region-card__stats">
                <div>
                  <dt>{cdmxVenues.length}<span>+</span></dt>
                  <dd>Venues</dd>
                </div>
                <div>
                  <dt>{cdmxZones.length}</dt>
                  <dd>Zonas</dd>
                </div>
                <div>
                  <dt>$$–$$$$</dt>
                  <dd>Rango de precio</dd>
                </div>
              </dl>
              <a class="hm__btn hm__btn--gold" href="/directorio/cdmx/" style="width:100%;justify-content:center;">
                Explorar venues en CDMX
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
          </article>

          <!-- Estado de México -->
          <article class="dr-region-card">
            <div class="dr-region-card__head">
              <p class="hm__eyebrow" style="color:var(--color-gold,#c2a24a);">Zona Metropolitana</p>
              <h3>Estado de México</h3>
              <p class="dr-region-card__tagline">
                Haciendas coloniales, quintas con jardines extensos y resorts de montaña
                a precio más accesible que en la capital.
              </p>
            </div>
            <div class="dr-region-card__body">
              <p class="dr-region-card__zones-label">Municipios disponibles</p>
              <div class="dr-region-card__zones">
                {edomexZones.map((zone) => (
                  <a
                    class="dr-region-card__zone"
                    href={`/directorio/estado-mexico/${zone.toLowerCase().replace(/\s+/g, "-").normalize("NFD").replace(/[̀-ͯ]/g, "")}/`}
                  >
                    {zone}
                  </a>
                ))}
              </div>
              <dl class="dr-region-card__stats">
                <div>
                  <dt>{edomexVenues.length}<span>+</span></dt>
                  <dd>Venues</dd>
                </div>
                <div>
                  <dt>{edomexZones.length}</dt>
                  <dd>Municipios</dd>
                </div>
                <div>
                  <dt>$–$$$$</dt>
                  <dd>Rango de precio</dd>
                </div>
              </dl>
              <a class="hm__btn hm__btn--gold" href="/directorio/estado-mexico/" style="width:100%;justify-content:center;">
                Explorar venues en Edo. México
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         TIPOS DE VENUE
         ══════════════════════════════════════════════════════════════ -->
    <section id="tipos-venue" class="hm__section hm__section--ivory" aria-labelledby="tipos-venue-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">¿Qué estilo prefieres?</p>
            <h2 id="tipos-venue-heading">Tipos de venue</h2>
            <p class="hm__head-sub">Cada espacio tiene una atmósfera distinta.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Una hacienda colonial no es lo mismo que un jardín moderno, y un rooftop
              en Polanco nada tiene que ver con una quinta en Metepec. El tipo de venue
              define la atmósfera del evento antes de que llegue una sola flor o una
              sola nota de música.
            </p>
            <p>
              Cada categoría tiene sus particularidades técnicas: qué equipo funciona
              mejor, qué restricciones son comunes y qué hay que planear con anticipación.
              Tres décadas equipando eventos en todos estos espacios nos convirtieron en
              el proveedor que mejor conoce las diferencias.
            </p>
          </div>
        </div>

        <div class="dr-vtype-grid">
          {venueTypesList.map((vt) => {
            const count = countByType(vt.type);
            return (
              <a class="dr-vtype-card" href={`/directorio/tipo-venue/${vt.slug}/`}>
                <div class="dr-vtype-card__ic" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={vt.icon} />
                </div>
                <h3 class="dr-vtype-card__name">{vt.label}</h3>
                <p class="dr-vtype-card__desc">{vt.desc}</p>
                <span class="dr-vtype-card__count">{count} venues</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         TIPOS DE EVENTO
         ══════════════════════════════════════════════════════════════ -->
    <section id="tipos-evento" class="hm__section" aria-labelledby="tipos-evento-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">¿Qué celebras?</p>
            <h2 id="tipos-evento-heading">Busca por tipo de evento</h2>
            <p class="hm__head-sub">Cada celebración tiene requerimientos distintos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Una boda de 300 personas necesita un tipo de venue completamente diferente
              a un lanzamiento corporativo para 80 ejecutivos o una fiesta de XV años
              con pista de baile grande. El tipo de evento no solo determina la capacidad —
              define el horario, el catering, el equipo de audio y el estilo de iluminación.
            </p>
            <p>
              Filtra venues que ya tienen experiencia en tu tipo de celebración y conocen
              los requerimientos específicos: restricciones de ruido en zonas residenciales,
              disponibilidad de capilla, requisitos de catering kosher o coordinación para
              ceremonias religiosas.
            </p>
          </div>
        </div>

        <div class="dr-etype-grid">
          {eventTypesList.map((et) => {
            const count = countByEvent(et.key);
            return (
              <a class="dr-etype-tag" href={`/directorio/tipo-evento/${et.slug}/`}>
                <span class="dr-etype-tag__name">{et.label}</span>
                <span class="dr-etype-tag__count">{count} venues</span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         VENUES DESTACADOS
         ══════════════════════════════════════════════════════════════ -->
    {featuredList.length > 0 && (
      <section class="hm__section hm__section--ivory" aria-labelledby="destacados-heading">
        <div class="hm__wrap">
          <div class="hm__head hm__head--split">
            <div class="hm__head-title">
              <p class="hm__eyebrow">Selección editorial</p>
              <h2 id="destacados-heading">Venues destacados</h2>
              <p class="hm__head-sub">Espacios que conocemos y recomendamos con nombre propio.</p>
            </div>
            <div class="hm__head-copy">
              <p>
                No son los que pagan más por aparecer primero. Son los que hemos equipado
                repetidamente, donde el equipo de EVENTECH conoce de nombre al coordinador
                de eventos y donde el historial de montajes sin contratiempos nos da la
                confianza de recomendarlos públicamente.
              </p>
              <p>
                Cada venue destacado tiene ficha completa con especificaciones técnicas,
                capacidades verificadas, galería de eventos reales y la nota honesta de
                para qué tipo de celebración funciona mejor.
              </p>
            </div>
          </div>

          <div class="dr-venue-grid">
            {featuredList.map((v) => (
              <article class="dr-venue-card">
                <a class="dr-venue-card__link" href={venueUrl(v)}>
                  <div class="dr-venue-card__media">
                    <img
                      src={v.data.image || "/images/placeholder-venue.avif"}
                      alt={`${v.data.name} — venue para eventos`}
                      loading="lazy"
                      decoding="async"
                    />
                    {v.data.premium && (
                      <span class="dr-venue-card__badge dr-venue-card__badge--premium">Premium</span>
                    )}
                    {v.data.eventechPartner && (
                      <span class="dr-venue-card__badge dr-venue-card__badge--partner">Partner</span>
                    )}
                    <span class="dr-venue-card__price">{v.data.priceRange}</span>
                  </div>
                  <div class="dr-venue-card__body">
                    <span class="dr-venue-card__type">{v.data.type}</span>
                    <h3 class="dr-venue-card__name">{v.data.name}</h3>
                    <p class="dr-venue-card__location">
                      <svg viewBox="0 0 24 24" width="13" height="13" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>
                      </svg>
                      {v.data.zone}, {v.data.region === "cdmx" ? "CDMX" : "Edo. Méx."}
                    </p>
                    <p class="dr-venue-card__desc">{v.data.shortDescription}</p>
                    <div class="dr-venue-card__meta">
                      <span>{v.data.capacity.min}–{v.data.capacity.max} personas</span>
                      {v.data.rating && <span class="dr-venue-card__rating">★ {v.data.rating}</span>}
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>

          <div class="dr-venue-grid__footer">
            <a class="hm__btn hm__btn--gold" href="/directorio/cdmx/">Ver todos los venues en CDMX →</a>
            <a class="hm__btn hm__btn--ghost" href="/directorio/estado-mexico/">Estado de México →</a>
          </div>
        </div>
      </section>
    )}

    <!-- ══════════════════════════════════════════════════════════════
         POR QUÉ CONFIAR EN ESTE DIRECTORIO
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm__section hm__section--navy" aria-labelledby="porque-dir-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">No es un listado de internet</p>
            <h2 id="porque-dir-heading">Directorio de primera mano</h2>
            <p class="hm__head-sub">Conocemos estos venues porque trabajamos en ellos.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              La mayoría de los directorios de venues en México son bases de datos con
              fichas llenadas por los propios salones. El nuestro es diferente: cada
              venue está documentado desde la perspectiva de quien lleva el equipo —
              quien sabe si el piso aguanta una pista de baile, si hay toma trifásica
              para el sistema de audio o si el acceso es por avenida principal.
            </p>
            <p>
              Tres décadas equipando bodas, XV años y eventos corporativos en CDMX y
              Estado de México nos convirtieron en el proveedor con el mapa más completo
              y honesto de los venues de la región.
            </p>
          </div>
        </div>
        <ul class="hm-why">
          {dirFeatures.map((f) => (
            <li class="hm-why__item">
              <div class="hm-why__ic" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
              </div>
              <div>
                <h3>{f.title}</h3>
                <p>{f.text}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         STATS
         ══════════════════════════════════════════════════════════════ -->
    <section class="dr-stats" aria-label="Indicadores del directorio EVENTECH">
      <div class="hm__wrap dr-stats__wrap">
        <dl class="dr-stats__grid">
          <div class="dr-stats__item">
            <dt class="dr-stats__num">{totalVenues}<span>+</span></dt>
            <dd class="dr-stats__label">Venues registrados</dd>
          </div>
          <div class="dr-stats__item">
            <dt class="dr-stats__num">{totalZones}</dt>
            <dd class="dr-stats__label">Zonas cubiertas</dd>
          </div>
          <div class="dr-stats__item">
            <dt class="dr-stats__num">9</dt>
            <dd class="dr-stats__label">Tipos de espacio</dd>
          </div>
          <div class="dr-stats__item">
            <dt class="dr-stats__num">30<span>+</span></dt>
            <dd class="dr-stats__label">Años de experiencia</dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════
         FAQ + FORMULARIO WHATSAPP
         ══════════════════════════════════════════════════════════════ -->
    <section class="hm__section" aria-labelledby="dir-faq-heading">
      <div class="hm__wrap">
        <div class="hm__head hm__head--split">
          <div class="hm__head-title">
            <p class="hm__eyebrow">Antes de decidir</p>
            <h2 id="dir-faq-heading">Preguntas frecuentes</h2>
            <p class="hm__head-sub">Lo que todo organizador de eventos necesita saber sobre venues.</p>
          </div>
          <div class="hm__head-copy">
            <p>
              Después de equipar miles de eventos en CDMX y Estado de México, conocemos
              las dudas que surgen en el momento de elegir un venue. Las preguntas que
              más nos hacen los planners, las familias y los equipos corporativos — y las
              respuestas honestas desde la perspectiva de quien trabaja en estos espacios.
            </p>
            <p>
              Si tu caso es específico —un venue fuera de lo común, una fecha de alto
              riesgo o una necesidad técnica particular— un especialista de EVENTECH
              te responde en minutos por WhatsApp con información de primera mano.
            </p>
          </div>
        </div>

        <div class="hm-faqx">
          <div class="hm-faq">
            {dirFaqs.map((f) => (
              <details class="hm-faq__item">
                <summary>{f.question}</summary>
                <p>{f.answer}</p>
              </details>
            ))}
          </div>

          <aside class="hm-faqx__aside" aria-labelledby="drform-heading">
            <form id="drForm" class="hm-form" data-wa={SITE.contact.whatsapp}>
              <p class="hm-form__eyebrow">Asesoría sin costo</p>
              <h3 id="drform-heading" class="hm-form__title">¿Buscas venue?</h3>
              <p class="hm-form__sub">Cuéntanos tu evento y te recomendamos los mejores venues para tu caso.</p>

              <label class="hm-form__field">
                <span>Nombre</span>
                <input type="text" name="nombre" autocomplete="name" placeholder="Tu nombre" required />
              </label>

              <label class="hm-form__field">
                <span>Tipo de evento</span>
                <select name="tipo">
                  <option value="">Selecciona…</option>
                  <option>Boda</option>
                  <option>XV años</option>
                  <option>Corporativo</option>
                  <option>Evento social</option>
                  <option>Fiesta infantil</option>
                  <option>Graduación</option>
                  <option>Otro</option>
                </select>
              </label>

              <label class="hm-form__field">
                <span>Número aproximado de invitados</span>
                <input type="number" name="invitados" placeholder="Ej. 150" min="10" max="5000" />
              </label>

              <label class="hm-form__field">
                <span>¿Qué necesitas?</span>
                <textarea name="mensaje" rows="3" placeholder="Zona preferida, presupuesto, tipo de venue, fecha aproximada…"></textarea>
              </label>

              <button type="submit" class="hm-form__btn">
                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="currentColor">
                  <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.11.82.83-3.03-.2-.31a8.18 8.18 0 0 1-1.26-4.37c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.23 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.42l-.48-.01c-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.11-.22-.17-.47-.29Z" />
                </svg>
                Enviar por WhatsApp
              </button>
              <p class="hm-form__note">Se abrirá WhatsApp con tu consulta. Sin compromiso.</p>
            </form>
          </aside>
        </div>
      </div>
    </section>

  </div><!-- /hm -->

  <script>
    const drForm = document.getElementById("drForm");
    if (drForm) {
      drForm.addEventListener("submit", (e) => {
        e.preventDefault();
        const f = e.currentTarget as HTMLFormElement;
        const wa = f.dataset.wa;
        const data = new FormData(f);
        const get = (k: string) => (data.get(k) || "").toString().trim();
        let t = "Hola, busco un venue para mi evento.";
        if (get("nombre")) t += `\nNombre: ${get("nombre")}`;
        if (get("tipo")) t += `\nTipo de evento: ${get("tipo")}`;
        if (get("invitados")) t += `\nInvitados aprox.: ${get("invitados")}`;
        if (get("mensaje")) t += `\nDetalles: ${get("mensaje")}`;
        window.open(
          `https://wa.me/${wa}?text=${encodeURIComponent(t)}`,
          "_blank",
          "noopener"
        );
      });
    }
  </script>

