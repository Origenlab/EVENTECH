---
/**
 * ─── Directorio de Salones Index ───
 * Página principal del directorio con estadísticas, filtros y listado de venues por zona.
 */
import PageLayout from "@layouts/PageLayout.astro";
import HeroPage from "@components/HeroPage.astro";
import SectionHeader from "@components/SectionHeader.astro";
import CTABanner from "@components/CTABanner.astro";
import Breadcrumbs from "@components/Breadcrumbs.astro";
import { getCollection } from "astro:content";
import { breadcrumbJsonLd } from "@utils/seo";
import "@styles/directorio.css";

const breadcrumbItems = [
  { label: "Inicio", href: "/" },
  { label: "Directorio" },
];

// Get all venues
const allVenues = await getCollection("venues");

// Group by region
const cdmxVenues = allVenues.filter(v => v.data.region === "cdmx");
const edomexVenues = allVenues.filter(v => v.data.region === "estado-mexico");

// Get unique zones for each region
const cdmxZones = [...new Set(cdmxVenues.map(v => v.data.zone))];
const edomexZones = [...new Set(edomexVenues.map(v => v.data.zone))];

// Stats
const totalVenues = allVenues.length;
const totalZones = cdmxZones.length + edomexZones.length;
const featuredVenues = allVenues.filter(v => v.data.featured).length;
const partnerVenues = allVenues.filter(v => v.data.eventechPartner).length;

// Featured venues for display
const featuredList = allVenues
  .filter(v => v.data.featured)
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  .slice(0, 6);

// Venue type labels
const venueTypeLabels: Record<string, string> = {
  "salon": "Salón",
  "jardin": "Jardín",
  "hacienda": "Hacienda",
  "terraza": "Terraza",
  "hotel": "Hotel",
  "restaurante": "Restaurante",
  "foro": "Foro",
  "quinta": "Quinta",
  "mansion": "Mansión",
  "centro-convenciones": "Centro de Convenciones",
  "rooftop": "Rooftop",
  "playa": "Playa",
};

const jsonLd = [
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Directorio", url: "/directorio/" },
  ]),
];
---

<PageLayout
  title="Directorio de Salones de Fiestas CDMX y Estado de México | EVENTECH"
  description="Encuentra el salón, jardín o hacienda perfecta para tu evento. Directorio completo con capacidades, precios y amenidades en CDMX y Zona Metropolitana."
  jsonLd={jsonLd}
>
  <!-- ═══════════════════════════════════════════════════════════════════════
       BREADCRUMBS
       ═══════════════════════════════════════════════════════════════════════ -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- ═══════════════════════════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════════════════════════ -->
  <HeroPage
    badge="Directorio de Venues"
    title='Salones de Fiestas en <span class="highlight">CDMX y Estado de México</span>'
    subtitle="Encuentra el venue perfecto para tu evento. Directorio completo con información detallada de capacidades, precios, amenidades y servicios disponibles en cada ubicación."
    primaryCTA={{ label: "Ver todos los salones", href: "#venues" }}
    secondaryCTA={{ label: "Cotizar equipo", href: "/cotizar/" }}
    cards={[
      {
        title: "Directorio verificado",
        content: "Cada venue ha sido <strong>verificado por nuestro equipo</strong>. Conocemos personalmente los espacios porque hemos llevado nuestro equipo a cientos de eventos ahí."
      },
      {
        title: "Cobertura completa",
        content: "Cubrimos <strong>toda la CDMX y Zona Metropolitana</strong>. Desde Polanco hasta Metepec, conocemos los mejores espacios para bodas, XV años y eventos corporativos."
      }
    ]}
  />

  <!-- ═══════════════════════════════════════════════════════════════════════
       ZONES SECTION
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section" id="venues">
    <div class="container">
      <SectionHeader
        title="Explora por Región"
        subtitle="Cobertura completa"
        description={[
          "Selecciona la región donde será tu evento. Contamos con información detallada de los mejores venues en cada zona.",
          "Como proveedores de equipo, conocemos de primera mano estos espacios y podemos recomendarte los más adecuados para tu celebración."
        ]}
      />

      <div class="grid grid--2" style="gap: var(--space-2xl);">
        <!-- CDMX Card -->
        <div class="zone-card">
          <div class="zone-card__header">
            <h3 class="zone-card__title">Ciudad de México</h3>
            <p class="zone-card__subtitle">Salones, jardines y haciendas en las principales alcaldías de la capital</p>
          </div>
          <div class="zone-card__content">
            <p class="zone-card__section-title">Zonas disponibles</p>
            <div class="zone-card__zones">
              {cdmxZones.map(zone => (
                <a href={`/directorio/cdmx/${zone.toLowerCase().replace(/\s+/g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "")}/`} class="zone-card__zone-tag">
                  {zone}
                </a>
              ))}
            </div>
            <div class="zone-card__stats">
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">{cdmxVenues.length}+</span>
                <span class="zone-card__stat-label">Venues</span>
              </div>
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">{cdmxZones.length}</span>
                <span class="zone-card__stat-label">Zonas</span>
              </div>
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">$$-$$$$</span>
                <span class="zone-card__stat-label">Precios</span>
              </div>
            </div>
            <a href="/directorio/cdmx/" class="zone-card__cta">
              Explorar CDMX
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>

        <!-- Estado de México Card -->
        <div class="zone-card">
          <div class="zone-card__header">
            <h3 class="zone-card__title">Estado de México</h3>
            <p class="zone-card__subtitle">Haciendas, jardines y salones en la Zona Metropolitana y alrededores</p>
          </div>
          <div class="zone-card__content">
            <p class="zone-card__section-title">Zonas disponibles</p>
            <div class="zone-card__zones">
              {edomexZones.map(zone => (
                <a href={`/directorio/estado-mexico/${zone.toLowerCase().replace(/\s+/g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "")}/`} class="zone-card__zone-tag">
                  {zone}
                </a>
              ))}
            </div>
            <div class="zone-card__stats">
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">{edomexVenues.length}+</span>
                <span class="zone-card__stat-label">Venues</span>
              </div>
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">{edomexZones.length}</span>
                <span class="zone-card__stat-label">Zonas</span>
              </div>
              <div class="zone-card__stat">
                <span class="zone-card__stat-number">$-$$$$</span>
                <span class="zone-card__stat-label">Precios</span>
              </div>
            </div>
            <a href="/directorio/estado-mexico/" class="zone-card__cta">
              Explorar Edo. México
              <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       FEATURED VENUES
       ═══════════════════════════════════════════════════════════════════════ -->
  {featuredList.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <SectionHeader
          title="Venues Destacados"
          subtitle="Recomendados por EVENTECH"
          description={[
            "Estos son algunos de los venues más populares donde hemos trabajado. Los conocemos bien porque hemos equipado decenas de eventos en cada uno.",
            "Son espacios que destacan por su calidad, servicio y versatilidad para diferentes tipos de celebraciones."
          ]}
        />

        <div class="dir-grid dir-grid--3">
          {featuredList.map(venue => (
            <article class="venue-card">
              <a href={`/directorio/${venue.data.region}/${venue.data.zoneSlug}/${venue.id.split('/').pop()?.replace('.md', '')}/`} class="venue-card__link">
                <div class="venue-card__image-wrapper">
                  <img
                    src={venue.data.image || "/images/placeholder-venue.jpg"}
                    alt={venue.data.name}
                    class="venue-card__image"
                    loading="lazy"
                    width="400"
                    height="300"
                  />
                  <div class="venue-card__badges">
                    {venue.data.premium && (
                      <span class="venue-card__badge venue-card__badge--premium">Premium</span>
                    )}
                    {venue.data.verified && (
                      <span class="venue-card__badge venue-card__badge--verified">Verificado</span>
                    )}
                  </div>
                  <span class="venue-card__price-badge">{venue.data.priceRange}</span>
                </div>
                <div class="venue-card__content">
                  <span class="venue-card__type">{venueTypeLabels[venue.data.type] || venue.data.type}</span>
                  <h3 class="venue-card__name">{venue.data.name}</h3>
                  <p class="venue-card__location">
                    <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {venue.data.zone}, {venue.data.region === "cdmx" ? "CDMX" : "Edo. Méx."}
                  </p>
                  <p class="venue-card__description">{venue.data.shortDescription}</p>
                  <div class="venue-card__meta">
                    <span class="venue-card__capacity">
                      <strong>{venue.data.capacity.min}-{venue.data.capacity.max}</strong> personas
                    </span>
                    {venue.data.rating && (
                      <span class="venue-card__rating">
                        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        {venue.data.rating}
                      </span>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>

        <div style="text-align: center; margin-top: var(--space-2xl);">
          <a href="/directorio/cdmx/" class="btn btn--primary" style="margin-right: var(--space-md);">
            Ver CDMX
          </a>
          <a href="/directorio/estado-mexico/" class="btn btn--outline">
            Ver Estado de México
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════════════════════════════════
       EVENTECH SERVICES INFO
       ═══════════════════════════════════════════════════════════════════════ -->
  <section class="section">
    <div class="container">
      <SectionHeader
        title="Equipo para tu Venue"
        subtitle="Servicio completo"
        description={[
          "No importa el salón que elijas, EVENTECH lleva el equipo que necesitas: mobiliario, carpas, iluminación, audio y más.",
          "Conocemos los requerimientos técnicos de cada venue y podemos asesorarte sobre qué equipo funciona mejor en cada espacio."
        ]}
      />

      <div class="grid grid--4">
        <div class="card">
          <div class="card__icon">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3 class="card__title">Conocemos los Venues</h3>
          <p class="card__content">Hemos trabajado en la mayoría de salones listados. Sabemos qué equipo funciona mejor en cada espacio.</p>
        </div>
        <div class="card">
          <div class="card__icon">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3 class="card__title">Cotización Rápida</h3>
          <p class="card__content">Dinos el venue y la fecha. Te enviamos cotización personalizada en menos de 24 horas.</p>
        </div>
        <div class="card">
          <div class="card__icon">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="card__title">Montaje Profesional</h3>
          <p class="card__content">Nuestro equipo se coordina con el venue para montaje y desmontaje sin complicaciones.</p>
        </div>
        <div class="card">
          <div class="card__icon">
            <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="card__title">Garantía Total</h3>
          <p class="card__content">Equipo de respaldo y técnicos en sitio durante tu evento para cualquier eventualidad.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════════════
       CTA BANNER
       ═══════════════════════════════════════════════════════════════════════ -->
  <CTABanner
    headline="¿Ya tienes tu venue?"
    subheadline="Cotiza el equipo que necesitas: mobiliario, carpas, iluminación, audio y más. Llevamos todo a donde sea tu evento."
    primaryCTA={{ label: "Cotizar equipo", href: "/cotizar/" }}
    secondaryCTA={{ label: "Ver servicios", href: "/servicios/" }}
    variant="accent"
  />
</PageLayout>
