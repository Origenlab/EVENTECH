---
/**
 * ─── Zone Pages ───
 * Renderiza páginas de zonas/ubicaciones desde content collections.
 */
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import ZoneLayout from "@layouts/ZoneLayout.astro";
import { localBusinessJsonLd, breadcrumbJsonLd } from "@utils/seo";

export async function getStaticPaths() {
  const zonas = await getCollection("zonas");
  return zonas.map((zona: CollectionEntry<"zonas">) => ({
    params: { slug: zona.slug },
    props: { zona },
  }));
}

const { zona } = Astro.props as { zona: CollectionEntry<"zonas"> };
const { Content } = await zona.render();
const { title, description, seoTitle, seoDescription, hero, subzones } = zona.data;

const pageTitle = seoTitle || title;
const pageDescription = seoDescription || description;
const pageUrl = `/zonas/${zona.slug}/`;

// Build areaServed from subzones
const areaServedNames = (subzones || []).map((z: string) =>
  z.split("-").map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(" ")
);

const jsonLd = [
  localBusinessJsonLd({
    description: pageDescription,
    areaServed: areaServedNames.length ? areaServedNames : undefined,
  }),
  breadcrumbJsonLd([
    { name: "Inicio", url: "/" },
    { name: "Zonas", url: "/zonas/" },
    { name: title, url: pageUrl },
  ]),
];
---

<ZoneLayout
  title={pageTitle}
  description={pageDescription}
  hero={hero}
  jsonLd={jsonLd}
>
  <Content />
</ZoneLayout>
