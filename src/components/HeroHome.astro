---
/**
 * ─── HeroHome Component ───
 * Hero específico para la página principal.
 * Usa el componente HeroPage con contenido predefinido.
 */
import HeroPage from "./HeroPage.astro";
---

<HeroPage
  badge="Más de 500 eventos realizados en CDMX"
  title='Renta de <span class="highlight">Equipo para Eventos</span> en CDMX y México'
  subtitle="Mobiliario, audiovisual, carpas e iluminación para bodas, XV años, eventos corporativos y sociales. Cotiza en línea y recibe respuesta en menos de 24 horas."
  primaryCTA={{ label: "Cotiza tu evento", href: "/cotizar/" }}
  secondaryCTA={{ label: "Ver catálogo completo", href: "/servicios/" }}
  cards={[
    {
      content: "En <strong>EVENTECH</strong> somos especialistas en renta de mobiliario, carpas, audiovisual e iluminación para todo tipo de eventos en la Ciudad de México y zona metropolitana. Con más de 10 años de experiencia equipando bodas, XV años, eventos corporativos y fiestas sociales, ofrecemos soluciones integrales que se adaptan a cualquier espacio y presupuesto."
    },
    {
      content: "Lo que nos diferencia: catálogo completo con más de 500 productos disponibles, entrega puntual con montaje profesional incluido y asesoría personalizada sin costo. Cotiza en línea y recibe respuesta en menos de 24 horas. Tu evento perfecto comienza aquí."
    }
  ]}
/>
