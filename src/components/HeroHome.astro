---
/**
 * ─── HeroHome Component ───
 * Hero específico para la página principal.
 * Usa el componente HeroPage con contenido predefinido.
 */
import HeroPage from "./HeroPage.astro";
---

<HeroPage
  badge="Más de 500 eventos realizados en CDMX"
  title='Renta de <span class="highlight">Equipo para Eventos</span> en CDMX y México'
  subtitle="Mobiliario, audiovisual, carpas e iluminación para bodas, XV años, eventos corporativos y sociales. Cotiza en línea y recibe respuesta en menos de 24 horas."
  primaryCTA={{ label: "Cotiza tu evento", href: "/cotizar/" }}
  secondaryCTA={{ label: "Ver catálogo completo", href: "/servicios/" }}
  cards={[
    {
      title: "Equipo para eventos de primer nivel",
      content: "<strong>Equipo para eventos</strong> que marca la diferencia. En EVENTECH ofrecemos la más amplia selección de mobiliario premium, sistemas audiovisuales de última generación y soluciones integrales de iluminación. Cada pieza de nuestro inventario es cuidadosamente seleccionada para garantizar la excelencia en tu celebración, desde bodas íntimas hasta congresos corporativos de gran escala."
    },
    {
      title: "Servicio integral garantizado",
      content: "<strong>Equipo para eventos</strong> con servicio completo: entrega puntual, montaje profesional y asesoría personalizada incluidos. Nuestro equipo de especialistas trabaja contigo desde la planificación hasta el desmontaje, asegurando que cada detalle esté perfectamente coordinado. Con cobertura en toda la CDMX y zona metropolitana, hacemos realidad eventos memorables sin complicaciones."
    }
  ]}
/>
