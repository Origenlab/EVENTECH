---
/**
 * CtaBar Component — OrigenLab Standard (EVENTECH)
 * Barra de navegación por categorías debajo del Hero.
 * Colores: primary #1a1a2e, accent #00b894
 */
interface CtaItem {
  label: string;
  href: string;
  icon?: string;
}

interface Props {
  headline?: string;
  items: CtaItem[];
}

const {
  headline = "¿Qué equipo necesitas para tu evento?",
  items,
} = Astro.props;

const icons: Record<string, string> = {
  mobiliario: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10V7a2 2 0 00-2-2H6a2 2 0 00-2 2v3m16 0a2 2 0 012 2v5a2 2 0 01-2 2H4a2 2 0 01-2-2v-5a2 2 0 012-2m16 0H4m4 7v2m8-2v2"/></svg>',
  audiovisual: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14M15.54 8.46a5 5 0 010 7.07"/></svg>',
  carpas: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l9-18 9 18H3z"/><path d="M12 3v18"/></svg>',
  iluminacion: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6M10 22h4M12 2a7 7 0 00-4 12.7V17h8v-2.3A7 7 0 0012 2z"/></svg>',
  catering: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8zM6 1v3M10 1v3M14 1v3"/></svg>',
  inflables: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01"/></svg>',
  pistas: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="15.5" r="2.5"/><path d="M8 17V5l12-2v12"/></svg>',
  laptop: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16V7a2 2 0 00-2-2H6a2 2 0 00-2 2v9"/><path d="M2 16h20l-1.5 3.6a2 2 0 01-1.85 1.4H5.35a2 2 0 01-1.85-1.4L2 16z"/></svg>',
  accesorios: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>',
  cotizar: '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>',
};
---

<section class="ctabar" aria-label="Navegación de servicios">
  <div class="container">
    <p class="ctabar__headline">{headline}</p>
    <div class="ctabar__grid">
      {items.map((item) => (
        <a href={item.href} class="ctabar__item">
          {item.icon && icons[item.icon] && (
            <span class="ctabar__icon" set:html={icons[item.icon]} />
          )}
          <span class="ctabar__label">{item.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .ctabar {
    background: linear-gradient(135deg, #1a1a2e 0%, #0f0f1a 100%);
    padding: 2rem 0;
  }

  .ctabar__headline {
    text-align: center;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9375rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
    letter-spacing: 0.01em;
  }

  .ctabar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
  }

  .ctabar__item {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
  }

  .ctabar__item:hover {
    background: rgba(0, 184, 148, 0.2);
    border-color: rgba(0, 184, 148, 0.4);
  }

  .ctabar__icon {
    display: flex;
    flex-shrink: 0;
    opacity: 0.85;
  }

  .ctabar__label {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .ctabar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .ctabar__label {
      font-size: 0.75rem;
    }
    .ctabar__icon {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .ctabar__grid {
      grid-template-columns: 1fr;
    }

    .ctabar__item {
      padding: 0.75rem 1rem;
    }
  }
</style>
