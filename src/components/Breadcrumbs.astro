---
/**
 * ─── Breadcrumbs Component ───
 * Barra de migas de pan standalone entre header y hero.
 * Usar via: <Breadcrumbs items={[...]} slot="breadcrumbs" />
 * Estilos scoped aquí (funciona en cualquier página, sin depender de home-2026.css).
 */
type BreadcrumbItem = {
  label: string;
  href?: string;
};

type Props = {
  items: BreadcrumbItem[];
};

const { items } = Astro.props;
---

<nav class="bc-bar" aria-label="Migas de pan">
  <div class="bc-wrap">
    <ol class="bc-list">
      {items.map((item, index) => (
        <li class="bc-item">
          {item.href && index < items.length - 1 ? (
            <a href={item.href} class="bc-link">{item.label}</a>
          ) : (
            <span class="bc-current" aria-current="page">{item.label}</span>
          )}
          {index < items.length - 1 && (
            <span class="bc-sep" aria-hidden="true">›</span>
          )}
        </li>
      ))}
    </ol>
  </div>
</nav>

<style>
  .bc-bar {
    background: #fff;
    border-bottom: 1px solid #e4ddd0;
    padding-block: 10px;
  }
  .bc-wrap {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(16px, 4vw, 48px);
  }
  .bc-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0 4px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .bc-item {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .bc-link {
    font-size: 0.78rem;
    color: #5c5c72;
    text-decoration: none;
    font-weight: 500;
    transition: color .15s;
  }
  .bc-link:hover { color: #c2a24a; }
  .bc-current {
    font-size: 0.78rem;
    color: #c2a24a;
    font-weight: 600;
  }
  .bc-sep {
    font-size: 0.72rem;
    color: #c0b8aa;
    line-height: 1;
    user-select: none;
  }
</style>
