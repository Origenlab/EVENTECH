---
/**
 * CategoryCard — Card de categoría con imagen, descripción y subcategorías desplegadas.
 * Estilo REDEIL: imagen 4:3, título, descripción, links de subcategorías, botón principal.
 */
interface Props {
  title: string;
  subtitle: string;
  href: string;
  image: string;
  subcategories: ReadonlyArray<{ name: string; href: string }>;
}

const { title, subtitle, href, image, subcategories } = Astro.props;
---

<article class="cat-card">
  <div class="cat-card__img-wrap">
    <img
      src={image}
      alt={title}
      class="cat-card__img"
      loading="lazy"
      decoding="async"
      width="640"
      height="480"
    />
  </div>
  <div class="cat-card__body">
    <h3 class="cat-card__title">{title}</h3>
    <p class="cat-card__desc">{subtitle}</p>
    {subcategories.length > 0 && (
      <div class="cat-card__links">
        {subcategories.map((sub) => (
          <a href={sub.href} class="cat-card__link">{sub.name}</a>
        ))}
      </div>
    )}
    <a href={href} class="cat-card__btn">{title}</a>
  </div>
</article>

<style>
  .cat-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-light);
    
  }

  .cat-card:hover {
    box-shadow: var(--shadow-md);
    
  }

  .cat-card__img-wrap {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-alt);
    overflow: hidden;
  }

  .cat-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    
  }

  .cat-card:hover .cat-card__img {
    
  }

  .cat-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: var(--space-sm);
  }

  .cat-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .cat-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.7;
    margin: 0;
  }

  .cat-card__links {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: var(--space-xs);
  }

  .cat-card__link {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text);
    padding: 0.5rem 0 0.5rem 1rem;
    border-bottom: 1px solid var(--color-bg-alt);
    position: relative;
    text-decoration: none;
  }

  .cat-card__link::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .cat-card__link:last-child {
    border-bottom: none;
  }

  .cat-card__link:hover {
    color: var(--color-accent);
  }

  .cat-card__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0.875rem 1.5rem;
    margin-top: auto;
    border-radius: var(--radius-md);
    background: var(--color-accent);
    color: #fff;
    text-align: center;
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .cat-card__btn:hover {
    background: var(--color-accent-hover);
  }
</style>
