---
/**
 * ImageShowcase Component
 * Displays a featured image with title, description, and optional CTA.
 *
 * @example
 * <ImageShowcase
 *   image="/images/guirnaldas/boda-jardin.avif"
 *   alt="Boda en jardín con guirnaldas Edison"
 *   title="Guirnaldas para Bodas en Jardín"
 *   description="Transforma tu boda al aire libre con nuestras guirnaldas Edison profesionales."
 *   cta={{ label: "Cotizar ahora", href: "/contacto/" }}
 *   reverse={false}
 * />
 */

interface Props {
  image: string;
  alt: string;
  title: string;
  description: string;
  cta?: {
    label: string;
    href: string;
  };
  reverse?: boolean;
  badge?: string;
}

const { image, alt, title, description, cta, reverse = false, badge } = Astro.props;
---

<div class={`image-showcase ${reverse ? "image-showcase--reverse" : ""}`}>
  <div class="image-showcase__image-wrapper">
    <img
      src={image}
      alt={alt}
      loading="lazy"
      decoding="async"
      class="image-showcase__image"
    />
    {badge && <span class="image-showcase__badge">{badge}</span>}
  </div>
  <div class="image-showcase__content">
    <h3 class="image-showcase__title">{title}</h3>
    <p class="image-showcase__description">{description}</p>
    {cta && (
      <a href={cta.href} class="image-showcase__cta">
        {cta.label}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    )}
  </div>
</div>

<style>
  .image-showcase {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    margin: var(--space-2xl) 0;
    padding: var(--space-xl);
    background: var(--color-bg-alt, #f8f9fa);
    border-radius: var(--radius-lg);
  }

  .image-showcase--reverse {
    direction: rtl;
  }

  .image-showcase--reverse > * {
    direction: ltr;
  }

  .image-showcase__image-wrapper {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .image-showcase__image {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
  }

  .image-showcase__badge {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    background: var(--color-accent, #00b894);
    color: #fff;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .image-showcase__content {
    padding: var(--space-lg) 0;
  }

  .image-showcase__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .image-showcase__description {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .image-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    background: var(--gradient-accent, linear-gradient(135deg, #00b894 0%, #00a884 100%));
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .image-showcase__cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent, 0 4px 15px rgba(0, 184, 148, 0.4));
  }

  .image-showcase__cta svg {
    transition: transform 0.2s ease;
  }

  .image-showcase__cta:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .image-showcase {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }

    .image-showcase--reverse {
      direction: ltr;
    }

    .image-showcase__title {
      font-size: var(--text-xl);
    }

    .image-showcase__description {
      font-size: var(--text-sm);
    }
  }
</style>
