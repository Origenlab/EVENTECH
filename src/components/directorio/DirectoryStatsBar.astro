---
/**
 * DirectoryStatsBar Component
 * Displays key statistics in a horizontal bar with icons.
 *
 * @example
 * <DirectoryStatsBar stats={[
 *   { value: "80+", label: "Venues", icon: "building" },
 *   { value: "20+", label: "Zonas", icon: "map" }
 * ]} />
 */

interface Stat {
  value: string | number;
  label: string;
  icon?: string;
  suffix?: string;
}

interface Props {
  stats: Stat[];
  variant?: "default" | "compact" | "accent";
}

const { stats, variant = "default" } = Astro.props;

// Icon SVGs
const icons: Record<string, string> = {
  building: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
  map: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/></svg>`,
  star: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  award: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>`,
  check: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  heart: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
  location: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
};

const defaultIcon = icons.building;
---

<div class={`stats-bar stats-bar--${variant}`}>
  {stats.map((stat, index) => (
    <div class="stats-bar__item">
      <div class="stats-bar__icon" set:html={stat.icon && icons[stat.icon] ? icons[stat.icon] : defaultIcon} />
      <div class="stats-bar__content">
        <span class="stats-bar__value">{stat.value}{stat.suffix || ""}</span>
        <span class="stats-bar__label">{stat.label}</span>
      </div>
    </div>
  ))}
</div>

<style>
  .stats-bar {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-xl);
    padding: var(--space-xl) var(--space-lg);
    background: linear-gradient(135deg, var(--color-primary) 0%, #1a2639 100%);
    border-radius: var(--radius-lg);
    margin: var(--space-2xl) 0;
  }

  .stats-bar__item {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-xl);
  }

  .stats-bar__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-md);
    color: var(--color-accent, #00b894);
  }

  .stats-bar__icon :global(svg) {
    width: 24px;
    height: 24px;
  }

  .stats-bar__content {
    display: flex;
    flex-direction: column;
  }

  .stats-bar__value {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .stats-bar__label {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-top: var(--space-xs);
  }

  /* Compact variant */
  .stats-bar--compact {
    padding: var(--space-md);
    gap: var(--space-lg);
  }

  .stats-bar--compact .stats-bar__item {
    padding: var(--space-sm) var(--space-md);
  }

  .stats-bar--compact .stats-bar__icon {
    width: 40px;
    height: 40px;
  }

  .stats-bar--compact .stats-bar__value {
    font-size: var(--text-2xl);
  }

  /* Accent variant */
  .stats-bar--accent {
    background: linear-gradient(135deg, var(--color-accent, #00b894) 0%, #009d7a 100%);
  }

  .stats-bar--accent .stats-bar__icon {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  @media (max-width: 768px) {
    .stats-bar {
      gap: var(--space-md);
      padding: var(--space-lg);
    }

    .stats-bar__item {
      flex: 1 1 45%;
      min-width: 140px;
      padding: var(--space-sm);
    }

    .stats-bar__icon {
      width: 40px;
      height: 40px;
    }

    .stats-bar__icon :global(svg) {
      width: 20px;
      height: 20px;
    }

    .stats-bar__value {
      font-size: var(--text-2xl);
    }
  }

  @media (max-width: 480px) {
    .stats-bar__item {
      flex: 1 1 100%;
      justify-content: center;
    }
  }
</style>
