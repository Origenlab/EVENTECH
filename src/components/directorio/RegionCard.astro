---
/**
 * RegionCard Component
 * Enhanced region selection card with image background and stats.
 *
 * @example
 * <RegionCard
 *   name="Ciudad de México"
 *   slug="cdmx"
 *   image="/images/directorio/cdmx-hero.jpg"
 *   venueCount={45}
 *   zoneCount={15}
 *   description="Salones, jardines y haciendas en las principales alcaldías"
 *   zones={["Polanco", "Santa Fe", "Coyoacán"]}
 * />
 */

interface Props {
  name: string;
  slug: string;
  image?: string;
  venueCount: number;
  zoneCount: number;
  description: string;
  zones: string[];
  priceRange?: string;
  variant?: "default" | "large" | "compact";
}

const {
  name,
  slug,
  image,
  venueCount,
  zoneCount,
  description,
  zones,
  priceRange = "$$-$$$$",
  variant = "default"
} = Astro.props;

const displayZones = zones.slice(0, 6);
const moreZones = zones.length - 6;
---

<article class={`region-card region-card--${variant}`}>
  {image && (
    <div class="region-card__image-wrapper">
      <img
        src={image}
        alt={`Venues en ${name}`}
        loading="lazy"
        decoding="async"
        class="region-card__image"
      />
      <div class="region-card__overlay"></div>
    </div>
  )}

  <div class="region-card__content">
    <div class="region-card__header">
      <h3 class="region-card__name">{name}</h3>
      <p class="region-card__description">{description}</p>
    </div>

    <div class="region-card__stats">
      <div class="region-card__stat">
        <span class="region-card__stat-value">{venueCount}+</span>
        <span class="region-card__stat-label">Venues</span>
      </div>
      <div class="region-card__stat">
        <span class="region-card__stat-value">{zoneCount}</span>
        <span class="region-card__stat-label">Zonas</span>
      </div>
      <div class="region-card__stat">
        <span class="region-card__stat-value">{priceRange}</span>
        <span class="region-card__stat-label">Precios</span>
      </div>
    </div>

    <div class="region-card__zones">
      <p class="region-card__zones-label">Zonas destacadas:</p>
      <div class="region-card__zones-list">
        {displayZones.map(zone => {
          const zoneSlug = zone.toLowerCase().replace(/\s+/g, '-').normalize("NFD").replace(/[\u0300-\u036f]/g, "");
          return (
            <a href={`/directorio/${slug}/${zoneSlug}/`} class="region-card__zone-tag">
              {zone}
            </a>
          );
        })}
        {moreZones > 0 && (
          <span class="region-card__zone-tag region-card__zone-tag--more">+{moreZones} más</span>
        )}
      </div>
    </div>

    <a href={`/directorio/${slug}/`} class="region-card__cta">
      Explorar {name}
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</article>

<style>
  .region-card {
    position: relative;
    background: #fff;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .region-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .region-card__image-wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .region-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .region-card:hover .region-card__image {
    transform: scale(1.05);
  }

  .region-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 38, 57, 0.95) 0%, rgba(26, 38, 57, 0.7) 50%, rgba(26, 38, 57, 0.4) 100%);
  }

  .region-card__content {
    position: relative;
    z-index: 1;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    min-height: 380px;
  }

  .region-card__header {
    flex: 1;
  }

  .region-card__name {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: #fff;
    margin: 0 0 var(--space-sm) 0;
  }

  .region-card__description {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.5;
    margin: 0;
  }

  .region-card__stats {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-md) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    margin: var(--space-md) 0;
  }

  .region-card__stat {
    text-align: center;
  }

  .region-card__stat-value {
    display: block;
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-accent, #00b894);
  }

  .region-card__stat-label {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .region-card__zones {
    margin-bottom: var(--space-md);
  }

  .region-card__zones-label {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.6);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 var(--space-sm) 0;
  }

  .region-card__zones-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .region-card__zone-tag {
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s ease;
  }

  .region-card__zone-tag:hover {
    background: var(--color-accent, #00b894);
  }

  .region-card__zone-tag--more {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    cursor: default;
  }

  .region-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-accent, #00b894);
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.2s ease;
  }

  .region-card__cta:hover {
    background: #009d7a;
  }

  .region-card__cta svg {
    width: 18px;
    height: 18px;
    transition: transform 0.2s ease;
  }

  .region-card__cta:hover svg {
    transform: translateX(4px);
  }

  /* Large variant */
  .region-card--large .region-card__content {
    min-height: 450px;
    padding: var(--space-2xl);
  }

  .region-card--large .region-card__name {
    font-size: var(--text-3xl);
  }

  /* Compact variant - no image */
  .region-card--compact {
    background: var(--color-primary);
  }

  .region-card--compact .region-card__content {
    min-height: auto;
    padding: var(--space-lg);
  }

  .region-card--compact .region-card__name {
    font-size: var(--text-xl);
  }

  @media (max-width: 768px) {
    .region-card__content {
      min-height: 320px;
      padding: var(--space-lg);
    }

    .region-card__name {
      font-size: var(--text-xl);
    }

    .region-card__stats {
      gap: var(--space-md);
    }
  }
</style>
