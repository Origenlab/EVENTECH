---
/**
 * VenueShowcase Component
 * Displays a featured venue with large image, description, and key details.
 *
 * @example
 * <VenueShowcase
 *   name="Hacienda de los Morales"
 *   image="/images/venues/hacienda-morales.jpg"
 *   type="Hacienda"
 *   location="Polanco, CDMX"
 *   capacity={{ min: 50, max: 1500 }}
 *   priceRange="$$$$"
 *   description="Una joya arquitectónica del siglo XVI..."
 *   href="/directorio/cdmx/polanco/hacienda-de-los-morales/"
 *   badges={["Premium", "Partner EVENTECH"]}
 *   reverse={false}
 * />
 */

interface Props {
  name: string;
  image: string;
  type: string;
  location: string;
  capacity: { min: number; max: number };
  priceRange: string;
  description: string;
  href: string;
  badges?: string[];
  reverse?: boolean;
  rating?: number;
  amenities?: string[];
}

const {
  name,
  image,
  type,
  location,
  capacity,
  priceRange,
  description,
  href,
  badges = [],
  reverse = false,
  rating,
  amenities = []
} = Astro.props;

const amenityIcons: Record<string, string> = {
  estacionamiento: "parking",
  jardin: "garden",
  capilla: "church",
  terraza: "terrace",
  pista: "dance",
  cocina: "kitchen",
  wifi: "wifi"
};
---

<div class={`venue-showcase ${reverse ? "venue-showcase--reverse" : ""}`}>
  <a href={href} class="venue-showcase__image-wrapper">
    <img
      src={image || "/images/placeholder-venue.jpg"}
      alt={name}
      loading="lazy"
      decoding="async"
      class="venue-showcase__image"
    />
    <div class="venue-showcase__badges">
      {badges.map(badge => (
        <span class="venue-showcase__badge">{badge}</span>
      ))}
    </div>
    <div class="venue-showcase__price">{priceRange}</div>
  </a>

  <div class="venue-showcase__content">
    <div class="venue-showcase__meta">
      <span class="venue-showcase__type">{type}</span>
      <span class="venue-showcase__location">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {location}
      </span>
    </div>

    <h3 class="venue-showcase__name">{name}</h3>

    {rating && (
      <div class="venue-showcase__rating">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>{rating}</span>
      </div>
    )}

    <p class="venue-showcase__description">{description}</p>

    <div class="venue-showcase__capacity">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      <span><strong>{capacity.min}-{capacity.max}</strong> personas</span>
    </div>

    {amenities.length > 0 && (
      <div class="venue-showcase__amenities">
        {amenities.slice(0, 5).map(amenity => (
          <span class="venue-showcase__amenity">{amenity}</span>
        ))}
        {amenities.length > 5 && (
          <span class="venue-showcase__amenity venue-showcase__amenity--more">+{amenities.length - 5}</span>
        )}
      </div>
    )}

    <a href={href} class="venue-showcase__cta">
      Ver detalles del venue
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</div>

<style>
  .venue-showcase {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-2xl);
    align-items: center;
    padding: var(--space-2xl);
    background: #fff;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    margin: var(--space-2xl) 0;
  }

  .venue-showcase--reverse {
    direction: rtl;
  }

  .venue-showcase--reverse > * {
    direction: ltr;
  }

  .venue-showcase__image-wrapper {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    aspect-ratio: 16 / 11;
    display: block;
  }

  .venue-showcase__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .venue-showcase__image-wrapper:hover .venue-showcase__image {
    transform: scale(1.05);
  }

  .venue-showcase__badges {
    position: absolute;
    top: var(--space-md);
    left: var(--space-md);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .venue-showcase__badge {
    background: var(--color-accent, #00b894);
    color: #fff;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .venue-showcase__badge:nth-child(2) {
    background: #f1c40f;
    color: #333;
  }

  .venue-showcase__price {
    position: absolute;
    bottom: var(--space-md);
    right: var(--space-md);
    background: rgba(0, 0, 0, 0.8);
    color: #fff;
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 700;
    border-radius: var(--radius-sm);
  }

  .venue-showcase__content {
    padding: var(--space-lg) 0;
  }

  .venue-showcase__meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .venue-showcase__type {
    display: inline-block;
    background: var(--color-accent-soft, rgba(0, 184, 148, 0.1));
    color: var(--color-accent, #00b894);
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-sm);
  }

  .venue-showcase__location {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-sm);
    color: var(--color-text-light);
  }

  .venue-showcase__location svg {
    width: 14px;
    height: 14px;
  }

  .venue-showcase__name {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-primary);
    margin: 0 0 var(--space-sm) 0;
    line-height: 1.2;
  }

  .venue-showcase__rating {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: #f1c40f;
    font-size: var(--text-sm);
    font-weight: 700;
    margin-bottom: var(--space-md);
  }

  .venue-showcase__rating svg {
    width: 16px;
    height: 16px;
  }

  .venue-showcase__description {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .venue-showcase__capacity {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-md);
  }

  .venue-showcase__capacity svg {
    width: 18px;
    height: 18px;
    color: var(--color-accent, #00b894);
  }

  .venue-showcase__capacity strong {
    color: var(--color-primary);
  }

  .venue-showcase__amenities {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .venue-showcase__amenity {
    background: var(--color-bg-alt);
    color: var(--color-text-light);
    padding: var(--space-xs) var(--space-sm);
    font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    text-transform: capitalize;
  }

  .venue-showcase__amenity--more {
    background: var(--color-accent-soft, rgba(0, 184, 148, 0.1));
    color: var(--color-accent, #00b894);
    font-weight: 600;
  }

  .venue-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-lg);
    background: var(--gradient-accent, linear-gradient(135deg, #00b894 0%, #00a884 100%));
    color: #fff;
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .venue-showcase__cta:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent, 0 4px 15px rgba(0, 184, 148, 0.4));
  }

  .venue-showcase__cta svg {
    width: 16px;
    height: 16px;
    transition: transform 0.2s ease;
  }

  .venue-showcase__cta:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 992px) {
    .venue-showcase {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }

    .venue-showcase--reverse {
      direction: ltr;
    }

    .venue-showcase__name {
      font-size: var(--text-xl);
    }
  }
</style>
