---
/**
 * ─── Proveedor Aliado Especialista en Iluminación — REDEIL (rentadeiluminacion.com) ───
 * Bloque unificado y profesional. Reemplaza las grillas "partner-card" rotas/duplicadas
 * que existían en las L5 de iluminación.
 *
 * Modelo white-label (igual que MESPIC en mesas-picnic): EVENTECH al frente,
 * REDEIL como aliado especialista y sitio hermano de iluminación.
 *
 * Props:
 *   focus?  → texto opcional para adaptar el copy a la categoría de la página
 *             (ej. "sky trackers y cabezas móviles"). Si se omite, cubre todo el catálogo.
 */
import SectionHeader from "@components/SectionHeader.astro";

interface Props {
  focus?: string;
}
const { focus } = Astro.props as Props;

const focusLead = focus
  ? `Cuando un evento necesita ${focus} a nivel de producción, sumamos a nuestro aliado especialista en iluminación para eventos: <strong>REDEIL</strong>.`
  : "Para llevar la iluminación de tu evento a nivel de producción, trabajamos de la mano de nuestro aliado especialista: <strong>REDEIL</strong>.";

const capabilities = [
  "Guirnaldas Edison",
  "Sky trackers",
  "Cabezas móviles",
  "Gobos personalizados",
  "Cascadas LED",
  "City Color / City Light",
  "Luces neón y vintage",
  "Luz negra UV",
  "Efectos especiales",
];

const stats = [
  { n: "+3,000", l: "eventos realizados" },
  { n: "+30", l: "años de experiencia" },
  { n: "CDMX", l: "y zona metropolitana" },
];

const waText = encodeURIComponent(
  "Hola, quiero cotizar iluminación profesional para mi evento" + (focus ? ` (${focus})` : "")
);
---

<section class="section prov-ilum" aria-labelledby="prov-ilum-heading">
  <div class="container">
    <SectionHeader
      id="prov-ilum-heading"
      title="Proveedor Aliado Especialista en Iluminación"
      subtitle="Red profesional EVENTECH"
      description={[
        "EVENTECH diseña, coordina y opera la iluminación de tu evento de principio a fin. Para las producciones lumínicas de mayor escala nos respaldamos en REDEIL, especialista en renta de iluminación y efectos para eventos en CDMX y Estado de México.",
        "Equipo profesional Martin Professional, Chauvet y Elation, transporte, instalación y operación técnica incluidos — el mismo estándar de calidad que exige cada montaje EVENTECH.",
      ]}
    />

    <div class="prov-ilum__grid">
      <!-- Aliado destacado: REDEIL -->
      <article class="prov-ilum__feature">
        <div class="prov-ilum__badge">Aliado especialista</div>
        <div class="prov-ilum__head">
          <span class="prov-ilum__logo" aria-hidden="true">REDEIL</span>
          <div>
            <h3 class="prov-ilum__name">REDEIL</h3>
            <p class="prov-ilum__tagline">Renta de Iluminación Profesional · rentadeiluminacion.com</p>
          </div>
        </div>

        <p class="prov-ilum__text" set:html={focusLead} />
        <p class="prov-ilum__text">
          Más de <strong>30 años</strong> y cientos de eventos montando iluminación, audio y efectos en
          bodas, XV años y eventos corporativos. Con equipo profesional
          <strong>Martin Professional, Chauvet y Elation</strong>, transporte, instalación,
          operación técnica y desmontaje incluidos — y plantas de luz para venues sin corriente.
        </p>

        <ul class="prov-ilum__caps" aria-label="Especialidades de iluminación">
          {capabilities.map((c) => (<li>{c}</li>))}
        </ul>

        <div class="prov-ilum__actions">
          <a
            class="prov-ilum__btn prov-ilum__btn--primary"
            href="https://rentadeiluminacion.com/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visitar rentadeiluminacion.com
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          <a class="prov-ilum__btn prov-ilum__btn--ghost" href="/servicios/iluminacion/">
            Ver todo en iluminación
          </a>
        </div>
      </article>

      <!-- Panel lateral: cifras + integración -->
      <aside class="prov-ilum__side" aria-label="Respaldo del aliado">
        <ul class="prov-ilum__stats">
          {stats.map((s) => (
            <li>
              <span class="prov-ilum__stat-n">{s.n}</span>
              <span class="prov-ilum__stat-l">{s.l}</span>
            </li>
          ))}
        </ul>
        <div class="prov-ilum__note">
          <h4>Producción integral, un solo interlocutor</h4>
          <p>
            EVENTECH integra la iluminación con
            <a href="/servicios/audiovisual/">audio y pantallas</a>,
            <a href="/servicios/carpas/">carpas</a> y
            <a href="/servicios/mobiliario/">mobiliario</a>, coordinando a REDEIL dentro de la misma
            producción. Tú tratas con un solo equipo; nosotros alineamos a todos los proveedores.
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .prov-ilum__grid {
    display: grid;
    grid-template-columns: 1.65fr 1fr;
    gap: var(--space-xl, 2rem);
    align-items: stretch;
    margin-block-start: var(--space-xl, 2rem);
  }

  /* Tarjeta destacada */
  .prov-ilum__feature {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: var(--color-bg, #fff);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-block-start: 4px solid var(--color-accent, #c2a24a);
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
  }
  .prov-ilum__badge {
    align-self: flex-start;
    padding: 0.3rem 0.85rem;
    background: var(--color-accent-soft, rgba(194, 162, 74, 0.12));
    color: var(--color-accent-hover, #a9883a);
    font-size: var(--text-xs, 0.78rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .prov-ilum__head {
    display: flex;
    align-items: center;
    gap: var(--space-md, 1rem);
  }
  .prov-ilum__logo {
    display: grid;
    place-items: center;
    inline-size: 60px;
    block-size: 60px;
    flex: 0 0 60px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #fff;
    background: var(--gradient-accent, linear-gradient(135deg, #c2a24a, #a9883a));
    border-radius: 14px;
    box-shadow: var(--shadow-accent, 0 4px 14px rgba(194, 162, 74, 0.35));
  }
  .prov-ilum__name {
    font-size: var(--text-xl, 1.35rem);
    font-weight: 800;
    color: var(--color-primary, #1a2238);
    line-height: 1.1;
  }
  .prov-ilum__tagline {
    font-size: var(--text-sm, 0.9rem);
    font-weight: 600;
    color: var(--color-accent-hover, #a9883a);
  }
  .prov-ilum__text {
    font-size: var(--text-sm, 0.95rem);
    line-height: 1.7;
    color: var(--color-text-light, #4a4f5c);
  }
  .prov-ilum__caps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.25rem 0;
  }
  .prov-ilum__caps li {
    padding: 0.35rem 0.7rem;
    background: var(--color-accent-soft, rgba(194, 162, 74, 0.1));
    color: var(--color-accent-hover, #a9883a);
    font-size: var(--text-xs, 0.78rem);
    font-weight: 600;
    border-radius: 8px;
  }
  .prov-ilum__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: auto;
    padding-block-start: var(--space-sm, 0.5rem);
  }
  .prov-ilum__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.35rem;
    font-size: var(--text-sm, 0.9rem);
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .prov-ilum__btn--primary {
    background: var(--color-accent, #c2a24a);
    color: #1c1607;
  }
  .prov-ilum__btn--primary:hover {
    background: var(--color-accent-hover, #a9883a);
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent-hover, 0 6px 20px rgba(194, 162, 74, 0.45));
  }
  .prov-ilum__btn--ghost {
    background: transparent;
    color: var(--color-primary, #1a2238);
    border: 1px solid rgba(0, 0, 0, 0.15);
  }
  .prov-ilum__btn--ghost:hover {
    border-color: var(--color-accent, #c2a24a);
    color: var(--color-accent-hover, #a9883a);
  }

  /* Panel lateral */
  .prov-ilum__side {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }
  .prov-ilum__stats {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    padding: var(--space-lg, 1.5rem);
    margin: 0;
    background: var(--color-primary, #1a2238);
    border-radius: var(--radius-lg, 16px);
    color: #fff;
  }
  .prov-ilum__stats li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .prov-ilum__stat-n {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-accent-light, #d4b96a);
    line-height: 1;
  }
  .prov-ilum__stat-l {
    font-size: var(--text-sm, 0.9rem);
    color: rgba(255, 255, 255, 0.82);
  }
  .prov-ilum__note {
    flex: 1;
    padding: var(--space-lg, 1.5rem);
    background: var(--color-bg, #fff);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-lg, 16px);
  }
  .prov-ilum__note h4 {
    font-size: var(--text-base, 1rem);
    font-weight: 700;
    color: var(--color-primary, #1a2238);
    margin: 0 0 0.5rem;
  }
  .prov-ilum__note p {
    font-size: var(--text-sm, 0.9rem);
    line-height: 1.7;
    color: var(--color-text-light, #4a4f5c);
    margin: 0;
  }
  .prov-ilum__note a {
    color: var(--color-accent-hover, #a9883a);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .prov-ilum__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
