---
/**
 * ─── ReviewCard Component ───
 * Componente de tarjeta para reseñas/testimonios empresariales.
 * Diseño profesional diferenciado del Card estándar.
 */

type Props = {
  company: string;
  author: string;
  role: string;
  rating: number;
  text: string;
  event: string;
  website?: string;
};

const { company, author, role, rating, text, event, website } = Astro.props;
---

<article class={`review-card ${website ? 'review-card--featured' : ''}`}>
  <!-- Partner Badge (for companies with website) -->
  {website && (
    <div class="review-card__partner-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
      </svg>
      Partner
    </div>
  )}

  <!-- Quote Icon -->
  <div class="review-card__quote" aria-hidden="true">
    <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
      <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.956.76-3.022.66-1.065 1.515-1.867 2.558-2.403L9.373 5c-.8.396-1.56.898-2.26 1.505-.71.607-1.34 1.305-1.9 2.094s-.98 1.68-1.25 2.69-.346 2.04-.217 3.1c.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368l.002.004zm9.124 0c0-.88-.23-1.618-.69-2.217-.326-.42-.768-.695-1.327-.825-.55-.13-1.07-.14-1.54-.03-.16-.94.09-1.95.75-3.02.66-1.06 1.514-1.86 2.557-2.4L18.49 5c-.8.396-1.555.898-2.26 1.505-.708.607-1.34 1.305-1.894 2.094-.556.79-.97 1.68-1.24 2.69-.273 1-.345 2.04-.217 3.1.165 1.4.615 2.52 1.35 3.35.732.833 1.646 1.25 2.742 1.25.967 0 1.768-.29 2.402-.876.627-.576.942-1.365.942-2.368v.012z"/>
    </svg>
  </div>

  <!-- Stars Rating -->
  <div class="review-card__stars" aria-label={`${rating} de 5 estrellas`}>
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class={`review-card__star ${i < rating ? 'review-card__star--filled' : ''}`}
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill={i < rating ? "currentColor" : "none"}
        stroke="currentColor"
        stroke-width="1.5"
      >
        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
      </svg>
    ))}
  </div>

  <!-- Event Type Badge -->
  <span class="review-card__badge">{event}</span>

  <!-- Testimonial Text -->
  <blockquote class="review-card__text">
    "{text}"
  </blockquote>

  <!-- Author Info -->
  <footer class="review-card__footer">
    <div class="review-card__avatar">
      {author.split(' ').map(n => n[0]).slice(0, 2).join('')}
    </div>
    <div class="review-card__author-info">
      <cite class="review-card__author">{author}</cite>
      <span class="review-card__role">{role}</span>
      {website ? (
        <a href={website} class="review-card__company review-card__company--link" target="_blank" rel="noopener noreferrer">
          {company}
          <svg class="review-card__external-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      ) : (
        <span class="review-card__company">{company}</span>
      )}
    </div>
  </footer>
</article>

<style>
  .review-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-sm);
  }

  /* ── Featured Card (with website) ── */
  .review-card--featured {
    padding-block-start: var(--space-2xl);
    border: 2px solid var(--color-accent);
    background: linear-gradient(135deg, var(--color-bg) 0%, rgba(var(--color-accent-rgb, 255, 107, 0), 0.03) 100%);
  }

  /* ── Partner Badge ── */
  .review-card__partner-badge {
    position: absolute;
    top: 0;
    left: var(--space-lg);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 0.35rem 0.75rem;
    background: var(--gradient-accent);
    color: white;
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    box-shadow: var(--shadow-sm);
  }

  /* ── Quote Icon ── */
  .review-card__quote {
    position: absolute;
    top: var(--space-md);
    right: var(--space-lg);
    color: var(--color-accent);
    opacity: 0.15;
  }

  /* ── Stars + Badge group ── */
  .review-card__stars {
    display: flex;
    gap: 3px;
    margin-block-end: var(--space-sm);
  }

  .review-card__star {
    color: #d1d5db;
  }

  .review-card__star--filled {
    color: #fbbf24;
  }

  /* ── Badge ── */
  .review-card__badge {
    display: inline-block;
    width: fit-content;
    padding: 0.3rem 0.85rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius-full);
    margin-block-end: var(--space-lg);
  }

  /* ── Text ── */
  .review-card__text {
    flex-grow: 1;
    margin: 0;
    padding: 0;
    font-size: var(--text-base);
    font-style: italic;
    line-height: 1.7;
    color: var(--color-text);
    margin-block-end: var(--space-lg);
  }

  /* ── Footer ── */
  .review-card__footer {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-block-start: var(--space-md);
    border-block-start: 1px solid var(--color-border-light);
  }

  .review-card__avatar {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient-accent);
    color: white;
    font-size: var(--text-sm);
    font-weight: 700;
    border-radius: var(--radius-full);
    text-transform: uppercase;
  }

  .review-card__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .review-card__author {
    font-size: var(--text-base);
    font-weight: 700;
    font-style: normal;
    color: var(--color-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-card__role {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-card__company {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .review-card__company--link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    text-decoration: none;
  }

  .review-card__company--link:hover {
    color: var(--color-primary);
  }

  .review-card__external-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .review-card__company--link:hover .review-card__external-icon {
    opacity: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .review-card {
      padding: var(--space-lg);
    }

    .review-card__text {
      font-size: var(--text-sm);
    }

    .review-card__avatar {
      width: 40px;
      height: 40px;
      font-size: var(--text-xs);
    }

    .review-card__author {
      font-size: var(--text-sm);
    }

    .review-card__role {
      font-size: var(--text-xs);
    }
  }
</style>
