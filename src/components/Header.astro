---
/**
 * ─── Header Component ───
 * Shell fijo: logo (wordmark EVENTECH) + Nav (mega-menú self-contained).
 * El toggle mobile y toda la lógica de dropdowns viven en Nav.astro.
 */
import Nav from "./Nav.astro";
import { SITE } from "@config/site";
---

<header class="header" role="banner">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label={`${SITE.name} — Ir al inicio`}>
      <img
        src="/images/eventech-logo.png"
        alt={SITE.name}
        width="779"
        height="114"
        class="header__logo-img"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Mega-menú (incluye hamburger mobile) -->
    <Nav />
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: var(--topbar-height, 36px);
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--color-bg, #fff);
    border-block-end: 1px solid var(--color-border-light, #e8e4dc);
    height: var(--header-height, 64px);
    display: flex;
    align-items: center;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: var(--space-lg, 2rem);
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-primary, #1a1a2e);
    flex-shrink: 0;
    z-index: 1001; /* encima del panel mobile */
  }

  .header__logo-img {
    display: block;
    height: 30px;
    width: auto;
  }

  @media (max-width: 480px) {
    .header__logo-img {
      height: 26px;
    }
  }
</style>
