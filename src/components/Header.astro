---
/**
 * ─── Header Component ───
 * Shell fijo: logo Cormorant + Nav (mega-menú self-contained).
 * El toggle mobile y toda la lógica de dropdowns viven en Nav.astro.
 */
import Nav from "./Nav.astro";
import { SITE } from "@config/site";
---

<header class="header" role="banner">
  <div class="container header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label={`${SITE.name} — Ir al inicio`}>
      <img
        src="/favicon.svg"
        alt=""
        width="32"
        height="32"
        aria-hidden="true"
        loading="eager"
        decoding="async"
      />
      <span class="header__brand">{SITE.name}</span>
    </a>

    <!-- Mega-menú (incluye hamburger mobile) -->
    <Nav />
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: var(--topbar-height, 36px);
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--color-bg, #fff);
    border-block-end: 1px solid var(--color-border-light, #e8e4dc);
    height: var(--header-height, 64px);
    display: flex;
    align-items: center;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: var(--space-lg, 2rem);
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--color-primary, #1a1a2e);
    flex-shrink: 0;
    z-index: 1001; /* encima del panel mobile */
  }

  .header__brand {
    font-family: var(--font-display, "Cormorant Garamond", serif);
    font-weight: 700;
    font-size: 1.35rem;
    line-height: 1;
    letter-spacing: 0.02em;
  }

  @media (max-width: 480px) {
    .header__brand {
      font-size: 1.15rem;
    }
  }
</style>
