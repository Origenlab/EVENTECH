---
/**
 * ─── Header Component ───
 * Site header with logo, navigation, and mobile menu toggle.
 * Implements accessible landmarks and keyboard navigation.
 */
import Nav from "./Nav.astro";
import { SITE } from "@data/site";
---

<header class="header" role="banner">
  <div class="container cluster header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label={`${SITE.name} — Ir al inicio`}>
      <img
        src="/favicon.svg"
        alt=""
        width="32"
        height="32"
        aria-hidden="true"
      />
      <span class="header__brand">{SITE.name}</span>
    </a>

    <!-- Mobile Menu Toggle -->
    <button
      class="header__toggle"
      aria-expanded="false"
      aria-controls="main-nav"
      aria-label="Abrir menú de navegación"
    >
      <span class="header__toggle-bar" aria-hidden="true"></span>
      <span class="header__toggle-bar" aria-hidden="true"></span>
      <span class="header__toggle-bar" aria-hidden="true"></span>
    </button>

    <!-- Navigation -->
    <div id="main-nav" class="header__nav">
      <Nav />
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector(".header__toggle");
    const nav = document.getElementById("main-nav");

    const closeMenu = () => {
      toggle?.setAttribute("aria-expanded", "false");
      nav?.classList.remove("header__nav--open");
    };

    toggle?.addEventListener("click", () => {
      const expanded = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!expanded));
      nav?.classList.toggle("header__nav--open");
    });

    // Cerrar con Escape y devolver el foco al botón (WCAG 2.1.2)
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && nav?.classList.contains("header__nav--open")) {
        closeMenu();
        toggle?.focus();
      }
    });

    // Cerrar al hacer clic en un enlace del menú (móvil)
    nav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  });
</script>

<style>
  .header {
    position: fixed;
    top: var(--topbar-height);
    left: 0;
    right: 0;
    z-index: 1000;
    background-color: var(--color-bg);
    border-block-end: 1px solid var(--color-border-light);
    padding-block: var(--space-md);
    height: var(--header-height);
    display: flex;
    align-items: center;
  }

  .header__inner {
    justify-content: space-between;
  }

  .header__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: var(--color-primary);
  }

  .header__brand {
    font-weight: 700;
    font-size: var(--text-lg);
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-sm);
    /* Touch target accesible >= 44px (WCAG 2.5.5) */
    min-width: 44px;
    min-height: 44px;
  }

  .header__toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-primary);
  }

  @media (max-width: 768px) {
    .header__toggle {
      display: flex;
    }

    .header__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-bg);
      padding: var(--space-lg) var(--container-padding);
      border-block-end: 1px solid var(--color-border-light);
      box-shadow: var(--shadow-md);
    }

    .header__nav--open {
      display: block;
    }
  }
</style>
