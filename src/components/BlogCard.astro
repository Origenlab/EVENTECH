---
/**
 * ─── BlogCard Component ───
 * Card for displaying blog post previews in grids.
 * Enhanced with category badge, tags, and filter support.
 */
import { readingTime } from "@utils/helpers";

type Props = {
  title: string;
  description: string;
  slug: string;
  date: Date;
  image?: string;
  body?: string;
  category?: string;
  tags?: string[];
  author?: string;
  featured?: boolean;
};

const { title, description, slug, date, image, body, category, tags, author, featured } = Astro.props;
const minutes = body ? readingTime(body) : undefined;

const CATEGORY_LABELS: Record<string, string> = {
  "bodas": "Bodas",
  "xv-anos": "XV Años",
  "corporativos": "Corporativos",
  "tendencias": "Tendencias",
  "guias": "Guías",
  "tips": "Tips",
  "casos-exito": "Casos de Éxito",
};
---

<article class:list={["blog-card", { "blog-card--featured": featured }]} data-category={category}>
  <a href={`/blog/${slug}/`} class="blog-card__link">
    {image ? (
      <img
        src={image}
        alt=""
        class="blog-card__image"
        loading="lazy"
        width="400"
        height="225"
      />
    ) : (
      <div class="blog-card__image-placeholder">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
          <circle cx="12" cy="13" r="3"/>
        </svg>
      </div>
    )}
    <div class="blog-card__body">
      {category && (
        <span class="blog-card__category">{CATEGORY_LABELS[category] || category}</span>
      )}
      <h3 class="blog-card__title">{title}</h3>
      <p class="blog-card__description">{description}</p>
      {tags && tags.length > 0 && (
        <div class="blog-card__tags">
          {tags.slice(0, 2).map((tag) => (
            <span class="blog-card__tag">{tag}</span>
          ))}
        </div>
      )}
      <div class="blog-card__meta">
        {minutes && <span>{minutes} min de lectura</span>}
        {author && <span class="blog-card__author">{author}</span>}
      </div>
    </div>
  </a>
</article>

<style>
  .blog-card {
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
    transition: box-shadow var(--transition-base), transform var(--transition-base);
  }

  .blog-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .blog-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .blog-card__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .blog-card__image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, #f0f4f8 0%, #e2e8f0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    opacity: 0.5;
  }

  .blog-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    flex: 1;
  }

  .blog-card__title {
    font-size: var(--text-lg);
    color: var(--color-primary);
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__description {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.5;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-block-start: auto;
    padding-block-start: var(--space-sm);
  }

  .blog-card__meta span::before {
    content: "·";
    margin-inline-end: var(--space-sm);
  }

  .blog-card__meta time::before {
    content: none;
  }
</style>
