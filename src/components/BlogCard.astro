---
/**
 * ─── BlogCard Component (elevado 2026) ───
 * Card editorial con fecha, lectura y categoría. Sin hashtags SEO.
 * Grid: featured = full-width horizontal; regular = columna vertical.
 * Estilos en blog-2026.css (clases hm-bl-card).
 */
import { readingTime } from "@lib/helpers";

type Props = {
  title: string;
  description: string;
  slug: string;
  date?: Date;
  image?: string;
  body?: string;
  category?: string;
  tags?: string[];
  author?: string;
  featured?: boolean;
};

const { title, description, slug, image, body, category, date, author, featured } = Astro.props;
const minutes = body ? readingTime(body) : undefined;

const CATEGORY_LABELS: Record<string, string> = {
  "bodas": "Bodas",
  "xv-anos": "XV Años",
  "corporativos": "Corporativos",
  "tendencias": "Tendencias",
  "guias": "Guías",
  "tips": "Tips",
  "casos-exito": "Casos de Éxito",
};

// Fecha formateada en español
const dateStr = date
  ? new Intl.DateTimeFormat("es-MX", {
      day: "numeric",
      month: "short",
      year: "numeric",
    }).format(date)
  : null;

const dateIso = date ? date.toISOString().split("T")[0] : null;
---

<article
  class:list={["hm-bl-card", { "hm-bl-card--featured": featured }]}
  data-category={category}
>
  <a href={`/blog/${slug}/`} class="hm-bl-card__link">

    <div class="hm-bl-card__media">
      {image ? (
        <img
          src={image}
          alt={title}
          class="hm-bl-card__img"
          loading="lazy"
          decoding="async"
          width="600"
          height="400"
        />
      ) : (
        <div class="hm-bl-card__ph">
          <svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/>
            <circle cx="12" cy="13" r="3"/>
          </svg>
        </div>
      )}

      {category && (
        <span class="hm-bl-card__badge">
          {CATEGORY_LABELS[category] || category}
        </span>
      )}

      {minutes && (
        <span class="hm-bl-card__rt" aria-label={`${minutes} minutos de lectura`}>
          <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          {minutes} min
        </span>
      )}
    </div>

    <div class="hm-bl-card__body">
      <h3 class="hm-bl-card__title">{title}</h3>
      <p class="hm-bl-card__desc">{description}</p>

      <footer class="hm-bl-card__foot">
        <div class="hm-bl-card__meta">
          {dateStr && dateIso && (
            <time datetime={dateIso} class="hm-bl-card__date">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {dateStr}
            </time>
          )}
          {author && (
            <span class="hm-bl-card__author">
              <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
              {author}
            </span>
          )}
        </div>
        <span class="hm-bl-card__more" aria-hidden="true">
          Leer
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </span>
      </footer>
    </div>

  </a>
</article>
