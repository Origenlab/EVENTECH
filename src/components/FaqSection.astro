---
/**
 * FaqSection — OrigenLab Standard (EVENTECH)
 * 2 columnas: FAQ acordeón izquierda + formulario cotización derecha
 * Sin animaciones. Sin wa.me directo. CTA → /cotizar/
 */
import { SITE } from "@config/site";

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  phone?: string;
  email?: string;
  schedule?: string;
  serviceName?: string;
}

const {
  items,
  phone = SITE.contact.phone,
  email = SITE.contact.email,
  schedule = "Lun–Vie 9:00–18:00 · Sáb 9:00–14:00",
  serviceName = "equipo para eventos",
} = Astro.props;
---

<div class="faq-layout container">

  <!-- COLUMNA 1: FAQ -->
  <div class="faq-layout__faqs">
    {items.map((item) => (
      <details class="faq-item">
        <summary class="faq-item__q">{item.question}</summary>
        <div class="faq-item__a">
          <p>{item.answer}</p>
        </div>
      </details>
    ))}
  </div>

  <!-- COLUMNA 2: Contacto + CTA Cotizar -->
  <div class="faq-layout__contact">
    <div class="faq-contact">
      <h3 class="faq-contact__title">¿No encuentras tu respuesta?</h3>
      <p class="faq-contact__desc">Escríbenos y te respondemos en minutos. Cotiza sin compromiso.</p>

      <div class="faq-contact__info">
        <a href={`tel:${SITE.contact.phoneRaw}`} class="faq-contact__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span>{phone}</span>
        </a>
        <a href={`mailto:${email}`} class="faq-contact__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>{email}</span>
        </a>
        <div class="faq-contact__item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>{schedule}</span>
        </div>
      </div>

      <a href="/cotizar/" class="faq-contact__cta">
        Cotiza Gratis tu Evento
      </a>
      <p class="faq-contact__note">Respuesta en menos de 24 horas</p>
    </div>
  </div>

</div>

<style>
  .faq-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 3rem;
    align-items: start;
  }

  .faq-layout__faqs {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .faq-item {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 8px;
    overflow: hidden;
  }

  .faq-item__q {
    padding: 1.125rem 1.5rem;
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #1a1a2e;
  }

  .faq-item__q::-webkit-details-marker { display: none; }

  .faq-item__q::after {
    content: '+';
    font-size: 1.25rem;
    font-weight: 300;
    color: #6c757d;
    flex-shrink: 0;
    margin-left: 1rem;
  }

  .faq-item[open] .faq-item__q::after {
    content: '−';
  }

  .faq-item[open] .faq-item__q {
    background: #f8f9fa;
  }

  .faq-item__a {
    padding: 0 1.5rem 1.125rem;
    color: #6c757d;
    font-size: 0.9375rem;
    line-height: 1.7;
  }

  /* Contact sidebar */
  .faq-contact {
    background: #fff;
    border: 1px solid #e9ecef;
    border-radius: 12px;
    padding: 2rem;
    position: sticky;
    top: calc(var(--topbar-height, 36px) + var(--header-height, 64px) + 1.5rem);
  }

  .faq-contact__title {
    font-size: 1.125rem;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
  }

  .faq-contact__desc {
    font-size: 0.875rem;
    color: #6c757d;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .faq-contact__info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #e9ecef;
  }

  .faq-contact__item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #1a1a2e;
    text-decoration: none;
  }

  .faq-contact__item svg {
    color: #00b894;
    flex-shrink: 0;
  }

  .faq-contact__cta {
    display: block;
    width: 100%;
    padding: 0.85rem 1rem;
    background: #FF6B6B;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    border-radius: 8px;
  }

  .faq-contact__cta:hover {
    background: #FF5252;
  }

  .faq-contact__note {
    text-align: center;
    font-size: 0.75rem;
    color: #6c757d;
    margin-top: 0.5rem;
  }

  @media (max-width: 1024px) {
    .faq-layout {
      grid-template-columns: 1fr 300px;
      gap: 2rem;
    }
  }

  @media (max-width: 860px) {
    .faq-layout {
      grid-template-columns: 1fr;
    }

    .faq-contact {
      position: static;
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
