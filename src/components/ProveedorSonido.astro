---
/**
 * ─── Proveedor Aliado Especialista en Sonido — SOEVE (sonidoparaeventos.com.mx) ───
 * Bloque unificado y profesional. Reemplaza las grillas "partner-card" ficticias
 * (AudioVisual Pro MX, SonidoEventos CDMX, TechEvents, MediaRent) que existían
 * en las L5 de sonido.
 *
 * Modelo white-label (igual que REDEIL en iluminación y MESPIC en mesas-picnic):
 * EVENTECH al frente, SOEVE como aliado especialista y sitio hermano de audio.
 *
 * Props:
 *   focus?  → texto opcional para adaptar el copy a la categoría de la página
 *             (ej. "line array y subwoofers de alto SPL"). Si se omite, cubre todo el catálogo.
 */
import SectionHeader from "@components/SectionHeader.astro";

interface Props {
  focus?: string;
}
const { focus } = Astro.props as Props;

const focusLead = focus
  ? `Cuando un evento necesita ${focus} a nivel de producción, sumamos a nuestro aliado especialista en renta de equipo de sonido: <strong>SOEVE</strong>.`
  : "Para llevar el audio de tu evento a nivel de producción, trabajamos de la mano de nuestro aliado especialista en sonido: <strong>SOEVE</strong>.";

const capabilities = [
  "Line array",
  "Bocinas profesionales",
  "Subwoofers",
  "Consolas de mezcla",
  "Amplificadores de potencia",
  "Micrófonos inalámbricos",
  "Monitores de escenario",
  "Paquetes DJ",
  "Instalación y montaje",
];

const stats = [
  { n: "+500", l: "eventos realizados" },
  { n: "24/7", l: "soporte técnico" },
  { n: "2", l: "sucursales en CDMX" },
];
---

<section class="section prov-son" aria-labelledby="prov-son-heading">
  <div class="container">
    <SectionHeader
      id="prov-son-heading"
      title="Proveedor Aliado Especialista en Sonido"
      subtitle="Red profesional EVENTECH"
      description={[
        "EVENTECH diseña, calibra y opera el audio de tu evento de principio a fin. Para las producciones de mayor escala nos respaldamos en SOEVE, especialista en renta de equipo de sonido profesional para eventos en CDMX y Estado de México.",
        "Bocinas, consolas, amplificación y microfonía de grado profesional, con instalación, configuración y soporte técnico incluidos — el mismo estándar que exige cada montaje EVENTECH.",
      ]}
    />

    <div class="prov-son__grid">
      <!-- Aliado destacado: SOEVE -->
      <article class="prov-son__feature">
        <div class="prov-son__badge">Aliado especialista</div>
        <div class="prov-son__head">
          <span class="prov-son__logo" aria-hidden="true">SOEVE</span>
          <div>
            <h3 class="prov-son__name">SOEVE</h3>
            <p class="prov-son__tagline">Sonido para Eventos · sonidoparaeventos.com.mx</p>
          </div>
        </div>

        <p class="prov-son__text" set:html={focusLead} />
        <p class="prov-son__text">
          Más de <strong>500 eventos</strong> cubiertos en CDMX y zona metropolitana, desde
          bodas y XV años hasta congresos y conciertos de <strong>50 a 5,000 personas</strong>.
          Bocinas de alta fidelidad, sistemas line array, subwoofers, consolas digitales y
          analógicas, amplificadores de potencia y microfonía inalámbrica — con
          <strong>instalación, cableado, pruebas de sonido pre-evento y soporte técnico 24/7</strong>.
        </p>

        <ul class="prov-son__caps" aria-label="Especialidades de sonido">
          {capabilities.map((c) => (<li>{c}</li>))}
        </ul>

        <div class="prov-son__actions">
          <a
            class="prov-son__btn prov-son__btn--primary"
            href="https://sonidoparaeventos.com.mx/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visitar sonidoparaeventos.com.mx
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          <a class="prov-son__btn prov-son__btn--ghost" href="/servicios/audiovisual/sonido/">
            Ver todo en sonido
          </a>
        </div>
      </article>

      <!-- Panel lateral: cifras + integración -->
      <aside class="prov-son__side" aria-label="Respaldo del aliado">
        <ul class="prov-son__stats">
          {stats.map((s) => (
            <li>
              <span class="prov-son__stat-n">{s.n}</span>
              <span class="prov-son__stat-l">{s.l}</span>
            </li>
          ))}
        </ul>
        <div class="prov-son__note">
          <h4>Producción integral, un solo interlocutor</h4>
          <p>
            EVENTECH integra el audio con
            <a href="/servicios/iluminacion/">iluminación</a>,
            <a href="/servicios/audiovisual/pantallas-led/">pantallas LED</a> y
            <a href="/servicios/mobiliario/">mobiliario</a>, coordinando a SOEVE dentro de la misma
            producción. Tú tratas con un solo equipo; nosotros alineamos a todos los proveedores.
          </p>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .prov-son__grid {
    display: grid;
    grid-template-columns: 1.65fr 1fr;
    gap: var(--space-xl, 2rem);
    align-items: stretch;
    margin-block-start: var(--space-xl, 2rem);
  }

  /* Tarjeta destacada */
  .prov-son__feature {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
    padding: clamp(1.5rem, 3vw, 2.5rem);
    background: var(--color-bg, #fff);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-block-start: 4px solid var(--color-accent, #c2a24a);
    border-radius: var(--radius-lg, 16px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
  }
  .prov-son__badge {
    align-self: flex-start;
    padding: 0.3rem 0.85rem;
    background: var(--color-accent-soft, rgba(194, 162, 74, 0.12));
    color: var(--color-accent-hover, #a9883a);
    font-size: var(--text-xs, 0.78rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
  }
  .prov-son__head {
    display: flex;
    align-items: center;
    gap: var(--space-md, 1rem);
  }
  .prov-son__logo {
    display: grid;
    place-items: center;
    inline-size: 60px;
    block-size: 60px;
    flex: 0 0 60px;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #fff;
    background: var(--gradient-accent, linear-gradient(135deg, #c2a24a, #a9883a));
    border-radius: 14px;
    box-shadow: var(--shadow-accent, 0 4px 14px rgba(194, 162, 74, 0.35));
  }
  .prov-son__name {
    font-size: var(--text-xl, 1.35rem);
    font-weight: 800;
    color: var(--color-primary, #1a2238);
    line-height: 1.1;
  }
  .prov-son__tagline {
    font-size: var(--text-sm, 0.9rem);
    font-weight: 600;
    color: var(--color-accent-hover, #a9883a);
  }
  .prov-son__text {
    font-size: var(--text-sm, 0.95rem);
    line-height: 1.7;
    color: var(--color-text-light, #4a4f5c);
  }
  .prov-son__caps {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0.25rem 0;
  }
  .prov-son__caps li {
    padding: 0.35rem 0.7rem;
    background: var(--color-accent-soft, rgba(194, 162, 74, 0.1));
    color: var(--color-accent-hover, #a9883a);
    font-size: var(--text-xs, 0.78rem);
    font-weight: 600;
    border-radius: 8px;
  }
  .prov-son__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: auto;
    padding-block-start: var(--space-sm, 0.5rem);
  }
  .prov-son__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.35rem;
    font-size: var(--text-sm, 0.9rem);
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .prov-son__btn--primary {
    background: var(--color-accent, #c2a24a);
    color: #1c1607;
  }
  .prov-son__btn--primary:hover {
    background: var(--color-accent-hover, #a9883a);
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent-hover, 0 6px 20px rgba(194, 162, 74, 0.45));
  }
  .prov-son__btn--ghost {
    background: transparent;
    color: var(--color-primary, #1a2238);
    border: 1px solid rgba(0, 0, 0, 0.15);
  }
  .prov-son__btn--ghost:hover {
    border-color: var(--color-accent, #c2a24a);
    color: var(--color-accent-hover, #a9883a);
  }

  /* Panel lateral */
  .prov-son__side {
    display: flex;
    flex-direction: column;
    gap: var(--space-md, 1rem);
  }
  .prov-son__stats {
    display: grid;
    gap: 0.75rem;
    list-style: none;
    padding: var(--space-lg, 1.5rem);
    margin: 0;
    background: var(--color-primary, #1a2238);
    border-radius: var(--radius-lg, 16px);
    color: #fff;
  }
  .prov-son__stats li {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .prov-son__stat-n {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--color-accent-light, #d4b96a);
    line-height: 1;
  }
  .prov-son__stat-l {
    font-size: var(--text-sm, 0.9rem);
    color: rgba(255, 255, 255, 0.82);
  }
  .prov-son__note {
    flex: 1;
    padding: var(--space-lg, 1.5rem);
    background: var(--color-bg, #fff);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-lg, 16px);
  }
  .prov-son__note h4 {
    font-size: var(--text-base, 1rem);
    font-weight: 700;
    color: var(--color-primary, #1a2238);
    margin: 0 0 0.5rem;
  }
  .prov-son__note p {
    font-size: var(--text-sm, 0.9rem);
    line-height: 1.7;
    color: var(--color-text-light, #4a4f5c);
    margin: 0;
  }
  .prov-son__note a {
    color: var(--color-accent-hover, #a9883a);
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .prov-son__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
