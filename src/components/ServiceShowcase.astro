---
/**
 * ─── ServiceShowcase ───
 * Sección "showcase" reutilizable (contenido + media) usada en hubs y páginas
 * de servicio. Los estilos viven en `@styles/l3-shared.css` (global), por lo
 * que este componente no lleva <style> propio y produce el mismo HTML que el
 * markup inline original.
 *
 * - Campos de texto simple (badge, título, subtítulo, tags, CTA) → props.
 * - Contenido rico (párrafos) → slot "body" (verbatim).
 * - Imagen/galería/placeholder → slot "media" (verbatim).
 */
interface Props {
  title: string;
  headingId?: string;
  badge?: string;
  subtitle?: string;
  tags?: string[];
  ctaHref?: string;
  ctaLabel?: string;
}
const { title, headingId, badge, subtitle, tags = [], ctaHref, ctaLabel } = Astro.props;
---

<div class="showcase">
  <div class="showcase__content">
    {badge && <span class="showcase__badge">{badge}</span>}
    <h2 class="showcase__title" id={headingId}>{title}</h2>
    {subtitle && <p class="showcase__subtitle">{subtitle}</p>}
    <slot name="body" />
    {tags.length > 0 && (
      <div class="showcase__tags">
        {tags.map((t) => <span class="showcase__tag">{t}</span>)}
      </div>
    )}
    {ctaHref && (
      <a href={ctaHref} class="btn btn--primary btn--lg">{ctaLabel}</a>
    )}
  </div>
  <div class="showcase__image">
    <slot name="media" />
  </div>
</div>
