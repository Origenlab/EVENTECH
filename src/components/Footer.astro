---
/**
 * ─── EVENTECH Footer Component ───
 * Site footer with navigation columns, contact info, and copyright.
 */
import { footerNav } from "@data/navigation";
import { SITE, LOCATIONS } from "@data/site";

const year = new Date().getFullYear();

const columnTitles: Record<string, string> = {
  servicios: "Servicios",
  empresa: "Empresa",
};
---

<footer class="footer section section--dark" role="contentinfo">
  <div class="container">
    <div class="footer__grid">
      <!-- Brand Column -->
      <div class="footer__brand">
        <a href="/" class="footer__brand-name">{SITE.name}</a>
        <p class="footer__tagline">{SITE.tagline}</p>

        <div class="footer__contact">
          <a href={`mailto:${SITE.contact.email}`} class="footer__contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            {SITE.contact.email}
          </a>
          <a href={`tel:${SITE.contact.phoneRaw}`} class="footer__contact-item footer__phone" aria-label={`Llamar al ${SITE.contact.phone}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {SITE.contact.phone}
          </a>
          <a
            href={`https://wa.me/${SITE.contact.whatsapp}?text=Hola, me interesa cotizar equipo para mi evento`}
            class="footer__contact-item footer__whatsapp"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
        </div>

        <!-- Social Links -->
        <div class="footer__social">
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Nav Columns -->
      {Object.entries(footerNav).map(([key, items]) => (
        <div class="footer__col">
          <h2 class="footer__nav-title">{columnTitles[key] ?? key}</h2>
          <ul class="footer__nav-list" role="list">
            {items.map((item) => (
              <li>
                <a href={item.href} class="footer__link">{item.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Locations Section -->
    <div class="footer__locations">
      <h2 class="footer__locations-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        Nuestras Ubicaciones
      </h2>
      <div class="footer__locations-grid">
        {LOCATIONS.map((location) => (
          <article class="location-card">
            <div class="location-card__header">
              <span class="location-card__zone">{location.zone}</span>
              {location.rating > 0 && (
                <div class="location-card__rating">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="#fbbf24" stroke="#fbbf24" stroke-width="1">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                  <span>{location.rating}</span>
                </div>
              )}
            </div>
            <h3 class="location-card__name">{location.name}</h3>
            <p class="location-card__building">{location.building}</p>
            <address class="location-card__address">
              {location.address}<br />
              {location.colony}<br />
              {location.city}
            </address>
            <div class="location-card__footer">
              <a href={`tel:${location.phone.replace(/\s/g, '')}`} class="location-card__phone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                {location.phone}
              </a>
              <a href={location.mapUrl} class="location-card__map" target="_blank" rel="noopener noreferrer">
                Ver mapa
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p>&copy; {year} {SITE.organization.name}. Todos los derechos reservados.</p>
      <p class="footer__address">{SITE.contact.address}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark, #1a1a2e);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: var(--space-2xl);
  }

  .footer__brand-name {
    display: inline-block;
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-on-dark, #fff);
    text-decoration: none;
    margin-block-end: var(--space-sm);
  }

  .footer__brand-name:hover {
    color: var(--color-accent, #00d4aa);
  }

  .footer__tagline {
    color: var(--color-text-light);
    margin-block-end: var(--space-lg);
    font-size: var(--text-sm);
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-block-end: var(--space-lg);
  }

  .footer__contact-item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-light);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .footer__contact-item:hover {
    color: var(--color-text-on-dark, #fff);
  }

  .footer__phone {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-on-dark, #fff);
  }

  .footer__whatsapp {
    color: #25d366;
  }

  .footer__whatsapp:hover {
    color: #128c7e;
  }

  .footer__social {
    display: flex;
    gap: var(--space-md);
  }

  .footer__social a {
    color: var(--color-text-light);
  }

  .footer__social a:hover {
    color: var(--color-accent, #00d4aa);
  }

  .footer__nav-title {
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-on-dark, #fff);
    margin-block-end: var(--space-md);
  }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .footer__link {
    color: var(--color-text-light);
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .footer__link:hover {
    color: var(--color-text-on-dark, #fff);
  }

  .footer__bottom {
    margin-block-start: var(--space-3xl);
    padding-block-start: var(--space-lg);
    border-block-start: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  .footer__address {
    font-size: var(--text-xs);
    color: var(--color-text-light);
  }

  /* ═══════════════════════════════════════════════════════════════════════
     LOCATIONS SECTION
     ═══════════════════════════════════════════════════════════════════════ */
  .footer__locations {
    margin-block-start: var(--space-3xl);
    padding-block-start: var(--space-2xl);
    border-block-start: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer__locations-title {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text-on-dark, #fff);
    margin-block-end: var(--space-xl);
  }

  .footer__locations-title svg {
    color: var(--color-accent, #00d4aa);
  }

  .footer__locations-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
  }

  /* Location Card */
  .location-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-md);
    padding: var(--space-lg);
  }

  .location-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--color-accent, #00d4aa);
  }

  .location-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-block-end: var(--space-sm);
  }

  .location-card__zone {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent, #00d4aa);
  }

  .location-card__rating {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    color: #fbbf24;
  }

  .location-card__name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-on-dark, #fff);
    margin-block-end: var(--space-xs);
  }

  .location-card__building {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    margin-block-end: var(--space-sm);
    font-weight: 500;
  }

  .location-card__address {
    font-size: var(--text-xs);
    font-style: normal;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-block-end: var(--space-md);
  }

  .location-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block-start: var(--space-sm);
    border-block-start: 1px solid rgba(255, 255, 255, 0.08);
  }

  .location-card__phone {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: var(--text-xs);
    color: var(--color-text-light);
    text-decoration: none;
  }

  .location-card__phone:hover {
    color: var(--color-text-on-dark, #fff);
  }

  .location-card__map {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent, #00d4aa);
    text-decoration: none;
  }

  .location-card__map:hover {
    color: #00ffcc;
  }

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }

    .footer__locations-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer__locations-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .location-card {
      padding: var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }

    .footer__locations-title {
      font-size: var(--text-base);
    }
  }
</style>
