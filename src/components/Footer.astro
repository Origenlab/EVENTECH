---
/**
 * ─── EVENTECH Footer (rediseño 2026 — homologado al home premium) ───
 * Navy + gold + serif Cormorant. Banda pre-footer de servicios + columnas de
 * navegación ampliadas (interlinking profundo), ubicaciones y barra legal.
 */
import { footerNav } from "@data/navigation";
import { SITE, LOCATIONS } from "@data/site";

const year = new Date().getFullYear();

// Menú pre-footer (banda full-width, homologada al menú del hero `hm-menu`).
// Enlaces distintos al del hero: las 8 categorías de servicio (páginas hub).
const preFooterMenu = footerNav.servicios;

// Columnas de navegación del footer — enlaces profundos para mejor interlinking
// (subcategorías de servicio, eventos, cobertura y empresa). Todas existen.
const footerColumns: { title: string; links: { label: string; href: string; external?: boolean }[] }[] = [
  {
    title: "Servicios",
    links: [
      { label: "Sillas y mesas", href: "/servicios/mobiliario/" },
      { label: "Pantallas LED", href: "/servicios/audiovisual/pantallas-led/" },
      { label: "Sonido y DJ", href: "/servicios/audiovisual/sonido/" },
      { label: "Carpas árabes", href: "/servicios/carpas/carpas-arabes/" },
      { label: "Iluminación decorativa", href: "/servicios/iluminacion/decorativa/" },
      { label: "Pistas LED", href: "/servicios/pistas-baile/pistas-led/" },
      { label: "Mantelería", href: "/servicios/accesorios/manteleria-textiles/" },
    ],
  },
  {
    title: "Eventos",
    links: [
      { label: "Bodas", href: "/eventos/bodas/" },
      { label: "XV Años", href: "/eventos/xv-anos/" },
      { label: "Corporativos", href: "/eventos/corporativos/" },
      { label: "Fiestas infantiles", href: "/eventos/fiestas-infantiles/" },
    ],
  },
  {
    title: "Salones",
    links: [
      { label: "Directorio de salones", href: "/directorio/" },
      { label: "Salones en CDMX", href: "/directorio/cdmx/" },
      { label: "Salones en Edomex", href: "/directorio/estado-mexico/" },
      { label: "Cobertura CDMX", href: "/zonas/cdmx/" },
    ],
  },
  {
    title: "Empresa",
    links: [
      { label: "Nosotros", href: "/nosotros/" },
      { label: "Blog", href: "/blog/" },
      { label: "Cotizar", href: "/cotizar/" },
    ],
  },
];

const waHref = `https://wa.me/${SITE.contact.whatsapp}?text=${encodeURIComponent("Hola, me interesa cotizar equipo para mi evento")}`;
---

<!-- Menú pre-footer: banda de categorías de servicio (interlinking site-wide) -->
<nav class="prefooter-menu" aria-label="Categorías de servicio">
  <ul class="prefooter-menu__grid">
    {preFooterMenu.map((item) => (
      <li>
        <a class="prefooter-menu__item" href={item.href}>{item.label}</a>
      </li>
    ))}
  </ul>
</nav>

<footer class="ft" role="contentinfo">
  <div class="ft__wrap">
    <!-- Top: Brand + Nav columns -->
    <div class="ft__top">
      <!-- Brand -->
      <div class="ft__brand">
        <a href="/" class="ft__logo">{SITE.name}</a>
        <p class="ft__tagline">{SITE.tagline}</p>

        <div class="ft__contact">
          <a href={`tel:${SITE.contact.phoneRaw}`} class="ft__phone" aria-label={`Llamar al ${SITE.contact.phone}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {SITE.contact.phone}
          </a>
          <a href={`mailto:${SITE.contact.email}`} class="ft__contact-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            {SITE.contact.email}
          </a>
          <p class="ft__hours">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            Lun–Vie 9:00–18:00 · Sáb 9:00–14:00
          </p>
        </div>

        <div class="ft__cta">
          <a href="/cotizar/" class="ft__btn ft__btn--gold">Cotizar evento</a>
          <a href={waHref} class="ft__btn ft__btn--wa" target="_blank" rel="noopener noreferrer">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>

        <div class="ft__social">
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <!-- Nav columns -->
      <div class="ft__cols">
        {footerColumns.map((col) => (
          <div class="ft__col">
            <h2 class="ft__col-title">{col.title}</h2>
            <ul class="ft__list" role="list">
              {col.links.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="ft__link"
                    {...(item.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <!-- Locations -->
    <div class="ft__locations">
      <h2 class="ft__locations-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Nuestras ubicaciones
      </h2>
      <div class="ft__locations-grid">
        {LOCATIONS.map((location) => (
          <article class="ft-loc">
            <div class="ft-loc__head">
              <span class="ft-loc__zone">{location.zone}</span>
              {location.rating > 0 && (
                <span class="ft-loc__rating">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {location.rating}
                </span>
              )}
            </div>
            <h3 class="ft-loc__name">{location.name}</h3>
            <p class="ft-loc__building">{location.building}</p>
            <address class="ft-loc__address">
              {location.address}<br />
              {location.colony}<br />
              {location.city}
            </address>
            <div class="ft-loc__foot">
              <a href={`tel:${location.phone.replace(/\s/g, '')}`} class="ft-loc__phone">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {location.phone}
              </a>
              <a href={location.mapUrl} class="ft-loc__map" target="_blank" rel="noopener noreferrer">
                Ver mapa
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="ft__bottom">
      <p class="ft__copy">&copy; {year} {SITE.organization.name}. Todos los derechos reservados.</p>
      <nav class="ft__mini" aria-label="Enlaces rápidos">
        <a href="/">Inicio</a>
        <a href="/servicios/">Servicios</a>
        <a href="/directorio/">Salones</a>
        <a href="/blog/">Blog</a>
        <a href="/cotizar/">Cotizar</a>
      </nav>
    </div>
  </div>
</footer>

<style>
  /* v2026.1 — footer premium navy+gold (homologado) */
  /* ═══════════════════════════════════════════════════════════════════════
     PRE-FOOTER MENU — banda homologada al menú del hero (hm-menu)
     ═══════════════════════════════════════════════════════════════════════ */
  .prefooter-menu {
    background: var(--color-ivory, #faf8f4);
    border-block: 1px solid var(--color-hairline, #e7e1d6);
  }
  .prefooter-menu__grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    width: 100%;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .prefooter-menu__grid li {
    border-left: 1px solid var(--color-hairline, #e7e1d6);
  }
  .prefooter-menu__grid li:first-child {
    border-left: 0;
  }
  .prefooter-menu__item {
    display: block;
    padding: 20px 12px;
    text-align: center;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--color-primary, #1a1a2e);
    border-top: 2px solid transparent;
    text-decoration: none;
  }
  .prefooter-menu__item:hover {
    background: var(--color-ivory-alt, #f3efe7);
    color: var(--color-gold-deep, #a9883a);
    border-top-color: var(--color-gold, #c2a24a);
  }
  @media (max-width: 1024px) {
    .prefooter-menu__grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .prefooter-menu__grid li:nth-child(4n + 1) {
      border-left: 0;
    }
    .prefooter-menu__grid li:nth-child(n + 5) {
      border-top: 1px solid var(--color-hairline, #e7e1d6);
    }
  }
  @media (max-width: 560px) {
    .prefooter-menu__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .prefooter-menu__grid li:nth-child(2n + 1) {
      border-left: 0;
    }
    .prefooter-menu__grid li:nth-child(n + 3) {
      border-top: 1px solid var(--color-hairline, #e7e1d6);
    }
    .prefooter-menu__item {
      padding: 16px 10px;
      letter-spacing: 0.08em;
    }
  }

  /* ═══════════════════════════════════════════════════════════════════════
     FOOTER — navy + gold + serif (homologado al home)
     ═══════════════════════════════════════════════════════════════════════ */
  .ft {
    --ft-gold: var(--color-gold, #c2a24a);
    --ft-gold-deep: var(--color-gold-deep, #a9883a);
    --ft-muted: rgba(255, 255, 255, 0.6);
    --ft-line: rgba(255, 255, 255, 0.1);
    background: var(--color-primary, #1a1a2e);
    color: #fff;
    border-top: 3px solid var(--ft-gold);
  }
  .ft__wrap {
    width: 100%;
    padding-inline: var(--container-padding, clamp(1rem, 4%, 4.5rem));
    padding-block: clamp(48px, 6vw, 80px) 0;
  }

  /* Top grid */
  .ft__top {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 2.5fr);
    gap: clamp(32px, 5vw, 72px);
    padding-bottom: clamp(36px, 4vw, 56px);
  }

  /* Brand */
  .ft__logo {
    display: inline-block;
    font-family: var(--font-display, "Cormorant Garamond", serif);
    font-weight: 600;
    font-size: 2rem;
    line-height: 1;
    color: #fff;
    text-decoration: none;
  }
  .ft__logo:hover {
    color: var(--ft-gold);
  }
  .ft__tagline {
    margin: 0.7rem 0 1.4rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--ft-muted);
    max-width: 34ch;
  }
  .ft__contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 1.4rem;
  }
  .ft__phone {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-display, serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
  }
  .ft__phone svg {
    color: var(--ft-gold);
  }
  .ft__phone:hover {
    color: var(--ft-gold);
  }
  .ft__contact-item,
  .ft__hours {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin: 0;
    font-size: 0.9rem;
    color: var(--ft-muted);
    text-decoration: none;
  }
  .ft__contact-item svg,
  .ft__hours svg {
    color: var(--ft-gold);
    flex-shrink: 0;
  }
  .ft__contact-item:hover {
    color: #fff;
  }

  /* CTA buttons */
  .ft__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 1.5rem;
  }
  .ft__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    font-size: 0.9rem;
    font-weight: 700;
    border-radius: 4px;
    text-decoration: none;
  }
  .ft__btn--gold {
    background: var(--ft-gold);
    color: #1c1607;
  }
  .ft__btn--gold:hover {
    background: #fff;
  }
  .ft__btn--wa {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.28);
    color: #fff;
  }
  .ft__btn--wa svg {
    color: #25d366;
  }
  .ft__btn--wa:hover {
    border-color: var(--ft-gold);
    color: var(--ft-gold);
  }

  .ft__social {
    display: flex;
    gap: 12px;
  }
  .ft__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: var(--ft-muted);
  }
  .ft__social a:hover {
    border-color: var(--ft-gold);
    color: var(--ft-gold);
  }

  /* Nav columns */
  .ft__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(20px, 2.5vw, 40px);
  }
  .ft__col-title {
    font-family: var(--font-display, serif);
    font-weight: 600;
    font-size: 1.3rem;
    color: #fff;
    margin: 0 0 16px;
    padding-bottom: 10px;
    position: relative;
  }
  .ft__col-title::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 34px;
    height: 2px;
    background: var(--ft-gold);
  }
  .ft__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .ft__link {
    font-size: 0.9rem;
    color: var(--ft-muted);
    text-decoration: none;
  }
  .ft__link:hover {
    color: var(--ft-gold);
  }

  /* Locations */
  .ft__locations {
    padding-block: clamp(36px, 4vw, 52px);
    border-top: 1px solid var(--ft-line);
  }
  .ft__locations-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display, serif);
    font-weight: 600;
    font-size: 1.5rem;
    color: #fff;
    margin: 0 0 clamp(20px, 2.5vw, 32px);
  }
  .ft__locations-title svg {
    color: var(--ft-gold);
  }
  .ft__locations-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.5vw, 22px);
  }
  .ft-loc {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 8px;
    padding: 20px;
  }
  .ft-loc:hover {
    background: rgba(255, 255, 255, 0.055);
    border-color: rgba(194, 162, 74, 0.55);
  }
  .ft-loc__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .ft-loc__zone {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ft-gold);
  }
  .ft-loc__rating {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ft-gold);
  }
  .ft-loc__name {
    font-family: var(--font-display, serif);
    font-weight: 600;
    font-size: 1.25rem;
    color: #fff;
    margin: 0 0 3px;
  }
  .ft-loc__building {
    font-size: 0.85rem;
    color: var(--ft-muted);
    margin: 0 0 10px;
  }
  .ft-loc__address {
    font-size: 0.8rem;
    font-style: normal;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    margin: 0 0 14px;
  }
  .ft-loc__foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.09);
  }
  .ft-loc__phone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.8rem;
    color: var(--ft-muted);
    text-decoration: none;
  }
  .ft-loc__phone:hover {
    color: #fff;
  }
  .ft-loc__map {
