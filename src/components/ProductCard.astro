---
/**
 * ProductCard — Ficha de producto para variantes/modelos.
 * Imagen 4:3, nombre, precio destacado, extracto, tags de uso, botón CTA.
 */
interface Props {
  name: string;
  price: string;
  excerpt: string;
  href: string;
  image: string;
  tags: string[];
  badge?: string;
  /** Alt descriptivo de la imagen. Si se omite, cae al `name` del producto. */
  imageAlt?: string;
}

const { name, price, excerpt, href, image, tags, badge, imageAlt } = Astro.props;
---

<article class="prod-card">
  <a href={href} class="prod-card__img-link">
    <img src={image} alt={imageAlt ?? name} class="prod-card__img" loading="lazy" decoding="async" width="640" height="480" />
    {badge && <span class="prod-card__badge">{badge}</span>}
  </a>
  <div class="prod-card__body">
    <div class="prod-card__header">
      <h3 class="prod-card__name">{name}</h3>
      <span class="prod-card__price">{price}</span>
    </div>
    <p class="prod-card__excerpt">{excerpt}</p>
    <div class="prod-card__tags">
      {tags.map((tag) => (
        <span class="prod-card__tag">{tag}</span>
      ))}
    </div>
    <a href={href} class="prod-card__cta">
      Cotizar {name}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>

<style>
  .prod-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    display: flex;
    flex-direction: column;
    
  }

  .prod-card:hover {
    box-shadow: var(--shadow-lg);
    
  }

  /* Image */
  .prod-card__img-link {
    display: block;
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .prod-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    
  }

  .prod-card:hover .prod-card__img {
    
  }

  .prod-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    padding: 0.3rem 0.75rem;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: 6px;
  }

  /* Body */
  .prod-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.75rem;
  }

  .prod-card__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.75rem;
  }

  .prod-card__name {
    font-size: var(--text-lg);
    font-weight: 800;
    color: var(--color-heading);
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0;
  }

  .prod-card__price {
    font-size: var(--text-base);
    font-weight: 800;
    color: var(--color-accent);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .prod-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.65;
    margin: 0;
  }

  /* Tags */
  .prod-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: auto;
  }

  .prod-card__tag {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--color-text);
    padding: 0.25rem 0.625rem;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
  }

  /* CTA */
  .prod-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem;
    margin-top: 0.5rem;
    background: var(--color-accent);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background 0.2s ease;
  }

  .prod-card__cta:hover {
    background: var(--color-accent-hover);
  }
</style>
