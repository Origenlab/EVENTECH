---
/**
 * ─── Card Component ───
 * Tarjeta de servicio/evento para homepage y listados.
 * Diseño: imagen 4:3 con hover zoom, extracto, botón full-width.
 */

type Props = {
  name: string;
  excerpt: string;
  cta: string;
  href: string;
  icon?: string;
  image?: string;
  badge?: string;
};

const { name, excerpt, cta, href, image } = Astro.props;
---

<article class="card">
  <a href={href} class="card__image-link" tabindex="-1" aria-hidden="true">
    {image ? (
      <img class="card__img" src={image} alt={name} loading="lazy" width="400" height="300" />
    ) : (
      <div class="card__placeholder">
        <span class="card__placeholder-text">{name}</span>
      </div>
    )}
  </a>

  <div class="card__content">
    <h3 class="card__title">{name}</h3>
    <p class="card__excerpt">{excerpt}</p>
  </div>

  <a href={href} class="card__btn">
    {cta}
    <svg class="card__btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14"/>
      <path d="M12 5l7 7-7 7"/>
    </svg>
  </a>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    
  }

  .card:hover {
    box-shadow: var(--shadow-md);
    
  }

  /* ── Image ── */
  .card__image-link {
    display: block;
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    overflow: hidden;
  }

  .card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    
  }

  .card:hover .card__img {
    
  }

  .card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }

  .card__placeholder-text {
    font-size: var(--text-lg);
    font-weight: 700;
    color: rgba(255, 255, 255, 0.3);
    text-align: center;
  }

  /* ── Content ── */
  .card__content {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    flex-grow: 1;
  }

  .card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-primary);
    margin-block-end: var(--space-sm);
    letter-spacing: -0.01em;
  }

  .card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-text-light);
    line-height: 1.7;
  }

  /* ── Button ── */
  .card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: 0.875rem 1.5rem;
    background: var(--color-accent);
    color: white;
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease;
    margin-top: auto;
  }

  .card__btn:hover {
    background: var(--color-accent-hover);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .card__content {
      padding: var(--space-md);
    }

    .card__title {
      font-size: var(--text-base);
    }

    .card__excerpt {
      font-size: var(--text-xs);
    }

    .card__btn {
      padding: 0.75rem 1rem;
      font-size: var(--text-xs);
    }
  }
</style>
