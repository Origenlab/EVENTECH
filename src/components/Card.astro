---
/**
 * ─── Card Component ───
 * Componente de tarjeta para servicios y eventos.
 * Diseño aprobado: imagen 4:3, extracto, botón full-width.
 */

type Props = {
  name: string;
  excerpt: string;
  cta: string;
  href: string;
  icon?: string;
};

const { name, excerpt, cta, href, icon } = Astro.props;
---

<article class="card">
  <div class="card__image">
    <div class="card__placeholder">
      {icon === "phone" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      )}
      {icon === "checkmark" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      )}
      {icon === "chair" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M19 13V5a2 2 0 00-2-2H7a2 2 0 00-2 2v8"/>
          <path d="M3 13h18v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6z"/>
          <path d="M5 21v-2"/>
          <path d="M19 21v-2"/>
        </svg>
      )}
      {icon === "speaker" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
          <circle cx="12" cy="14" r="4"/>
          <line x1="12" y1="6" x2="12.01" y2="6"/>
        </svg>
      )}
      {icon === "tent" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L2 22h20L12 2z"/>
          <path d="M12 22V12"/>
        </svg>
      )}
      {icon === "lightbulb" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 18h6"/>
          <path d="M10 22h4"/>
          <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0018 8 6 6 0 006 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 018.91 14"/>
        </svg>
      )}
      {icon === "music" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="5.5" cy="17.5" r="2.5"/>
          <circle cx="17.5" cy="15.5" r="2.5"/>
          <path d="M8 17V5l12-2v12"/>
        </svg>
      )}
      {icon === "package" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M16.5 9.4l-9-5.19"/>
          <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
          <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
          <line x1="12" y1="22.08" x2="12" y2="12"/>
        </svg>
      )}
      {icon === "balloon" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2C8.13 2 5 5.13 5 9c0 4.17 4.42 9.92 6.24 12.11.4.48 1.12.48 1.52 0C14.58 18.92 19 13.17 19 9c0-3.87-3.13-7-7-7z"/>
          <path d="M12 21v1"/>
          <path d="M10 22h4"/>
          <ellipse cx="12" cy="9" rx="3" ry="4"/>
        </svg>
      )}
      {icon === "utensils" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 002-2V2"/>
          <path d="M7 2v20"/>
          <path d="M21 15V2a5 5 0 00-5 5v6c0 1.1.9 2 2 2h3zm0 0v7"/>
        </svg>
      )}
      {icon === "heart" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
        </svg>
      )}
      {icon === "crown" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"/>
          <path d="M3 20h18"/>
        </svg>
      )}
      {icon === "briefcase" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
          <path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/>
        </svg>
      )}
      {icon === "users" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/>
          <path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
      )}
      {icon === "cake" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M20 21v-8a2 2 0 00-2-2H6a2 2 0 00-2 2v8"/>
          <path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/>
          <path d="M2 21h20"/>
          <path d="M7 8v3"/>
          <path d="M12 8v3"/>
          <path d="M17 8v3"/>
          <path d="M7 4h.01"/>
          <path d="M12 4h.01"/>
          <path d="M17 4h.01"/>
        </svg>
      )}
      {icon === "graduation" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
          <path d="M6 12v5c0 2 2 3 6 3s6-1 6-3v-5"/>
        </svg>
      )}
      {icon === "baby" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M9 12h.01"/>
          <path d="M15 12h.01"/>
          <path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/>
          <path d="M19 6.3a9 9 0 01.8 3.7 9 9 0 01-18 0c0-1.3.3-2.6.8-3.7"/>
          <path d="M12 2C8 2 6.5 4 6.5 4s1 1 5.5 1 5.5-1 5.5-1S16 2 12 2z"/>
        </svg>
      )}
      {icon === "church" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 21V8l-6-6-6 6v13"/>
          <path d="M2 21h20"/>
          <path d="M12 2v4"/>
          <path d="M10 4h4"/>
          <rect x="9" y="13" width="6" height="8" rx="1"/>
        </svg>
      )}
      {icon === "clock" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      )}
      {icon === "layers" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
      )}
      {icon === "shield" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      )}
      {icon === "creditcard" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
          <line x1="1" y1="10" x2="23" y2="10"/>
        </svg>
      )}
      {icon === "mappin" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
      )}
      {icon === "team" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 00-3-3.87"/>
          <path d="M16 3.13a4 4 0 010 7.75"/>
        </svg>
      )}
      {icon === "truck" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="1" y="3" width="15" height="13"/>
          <path d="M16 8h4l3 3v5h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      )}
      {icon === "award" && (
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="8" r="7"/>
          <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
        </svg>
      )}
    </div>
  </div>

  <div class="card__content">
    <h3 class="card__title">{name}</h3>
    <p class="card__excerpt">{excerpt}</p>
  </div>

  <a href={href} class="card__btn">
    {cta}
    <svg class="card__btn-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M5 12h14"/>
      <path d="M12 5l7 7-7 7"/>
    </svg>
  </a>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
  }

  /* ── Image / Placeholder ── */
  .card__image {
    position: relative;
    aspect-ratio: 4 / 3;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    overflow: hidden;
  }

  .card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
  }

  /* ── Content ── */
  .card__content {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    flex-grow: 1;
  }

  .card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-primary);
    margin-block-end: var(--space-sm);
  }

  .card__excerpt {
    font-size: var(--text-base);
    color: var(--color-text-light);
    line-height: 1.7;
  }

  /* ── Button ── */
  .card__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: 100%;
    padding: 1rem 1.5rem;
    background: var(--gradient-accent);
    color: white;
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
    transition: all var(--transition-fast);
    margin-top: auto;
  }

  .card__btn:hover {
    background: var(--color-accent-hover);
  }

  .card__btn-icon {
    transition: transform var(--transition-fast);
  }

  .card__btn:hover .card__btn-icon {
    transform: translateX(4px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .card__content {
      padding: var(--space-lg);
    }

    .card__title {
      font-size: var(--text-lg);
    }

    .card__excerpt {
      font-size: var(--text-sm);
    }

    .card__btn {
      padding: 0.875rem 1.25rem;
      font-size: var(--text-sm);
    }
  }
</style>
